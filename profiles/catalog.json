{
  "schema": "sevenos.profiles.catalog.v1",
  "model": "layered-autonomous-profiles-architecture",
  "golden_rule": "No profile dependency, only profile collaboration.",
  "default_profile": "equinox",
  "profile_model": {
    "name": "Layered Autonomous Profiles Architecture",
    "short_name": "LAPA",
    "contract": "Each visible profile is a self-contained mini OS with Kernel, Runtime, Experience and Intelligence layers. SevenOS exposes seven specialized mini OSes; retired aliases may redirect to a merged profile for compatibility.",
    "composition": "Profiles can collaborate through declared capabilities, but no profile may silently load another profile's full stack.",
    "equinox_role": "Equinox is the balanced general profile. It is not a hidden super-profile and it must not make another profile dominant by default."
  },
  "profile_naming": {
    "equinox": "Equinox Balance",
    "baobab": "Baobab Cultural OS",
    "forge": "Forge DevOps",
    "shield": "Shield Cybersecurity",
    "studio": "Studio Creator",
    "windows": "Windows Bridge",
    "pulse": "Pulse Gaming"
  },
  "state_files": {
    "active_env": "~/.config/sevenos/profile.env",
    "active_json": "~/.config/sevenos/profile.json",
    "runtime_json": "~/.config/sevenos/runtime.json",
    "runtime_env": "~/.config/sevenos/runtime.env",
    "isolation_json": "~/.config/sevenos/profile-isolation.json",
    "active_packages": "~/.config/sevenos/active-packages.txt",
    "service_policy": "~/.config/sevenos/profile-services.json"
  },
  "core_package_files": [
    "scripts/packages-base.txt"
  ],
  "runtime_optional_package_files": [
    "scripts/packages-runtime-optional.txt"
  ],
  "isolation_policy": {
    "package_store": "pacman packages are installed globally",
    "activation": "SevenOS activates packages per profile through runtime state, service policy, app shims and systemd slices",
    "rule": "Installed does not mean active. No profile dependency, only profile collaboration."
  },
  "profiles": {
