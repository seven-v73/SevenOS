      "independence": {
        "standalone": true,
        "does_not_require": [
          "forge",
          "shield",
          "studio",
          "windows",
          "pulse",
          "baobab"
        ],
        "composition_policy": "may borrow light capabilities only after explicit user action or SevenAI confirmation"
      },
      "resource_intent": {
        "cpu": "balanced-arbitration",
        "ram": "shared-general-pool",
        "gpu": "foreground-fairness",
        "io": "responsive",
