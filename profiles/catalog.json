{
  "schema": "sevenos.profiles.catalog.v1",
  "model": "layered-autonomous-profiles-architecture",
  "golden_rule": "No profile dependency, only profile collaboration.",
  "default_profile": "equinox",
  "profile_model": {
    "name": "Layered Autonomous Profiles Architecture",
    "short_name": "LAPA",
    "contract": "Each profile is a self-contained mini OS with Kernel, Runtime, Experience and Intelligence layers.",
    "composition": "Profiles can collaborate through declared capabilities, but no profile may silently load another profile's full stack.",
    "equinox_role": "Equinox is the balanced general profile. It is not a hidden super-profile and it must not make another profile dominant by default."
  },
  "profile_naming": {
    "equinox": "Equinox Balance",
    "baobab": "Baobab Culture",
    "forge": "Forge Developer",
    "shield": "Shield Cybersecurity",
    "studio": "Studio Creator",
    "windows": "Windows Bridge",
    "horizon": "Horizon Cloud",
    "pulse": "Pulse Gaming"
  },
  "state_files": {
    "active_env": "~/.config/sevenos/profile.env",
    "active_json": "~/.config/sevenos/profile.json",
    "runtime_json": "~/.config/sevenos/runtime.json",
    "runtime_env": "~/.config/sevenos/runtime.env",
    "isolation_json": "~/.config/sevenos/profile-isolation.json",
    "active_packages": "~/.config/sevenos/active-packages.txt",
    "service_policy": "~/.config/sevenos/profile-services.json"
  },
  "core_package_files": [
    "scripts/packages-base.txt"
  ],
  "runtime_optional_package_files": [
    "scripts/packages-runtime-optional.txt"
  ],
  "isolation_policy": {
    "package_store": "pacman packages are installed globally",
    "activation": "SevenOS activates packages per profile through runtime state, service policy, app shims and systemd slices",
    "rule": "Installed does not mean active. No profile dependency, only profile collaboration."
  },
  "profiles": {
    "equinox": {
      "title": "Equinox Balance",
      "role": "Balanced general mini OS",
      "target": "base",
      "domain": "balanced general computing",
      "purpose": "A neutral daily SevenOS environment for work, media, browsing, files and light creation without making any specialized profile dominant.",
      "mini_os": true,
      "layers": {
        "kernel": [
          "balanced CPU scheduling",
          "moderate power policy",
          "responsive foreground apps"
        ],
        "runtime": [
          "core desktop services",
          "files, settings, terminal and browser readiness",
          "safe common tools"
        ],
        "experience": [
          "neutral SevenOS glass UI",
          "general Waybar and Control Center",
          "broad public-user workflow"
        ],
        "intelligence": [
          "SevenAI general assistant",
          "Seven Doctor baseline checks",
          "capability arbitration without forced stacks"
        ]
      },
      "package_files": [
        "scripts/packages-base.txt"
      ],
      "waybar_modules": [
        "profile",
        "spotlight",
        "media",
        "wifi",
        "bluetooth",
        "audio",
        "battery",
        "ai"
      ],
      "runtime_slice": "seven-equinox.slice",
      "capabilities": [
        "balanced-ui",
        "core-tools",
        "basic-security",
        "light-dev",
        "light-creative",
        "light-cloud",
        "light-performance"
      ],
      "anti_nuisance": [
        "no heavy dev stack by default",
        "no security scans by default",
        "no cloud daemons by default",
        "no gaming overlays by default",
        "no Windows VM by default"
      ],
      "independence": {
        "standalone": true,
        "does_not_require": [
          "forge",
          "shield",
          "studio",
          "windows",
          "horizon",
          "pulse",
          "baobab"
        ],
        "composition_policy": "may borrow light capabilities only after explicit user action or SevenAI confirmation"
      },
      "resource_intent": {
        "cpu": "balanced-arbitration",
        "ram": "shared-general-pool",
        "gpu": "foreground-fairness",
        "io": "responsive",
        "network": "normal-qos"
      },
      "priority": 150,
      "center_command": "seven-profile-center-native",
      "profile_surfaces": {
        "center": "seven-profile-center-native",
        "workspace": "seven profile open equinox",
        "apps": "seven profile apps equinox",
        "runtime": "seven runtime plan equinox"
      }
