      "mini_os": true,
      "layers": {
        "kernel": [
          "balanced CPU scheduling",
          "moderate power policy",
          "responsive foreground apps"
        ],
        "runtime": [
          "core desktop services",
          "files, settings, terminal and browser readiness",
          "safe common tools"
        ],
        "experience": [
          "neutral SevenOS glass UI",
          "general Waybar and Control Center",
          "broad public-user workflow"
        ],
        "intelligence": [
          "SevenAI general assistant",
          "Seven Doctor baseline checks",
          "capability arbitration without forced stacks"
