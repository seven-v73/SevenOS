[Unit]
Description=SevenOS Core runtime daemon
PartOf=sevenos-session.target
After=graphical-session.target

[Service]
Type=simple
Environment=SEVENOS_ROOT=%h/Code/OS/SevenOS
PassEnvironment=WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE
ExecStart=%h/.local/bin/seven-daemon serve
Restart=on-failure
RestartSec=3

[Install]
WantedBy=sevenos-session.target
