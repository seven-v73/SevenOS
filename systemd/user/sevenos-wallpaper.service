[Unit]
Description=SevenOS wallpaper refresh
PartOf=sevenos-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/env sh -lc 'if [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.env" ]; then . "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.env"; fi; exec seven-wallpaper serve'
Restart=on-failure
RestartSec=2

[Install]
WantedBy=sevenos-session.target
