[Unit]
Description=SevenOS semantic context observer
PartOf=sevenos-session.target
After=seven-daemon.service graphical-session.target

[Service]
Type=simple
Environment=SEVENOS_ROOT=%h/Code/OS/SevenOS
Environment=SEVENOS_CONTEXT_INTERVAL=60
ExecStart=%h/.local/bin/seven-daemon observe-loop
Restart=on-failure
RestartSec=5

[Install]
WantedBy=sevenos-session.target
