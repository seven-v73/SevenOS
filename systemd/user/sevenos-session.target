[Unit]
Description=SevenOS desktop session services
Documentation=https://github.com/seven-v73/SevenOS
Wants=seven-daemon.service seven-context-observer.service sevenos-waybar.service sevenos-notifications.service sevenos-wallpaper.service sevenos-idle.service sevenos-hyprsunset.service sevenos-hypr-lua-events.service sevenos-polkit-agent.service
After=graphical-session.target

[Install]
WantedBy=default.target
