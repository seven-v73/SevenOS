@theme "sevenos.rasi"

window {
  location: northeast;
  anchor: northeast;
  x-offset: -14px;
  y-offset: 46px;
  width: 360px;
  border: 1px;
  border-color: @gold-dim;
  border-radius: 24px;
  background-color: @surface-1;
}

mainbox {
  padding: 16px;
  spacing: 11px;
  background-color: @surface-1;
  children: [ message, inputbar, listview ];
}

message {
  padding: 0px 0px 11px 0px;
  border: 0px 0px 3px 0px;
  border-color: @gold;
  background-color: transparent;
}

textbox {
  text-color: @gold-bright;
  font: "Cormorant Garamond Italic 21";
}

inputbar {
  padding: 10px 12px;
  border: 1px;
  border-color: @glass-border-2;
  border-radius: 16px;
  background-color: @surface-2;
  children: [ prompt, textbox-prompt-colon, entry ];
}

prompt {
  text-color: @gold;
  font: "JetBrains Mono Medium 12";
}

entry {
  placeholder: "Search Controls";
  placeholder-color: @text-2;
  text-color: @text-1;
  cursor-color: @gold;
  font: "DM Sans 13";
}

listview {
  lines: 10;
  spacing: 8px;
  fixed-height: true;
  background-color: transparent;
}

element {
  padding: 13px 14px;
  border: 1px;
  border-radius: 16px;
  border-color: @glass-border;
  background-color: @surface-1;
  text-color: @text-1;
}

element selected {
  background-color: @gold-bright;
  border-color: @gold-bright;
  text-color: @ebene;
}

element alternate {
  background-color: @surface-3;
}

element-text {
  text-color: inherit;
  font: "JetBrains Mono Medium 13";
}
