@theme "sevenos.rasi"

window {
  width: 32%;
  border-color: #c4673a;
  background-color: @surface-1;
}

listview {
  lines: 5;
}

entry {
  placeholder: "Seven Power";
}

message {
  background-color: @surface-2;
  border-color: @clay;
}

element selected {
  background-color: @clay;
  border-color: @clay;
  text-color: @ebene;
}
