{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-margin-top": 18,
  "control-center-margin-bottom": 18,
  "control-center-margin-right": 18,
  "control-center-margin-left": 18,
  "notification-window-width": 390,
  "control-center-width": 430,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 160,
  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 0,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": ["title", "dnd", "notifications"],
  "widget-config": {
    "title": {
      "text": "SevenOS",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    }
  }
}
