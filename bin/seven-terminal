#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT/hyprland/kitty" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/../hyprland/kitty" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -d "$candidate/hyprland/kitty" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-terminal: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
KITTY_CONFIG_DIR="$CONFIG_HOME/kitty"

usage() {
  cat <<'EOF'
Usage:
  seven-terminal [profile|classic|dark|light|forge|cyber|focus|admin|windows|menu|status|doctor] [-- command...]

Profiles:
  profile  Default terminal for the active SevenOS mini OS
  classic  SevenOS classic bright terminal
  dark     SevenOS graphite terminal
  light    SevenOS clarity-first light terminal
  forge    development terminal with build/git emphasis
  cyber    network/security terminal with calm SOC contrast
  focus    quiet writing and long-reading terminal
  admin    cautious system-control terminal
  windows  Windows Bridge VM and compatibility terminal
  menu     choose a terminal profile

Examples:
  seven-terminal
  seven-terminal dark
  seven-terminal light
  seven-terminal forge
  seven-terminal profile -- btop
  seven-terminal dark -- btop
EOF
}

active_profile() {
  local profile_env="$CONFIG_HOME/sevenos/profile.env"
  if [[ -n "${SEVENOS_ACTIVE_PROFILE:-}" ]]; then
    printf '%s\n' "$SEVENOS_ACTIVE_PROFILE"
    return 0
  fi
  if [[ -r "$profile_env" ]]; then
    # shellcheck disable=SC1090
    source "$profile_env" >/dev/null 2>&1 || true
    if [[ -n "${SEVENOS_ACTIVE_PROFILE:-}" ]]; then
      printf '%s\n' "$SEVENOS_ACTIVE_PROFILE"
      return 0
    fi
  fi
  printf 'equinox\n'
}

profile_terminal_mode() {
  local profile="${1:-$(active_profile)}"
  case "$profile" in
    forge) printf 'forge' ;;
    shield) printf 'cyber' ;;
    studio) printf 'focus' ;;
    baobab) printf 'focus' ;;
    horizon) printf 'forge' ;;
    pulse) printf 'dark' ;;
    windows) printf 'windows' ;;
    equinox|*) printf 'classic' ;;
  esac
}

terminal_shell() {
  local helper="$ROOT_DIR/bin/seven-terminal-shell"
  if [[ -x "$helper" ]]; then
    printf '%s\n' "$helper"
    return 0
  fi

  helper="$HOME/.local/bin/seven-terminal-shell"
  if [[ -x "$helper" ]]; then
    printf '%s\n' "$helper"
    return 0
  fi

  printf '%s\n' "${SHELL:-/bin/sh}"
}

config_for_profile() {
  case "$1" in
    classic) printf '%s\n' "$KITTY_CONFIG_DIR/classic.conf" ;;
    dark) printf '%s\n' "$KITTY_CONFIG_DIR/dark.conf" ;;
    light) printf '%s\n' "$KITTY_CONFIG_DIR/light.conf" ;;
    forge|cyber|admin|windows) printf '%s\n' "$KITTY_CONFIG_DIR/dark.conf" ;;
    focus) printf '%s\n' "$KITTY_CONFIG_DIR/light.conf" ;;
    *) return 1 ;;
  esac
}

repo_config_for_profile() {
  case "$1" in
    classic) printf '%s\n' "$ROOT_DIR/hyprland/kitty/classic.conf" ;;
    dark) printf '%s\n' "$ROOT_DIR/hyprland/kitty/dark.conf" ;;
    light) printf '%s\n' "$ROOT_DIR/hyprland-light/kitty/light.conf" ;;
    forge|cyber|admin|windows) printf '%s\n' "$ROOT_DIR/hyprland/kitty/dark.conf" ;;
    focus) printf '%s\n' "$ROOT_DIR/hyprland-light/kitty/light.conf" ;;
    *) return 1 ;;
  esac
}

profile_label() {
  case "$1" in
    classic) printf 'Classic' ;;
    dark) printf 'Graphite' ;;
    light) printf 'Light' ;;
    forge) printf 'Forge' ;;
    cyber) printf 'Cyber' ;;
    focus) printf 'Focus' ;;
    admin) printf 'Admin' ;;
    windows) printf 'Windows' ;;
  esac
}

profile_class() {
  case "$1" in
    classic) printf 'SevenTerminalClassic' ;;
    dark) printf 'SevenTerminalDark' ;;
    light) printf 'SevenTerminalLight' ;;
    forge) printf 'SevenTerminalForge' ;;
    cyber) printf 'SevenTerminalCyber' ;;
    focus) printf 'SevenTerminalFocus' ;;
    admin) printf 'SevenTerminalAdmin' ;;
    windows) printf 'SevenTerminalWindows' ;;
  esac
}

profile_overrides() {
  case "$1" in
    forge)
      printf '%s\n' \
        foreground=#F4F7FA background=#0B1020 background_opacity=0.89 \
        cursor=#4DA3FF selection_background=#314C73 active_border_color=#4DA3FF \
        active_tab_background=#121A2A tab_bar_background=#101827
      ;;
    cyber)
      printf '%s\n' \
        foreground=#D8FFF3 background=#07110E background_opacity=0.88 \
        cursor=#00FFB3 selection_background=#174D40 active_border_color=#00FFB3 \
        active_tab_background=#0A1B16 tab_bar_background=#081510
      ;;
    focus)
      printf '%s\n' \
        foreground=#20242D background=#FAFBFF background_opacity=0.96 \
        cursor=#6A5CFF selection_background=#E3DFFF active_border_color=#6A5CFF \
        active_tab_background=#FFFFFF tab_bar_background=#F5F7FA
      ;;
    admin)
      printf '%s\n' \
        foreground=#FFF4F0 background=#130A0A background_opacity=0.91 \
        cursor=#FF9B70 selection_background=#62332C active_border_color=#FF9B70 \
        active_tab_background=#231111 tab_bar_background=#180D0D
      ;;
    windows)
      printf '%s\n' \
        foreground=#EEF7FF background=#07111F background_opacity=0.90 \
        cursor=#74C7EC selection_background=#173B5C active_border_color=#74C7EC \
        active_tab_background=#0D1B2F tab_bar_background=#081421
      ;;
  esac
}

native_enabled() {
  [[ "${SEVENOS_TERMINAL_NATIVE:-1}" != "0" ]]
}

ensure_config() {
  local profile="$1"
  local active_config repo_config
  active_config="$(config_for_profile "$profile")"
  repo_config="$(repo_config_for_profile "$profile")"

  if [[ -s "$active_config" ]]; then
    printf '%s\n' "$active_config"
    return 0
  fi
  if [[ -s "$repo_config" ]]; then
    printf '%s\n' "$repo_config"
    return 0
  fi

  printf 'seven-terminal: missing Kitty profile: %s\n' "$profile" >&2
  return 1
}

open_terminal() {
  local profile="$1"
  shift || true
  local config title class width height shell_helper native label
  config="$(ensure_config "$profile")"

  if ! command -v kitty >/dev/null 2>&1; then
    printf 'seven-terminal: kitty is not installed\n' >&2
    return 1
  fi

  label="$(profile_label "$profile")"
  title="Seven Terminal · $label"
  class="$(profile_class "$profile")"
  width=760
  height=480
  shell_helper="$(terminal_shell)"
  native="$ROOT_DIR/bin/seven-terminal-native"

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    if native_enabled && [[ -x "$native" ]]; then
      printf 'DRY-RUN > Terminal > Open %s > native-vte > real traffic lights > %sx%s floating centered\n' "$profile" "$width" "$height"
    else
      printf 'DRY-RUN > Terminal > Open %s > kitty-default > %s > %sx%s floating centered\n' "$profile" "$config" "$width" "$height"
    fi
    return 0
  fi

  if native_enabled && [[ -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
    SEVENOS_TERMINAL_MODE="$profile" setsid -f "$native" --profile "$profile" "$@" >/tmp/sevenos-terminal.log 2>&1 || return 1
    place_window SevenTerminalNative "$width" "$height" "$title"
    return 0
  fi

  local overrides=()
  while IFS= read -r override; do
    [[ -n "$override" ]] && overrides+=(--override "$override")
  done < <(profile_overrides "$profile")

  if [[ "$#" -gt 0 ]]; then
    SEVENOS_TERMINAL_MODE="$profile" setsid -f kitty --config "$config" \
      --class "$class" \
      --name "$class" \
      --title "$title" \
      --override remember_window_size=no \
      --override tab_bar_min_tabs=1 \
      --override initial_window_width=88c \
      --override initial_window_height=24c \
      "${overrides[@]}" \
      "$@" >/tmp/sevenos-terminal.log 2>&1 || return 1
  else
    SEVENOS_TERMINAL_MODE="$profile" setsid -f kitty --config "$config" \
      --class "$class" \
      --name "$class" \
      --title "$title" \
      --override remember_window_size=no \
      --override tab_bar_min_tabs=1 \
      --override initial_window_width=88c \
      --override initial_window_height=24c \
      "${overrides[@]}" \
      "$shell_helper" >/tmp/sevenos-terminal.log 2>&1 || return 1
  fi

  place_window "$class" "$width" "$height"
}

place_window() {
  # Hyprland windowrules own Seven Terminal placement. Avoid post-launch
  # resizeactive calls here: if focus races during app startup, Hyprland can
  # resize the previously focused full-size application instead of the terminal.
  return 0
}

open_menu() {
  local menu selected
  menu=$'Classic Terminal\tDaily SevenOS terminal\nForge Terminal\tDevelopment, git and builds\nCyber Terminal\tSecurity and network workflow\nWindows Terminal\tWindows Bridge VM and compatibility\nFocus Terminal\tQuiet writing and reading\nAdmin Terminal\tCautious system control\nDark Terminal\tSevenOS graphite terminal\nLight Terminal\tSevenOS clarity-first terminal'

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'DRY-RUN > Terminal > Open profile chooser\n'
    printf '%s\n' "$menu"
    return 0
  fi

  if command -v rofi >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    selected="$(printf '%s\n' "$menu" | rofi -dmenu -i -p "Terminal" -mesg "Choose a SevenOS terminal profile" -theme "$ROOT_DIR/hyprland/rofi/sevenos.rasi" 2>/dev/null || true)"
  else
    printf '%s\n' "$menu"
    return 0
  fi

  case "$selected" in
    Classic*) open_terminal classic ;;
    Forge*) open_terminal forge ;;
    Cyber*) open_terminal cyber ;;
    Windows*) open_terminal windows ;;
    Focus*) open_terminal focus ;;
    Admin*) open_terminal admin ;;
    Dark*) open_terminal dark ;;
    Light*) open_terminal light ;;
    "") return 0 ;;
  esac
}

status() {
  local current_profile current_mode
  current_profile="$(active_profile)"
  current_mode="$(profile_terminal_mode "$current_profile")"
  printf 'SevenOS Terminal Profiles\n'
  printf 'active-profile: %s\n' "$current_profile"
  printf 'profile-mode:   %s\n' "$current_mode"
  printf 'classic: %s\n' "$(ensure_config classic)"
  printf 'dark:    %s\n' "$(ensure_config dark)"
  printf 'light:   %s\n' "$(ensure_config light)"
  printf 'modes:   forge cyber windows focus admin\n'
  printf 'default: %s\n' "$KITTY_CONFIG_DIR/kitty.conf"
  printf 'backend: native VTE default with Kitty fallback; set SEVENOS_TERMINAL_NATIVE=0 for Kitty\n'
  if [[ -x "$ROOT_DIR/bin/seven-terminal-native" ]] && "$ROOT_DIR/bin/seven-terminal-native" --probe >/dev/null 2>&1; then
    printf 'native:  OK - GTK/VTE traffic-light terminal available\n'
  else
    printf 'native:  MISS - install python-gobject and vte3, then run ./install.sh cli\n'
  fi
}

if [[ "${1:-}" == "--" ]]; then
  action="profile"
else
  action="${1:-profile}"
fi
case "$action" in
  profile|default)
    [[ "$#" -gt 0 && "${1:-}" != "--" ]] && shift || true
    if [[ "${1:-}" == "--" ]]; then
      shift
    fi
    open_terminal "$(profile_terminal_mode)" "$@"
    ;;
  classic|dark|light|forge|cyber|windows|focus|admin)
    shift || true
    if [[ "${1:-}" == "--" ]]; then
      shift
    fi
    open_terminal "$action" "$@"
    ;;
  menu|choose)
    open_menu
    ;;
  status|doctor)
    status
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
