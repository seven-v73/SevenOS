        settings_row("󰏗", tr("settings.sevenpkg_public", "Applications installées"), tr("settings.sevenpkg.note", "Voir et installer les apps graphiquement."), [callback_button(tr("settings.summary", "Résumé"), "apps:dashboard", show_apps_dashboard), action_button(tr("settings.open", "Ouvrir"), "seven-store")]),
        settings_row("󰈙", tr("settings.software_sources", "Sources d’apps"), tr("settings.software_sources.note", "Voir les sources d’applications utilisées par SevenOS."), [action_button(tr("settings.status", "Voir"), "seven flatpak status || flatpak list")]),
        settings_row("󰉋", tr("settings.applications_folder", "Applications visibles"), tr("settings.applications_folder.note", "Ouvrir la vue SevenOS des applications installées."), [callback_button(tr("settings.open", "Ouvrir"), "apps:dashboard", show_apps_dashboard)]),
    ])

    # System
    system = pages["system"][0]
    update_value, update_label = update_state_label()
    about_system = system_about()
    status_grid(
        system,
        [
            (about_system["release"], tr("settings.version", "Version")),
            (about_system["profile"], tr("settings.active_space", "Espace actif")),
            (about_system["smoke"], tr("settings.readiness", "Préparation")),
            (current_theme_mode(), tr("settings.theme", "Thème")),
            (update_value, update_label),
            (about_system["kernel"], tr("settings.system_base", "Base système")),
        ],
    )
    system.pack_start(
        workflow_card(
            tr("settings.system.workflow.title", "Entretien guidé"),
            tr("settings.system.workflow.note", "Les opérations système sensibles passent par des vues guidées avec progression, résultat et détails consultables."),
            [
                (tr("settings.system.step.check", "Vérifier"), tr("settings.system.step.check.note", "Contrôle santé, interface, mini OS, paquets et surfaces.")),
                (tr("settings.system.step.update", "Mettre à jour"), tr("settings.system.step.update.note", "Prépare les changements, installe, puis relance seulement ce qui est nécessaire.")),
                (tr("settings.system.step.recover", "Revenir en arrière"), tr("settings.system.step.recover.note", "Utilise sauvegarde ou rollback quand une opération doit être annulée.")),
            ],
            [
                action_button(tr("settings.check", "Vérifier"), "seven doctor"),
                action_button(tr("settings.update", "Mettre à jour"), "seven update"),
                page_button(tr("settings.backup", "Sauvegarde"), "backup"),
            ],
        ),
        False,
        False,
        0,
    )
    system.pack_start(
        workflow_card(
            tr("settings.system.levels.title", "Choisir le bon niveau d’action"),
            tr("settings.system.levels.note", "Pour éviter les interventions trop fortes, SevenOS sépare les contrôles légers, les mises à jour, les réparations et les diagnostics."),
            [
                (tr("settings.system.level.check", "Contrôle léger"), tr("settings.system.level.check.note", "Vérifie l’état sans modifier la machine.")),
                (tr("settings.system.level.update", "Mise à jour"), tr("settings.system.level.update.note", "Installe les changements avec suivi et résumé.")),
                (tr("settings.system.level.repair", "Réparation ciblée"), tr("settings.system.level.repair.note", "Réapplique seulement les surfaces et services nécessaires.")),
            ],
            [
                action_button(tr("settings.check", "Vérifier"), "seven smoke doctor"),
                action_button(tr("settings.repair", "Réparer"), repair_interface_command()),
            ],
        ),
        False,
        False,
        0,
    )
    settings_group(system, tr("settings.maintenance", "Maintenance"), [
        settings_row("󰚰", tr("settings.system_updates", "Mises à jour"), tr("settings.system_updates.note", "Mettre à jour SevenOS et les applications."), [action_button(tr("settings.update", "Mettre à jour"), "seven update")]),
        settings_row("󰏗", tr("settings.package_status", "Applications"), tr("settings.package_status.note", "Ouvrir SevenStore pour gérer les apps."), [action_button(tr("settings.open", "Ouvrir"), "seven-store")]),
        settings_row("󰄬", tr("settings.daily_gate", "Prêt pour le quotidien"), tr("settings.daily_gate.note", "Vérifier que SevenOS est prêt comme système principal."), [action_button(tr("settings.check", "Vérifier"), "seven daily")]),
        settings_row("󰩂", tr("settings.doctor", "Assistant de vérification"), tr("settings.doctor.note", "Diagnostiquer les soucis courants."), [action_button(tr("settings.run", "Lancer"), "seven doctor")]),
        settings_row("󰒓", tr("settings.runtime_status", "Résumé SevenOS"), tr("settings.runtime_status.note", "Ouvrir le résumé lisible de SevenOS."), [action_button(tr("settings.open", "Ouvrir"), "seven status")]),
        settings_row("󰜉", tr("settings.repair_ui", "Réparer l’interface"), tr("settings.repair_ui.note", "Réappliquer le thème, rafraîchir l’interface et réparer la barre."), [action_button(tr("settings.repair", "Réparer"), repair_interface_command())]),
        settings_row("󰌢", tr("settings.logs", "Alertes récentes"), tr("settings.logs.note", "Voir les avertissements récents dans une vue lisible."), [action_button(tr("settings.open", "Ouvrir"), "seven-doctor-native logs")]),
    ])

    stack.set_visible_child_name(initial_page)
    if initial_page in nav_by_target:
        nav_by_target[initial_page].get_style_context().add_class("active")
    elif nav_buttons:
        nav_buttons[0].get_style_context().add_class("active")
    page_context.set_text(nav_titles.get(initial_page, initial_page.title()))
    page_context.set_tooltip_text(page_title(initial_page))
    page_hint.set_text(page_subtitle(initial_page))
    page_hint.set_tooltip_text(page_subtitle(initial_page) or page_title(initial_page))
    initial_targets = list(nav_by_target.keys())
    if initial_page in initial_targets:
        page_position.set_text(f"{initial_targets.index(initial_page) + 1}/{len(initial_targets)}")
        page_position.set_tooltip_text(tr("settings.nav.position", "Page {index} sur {total}", index=initial_targets.index(initial_page) + 1, total=len(initial_targets)))
    live_refresh_button.set_tooltip_text(tr("settings.refresh_live.page_tooltip", "Actualiser {page} avec les informations live.", page=page_title(initial_page)))
    update_history_buttons()
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", handle_window_keys)
    window.show_all()
    if os.environ.get("SEVENOS_SETTINGS_SMOKE_OPEN") == "1":
        GLib.timeout_add(320, lambda: (window.destroy(), False)[1])
    Gtk.main()
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    if "--smoke-open" in sys.argv:
        os.environ["SEVENOS_SETTINGS_SMOKE_OPEN"] = "1"
    page = next((arg for arg in sys.argv[1:] if not arg.startswith("-")), "overview")
    return run(page)


if __name__ == "__main__":
    raise SystemExit(main())
