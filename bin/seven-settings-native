            ("󰛖", tr("settings.font_text", "Lecture"), str(payload.get("text") or "SevenOS"), None),
            ("󰛖", tr("settings.font_mono", "Terminal"), str(payload.get("mono") or "SevenOS Mono"), None),
            ("󰉋", tr("settings.font_storage", "Bibliothèque"), str(payload.get("font_home") or ""), tr("settings.ready", "Prêt")),
        ]
        info_dialog(
            tr("settings.font_status", "Polices SevenOS"),
            tr("settings.fonts_overview.note", "Familles utilisées pour garder l’interface lisible et cohérente."),
            rows,
        )

    def current_power_profile() -> str:
        if not command_exists("powerprofilesctl"):
            return ""
        try:
            result = subprocess.run(["powerprofilesctl", "get"], text=True, capture_output=True, check=False, timeout=0.8)
            return (result.stdout or "").strip()
        except Exception:
            return ""

    def available_power_profiles() -> list[str]:
        fallback = ["power-saver", "balanced", "performance"]
        if not command_exists("powerprofilesctl"):
            return []
        try:
            result = subprocess.run(["powerprofilesctl", "list"], text=True, capture_output=True, check=False, timeout=0.8)
            profiles: list[str] = []
            for line in (result.stdout or "").splitlines():
                candidate = line.strip().lstrip("*").strip().split(":", 1)[0].strip()
                if candidate in fallback and candidate not in profiles:
                    profiles.append(candidate)
            return profiles or fallback
        except Exception:
            return fallback

    def set_power_profile(profile: str) -> None:
        label_map = {
            "power-saver": tr("settings.power_saver", "Économie"),
            "balanced": tr("settings.power_balanced", "Équilibré"),
            "performance": tr("settings.power_performance", "Performance"),
        }
        if not command_exists("powerprofilesctl"):
            show_feedback(tr("settings.power_profile_unavailable", "Gestion d’énergie indisponible sur cette machine."))
            notify("SevenOS Settings", tr("settings.power_profile_unavailable", "Gestion d’énergie indisponible sur cette machine."))
            return
        try:
            result = subprocess.run(["powerprofilesctl", "set", profile], text=True, capture_output=True, check=False, timeout=1.2)
            if result.returncode == 0:
                message = tr("settings.power_profile_applied", "Mode d’énergie appliqué : {profile}", profile=label_map.get(profile, profile))
                show_feedback(message)
                notify("SevenOS Settings", message)
            else:
                show_feedback((result.stderr or result.stdout or tr("settings.action_failed", "Action impossible pour le moment.")).strip())
        except Exception:
            show_feedback(tr("settings.action_failed", "Action impossible pour le moment."))

    def idle_policy_status() -> dict:
        return run_json_timeout([str(ROOT / "bin/seven-idle"), "status", "--json"], {}, timeout=0.9)

    def idle_policy_summary() -> tuple[str, str]:
        data = idle_policy_status()
        mode = str(data.get("mode") or "standard")
        lock_minutes = int(data.get("lock_minutes") or 0)
        screen_minutes = int(data.get("screen_minutes") or 0)
        sleep_minutes = int(data.get("sleep_minutes") or 0)
        service = str(data.get("service") or "unknown")
        service_label = {
            "active": tr("settings.running", "Actif"),
            "inactive": tr("settings.stopped", "Arrêté"),
            "failed": tr("settings.action_failed", "Action impossible pour le moment."),
        }.get(service, service)
        if mode == "never":
            return (
                tr("settings.idle_never", "Jamais"),
                tr("settings.idle_never.note", "L’écran reste actif et SevenOS ne met pas la machine en veille automatiquement. Service : {service}", service=service_label),
            )
        if sleep_minutes > 0:
            return (
                tr("settings.idle_after", "Après {minutes} min", minutes=sleep_minutes),
                tr(
                    "settings.idle_timeout.note",
                    "Verrouillage {lock} min · écran {screen} min · veille {sleep} min · service {service}",
                    lock=lock_minutes,
                    screen=screen_minutes,
                    sleep=sleep_minutes,
                    service=service_label,
                ),
            )
        return (
            tr("settings.idle_standard", "Standard SevenOS"),
            tr("settings.idle_standard.note", "Comportement par défaut : verrouillage après 10 min, écran éteint après 15 min, sans veille forcée."),
        )

    def set_idle_policy(value: str) -> None:
        label = tr("settings.idle_never", "Jamais") if value == "never" else tr("settings.idle_after", "Après {minutes} min", minutes=value)
        try:
            command = [str(ROOT / "bin/seven-idle"), "never"] if value == "never" else [str(ROOT / "bin/seven-idle"), "set", str(value)]
            result = subprocess.run(command, text=True, capture_output=True, check=False, timeout=2.5)
            if result.returncode == 0:
                message = tr("settings.idle_applied", "Veille automatique réglée : {value}", value=label)
                show_feedback(message)
                notify("SevenOS Settings", message)
            else:
                show_feedback((result.stderr or result.stdout or tr("settings.action_failed", "Action impossible pour le moment.")).strip())
        except Exception:
            show_feedback(tr("settings.action_failed", "Action impossible pour le moment."))

    def reset_idle_policy() -> None:
        try:
            result = subprocess.run([str(ROOT / "bin/seven-idle"), "reset"], text=True, capture_output=True, check=False, timeout=2.5)
            if result.returncode == 0:
                message = tr("settings.idle_reset", "Veille automatique revenue au standard SevenOS.")
                show_feedback(message)
                notify("SevenOS Settings", message)
            else:
                show_feedback((result.stderr or result.stdout or tr("settings.action_failed", "Action impossible pour le moment.")).strip())
        except Exception:
            show_feedback(tr("settings.action_failed", "Action impossible pour le moment."))

    def show_idle_policy_dialog() -> None:
        dialog = Gtk.Dialog(title=tr("settings.idle_section", "Veille automatique"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(620, 520)
        box = style_dialog(dialog)
        box.set_spacing(14)
        box.set_border_width(18)

        title = Gtk.Label(label=tr("settings.idle_section", "Veille automatique"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(
            label=tr(
                "settings.idle_panel.note",
                "Choisis après combien de temps d’inactivité SevenOS verrouille, éteint l’écran puis met la machine en veille. Le mode Jamais garde l’écran actif.",
            )
        )
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)

        status_card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        status_card.get_style_context().add_class("settings-card")
        status_icon = Gtk.Label(label="󰒲")
        status_icon.get_style_context().add_class("settings-row-icon")
        status_labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        status_title = Gtk.Label()
        status_title.set_xalign(0)
        status_title.get_style_context().add_class("settings-row-title")
        status_note = Gtk.Label()
        status_note.set_xalign(0)
        status_note.set_line_wrap(True)
        status_note.get_style_context().add_class("settings-row-note")
        status_labels.pack_start(status_title, False, False, 0)
        status_labels.pack_start(status_note, False, False, 0)
        status_card.pack_start(status_icon, False, False, 0)
        status_card.pack_start(status_labels, True, True, 0)
        box.pack_start(status_card, False, False, 0)

        def update_status() -> None:
            current_title, current_note = idle_policy_summary()
            status_title.set_text(current_title)
            status_note.set_text(current_note)

        update_status()

        presets = [
            ("5", tr("settings.idle_preset.quick", "Très court"), tr("settings.idle_preset.quick.note", "Idéal sur batterie ou en espace partagé.")),
            ("15", tr("settings.idle_preset.normal", "Standard"), tr("settings.idle_preset.normal.note", "Bon équilibre entre sécurité, confort et économie.")),
            ("30", tr("settings.idle_preset.comfort", "Confort"), tr("settings.idle_preset.comfort.note", "Laisse le temps de lire ou suivre une tâche longue.")),
            ("60", tr("settings.idle_preset.long", "Travail long"), tr("settings.idle_preset.long.note", "Adapté aux téléchargements, lecture et sessions créatives.")),
            ("120", tr("settings.idle_preset.presentation", "Présentation"), tr("settings.idle_preset.presentation.note", "Évite les coupures pendant une démonstration ou une projection.")),
            ("never", tr("settings.idle_never", "Jamais"), tr("settings.idle_preset.never.note", "L’écran reste actif et la veille automatique est désactivée.")),
        ]

        list_box = Gtk.ListBox()
        list_box.get_style_context().add_class("account-list")
        apply_buttons: dict[str, Gtk.Button] = {}
        idle_values: list[str] = [value for value, _preset_title, _preset_note in presets]

        def refresh_choice_buttons() -> None:
            current = idle_policy_status()
            current_mode = str(current.get("mode") or "standard")
            current_sleep = str(current.get("sleep_minutes") or "")
            for value, button in apply_buttons.items():
                if (value == "never" and current_mode == "never") or (value == current_sleep and current_mode != "never"):
                    button.set_label(tr("settings.active", "Actif"))
                    button.get_style_context().add_class("suggested-action")
                else:
                    button.set_label(tr("settings.apply", "Appliquer"))
                    button.get_style_context().remove_class("suggested-action")

        def apply_idle_choice(value: str) -> None:
            set_idle_policy(value)
            update_status()
            refresh_choice_buttons()

        for value, preset_title, preset_note in presets:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label="󰔛" if value == "never" else "󰥔")
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            title_label = Gtk.Label(label=preset_title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            value_label = tr("settings.idle_never", "Jamais") if value == "never" else tr("settings.idle_after", "Après {minutes} min", minutes=value)
            note_label = Gtk.Label(label=f"{value_label} · {preset_note}")
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            apply = Gtk.Button(label=tr("settings.apply", "Appliquer"))
            apply.get_style_context().add_class("action-button")
            apply.set_tooltip_text(tr("settings.idle_apply.tooltip", "Appliquer ce délai de veille automatique."))
            apply_buttons[value] = apply
            apply.connect("clicked", lambda _button, selected=value: apply_idle_choice(selected))
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            wrapper.pack_start(apply, False, False, 0)
            row.set_selectable(True)
            row.set_activatable(True)
            row.set_tooltip_text(tr("settings.idle_row.tooltip", "Double-clic ou Entrée pour appliquer ce choix."))
            row.add(wrapper)
            list_box.add(row)
        box.pack_start(list_box, True, True, 0)
        refresh_choice_buttons()

        def on_idle_row_activated(_list_box, row) -> None:
            index = row.get_index()
            if 0 <= index < len(idle_values):
                apply_idle_choice(idle_values[index])

        list_box.connect("row-activated", on_idle_row_activated)

        custom_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        custom_box.get_style_context().add_class("settings-card")
        custom_icon = Gtk.Label(label="󰔟")
        custom_icon.get_style_context().add_class("settings-row-icon")
        custom_labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        custom_labels.set_hexpand(True)
        custom_title = Gtk.Label(label=tr("settings.idle_custom", "Temps personnalisé"))
        custom_title.set_xalign(0)
        custom_title.get_style_context().add_class("settings-row-title")
        custom_note = Gtk.Label(label=tr("settings.idle_custom.note", "Définis un délai précis entre 1 et 240 minutes."))
        custom_note.set_xalign(0)
        custom_note.set_line_wrap(True)
        custom_note.get_style_context().add_class("settings-row-note")
        custom_labels.pack_start(custom_title, False, False, 0)
        custom_labels.pack_start(custom_note, False, False, 0)
        current_custom = idle_policy_status()
        custom_default = int(current_custom.get("sleep_minutes") or 30)
        if custom_default <= 0:
            custom_default = 30
        custom_spin = Gtk.SpinButton.new_with_range(1, 240, 1)
        custom_spin.set_value(min(max(custom_default, 1), 240))
        custom_spin.set_numeric(True)
        custom_spin.set_width_chars(4)
        custom_spin.set_tooltip_text(tr("settings.idle_custom.spin.tooltip", "Choisir un délai personnalisé en minutes."))
        custom_apply = Gtk.Button(label=tr("settings.apply", "Appliquer"))
        custom_apply.get_style_context().add_class("action-button")
        custom_apply.set_tooltip_text(tr("settings.idle_custom.apply.tooltip", "Appliquer ce délai personnalisé."))
        custom_apply.connect("clicked", lambda _button: apply_idle_choice(str(custom_spin.get_value_as_int())))
        custom_box.pack_start(custom_icon, False, False, 0)
        custom_box.pack_start(custom_labels, True, True, 0)
        custom_box.pack_start(custom_spin, False, False, 0)
        custom_box.pack_start(Gtk.Label(label=tr("settings.minutes_short", "min")), False, False, 0)
        custom_box.pack_start(custom_apply, False, False, 0)
        box.pack_start(custom_box, False, False, 0)

        button_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        button_row.set_halign(Gtk.Align.END)
        reset = Gtk.Button(label=tr("settings.reset", "Réinitialiser"))
        reset.get_style_context().add_class("action-button")
        reset.set_tooltip_text(tr("settings.idle_reset.tooltip", "Revenir au comportement SevenOS standard."))
        reset.connect("clicked", lambda _button: (reset_idle_policy(), update_status(), refresh_choice_buttons()))
        close = Gtk.Button(label=tr("settings.close", "Fermer"))
        close.get_style_context().add_class("action-button")
        close.connect("clicked", lambda _button: dialog.destroy())
        button_row.pack_start(reset, False, False, 0)
        button_row.pack_start(close, False, False, 0)
        box.pack_start(button_row, False, False, 0)

        def idle_dialog_key(_dialog, event) -> bool:
            key_map = {
                Gdk.KEY_1: "5",
                Gdk.KEY_2: "15",
                Gdk.KEY_3: "30",
                Gdk.KEY_4: "60",
                Gdk.KEY_5: "120",
                Gdk.KEY_6: "never",
            }
            if event.keyval in key_map:
                apply_idle_choice(key_map[event.keyval])
                return True
            if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter} and custom_spin.has_focus():
                apply_idle_choice(str(custom_spin.get_value_as_int()))
                return True
            return False

        dialog.connect("key-press-event", idle_dialog_key)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def show_power_overview() -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        active = current_power_profile()
        label_map = {
            "power-saver": tr("settings.power_saver", "Économie"),
            "balanced": tr("settings.power_balanced", "Équilibré"),
            "performance": tr("settings.power_performance", "Performance"),
        }
        rows.append(("󰁹", tr("settings.power_mode", "Mode d’énergie"), label_map.get(active, active or tr("settings.unavailable", "Indisponible")), tr("settings.active", "Actif") if active else None))
        rows.extend(
            [
                ("󰾅", tr("settings.power_note_balanced", "Usage quotidien"), tr("settings.power_note_balanced.note", "SevenOS privilégie le confort et l’autonomie."), None),
                ("󰓅", tr("settings.power_note_perf", "Travail intense"), tr("settings.power_note_perf.note", "Performance disponible depuis le centre de contrôle si la machine le permet."), None),
            ]
        )
        dialog = Gtk.Dialog(title=tr("settings.energy", "Énergie"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(560, 520)
        box = style_dialog(dialog)
        box.set_spacing(14)
        box.set_border_width(18)

        title = Gtk.Label(label=tr("settings.power_profile", "Mode d’énergie"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=tr("settings.power_overview.note", "État lisible du mode d’énergie de cette machine."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)

        list_box = Gtk.ListBox()
        list_box.get_style_context().add_class("account-list")
        mode_badge = Gtk.Label()
        power_buttons: dict[str, Gtk.Button] = {}

        def refresh_power_buttons() -> None:
            current = current_power_profile()
            mode_badge.set_text(label_map.get(current, current or tr("settings.unavailable", "Indisponible")))
            for profile, button in power_buttons.items():
                if profile == current:
                    button.get_style_context().add_class("suggested-action")
                    button.set_label(tr("settings.active_named", "{name} actif", name=label_map.get(profile, profile)))
                else:
                    button.get_style_context().remove_class("suggested-action")
                    button.set_label(label_map.get(profile, profile))

        def apply_power_profile(profile: str) -> None:
            set_power_profile(profile)
            refresh_power_buttons()

        for icon, row_title, row_note, badge_text in rows:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label=icon)
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            title_label = Gtk.Label(label=row_title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            note_label = Gtk.Label(label=row_note)
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.set_max_width_chars(76)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            if badge_text:
                badge = mode_badge if row_title == tr("settings.power_mode", "Mode d’énergie") else Gtk.Label(label=badge_text)
                if row_title == tr("settings.power_mode", "Mode d’énergie"):
                    badge.set_text(label_map.get(active, active or tr("settings.unavailable", "Indisponible")))
                badge.get_style_context().add_class("update-summary-chip")
                wrapper.pack_start(badge, False, False, 0)
            row.add(wrapper)
            list_box.add(row)
        box.pack_start(list_box, True, True, 0)

        button_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        button_row.set_halign(Gtk.Align.END)
        for profile in available_power_profiles():
            button = Gtk.Button(label=label_map.get(profile, profile))
            button.get_style_context().add_class("action-button")
            button.set_tooltip_text(tr("settings.power_profile_apply.tooltip", "Appliquer le mode {mode}.", mode=label_map.get(profile, profile)))
            power_buttons[profile] = button
            button.connect("clicked", lambda _button, selected=profile: apply_power_profile(selected))
            button_row.pack_start(button, False, False, 0)
        close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
        close_button.get_style_context().add_class("action-button")
        button_row.pack_start(close_button, False, False, 0)
        box.pack_start(button_row, False, False, 0)
        refresh_power_buttons()

        def power_dialog_key(_dialog, event) -> bool:
            key_map = {
                Gdk.KEY_1: "power-saver",
                Gdk.KEY_2: "balanced",
                Gdk.KEY_3: "performance",
            }
            if event.keyval in key_map and key_map[event.keyval] in power_buttons:
                apply_power_profile(key_map[event.keyval])
                return True
            return False

        dialog.connect("key-press-event", power_dialog_key)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def theme_session_status() -> dict[str, str]:
        payload = run_json_timeout([str(ROOT / "scripts/theme-session.sh"), "doctor"], {}, timeout=1.0)
        if not isinstance(payload, dict) or payload.get("schema") != "sevenos.theme-session.v1":
            return {
                "state": "unknown",
                "title": tr("settings.theme_session.unknown", "À vérifier"),
                "note": tr("settings.theme_session.unknown_note", "SevenOS n’a pas encore reçu l’état complet du thème de session."),
            }
        state = str(payload.get("state") or "unknown")
        preferred = str(payload.get("preferred") or current_theme_mode())
        runtime = str(payload.get("runtime") or "unknown")
        checks = payload.get("checks", {}) if isinstance(payload.get("checks"), dict) else {}
        ok_count = sum(1 for value in checks.values() if bool(value))
        total_count = len(checks)
        if state == "ok":
            return {
                "state": state,
                "title": tr("settings.theme_session.ready", "Cohérent"),
                "note": tr(
                    "settings.theme_session.ready_note",
                    "{mode} actif · {ok}/{total} contrôles alignés pour les prochaines fenêtres.",
                    mode=preferred,
                    ok=ok_count,
                    total=total_count,
                ),
            }
        return {
            "state": state,
            "title": tr("settings.theme_session.attention", "À resynchroniser"),
            "note": tr(
                "settings.theme_session.attention_note",
                "Préférence {preferred}, runtime {runtime}. Resynchronise pour les apps et navigateurs.",
                preferred=preferred,
                runtime=runtime,
            ),
        }

    def show_theme_session_dashboard(auto_sync: bool = False) -> None:
        dialog = Gtk.Dialog(title=tr("settings.theme_session", "Session thème"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(min(680, max(520, int(screen_width * 0.50))), min(560, max(380, int(screen_height * 0.58))))
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(16)

        title = Gtk.Label(label=tr("settings.theme_session", "Session thème"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=tr("settings.theme_session.panel_note", "SevenOS vérifie que le mode clair/sombre est aligné entre les apps, la session, Hyprland, GTK, Qt et les navigateurs."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        status = Gtk.Label()
        status.set_xalign(0)
        status.set_line_wrap(True)
        status.get_style_context().add_class("settings-inline-status")
        list_box = Gtk.ListBox()
        list_box.get_style_context().add_class("account-list")
        list_box.set_selection_mode(Gtk.SelectionMode.NONE)

        check_labels = {
            "runtime_matches_preference": tr("settings.theme_check.runtime", "Préférence et runtime"),
            "gsettings_color_scheme": tr("settings.theme_check.gsettings", "Préférence système GTK"),
            "gtk_settings_match_runtime": tr("settings.theme_check.gtk", "Thème GTK des applications"),
            "hyprland_env_matches_runtime": tr("settings.theme_check.hyprland", "Apps lancées par Hyprland"),
            "electron_hint_ready": tr("settings.theme_check.electron", "Navigateurs et apps Electron"),
        }
        check_notes = {
            "runtime_matches_preference": tr("settings.theme_check.runtime.note", "Le thème enregistré et le runtime SevenOS disent la même chose."),
            "gsettings_color_scheme": tr("settings.theme_check.gsettings.note", "Les apps GTK/libadwaita reçoivent prefer-light ou prefer-dark."),
            "gtk_settings_match_runtime": tr("settings.theme_check.gtk.note", "Les fichiers GTK suivent le thème SevenOS actif."),
            "hyprland_env_matches_runtime": tr("settings.theme_check.hyprland.note", "Les nouvelles fenêtres lancées par raccourci ou Launchpad héritent du bon thème."),
            "electron_hint_ready": tr("settings.theme_check.electron.note", "Les navigateurs Chromium/Electron reçoivent le hint Wayland/Ozone attendu."),
        }

        def clear_list() -> None:
            for child in list(list_box.get_children()):
                list_box.remove(child)

        def add_check_row(icon: str, row_title: str, row_note: str, badge_text: str | None = None) -> None:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label=icon)
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            title_label = Gtk.Label(label=row_title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            note_label = Gtk.Label(label=row_note)
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            if badge_text:
                badge = Gtk.Label(label=badge_text)
                badge.get_style_context().add_class("update-summary-chip")
                wrapper.pack_start(badge, False, False, 0)
            row.add(wrapper)
            list_box.add(row)

        def load_payload() -> dict:
            return run_json_timeout([str(ROOT / "scripts/theme-session.sh"), "doctor"], {}, timeout=1.4)

        def render(payload: dict | None = None) -> None:
            data = payload if isinstance(payload, dict) else load_payload()
            clear_list()
            state = str(data.get("state") or "unknown")
            preferred = str(data.get("preferred") or current_theme_mode())
            runtime = str(data.get("runtime") or "unknown")
            color = str(data.get("gsettings_color_scheme") or "unknown")
            if state == "ok":
                status.set_text(tr("settings.theme_session.panel_ready", "Cohérent · les prochaines fenêtres utiliseront {mode}.", mode=preferred))
                status.get_style_context().remove_class("action-state-error")
                status.get_style_context().add_class("action-state-success")
            else:
                status.set_text(tr("settings.theme_session.panel_attention", "À resynchroniser · préférence {preferred}, runtime {runtime}.", preferred=preferred, runtime=runtime))
                status.get_style_context().remove_class("action-state-success")
                status.get_style_context().add_class("action-state-error")
            add_check_row("󰔎", tr("settings.theme", "Thème"), tr("settings.theme_session.mode_detail", "Préférence {preferred} · runtime {runtime} · système {color}", preferred=preferred, runtime=runtime, color=color), tr("settings.active", "Actif") if state == "ok" else tr("settings.attention", "Attention"))
            checks = data.get("checks", {}) if isinstance(data.get("checks"), dict) else {}
            for key, label in check_labels.items():
                ok = bool(checks.get(key))
                add_check_row("✓" if ok else "!", label, check_notes.get(key, ""), tr("settings.ok", "OK") if ok else tr("settings.repair", "Réparer"))
            list_box.show_all()

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.add(list_box)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_halign(Gtk.Align.END)
        resync_button = Gtk.Button(label=tr("settings.resync", "Resynchroniser"))
        resync_button.get_style_context().add_class("action-button")
        close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
        close_button.get_style_context().add_class("action-button")
        close_button.connect("clicked", lambda _button: dialog.response(Gtk.ResponseType.CLOSE))

        def do_resync(_button=None) -> None:
            resync_button.set_sensitive(False)
            resync_button.get_style_context().add_class("busy")
            status.set_text(tr("settings.theme_session.syncing", "Resynchronisation de la session thème…"))

            def worker() -> None:
                subprocess.run([str(ROOT / "bin/seven"), "theme", "sync"], cwd=ROOT, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
                payload = load_payload()

                def done() -> bool:
                    resync_button.set_sensitive(True)
                    resync_button.get_style_context().remove_class("busy")
                    render(payload)
                    show_feedback(tr("settings.theme_session.synced", "Thème de session resynchronisé."), "success")
                    return False

                GLib.idle_add(done)

            threading.Thread(target=worker, daemon=True).start()

        resync_button.connect("clicked", do_resync)
        actions.pack_start(resync_button, False, False, 0)
        actions.pack_start(close_button, False, False, 0)

        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)
        box.pack_start(status, False, False, 0)
        box.pack_start(scroller, True, True, 0)
        box.pack_start(actions, False, False, 0)
        render()
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()
        if auto_sync:
            GLib.timeout_add(220, lambda: (do_resync(), False)[1])

    def show_appearance_overview() -> None:
