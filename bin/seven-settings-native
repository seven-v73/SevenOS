    def current_power_profile() -> str:
        if not command_exists("powerprofilesctl"):
            return ""
        try:
            result = subprocess.run(["powerprofilesctl", "get"], text=True, capture_output=True, check=False, timeout=0.8)
            return (result.stdout or "").strip()
        except Exception:
            return ""

    def available_power_profiles() -> list[str]:
        fallback = ["power-saver", "balanced", "performance"]
        if not command_exists("powerprofilesctl"):
            return []
        try:
            result = subprocess.run(["powerprofilesctl", "list"], text=True, capture_output=True, check=False, timeout=0.8)
            profiles: list[str] = []
            for line in (result.stdout or "").splitlines():
                candidate = line.strip().lstrip("*").strip().split(":", 1)[0].strip()
                if candidate in fallback and candidate not in profiles:
                    profiles.append(candidate)
            return profiles or fallback
        except Exception:
            return fallback

    def set_power_profile(profile: str) -> None:
        label_map = {
            "power-saver": tr("settings.power_saver", "Économie"),
            "balanced": tr("settings.power_balanced", "Équilibré"),
            "performance": tr("settings.power_performance", "Performance"),
        }
        if not command_exists("powerprofilesctl"):
            show_feedback(tr("settings.power_profile_unavailable", "Gestion d’énergie indisponible sur cette machine."))
            notify("SevenOS Settings", tr("settings.power_profile_unavailable", "Gestion d’énergie indisponible sur cette machine."))
            return
        try:
            result = subprocess.run(["powerprofilesctl", "set", profile], text=True, capture_output=True, check=False, timeout=1.2)
            if result.returncode == 0:
                message = tr("settings.power_profile_applied", "Mode d’énergie appliqué : {profile}", profile=label_map.get(profile, profile))
                show_feedback(message)
                notify("SevenOS Settings", message)
            else:
                show_feedback((result.stderr or result.stdout or tr("settings.action_failed", "Action impossible pour le moment.")).strip())
        except Exception:
            show_feedback(tr("settings.action_failed", "Action impossible pour le moment."))

    def show_power_overview() -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        active = current_power_profile()
        label_map = {
            "power-saver": tr("settings.power_saver", "Économie"),
            "balanced": tr("settings.power_balanced", "Équilibré"),
            "performance": tr("settings.power_performance", "Performance"),
        }
        rows.append(("󰁹", tr("settings.power_mode", "Mode d’énergie"), label_map.get(active, active or tr("settings.unavailable", "Indisponible")), tr("settings.active", "Actif") if active else None))
        rows.extend(
            [
                ("󰾅", tr("settings.power_note_balanced", "Usage quotidien"), tr("settings.power_note_balanced.note", "SevenOS privilégie le confort et l’autonomie."), None),
                ("󰓅", tr("settings.power_note_perf", "Travail intense"), tr("settings.power_note_perf.note", "Performance disponible depuis le centre de contrôle si la machine le permet."), None),
            ]
        )
        dialog = Gtk.Dialog(title=tr("settings.energy", "Énergie"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(560, 520)
        dialog.get_style_context().add_class("settings-dialog")
        box = dialog.get_content_area()
        box.set_spacing(14)
        box.set_border_width(18)

        title = Gtk.Label(label=tr("settings.power_profile", "Mode d’énergie"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=tr("settings.power_overview.note", "État lisible du mode d’énergie de cette machine."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)

        list_box = Gtk.ListBox()
        list_box.get_style_context().add_class("account-list")
        for icon, row_title, row_note, badge_text in rows:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label=icon)
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            title_label = Gtk.Label(label=row_title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            note_label = Gtk.Label(label=row_note)
            note_label.set_xalign(0)
            note_label.set_ellipsize(Pango.EllipsizeMode.END)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            if badge_text:
                badge = Gtk.Label(label=badge_text)
                badge.get_style_context().add_class("update-summary-chip")
                wrapper.pack_start(badge, False, False, 0)
            row.add(wrapper)
            list_box.add(row)
        box.pack_start(list_box, True, True, 0)

        button_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        button_row.set_halign(Gtk.Align.END)
        for profile in available_power_profiles():
            button = Gtk.Button(label=label_map.get(profile, profile))
            button.get_style_context().add_class("action-button")
            if profile == active:
                button.get_style_context().add_class("suggested-action")
            button.connect("clicked", lambda _button, selected=profile: (set_power_profile(selected), dialog.destroy()))
            button_row.pack_start(button, False, False, 0)
        close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
        close_button.get_style_context().add_class("action-button")
        close_button.connect("clicked", lambda _button: dialog.destroy())
        button_row.pack_start(close_button, False, False, 0)
        box.pack_start(button_row, False, False, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def show_ai_overview() -> None:
        provider = tr("settings.ai_local", "Local")
        privacy = tr("settings.ai_private", "Privé par défaut")
        try:
            result = subprocess.run(
                [str(ROOT / "scripts/ai.sh"), "provider", "--json"],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                text=True,
                capture_output=True,
                check=False,
                timeout=1.0,
            )
            payload = json.loads(result.stdout or "{}")
            if isinstance(payload, dict):
                provider = str(payload.get("provider") or payload.get("name") or provider)
                privacy = str(payload.get("mode") or payload.get("privacy") or privacy)
        except Exception:
            pass
        info_dialog(
            tr("settings.ai", "SevenAI"),
            tr("settings.ai_overview.note", "Assistant local de SevenOS, avec actions confirmées avant application."),
            [
                ("󰚩", tr("settings.ai_provider", "Assistant"), provider, tr("settings.ready", "Prêt")),
                ("󰒃", tr("settings.privacy", "Confidentialité"), privacy, None),
                ("󰜎", tr("settings.ai_actions", "Actions"), tr("settings.ai_actions.note", "Les changements importants demandent toujours une validation."), None),
            ],
        )

    def show_plan_overview(title_text: str, note_text: str, command: list[str]) -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        try:
            result = subprocess.run(
                command,
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                text=True,
                capture_output=True,
                check=False,
                timeout=1.2,
            )
            lines = [line.strip() for line in (result.stdout or result.stderr or "").splitlines() if line.strip()]
        except Exception:
            lines = []
        for line in lines[:10]:
            clean = line.replace("$", "").strip()
            if not clean or clean.startswith("{") or clean.startswith("["):
                continue
            rows.append(("󰄬", tr("settings.plan_item", "Élément"), clean[:180], None))
        info_dialog(
            title_text,
            note_text,
            rows or [("✓", tr("settings.no_action_needed", "Rien à faire"), tr("settings.no_action_needed.note", "SevenOS ne voit aucune action nécessaire pour le moment."), tr("settings.ready", "Prêt"))],
        )

    def show_security_overview() -> None:
        rows = [
            ("󰒃", tr("settings.security_posture", "Protection"), tr("settings.security_posture.note", "Shield garde les actions sensibles visibles avant application."), tr("settings.ready", "Prêt")),
            ("󰈙", tr("settings.sandbox", "Isolation"), tr("settings.sandbox.note", "Les apps mini OS utilisent leur espace quand elles passent par SevenOS."), None),
            ("󰋼", tr("settings.audit", "Vérification"), tr("settings.audit.note", "Les détails techniques restent disponibles dans Aide pour les utilisateurs avancés."), None),
        ]
        info_dialog(tr("settings.security", "Sécurité"), tr("settings.security_overview.note", "Résumé grand public des protections SevenOS."), rows)

    def show_interface_overview() -> None:
        rows = [
            ("󰕮", tr("settings.menu_bar", "Barre de menu"), tr("settings.menu_bar.note", "Waybar suit le mini OS actif et les actions système."), tr("settings.ready", "Prêt")),
            ("󰀻", tr("settings.dock_launchpad", "Dock et Launchpad"), tr("settings.dock_launchpad.note", "Accès rapide aux apps et espaces SevenOS."), None),
            ("󰔎", tr("settings.theme", "Thème"), current_theme_mode().title(), tr("settings.active", "Actif")),
        ]
        info_dialog(tr("settings.interface", "Interface"), tr("settings.interface_overview.note", "État lisible des surfaces SevenOS."), rows)

    def show_mini_os_overview(command: str = "") -> None:
        catalog = profile_catalog()
        profile_defs = catalog.get("profiles", {}) if isinstance(catalog.get("profiles"), dict) else {}
        current_key = active_profile_key()
        rows: list[tuple[str, str, str, str | None]] = []
        for key in ["equinox", "baobab", "forge", "shield", "studio", "atlas", "pulse"]:
            data = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
            rows.append(
                (
                    {"equinox": "󰐃", "baobab": "󰣇", "forge": "󰅩", "shield": "󰒃", "studio": "󰏗", "atlas": "󰙅", "pulse": "󰊴"}.get(key, "󰐃"),
                    str(data.get("title") or key.title()),
                    str(data.get("purpose") or tr("settings.profile_space", "Espace SevenOS")),
                    tr("settings.active", "Actif") if key == current_key else None,
                )
            )
        info_dialog(
            tr("settings.profiles", "Mini OS"),
            tr("settings.mini_os_overview.note", "Chaque mini OS garde son espace. Les partages restent explicites."),
            rows,
            width=640,
            height=520,
        )

    def show_system_overview() -> None:
        about = system_about()
        rows = [
            ("󰣇", "SevenOS", about.get("release", "SevenOS"), None),
            ("󰌢", tr("settings.device_name", "Appareil"), about.get("hostname", platform.node()), None),
            ("󰒓", tr("settings.active_space", "Espace actif"), about.get("profile", active_profile_key()), None),
            ("󰔎", tr("settings.theme", "Thème"), current_theme_mode(), None),
            ("✓", tr("settings.readiness", "Préparation"), str(about.get("smoke", "")), tr("settings.ready", "Prêt")),
        ]
        info_dialog(
            tr("settings.runtime_status", "État général"),
            tr("settings.system_overview.note", "Résumé lisible de l’état courant de SevenOS."),
            rows,
        )

    def show_alerts_overview() -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        try:
            result = subprocess.run(["journalctl", "-p", "warning", "-b", "-n", "12", "--no-pager"], text=True, capture_output=True, check=False, timeout=1.5)
            for line in result.stdout.splitlines():
                if not line.strip() or line.startswith("--"):
                    continue
                rows.append(("󰌢", tr("settings.alert", "Alerte"), line[-180:], None))
        except Exception:
            pass
        info_dialog(
            tr("settings.logs", "Alertes récentes"),
            tr("settings.alerts_overview.note", "Événements récents qui peuvent demander ton attention."),
            rows or [("✓", tr("settings.no_alerts", "Aucune alerte récente"), tr("settings.no_alerts.note", "SevenOS ne voit rien d’important pour le moment."), None)],
            width=680,
            height=520,
        )

    def handle_graphical_action(command: str) -> bool:
        stripped = command.strip()
        if stripped in {"seven language status", "seven language list"}:
            show_language_overview()
            return True
        if stripped == "seven-files resources status":
            show_files_resources_overview()
            return True
        if stripped == "sevenpkg status":
            show_software_overview()
            return True
        if stripped.startswith("seven flatpak status") or stripped.startswith("flatpak list"):
            show_app_sources_overview()
            return True
        if stripped.startswith(("seven mini-os status", "seven runtime", "seven runtime plan")):
            show_mini_os_overview(stripped)
            return True
        if stripped in {"seven status", "seven state --json"}:
            show_system_overview()
            return True
        if stripped.startswith("journalctl"):
            show_alerts_overview()
            return True
        if stripped.startswith("seven fonts status"):
            show_fonts_overview()
            return True
        if stripped.startswith("powerprofilesctl"):
            show_power_overview()
            return True
        if stripped.startswith("seven ai provider"):
            show_ai_overview()
            return True
        if stripped.startswith("seven cloud plan"):
            show_plan_overview(
                tr("settings.cloud_sync", "Synchronisation"),
                tr("settings.cloud_sync.note", "Ce que SevenOS préparerait pour synchroniser tes données."),
                [str(ROOT / "bin/seven"), "cloud", "plan"],
            )
            return True
        if stripped.startswith("seven manifest restore-plan"):
            show_plan_overview(
                tr("settings.restore_plan", "Restauration"),
                tr("settings.restore_plan.note", "Plan lisible des éléments restaurables."),
                [str(ROOT / "bin/seven"), "manifest", "restore-plan"],
            )
            return True
        if stripped.startswith("seven shield audit"):
            show_security_overview()
            return True
        if stripped.startswith("seven hypr lua audit"):
            show_interface_overview()
            return True
        if stripped.startswith("seven identity"):
            show_interface_overview()
            return True
        return False

    def mark_action_running(button: Gtk.Button, message: str | None = None) -> None:
        old_label = button.get_label() or ""
        if old_label:
            button.set_label(tr("settings.running", "En cours…"))
        button.get_style_context().add_class("busy")
        button.set_sensitive(False)
        if message:
            show_feedback(message)

        def restore() -> bool:
            if old_label:
                button.set_label(old_label)
            button.get_style_context().remove_class("busy")
            button.set_sensitive(True)
            return False

        GLib.timeout_add(760, restore)

    def nav(name: str, icon: str, label: str, target: str) -> None:
        button = Gtk.Button()
        button.get_style_context().add_class("nav-button")
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=11)
        glyph = Gtk.Label(label=icon)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        text.set_hexpand(True)
        row.pack_start(glyph, False, False, 0)
        row.pack_start(text, True, True, 0)
        button.add(row)
        button.connect("clicked", lambda clicked: activate_page(target, clicked))
        nav_buttons.append(button)
        nav_by_target[target] = button
        sidebar.pack_start(button, False, False, 0)

    def section(container: Gtk.Box, text: str) -> None:
        label = Gtk.Label(label=text.upper())
        label.set_xalign(0)
        label.get_style_context().add_class("section-label")
        container.pack_start(label, False, False, 0)

    def status_grid(container: Gtk.Box, items: list[tuple[str, str]]) -> None:
        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.START)
        for index, (value, label) in enumerate(items):
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
            card.get_style_context().add_class("status-card")
            value_label = Gtk.Label(label=value)
            value_label.set_xalign(0)
            value_label.get_style_context().add_class("status-value")
            note = Gtk.Label(label=label)
            note.set_xalign(0)
            note.get_style_context().add_class("status-label")
            card.pack_start(value_label, False, False, 0)
            card.pack_start(note, False, False, 0)
            card.set_size_request(118, -1)
            grid.attach(card, index % 3, index // 3, 1, 1)
        container.pack_start(grid, False, False, 0)

    def card_grid(container: Gtk.Box, cards: list[Gtk.Widget], columns: int = 2) -> None:
        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.START)
        for index, card in enumerate(cards):
            card.set_hexpand(False)
            card.set_size_request(card_width if columns > 1 else content_width, -1)
            grid.attach(card, index % columns, index // columns, 1, 1)
        container.pack_start(grid, False, False, 0)

    def hero_card(title: str, note: str, actions: list[Gtk.Widget] | None = None) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("hero-card")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("hero-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("hero-note")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(note_label, False, False, 0)
        if actions:
            action_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            action_row.set_halign(Gtk.Align.START)
            action_row.set_margin_top(8)
            for action in actions:
                action_row.pack_start(action, False, False, 0)
            card.pack_start(action_row, False, False, 0)
        return card

