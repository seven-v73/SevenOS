    def show_profile_workflow() -> None:
        catalog = profile_catalog()
        profile_defs = catalog.get("profiles", {}) if isinstance(catalog.get("profiles"), dict) else {}
        naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
        current_key = active_profile_key()
        profile_icons = {
            "equinox": "󰐃",
            "baobab": "󰣇",
            "forge": "󰅩",
            "shield": "󰒃",
            "studio": "󰏗",
            "atlas": "󰙅",
            "pulse": "󰊴",
        }
        rows: list[tuple[str, str, str, str | None]] = []
        for key in ["equinox", "baobab", "forge", "shield", "studio", "atlas", "pulse"]:
            data = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
            title = str(data.get("title") or naming.get(key) or key.title())
            purpose = str(data.get("purpose") or data.get("description") or "")
            rows.append((profile_icons.get(key, "󰐃"), title, purpose, tr("settings.active", "Actif") if key == current_key else None))
        info_dialog(
            tr("settings.mini_os_profiles", "Mini OS"),
            tr("settings.profile_workflow.public_note", "Chaque mini OS a un objectif clair. Le changement applique l’espace, recharge les surfaces et garde les données séparées."),
            rows,
            width=700,
            height=560,
        )

    def show_network_overview() -> None:
