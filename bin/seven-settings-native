    def recommendation_card() -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("recommendation-card")
        title = Gtk.Label(label=tr("settings.recommendations.title", "Recommandé maintenant"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=tr("settings.recommendations.note", "SevenOS lit l’état actuel et propose les raccourcis les plus utiles. Rien n’est appliqué sans action de ta part."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        card.pack_start(title, False, False, 0)
        card.pack_start(note, False, False, 0)

        recommendations: list[tuple[str, str, str, str, Gtk.Button]] = []

        def add(icon: str, title_text: str, note_text: str, state: str, button: Gtk.Button) -> None:
            if len(recommendations) < 4:
                recommendations.append((icon, title_text, note_text, state, button))

        wifi_radio_now, wifi_detail_now = wifi_state()
        if wifi_radio_now.lower() in {"off", "disabled"} or "not connected" in wifi_detail_now.lower() or "non connecté" in wifi_detail_now.lower():
            add(
                "󰤨",
                tr("settings.recommendation.network.title", "Reconnecter le réseau"),
                tr("settings.recommendation.network.note", "La connexion n’est pas claire. Ouvre le panneau Wi-Fi avant de lancer une action système."),
                "attention",
                callback_button(tr("settings.open", "Ouvrir"), "network:overview", lambda: (activate_page("network", nav_by_target["network"]), show_network_overview())),
            )

        battery_value, battery_note = battery_state()
        try:
            battery_percent = int(str(battery_value).strip().rstrip("%"))
        except Exception:
            battery_percent = 100
        if battery_percent <= 25 and "charg" not in battery_note.lower() and battery_value != "AC":
            add(
                "󰁹",
                tr("settings.recommendation.power.title", "Préserver la batterie"),
                tr("settings.recommendation.power.note", "La batterie est basse. Passe en économie ou ajuste la veille."),
                "attention",
                callback_button(tr("settings.open", "Ouvrir"), "power:overview", lambda: (activate_page("power", nav_by_target["power"]), show_power_overview())),
            )

        shield_value, shield_note = shield_state()
        if not str(shield_value).startswith(("100", "OK")):
            add(
                "󰒃",
                tr("settings.recommendation.security.title", "Vérifier la protection"),
                tr("settings.recommendation.security.note", "Shield indique un état à confirmer. Lance un résumé avant les changements importants."),
                "attention",
                callback_button(tr("settings.summary", "Résumé"), "security:dashboard", show_security_dashboard),
            )

        if SETTINGS_ACTION_LOG.exists():
            add(
                "󰋚",
                tr("settings.recommendation.history.title", "Relire les dernières actions"),
                tr("settings.recommendation.history.note", "Un historique existe. Utile si un changement récent a modifié l’interface."),
                "good",
                callback_button(tr("settings.open", "Ouvrir"), "settings:action-history", show_settings_action_history),
            )

        add(
            "󰄬",
            tr("settings.recommendation.quick_check.title", "Faire un contrôle léger"),
            tr("settings.recommendation.quick_check.note", "Vérifie rapidement l’état SevenOS sans modifier la machine."),
            "good",
            action_button(tr("settings.check", "Vérifier"), "seven smoke doctor"),
        )
        add(
            "󰔎",
            tr("settings.recommendation.theme.title", "Resynchroniser le thème"),
            tr("settings.recommendation.theme.note", "À utiliser si une app reste en clair/sombre après un changement."),
            "good",
            action_button(tr("settings.resync", "Resynchroniser"), "seven theme sync"),
        )

        for icon, row_title, row_note, state, button in recommendations:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.get_style_context().add_class("recommendation-row")
            row.get_style_context().add_class(state)
            glyph = Gtk.Label(label=icon)
            glyph.get_style_context().add_class("recommendation-icon")
