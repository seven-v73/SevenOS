        nav_buttons[0].get_style_context().add_class("active")
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    page = next((arg for arg in sys.argv[1:] if not arg.startswith("-")), "overview")
    return run(page)


if __name__ == "__main__":
    raise SystemExit(main())
