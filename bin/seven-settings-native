            ("󰐃", tr("settings.active_mini_os", "Mini OS actif"), profile_name, profile_status),
            ("󰸉", tr("settings.wallpaper", "Fond d’écran"), tr("settings.wallpaper_dynamic_note", "Fond, palette et surfaces restent synchronisés."), None),
            ("󰃣", tr("settings.dock", "Dock"), tr("settings.dock.appearance_note", "Dock SevenOS avec présence discrète et autohide."), None),
            ("󰇄", tr("settings.shell_bar", "Barre de menu"), tr("settings.shell_bar.note", "Réparer et relancer la barre de menu SevenOS."), None),
            ("󰆍", tr("settings.terminal_style", "Style du terminal"), tr("settings.terminal_style.note", "Le terminal suit l’identité du mini OS actif."), None),
