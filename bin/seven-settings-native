    def search_norm(value: str) -> str:
        normalized = unicodedata.normalize("NFKD", value or "")
        return "".join(ch for ch in normalized if not unicodedata.combining(ch)).lower()

    def search_settings(_entry=None) -> None:
        query = search_norm(search_entry.get_text().strip())
        if not query:
            search_results.hide()
            return
        for target, terms in settings_search_index.items():
            page_title = search_norm(pages[target][0].get_children()[0].get_text())
            if query in search_norm(terms) or query in page_title:
                activate_page(target, nav_by_target[target])
                show_feedback(page_opened_message(target))
                return
        show_feedback(tr("settings.search.no_result", "Aucune page ne correspond à “{query}”.", query=query), "warning")

    search_entry.connect("activate", search_settings)

    def search_key(_entry, event) -> bool:
        if event.keyval == Gdk.KEY_Escape:
            search_entry.set_text("")
            search_results.hide()
            return True
        if event.keyval in {Gdk.KEY_Down, Gdk.KEY_Tab, Gdk.KEY_Up} and search_results.get_visible():
            children = [child for child in search_results.get_children() if isinstance(child, Gtk.Button)]
            if children:
                children[-1 if event.keyval == Gdk.KEY_Up else 0].grab_focus()
                return True
        return False

    search_entry.connect("key-press-event", search_key)

