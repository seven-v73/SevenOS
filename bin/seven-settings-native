        settings_row("󰛖", tr("settings.apply_default_roles", "Restaurer les polices SevenOS"), tr("settings.apply_default_roles.note", "Réappliquer les polices recommandées pour l’interface et le texte."), [action_button(tr("settings.apply", "Appliquer"), "seven fonts apply-default")]),
        settings_row("󰈙", tr("settings.import_font_files", "Importer des polices"), tr("settings.import_font_files.note", "Ajouter des fichiers de police à la bibliothèque SevenOS."), [import_fonts_button(tr("settings.import", "Importer"))]),
        settings_row("󰉋", tr("settings.font_library", "Dossier des polices"), tr("settings.font_library.note", "Ouvrir le dossier pour glisser-déposer des polices."), [action_button(tr("settings.open", "Ouvrir"), "seven fonts open")]),
        settings_row("󰜉", tr("settings.refresh_cache", "Actualiser les polices"), tr("settings.refresh_cache.note", "Rendre visibles les polices ajoutées ou retirées."), [action_button(tr("settings.refresh", "Actualiser"), "seven fonts refresh")]),
        settings_row("󰌢", tr("settings.advanced_roles", "Réglages avancés"), tr("settings.advanced_roles.note", "Modifier les rôles de police seulement si nécessaire."), [action_button(tr("settings.edit", "Modifier"), "seven fonts prefs")]),
        settings_row("󰄬", tr("settings.font_status", "Aperçu des polices"), tr("settings.font_status.note", "Voir les familles de polices utilisées par SevenOS."), [action_button(tr("settings.status", "Voir"), "seven fonts status")]),
    ])

    # Security
    security = pages["security"][0]
    settings_group(security, tr("settings.trust", "Confiance"), [
        settings_row("󰒃", "Shield", f"{shield_percent} · {shield_posture}", [action_button(tr("settings.open", "Ouvrir"), "seven-shield-center-native")]),
        settings_row("󰞀", tr("settings.enable_protection", "Activer la protection"), tr("settings.enable_protection.note", "Appliquer les protections recommandées."), [action_button(tr("settings.enable", "Activer"), "seven shield enable")]),
        settings_row("󰄬", tr("settings.audit", "Vérifier la sécurité"), tr("settings.audit.note", "Contrôler les points de confiance et les protections actives."), [action_button(tr("settings.audit", "Vérifier"), "seven shield audit")]),
        settings_row("󱗼", "CyberSpace", tr("settings.cyberspace.note", "Ouvrir l’espace spécialisé de cybersécurité."), [action_button(tr("settings.open", "Ouvrir"), "seven shield mode")]),
    ])

    # Profiles
    profiles = pages["profiles"][0]
    catalog = profile_catalog()
    profile_defs = catalog.get("profiles", {}) if isinstance(catalog.get("profiles"), dict) else {}
    naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
    current_profile_key = active_profile_key()
    profile_icons = {
        "equinox": "󰐃",
        "baobab": "󰣇",
        "forge": "󰅩",
        "shield": "󰒃",
        "studio": "󰏗",
        "windows": "󰖳",
        "pulse": "󰊴",
    }
    profile_notes = {
        "equinox": tr("settings.profile.equinox.note", "Espace équilibré pour l’usage quotidien."),
        "baobab": tr("settings.profile.baobab.note", "Espace culturel pour patrimoine, langues, récits, sons, cartes et mémoire hors ligne."),
        "forge": tr("settings.profile.forge.note", "Espace de développement pour code, projets, services locaux et livraisons."),
        "shield": tr("settings.profile.shield.note", "Espace sécurité pour vérifications autorisées, protection et rapports."),
        "studio": tr("settings.profile.studio.note", "Espace création pour design, vidéo, audio, 3D, capture et assets."),
        "windows": tr("settings.profile.windows.note", "Espace Windows pour les applications compatibles et les dossiers partagés."),
        "pulse": tr("settings.profile.pulse.note", "Espace gaming pour jeux, manettes, performance et captures."),
    }

    profiles.pack_start(
        hero_card(
            tr("settings.profiles.hero.title", "Chaque mini OS garde son espace"),
            tr(
                "settings.profiles.hero.note",
            "Chaque espace garde ses données et ses habitudes. Tu peux ajouter des outils explicitement, sans mélange silencieux.",
            ),
        ),
        False,
        False,
        0,
    )
    status_grid(
        profiles,
        [
            (profile_name, tr("settings.active_mini_os", "Mini OS actif")),
            (profile_status, tr("settings.profile_state", "État")),
            (str(len(naming) or len(profile_defs)), tr("settings.profile_count", "Espaces")),
            (current_profile_key, tr("settings.runtime_key", "Nom court")),
            ("SevenOS", tr("settings.profile_model", "Modèle")),
            (tr("settings.collaboration", "Partage"), tr("settings.no_pollution", "Sur demande")),
        ],
    )
    section(profiles, tr("settings.profile_center", "Gestion des mini OS"))
    settings_group(
        profiles,
        "",
        [
            settings_row("󰐃", tr("settings.profile_center", "Vue complète"), tr("settings.profile_center.note", "Ouvrir le tableau de bord des mini OS."), [action_button(tr("settings.open", "Ouvrir"), "seven-profile-center-native")]),
            settings_row("󰮍", tr("settings.composition_layer", "Outils ajoutés"), tr("settings.composition_layer.note", "Voir les outils ajoutés à l’espace actif."), [page_button(tr("settings.open", "Ouvrir"), "general")]),
            settings_row("󰄬", tr("settings.compare_profiles", "Comparer les espaces"), tr("settings.compare_profiles.note", "Comparer les espaces avant de changer."), [action_button(tr("settings.open", "Ouvrir"), "seven-profile-center-native")]),
            settings_row("󰜉", tr("settings.profile_runtime", "Dossiers et apps"), tr("settings.profile_runtime.note", "Ouvrir l’espace actif dans Seven Files."), [action_button(tr("settings.open", "Ouvrir"), f"seven-files profile {current_profile_key}")]),
            settings_row("󰁨", tr("settings.profile_aliases", "Nettoyer les anciens noms"), tr("settings.profile_aliases.note", "Retirer les anciens noms de profils pour éviter la confusion."), [action_button(tr("settings.repair", "Réparer"), "seven profile migrate-aliases --apply")]),
        ],
    )
    section(profiles, tr("settings.mini_os_profiles", "Mini OS"))
    profile_rows = []
    profile_order = ["equinox", "baobab", "forge", "shield", "studio", "windows", "pulse"]
    for key in profile_order:
        data = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
        title = str(data.get("title") or naming.get(key) or key.title())
        state_prefix = f"{tr('settings.active', 'Actif')} · " if key == current_profile_key else ""
        note = state_prefix + profile_notes.get(key, str(data.get("purpose") or ""))
        center_command = str((data.get("profile_surfaces") or {}).get("center") or data.get("center_command") or f"seven-mini-os-center {key}")
        controls = []
        if key != current_profile_key:
            controls.append(
                action_button(
                    tr("settings.activate", "Activer"),
                    f"seven profile activate {key}",
                    tr("settings.profile_switching", "Changement de mini OS demandé."),
                )
            )
        controls.append(action_button(tr("settings.center", "Ouvrir"), center_command))
        profile_rows.append(
            settings_row(
                profile_icons.get(key, "󰐃"),
                title,
                note,
                controls,
            )
        )
    settings_group(profiles, "", profile_rows)

    # Power
    power = pages["power"][0]
    settings_group(power, tr("settings.energy", "Énergie"), [
        settings_row("󰁹", tr("settings.battery", "Batterie"), f"{battery} · {battery_status}", [action_button(tr("settings.panel", "Détails"), "seven-waybar-center-native power")]),
        settings_row("󰈐", tr("settings.power_profile", "Mode d’énergie"), tr("settings.power_profile.note", "Voir ou changer le comportement énergie/performance."), [action_button(tr("settings.open", "Ouvrir"), "powerprofilesctl")]),
        settings_row("󰍁", tr("settings.lock", "Verrouiller"), tr("settings.lock.note", "Verrouiller la session SevenOS."), [action_button(tr("settings.lock", "Verrouiller"), "seven-power lock")]),
        settings_row("󰜉", tr("settings.power_menu", "Menu d’alimentation"), tr("settings.power_menu.note", "Veille, redémarrage et extinction."), [action_button(tr("settings.open", "Ouvrir"), "seven-power")]),
    ])

    # Privacy
    privacy = pages["privacy"][0]
    privacy.pack_start(hero_card(tr("settings.privacy.hero.title", "Local par défaut"), tr("settings.privacy.hero.note", "SevenOS doit montrer clairement ce qu’il garde, ce qu’il indexe et quelles apps peuvent utiliser les appareils sensibles.")), False, False, 0)
    settings_group(privacy, tr("settings.privacy", "Confidentialité"), [
        settings_row("󰂚", tr("settings.notifications", "Notifications"), tr("settings.notifications.note", "Ouvrir l’historique, le mode Ne pas déranger et les contrôles de notifications."), [action_button(tr("settings.open", "Ouvrir"), "seven-waybar-notifications menu")]),
        settings_row("󰌾", tr("settings.local_ai_data", "Données SevenAI"), tr("settings.local_ai_data.note", "Voir ce que SevenAI garde localement et comment il protège la confidentialité."), [action_button(tr("settings.open", "Ouvrir"), "seven ai provider")]),
        settings_row("󰍬", tr("settings.microphone_camera", "Microphone et caméra"), tr("settings.microphone_camera.note", "Ouvrir les appareils audio et les surfaces de permission disponibles."), [action_button(tr("settings.open", "Ouvrir"), "pavucontrol || wpctl status")]),
        settings_row("󰚰", tr("settings.spotlight_history", "Historique Spotlight"), tr("settings.spotlight_history.note", "Voir ou effacer l’historique récent de recherche."), [action_button(tr("settings.open", "Ouvrir"), "seven-spotlight history")]),
    ])

    # Backup and restore
    backup = pages["backup"][0]
    backup.pack_start(hero_card(tr("settings.backup.hero.title", "Protéger avant de changer"), tr("settings.backup.hero.note", "SevenOS peut sauvegarder l’état, préparer une restauration et protéger les réglages avant une grosse modification.")), False, False, 0)
    settings_group(backup, tr("settings.backup_restore", "Sauvegarde et restauration"), [
        settings_row("󰁯", tr("settings.export_state", "Exporter un résumé"), tr("settings.export_state.note", "Créer un résumé lisible de SevenOS pour l’aide ou la migration."), [action_button(tr("settings.open", "Ouvrir"), "seven state --json")]),
        settings_row("󰕒", tr("settings.restore_plan", "Plan de restauration"), tr("settings.restore_plan.note", "Voir ce qui sera protégé avant de modifier le système."), [action_button(tr("settings.open", "Ouvrir"), "seven manifest restore-plan")]),
        settings_row("󰄬", tr("settings.migration_backup", "Sauvegarde de migration"), tr("settings.migration_backup.note", "Créer une sauvegarde protégée de la configuration SevenOS."), [action_button(tr("settings.run", "Lancer"), "seven migrate backup")]),
        settings_row("󰒋", "SevenCloud", tr("settings.sevencloud.note", "Voir la préparation de sauvegarde locale."), [action_button(tr("settings.open", "Ouvrir"), "seven cloud plan")]),
    ])

    # Shortcuts
    shortcuts = pages["shortcuts"][0]
    shortcuts.pack_start(hero_card(tr("settings.shortcuts.hero.title", "Tout a un chemin visible"), tr("settings.shortcuts.hero.note", "Les raccourcis importants sont dans Aide, et Settings garde les actions accessibles sans console.")), False, False, 0)
    settings_group(shortcuts, tr("settings.shortcuts", "Raccourcis"), [
        settings_row("󰩂", tr("settings.help_center", "Aide SevenOS"), tr("settings.help_center.note", "Ouvrir la documentation Super+H avec les commandes utiles et les mini OS."), [action_button(tr("settings.open", "Ouvrir"), "seven-help")]),
        settings_row("󰄬", tr("settings.shortcut_audit", "Vérifier les raccourcis"), tr("settings.shortcut_audit.note", "Contrôler que les raccourcis SevenOS sont bien générés."), [action_button(tr("settings.check", "Vérifier"), "seven hypr lua audit")]),
        settings_row("󰜉", tr("settings.regenerate_shortcuts", "Reconstruire les raccourcis"), tr("settings.regenerate_shortcuts.note", "Reconstruire les raccourcis SevenOS et rafraîchir l’interface."), [action_button(tr("settings.apply", "Appliquer"), "seven hypr lua apply")]),
        settings_row("󰌢", tr("settings.keyboard_override", "Réglage clavier avancé"), tr("settings.keyboard_override.note", "Ouvrir le réglage clavier manuel si nécessaire."), [action_button(tr("settings.edit", "Modifier"), "xdg-open ~/.config/hypr/conf/keyboard.conf")]),
    ])

    # Apps
    apps = pages["apps"][0]
    settings_group(apps, tr("settings.software", "Applications"), [
        settings_row("󰀻", "Launchpad", tr("settings.launchpad.apps.note", "Parcourir les applications installées."), [action_button(tr("settings.open", "Ouvrir"), "seven-overview apps")]),
        settings_row("󰏗", tr("settings.sevenpkg_public", "Applications installées"), tr("settings.sevenpkg.note", "Voir et installer les apps graphiquement."), [action_button(tr("settings.status", "Voir"), "seven-store")]),
        settings_row("󰈙", tr("settings.software_sources", "Sources d’apps"), tr("settings.software_sources.note", "Voir les sources d’applications utilisées par SevenOS."), [action_button(tr("settings.status", "Voir"), "seven flatpak status || flatpak list")]),
        settings_row("󰉋", tr("settings.applications_folder", "Dossier Applications"), tr("settings.applications_folder.note", "Ouvrir les lanceurs d’applications."), [action_button(tr("settings.open", "Ouvrir"), "xdg-open /usr/share/applications")]),
    ])

    # System
    system = pages["system"][0]
    settings_group(system, tr("settings.maintenance", "Maintenance"), [
        settings_row("󰚰", tr("settings.system_updates", "Mises à jour"), tr("settings.system_updates.note", "Mettre à jour SevenOS et les applications."), [action_button(tr("settings.update", "Mettre à jour"), "seven update")]),
        settings_row("󰏗", tr("settings.package_status", "Applications"), tr("settings.package_status.note", "Ouvrir SevenStore pour gérer les apps."), [action_button(tr("settings.open", "Ouvrir"), "seven-store")]),
        settings_row("󰄬", tr("settings.daily_gate", "Prêt pour le quotidien"), tr("settings.daily_gate.note", "Vérifier que SevenOS est prêt comme système principal."), [action_button(tr("settings.check", "Vérifier"), "seven daily")]),
        settings_row("󰩂", tr("settings.doctor", "Assistant de vérification"), tr("settings.doctor.note", "Diagnostiquer les soucis courants."), [action_button(tr("settings.run", "Lancer"), "seven doctor")]),
        settings_row("󰒓", tr("settings.runtime_status", "Résumé SevenOS"), tr("settings.runtime_status.note", "Ouvrir le résumé lisible de SevenOS."), [action_button(tr("settings.open", "Ouvrir"), "seven status")]),
        settings_row("󰜉", tr("settings.repair_ui", "Réparer l’interface"), tr("settings.repair_ui.note", "Réappliquer le thème, rafraîchir l’interface et réparer la barre."), [action_button(tr("settings.repair", "Réparer"), "./install.sh theme && hyprctl reload && seven-waybar repair")]),
        settings_row("󰌢", tr("settings.logs", "Alertes récentes"), tr("settings.logs.note", "Voir les avertissements récents dans une vue lisible."), [action_button(tr("settings.open", "Ouvrir"), "seven-doctor-native logs")]),
    ])

    stack.set_visible_child_name(initial_page)
    if initial_page in nav_by_target:
        nav_by_target[initial_page].get_style_context().add_class("active")
    elif nav_buttons:
        nav_buttons[0].get_style_context().add_class("active")
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    page = next((arg for arg in sys.argv[1:] if not arg.startswith("-")), "overview")
    return run(page)


if __name__ == "__main__":
    raise SystemExit(main())
