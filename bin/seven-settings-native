    def should_show_output(command: str) -> bool:
        stripped = command.strip()
        gui_prefixes = (
            "seven-files",
            "seven-overview",
            "seven-spotlight",
            "seven-help-native",
            "seven-terminal",
            "seven-profile-center-native",
            "seven-waybar-center-native",
            "seven-waybar-notifications",
            "seven-quick-settings",
            "seven-shield-center-native",
            "seven-doctor-native",
            "seven-installer",
            "seven-store",
            "seven-power",
            "seven-bluetooth",
            "xdg-open",
            "pavucontrol",
            "nm-connection-editor",
            "wdisplays",
            "nwg-displays",
            "arandr",
        )
        instant_prefixes = (
            "wpctl set-mute",
            "wpctl set-volume",
            "brightnessctl",
            "seven-power lock",
        )
        if stripped.startswith(gui_prefixes + instant_prefixes):
            return False
        if "install.sh theme" in stripped or "seven-waybar repair" in stripped or "hyprctl reload" in stripped:
            return True
        if stripped.startswith(("seven ", "seven-", "sevenpkg", "journalctl", "powerprofilesctl", "flatpak list")):
            return True
        return stripped.startswith(output_action_prefixes)

    def collect_update_items() -> list[dict[str, str]]:
        items: list[dict[str, str]] = []

        def command_lines(command: list[str], timeout: float = 3.5) -> list[str]:
            try:
                result = subprocess.run(
                    command,
                    cwd=ROOT,
                    env={**os.environ, "SEVENOS_ROOT": str(ROOT), "LC_ALL": "C"},
                    text=True,
                    capture_output=True,
                    check=False,
                    timeout=timeout,
                )
            except Exception:
                return []
            return [line.strip() for line in result.stdout.splitlines() if line.strip()]

        if command_exists("pacman"):
            for line in command_lines(["pacman", "-Qu"], timeout=3.0):
                parts = line.split()
                if len(parts) >= 2:
                    items.append({"name": parts[0], "version": " ".join(parts[1:]), "source": tr("settings.update.source.system", "Système"), "kind": "system"})

        if command_exists("flatpak"):
            for line in command_lines(["flatpak", "remote-ls", "--updates", "--columns=application,version", "flathub"], timeout=3.5):
                parts = line.split()
                if parts:
                    version = parts[-1] if len(parts) > 1 else tr("settings.update", "Mise à jour")
                    name = " ".join(parts[:-1]) if len(parts) > 1 else parts[0]
                    items.append({"name": name, "version": version, "source": tr("settings.update.source.apps", "Apps"), "kind": "apps"})

        aur_helper = "paru" if command_exists("paru") else "yay" if command_exists("yay") else ""
        if aur_helper:
            for line in command_lines([aur_helper, "-Qua"], timeout=3.0):
                parts = line.split()
                if len(parts) >= 2:
                    items.append({"name": parts[0], "version": " ".join(parts[1:]), "source": tr("settings.update.source.community", "Apps externes"), "kind": "community"})

        return items

