    def show_alerts_overview() -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        try:
            result = subprocess.run(["journalctl", "-p", "warning", "-b", "-n", "12", "--no-pager"], text=True, capture_output=True, check=False, timeout=1.5)
            for line in result.stdout.splitlines():
                if not line.strip() or line.startswith("--"):
                    continue
                rows.append(("󰌢", tr("settings.alert", "Alerte"), line[-180:], None))
        except Exception:
            pass
        info_dialog(
            tr("settings.logs", "Alertes récentes"),
            tr("settings.alerts_overview.note", "Événements récents qui peuvent demander ton attention."),
            rows or [("✓", tr("settings.no_alerts", "Aucune alerte récente"), tr("settings.no_alerts.note", "SevenOS ne voit rien d’important pour le moment."), None)],
            width=680,
            height=520,
        )

    def handle_graphical_action(command: str) -> bool:
        stripped = command.strip()
        if stripped in {"seven language status", "seven language list"}:
            show_language_overview()
            return True
        if stripped == "seven-files resources status":
            show_files_resources_overview()
            return True
        if stripped == "sevenpkg status":
            show_software_overview()
            return True
        if stripped.startswith("seven flatpak status") or stripped.startswith("flatpak list"):
            show_app_sources_overview()
            return True
        if stripped.startswith(("seven mini-os status", "seven runtime", "seven runtime plan")):
            show_mini_os_overview(stripped)
            return True
        if stripped in {"seven status", "seven state --json"}:
            show_system_overview()
            return True
        if stripped.startswith("journalctl"):
            show_alerts_overview()
            return True
        if stripped.startswith("hyprctl monitors"):
            show_display_overview()
            return True
        if stripped.startswith("seven keyboard status"):
            show_keyboard_overview()
            return True
        if stripped in {"seven-wifi connect", "seven-waybar-center-native network"} or stripped.startswith("nm-connection-editor"):
            show_network_overview()
            return True
        if stripped in {"seven-waybar-center-native audio", "pavucontrol || wpctl status"} or stripped.startswith("wpctl status"):
            show_sound_overview()
            return True
        if stripped.startswith("seven fonts status"):
            show_fonts_overview()
            return True
        if stripped in {"seven theme doctor", "seven theme status"}:
            show_theme_session_dashboard(False)
            return True
        if stripped in {"seven theme sync", "seven theme repair", "seven theme session"}:
            show_theme_session_dashboard(True)
            return True
        if stripped.startswith("powerprofilesctl"):
            show_power_overview()
            return True
        if stripped.startswith("seven ai provider"):
            show_ai_overview()
            return True
        if stripped.startswith(("seven-waybar-notifications", "seven-quick-settings notifications", "seven-spotlight history")):
            show_privacy_dashboard()
            return True
        if stripped.startswith("seven cloud plan"):
            show_plan_overview(
                tr("settings.cloud_sync", "Synchronisation"),
                tr("settings.cloud_sync.note", "Ce que SevenOS préparerait pour synchroniser tes données."),
                [str(ROOT / "bin/seven"), "cloud", "plan"],
            )
            return True
        if stripped.startswith("seven manifest restore-plan"):
            show_plan_overview(
                tr("settings.restore_plan", "Restauration"),
                tr("settings.restore_plan.note", "Plan lisible des éléments restaurables."),
                [str(ROOT / "bin/seven"), "manifest", "restore-plan"],
            )
            return True
        if stripped.startswith(("seven shield audit", "seven shield enable")):
            show_security_dashboard()
            return True
        if stripped.startswith("seven recovery plan") or stripped.startswith("seven cloud plan"):
            show_backup_wizard()
            return True
        if stripped.startswith("seven recovery backup"):
            show_command_output(stripped, tr("settings.create_backup", "Créer une sauvegarde SevenOS"))
            return True
        if stripped.startswith("seven shield mode"):
            show_security_overview()
            return True
        if stripped.startswith("seven hypr lua audit"):
            show_interface_overview()
            return True
        if stripped.startswith("seven identity"):
            show_interface_overview()
            return True
        return False

    def mark_action_running(button: Gtk.Button, message: str | None = None) -> None:
        old_label = button.get_label() or ""
        button.sevenos_old_label = old_label
        if old_label:
            button.set_label(tr("settings.running", "En cours…"))
        button.get_style_context().add_class("busy")
        button.set_sensitive(False)
        if message:
            show_feedback(message)

        def restore() -> bool:
            if old_label:
                button.set_label(old_label)
            button.get_style_context().remove_class("busy")
            button.set_sensitive(True)
            return False

        GLib.timeout_add(760, restore)

    def mark_action_done(button: Gtk.Button) -> None:
        old_label = getattr(button, "sevenos_old_label", None)
        if isinstance(old_label, str) and old_label:
            button.set_label(old_label)
        button.get_style_context().remove_class("busy")
        button.set_sensitive(True)

    def pulse_button(button: Gtk.Button, duration: int = 260) -> None:
        button.get_style_context().add_class("busy")

        def restore() -> bool:
            button.get_style_context().remove_class("busy")
            return False

        GLib.timeout_add(duration, restore)

    def button_recently_triggered(button: Gtk.Button, window_ms: int = 650) -> bool:
        now = time.monotonic() * 1000
        last = getattr(button, "sevenos_last_click_ms", None)
        if isinstance(last, (int, float)) and now - float(last) < window_ms:
            return True
        button.sevenos_last_click_ms = now
        return False

    def nav(name: str, icon: str, label: str, target: str) -> None:
        button = Gtk.Button()
        button.get_style_context().add_class("nav-button")
        button.set_tooltip_text(tr("settings.nav.tooltip", "Ouvrir {page}", page=label))
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=11)
        glyph = Gtk.Label(label=icon)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        text.set_hexpand(True)
        text.set_ellipsize(Pango.EllipsizeMode.END)
        text.set_max_width_chars(18 if compact_screen else 22)
        row.pack_start(glyph, False, False, 0)
        row.pack_start(text, True, True, 0)
        button.add(row)
        button.connect("clicked", lambda clicked: activate_page(target, clicked))
        nav_buttons.append(button)
        nav_by_target[target] = button
        nav_titles[target] = label
        sidebar.pack_start(button, False, False, 0)

    def sidebar_section(label: str) -> None:
        section_label = Gtk.Label(label=label.upper())
        section_label.set_xalign(0)
        section_label.get_style_context().add_class("sidebar-section-label")
        sidebar.pack_start(section_label, False, False, 0)

    def section(container: Gtk.Box, text: str) -> None:
        label = Gtk.Label(label=text.upper())
        label.set_xalign(0)
        label.get_style_context().add_class("section-label")
        container.pack_start(label, False, False, 0)

    def status_grid(container: Gtk.Box, items: list[tuple[str, str]]) -> None:
        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.START)
        columns = 2 if content_width < 620 else 3
        status_width = max(150, int((content_width - (10 * (columns - 1))) / columns))
        for index, (value, label) in enumerate(items):
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
            card.set_can_focus(True)
            card.set_tooltip_text(f"{label}: {value}")
            card.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
            card.connect("button-press-event", lambda widget, _event: (widget.grab_focus(), False)[1])
            card.get_style_context().add_class("status-card")
            value_label = Gtk.Label(label=value)
            value_label.set_xalign(0)
            value_label.set_ellipsize(Pango.EllipsizeMode.END)
            value_label.set_max_width_chars(22)
            value_label.get_style_context().add_class("status-value")
            note = Gtk.Label(label=label)
            note.set_xalign(0)
            note.set_line_wrap(True)
            note.set_max_width_chars(28)
            note.get_style_context().add_class("status-label")
            card.pack_start(value_label, False, False, 0)
            card.pack_start(note, False, False, 0)
            card.set_size_request(status_width, -1)
            grid.attach(card, index % columns, index // columns, 1, 1)
        container.pack_start(grid, False, False, 0)

    def card_grid(container: Gtk.Box, cards: list[Gtk.Widget], columns: int = 2) -> None:
        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.START)
        for index, card in enumerate(cards):
            card.set_hexpand(False)
            card.set_size_request(card_width if columns > 1 else content_width, -1)
            grid.attach(card, index % columns, index // columns, 1, 1)
        container.pack_start(grid, False, False, 0)

    def action_flow(actions: list[Gtk.Widget]) -> Gtk.FlowBox:
        flow = Gtk.FlowBox()
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_halign(Gtk.Align.START)
        flow.set_valign(Gtk.Align.CENTER)
        flow.set_column_spacing(8)
        flow.set_row_spacing(8)
        flow.set_max_children_per_line(4)
        flow.get_style_context().add_class("settings-action-flow")
        for action in actions:
            flow.add(action)
        return flow

    def hero_card(title: str, note: str, actions: list[Gtk.Widget] | None = None) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("hero-card")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("hero-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("hero-note")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(note_label, False, False, 0)
        if actions:
            flow = action_flow(actions)
            flow.set_margin_top(8)
            card.pack_start(flow, False, False, 0)
        return card

    def workflow_card(title: str, note: str, steps: list[tuple[str, str]], actions: list[Gtk.Widget] | None = None) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=9)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("settings-insight-card")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("hero-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("hero-note")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(note_label, False, False, 0)
        for index, (step_title, step_note) in enumerate(steps, start=1):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.set_can_focus(True)
            row.set_tooltip_text(f"{step_title}\n{step_note}")
            row.get_style_context().add_class("settings-workflow-row")
            badge = Gtk.Label(label=str(index))
            badge.get_style_context().add_class("settings-workflow-index")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            step = Gtk.Label(label=step_title)
            step.set_xalign(0)
            step.get_style_context().add_class("settings-row-title")
            detail = Gtk.Label(label=step_note)
            detail.set_xalign(0)
            detail.set_line_wrap(True)
            detail.get_style_context().add_class("settings-row-note")
            labels.pack_start(step, False, False, 0)
            labels.pack_start(detail, False, False, 0)
            row.pack_start(badge, False, False, 0)
            row.pack_start(labels, True, True, 0)
            card.pack_start(row, False, False, 0)
        if actions:
            card.pack_start(action_flow(actions), False, False, 0)
        return card

    def solution_button(icon: str, title: str, note: str, callback) -> Gtk.Button:
        button = Gtk.Button()
        button.set_can_focus(True)
        button.set_tooltip_text(f"{title}\n{note}")
        button.get_style_context().add_class("solution-tile")
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
        glyph = Gtk.Label(label=icon)
        glyph.set_halign(Gtk.Align.CENTER)
        glyph.get_style_context().add_class("solution-tile-icon")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        labels.set_hexpand(True)
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.set_ellipsize(Pango.EllipsizeMode.END)
        title_label.get_style_context().add_class("solution-tile-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.set_max_width_chars(34)
        note_label.get_style_context().add_class("solution-tile-note")
        labels.pack_start(title_label, False, False, 0)
        labels.pack_start(note_label, False, False, 0)
        row.pack_start(glyph, False, False, 0)
        row.pack_start(labels, True, True, 0)
        button.add(row)

        def clicked(_button) -> None:
            if button_recently_triggered(_button):
                pulse_button(_button, 160)
                return
            pulse_button(_button)
            callback()
            show_feedback(tr("settings.solution.opened", "Aide ouverte : {topic}", topic=title))

        button.connect("clicked", clicked)
        return button

    def show_solution_guide(
        icon: str,
        title_text: str,
        note_text: str,
        steps: list[tuple[str, str]],
        page_name: str,
        summary_callback=None,
    ) -> None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(min(560, max(460, int(workarea_width * 0.42))), min(430, max(320, int(workarea_height * 0.50))))
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(15)

        hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        hero.get_style_context().add_class("guide-dialog-card")
        glyph = Gtk.Label(label=icon)
        glyph.get_style_context().add_class("action-hero-glyph")
        copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        copy.set_hexpand(True)
        title_label = Gtk.Label(label=title_text)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("action-hero-title")
        note_label = Gtk.Label(label=note_text)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("action-hero-note")
        copy.pack_start(title_label, False, False, 0)
        copy.pack_start(note_label, False, False, 0)
        hero.pack_start(glyph, False, False, 0)
        hero.pack_start(copy, True, True, 0)
        box.pack_start(hero, False, False, 0)

        for index, (step_title, step_note) in enumerate(steps, start=1):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.get_style_context().add_class("guide-step")
            badge = Gtk.Label(label=str(index))
            badge.get_style_context().add_class("guide-step-index")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            label = Gtk.Label(label=step_title)
            label.set_xalign(0)
            label.get_style_context().add_class("settings-row-title")
            detail = Gtk.Label(label=step_note)
            detail.set_xalign(0)
            detail.set_line_wrap(True)
            detail.get_style_context().add_class("settings-row-note")
            labels.pack_start(label, False, False, 0)
            labels.pack_start(detail, False, False, 0)
            row.pack_start(badge, False, False, 0)
            row.pack_start(labels, True, True, 0)
            box.pack_start(row, False, False, 0)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_halign(Gtk.Align.END)
        close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
        close_button.get_style_context().add_class("action-button")
        close_button.connect("clicked", lambda _button: dialog.response(Gtk.ResponseType.CLOSE))
        if summary_callback:
            summary_button = Gtk.Button(label=tr("settings.summary", "Résumé"))
            summary_button.get_style_context().add_class("action-button")
            summary_button.connect("clicked", lambda _button: (dialog.response(Gtk.ResponseType.CLOSE), GLib.idle_add(lambda: (summary_callback(), False)[1])))
            actions.pack_start(summary_button, False, False, 0)
        open_button = Gtk.Button(label=tr("settings.open_panel", "Ouvrir le panneau"))
        open_button.get_style_context().add_class("primary-action")
        open_button.connect(
            "clicked",
            lambda _button: (
                dialog.response(Gtk.ResponseType.CLOSE),
                activate_page(page_name, nav_by_target[page_name]),
                show_feedback(page_opened_message(page_name)),
            ),
        )
        actions.pack_start(close_button, False, False, 0)
        actions.pack_start(open_button, False, False, 0)
        box.pack_start(actions, False, False, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def solution_guide_callback(
        icon: str,
        title_text: str,
        note_text: str,
        page_name: str,
        steps: list[tuple[str, str]],
        summary_callback=None,
    ):
        return lambda: show_solution_guide(icon, title_text, note_text, steps, page_name, summary_callback)

