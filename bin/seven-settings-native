    def show_ai_overview() -> None:
        provider = tr("settings.ai_local", "Local")
        privacy = tr("settings.ai_private", "Privé par défaut")
        try:
            result = subprocess.run(
                [str(ROOT / "scripts/ai.sh"), "provider", "--json"],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                text=True,
                capture_output=True,
                check=False,
                timeout=1.0,
            )
            payload = json.loads(result.stdout or "{}")
            if isinstance(payload, dict):
                provider = str(payload.get("provider") or payload.get("name") or provider)
                privacy = str(payload.get("mode") or payload.get("privacy") or privacy)
        except Exception:
            pass
        info_dialog(
            tr("settings.ai", "SevenAI"),
            tr("settings.ai_overview.note", "Assistant local de SevenOS, avec actions confirmées avant application."),
            [
                ("󰚩", tr("settings.ai_provider", "Assistant"), provider, tr("settings.ready", "Prêt")),
                ("󰒃", tr("settings.privacy", "Confidentialité"), privacy, None),
                ("󰜎", tr("settings.ai_actions", "Actions"), tr("settings.ai_actions.note", "Les changements importants demandent toujours une validation."), None),
            ],
        )

    def show_plan_overview(title_text: str, note_text: str, command: list[str]) -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        try:
            result = subprocess.run(
                command,
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                text=True,
                capture_output=True,
                check=False,
                timeout=1.2,
            )
            lines = [line.strip() for line in (result.stdout or result.stderr or "").splitlines() if line.strip()]
        except Exception:
            lines = []
        for line in lines[:10]:
            clean = line.replace("$", "").strip()
            if not clean or clean.startswith("{") or clean.startswith("["):
                continue
            rows.append(("󰄬", tr("settings.plan_item", "Élément"), clean[:180], None))
        info_dialog(
            title_text,
            note_text,
            rows or [("✓", tr("settings.no_action_needed", "Rien à faire"), tr("settings.no_action_needed.note", "SevenOS ne voit aucune action nécessaire pour le moment."), tr("settings.ready", "Prêt"))],
        )

