    def show_mini_os_overview(command: str = "") -> None:
        catalog = profile_catalog()
        profile_defs = catalog.get("profiles", {}) if isinstance(catalog.get("profiles"), dict) else {}
        current_key = active_profile_key()
        rows: list[tuple[str, str, str, str | None]] = []
        for key in ["equinox", "baobab", "forge", "shield", "studio", "windows", "pulse"]:
            data = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
            rows.append(
                (
                    {"equinox": "󰐃", "baobab": "󰣇", "forge": "󰅩", "shield": "󰒃", "studio": "󰏗", "windows": "󰖳", "pulse": "󰊴"}.get(key, "󰐃"),
                    str(data.get("title") or key.title()),
                    str(data.get("purpose") or tr("settings.profile_space", "Espace SevenOS")),
                    tr("settings.active", "Actif") if key == current_key else None,
                )
            )
        info_dialog(
            tr("settings.profiles", "Mini OS"),
            tr("settings.mini_os_overview.note", "Chaque mini OS garde son espace. Les partages restent explicites."),
            rows,
            width=640,
            height=520,
        )

