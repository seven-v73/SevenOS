        ("󰌌", tr("settings.shortcuts", "Shortcuts"), tr("settings.shortcuts.subtitle", "Open, inspect and repair SevenOS keyboard shortcuts."), "shortcuts"),
        ("󰩂", tr("settings.doctor", "Doctor"), tr("settings.doctor.note", "Diagnose common system issues."), "system"),
    ]

    def rebuild_search_results(_entry=None) -> None:
        for child in list(search_results.get_children()):
            search_results.remove(child)
        query = search_entry.get_text().strip().lower()
        if len(query) < 2:
            search_results.hide()
            return
        matches = []
        for icon, title, note, target in search_items:
            haystack = f"{title} {note} {settings_search_index.get(target, '')}".lower()
            if query in haystack:
                matches.append((icon, title, note, target))
        if not matches:
            label = Gtk.Label(label=tr("settings.search.no_result", "No Settings page matched “{query}”.", query=query))
            label.set_xalign(0)
            label.get_style_context().add_class("card-note")
            search_results.pack_start(label, False, False, 0)
        for icon, title, note, target in matches[:6]:
            button = Gtk.Button()
            button.get_style_context().add_class("search-result-button")
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            glyph = Gtk.Label(label=icon)
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            title_label = Gtk.Label(label=title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("card-title")
            note_label = Gtk.Label(label=note)
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("card-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            row.pack_start(glyph, False, False, 0)
            row.pack_start(labels, True, True, 0)
            button.add(row)
            button.connect("clicked", lambda _button, page_name=target: (activate_page(page_name, nav_by_target[page_name]), search_results.hide()))
            search_results.pack_start(button, False, False, 0)
        search_results.show_all()

    search_entry.connect("search-changed", rebuild_search_results)

