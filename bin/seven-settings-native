            tr("settings.network", "Wi-Fi et réseau"),
            tr("settings.network_overview.public_note", "Vue lisible de la connexion actuelle et des réseaux proches. Les mots de passe restent demandés dans le panneau réseau SevenOS."),
            rows,
            width=660,
            height=520,
        )

    def show_sound_overview() -> None:
        rows: list[tuple[str, str, str, str | None]] = [
            ("󰕾", tr("settings.output_volume", "Volume de sortie"), f"{volume_state()}%", tr("settings.active", "Actif")),
        ]
        for route in audio_routes():
            rows.append(("󰕾" if route["kind"] == "sink" else "󰍬", tr("settings.audio_output", "Sortie") if route["kind"] == "sink" else tr("settings.audio_input", "Entrée"), route["label"], None))
        if len(rows) == 1:
            rows.append(("󰄬", tr("settings.audio_status", "Sorties et entrées"), tr("settings.audio_status.unavailable", "Aucun périphérique détaillé reçu de PipeWire pour le moment."), None))
