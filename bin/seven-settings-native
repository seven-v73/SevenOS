#!/usr/bin/env python3
"""Native SevenOS Settings.

This is the normal-user control surface for SevenOS. Spotlight remains the
global command search, while Settings keeps a focused preference search for
people who already know they are changing system behavior.
"""

from __future__ import annotations

import json
import os
import platform
import shutil
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
REGION_PREFS = CONFIG_DIR / "region.conf"
REGION_ENV = CONFIG_DIR / "region.env"
HYPR_CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "hypr" / "conf"
MONITOR_PREFS = HYPR_CONFIG_DIR / "monitor.conf"
MONITOR_BACKUP = HYPR_CONFIG_DIR / "monitor.conf.sevenos.bak"
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr, tr_text  # noqa: E402
import seven_theme  # noqa: E402


def out(command: list[str], fallback: str = "") -> str:
    result = subprocess.run(command, cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, text=True, capture_output=True, check=False)
    return result.stdout.strip() or fallback


def run_json(command: list[str], fallback):
    try:
        return json.loads(out(command, ""))
    except Exception:
        return fallback


def run_detached(command: str) -> None:
    if command.strip() == "seven doctor open":
        command = "seven-doctor-native"
    text_prefixes = (
        "seven daily",
        "seven doctor check",
        "seven doctor fix",
        "seven status",
        "seven update",
        "seven state",
        "seven manifest",
        "seven migrate",
        "seven cloud",
        "seven runtime",
        "seven mini-os",
        "seven hypr",
        "seven ai",
        "seven language status",
        "seven language list",
        "seven language ensure",
        "seven language set",
        "sevenpkg status",
        "seven shield audit",
        "wpctl status",
        "powerprofilesctl",
        "hyprctl monitors",
        "flatpak list",
        "seven-wifi status",
        "btop",
        "journalctl",
    )
    if command.strip().startswith(text_prefixes) and command_exists("seven-terminal"):
        quoted = command.replace("'", "'\"'\"'")
        command = f"seven-terminal classic -- bash -lc '{quoted}; printf \"\\nPress Enter to close...\"; read -r'"
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def command_exists(command: str) -> bool:
    return shutil.which(command) is not None


def current_theme_mode() -> str:
    theme_file = CONFIG_DIR / "theme.conf"
    if theme_file.exists():
        for line in theme_file.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() == "SEVENOS_THEME_MODE":
                value = value.strip().strip('"').strip("'").lower()
                if value in {"dark", "light"}:
                    return value
    return "dark"


def read_region_prefs() -> dict[str, str]:
    prefs = {
        "region": "France",
        "time_format": "24h",
        "date_format": "DD/MM/YYYY",
        "week_start": "Monday",
        "units": "metric",
    }
    if REGION_PREFS.exists():
        for line in REGION_PREFS.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() in prefs and value.strip():
                prefs[key.strip()] = value.strip().strip('"').strip("'")
    return prefs


def write_region_contract(prefs: dict[str, str]) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    REGION_PREFS.write_text("\n".join(f"{name}={prefs[name]}" for name in sorted(prefs)) + "\n", encoding="utf-8")
    REGION_ENV.write_text(
        "\n".join(
            [
                f'export SEVENOS_REGION="{prefs["region"]}"',
                f'export SEVENOS_TIME_FORMAT="{prefs["time_format"]}"',
                f'export SEVENOS_DATE_FORMAT="{prefs["date_format"]}"',
                f'export SEVENOS_WEEK_START="{prefs["week_start"]}"',
                f'export SEVENOS_UNITS="{prefs["units"]}"',
            ]
        )
        + "\n",
        encoding="utf-8",
    )


def write_region_pref(key: str, value: str) -> None:
    prefs = read_region_prefs()
    prefs[key] = value
    write_region_contract(prefs)


def region_sample(prefs: dict[str, str]) -> str:
    date_samples = {
        "DD/MM/YYYY": "20/05/2026",
        "MM/DD/YYYY": "05/20/2026",
        "YYYY-MM-DD": "2026-05-20",
    }
    time_sample = "22:40" if prefs.get("time_format") == "24h" else "10:40 PM"
    units_sample = "km · kg · °C" if prefs.get("units") == "metric" else "mi · lb · °F"
    return f"{date_samples.get(prefs.get('date_format', ''), '2026-05-20')} · {time_sample} · {units_sample}"


def xdg_default(mime: str) -> str:
    if not command_exists("xdg-mime"):
        return tr_text("Unknown")
    value = out(["xdg-mime", "query", "default", mime])
    return value or tr_text("Not set")


def set_xdg_default(desktop_id: str, *mimes: str) -> None:
    if not command_exists("xdg-mime"):
        notify("SevenOS Settings", tr_text("xdg-mime is unavailable."))
        return
    for mime in mimes:
        subprocess.run(["xdg-mime", "default", desktop_id, mime], check=False)
    notify("SevenOS Settings", tr_text("Default app updated."))


def system_about() -> dict[str, str]:
    release = "SevenOS"
    release_file = Path("/etc/sevenos-release")
    if release_file.exists():
        release = release_file.read_text(encoding="utf-8", errors="ignore").strip().splitlines()[0] or release
    readiness = run_json([str(ROOT / "scripts/readiness.sh"), "--json"], {"percent": "?"})
    profile_name, profile_status = active_profile()
    return {
        "release": release,
        "hostname": platform.node() or "sevenos",
        "kernel": platform.release(),
        "session": os.environ.get("XDG_CURRENT_DESKTOP") or os.environ.get("DESKTOP_SESSION") or "Hyprland",
        "profile": f"{profile_name} · {profile_status}",
        "readiness": f"{readiness.get('percent', '?')}%",
    }


def notify(title: str, message: str) -> None:
    if command_exists("notify-send"):
        subprocess.Popen(["notify-send", title, message], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def volume_state() -> int:
    if not command_exists("wpctl"):
        return 0
    raw = out(["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"])
    try:
        return max(0, min(100, int(float(raw.split()[1]) * 100)))
    except Exception:
        return 0


def set_volume(value: float) -> None:
    if command_exists("wpctl"):
        subprocess.Popen(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def brightness_state() -> int:
    if not command_exists("brightnessctl"):
        return 0
    try:
        current = int(out(["brightnessctl", "g"], "0"))
        maximum = int(out(["brightnessctl", "m"], "1")) or 1
        return max(0, min(100, round(current / maximum * 100)))
    except Exception:
        return 0


def set_brightness(value: float) -> None:
    if command_exists("brightnessctl"):
        subprocess.Popen(["brightnessctl", "set", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def monitors_state() -> list[dict[str, str]]:
    payload = run_json(["hyprctl", "monitors", "-j"], []) if command_exists("hyprctl") else []
    monitors: list[dict[str, str]] = []
    if isinstance(payload, list):
        for item in payload:
            if not isinstance(item, dict):
                continue
            name = str(item.get("name") or item.get("description") or "").strip()
            if not name:
                continue
            width = int(item.get("width") or 0)
            height = int(item.get("height") or 0)
            refresh = float(item.get("refreshRate") or 60)
            scale = float(item.get("scale") or 1)
            monitors.append(
                {
                    "name": name,
                    "label": f"{name} · {width}x{height}@{refresh:.0f}Hz · {scale:g}x",
                    "resolution": f"{width}x{height}" if width and height else "preferred",
                    "refresh": f"{refresh:.0f}",
                    "scale": f"{scale:g}",
                }
            )
    if not monitors:
        monitors.append({"name": "", "label": tr("settings.all_monitors", "All monitors"), "resolution": "preferred", "refresh": "60", "scale": "1"})
    return monitors


def write_monitor_rule(name: str, resolution: str, scale: str) -> None:
    HYPR_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    monitor_name = name or ""
    mode = "preferred" if resolution == "preferred" else f"{resolution}@60"
    rule = f"monitor = {monitor_name},{mode},auto,{scale}"
    lines: list[str] = []
    replaced = False
    if MONITOR_PREFS.exists():
        MONITOR_BACKUP.write_text(MONITOR_PREFS.read_text(encoding="utf-8", errors="ignore"), encoding="utf-8")
        for line in MONITOR_PREFS.read_text(encoding="utf-8", errors="ignore").splitlines():
            stripped = line.strip()
            if stripped.startswith("monitor") and "=" in stripped:
                _left, _eq, value = stripped.partition("=")
                current_name = value.strip().split(",", 1)[0].strip()
                if current_name == monitor_name:
                    lines.append(rule)
                    replaced = True
                    continue
            lines.append(line)
    if not lines:
        lines = ["# SevenOS monitor override", "# Example:", "# monitor = eDP-1,preferred,auto,1"]
    if not replaced:
        lines.append(rule)
    MONITOR_PREFS.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")


def restore_monitor_rule() -> bool:
    if not MONITOR_BACKUP.exists():
        return False
    HYPR_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    MONITOR_PREFS.write_text(MONITOR_BACKUP.read_text(encoding="utf-8", errors="ignore"), encoding="utf-8")
    return True


def wifi_state() -> tuple[str, str]:
    if not command_exists("nmcli"):
        return tr_text("Missing"), tr_text("NetworkManager tools unavailable")
    radio = out(["nmcli", "radio", "wifi"], "unknown")
    ssid = out(["bash", "-lc", "nmcli -t -f active,ssid dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"])
    if radio == "disabled":
        return tr_text("Off"), tr_text("Radio disabled")
    return tr_text("On"), ssid or tr_text("Not connected")


def battery_state() -> tuple[str, str]:
    bats = list(Path("/sys/class/power_supply").glob("BAT*"))
    if not bats:
        return "AC", tr_text("No battery")
    bat = bats[0]
    status = (bat / "status").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "status").exists() else tr_text("Unknown")
    capacity = (bat / "capacity").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "capacity").exists() else "?"
    return f"{capacity}%", status


def active_profile() -> tuple[str, str]:
    payload = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
    if isinstance(payload, list):
        item = next((row for row in payload if row.get("active")), None)
        if item:
            return item.get("title", tr_text("Profile")), item.get("state", "unknown")
    return "Equinox", "unknown"


def active_profile_key() -> str:
    payload = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
    if isinstance(payload, list):
        item = next((row for row in payload if row.get("active")), None)
        if item:
            return str(item.get("key") or item.get("profile") or "equinox").lower()
    profile_env = CONFIG_DIR / "profile.env"
    if profile_env.exists():
        for line in profile_env.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() in {"SEVENOS_ACTIVE_PROFILE", "SEVENOS_PROFILE"} and value.strip():
                return value.strip().strip('"').strip("'").lower()
    return "equinox"


def profile_catalog() -> dict:
    catalog_file = ROOT / "profiles/catalog.json"
    fallback = {
        "profile_naming": {
            "equinox": "Equinox Balance",
            "baobab": "Baobab Culture",
            "forge": "Forge Developer",
            "shield": "Shield Cybersecurity",
            "studio": "Studio Creator",
            "windows": "Windows Bridge",
            "horizon": "Horizon Cloud",
            "pulse": "Pulse Gaming",
        },
        "profiles": {},
    }
    if not catalog_file.exists():
        return fallback
    try:
        payload = json.loads(catalog_file.read_text(encoding="utf-8"))
        return payload if isinstance(payload, dict) else fallback
    except Exception:
        return fallback


def shield_state() -> tuple[str, str]:
    payload = run_json([str(ROOT / "security/shield-status.sh"), "--json"], {"percent": 0, "posture": "unknown"})
    return f"{payload.get('percent', 0)}%", str(payload.get("posture", "unknown"))


def session_state() -> tuple[str, str]:
    payload = run_json([str(ROOT / "bin/seven-session-status"), "--json"], {"percent": 0, "mode": "unknown"})
    return f"{payload.get('percent', 0)}%", str(payload.get("mode", "unknown"))


def font_state() -> dict:
    return run_json(
        [str(ROOT / "scripts/fonts.sh"), "status", "--json"],
        {
            "interface": "SF Pro Display",
            "text": "SF Pro Text",
            "mono": "SF Mono",
            "cyber": "JetBrainsMono Nerd Font",
            "brand": "SF Pro Rounded",
            "font_home": str(Path.home() / ".local/share/fonts/SevenOS"),
        },
    )


def language_state() -> dict:
    return run_json(
        [str(ROOT / "bin/seven-language"), "status", "--json"],
        {
            "current": os.environ.get("LANG", "C.UTF-8"),
            "label": tr("language.system_default", "System default"),
            "language": "C",
            "languages": [
                {
                    "locale": "C.UTF-8",
                    "label": tr("language.system_default", "System default"),
                    "language": "C",
                    "current": True,
                    "installed": True,
                }
            ],
        },
    )


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run(initial_page: str = "overview") -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenSettingsNative")
    GLib.set_application_name(tr("settings.title", "SevenOS Settings"))
    try:
        Gdk.set_program_class("SevenSettingsNative")
    except Exception:
        pass

    theme_mode = current_theme_mode()
    css = seven_theme.gtk_app_css("settings", theme_mode) + seven_theme.surface_css("settings", mode=theme_mode)
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title=tr("settings.title", "SevenOS Settings"))
    window.set_wmclass("SevenSettingsNative", "SevenSettingsNative")
    window.set_decorated(False)
    window.set_resizable(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(1000, 680)
    geometry = Gdk.Geometry()
    geometry.min_width = 860
    geometry.min_height = 560
    window.set_geometry_hints(None, geometry, Gdk.WindowHints.MIN_SIZE)
    window.get_style_context().add_class("settings-window")

    shell = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    shell.get_style_context().add_class("settings-shell")
    window.add(shell)

    body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)

    def toggle_zoom() -> None:
        if window.is_maximized():
            window.unmaximize()
        width, _height = window.get_size()
        if width >= 1120:
            window.resize(1000, 680)
        else:
            window.resize(1160, 760)
        window.set_position(Gtk.WindowPosition.CENTER)

    sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
    sidebar.set_size_request(220, -1)
    sidebar.get_style_context().add_class("sidebar")

    traffic = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    traffic.get_style_context().add_class("traffic")
    for klass, action in (("dot-close", window.close), ("dot-min", window.iconify), ("dot-max", toggle_zoom)):
        button = Gtk.Button()
        button.get_style_context().add_class("traffic-dot")
        button.get_style_context().add_class(klass)
        button.connect("clicked", lambda _button, callback=action: callback())
        traffic.pack_start(button, False, False, 0)
    sidebar.pack_start(traffic, False, False, 0)

    brand = Gtk.Label(label=f"7  {tr('settings.title', 'Settings').replace('SevenOS ', '')}")
    brand.set_xalign(0)
    brand.get_style_context().add_class("brand")
    sidebar.pack_start(brand, False, False, 0)

    stack = Gtk.Stack()
    stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
    stack.set_hexpand(True)
    stack.set_vexpand(True)
    content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    content.get_style_context().add_class("content")
    search_entry = Gtk.SearchEntry()
    search_entry.set_placeholder_text(tr("settings.search.placeholder", "Search settings, defaults, language, Wi-Fi..."))
    search_entry.get_style_context().add_class("settings-search")
    content.pack_start(search_entry, False, False, 0)
    search_results = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    search_results.set_no_show_all(True)
    search_results.get_style_context().add_class("search-results")
    content.pack_start(search_results, False, False, 0)
    feedback_banner = Gtk.Label(label="")
    feedback_banner.set_xalign(0)
    feedback_banner.set_line_wrap(True)
    feedback_banner.set_no_show_all(True)
    feedback_banner.get_style_context().add_class("feedback-banner")
    content.pack_start(feedback_banner, False, False, 0)
    content.pack_start(stack, True, True, 0)

    body.pack_start(sidebar, False, False, 0)
    body.pack_start(content, True, True, 0)
    shell.pack_start(body, True, True, 0)

    nav_buttons: list[Gtk.Button] = []
    nav_by_target: dict[str, Gtk.Button] = {}

    def page(title: str, subtitle: str) -> tuple[Gtk.Box, Gtk.ScrolledWindow]:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        outer.set_halign(Gtk.Align.START)
        outer.set_valign(Gtk.Align.START)
        outer.set_size_request(850, -1)
        outer.get_style_context().add_class("page-frame")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("page-title")
        subtitle_label = Gtk.Label(label=subtitle)
        subtitle_label.set_xalign(0)
        subtitle_label.set_line_wrap(True)
        subtitle_label.get_style_context().add_class("page-subtitle")
        outer.pack_start(title_label, False, False, 0)
        outer.pack_start(subtitle_label, False, False, 0)
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        viewport = Gtk.Viewport()
        viewport.add(outer)
        scrolled.add(viewport)
        return outer, scrolled

    def activate_page(name: str, button: Gtk.Button) -> None:
        stack.set_visible_child_name(name)
        for item in nav_buttons:
            item.get_style_context().remove_class("active")
        button.get_style_context().add_class("active")

    def show_feedback(message: str) -> None:
        feedback_banner.set_text(message)
        feedback_banner.show()

        def hide_feedback() -> bool:
            feedback_banner.hide()
            return False

        GLib.timeout_add_seconds(4, hide_feedback)

    def nav(name: str, icon: str, label: str, target: str) -> None:
        button = Gtk.Button()
        button.get_style_context().add_class("nav-button")
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=11)
        glyph = Gtk.Label(label=icon)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        text.set_hexpand(True)
        row.pack_start(glyph, False, False, 0)
        row.pack_start(text, True, True, 0)
        button.add(row)
        button.connect("clicked", lambda clicked: activate_page(target, clicked))
        nav_buttons.append(button)
        nav_by_target[target] = button
        sidebar.pack_start(button, False, False, 0)

    def section(container: Gtk.Box, text: str) -> None:
        label = Gtk.Label(label=text.upper())
        label.set_xalign(0)
        label.get_style_context().add_class("section-label")
        container.pack_start(label, False, False, 0)

    def status_grid(container: Gtk.Box, items: list[tuple[str, str]]) -> None:
        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.START)
        for index, (value, label) in enumerate(items):
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
            card.get_style_context().add_class("status-card")
            value_label = Gtk.Label(label=value)
            value_label.set_xalign(0)
            value_label.get_style_context().add_class("status-value")
            note = Gtk.Label(label=label)
            note.set_xalign(0)
            note.get_style_context().add_class("status-label")
            card.pack_start(value_label, False, False, 0)
            card.pack_start(note, False, False, 0)
            card.set_size_request(118, -1)
            grid.attach(card, index % 3, index // 3, 1, 1)
        container.pack_start(grid, False, False, 0)

    def card_grid(container: Gtk.Box, cards: list[Gtk.Widget], columns: int = 2) -> None:
        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        grid.set_halign(Gtk.Align.START)
        for index, card in enumerate(cards):
            card.set_hexpand(False)
            card.set_size_request(410, -1)
            grid.attach(card, index % columns, index // columns, 1, 1)
        container.pack_start(grid, False, False, 0)

    def hero_card(title: str, note: str) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        card.set_size_request(850, -1)
        card.get_style_context().add_class("hero-card")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("hero-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("hero-note")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(note_label, False, False, 0)
        return card

    def action_button(label: str, command: str, feedback: str | None = None) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("action-button")
        button.set_tooltip_text(command)

        def clicked(_button, cmd=command, feedback_text=feedback) -> None:
            run_detached(cmd)
            show_feedback(feedback_text or tr("settings.action_started", "Action started."))

        button.connect("clicked", clicked)
        return button

    def callback_button(label: str, tooltip: str, callback, feedback: str | None = None) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("action-button")
        button.set_tooltip_text(tooltip)

        def clicked(_button) -> None:
            callback()
            if feedback:
                show_feedback(feedback)

        button.connect("clicked", clicked)
        return button

    def copy_system_summary() -> None:
        about = system_about()
        summary = "\n".join(
            [
                f"SevenOS: {about['release']}",
                f"Device: {about['hostname']}",
                f"Kernel: {about['kernel']}",
                f"Session: {about['session']}",
                f"Profile: {about['profile']}",
                f"Readiness: {about['readiness']}",
            ]
        )
        clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        clipboard.set_text(summary, -1)
        clipboard.store()
        notify("SevenOS Settings", tr_text("System information copied."))
        show_feedback(tr("settings.system_info_copied", "System information copied."))

    def quick_dot(icon: str, tooltip: str, command: str) -> Gtk.Button:
        button = Gtk.Button(label=icon)
        button.get_style_context().add_class("quick-dot")
        button.set_tooltip_text(tooltip)
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        return button

    def quick_strip(items: list[tuple[str, str, str]]) -> Gtk.Box:
        strip = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        strip.set_halign(Gtk.Align.START)
        strip.get_style_context().add_class("quick-strip")
        for icon, tooltip, command in items:
            strip.pack_start(quick_dot(icon, tooltip, command), False, False, 0)
        return strip

    def file_wallpaper_button(label: str) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("action-button")

        def choose(_button) -> None:
            dialog = Gtk.FileChooserDialog(
                title=tr("settings.choose_image", "Choose SevenOS Wallpaper"),
                parent=window,
                action=Gtk.FileChooserAction.OPEN,
                buttons=(f"_{tr_text('Cancel')}", Gtk.ResponseType.CANCEL, f"_{tr('settings.set_wallpaper', 'Set Wallpaper')}", Gtk.ResponseType.ACCEPT),
            )
            image_filter = Gtk.FileFilter()
            image_filter.set_name("Images")
            for mime in ("image/png", "image/jpeg", "image/webp", "image/svg+xml"):
                image_filter.add_mime_type(mime)
            dialog.add_filter(image_filter)
            response = dialog.run()
            filename = dialog.get_filename()
            dialog.destroy()
            if response == Gtk.ResponseType.ACCEPT and filename:
                subprocess.Popen([str(ROOT / "bin/seven-wallpaper"), "set", filename], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
                notify(tr("settings.title", "SevenOS Settings"), tr_text("Wallpaper updated."))

        button.connect("clicked", choose)
        return button

    def import_fonts_button(label: str) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("action-button")

        def choose(_button) -> None:
            dialog = Gtk.FileChooserDialog(
                title=tr("settings.import_font_files", "Import Fonts"),
                parent=window,
                action=Gtk.FileChooserAction.OPEN,
                buttons=(f"_{tr_text('Cancel')}", Gtk.ResponseType.CANCEL, f"_{tr('settings.import', 'Import')}", Gtk.ResponseType.ACCEPT),
            )
            dialog.set_select_multiple(True)
            font_filter = Gtk.FileFilter()
            font_filter.set_name("Fonts")
            for pattern in ("*.ttf", "*.otf", "*.ttc"):
                font_filter.add_pattern(pattern)
            dialog.add_filter(font_filter)
            response = dialog.run()
            filenames = dialog.get_filenames()
            dialog.destroy()
            if response == Gtk.ResponseType.ACCEPT and filenames:
                subprocess.Popen([str(ROOT / "scripts/fonts.sh"), "import", *filenames], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
                notify("SevenOS Fonts", tr_text("Fonts imported and cache refreshed."))

        button.connect("clicked", choose)
        return button

    def setting_card(icon: str, title: str, note: str, buttons: list[Gtk.Button]) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.get_style_context().add_class("settings-card")
        icon_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        icon_box.set_halign(Gtk.Align.CENTER)
        icon_box.set_valign(Gtk.Align.CENTER)
        icon_box.get_style_context().add_class("icon-pill")
        icon_label = Gtk.Label(label=icon)
        icon_box.pack_start(icon_label, True, True, 0)
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        text_box.set_hexpand(True)
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("card-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("card-note")
        text_box.pack_start(title_label, False, False, 0)
        text_box.pack_start(note_label, False, False, 0)
        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_valign(Gtk.Align.CENTER)
        for button in buttons:
            actions.pack_start(button, False, False, 0)
        card.pack_start(icon_box, False, False, 0)
        card.pack_start(text_box, True, True, 0)
        card.pack_start(actions, False, False, 0)
        return card

    def region_selector_card() -> Gtk.Box:
        prefs = read_region_prefs()
        options = {
            "region": [("France", "France"), ("United States", "United States"), ("Côte d’Ivoire", "Côte d’Ivoire"), ("System", tr("language.system_default", "System default"))],
            "time_format": [("24h", "24h"), ("12h", "12h")],
            "date_format": [("DD/MM/YYYY", "DD/MM/YYYY"), ("MM/DD/YYYY", "MM/DD/YYYY"), ("YYYY-MM-DD", "YYYY-MM-DD")],
            "week_start": [("Monday", tr("settings.monday", "Monday")), ("Sunday", tr("settings.sunday", "Sunday"))],
            "units": [("metric", tr("settings.metric", "Metric")), ("imperial", tr("settings.imperial", "Imperial"))],
        }

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(850, -1)
        card.get_style_context().add_class("settings-card")
        title = Gtk.Label(label=tr("settings.region_formats", "Region & formats"))
        title.set_xalign(0)
        title.get_style_context().add_class("card-title")
        note = Gtk.Label(label=tr("settings.region_formats.note", "Choose everyday formats without changing your keyboard layout."))
        note.set_xalign(0)
        note.get_style_context().add_class("card-note")
        card.pack_start(title, False, False, 0)
        card.pack_start(note, False, False, 0)

        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(8)
        for index, (key, label_text) in enumerate(
            [
                ("region", tr("settings.region", "Region")),
                ("time_format", tr("settings.time_format", "Time")),
                ("date_format", tr("settings.date_format", "Date")),
                ("week_start", tr("settings.week_start", "Week starts")),
                ("units", tr("settings.units", "Units")),
            ]
        ):
            label = Gtk.Label(label=label_text)
            label.set_xalign(0)
            label.get_style_context().add_class("card-note")
            combo = Gtk.ComboBoxText()
            active = 0
            for option_index, (value, option_label) in enumerate(options[key]):
                combo.append(value, option_label)
                if prefs.get(key) == value:
                    active = option_index
            combo.set_active(active)
            def update_region(widget, pref_key=key) -> None:
                write_region_pref(pref_key, widget.get_active_id() or "")
                show_feedback(
                    tr(
                        "settings.region_updated",
                        "Region formats updated. New SevenOS windows will use the refreshed contract.",
                    )
                )

            combo.connect("changed", update_region)
            grid.attach(label, 0, index, 1, 1)
            grid.attach(combo, 1, index, 1, 1)
        card.pack_start(grid, False, False, 0)
        return card

    def default_app_card(icon: str, title: str, note: str, desktop_id: str, mimes: tuple[str, ...]) -> Gtk.Box:
        current = xdg_default(mimes[0])
        return setting_card(
            icon,
            title,
            f"{note} · {tr('settings.current', 'Current')}: {current}",
            [
                callback_button(
                    tr("settings.set_default", "Set default"),
                    f"xdg-mime default {desktop_id}",
                    lambda app=desktop_id, targets=mimes: set_xdg_default(app, *targets),
                    tr("settings.default_updated", "Default application updated."),
                )
            ],
        )

    def language_selector_card() -> Gtk.Box:
        payload = language_state()
        languages = payload.get("languages", [])
        if not isinstance(languages, list) or not languages:
            languages = [{"locale": "C.UTF-8", "label": tr("language.system_default", "System default"), "current": True}]
        current = str(payload.get("current", "C.UTF-8"))

        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.set_size_request(850, -1)
        card.get_style_context().add_class("settings-card")

        icon_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        icon_box.set_halign(Gtk.Align.CENTER)
        icon_box.set_valign(Gtk.Align.CENTER)
        icon_box.get_style_context().add_class("icon-pill")
        icon_box.pack_start(Gtk.Label(label="󰗊"), True, True, 0)

        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        text_box.set_hexpand(True)
        title_label = Gtk.Label(label=tr("settings.language", "Language"))
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("card-title")
        note_label = Gtk.Label(label=tr("settings.language.note", "{label} · applies to new apps and terminals", label=payload.get("label", current)))
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("card-note")
        text_box.pack_start(title_label, False, False, 0)
        text_box.pack_start(note_label, False, False, 0)

        selector = Gtk.ComboBoxText()
        active_index = 0
        installed_by_locale: dict[str, bool] = {}
        for index, item in enumerate(languages):
            locale_name = str(item.get("locale", "C.UTF-8"))
            label = str(item.get("label", locale_name))
            installed = bool(item.get("installed", True))
            installed_by_locale[locale_name] = installed
            suffix = locale_name if installed else f"{locale_name} · {tr_text('installable')}"
            selector.append(locale_name, f"{label} · {suffix}")
            if locale_name == current or item.get("current"):
                active_index = index
        selector.set_active(active_index)
        selector.set_tooltip_text("seven language set <locale>")

        ready = {"value": False}

        def mark_ready() -> bool:
            ready["value"] = True
            return False

        def change_language(widget) -> None:
            if not ready["value"]:
                return
            locale_name = widget.get_active_id()
            if not locale_name:
                return
            run_detached(f"seven language set {locale_name}")
            if installed_by_locale.get(locale_name, True):
                notify("SevenOS Language", tr_text("Language updated for new apps and terminals.") + " " + tr("language.needs_restart", "Some open apps need to be reopened to fully switch language."))
                show_feedback(tr("language.needs_restart", "Some open apps need to be reopened to fully switch language."))
            else:
                notify("SevenOS Language", tr_text("SevenOS will generate this locale, then apply it."))
                show_feedback(tr_text("SevenOS will generate this locale, then apply it."))

        selector.connect("changed", change_language)
        GLib.idle_add(mark_ready)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_valign(Gtk.Align.CENTER)
        actions.pack_start(selector, False, False, 0)
        actions.pack_start(action_button(tr("settings.status", "Status"), "seven language status"), False, False, 0)

        card.pack_start(icon_box, False, False, 0)
        card.pack_start(text_box, True, True, 0)
        card.pack_start(actions, False, False, 0)
        return card

    def slider_card(icon: str, title: str, note: str, value: int, callback) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.get_style_context().add_class("scale-card")
        icon_label = Gtk.Label(label=icon)
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        labels.set_size_request(170, -1)
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("card-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.get_style_context().add_class("card-note")
        labels.pack_start(title_label, False, False, 0)
        labels.pack_start(note_label, False, False, 0)
        scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
        scale.set_value(value)
        scale.set_hexpand(True)
        scale.connect("value-changed", lambda widget: callback(widget.get_value()))
        card.pack_start(icon_label, False, False, 0)
        card.pack_start(labels, False, False, 0)
        card.pack_start(scale, True, True, 0)
        return card

    def monitor_resolution_card() -> Gtk.Box:
        monitor_options = monitors_state()
        resolution_options = [
            ("preferred", tr("settings.resolution_preferred", "Preferred")),
            ("3840x2160", "3840x2160"),
            ("2560x1440", "2560x1440"),
            ("1920x1080", "1920x1080"),
            ("1600x900", "1600x900"),
            ("1366x768", "1366x768"),
            ("1280x720", "1280x720"),
        ]
        scale_options = [("1", "100%"), ("1.25", "125%"), ("1.5", "150%"), ("1.75", "175%"), ("2", "200%")]

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(850, -1)
        card.get_style_context().add_class("settings-card")
        title = Gtk.Label(label=tr("settings.monitor_resolution", "Monitor size and resolution"))
        title.set_xalign(0)
        title.get_style_context().add_class("card-title")
        note = Gtk.Label(label=tr("settings.monitor_resolution.note", "Choose a monitor resolution such as 1920x1080, then apply it without editing Hyprland files."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("card-note")
        card.pack_start(title, False, False, 0)
        card.pack_start(note, False, False, 0)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        monitor_combo = Gtk.ComboBoxText()
        for item in monitor_options:
            monitor_combo.append(item["name"], item["label"])
        monitor_combo.set_active(0)

        resolution_combo = Gtk.ComboBoxText()
        active_resolution = monitor_options[0].get("resolution", "preferred")
        resolution_active = 0
        for index, (value, label) in enumerate(resolution_options):
            resolution_combo.append(value, label)
            if value == active_resolution:
                resolution_active = index
        resolution_combo.set_active(resolution_active)

        scale_combo = Gtk.ComboBoxText()
        active_scale = monitor_options[0].get("scale", "1")
        scale_active = 0
        for index, (value, label) in enumerate(scale_options):
            scale_combo.append(value, label)
            if value == active_scale:
                scale_active = index
        scale_combo.set_active(scale_active)

        def apply_monitor() -> None:
            monitor_name = monitor_combo.get_active_id() or ""
            resolution = resolution_combo.get_active_id() or "preferred"
            scale = scale_combo.get_active_id() or "1"
            write_monitor_rule(monitor_name, resolution, scale)
            run_detached("hyprctl reload")
            show_feedback(tr("settings.monitor_applied", "Monitor resolution applied. Hyprland is reloading."))

        row.pack_start(monitor_combo, True, True, 0)
        row.pack_start(resolution_combo, False, False, 0)
        row.pack_start(scale_combo, False, False, 0)
        row.pack_start(callback_button(tr("settings.apply", "Apply"), "write Hyprland monitor rule", apply_monitor), False, False, 0)
        row.pack_start(
            callback_button(
                tr("settings.restore", "Restore"),
                "restore previous Hyprland monitor rule",
                lambda: (restore_monitor_rule() and run_detached("hyprctl reload")),
                tr("settings.monitor_restore", "Previous monitor configuration restored when a backup exists."),
            ),
            False,
            False,
            0,
        )
        card.pack_start(row, False, False, 0)
        return card

    def theme_preview_card() -> Gtk.Box:
        profile_theme_file = ROOT / "identity/profile-themes.json"
        profile_theme_payload = run_json(["python", "-m", "json.tool", str(profile_theme_file)], {}) if profile_theme_file.exists() else {}
        profile_themes = profile_theme_payload.get("profiles", {}) if isinstance(profile_theme_payload.get("profiles"), dict) else {}
        profile_order = ["equinox", "baobab", "forge", "shield", "studio", "windows", "horizon", "pulse"]
        selected = {"mode": theme_mode, "profile": active_profile_key()}

        def profile_override(key: str) -> dict:
            data = profile_themes.get(key, {}) if isinstance(profile_themes.get(key), dict) else {}
            return {
                "profile": key,
                "title": str(data.get("label") or key.title()),
                "accent": str(data.get("accent") or "#8B7CFF"),
                "secondary": str(data.get("secondary") or "#6EA8FF"),
                "mood": str(data.get("ui_mood") or ""),
            }

        def contract_for_selection() -> dict:
            return seven_theme.resolved_theme(
                "settings",
                selected["mode"],
                profile_override=profile_override(selected["profile"]),
            )

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(850, -1)
        card.get_style_context().add_class("theme-preview-card")

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title_box.set_hexpand(True)
        title = Gtk.Label(label=tr("settings.theme_preview", "Theme preview"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label()
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(note, False, False, 0)
        header.pack_start(title_box, True, True, 0)
        apply_button = Gtk.Button(label=tr("settings.apply_now", "Apply now"))
        apply_button.get_style_context().add_class("action-button")
        header.pack_start(apply_button, False, False, 0)
        card.pack_start(header, False, False, 0)

        controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        controls.set_halign(Gtk.Align.START)
        dark_button = Gtk.Button(label=tr("settings.dark_mode", "Dark Mode"))
        dark_button.get_style_context().add_class("action-button")
        light_button = Gtk.Button(label=tr("settings.light_mode", "Light Mode"))
        light_button.get_style_context().add_class("action-button")
        profile_combo = Gtk.ComboBoxText()
        active_index = 0
        for index, key in enumerate(profile_order):
            data = profile_themes.get(key, {}) if isinstance(profile_themes.get(key), dict) else {}
            profile_combo.append(key, str(data.get("label") or key.title()))
            if key == selected["profile"]:
                active_index = index
        profile_combo.set_active(active_index)
        wallpaper_button = Gtk.Button(label=tr("settings.choose_image", "Choose image"))
        wallpaper_button.get_style_context().add_class("action-button")
        controls.pack_start(dark_button, False, False, 0)
        controls.pack_start(light_button, False, False, 0)
        controls.pack_start(profile_combo, False, False, 0)
        controls.pack_start(wallpaper_button, False, False, 0)
        card.pack_start(controls, False, False, 0)

        preview = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=9)
        preview.get_style_context().add_class("theme-preview-window")
        toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        toolbar.get_style_context().add_class("theme-preview-toolbar")
        toolbar.pack_start(Gtk.Label(label="  7  SevenOS"), False, False, 8)
        profile_badge = Gtk.Label()
        toolbar.pack_end(profile_badge, False, False, 8)
        preview.pack_start(toolbar, False, False, 0)

        mock_body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
        mock_sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
        mock_sidebar.get_style_context().add_class("theme-preview-sidebar")
        for _ in range(3):
            pill = Gtk.Box()
            pill.get_style_context().add_class("theme-preview-pill")
            mock_sidebar.pack_start(pill, False, False, 0)
        mock_content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        mock_content.set_hexpand(True)
        mock_content.get_style_context().add_class("theme-preview-content")
        for index in range(2):
            pill = Gtk.Box()
            pill.get_style_context().add_class("theme-preview-pill")
            if index == 1:
                pill.get_style_context().add_class("alt")
            mock_content.pack_start(pill, False, False, 0)
        mock_body.pack_start(mock_sidebar, False, False, 0)
        mock_body.pack_start(mock_content, True, True, 0)
        preview.pack_start(mock_body, True, True, 0)
        card.pack_start(preview, False, False, 0)

        swatches = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
        swatches.get_style_context().add_class("theme-swatch-row")
        swatch_dots: list[Gtk.Box] = []
        for klass in ("swatch-accent", "swatch-secondary", "swatch-wallpaper", "swatch-cyan"):
            dot = Gtk.Box()
            dot.get_style_context().add_class("theme-swatch")
            dot.get_style_context().add_class(klass)
            swatch_dots.append(dot)
            swatches.pack_start(dot, False, False, 0)
        details = Gtk.Label()
        details.set_xalign(0)
        details.set_line_wrap(True)
        details.get_style_context().add_class("card-note")
        swatches.pack_start(details, True, True, 0)
        card.pack_start(swatches, False, False, 0)

        def refresh_preview(apply_css: bool = True) -> None:
            contract = contract_for_selection()
            palette = contract.get("palette", {}) if isinstance(contract.get("palette"), dict) else {}
            wallpaper = contract.get("wallpaper", {}) if isinstance(contract.get("wallpaper"), dict) else {}
            toolkits = contract.get("toolkits", {}) if isinstance(contract.get("toolkits"), dict) else {}
            wallpaper_image = str(wallpaper.get("image") or "")
            wallpaper_name = Path(wallpaper_image).name if wallpaper_image else tr("settings.wallpaper_dynamic", "dynamic wallpaper")
            profile_title = str(contract.get("profile_title") or selected["profile"].title())
            note.set_text(
                tr(
                    "settings.theme_preview.note",
                    "{mode} · {profile} · wallpaper atmosphere: {source}",
                    mode=str(contract.get("mode_label") or selected["mode"]),
                    profile=profile_title,
                    source=str(wallpaper.get("source") or "fallback"),
                )
            )
            profile_badge.set_text(str(contract.get("profile") or selected["profile"]).upper())
            for dot, tooltip in zip(
                swatch_dots,
                (
                    f"{tr('settings.profile_accent', 'Profile accent')}: {palette.get('accent', '')}",
                    f"{tr('settings.profile_secondary', 'Profile secondary')}: {palette.get('secondary', '')}",
                    f"{tr('settings.wallpaper_accent', 'Wallpaper accent')}: {palette.get('wallpaper_accent', '')}",
                    f"{tr('settings.wallpaper_cyan', 'Wallpaper cyan')}: {palette.get('wallpaper_cyan', '')}",
                ),
            ):
                dot.set_tooltip_text(tooltip)
            details.set_text(
                tr(
                    "settings.theme_preview.details",
                    "Icons: {icons} · Qt/Kvantum: {kvantum} · Wallpaper: {wallpaper}",
                    icons=str(toolkits.get("icon_theme") or tr("settings.unknown", "Unknown")),
                    kvantum=str(toolkits.get("kvantum_theme") or tr("settings.unknown", "Unknown")),
                    wallpaper=wallpaper_name,
                )
            )
            if apply_css:
                provider.load_from_data(
                    (
                        seven_theme.gtk_app_css(
                            "settings",
                            selected["mode"],
                            profile_override=profile_override(selected["profile"]),
                        )
                        + seven_theme.surface_css("settings", mode=selected["mode"])
                    ).encode("utf-8")
                )

        def preview_mode(mode: str) -> None:
            selected["mode"] = mode
            refresh_preview()
            show_feedback(tr("settings.preview_updated", "Preview updated. Apply when it feels right."))

        def preview_profile(widget) -> None:
            selected["profile"] = widget.get_active_id() or selected["profile"]
            refresh_preview()
            show_feedback(tr("settings.preview_updated", "Preview updated. Apply when it feels right."))

        def choose_wallpaper(_button) -> None:
            dialog = Gtk.FileChooserDialog(
                title=tr("settings.choose_image", "Choose SevenOS Wallpaper"),
                parent=window,
                action=Gtk.FileChooserAction.OPEN,
                buttons=(f"_{tr_text('Cancel')}", Gtk.ResponseType.CANCEL, f"_{tr('settings.set_wallpaper', 'Set Wallpaper')}", Gtk.ResponseType.ACCEPT),
            )
            image_filter = Gtk.FileFilter()
            image_filter.set_name("Images")
            for mime in ("image/png", "image/jpeg", "image/webp", "image/svg+xml"):
                image_filter.add_mime_type(mime)
            dialog.add_filter(image_filter)
            response = dialog.run()
            filename = dialog.get_filename()
            dialog.destroy()
            if response == Gtk.ResponseType.ACCEPT and filename:
                subprocess.Popen([str(ROOT / "bin/seven-wallpaper"), "set", filename], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
                show_feedback(tr("settings.wallpaper_preview_requested", "Wallpaper update requested. The preview will use the refreshed palette after generation."))

        def apply_theme_selection(_button) -> None:
            command = (
                f"./install.sh theme {selected['mode']} && "
                f"seven profile activate {selected['profile']} && "
                f"seven-wallpaper profile {selected['profile']} && "
                "seven-profile-theme apply && "
                "seven language apply --live && "
                "hyprctl reload"
            )
            run_detached(command)
            show_feedback(tr("settings.theme_apply_requested", "Theme, profile and wallpaper changes are being applied."))

        dark_button.connect("clicked", lambda _button: preview_mode("dark"))
        light_button.connect("clicked", lambda _button: preview_mode("light"))
        profile_combo.connect("changed", preview_profile)
        wallpaper_button.connect("clicked", choose_wallpaper)
        apply_button.connect("clicked", apply_theme_selection)
        refresh_preview(apply_css=False)
        return card

