            row.pack_start(glyph, False, False, 0)
            row.pack_start(labels, True, True, 0)
            row.pack_start(button, False, False, 0)
            card.pack_start(row, False, False, 0)
        return card

    def instant_verdict_card() -> Gtk.Box:
        checks: list[tuple[str, str, bool]] = []
        wifi_radio_now, wifi_detail_now = wifi_state()
        wifi_ok = wifi_radio_now.lower() not in {"off", "disabled"} and "not connected" not in wifi_detail_now.lower() and "non connecté" not in wifi_detail_now.lower()
        checks.append((tr("settings.verdict.network", "Réseau"), wifi_detail_now, wifi_ok))
        shield_value, shield_note = shield_state()
        shield_ok = str(shield_value).startswith(("100", "OK"))
        checks.append(("Shield", f"{shield_value} · {shield_note}", shield_ok))
        battery_value, battery_note = battery_state()
        try:
            battery_percent = int(str(battery_value).strip().rstrip("%"))
        except Exception:
            battery_percent = 100
        power_ok = battery_value == "AC" or battery_percent > 20 or "charg" in battery_note.lower()
        checks.append((tr("settings.power", "Énergie"), f"{battery_value} · {battery_note}", power_ok))
        recent_ok = SETTINGS_ACTION_LOG.exists()
        checks.append((tr("settings.history", "Historique"), tr("settings.available", "Disponible") if recent_ok else tr("settings.empty", "Vide"), True))
        issues = [item for item in checks if not item[2]]

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("verdict-card")
        if issues:
            card.get_style_context().add_class("attention")

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        glyph = Gtk.Label(label="!" if issues else "✓")
        glyph.set_halign(Gtk.Align.CENTER)
        glyph.set_valign(Gtk.Align.CENTER)
        glyph.get_style_context().add_class("verdict-glyph")
        copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        copy.set_hexpand(True)
        title = Gtk.Label(
            label=(
                tr("settings.verdict.attention_title", "À vérifier en premier")
                if issues
                else tr("settings.verdict.ready_title", "SevenOS semble prêt")
            )
        )
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(
            label=(
                tr("settings.verdict.attention_note", "Commence par le point signalé ci-dessous avant les changements importants.")
                if issues
                else tr("settings.verdict.ready_note", "Les signaux essentiels sont cohérents. Tu peux personnaliser ou lancer une action sûre.")
            )
        )
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        copy.pack_start(title, False, False, 0)
        copy.pack_start(note, False, False, 0)
        header.pack_start(glyph, False, False, 0)
        header.pack_start(copy, True, True, 0)
        if issues and issues[0][0] == tr("settings.verdict.network", "Réseau"):
            header.pack_start(callback_button(tr("settings.open", "Ouvrir"), "network:overview", lambda: activate_page("network", nav_by_target["network"])), False, False, 0)
        elif issues and issues[0][0] == "Shield":
            header.pack_start(callback_button(tr("settings.summary", "Résumé"), "security:dashboard", show_security_dashboard), False, False, 0)
        elif issues:
            header.pack_start(callback_button(tr("settings.open", "Ouvrir"), "power:overview", lambda: activate_page("power", nav_by_target["power"])), False, False, 0)
        else:
            header.pack_start(action_button(tr("settings.check", "Vérifier"), "seven smoke doctor"), False, False, 0)
        card.pack_start(header, False, False, 0)

        chips = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        for label, detail, ok in checks:
            chip = Gtk.Label(label=f"{'✓' if ok else '!'} {label}")
            chip.set_tooltip_text(detail)
            chip.get_style_context().add_class("verdict-chip")
            chips.pack_start(chip, False, False, 0)
        card.pack_start(chips, False, False, 0)
        return card

    def continue_card() -> Gtk.Box | None:
        items = recent_pages()[:5]
        if not items:
            return None
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=9)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("continue-card")
        title = Gtk.Label(label=tr("settings.continue.title", "Reprendre rapidement"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=tr("settings.continue.note", "Les dernières sections consultées restent accessibles ici pour revenir à un réglage sans chercher."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        card.pack_start(title, False, False, 0)
        card.pack_start(note, False, False, 0)
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        for item in items:
            button = Gtk.Button(label=page_title(item))
            button.get_style_context().add_class("continue-pill")
            button.set_tooltip_text(page_subtitle(item) or page_title(item))
            button.connect(
                "clicked",
                lambda _button, page_name=item: (
                    activate_page(page_name, nav_by_target[page_name]),
                    show_feedback(page_opened_message(page_name)),
                ),
            )
            row.pack_start(button, False, False, 0)
        clear_button = Gtk.Button(label=tr("settings.clear", "Effacer"))
        clear_button.get_style_context().add_class("action-button")
        clear_button.set_tooltip_text(tr("settings.continue.clear", "Effacer les pages récentes des Paramètres."))

        def clear_recent(_button=None) -> None:
            try:
                SETTINGS_RECENT_PAGES.unlink(missing_ok=True)
            except Exception:
                pass
            card.hide()
            show_feedback(tr("settings.continue.cleared", "Pages récentes effacées."), "success")

        clear_button.connect("clicked", clear_recent)
        row.pack_end(clear_button, False, False, 0)
        card.pack_start(row, False, False, 0)
        return card

