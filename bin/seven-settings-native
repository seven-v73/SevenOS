    def rebuild_search_results(_entry=None) -> None:
        for child in list(search_results.get_children()):
            search_results.remove(child)
        query = search_norm(search_entry.get_text().strip())
        if len(query) < 2:
            search_results.hide()
            return
        matches = []
        for icon, title, note, target in search_items:
            haystack = search_norm(f"{title} {note} {settings_search_index.get(target, '')}")
            if query in haystack:
                matches.append((icon, title, note, target))
        if not matches:
            empty = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            empty.get_style_context().add_class("search-empty-card")
            glyph = Gtk.Label(label="󰍉")
            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            title_label = Gtk.Label(label=tr("settings.search.no_result_title", "Aucun réglage trouvé"))
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("card-title")
            note_label = Gtk.Label(label=tr("settings.search.no_result", "Aucune page ne correspond à “{query}”.", query=query))
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("card-note")
            hint_label = Gtk.Label(label=tr("settings.search.no_result_hint", "Essaie “internet”, “écran”, “son”, “veille”, “thème”, “lent”, “installer” ou “sauvegarde”."))
            hint_label.set_xalign(0)
            hint_label.set_line_wrap(True)
            hint_label.get_style_context().add_class("card-note")
            text_box.pack_start(title_label, False, False, 0)
            text_box.pack_start(note_label, False, False, 0)
            text_box.pack_start(hint_label, False, False, 0)
            actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            overview_button = Gtk.Button(label=tr("settings.overview", "Vue d’ensemble"))
            overview_button.get_style_context().add_class("action-button")
            overview_button.connect(
                "clicked",
                lambda _button: (
                    activate_page("overview", nav_by_target["overview"]),
                    search_entry.set_text(""),
                    search_results.hide(),
                    show_feedback(page_opened_message("overview")),
                ),
            )
            help_button = Gtk.Button(label=tr("settings.help", "Aide"))
            help_button.get_style_context().add_class("action-button")
            help_button.connect("clicked", lambda _button: run_detached("seven-help-native"))
            actions.pack_start(overview_button, False, False, 0)
            actions.pack_start(help_button, False, False, 0)
            text_box.pack_start(actions, False, False, 0)
            empty.pack_start(glyph, False, False, 0)
            empty.pack_start(text_box, True, True, 0)
            search_results.pack_start(empty, False, False, 0)
        for icon, title, note, target in matches[:6]:
            button = Gtk.Button()
            button.get_style_context().add_class("search-result-button")
            button.set_can_focus(True)
            button.set_tooltip_text(tr("settings.search.open_page", "Ouvrir {page}", page=title))
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            glyph = Gtk.Label(label=icon)
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            title_label = Gtk.Label(label=title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("card-title")
            note_label = Gtk.Label(label=note)
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("card-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            row.pack_start(glyph, False, False, 0)
            row.pack_start(labels, True, True, 0)
            button.add(row)
            def result_key(_button, event) -> bool:
                children = [child for child in search_results.get_children() if isinstance(child, Gtk.Button)]
                if event.keyval == Gdk.KEY_Escape:
                    search_entry.set_text("")
                    search_results.hide()
                    search_entry.grab_focus()
                    return True
                if event.keyval in {Gdk.KEY_Down, Gdk.KEY_Tab, Gdk.KEY_Up} and children:
                    try:
                        index = children.index(_button)
                    except ValueError:
                        index = 0
                    if event.keyval == Gdk.KEY_Up and index == 0:
                        search_entry.grab_focus()
                    else:
                        delta = -1 if event.keyval == Gdk.KEY_Up else 1
                        children[(index + delta) % len(children)].grab_focus()
                    return True
                return False

            button.connect("key-press-event", result_key)
            button.connect(
                "clicked",
                lambda _button, page_name=target: (
                    activate_page(page_name, nav_by_target[page_name]),
                    search_entry.set_text(""),
                    search_results.hide(),
                    show_feedback(page_opened_message(page_name)),
                ),
            )
            search_results.pack_start(button, False, False, 0)
        search_results.show_all()

    search_entry.connect("search-changed", rebuild_search_results)

