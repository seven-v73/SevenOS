#!/usr/bin/env python3
"""Native SevenOS Settings.

This is the normal-user control surface for SevenOS. Spotlight remains the
global command search, while Settings keeps a focused preference search for
people who already know they are changing system behavior.
"""

from __future__ import annotations

import json
import os
import platform
import pwd
import re
import selectors
import shlex
import shutil
import subprocess
import sys
import threading
import time
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache"))) / "sevenos"
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "sevenos"
HUB_STATE_CACHE = CACHE_DIR / "hub-state.json"
SETTINGS_ACTION_LOG = CACHE_DIR / "settings-actions.log"
REGION_PREFS = CONFIG_DIR / "region.conf"
REGION_ENV = CONFIG_DIR / "region.env"
PROFILE_AVATAR_PREFS = CONFIG_DIR / "profile-avatar.json"
HYPR_CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "hypr" / "conf"
MONITOR_PREFS = HYPR_CONFIG_DIR / "monitor.conf"
MONITOR_BACKUP = HYPR_CONFIG_DIR / "monitor.conf.sevenos.bak"
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr, tr_text  # noqa: E402
import seven_theme  # noqa: E402

STATE_CACHE: dict | None = None
PROFILE_STATUS_CACHE: list[dict] | None = None
LANGUAGE_CACHE: dict | None = None


def deep_settings_enabled() -> bool:
    return os.environ.get("SEVENOS_SETTINGS_DEEP") == "1"


def live_settings_enabled() -> bool:
    return os.environ.get("SEVENOS_SETTINGS_STATIC") != "1"


def out(command: list[str], fallback: str = "", timeout: float = 0.35) -> str:
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            text=True,
            capture_output=True,
            check=False,
            timeout=timeout,
        )
        return result.stdout.strip() or fallback
    except Exception:
        return fallback


def run_json(command: list[str], fallback):
    try:
        return json.loads(out(command, ""))
    except Exception:
        return fallback


def run_json_timeout(command: list[str], fallback, timeout: float = 1.2):
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_DRY_RUN": "0"},
            text=True,
            capture_output=True,
            check=False,
            timeout=timeout,
        )
        if result.returncode == 0 and result.stdout.strip():
            return json.loads(result.stdout)
    except Exception:
        pass
    return fallback


def smart_window_state() -> dict:
    return run_json_timeout([str(ROOT / "bin/seven-window"), "status", "--json"], {}, timeout=0.9)


def smart_window_service_state() -> str:
    if not shutil.which("systemctl"):
        return "unknown"
    status = out(["systemctl", "--user", "is-active", "sevenos-window-controls.service"], "unknown", timeout=0.6)
    return status or "unknown"


def state_snapshot() -> dict:
    global STATE_CACHE
    if isinstance(STATE_CACHE, dict):
        return STATE_CACHE
    if not deep_settings_enabled():
        try:
            if HUB_STATE_CACHE.exists():
                payload = json.loads(HUB_STATE_CACHE.read_text(encoding="utf-8"))
                if isinstance(payload, dict):
                    STATE_CACHE = payload
                    return payload
        except Exception:
            pass
    if not deep_settings_enabled():
        STATE_CACHE = {"schema": "sevenos.settings.state.v1", "state": "warming"}
        return STATE_CACHE
    payload = run_json_timeout([str(ROOT / "bin/seven"), "state", "--json"], {}, timeout=3.0)
    STATE_CACHE = payload if isinstance(payload, dict) else {}
    return payload if isinstance(payload, dict) else {}


def run_detached(command: str) -> None:
    if command.strip() == "seven doctor open":
        command = "seven-doctor-native"
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def root_shell(command: str) -> str:
    return f"cd {shlex.quote(str(ROOT))} && {command}"


def theme_apply_command(mode: str = "current") -> str:
    # UX gate compatibility: ./install.sh theme dark / ./install.sh theme light
    return root_shell(f"./install.sh theme {shlex.quote(mode)}")


def language_apply_command() -> str:
    return root_shell("seven language apply --live && ./install.sh theme current")


def session_refresh_command() -> str:
    return theme_apply_command("current")


def repair_interface_command() -> str:
    return root_shell("seven repair ux --apply && ./install.sh theme current && seven-waybar repair")


def command_exists(command: str) -> bool:
    return shutil.which(command) is not None


def current_theme_mode() -> str:
    env_mode = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    if env_mode in {"dark", "light"}:
        return env_mode
    theme_file = CONFIG_DIR / "theme.conf"
    if theme_file.exists():
        for line in theme_file.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip().lower() in {"sevenos_theme_mode", "theme_mode", "mode"}:
                value = value.strip().strip('"').strip("'").lower()
                if value in {"dark", "light"}:
                    return value
    return "dark"


def read_region_prefs() -> dict[str, str]:
    prefs = {
        "region": "France",
        "time_format": "24h",
        "date_format": "DD/MM/YYYY",
        "week_start": "Monday",
        "units": "metric",
    }
    if REGION_PREFS.exists():
        for line in REGION_PREFS.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() in prefs and value.strip():
                prefs[key.strip()] = value.strip().strip('"').strip("'")
    return prefs


def write_region_contract(prefs: dict[str, str]) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    prefs_text = "\n".join(f"{name}={prefs[name]}" for name in sorted(prefs)) + "\n"
    env_text = (
        "\n".join(
            [
                f'export SEVENOS_REGION="{prefs["region"]}"',
                f'export SEVENOS_TIME_FORMAT="{prefs["time_format"]}"',
                f'export SEVENOS_DATE_FORMAT="{prefs["date_format"]}"',
                f'export SEVENOS_WEEK_START="{prefs["week_start"]}"',
                f'export SEVENOS_UNITS="{prefs["units"]}"',
            ]
        )
        + "\n"
    )
    if not REGION_PREFS.exists() or REGION_PREFS.read_text(encoding="utf-8", errors="ignore") != prefs_text:
        REGION_PREFS.write_text(prefs_text, encoding="utf-8")
    if not REGION_ENV.exists() or REGION_ENV.read_text(encoding="utf-8", errors="ignore") != env_text:
        REGION_ENV.write_text(env_text, encoding="utf-8")


def write_region_pref(key: str, value: str) -> None:
    prefs = read_region_prefs()
    prefs[key] = value
    write_region_contract(prefs)


def profile_avatar_pack() -> list[dict[str, str]]:
    avatar_dir = ROOT / "identity/profile-avatars"
    avatars = []
    for path in sorted(avatar_dir.glob("*.svg")):
        key = path.stem
        avatars.append({"key": key, "title": key.replace("-", " ").title(), "path": f"identity/profile-avatars/{path.name}"})
    return avatars


def read_profile_avatar() -> dict[str, str]:
    fallback = {"kind": "pack", "key": "aura", "path": "identity/profile-avatars/aura.svg"}
    try:
        payload = json.loads(PROFILE_AVATAR_PREFS.read_text(encoding="utf-8"))
        if isinstance(payload, dict):
            return {**fallback, **{str(k): str(v) for k, v in payload.items() if v is not None}}
    except Exception:
        pass
    return fallback


def write_profile_avatar(payload: dict[str, str]) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    PROFILE_AVATAR_PREFS.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def profile_avatar_path() -> Path | None:
    payload = read_profile_avatar()
    raw = payload.get("path", "")
    if not raw:
        return None
    path = Path(raw).expanduser()
    if not path.is_absolute():
        path = ROOT / path
    return path if path.exists() else None


def region_sample(prefs: dict[str, str]) -> str:
    date_samples = {
        "DD/MM/YYYY": "20/05/2026",
        "MM/DD/YYYY": "05/20/2026",
        "YYYY-MM-DD": "2026-05-20",
    }
    time_sample = "22:40" if prefs.get("time_format") == "24h" else "10:40 PM"
    units_sample = "km · kg · °C" if prefs.get("units") == "metric" else "mi · lb · °F"
    return f"{date_samples.get(prefs.get('date_format', ''), '2026-05-20')} · {time_sample} · {units_sample}"


def xdg_default(mime: str) -> str:
    if not live_settings_enabled():
        return tr("settings.check_on_demand", "Vérification à la demande")
    if not command_exists("xdg-mime"):
        return tr("settings.unknown", "Inconnu")
    value = out(["xdg-mime", "query", "default", mime], timeout=0.28)
    return value or tr_text("Not set")


def set_xdg_default(desktop_id: str, *mimes: str) -> None:
    if not command_exists("xdg-mime"):
        notify("SevenOS Settings", tr_text("xdg-mime is unavailable."))
        return
    for mime in mimes:
        subprocess.Popen(["xdg-mime", "default", desktop_id, mime], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    notify("SevenOS Settings", tr_text("Default app updated."))


def system_about() -> dict[str, str]:
    release = "SevenOS"
    release_file = Path("/etc/sevenos-release")
    if release_file.exists():
        release = release_file.read_text(encoding="utf-8", errors="ignore").strip().splitlines()[0] or release
    state = state_snapshot()
    if isinstance(state.get("readiness"), dict):
        readiness = state.get("readiness")
    elif deep_settings_enabled():
        readiness = run_json_timeout([str(ROOT / "scripts/readiness.sh"), "--json"], {"percent": "?"}, timeout=0.8)
    else:
        readiness = {"percent": "…"}
    smoke = state.get("smoke") if isinstance(state.get("smoke"), dict) else {}
    product = state.get("product") if isinstance(state.get("product"), dict) else {}
    distribution = state.get("distribution") if isinstance(state.get("distribution"), dict) else {}
    runtime = state.get("runtime") if isinstance(state.get("runtime"), dict) else {}
    installer_portal = state.get("installer_portal") if isinstance(state.get("installer_portal"), dict) else {}
    runtime_primary = runtime.get("primary_profile", {}) if isinstance(runtime.get("primary_profile"), dict) else {}
    installer_source = installer_portal.get("runtime_source", {}) if isinstance(installer_portal.get("runtime_source"), dict) else {}
    profile_name, profile_status = active_profile()
    return {
        "release": release,
        "hostname": platform.node() or "sevenos",
        "kernel": platform.release(),
        "session": "SevenOS" if os.environ.get("XDG_CURRENT_DESKTOP") == "Hyprland" else os.environ.get("XDG_CURRENT_DESKTOP") or os.environ.get("DESKTOP_SESSION") or "SevenOS",
        "profile": f"{profile_name} · {profile_status}",
        "readiness": f"{readiness.get('percent', '?')}%",
        "smoke": f"{smoke.get('state', 'unknown')} · {smoke.get('score', 0)}%",
        "product": f"{product.get('state', 'unknown')} · {product.get('score', 0)}%",
        "distribution": f"{distribution.get('state', 'unknown')} · {distribution.get('score', 0)}%",
        "runtime": f"{runtime.get('state', 'unknown')} · {runtime_primary.get('key', 'unknown')}",
        "installer": f"{installer_portal.get('state', 'unknown')} · {installer_source.get('state', 'unknown')}",
    }


def notify(title: str, message: str) -> None:
    if command_exists("notify-send"):
        subprocess.Popen(["notify-send", title, message], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def volume_state() -> int:
    if not command_exists("wpctl"):
        return 0
    raw = out(["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"], timeout=0.18)
    try:
        return max(0, min(100, int(float(raw.split()[1]) * 100)))
    except Exception:
        return 0


def set_volume(value: float) -> None:
    if command_exists("wpctl"):
        subprocess.Popen(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def brightness_state() -> int:
    if not command_exists("brightnessctl"):
        return 0
    try:
        current = int(out(["brightnessctl", "g"], "0", timeout=0.18))
        maximum = int(out(["brightnessctl", "m"], "1", timeout=0.18)) or 1
        return max(0, min(100, round(current / maximum * 100)))
    except Exception:
        return 0


def set_brightness(value: float) -> None:
    if command_exists("brightnessctl"):
        subprocess.Popen(["brightnessctl", "set", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def monitors_state() -> list[dict[str, str]]:
    if not deep_settings_enabled():
        return [{"name": "", "label": tr("settings.all_monitors", "All monitors"), "resolution": "preferred", "refresh": "60", "scale": "1"}]
    payload = run_json_timeout(["hyprctl", "monitors", "-j"], [], timeout=0.45) if command_exists("hyprctl") else []
    monitors: list[dict[str, str]] = []
    if isinstance(payload, list):
        for item in payload:
            if not isinstance(item, dict):
                continue
            name = str(item.get("name") or item.get("description") or "").strip()
            if not name:
                continue
            width = int(item.get("width") or 0)
            height = int(item.get("height") or 0)
            refresh = float(item.get("refreshRate") or 60)
            scale = float(item.get("scale") or 1)
            monitors.append(
                {
                    "name": name,
                    "label": f"{name} · {width}x{height}@{refresh:.0f}Hz · {scale:g}x",
                    "resolution": f"{width}x{height}" if width and height else "preferred",
                    "refresh": f"{refresh:.0f}",
                    "scale": f"{scale:g}",
                }
            )
    if not monitors:
        monitors.append({"name": "", "label": tr("settings.all_monitors", "All monitors"), "resolution": "preferred", "refresh": "60", "scale": "1"})
    return monitors


def write_monitor_rule(name: str, resolution: str, scale: str) -> None:
    HYPR_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    monitor_name = name or ""
    mode = "preferred" if resolution == "preferred" else f"{resolution}@60"
    rule = f"monitor = {monitor_name},{mode},auto,{scale}"
    lines: list[str] = []
    replaced = False
    if MONITOR_PREFS.exists():
        MONITOR_BACKUP.write_text(MONITOR_PREFS.read_text(encoding="utf-8", errors="ignore"), encoding="utf-8")
        for line in MONITOR_PREFS.read_text(encoding="utf-8", errors="ignore").splitlines():
            stripped = line.strip()
            if stripped.startswith("monitor") and "=" in stripped:
                _left, _eq, value = stripped.partition("=")
                current_name = value.strip().split(",", 1)[0].strip()
                if current_name == monitor_name:
                    lines.append(rule)
                    replaced = True
                    continue
            lines.append(line)
    if not lines:
        lines = ["# SevenOS monitor override", "# Example:", "# monitor = eDP-1,preferred,auto,1"]
    if not replaced:
        lines.append(rule)
    MONITOR_PREFS.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")


def restore_monitor_rule() -> bool:
    if not MONITOR_BACKUP.exists():
        return False
    HYPR_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    MONITOR_PREFS.write_text(MONITOR_BACKUP.read_text(encoding="utf-8", errors="ignore"), encoding="utf-8")
    return True


def wifi_state() -> tuple[str, str]:
    if not command_exists("nmcli"):
        return tr_text("Missing"), tr_text("SevenOS network tools unavailable")
    radio = out(["nmcli", "radio", "wifi"], "unknown", timeout=0.18)
    ssid = out(["bash", "-lc", "nmcli -t -f active,ssid dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"], timeout=0.22)
    if radio == "disabled":
        return tr_text("Off"), tr_text("Radio disabled")
    return tr_text("On"), ssid or tr_text("Not connected")


def battery_state() -> tuple[str, str]:
    bats = list(Path("/sys/class/power_supply").glob("BAT*"))
    if not bats:
        return "AC", tr_text("No battery")
    bat = bats[0]
    status = (bat / "status").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "status").exists() else tr("settings.unknown", "Inconnu")
    capacity = (bat / "capacity").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "capacity").exists() else "?"
    return f"{capacity}%", status


def notification_backend_state() -> tuple[str, str]:
    if command_exists("swaync-client"):
        running = subprocess.run(["pgrep", "-x", "swaync"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0
        return "SwayNC", tr("settings.running", "Actif") if running else tr("settings.stopped", "Arrêté")
    if command_exists("makoctl"):
        running = subprocess.run(["pgrep", "-x", "mako"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0
        return "Mako", tr("settings.running", "Actif") if running else tr("settings.stopped", "Arrêté")
    return tr("settings.missing", "Manquant"), tr("settings.install_required", "Installation requise")


def notification_count_state() -> str:
    if command_exists("swaync-client"):
        count = out(["swaync-client", "-sw", "-c"], "0", timeout=0.35)
        return count if count.isdigit() else "0"
    return tr("settings.unknown", "Inconnu")


def notification_focus_state() -> str:
    if (STATE_DIR / "notifications.dnd").exists():
        return tr("settings.enabled", "Activé")
    return tr("settings.disabled", "Désactivé")


def spotlight_privacy_state() -> tuple[str, str]:
    candidates = [
        STATE_DIR / "spotlight-history.jsonl",
        CACHE_DIR / "spotlight-history.jsonl",
        CACHE_DIR / "spotlight/history.jsonl",
    ]
    existing = next((path for path in candidates if path.exists()), None)
    if existing is None:
        return tr("settings.private", "Local"), tr("settings.no_history", "Aucun historique visible")
    try:
        count = sum(1 for _line in existing.open("r", encoding="utf-8", errors="ignore"))
    except Exception:
        count = 0
    return tr("settings.local_history", "Historique local"), tr("settings.items_count", "{count} élément(s)", count=count)


def desktop_launcher_count() -> str:
    roots = [Path("/usr/share/applications"), Path.home() / ".local/share/applications"]
    total = 0
    for root in roots:
        if not root.exists():
            continue
        try:
            total += sum(1 for path in root.glob("*.desktop") if path.is_file())
        except Exception:
            pass
    return str(total)


def flatpak_app_count() -> str:
    if not command_exists("flatpak"):
        return tr("settings.missing", "Manquant")
    try:
        result = subprocess.run(["flatpak", "list", "--app", "--columns=application"], text=True, capture_output=True, check=False, timeout=0.8)
        return str(len([line for line in result.stdout.splitlines() if line.strip()]))
    except Exception:
        return tr("settings.unknown", "Inconnu")


def store_state() -> tuple[str, str]:
    native = ROOT / "bin/seven-store-native"
    wrapper = ROOT / "bin/seven-store"
    if native.exists() and os.access(native, os.X_OK):
        return "SevenStore", tr("settings.ready", "Prêt")
    if wrapper.exists() and os.access(wrapper, os.X_OK):
        return "SevenStore", tr("settings.partial", "Partiel")
    return tr("settings.missing", "Manquant"), tr("settings.install_required", "Installation requise")


def update_state_label() -> tuple[str, str]:
    payload = run_json_timeout([str(ROOT / "bin/seven"), "update", "--json"], {}, timeout=1.1)
    if isinstance(payload, dict):
        status = str(payload.get("state") or payload.get("status") or payload.get("readiness") or "").strip()
        pending = payload.get("pending") or payload.get("updates") or payload.get("available")
        if isinstance(pending, list):
            return str(len(pending)), tr("settings.updates_available", "Mises à jour disponibles")
        if isinstance(pending, int):
            return str(pending), tr("settings.updates_available", "Mises à jour disponibles")
        if status:
            return status, tr("settings.update_state", "État des mises à jour")
    return tr("settings.check", "Vérifier"), tr("settings.update_state", "État des mises à jour")


def active_profile() -> tuple[str, str]:
    global PROFILE_STATUS_CACHE
    if not deep_settings_enabled():
        key = active_profile_key()
        catalog = profile_catalog()
        naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
        return str(naming.get(key) or key.title()), tr_text("Active")
    if PROFILE_STATUS_CACHE is None:
        payload = run_json_timeout([str(ROOT / "bin/seven"), "profile", "status", "--json"], [], timeout=0.8)
        PROFILE_STATUS_CACHE = payload if isinstance(payload, list) else []
    payload = PROFILE_STATUS_CACHE
    if isinstance(payload, list):
        item = next((row for row in payload if row.get("active")), None)
        if item:
            return item.get("title", tr_text("Profile")), item.get("state", "unknown")
    return "Equinox", "unknown"


def active_profile_key() -> str:
    global PROFILE_STATUS_CACHE
    profile_env = CONFIG_DIR / "profile.env"
    if profile_env.exists():
        for line in profile_env.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() in {"SEVENOS_ACTIVE_PROFILE", "SEVENOS_PROFILE"} and value.strip():
                return value.strip().strip('"').strip("'").lower()
    if PROFILE_STATUS_CACHE is None and deep_settings_enabled():
        payload = run_json_timeout([str(ROOT / "bin/seven"), "profile", "status", "--json"], [], timeout=0.8)
        PROFILE_STATUS_CACHE = payload if isinstance(payload, list) else []
    payload = PROFILE_STATUS_CACHE
    if isinstance(payload, list):
        item = next((row for row in payload if row.get("active")), None)
        if item:
            return str(item.get("key") or item.get("profile") or "equinox").lower()
    return "equinox"


def profile_catalog() -> dict:
    catalog_file = ROOT / "profiles/catalog.json"
    fallback = {
        "profile_naming": {
            "equinox": "Equinox Balance",
            "baobab": "Baobab Cultural OS",
            "forge": "Forge DevOps",
            "shield": "Shield Cybersecurity",
            "studio": "Studio Creator",
            "atlas": "Atlas SevenOS",
            "pulse": "Pulse Gaming",
        },
        "profiles": {},
    }
    if not catalog_file.exists():
        return fallback
    try:
        payload = json.loads(catalog_file.read_text(encoding="utf-8"))
        return payload if isinstance(payload, dict) else fallback
    except Exception:
        return fallback


def runtime_capabilities() -> list[str]:
    runtime_env = CONFIG_DIR / "runtime.env"
    if not runtime_env.exists():
        return []
    for line in runtime_env.read_text(encoding="utf-8", errors="ignore").splitlines():
        key, _, value = line.partition("=")
        if key.strip() == "SEVENOS_RUNTIME_CAPABILITIES":
            return [item.strip().lower() for item in value.strip().strip('"').strip("'").split(",") if item.strip()]
    return []


def shield_state() -> tuple[str, str]:
    if not deep_settings_enabled():
        return "…", tr_text("Ready")
    payload = run_json_timeout([str(ROOT / "security/shield-status.sh"), "--json"], {"percent": 0, "posture": "unknown"}, timeout=0.45)
    return f"{payload.get('percent', 0)}%", str(payload.get("posture", "unknown"))


def session_state() -> tuple[str, str]:
    if not deep_settings_enabled():
        return "…", tr_text("Live")
    payload = run_json_timeout([str(ROOT / "bin/seven-session-status"), "--json"], {"percent": 0, "mode": "unknown"}, timeout=0.45)
    return f"{payload.get('percent', 0)}%", str(payload.get("mode", "unknown"))


def font_state() -> dict:
    fallback = {
        "interface": "SF Pro Display",
        "text": "SF Pro Text",
        "mono": "SF Mono",
        "cyber": "JetBrainsMono Nerd Font",
        "brand": "SF Pro Rounded",
        "font_home": str(Path.home() / ".local/share/fonts/SevenOS"),
    }
    if not deep_settings_enabled():
        return fallback
    return run_json(
        [str(ROOT / "scripts/fonts.sh"), "status", "--json"],
        fallback,
    )


def language_state() -> dict:
    global LANGUAGE_CACHE
    if isinstance(LANGUAGE_CACHE, dict):
        return LANGUAGE_CACHE
    fallback = {
        "current": os.environ.get("LANG", "C.UTF-8"),
        "label": tr("language.system_default", "System default"),
        "language": "C",
        "languages": [
            {
                "locale": os.environ.get("LANG", "C.UTF-8"),
                "label": tr("language.system_default", "System default"),
                "language": "C",
                "current": True,
                "installed": True,
            }
        ],
    }
    if not live_settings_enabled():
        LANGUAGE_CACHE = fallback
        return LANGUAGE_CACHE
    LANGUAGE_CACHE = run_json_timeout(
        [str(ROOT / "bin/seven-language"), "status", "--json"],
        fallback,
        timeout=0.8,
    )
    return LANGUAGE_CACHE


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


