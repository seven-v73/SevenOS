    nav("display", "󰍹", "Displays", "display")
    nav("network", "󰤨", "Wi-Fi", "network")
    nav("sound", "󰕾", "Sound", "sound")
    nav("keyboard", "󰌌", "Keyboard", "keyboard")
    nav("fonts", "󰛖", "Fonts", "fonts")
    nav("security", "󰒃", "Security", "security")
    nav("profiles", "󰐃", "Profiles", "profiles")
    nav("power", "󰁹", "Power", "power")
    nav("apps", "󰀻", "Apps", "apps")
    nav("system", "󰒓", "System", "system")
    initial_page = initial_page if initial_page in pages else "overview"

    # Overview
    overview = pages["overview"][0]
    profile_name, profile_status = active_profile()
