    def search_settings(_entry=None) -> None:
        query = search_entry.get_text().strip().lower()
        if not query:
            search_results.hide()
            return
        for target, terms in settings_search_index.items():
            page_title = pages[target][0].get_children()[0].get_text().lower()
            if query in terms or query in page_title:
                activate_page(target, nav_by_target[target])
                show_feedback(tr("settings.search.opened", "Opened {page}.", page=pages[target][0].get_children()[0].get_text()))
                return
        show_feedback(tr("settings.search.no_result", "No Settings page matched “{query}”.", query=query))

    search_entry.connect("activate", search_settings)

    search_items = [
        ("󰒓", tr("settings.general", "General"), tr("settings.general.subtitle", "Language, region, theme entry points and everyday SevenOS behavior."), "general"),
        ("󰤨", "Wi-Fi", tr("settings.network.subtitle", "Connect, diagnose and configure NetworkManager."), "network"),
        ("󰂯", "Bluetooth", tr("settings.bluetooth.note", "Pair headphones, keyboards, phones and nearby devices."), "network"),
        ("󰍹", tr("settings.displays", "Displays"), tr("settings.display.subtitle", "Brightness, monitor tools and Hyprland display configuration."), "display"),
        ("󰒓", tr("settings.default_apps", "Default apps"), tr("settings.default_apps.subtitle", "Choose the apps SevenOS uses for files, links, documents, media and archives."), "defaults"),
        ("󰐃", tr("settings.profiles", "Profiles"), tr("settings.profiles.subtitle", "Switch SevenOS work modes and open profile workspaces."), "profiles"),
        ("󰌾", tr("settings.privacy", "Privacy"), tr("settings.privacy.subtitle", "Local data, permissions, notifications and SevenAI privacy controls."), "privacy"),
