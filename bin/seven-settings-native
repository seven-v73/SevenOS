#!/usr/bin/env python3
"""Native SevenOS Settings.

This is the normal-user control surface for SevenOS. Spotlight remains the
global command search, while Settings keeps a focused preference search for
people who already know they are changing system behavior.
"""

from __future__ import annotations

import json
import os
import platform
import pwd
import re
import selectors
import shlex
import shutil
import subprocess
import sys
import threading
import time
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache"))) / "sevenos"
HUB_STATE_CACHE = CACHE_DIR / "hub-state.json"
SETTINGS_ACTION_LOG = CACHE_DIR / "settings-actions.log"
REGION_PREFS = CONFIG_DIR / "region.conf"
REGION_ENV = CONFIG_DIR / "region.env"
HYPR_CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "hypr" / "conf"
MONITOR_PREFS = HYPR_CONFIG_DIR / "monitor.conf"
MONITOR_BACKUP = HYPR_CONFIG_DIR / "monitor.conf.sevenos.bak"
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr, tr_text  # noqa: E402
import seven_theme  # noqa: E402

STATE_CACHE: dict | None = None
PROFILE_STATUS_CACHE: list[dict] | None = None
LANGUAGE_CACHE: dict | None = None


def deep_settings_enabled() -> bool:
    return os.environ.get("SEVENOS_SETTINGS_DEEP") == "1"


def out(command: list[str], fallback: str = "", timeout: float = 0.35) -> str:
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            text=True,
            capture_output=True,
            check=False,
            timeout=timeout,
        )
        return result.stdout.strip() or fallback
    except Exception:
        return fallback


def run_json(command: list[str], fallback):
    try:
        return json.loads(out(command, ""))
    except Exception:
        return fallback


def run_json_timeout(command: list[str], fallback, timeout: float = 1.2):
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_DRY_RUN": "0"},
            text=True,
            capture_output=True,
            check=False,
            timeout=timeout,
        )
        if result.returncode == 0 and result.stdout.strip():
            return json.loads(result.stdout)
    except Exception:
        pass
    return fallback


def state_snapshot() -> dict:
    global STATE_CACHE
    if isinstance(STATE_CACHE, dict):
        return STATE_CACHE
    if not deep_settings_enabled():
        try:
            if HUB_STATE_CACHE.exists():
                payload = json.loads(HUB_STATE_CACHE.read_text(encoding="utf-8"))
                if isinstance(payload, dict):
                    STATE_CACHE = payload
                    return payload
        except Exception:
            pass
    if not deep_settings_enabled():
        STATE_CACHE = {"schema": "sevenos.settings.state.v1", "state": "warming"}
        return STATE_CACHE
    payload = run_json_timeout([str(ROOT / "bin/seven"), "state", "--json"], {}, timeout=3.0)
    STATE_CACHE = payload if isinstance(payload, dict) else {}
    return payload if isinstance(payload, dict) else {}


def run_detached(command: str) -> None:
    if command.strip() == "seven doctor open":
        command = "seven-doctor-native"
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def command_exists(command: str) -> bool:
    return shutil.which(command) is not None


def current_theme_mode() -> str:
    env_mode = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    if env_mode in {"dark", "light"}:
        return env_mode
    theme_file = CONFIG_DIR / "theme.conf"
    if theme_file.exists():
        for line in theme_file.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip().lower() in {"sevenos_theme_mode", "theme_mode", "mode"}:
                value = value.strip().strip('"').strip("'").lower()
                if value in {"dark", "light"}:
                    return value
    return "dark"


def read_region_prefs() -> dict[str, str]:
    prefs = {
        "region": "France",
        "time_format": "24h",
        "date_format": "DD/MM/YYYY",
        "week_start": "Monday",
        "units": "metric",
    }
    if REGION_PREFS.exists():
        for line in REGION_PREFS.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() in prefs and value.strip():
                prefs[key.strip()] = value.strip().strip('"').strip("'")
    return prefs


def write_region_contract(prefs: dict[str, str]) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    prefs_text = "\n".join(f"{name}={prefs[name]}" for name in sorted(prefs)) + "\n"
    env_text = (
        "\n".join(
            [
                f'export SEVENOS_REGION="{prefs["region"]}"',
                f'export SEVENOS_TIME_FORMAT="{prefs["time_format"]}"',
                f'export SEVENOS_DATE_FORMAT="{prefs["date_format"]}"',
                f'export SEVENOS_WEEK_START="{prefs["week_start"]}"',
                f'export SEVENOS_UNITS="{prefs["units"]}"',
            ]
        )
        + "\n"
    )
    if not REGION_PREFS.exists() or REGION_PREFS.read_text(encoding="utf-8", errors="ignore") != prefs_text:
        REGION_PREFS.write_text(prefs_text, encoding="utf-8")
    if not REGION_ENV.exists() or REGION_ENV.read_text(encoding="utf-8", errors="ignore") != env_text:
        REGION_ENV.write_text(env_text, encoding="utf-8")


def write_region_pref(key: str, value: str) -> None:
    prefs = read_region_prefs()
    prefs[key] = value
    write_region_contract(prefs)


def region_sample(prefs: dict[str, str]) -> str:
    date_samples = {
        "DD/MM/YYYY": "20/05/2026",
        "MM/DD/YYYY": "05/20/2026",
        "YYYY-MM-DD": "2026-05-20",
    }
    time_sample = "22:40" if prefs.get("time_format") == "24h" else "10:40 PM"
    units_sample = "km · kg · °C" if prefs.get("units") == "metric" else "mi · lb · °F"
    return f"{date_samples.get(prefs.get('date_format', ''), '2026-05-20')} · {time_sample} · {units_sample}"


def xdg_default(mime: str) -> str:
    if not deep_settings_enabled():
        return tr("settings.check_on_demand", "Vérification à la demande")
    if not command_exists("xdg-mime"):
        return tr("settings.unknown", "Inconnu")
    value = out(["xdg-mime", "query", "default", mime], timeout=0.18)
    return value or tr_text("Not set")


def set_xdg_default(desktop_id: str, *mimes: str) -> None:
    if not command_exists("xdg-mime"):
        notify("SevenOS Settings", tr_text("xdg-mime is unavailable."))
        return
    for mime in mimes:
        subprocess.Popen(["xdg-mime", "default", desktop_id, mime], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    notify("SevenOS Settings", tr_text("Default app updated."))


def system_about() -> dict[str, str]:
    release = "SevenOS"
    release_file = Path("/etc/sevenos-release")
    if release_file.exists():
        release = release_file.read_text(encoding="utf-8", errors="ignore").strip().splitlines()[0] or release
    state = state_snapshot()
    if isinstance(state.get("readiness"), dict):
        readiness = state.get("readiness")
    elif deep_settings_enabled():
        readiness = run_json_timeout([str(ROOT / "scripts/readiness.sh"), "--json"], {"percent": "?"}, timeout=0.8)
    else:
        readiness = {"percent": "…"}
    smoke = state.get("smoke") if isinstance(state.get("smoke"), dict) else {}
    product = state.get("product") if isinstance(state.get("product"), dict) else {}
    distribution = state.get("distribution") if isinstance(state.get("distribution"), dict) else {}
    runtime = state.get("runtime") if isinstance(state.get("runtime"), dict) else {}
    installer_portal = state.get("installer_portal") if isinstance(state.get("installer_portal"), dict) else {}
    runtime_primary = runtime.get("primary_profile", {}) if isinstance(runtime.get("primary_profile"), dict) else {}
    installer_source = installer_portal.get("runtime_source", {}) if isinstance(installer_portal.get("runtime_source"), dict) else {}
    profile_name, profile_status = active_profile()
    return {
        "release": release,
        "hostname": platform.node() or "sevenos",
        "kernel": platform.release(),
        "session": "SevenOS" if os.environ.get("XDG_CURRENT_DESKTOP") == "Hyprland" else os.environ.get("XDG_CURRENT_DESKTOP") or os.environ.get("DESKTOP_SESSION") or "SevenOS",
        "profile": f"{profile_name} · {profile_status}",
        "readiness": f"{readiness.get('percent', '?')}%",
        "smoke": f"{smoke.get('state', 'unknown')} · {smoke.get('score', 0)}%",
        "product": f"{product.get('state', 'unknown')} · {product.get('score', 0)}%",
        "distribution": f"{distribution.get('state', 'unknown')} · {distribution.get('score', 0)}%",
        "runtime": f"{runtime.get('state', 'unknown')} · {runtime_primary.get('key', 'unknown')}",
        "installer": f"{installer_portal.get('state', 'unknown')} · {installer_source.get('state', 'unknown')}",
    }


def notify(title: str, message: str) -> None:
    if command_exists("notify-send"):
        subprocess.Popen(["notify-send", title, message], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def volume_state() -> int:
    if not command_exists("wpctl"):
        return 0
    raw = out(["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"], timeout=0.18)
    try:
        return max(0, min(100, int(float(raw.split()[1]) * 100)))
    except Exception:
        return 0


def set_volume(value: float) -> None:
    if command_exists("wpctl"):
        subprocess.Popen(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def brightness_state() -> int:
    if not command_exists("brightnessctl"):
        return 0
    try:
        current = int(out(["brightnessctl", "g"], "0", timeout=0.18))
        maximum = int(out(["brightnessctl", "m"], "1", timeout=0.18)) or 1
        return max(0, min(100, round(current / maximum * 100)))
    except Exception:
        return 0


def set_brightness(value: float) -> None:
    if command_exists("brightnessctl"):
        subprocess.Popen(["brightnessctl", "set", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def monitors_state() -> list[dict[str, str]]:
    if not deep_settings_enabled():
        return [{"name": "", "label": tr("settings.all_monitors", "All monitors"), "resolution": "preferred", "refresh": "60", "scale": "1"}]
    payload = run_json_timeout(["hyprctl", "monitors", "-j"], [], timeout=0.45) if command_exists("hyprctl") else []
    monitors: list[dict[str, str]] = []
    if isinstance(payload, list):
        for item in payload:
            if not isinstance(item, dict):
                continue
            name = str(item.get("name") or item.get("description") or "").strip()
            if not name:
                continue
            width = int(item.get("width") or 0)
            height = int(item.get("height") or 0)
            refresh = float(item.get("refreshRate") or 60)
            scale = float(item.get("scale") or 1)
            monitors.append(
                {
                    "name": name,
                    "label": f"{name} · {width}x{height}@{refresh:.0f}Hz · {scale:g}x",
                    "resolution": f"{width}x{height}" if width and height else "preferred",
                    "refresh": f"{refresh:.0f}",
                    "scale": f"{scale:g}",
                }
            )
    if not monitors:
        monitors.append({"name": "", "label": tr("settings.all_monitors", "All monitors"), "resolution": "preferred", "refresh": "60", "scale": "1"})
    return monitors


def write_monitor_rule(name: str, resolution: str, scale: str) -> None:
    HYPR_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    monitor_name = name or ""
    mode = "preferred" if resolution == "preferred" else f"{resolution}@60"
    rule = f"monitor = {monitor_name},{mode},auto,{scale}"
    lines: list[str] = []
    replaced = False
    if MONITOR_PREFS.exists():
        MONITOR_BACKUP.write_text(MONITOR_PREFS.read_text(encoding="utf-8", errors="ignore"), encoding="utf-8")
        for line in MONITOR_PREFS.read_text(encoding="utf-8", errors="ignore").splitlines():
            stripped = line.strip()
            if stripped.startswith("monitor") and "=" in stripped:
                _left, _eq, value = stripped.partition("=")
                current_name = value.strip().split(",", 1)[0].strip()
                if current_name == monitor_name:
                    lines.append(rule)
                    replaced = True
                    continue
            lines.append(line)
    if not lines:
        lines = ["# SevenOS monitor override", "# Example:", "# monitor = eDP-1,preferred,auto,1"]
    if not replaced:
        lines.append(rule)
    MONITOR_PREFS.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")


def restore_monitor_rule() -> bool:
    if not MONITOR_BACKUP.exists():
        return False
    HYPR_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    MONITOR_PREFS.write_text(MONITOR_BACKUP.read_text(encoding="utf-8", errors="ignore"), encoding="utf-8")
    return True


def wifi_state() -> tuple[str, str]:
    if not command_exists("nmcli"):
        return tr_text("Missing"), tr_text("SevenOS network tools unavailable")
    radio = out(["nmcli", "radio", "wifi"], "unknown", timeout=0.18)
    ssid = out(["bash", "-lc", "nmcli -t -f active,ssid dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"], timeout=0.22)
    if radio == "disabled":
        return tr_text("Off"), tr_text("Radio disabled")
    return tr_text("On"), ssid or tr_text("Not connected")


def battery_state() -> tuple[str, str]:
    bats = list(Path("/sys/class/power_supply").glob("BAT*"))
    if not bats:
        return "AC", tr_text("No battery")
    bat = bats[0]
    status = (bat / "status").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "status").exists() else tr("settings.unknown", "Inconnu")
    capacity = (bat / "capacity").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "capacity").exists() else "?"
    return f"{capacity}%", status


def active_profile() -> tuple[str, str]:
    global PROFILE_STATUS_CACHE
    if not deep_settings_enabled():
        key = active_profile_key()
        catalog = profile_catalog()
        naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
        return str(naming.get(key) or key.title()), tr_text("Active")
    if PROFILE_STATUS_CACHE is None:
        payload = run_json_timeout([str(ROOT / "bin/seven"), "profile", "status", "--json"], [], timeout=0.8)
        PROFILE_STATUS_CACHE = payload if isinstance(payload, list) else []
    payload = PROFILE_STATUS_CACHE
    if isinstance(payload, list):
        item = next((row for row in payload if row.get("active")), None)
        if item:
            return item.get("title", tr_text("Profile")), item.get("state", "unknown")
    return "Equinox", "unknown"


def active_profile_key() -> str:
    global PROFILE_STATUS_CACHE
    profile_env = CONFIG_DIR / "profile.env"
    if profile_env.exists():
        for line in profile_env.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip() in {"SEVENOS_ACTIVE_PROFILE", "SEVENOS_PROFILE"} and value.strip():
                return value.strip().strip('"').strip("'").lower()
    if PROFILE_STATUS_CACHE is None and deep_settings_enabled():
        payload = run_json_timeout([str(ROOT / "bin/seven"), "profile", "status", "--json"], [], timeout=0.8)
        PROFILE_STATUS_CACHE = payload if isinstance(payload, list) else []
    payload = PROFILE_STATUS_CACHE
    if isinstance(payload, list):
        item = next((row for row in payload if row.get("active")), None)
        if item:
            return str(item.get("key") or item.get("profile") or "equinox").lower()
    return "equinox"


def profile_catalog() -> dict:
    catalog_file = ROOT / "profiles/catalog.json"
    fallback = {
        "profile_naming": {
            "equinox": "Equinox Balance",
            "baobab": "Baobab Cultural OS",
            "forge": "Forge DevOps",
            "shield": "Shield Cybersecurity",
            "studio": "Studio Creator",
            "windows": "Windows SevenOS",
            "pulse": "Pulse Gaming",
        },
        "profiles": {},
    }
    if not catalog_file.exists():
        return fallback
    try:
        payload = json.loads(catalog_file.read_text(encoding="utf-8"))
        return payload if isinstance(payload, dict) else fallback
    except Exception:
        return fallback


def runtime_capabilities() -> list[str]:
    runtime_env = CONFIG_DIR / "runtime.env"
    if not runtime_env.exists():
        return []
    for line in runtime_env.read_text(encoding="utf-8", errors="ignore").splitlines():
        key, _, value = line.partition("=")
        if key.strip() == "SEVENOS_RUNTIME_CAPABILITIES":
            return [item.strip().lower() for item in value.strip().strip('"').strip("'").split(",") if item.strip()]
    return []


def shield_state() -> tuple[str, str]:
    if not deep_settings_enabled():
        return "…", tr_text("Ready")
    payload = run_json_timeout([str(ROOT / "security/shield-status.sh"), "--json"], {"percent": 0, "posture": "unknown"}, timeout=0.45)
    return f"{payload.get('percent', 0)}%", str(payload.get("posture", "unknown"))


def session_state() -> tuple[str, str]:
    if not deep_settings_enabled():
        return "…", tr_text("Live")
    payload = run_json_timeout([str(ROOT / "bin/seven-session-status"), "--json"], {"percent": 0, "mode": "unknown"}, timeout=0.45)
    return f"{payload.get('percent', 0)}%", str(payload.get("mode", "unknown"))


def font_state() -> dict:
    fallback = {
        "interface": "SF Pro Display",
        "text": "SF Pro Text",
        "mono": "SF Mono",
        "cyber": "JetBrainsMono Nerd Font",
        "brand": "SF Pro Rounded",
        "font_home": str(Path.home() / ".local/share/fonts/SevenOS"),
    }
    if not deep_settings_enabled():
        return fallback
    return run_json(
        [str(ROOT / "scripts/fonts.sh"), "status", "--json"],
        fallback,
    )


def language_state() -> dict:
    global LANGUAGE_CACHE
    if isinstance(LANGUAGE_CACHE, dict):
        return LANGUAGE_CACHE
    fallback = {
        "current": os.environ.get("LANG", "C.UTF-8"),
        "label": tr("language.system_default", "System default"),
        "language": "C",
        "languages": [
            {
                "locale": os.environ.get("LANG", "C.UTF-8"),
                "label": tr("language.system_default", "System default"),
                "language": "C",
                "current": True,
                "installed": True,
            }
        ],
    }
    if not deep_settings_enabled():
        LANGUAGE_CACHE = fallback
        return LANGUAGE_CACHE
    LANGUAGE_CACHE = run_json_timeout(
        [str(ROOT / "bin/seven-language"), "status", "--json"],
        fallback,
        timeout=0.8,
    )
    return LANGUAGE_CACHE


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run(initial_page: str = "overview") -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk, Pango

    GLib.set_prgname("SevenSettingsNative")
    GLib.set_application_name(tr("settings.title", "Réglages SevenOS"))
    try:
        Gdk.set_program_class("SevenSettingsNative")
    except Exception:
        pass

    theme_mode = current_theme_mode()
    css = seven_theme.gtk_app_css("settings", theme_mode) + seven_theme.surface_css("settings", mode=theme_mode)
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title=tr("settings.title", "Réglages SevenOS"))
    window.set_wmclass("SevenSettingsNative", "SevenSettingsNative")
    window.set_decorated(False)
    window.set_resizable(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    screen = Gdk.Screen.get_default()
    screen_width = screen.get_width() if screen else 1280
    screen_height = screen.get_height() if screen else 720
    compact_screen = screen_width < 1180 or screen_height < 720
    default_width = min(1000, max(760, int(screen_width * 0.76)))
    default_height = min(680, max(520, int(screen_height * 0.72)))
    min_width = 720 if compact_screen else 860
    min_height = 500 if compact_screen else 560
    sidebar_width = 188 if compact_screen else 220
    content_width = min(850, max(520, default_width - sidebar_width - 54))
    card_width = max(250, int((content_width - 12) / 2))
    window.set_default_size(default_width, default_height)
    geometry = Gdk.Geometry()
    geometry.min_width = min_width
    geometry.min_height = min_height
    window.set_geometry_hints(None, geometry, Gdk.WindowHints.MIN_SIZE)
    window.get_style_context().add_class("settings-window")
    window.get_style_context().add_class(f"theme-{theme_mode}")

    shell = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    shell.get_style_context().add_class("settings-shell")
    window.add(shell)

    body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)

    def toggle_zoom() -> None:
        if window.is_maximized():
            window.unmaximize()
        width, _height = window.get_size()
        if width >= 1120:
            window.resize(default_width, default_height)
        else:
            window.resize(min(1160, max(default_width, int(screen_width * 0.82))), min(760, max(default_height, int(screen_height * 0.78))))
        window.set_position(Gtk.WindowPosition.CENTER)

    sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
    sidebar.set_size_request(sidebar_width, -1)
    sidebar.get_style_context().add_class("sidebar")

    traffic = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    traffic.get_style_context().add_class("traffic")
    for klass, action in (("dot-close", window.close), ("dot-min", window.iconify), ("dot-max", toggle_zoom)):
        button = Gtk.Button()
        button.get_style_context().add_class("traffic-dot")
        button.get_style_context().add_class(klass)
        button.connect("clicked", lambda _button, callback=action: callback())
        traffic.pack_start(button, False, False, 0)
    sidebar.pack_start(traffic, False, False, 0)

    brand = Gtk.Label(label=tr("settings.title", "Réglages SevenOS"))
    brand.set_xalign(0)
    brand.get_style_context().add_class("brand")
    sidebar.pack_start(brand, False, False, 0)

    stack = Gtk.Stack()
    stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
    stack.set_transition_duration(140)
    stack.set_hexpand(True)
    stack.set_vexpand(True)
    content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    content.get_style_context().add_class("content")
    search_entry = Gtk.SearchEntry()
    search_entry.set_placeholder_text(tr("settings.search.placeholder", "Rechercher réglages, apps, langue, Wi-Fi…"))
    search_entry.get_style_context().add_class("settings-search")
    content.pack_start(search_entry, False, False, 0)
    search_results = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    search_results.set_no_show_all(True)
    search_results.get_style_context().add_class("search-results")
    content.pack_start(search_results, False, False, 0)
    feedback_banner = Gtk.Label(label="")
    feedback_banner.set_xalign(0)
    feedback_banner.set_line_wrap(True)
    feedback_banner.set_no_show_all(True)
    feedback_banner.get_style_context().add_class("feedback-banner")
    content.pack_start(feedback_banner, False, False, 0)
    content.pack_start(stack, True, True, 0)

    body.pack_start(sidebar, False, False, 0)
    body.pack_start(content, True, True, 0)
    shell.pack_start(body, True, True, 0)

    nav_buttons: list[Gtk.Button] = []
    nav_by_target: dict[str, Gtk.Button] = {}

    def page(title: str, subtitle: str) -> tuple[Gtk.Box, Gtk.ScrolledWindow]:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        outer.set_halign(Gtk.Align.START)
        outer.set_valign(Gtk.Align.START)
        outer.set_size_request(content_width, -1)
        outer.get_style_context().add_class("page-frame")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("page-title")
        subtitle_label = Gtk.Label(label=subtitle)
        subtitle_label.set_xalign(0)
        subtitle_label.set_line_wrap(True)
        subtitle_label.get_style_context().add_class("page-subtitle")
        outer.pack_start(title_label, False, False, 0)
        outer.pack_start(subtitle_label, False, False, 0)
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        viewport = Gtk.Viewport()
        viewport.add(outer)
        scrolled.add(viewport)
        return outer, scrolled

    def activate_page(name: str, button: Gtk.Button) -> None:
        stack.set_visible_child_name(name)
        for item in nav_buttons:
            item.get_style_context().remove_class("active")
        button.get_style_context().add_class("active")

    def show_feedback(message: str) -> None:
        feedback_banner.set_text(message)
        feedback_banner.show()

        def hide_feedback() -> bool:
            feedback_banner.hide()
            return False

        GLib.timeout_add_seconds(4, hide_feedback)

    def style_dialog(dialog: Gtk.Dialog) -> Gtk.Box:
        dialog.set_decorated(False)
        dialog.set_app_paintable(True)
        try:
            rgba_visual = Gdk.Screen.get_default().get_rgba_visual()
            if rgba_visual is not None:
                dialog.set_visual(rgba_visual)
        except Exception:
            pass
        dialog.get_style_context().add_class("settings-dialog")
        dialog.get_style_context().add_class(f"theme-{current_theme_mode()}")
        dialog.set_border_width(0)
        box = dialog.get_content_area()
        box.get_style_context().add_class("settings-dialog-content")
        action_area = dialog.get_action_area()
        action_area.get_style_context().add_class("settings-dialog-actions")
        try:
            dialog.get_child().get_style_context().add_class("settings-dialog-frame")
        except Exception:
            pass
        return box

    def display_user_name(username: str | None = None) -> str:
        username = username or os.environ.get("USER") or os.environ.get("LOGNAME") or "seven"
        try:
            gecos = pwd.getpwnam(username).pw_gecos.split(",", 1)[0].strip()
            return gecos or username
        except Exception:
            return username

    def system_users() -> list[dict[str, str]]:
        users: list[dict[str, str]] = []
        seen: set[str] = set()
        for item in pwd.getpwall():
            if item.pw_uid < 1000 or item.pw_name in {"nobody", "systemd-coredump"}:
                continue
            if item.pw_name in seen:
                continue
            shell_name = Path(item.pw_shell or "").name
            if shell_name in {"nologin", "false"}:
                continue
            seen.add(item.pw_name)
            users.append(
                {
                    "name": item.pw_name,
                    "label": display_user_name(item.pw_name),
                    "home": item.pw_dir,
                }
            )
        return sorted(users, key=lambda entry: entry["label"].lower())

    def show_user_result(title_text: str, note_text: str, success: bool = True) -> None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(430, 220)
        dialog.add_button(tr("settings.close", "Fermer"), Gtk.ResponseType.CLOSE)
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(16)
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.get_style_context().add_class("action-hero-card")
        glyph = Gtk.Label(label="✓" if success else "!")
        glyph.get_style_context().add_class("action-hero-glyph")
        copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        copy.set_hexpand(True)
        title_label = Gtk.Label(label=title_text)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("action-hero-title")
        note_label = Gtk.Label(label=note_text)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("action-hero-note")
        copy.pack_start(title_label, False, False, 0)
        copy.pack_start(note_label, False, False, 0)
        card.pack_start(glyph, False, False, 0)
        card.pack_start(copy, True, True, 0)
        box.pack_start(card, True, True, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def create_user_account() -> None:
        dialog = Gtk.Dialog(
            title=tr("settings.users.create", "Créer un compte"),
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
        )
        dialog.set_default_size(460, 360)
        dialog.add_button(tr("settings.cancel", "Annuler"), Gtk.ResponseType.CANCEL)
        create_action = dialog.add_button(tr("settings.users.create_action", "Créer"), Gtk.ResponseType.ACCEPT)
        create_action.get_style_context().add_class("primary-action")
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(16)

        title = Gtk.Label(label=tr("settings.users.create_title", "Nouveau compte"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=tr("settings.users.create_note", "SevenOS crée le compte avec son dossier personnel et demande l’autorisation système si nécessaire."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")

        full_name = Gtk.Entry()
        full_name.set_placeholder_text(tr("settings.users.full_name", "Nom affiché"))
        username = Gtk.Entry()
        username.set_placeholder_text(tr("settings.users.username", "Nom court"))
        password = Gtk.Entry()
        password.set_placeholder_text(tr("settings.users.password", "Mot de passe"))
        password.set_visibility(False)
        confirm = Gtk.Entry()
        confirm.set_placeholder_text(tr("settings.users.password_confirm", "Confirmer le mot de passe"))
        confirm.set_visibility(False)
        admin = Gtk.CheckButton(label=tr("settings.users.admin", "Autoriser l’administration de SevenOS"))

        for entry in (full_name, username, password, confirm):
            entry.get_style_context().add_class("settings-entry")

        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)
        box.pack_start(full_name, False, False, 0)
        box.pack_start(username, False, False, 0)
        box.pack_start(password, False, False, 0)
        box.pack_start(confirm, False, False, 0)
        box.pack_start(admin, False, False, 0)

        def suggest_username(_entry: Gtk.Entry) -> None:
            if username.get_text().strip():
                return
            candidate = full_name.get_text().strip().lower()
            candidate = re.sub(r"[^a-z0-9_-]+", "", candidate.replace(" ", "-"))
            if candidate:
                username.set_text(candidate[:28])

        full_name.connect("changed", suggest_username)
        dialog.show_all()
        response = dialog.run()
        data = {
            "full_name": full_name.get_text().strip(),
            "username": username.get_text().strip(),
            "password": password.get_text(),
            "confirm": confirm.get_text(),
            "admin": admin.get_active(),
        }
        dialog.destroy()
        if response != Gtk.ResponseType.ACCEPT:
            return
        if not re.fullmatch(r"[a-z_][a-z0-9_-]{0,30}", data["username"]):
            show_user_result(
                tr("settings.users.create_invalid", "Compte non créé"),
                tr("settings.users.create_invalid_note", "Le nom court doit commencer par une lettre et utiliser seulement lettres, chiffres, tirets ou tirets bas."),
                False,
            )
            return
        try:
            pwd.getpwnam(data["username"])
            show_user_result(
                tr("settings.users.exists", "Compte déjà présent"),
                tr("settings.users.exists_note", "Choisis un autre nom court pour créer un nouveau compte."),
                False,
            )
            return
        except KeyError:
            pass
        if data["password"] != data["confirm"] or len(data["password"]) < 6:
            show_user_result(
                tr("settings.users.password_invalid", "Mot de passe à vérifier"),
                tr("settings.users.password_invalid_note", "Les deux mots de passe doivent être identiques et contenir au moins 6 caractères."),
                False,
            )
            return
        if shutil.which("pkexec") is None:
            show_user_result(
                tr("settings.users.auth_missing", "Autorisation indisponible"),
                tr("settings.users.auth_missing_note", "SevenOS ne trouve pas l’agent d’autorisation système. Réessaie après redémarrage de session."),
                False,
            )
            return
        groups = "-G wheel" if data["admin"] else ""
        shell_command = (
            f"useradd -m {groups} -c {shlex.quote(data['full_name'] or data['username'])} "
            f"{shlex.quote(data['username'])} && "
            f"printf '%s:%s\\n' {shlex.quote(data['username'])} {shlex.quote(data['password'])} | chpasswd"
        )
        subprocess.Popen(
            ["pkexec", "bash", "-lc", shell_command],
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        show_user_result(
            tr("settings.users.create_started", "Création demandée"),
            tr("settings.users.create_started_note", "Valide l’autorisation système. Le compte apparaîtra ici dès qu’il sera créé."),
            True,
        )

    def switch_user() -> None:
        command = "dm-tool switch-to-greeter || loginctl lock-session"
        run_detached(command)
        show_feedback(tr("settings.users.switching", "Changement d’utilisateur demandé."))

    def confirm_delete_user(username: str, label: str) -> None:
        dialog = Gtk.Dialog(
            title=tr("settings.users.delete_title", "Supprimer ce compte ?"),
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
        )
        dialog.set_default_size(430, 210)
        dialog.add_button(tr("settings.cancel", "Annuler"), Gtk.ResponseType.CANCEL)
        delete_button = dialog.add_button(tr("settings.delete", "Supprimer"), Gtk.ResponseType.ACCEPT)
        delete_button.get_style_context().add_class("destructive-action")
        box = style_dialog(dialog)
        box.set_spacing(10)
        box.set_border_width(16)
        title = Gtk.Label(label=tr("settings.users.delete_confirm", "Supprimer {name}", name=label))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(
            label=tr(
                "settings.users.delete_note",
                "SevenOS demandera une autorisation avant de retirer ce compte et ses données personnelles.",
            )
        )
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        dialog.destroy()
        if response == Gtk.ResponseType.ACCEPT:
            run_detached(f"pkexec userdel -r {shlex.quote(username)}")
            show_feedback(tr("settings.users.delete_requested", "Suppression demandée pour {name}.", name=label))

    def show_user_accounts_dialog() -> None:
        current_user = os.environ.get("USER") or os.environ.get("LOGNAME") or ""
        dialog = Gtk.Dialog(
            title=tr("settings.users.title", "Compte utilisateur"),
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
        )
        dialog.set_default_size(480, 420)
        dialog.add_button(tr("settings.close", "Fermer"), Gtk.ResponseType.CLOSE)
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(16)

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        avatar = Gtk.Label(label=(display_user_name(current_user)[:1] or "S").upper())
        avatar.get_style_context().add_class("user-avatar-large")
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        text_box.set_hexpand(True)
        title = Gtk.Label(label=display_user_name(current_user))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        subtitle = Gtk.Label(label=tr("settings.users.current", "Compte connecté"))
        subtitle.set_xalign(0)
        subtitle.get_style_context().add_class("hero-note")
        text_box.pack_start(title, False, False, 0)
        text_box.pack_start(subtitle, False, False, 0)
        header.pack_start(avatar, False, False, 0)
        header.pack_start(text_box, True, True, 0)
        box.pack_start(header, False, False, 0)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        create_button = Gtk.Button(label=tr("settings.users.create", "Créer un compte"))
        create_button.get_style_context().add_class("action-button")
        create_button.connect("clicked", lambda _button: create_user_account())
        switch_button = Gtk.Button(label=tr("settings.users.switch", "Changer d’utilisateur"))
        switch_button.get_style_context().add_class("action-button")
        switch_button.connect("clicked", lambda _button: switch_user())
        actions.pack_start(create_button, False, False, 0)
        actions.pack_start(switch_button, False, False, 0)
        box.pack_start(actions, False, False, 0)

        list_box = Gtk.ListBox()
        list_box.get_style_context().add_class("account-list")
        for account in system_users():
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label=account["label"][:1].upper())
            glyph.get_style_context().add_class("user-avatar-small")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            name_label = Gtk.Label(label=account["label"])
            name_label.set_xalign(0)
            name_label.get_style_context().add_class("settings-row-title")
            note_text = tr("settings.users.active", "Connecté") if account["name"] == current_user else tr("settings.users.available", "Disponible")
            note_label = Gtk.Label(label=note_text)
            note_label.set_xalign(0)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(name_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            if account["name"] != current_user:
                delete = Gtk.Button(label=tr("settings.delete", "Supprimer"))
                delete.get_style_context().add_class("action-button")
                delete.get_style_context().add_class("destructive-action")
                delete.connect("clicked", lambda _button, user=account["name"], label=account["label"]: confirm_delete_user(user, label))
                wrapper.pack_start(delete, False, False, 0)
            row.add(wrapper)
            list_box.add(row)
        box.pack_start(list_box, True, True, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()

    def user_account_button() -> Gtk.Button:
        current_user = os.environ.get("USER") or os.environ.get("LOGNAME") or "seven"
        label = display_user_name(current_user)
        button = Gtk.Button()
        button.get_style_context().add_class("user-account-button")
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        avatar = Gtk.Label(label=(label[:1] or "S").upper())
        avatar.get_style_context().add_class("user-avatar-small")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        labels.set_hexpand(True)
        name = Gtk.Label(label=label)
        name.set_xalign(0)
        name.get_style_context().add_class("user-account-name")
        note = Gtk.Label(label=tr("settings.users.account", "Compte"))
        note.set_xalign(0)
        note.get_style_context().add_class("user-account-note")
        labels.pack_start(name, False, False, 0)
        labels.pack_start(note, False, False, 0)
        chevron = Gtk.Label(label="›")
        chevron.get_style_context().add_class("user-account-chevron")
        row.pack_start(avatar, False, False, 0)
        row.pack_start(labels, True, True, 0)
        row.pack_start(chevron, False, False, 0)
        button.add(row)
        button.connect("clicked", lambda _button: show_user_accounts_dialog())
        return button

    sidebar.pack_start(user_account_button(), False, False, 0)

    def info_dialog(title_text: str, note_text: str, rows: list[tuple[str, str, str, str | None]], width: int = 560, height: int = 460) -> None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(min(width, max(460, int(screen_width * 0.48))), min(height, max(320, int(screen_height * 0.54))))
        dialog.add_button(tr("settings.close", "Fermer"), Gtk.ResponseType.CLOSE)
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(16)

        title = Gtk.Label(label=title_text)
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=note_text)
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)

        list_box = Gtk.ListBox()
        list_box.get_style_context().add_class("account-list")
        for icon, row_title, row_note, badge_text in rows:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label=icon)
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            title_label = Gtk.Label(label=row_title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            note_label = Gtk.Label(label=row_note)
            note_label.set_xalign(0)
            note_label.set_ellipsize(Pango.EllipsizeMode.END)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            if badge_text:
                badge = Gtk.Label(label=badge_text)
                badge.get_style_context().add_class("update-summary-chip")
                wrapper.pack_start(badge, False, False, 0)
            row.add(wrapper)
            list_box.add(row)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.add(list_box)
        box.pack_start(scroller, True, True, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def show_language_overview() -> None:
        payload = language_state()
        rows: list[tuple[str, str, str, str | None]] = []
        for item in payload.get("languages", []):
            if not isinstance(item, dict):
                continue
            rows.append(
                (
                    "󰗊",
                    str(item.get("label") or item.get("locale") or tr("settings.language", "Langue")),
                    str(item.get("locale") or ""),
                    tr("settings.active", "Actif") if item.get("current") else (tr("settings.ready", "Prêt") if item.get("installed") else tr("settings.installable", "Disponible")),
                )
            )
        info_dialog(
            tr("settings.language_region", "Langue et région"),
            tr("settings.language_overview.note", "Langues disponibles pour les nouvelles fenêtres SevenOS."),
            rows or [("󰗊", tr("settings.language", "Langue"), tr("settings.no_data", "Aucune information disponible."), None)],
        )

    def show_files_resources_overview() -> None:
        mode = "mini-os"
        root = Path.home()
        try:
            result = subprocess.run(
                [str(ROOT / "bin/seven-files"), "resources", "status"],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                text=True,
                capture_output=True,
                check=False,
                timeout=1.0,
            )
            for line in result.stdout.splitlines():
                if line.lower().startswith("seven files resources:"):
                    mode = line.split(":", 1)[1].strip()
                if line.lower().startswith("root:"):
                    root = Path(line.split(":", 1)[1].strip())
        except Exception:
            pass
        folders = ["Downloads", "Documents", "Code", "Music", "Pictures", "Videos"]
        rows = [
            ("󰉋", tr("settings.file_resources", "Ressources de fichiers"), tr("settings.resources.mode", "Mode actuel: {mode}", mode=mode), tr("settings.active", "Actif")),
            ("󰉌", tr("settings.resources.root", "Espace utilisé"), str(root), None),
        ]
        rows.extend(("󰉋", name, str(root / name), None) for name in folders)
        info_dialog(
            tr("settings.resource_status", "Organisation des fichiers"),
            tr("settings.resources_overview.note", "Seven Files range les dossiers selon l’espace actif ou le mode partagé choisi."),
            rows,
        )

    def show_software_overview() -> None:
        payload = run_json_timeout([str(ROOT / "bin/sevenpkg"), "status", "--json"], [], timeout=2.0)
        rows: list[tuple[str, str, str, str | None]] = []
        if isinstance(payload, list):
            for item in payload[:18]:
                if not isinstance(item, dict):
                    continue
                installed = item.get("installed", 0)
                total = item.get("total", 0)
                rows.append(
                    (
                        "󰏗",
                        str(item.get("name", "")).title(),
                        str(item.get("description") or tr("settings.software.ready_note", "{installed}/{total} éléments prêts", installed=installed, total=total)),
                        str(item.get("state") or ""),
                    )
                )
        info_dialog(
            tr("settings.sevenpkg_public", "État des logiciels"),
            tr("settings.software_overview.note", "Résumé des ensembles SevenOS installés et prêts pour chaque mini OS."),
            rows or [("󰏗", tr("settings.software", "Applications"), tr("settings.no_data", "Aucune information disponible."), None)],
            width=640,
            height=520,
        )

    def show_app_sources_overview() -> None:
        rows: list[tuple[str, str, str, str | None]] = []
        if command_exists("flatpak"):
            try:
                result = subprocess.run(["flatpak", "list", "--app", "--columns=name"], text=True, capture_output=True, check=False, timeout=1.2)
                count = len([line for line in result.stdout.splitlines() if line.strip()])
                rows.append(("󰈙", "Flatpak", tr("settings.apps.count", "{count} app(s) disponible(s)", count=count), tr("settings.ready", "Prêt")))
            except Exception:
                rows.append(("󰈙", "Flatpak", tr("settings.unavailable", "Indisponible"), None))
        else:
            rows.append(("󰈙", "Flatpak", tr("settings.unavailable", "Indisponible"), None))
        rows.append(("󰏗", "SevenStore", tr("settings.store.source_note", "Le Store garde l’installation graphique pour le grand public."), tr("settings.ready", "Prêt")))
        info_dialog(
            tr("settings.software_sources", "Sources d’apps"),
            tr("settings.software_sources.public_note", "Sources utilisées par SevenOS pour afficher et installer les apps."),
            rows,
        )

