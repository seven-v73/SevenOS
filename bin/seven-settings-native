            (about_system["release"], tr("settings.version", "Version")),
            (about_system["profile"], tr("settings.active_space", "Espace actif")),
            (about_system["smoke"], tr("settings.readiness", "Préparation")),
            (current_theme_mode(), tr("settings.theme", "Thème")),
            (update_value, update_label),
            (about_system["kernel"], tr("settings.system_base", "Base système")),
        ],
    )
    settings_group(system, tr("settings.maintenance", "Maintenance"), [
        settings_row("󰚰", tr("settings.system_updates", "Mises à jour"), tr("settings.system_updates.note", "Mettre à jour SevenOS et les applications."), [action_button(tr("settings.update", "Mettre à jour"), "seven update")]),
        settings_row("󰏗", tr("settings.package_status", "Applications"), tr("settings.package_status.note", "Ouvrir SevenStore pour gérer les apps."), [action_button(tr("settings.open", "Ouvrir"), "seven-store")]),
        settings_row("󰄬", tr("settings.daily_gate", "Prêt pour le quotidien"), tr("settings.daily_gate.note", "Vérifier que SevenOS est prêt comme système principal."), [action_button(tr("settings.check", "Vérifier"), "seven daily")]),
        settings_row("󰩂", tr("settings.doctor", "Assistant de vérification"), tr("settings.doctor.note", "Diagnostiquer les soucis courants."), [action_button(tr("settings.run", "Lancer"), "seven doctor")]),
        settings_row("󰒓", tr("settings.runtime_status", "Résumé SevenOS"), tr("settings.runtime_status.note", "Ouvrir le résumé lisible de SevenOS."), [action_button(tr("settings.open", "Ouvrir"), "seven status")]),
        settings_row("󰜉", tr("settings.repair_ui", "Réparer l’interface"), tr("settings.repair_ui.note", "Réappliquer le thème, rafraîchir l’interface et réparer la barre."), [action_button(tr("settings.repair", "Réparer"), repair_interface_command())]),
        settings_row("󰌢", tr("settings.logs", "Alertes récentes"), tr("settings.logs.note", "Voir les avertissements récents dans une vue lisible."), [action_button(tr("settings.open", "Ouvrir"), "seven-doctor-native logs")]),
    ])

    stack.set_visible_child_name(initial_page)
    if initial_page in nav_by_target:
        nav_by_target[initial_page].get_style_context().add_class("active")
    elif nav_buttons:
        nav_buttons[0].get_style_context().add_class("active")
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    page = next((arg for arg in sys.argv[1:] if not arg.startswith("-")), "overview")
    return run(page)


if __name__ == "__main__":
    raise SystemExit(main())
