    overview.pack_start(hero_card("Ajuster SevenOS sans terminal", "Les controles essentiels sont ici. Spotlight reste la recherche globale; Settings reste le lieu des reglages."), False, False, 0)
    overview.pack_start(
        quick_strip(
            [
                ("󰸉", "Wallpaper", "seven-settings-native"),
