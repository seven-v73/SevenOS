        setting_card("󰆍", "Terminal style", "Choose classic light or graphite SevenOS terminal.", [action_button("Choose", "seven-terminal menu")]),
        setting_card("󰇄", "Waybar", "Repair and restart the liquid glass menu bar.", [action_button("Repair", "seven-waybar repair")]),
