    def search_settings(_entry=None) -> None:
        query = search_entry.get_text().strip().lower()
        if not query:
            search_results.hide()
            return
        for target, terms in settings_search_index.items():
            page_title = pages[target][0].get_children()[0].get_text().lower()
            if query in terms or query in page_title:
                activate_page(target, nav_by_target[target])
                show_feedback(tr("settings.search.opened", "Page ouverte."))
                return
        show_feedback(tr("settings.search.no_result", "Aucune page ne correspond à “{query}”.", query=query))

    search_entry.connect("activate", search_settings)

    def search_key(_entry, event) -> bool:
        if event.keyval == Gdk.KEY_Escape:
            search_entry.set_text("")
            search_results.hide()
            return True
        if event.keyval in {Gdk.KEY_Down, Gdk.KEY_Tab} and search_results.get_visible():
            children = [child for child in search_results.get_children() if isinstance(child, Gtk.Button)]
            if children:
                children[0].grab_focus()
                return True
        return False

    search_entry.connect("key-press-event", search_key)

    search_items = [
        ("󰒓", tr("settings.general", "Général"), tr("settings.general.subtitle", "Langue, région, thèmes et comportement quotidien de SevenOS."), "general"),
        ("󰤨", "Wi-Fi", tr("settings.network.subtitle", "Se connecter et gérer le réseau SevenOS."), "network"),
        ("󰂯", "Bluetooth", tr("settings.bluetooth.note", "Associer écouteurs, claviers, téléphones et appareils proches."), "network"),
        ("󰍹", tr("settings.displays", "Écrans"), tr("settings.display.subtitle", "Luminosité, organisation des écrans et affichage SevenOS."), "display"),
        ("󰒓", tr("settings.default_apps", "Apps par défaut"), tr("settings.default_apps.subtitle", "Choisir les apps utilisées pour les fichiers, liens, documents, médias et archives."), "defaults"),
        ("󰐃", tr("settings.profiles", "Mini OS"), tr("settings.profiles.subtitle", "Changer de mode de travail et ouvrir les espaces SevenOS."), "profiles"),
        ("󰌾", tr("settings.privacy", "Confidentialité"), tr("settings.privacy.subtitle", "Données locales, permissions, notifications et confidentialité SevenAI."), "privacy"),
        ("󰁯", tr("settings.backup_restore", "Sauvegarde"), tr("settings.backup_restore.subtitle", "Exporter, restaurer et protéger la configuration SevenOS."), "backup"),
        ("󰌌", tr("settings.shortcuts", "Raccourcis"), tr("settings.shortcuts.subtitle", "Ouvrir, vérifier et réparer les raccourcis clavier SevenOS."), "shortcuts"),
        ("󰩂", tr("settings.doctor", "Vérification"), tr("settings.doctor.note", "Diagnostiquer les soucis courants."), "system"),
    ]

    def rebuild_search_results(_entry=None) -> None:
        for child in list(search_results.get_children()):
            search_results.remove(child)
        query = search_entry.get_text().strip().lower()
        if len(query) < 2:
            search_results.hide()
            return
        matches = []
        for icon, title, note, target in search_items:
            haystack = f"{title} {note} {settings_search_index.get(target, '')}".lower()
            if query in haystack:
                matches.append((icon, title, note, target))
        if not matches:
            label = Gtk.Label(label=tr("settings.search.no_result", "No Settings page matched “{query}”.", query=query))
            label.set_xalign(0)
            label.get_style_context().add_class("card-note")
            search_results.pack_start(label, False, False, 0)
        for icon, title, note, target in matches[:6]:
            button = Gtk.Button()
            button.get_style_context().add_class("search-result-button")
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            glyph = Gtk.Label(label=icon)
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            title_label = Gtk.Label(label=title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("card-title")
            note_label = Gtk.Label(label=note)
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("card-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            row.pack_start(glyph, False, False, 0)
            row.pack_start(labels, True, True, 0)
            button.add(row)
            button.connect("clicked", lambda _button, page_name=target: (activate_page(page_name, nav_by_target[page_name]), search_results.hide()))
            search_results.pack_start(button, False, False, 0)
        search_results.show_all()

    search_entry.connect("search-changed", rebuild_search_results)

