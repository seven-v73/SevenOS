        listbox.get_style_context().add_class("update-list")
        scroller.add(listbox)

        update_items: list[dict[str, str]] = []
        process_ref: dict[str, subprocess.Popen] = {}
        pulse_ref = {"source": 0}
        install_output: list[str] = []

        def set_widget_state(widget: Gtk.Widget, state: str) -> None:
            context = widget.get_style_context()
            for css_class in ("action-state-running", "action-state-success", "action-state-error"):
                context.remove_class(css_class)
            context.add_class(f"action-state-{state}")

        def set_update_state(state: str, message: str | None = None) -> None:
            set_widget_state(status, state)
            if message:
                status.set_text(message)

        def start_pulse() -> None:
            if pulse_ref["source"]:
                return

            def tick() -> bool:
                progress.pulse()
                return True

            pulse_ref["source"] = GLib.timeout_add(120, tick)

        def stop_pulse() -> None:
            if pulse_ref["source"]:
                GLib.source_remove(pulse_ref["source"])
                pulse_ref["source"] = 0

        def clear_list() -> None:
            for child in list(listbox.get_children()):
                listbox.remove(child)

        def add_empty_row(message: str) -> None:
            row = Gtk.ListBoxRow()
            label = Gtk.Label(label=message)
            label.set_xalign(0)
            label.get_style_context().add_class("hero-note")
            wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            wrapper.get_style_context().add_class("update-row")
            wrapper.pack_start(label, False, False, 0)
            row.add(wrapper)
            listbox.add(row)

        def add_update_section(kind: str, count: int) -> None:
            title_map = {
                "system": tr("settings.update.source.system", "Système"),
                "apps": tr("settings.update.source.apps", "Apps"),
                "community": tr("settings.update.source.community", "Apps externes"),
            }
            icon_map = {"system": "󰒓", "apps": "󰀻", "community": "󰚩"}
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            wrapper.get_style_context().add_class("update-section-row")
            icon_label = Gtk.Label(label=icon_map.get(kind, "󰚰"))
            icon_label.get_style_context().add_class("update-section-icon")
            title_label = Gtk.Label(label=title_map.get(kind, kind.title()))
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("update-section-title")
            count_label = Gtk.Label(label=tr("settings.update.section_count", "{count} élément(s)", count=count))
            count_label.get_style_context().add_class("update-section-count")
            wrapper.pack_start(icon_label, False, False, 0)
            wrapper.pack_start(title_label, True, True, 0)
            wrapper.pack_start(count_label, False, False, 0)
            row.add(wrapper)
            listbox.add(row)

        def add_update_row(item: dict[str, str]) -> None:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("update-row")
            kind = item.get("kind", "")
            icon = {"system": "󰒓", "apps": "󰀻", "community": "󰚩"}.get(kind, "󰚰")
            icon_label = Gtk.Label(label=icon)
            icon_label.get_style_context().add_class("update-kind-icon")
            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text_box.set_hexpand(True)
            name = Gtk.Label(label=item.get("name", tr("settings.update", "Mise à jour")))
            name.set_xalign(0)
            name.set_ellipsize(Pango.EllipsizeMode.END)
            name.get_style_context().add_class("update-name")
            version = Gtk.Label(label=item.get("version", ""))
            version.set_xalign(0)
            version.set_ellipsize(Pango.EllipsizeMode.END)
            version.get_style_context().add_class("update-version")
            badge = Gtk.Label(label=item.get("source", "SevenOS"))
            badge.get_style_context().add_class("update-badge")
            if kind:
                badge.get_style_context().add_class(f"update-badge-{kind}")
            text_box.pack_start(name, False, False, 0)
            text_box.pack_start(version, False, False, 0)
            wrapper.pack_start(icon_label, False, False, 0)
            wrapper.pack_start(text_box, True, True, 0)
            wrapper.pack_start(badge, False, False, 0)
            row.add(wrapper)
            listbox.add(row)

        def render_items(items: list[dict[str, str]]) -> None:
            clear_list()
            update_items[:] = items
            total_value.set_text(str(len(items)))
            counts = {"system": 0, "apps": 0, "community": 0}
            for item in items:
                kind = item.get("kind", "")
                if kind in counts:
                    counts[kind] += 1
            for key, chip in summary_labels.items():
                source_label = {
                    "system": tr("settings.update.source.system", "Système"),
                    "apps": tr("settings.update.source.apps", "Apps"),
                    "community": tr("settings.update.source.community", "Apps externes"),
                }[key]
                chip.set_text(f"{source_label} {counts[key]}")
            if not items:
                subtitle.set_text(tr("settings.update.none", "Votre système est à jour."))
                set_update_state("success", tr("settings.update.none.detail", "Aucune mise à jour disponible pour le moment."))
                impact_label.set_text(tr("settings.update.impact.none", "Aucune action requise"))
                install_button.set_sensitive(False)
                add_empty_row(tr("settings.update.none", "Votre système est à jour."))
            else:
                subtitle.set_text(tr("settings.update.count", "{count} élément(s) à installer", count=len(items)))
                if counts["community"] and not counts["system"] and not counts["apps"]:
                    set_update_state("running", tr("settings.update.community_only", "Apps communautaires prêtes à installer."))
                    impact_label.set_text(tr("settings.update.impact.community", "Installation personnelle · mot de passe seulement si nécessaire"))
                    install_button.set_label(tr("settings.update.install_community", "Installer apps"))
                else:
                    set_update_state("running", tr("settings.update.review", "Prêt à installer après confirmation."))
                    if counts["community"]:
                        impact_label.set_text(tr("settings.update.impact.mixed", "Mise à jour complète · mot de passe administrateur demandé"))
                    else:
                        impact_label.set_text(tr("settings.update.impact.system", "Mise à jour protégée · mot de passe administrateur demandé"))
                    install_button.set_label(tr("settings.update.install", "Installer"))
                install_button.set_sensitive(True)
                for kind in ("system", "apps", "community"):
                    group = [item for item in items if item.get("kind") == kind]
                    if group:
                        add_update_section(kind, len(group))
                        for item in group:
                            add_update_row(item)
            listbox.show_all()

        def refresh_updates(_button: Gtk.Button | None = None) -> None:
            install_button.set_sensitive(False)
            refresh_button.set_sensitive(False)
            set_update_state("running", tr("settings.update.loading", "Recherche des mises à jour disponibles…"))
            activity.set_text(tr("settings.update.activity.scan", "Analyse des mises à jour disponibles…"))
            start_pulse()
            clear_list()
            add_empty_row(tr("settings.update.loading", "Recherche des mises à jour disponibles…"))
            listbox.show_all()

            def worker() -> None:
                items = collect_update_items()

                def finish() -> bool:
                    render_items(items)
                    refresh_button.set_sensitive(True)
                    activity.set_text("")
                    stop_pulse()
                    progress.set_fraction(0.0)
                    return False

                GLib.idle_add(finish)

            threading.Thread(target=worker, daemon=True).start()

        def install_updates(_button: Gtk.Button) -> None:
            if not update_items:
                return
            privileged_items = [item for item in update_items if item.get("kind") in {"system", "apps"}]
            community_items = [item for item in update_items if item.get("kind") == "community"]
            if privileged_items and not command_exists("pkexec"):
                set_update_state("error", tr("settings.update.no_pkexec", "La demande de mot de passe ne peut pas s’ouvrir. Réessaie depuis SevenStore."))
                return
            aur_helper = "paru" if command_exists("paru") else "yay" if command_exists("yay") else ""
            if community_items and not aur_helper:
                set_update_state("error", tr("settings.update.no_aur_helper", "Aucun assistant communautaire disponible pour installer ces apps."))
                return
            install_button.set_sensitive(False)
            refresh_button.set_sensitive(False)
            install_button.get_style_context().add_class("busy")
            set_update_state("running", tr("settings.update.auth", "Authentification requise…") if privileged_items else tr("settings.update.community_auth", "Installation des apps communautaires…"))
            activity.set_text(tr("settings.update.activity.auth", "Valide ton mot de passe administrateur pour continuer.") if privileged_items else tr("settings.update.activity.community", "SevenOS prépare l’installation communautaire."))
            install_output.clear()
            start_pulse()
            quoted_root = shlex.quote(str(ROOT))
            privileged_command = f"cd {quoted_root} && stdbuf -oL -eL ./scripts/update.sh apply --yes"

            def askpass_script() -> Path:
                CACHE_DIR.mkdir(parents=True, exist_ok=True)
                script = CACHE_DIR / "settings-sudo-askpass.sh"
                script.write_text(
                    "#!/usr/bin/env bash\n"
                    "zenity --password --title='SevenOS' --text='Mot de passe administrateur requis'\n",
                    encoding="utf-8",
                )
                script.chmod(0o700)
                return script

            def community_command() -> str:
                helper = shlex.quote(aur_helper)
                askpass = shlex.quote(str(askpass_script()))
                return (
                    f"cd {quoted_root} && "
                    f"env SUDO_ASKPASS={askpass} stdbuf -oL -eL {helper} -Sua --noconfirm "
                    "--sudoflags -A --sudoloop --answerclean None --answerdiff None --answeredit None --answerupgrade None"
                )

            def line_to_message(line: str) -> str:
                lower = line.lower()
                if "pacman" in lower and "non-zero exit status" in lower:
                    return tr("settings.update.activity.pacman_failed", "L’installation a été refusée. Vérifie le réseau ou réessaie dans quelques minutes.")
                if "failed to synchronize" in lower or "database is locked" in lower or "unable to lock database" in lower:
                    return tr("settings.update.activity.lock_or_network", "La mise à jour est bloquée par le réseau ou par une autre installation en cours.")
                if any(word in lower for word in ("download", "receiving", "fetch", "télécharg")):
                    return tr("settings.update.activity.download", "Téléchargement des mises à jour…")
                if any(word in lower for word in ("install", "upgrad", "transaction", "package", "flatpak")):
                    return tr("settings.update.activity.install", "Installation en cours…")
                if any(word in lower for word in ("checking", "resolving", "synchronizing", "sync")):
                    return tr("settings.update.activity.prepare", "Préparation des éléments nécessaires…")
                if any(word in lower for word in ("error", "failed", "fatal", "erreur", "échec")):
                    return tr("settings.update.activity.error", "Une erreur demande ton attention.")
                if "aur update skipped" in lower:
                    return tr("settings.update.activity.community_skipped", "Les apps externes seront installées séparément.")
                if any(word in lower for word in ("aur", "pkgbuild", "makepkg", "yay", "paru", "community")):
                    return tr("settings.update.activity.community", "Installation des apps externes…")
                return line[:140]

            def append_install_line(line: str) -> bool:
                line = line.strip()
                if not line:
                    return False
                install_output.append(line)
                set_update_state("running", tr("settings.update.installing", "Installation en cours…"))
                activity.set_text(line_to_message(line))
                return False

            def worker() -> None:
                code = 1
                try:
                    commands: list[tuple[str, list[str]]] = []
                    if privileged_items:
                        commands.append((
                            "privileged",
                            ["pkexec", "env", f"SEVENOS_ROOT={ROOT}", "SEVENOS_YES=1", "bash", "-lc", privileged_command],
                        ))
                    if community_items:
                        commands.append(("community", ["bash", "-lc", community_command()]))
                    code = 0
                    for kind, argv in commands:
                        GLib.idle_add(
                            append_install_line,
                            tr("settings.update.phase.community", "Installation des apps externes…")
                            if kind == "community"
                            else tr("settings.update.phase.system", "Installation système…"),
                        )
                        process = subprocess.Popen(
                            argv,
                            cwd=ROOT,
                            text=True,
                            stdin=subprocess.DEVNULL,
                            stdout=subprocess.PIPE,
                            stderr=subprocess.STDOUT,
                            start_new_session=True,
                        )
                        process_ref["process"] = process
                        if process.stdout:
                            for line in process.stdout:
                                GLib.idle_add(append_install_line, line)
                        code = process.wait()
                        if code != 0:
                            break
                except Exception as exc:
                    install_output.append(str(exc))
                    code = 1

                def finish() -> bool:
                    stop_pulse()
                    install_button.get_style_context().remove_class("busy")
                    CACHE_DIR.mkdir(parents=True, exist_ok=True)
                    with SETTINGS_ACTION_LOG.open("a", encoding="utf-8") as handle:
                        handle.write(
                            "\n--- SevenOS Settings update install ---\n"
                            f"exit={code}\n"
                            + "\n".join(install_output[-120:])
                            + "\n"
                        )
                    if code == 0:
                        set_update_state("success", tr("settings.update.installed", "Mises à jour installées."))
                        activity.set_text(tr("settings.update.activity.done", "SevenOS est à jour."))
                        progress.set_fraction(1.0)
                        refresh_updates()
                    else:
                        detail = "\n".join(install_output[-3:]) if install_output else tr("settings.update.no_detail", "Aucun détail reçu du service d’authentification.")
                        detail = line_to_message(detail)
                        set_update_state("error", tr("settings.update.cancelled_or_failed", "Installation annulée ou non terminée."))
                        activity.set_text(detail[:180])
                        install_button.set_sensitive(True)
                        refresh_button.set_sensitive(True)
                        progress.set_fraction(0.0)
                    return False

                GLib.idle_add(finish)

            threading.Thread(target=worker, daemon=True).start()

        install_button.connect("clicked", install_updates)
        refresh_button.connect("clicked", refresh_updates)
        box.pack_start(header, False, False, 0)
        box.pack_start(status, False, False, 0)
        box.pack_start(summary_panel, False, False, 0)
        box.pack_start(impact_label, False, False, 0)
        box.pack_start(activity, False, False, 0)
        box.pack_start(progress, False, False, 0)
        box.pack_start(scroller, True, True, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()
        refresh_updates()

    def show_command_output(command: str, action_label: str | None = None) -> None:
        ui_command = command
        if command.strip() == "seven status":
            ui_command = "seven smoke status"

        def update_status_payload() -> dict:
            if not ui_command.strip().startswith("seven update"):
                return {}
            try:
                result = subprocess.run(
                    [str(ROOT / "bin/seven"), "update", "--json"],
                    cwd=ROOT,
                    env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_UPDATE_FAST": "1"},
                    text=True,
                    capture_output=True,
                    check=False,
                    timeout=1.5,
                )
                payload = json.loads(result.stdout or "{}")
                return payload if isinstance(payload, dict) else {}
            except Exception:
                return {}

        def action_summary() -> tuple[str, str, list[str]]:
            stripped = command.strip()
            if stripped == "seven status":
                return (
                    tr("settings.action.status.title", "État SevenOS"),
                    tr("settings.action.status.note", "SevenOS prépare un résumé rapide et lisible."),
                    [tr("settings.step.collect", "Collecter"), tr("settings.step.check", "Vérifier"), tr("settings.step.report", "Résumer")],
                )
            if stripped.startswith("seven update"):
                return (
                    tr("settings.action.update.title", "Mise à jour SevenOS"),
                    tr("settings.action.update.note", "SevenOS vérifie, applique et résume les mises à jour système disponibles."),
                    [tr("settings.step.check", "Vérifier"), tr("settings.step.download", "Télécharger"), tr("settings.step.apply", "Appliquer")],
                )
            if stripped.startswith("seven profile requirements"):
                return (
                    tr("settings.action.requirements.title", "Installation des besoins essentiels"),
                    tr("settings.action.requirements.note", "SevenOS prépare les éléments nécessaires aux mini OS et aux apps SevenOS."),
                    [tr("settings.step.scan", "Scanner"), tr("settings.step.install", "Installer"), tr("settings.step.verify", "Vérifier")],
                )
            if stripped.startswith("seven post-install"):
                return (
                    tr("settings.action.post_install.title", "Vérification post-installation"),
                    tr("settings.action.post_install.note", "SevenOS contrôle que cette machine est prête pour une utilisation normale."),
                    [tr("settings.step.inspect", "Inspecter"), tr("settings.step.fix", "Ajuster"), tr("settings.step.report", "Résumer")],
                )
            if stripped.startswith(("seven daily", "seven doctor", "seven smoke doctor")):
                return (
                    tr("settings.action.health.title", "Vérification de santé"),
                    tr("settings.action.health.note", "SevenOS regarde les points essentiels et te donne un résultat simple."),
                    [tr("settings.step.inspect", "Observer"), tr("settings.step.verify", "Vérifier"), tr("settings.step.report", "Résumer")],
                )
            if stripped.startswith("seven atlas"):
                return (
                    tr("settings.action.atlas.title", "Atlas Explorer"),
                    tr("settings.action.atlas.note", "SevenOS vérifie Atlas pour documents, scans, cartes, OCR et références."),
                    [tr("settings.step.prepare", "Préparer"), tr("settings.step.check", "Vérifier"), tr("settings.step.report", "Résumer")],
                )
            if stripped.startswith("seven recovery"):
                return (
                    tr("settings.action.backup.title", "Sauvegarde et restauration"),
                    tr("settings.action.backup.note", "SevenOS protège ou inspecte l’état de restauration avant une intervention importante."),
                    [tr("settings.step.collect", "Collecter"), tr("settings.step.archive", "Archiver"), tr("settings.step.confirm", "Confirmer")],
                )
            if stripped.startswith("seven repair") or "seven-waybar repair" in stripped:
                return (
                    tr("settings.action.repair.title", "Réparation de l’interface"),
                    tr("settings.action.repair.note", "SevenOS répare la barre, le thème et les surfaces shell en une opération guidée."),
                    [tr("settings.step.repair", "Réparer"), tr("settings.step.reload", "Recharger"), tr("settings.step.verify", "Vérifier")],
                )
            if stripped.startswith(("seven migrate", "seven recovery backup")):
                return (
                    tr("settings.action.protect.title", "Protection des données"),
                    tr("settings.action.protect.note", "SevenOS prépare une sauvegarde lisible avant les changements importants."),
                    [tr("settings.step.collect", "Collecter"), tr("settings.step.archive", "Protéger"), tr("settings.step.confirm", "Confirmer")],
                )
            if stripped.startswith("seven profile activate"):
                return (
                    tr("settings.action.profile.title", "Changement de mini OS"),
                    tr("settings.action.profile.note", "SevenOS applique l’espace choisi et rafraîchit l’interface."),
                    [tr("settings.step.profile", "Espace"), tr("settings.step.prepare", "Préparer"), tr("settings.step.shell", "Interface")],
                )
            if stripped.startswith("seven motion"):
                return (
                    tr("settings.action.motion.title", "Animations SevenOS"),
                    tr("settings.action.motion.note", "SevenOS applique le niveau de mouvement choisi aux surfaces compatibles."),
                    [tr("settings.step.mode", "Mode"), tr("settings.step.theme", "Thème"), tr("settings.step.apply", "Appliquer")],
                )
            if stripped.startswith(("seven keyboard", "hyprctl reload")):
                return (
                    tr("settings.action.input.title", "Réglages d’entrée"),
                    tr("settings.action.input.note", "SevenOS applique les préférences clavier et recharge la session si nécessaire."),
                    [tr("settings.step.prepare", "Préparer"), tr("settings.step.apply", "Appliquer"), tr("settings.step.finish", "Terminer")],
                )
            if stripped.startswith(("seven fonts", "seven language", "seven identity")) or "install.sh theme" in stripped:
                return (
                    tr("settings.action.appearance.title", "Apparence SevenOS"),
                    tr("settings.action.appearance.note", "SevenOS applique les ressources visuelles et garde les surfaces cohérentes."),
                    [tr("settings.step.prepare", "Préparer"), tr("settings.step.apply", "Appliquer"), tr("settings.step.refresh", "Rafraîchir")],
                )
            if stripped.startswith("seven-files resources"):
                return (
                    tr("settings.action.resources.title", "Ressources de fichiers"),
                    tr("settings.action.resources.note", "SevenOS ajuste l’espace utilisé par les dossiers personnels et les mini OS."),
                    [tr("settings.step.profile", "Espace"), tr("settings.step.apply", "Appliquer"), tr("settings.step.verify", "Vérifier")],
                )
            if stripped.startswith("seven shield"):
                return (
                    tr("settings.action.security.title", "Sécurité SevenOS"),
                    tr("settings.action.security.note", "SevenOS applique ou vérifie les protections utiles depuis une interface guidée."),
                    [tr("settings.step.check", "Vérifier"), tr("settings.step.apply", "Appliquer"), tr("settings.step.report", "Résumer")],
                )
            if stripped.startswith(("sevenpkg", "seven flatpak", "flatpak list")):
                return (
                    tr("settings.action.software.title", "Logiciels"),
                    tr("settings.action.software.note", "SevenOS vérifie les apps et les éléments disponibles."),
                    [tr("settings.step.collect", "Collecter"), tr("settings.step.check", "Vérifier"), tr("settings.step.report", "Résumer")],
                )
            if stripped.startswith("seven hypr") or "seven-waybar repair" in stripped:
                return (
                    tr("settings.action.shell.title", "Interface SevenOS"),
                    tr("settings.action.shell.note", "SevenOS ajuste l’interface et les raccourcis visibles."),
                    [tr("settings.step.prepare", "Préparer"), tr("settings.step.reload", "Recharger"), tr("settings.step.verify", "Vérifier")],
                )
            if stripped.startswith(("seven ai", "seven cloud", "seven manifest", "seven migrate", "journalctl", "powerprofilesctl")):
                return (
                    tr("settings.action.inspect.title", "Vérification SevenOS"),
                    tr("settings.action.inspect.note", "SevenOS prépare un résumé lisible pour comprendre la situation."),
                    [tr("settings.step.collect", "Collecter"), tr("settings.step.check", "Vérifier"), tr("settings.step.report", "Résumer")],
                )
            fallback_title = action_label or tr("settings.command_output.title", "Action SevenOS en cours")
            return (
                fallback_title,
                tr("settings.action.generic.note", "SevenOS exécute l’action et affiche son état en direct."),
                [tr("settings.step.start", "Démarrer"), tr("settings.step.run", "Exécuter"), tr("settings.step.finish", "Terminer")],
            )

        def operation_stage(line: str) -> str:
            lower = line.lower()
            if any(word in lower for word in ("error", "failed", "erreur", "échec", "fatal")):
                return tr("settings.operation_stage.error", "Attention")
            if any(word in lower for word in ("download", "fetch", "sync", "mirror", "télécharg", "receiving")):
                return tr("settings.operation_stage.download", "Téléchargement")
            if any(word in lower for word in ("install", "pacman", "paru", "flatpak", "package", "dépendance", "dependency")):
                return tr("settings.operation_stage.install", "Installation")
            if any(word in lower for word in ("repair", "reload", "restart", "daemon", "service", "systemctl")):
                return tr("settings.operation_stage.repair", "Réparation")
            if any(word in lower for word in ("backup", "snapshot", "archive", "restore", "sauvegarde")):
                return tr("settings.operation_stage.backup", "Sauvegarde")
            if any(word in lower for word in ("checking", "verify", "doctor", "status", "check", "vérif")):
                return tr("settings.operation_stage.check", "Vérification")
            return tr("settings.operation_stage.running", "En cours")

        dialog = Gtk.Dialog(
            title=tr("settings.command_output", "Action SevenOS"),
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
        )
        dialog.set_default_size(min(760, max(560, int(screen_width * 0.52))), min(460, max(340, int(screen_height * 0.52))))
        close_button = dialog.add_button(tr("settings.close", "Fermer"), Gtk.ResponseType.CLOSE)
        cancel_button = dialog.add_button(tr("settings.cancel", "Annuler"), Gtk.ResponseType.CANCEL)
        close_button.get_style_context().add_class("action-button")
        cancel_button.get_style_context().add_class("destructive-action")
        close_button.set_tooltip_text(tr("settings.close_when_done", "Fermer quand l’action est terminée."))
        cancel_button.set_tooltip_text(tr("settings.cancel_running_action", "Interrompre l’action en cours."))
        close_button.set_sensitive(False)
        box = style_dialog(dialog)
        box.set_spacing(10)
        box.set_border_width(14)

        action_title, action_note, expected_steps = action_summary()
        title = Gtk.Label(label=action_title)
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(label=action_note)
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        status = Gtk.Label(label=tr("settings.command_output.running", "Exécution…"))
        status.set_xalign(0)
        status.get_style_context().add_class("settings-inline-status")
        status.get_style_context().add_class("action-state-running")
        progress = Gtk.ProgressBar()
        progress.set_show_text(False)
        progress.get_style_context().add_class("settings-progress")

        activity_label = Gtk.Label(label=tr("settings.operation_activity.waiting", "Initialisation"))
        activity_label.set_xalign(0)
        activity_label.set_ellipsize(Pango.EllipsizeMode.END)
        activity_label.get_style_context().add_class("update-activity")

        action_list = Gtk.ListBox()
        action_list.get_style_context().add_class("update-list")
        action_list.get_style_context().add_class("action-step-list")
        step_labels: list[Gtk.Label] = []
        step_icons: list[Gtk.Label] = []

        def add_action_step(step: str, index: int) -> None:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("update-row")
            icon_label = Gtk.Label(label="○")
            icon_label.get_style_context().add_class("update-kind-icon")
            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text_box.set_hexpand(True)
            title_label = Gtk.Label(label=step)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("update-name")
            state_label = Gtk.Label(label=tr("settings.operation.waiting", "En attente"))
            state_label.set_xalign(0)
            state_label.get_style_context().add_class("update-version")
            state_label.get_style_context().add_class("action-step-state")
            text_box.pack_start(title_label, False, False, 0)
            text_box.pack_start(state_label, False, False, 0)
            wrapper.pack_start(icon_label, False, False, 0)
            wrapper.pack_start(text_box, True, True, 0)
            row.add(wrapper)
            action_list.add(row)
            step_icons.append(icon_label)
            step_labels.append(state_label)

        for step_index, step in enumerate(expected_steps):
            add_action_step(step, step_index)

        def set_step(index: int, state: str, message: str | None = None) -> None:
            if not step_labels:
                return
            index = max(0, min(index, len(step_labels) - 1))
            label = step_labels[index]
            icon = step_icons[index]
            if state == "done":
                icon.set_text("✓")
                label.set_text(message or tr("settings.operation.done", "Terminé"))
            elif state == "error":
                icon.set_text("!")
                label.set_text(message or tr("settings.operation.needs_attention", "À vérifier"))
            elif state == "running":
                icon.set_text("●")
                label.set_text(message or tr("settings.operation.running", "En cours"))
            else:
                icon.set_text("○")
                label.set_text(message or tr("settings.operation.waiting", "En attente"))

        def complete_steps(success: bool) -> None:
            for index in range(len(step_labels)):
                set_step(index, "done" if success else ("error" if index == len(step_labels) - 1 else "done"))

        def set_action_state(state: str) -> None:
            for widget in (status,):
                context = widget.get_style_context()
                for css_class in ("action-state-running", "action-state-success", "action-state-error"):
                    context.remove_class(css_class)
                context.add_class(f"action-state-{state}")

        set_action_state("running")
        set_step(0, "running")
        buffer = Gtk.TextBuffer()
        buffer.set_text(tr("settings.command_output.waiting", "Préparation de l’action…") + "\n")

        action_card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        action_card.get_style_context().add_class("action-hero-card")
        action_glyph = Gtk.Label(label="󰜉")
        action_glyph.get_style_context().add_class("action-hero-glyph")
        action_copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        action_copy.set_hexpand(True)
        action_card_title = Gtk.Label(label=tr("settings.action_card.running", "SevenOS s’en occupe"))
        action_card_title.set_xalign(0)
        action_card_title.get_style_context().add_class("action-hero-title")
        action_card_note = Gtk.Label(label=tr("settings.action_card.note", "Tu peux garder cette fenêtre ouverte pendant l’opération."))
        action_card_note.set_xalign(0)
        action_card_note.set_line_wrap(True)
        action_card_note.get_style_context().add_class("action-hero-note")
        action_copy.pack_start(action_card_title, False, False, 0)
        action_copy.pack_start(action_card_note, False, False, 0)
        action_card.pack_start(action_glyph, False, False, 0)
        action_card.pack_start(action_copy, True, True, 0)

        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)
        box.pack_start(action_card, False, False, 0)
        box.pack_start(status, False, False, 0)
        box.pack_start(activity_label, False, False, 0)
        box.pack_start(progress, False, False, 0)
        box.pack_start(action_list, True, True, 0)

        process_ref: dict[str, subprocess.Popen] = {}
        last_output = {"text": f"$ {ui_command}\n"}
        line_count = {"value": 0}
        heartbeat_index = {"value": 0}
        heartbeat_seen = {"lines": 0}

        def pulse() -> bool:
            process = process_ref.get("process")
            if process is None or process.poll() is None:
                progress.pulse()
                return True
            return False

        def heartbeat() -> bool:
            process = process_ref.get("process")
            if process is not None and process.poll() is not None:
                return False
            if heartbeat_seen["lines"] == line_count["value"]:
                messages = [
                    tr("settings.operation.synthetic.prepare", "Préparation de l’action…"),
                    tr("settings.operation.synthetic.sources", "Préparation des éléments disponibles…"),
                    tr("settings.operation.synthetic.packages", "Vérification des éléments à traiter…"),
                    tr("settings.operation.synthetic.wait", "L’opération continue en arrière-plan…"),
                ]
                message = messages[heartbeat_index["value"] % len(messages)]
                heartbeat_index["value"] += 1
                set_step(min(1, len(step_labels) - 1), "running", message)
                activity_label.set_text(message)
                status.set_text(tr("settings.command_output.live", "Action en cours…"))
            heartbeat_seen["lines"] = line_count["value"]
            return True

        def copy_details(_button: Gtk.Button) -> None:
            clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
            clipboard.set_text(last_output.get("text") or ui_command, -1)
            clipboard.store()
            show_feedback(tr("settings.command_output.copied", "Compte rendu copié."), "success")

        copy_button = Gtk.Button(label=tr("settings.copy_details", "Copier le compte rendu"))
        copy_button.get_style_context().add_class("action-button")
        copy_button.set_tooltip_text(tr("settings.copy_details.tooltip", "Copier le compte rendu disponible dans le presse-papiers."))
        copy_button.set_sensitive(False)
        copy_button.connect("clicked", copy_details)
        dialog.get_action_area().pack_start(copy_button, False, False, 0)
        copy_button.show()

        def on_response(_dialog: Gtk.Dialog, response: int) -> None:
            process = process_ref.get("process")
            if process and process.poll() is None:
                if response == Gtk.ResponseType.CANCEL:
                    process.terminate()
                    status.set_text(tr("settings.command_output.cancelled", "Action annulée."))
                    set_action_state("error")
                    set_step(len(step_labels) - 1, "error", tr("settings.operation_result.cancelled", "Annulé"))
                    activity_label.set_text(tr("settings.command_output.cancelled", "Action annulée."))
                    cancel_button.set_sensitive(False)
                    close_button.set_sensitive(True)
                    copy_button.set_sensitive(True)
                    return
                show_feedback(tr("settings.command_output.still_running", "Action en cours. Utilise Annuler pour l’interrompre."), "warning")
                return
            dialog.destroy()

        dialog.connect("response", on_response)
        dialog.show_all()
        close_button.set_sensitive(False)
        if command.strip() == "seven status":
            about = system_about()
            rows = [
                f"SevenOS: {about.get('release', 'SevenOS')}",
                f"Appareil: {about.get('hostname', platform.node() or 'SevenOS')}",
                f"Base: {about.get('kernel', platform.release())}",
                f"Session: {about.get('session', 'Hyprland')}",
                f"Espace: {about.get('profile', active_profile_key())}",
                f"Thème: {current_theme_mode()}",
                f"État: {about.get('readiness', 'ready')}",
                f"Résumé: {about.get('smoke', 'fast status')}",
            ]
            summary = "\n".join(rows)
            buffer.set_text(summary)
            last_output["text"] = f"$ seven status\n\n{summary}\n\nexit=0"
            copy_button.set_sensitive(True)
            status.set_text(tr("settings.command_output.done", "Terminé."))
            set_action_state("success")
            complete_steps(True)
            activity_label.set_text(tr("settings.status.instant", "Résumé prêt dans Paramètres."))
            progress.set_fraction(1.0)
            progress.set_show_text(True)
            progress.set_text("OK")
            cancel_button.set_sensitive(False)
            close_button.set_sensitive(True)
            append_settings_action_log("seven status", 0, summary)
            return
        pulse_source = GLib.timeout_add(120, pulse)
        heartbeat_source = GLib.timeout_add_seconds(2, heartbeat)

        def worker() -> None:
            output_lines: list[str] = []
            ui_timeout = 10.0 if ui_command.strip().startswith(("seven smoke", "seven status")) else 180.0

            def append_line(line: str) -> bool:
                line = line.rstrip("\n")
                if not line:
                    return False
                line_count["value"] += 1
                last_output["text"] = f"$ {ui_command}\n\n" + "\n".join(output_lines[-500:])
                copy_button.set_sensitive(True)
                stage = operation_stage(line)
                set_step(min(1 if line_count["value"] < 4 else 2, len(step_labels) - 1), "running", stage)
                activity_label.set_text(stage)
                status.set_text(tr("settings.command_output.live", "Action en cours…"))
                end = buffer.get_end_iter()
                buffer.insert(end, line + "\n")
                return False

            try:
                runner = f"stdbuf -oL -eL {ui_command}" if command_exists("stdbuf") else ui_command
                process = subprocess.Popen(
                    ["bash", "-lc", runner],
                    cwd=ROOT,
                    env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_SETTINGS_ACTION": "1"},
                    text=True,
                    stdin=subprocess.DEVNULL,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    start_new_session=True,
                )
                process_ref["process"] = process
                deadline = time.monotonic() + ui_timeout
                if process.stdout:
                    selector = selectors.DefaultSelector()
                    selector.register(process.stdout, selectors.EVENT_READ)
                    try:
                        while process.poll() is None:
                            if time.monotonic() > deadline:
                                process.terminate()
                                timeout_line = tr(
                                    "settings.command_output.timeout",
                                    "SevenOS a arrêté l’attente graphique après {seconds}s. Tu peux relancer une vérification depuis Aide si besoin.",
                                    seconds=int(ui_timeout),
                                )
                                output_lines.append(timeout_line)
                                GLib.idle_add(append_line, timeout_line)
                                break
                            events = selector.select(timeout=0.25)
                            for _key, _mask in events:
                                line = process.stdout.readline()
                                if not line:
                                    continue
                                output_lines.append(line.rstrip("\n"))
                                GLib.idle_add(append_line, line)
                        for line in process.stdout.readlines():
                            output_lines.append(line.rstrip("\n"))
                            GLib.idle_add(append_line, line)
                    finally:
                        selector.close()
                try:
                    code = process.wait(timeout=2.0)
                except subprocess.TimeoutExpired:
                    process.kill()
                    code = process.wait()
                output = "\n".join(output_lines)
            except Exception as exc:
                output = str(exc)
                code = 1

            def finish() -> bool:
                clean_output = output.strip() or tr("settings.command_output.empty", "Action terminée sans sortie détaillée.")
                last_output["text"] = f"$ {ui_command}\n\n{clean_output}\n\nexit={code}"
                if not output.strip():
                    end = buffer.get_end_iter()
                    buffer.insert(end, clean_output + "\n")
                if code == 0:
                    if any(marker in ui_command for marker in ("install.sh theme", "seven language apply", "seven-waybar repair", "hyprctl reload")):
                        refresh_runtime_css()
                    status.set_text(tr("settings.command_output.done", "Terminé."))
                    set_action_state("success")
                    complete_steps(True)
                    activity_label.set_text(tr("settings.operation.done", "Terminé"))
                    action_glyph.set_text("✓")
                    action_card_title.set_text(tr("settings.action_card.done", "C’est prêt"))
                    action_card_note.set_text(tr("settings.action_card.done_note", "L’action s’est terminée correctement."))
                else:
                    status.set_text(tr("settings.command_output.failed", "Action incomplète. Le compte rendu peut être copié si besoin."))
                    set_action_state("error")
                    complete_steps(False)
                    activity_label.set_text(tr("settings.operation.needs_attention", "À vérifier"))
                    action_glyph.set_text("!")
                    action_card_title.set_text(tr("settings.action_card.failed", "À vérifier"))
                    action_card_note.set_text(tr("settings.action_card.failed_note", "SevenOS n’a pas pu terminer cette action. Le compte rendu est disponible si besoin."))
                progress.set_fraction(1.0 if code == 0 else 0.0)
                progress.set_show_text(True)
                progress.set_text("OK" if code == 0 else tr("settings.needs_attention", "À vérifier"))
                cancel_button.set_sensitive(False)
                close_button.set_sensitive(True)
                copy_button.set_sensitive(True)
                append_settings_action_log(ui_command, code, clean_output[-4000:])
                GLib.source_remove(pulse_source)
                GLib.source_remove(heartbeat_source)
                return False

            GLib.idle_add(finish)

        threading.Thread(target=worker, daemon=True).start()

    def show_settings_action_history() -> None:
        dialog = Gtk.Dialog(
            title=tr("settings.action_history", "Historique des actions"),
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
        )
        dialog.set_default_size(min(760, max(560, int(screen_width * 0.52))), min(460, max(340, int(screen_height * 0.52))))
        dialog.add_button(tr("settings.close", "Fermer"), Gtk.ResponseType.CLOSE)
        box = style_dialog(dialog)
        box.set_spacing(10)
        box.set_border_width(14)

        title = Gtk.Label(label=tr("settings.action_history.title", "Dernières actions SevenOS"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(
            label=tr(
                "settings.action_history.note",
                "Les actions lancées depuis Paramètres sont résumées ici pour comprendre ce qui a réussi ou échoué.",
            )
        )
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")

        raw_history = ""
        if SETTINGS_ACTION_LOG.exists():
            raw_history = SETTINGS_ACTION_LOG.read_text(encoding="utf-8", errors="ignore").strip()[-12000:]

        def friendly_command_name(command: str) -> str:
            stripped = command.strip()
            if stripped.startswith("seven update"):
                return tr("settings.action.update.title", "Mise à jour SevenOS")
            if stripped.startswith("seven profile requirements"):
                return tr("settings.action.requirements.title", "Installation des besoins essentiels")
            if stripped.startswith("seven post-install"):
                return tr("settings.action.post_install.title", "Vérification post-installation")
            if stripped.startswith("seven repair") or "seven-waybar repair" in stripped:
                return tr("settings.action.repair.title", "Réparation de l’interface")
            if stripped.startswith("seven atlas"):
                return tr("settings.action.atlas.title", "Atlas Explorer")
            if stripped.startswith("seven recovery"):
                return tr("settings.action.backup.title", "Sauvegarde et restauration")
            if stripped.startswith("seven profile activate"):
                return tr("settings.action.profile.title", "Changement de mini OS")
            if stripped.startswith(("sevenpkg", "seven flatpak", "flatpak")):
                return tr("settings.action.software.title", "Logiciels")
            if stripped.startswith(("seven state", "seven status", "seven smoke")):
                return tr("settings.action.status.title", "État SevenOS")
            return tr("settings.action.generic.title", "Action SevenOS")

        def history_rows() -> list[tuple[str, str, str, str | None]]:
            rows: list[tuple[str, str, str, str | None]] = []
            blocks = [block.strip() for block in raw_history.split("--- SevenOS Settings action ---") if block.strip()]
            for block in blocks[-12:]:
                command = ""
                code = ""
                first_detail = ""
                for line in block.splitlines():
                    clean = line.strip()
                    if clean.startswith("$ "):
                        command = clean[2:].strip()
                    elif clean.startswith("exit="):
                        code = clean.split("=", 1)[1].strip()
                    elif clean.startswith("time="):
                        continue
                    elif clean and not first_detail:
                        first_detail = clean
                success = code == "0"
                started = code in {"started", "running", "pending"}
                if success:
                    icon = "✓"
                    note_text = tr("settings.action_history.success_note", "Action terminée correctement.")
                    badge = tr("settings.done", "Terminé")
                elif started:
                    icon = "…"
                    note_text = first_detail or tr(
                        "settings.action_history.started_note",
                        "Action lancée en arrière-plan. Elle peut ouvrir ou actualiser une surface SevenOS.",
                    )
                    badge = tr("settings.started", "Lancé")
                else:
                    icon = "!"
                    note_text = (
                        f"{tr('settings.action_history.failed_note', 'Action non terminée. Le compte rendu peut être copié.')}"
                        f" · {command or tr('settings.unknown', 'Inconnu')}"
                    )
                    badge = tr("settings.needs_attention", "À vérifier")
                rows.append(
                    (
                        icon,
                        friendly_command_name(command),
                        note_text,
                        badge,
                    )
                )
            return rows

        scroller = Gtk.ScrolledWindow()
        scroller.set_hexpand(True)
        scroller.set_vexpand(True)
        action_list = Gtk.ListBox()
        action_list.get_style_context().add_class("account-list")
        rows = history_rows()
        if not rows:
            rows = [("󰄬", tr("settings.action_history.empty", "Aucune action récente."), tr("settings.action_history.empty_note", "Les actions lancées depuis Paramètres apparaîtront ici."), None)]
        for icon, row_title, row_note, badge_text in rows:
            row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label=icon)
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            row_title_label = Gtk.Label(label=row_title)
            row_title_label.set_xalign(0)
            row_title_label.get_style_context().add_class("settings-row-title")
            row_note_label = Gtk.Label(label=row_note)
            row_note_label.set_xalign(0)
            row_note_label.set_line_wrap(True)
            row_note_label.set_max_width_chars(78)
            row_note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(row_title_label, False, False, 0)
            labels.pack_start(row_note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            if badge_text:
                badge = Gtk.Label(label=badge_text)
                badge.get_style_context().add_class("update-summary-chip")
                wrapper.pack_start(badge, False, False, 0)
            row.add(wrapper)
            action_list.add(row)
        scroller.add(action_list)

        button_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

        def copy_history(_button: Gtk.Button) -> None:
            payload = raw_history or tr("settings.action_history.empty", "Aucune action récente.")
            clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
            clipboard.set_text(payload, -1)
            clipboard.store()
            show_feedback(tr("settings.action_history.copied", "Historique copié."), "success")

        def clear_history(_button: Gtk.Button) -> None:
            nonlocal raw_history
            SETTINGS_ACTION_LOG.unlink(missing_ok=True)
            raw_history = ""
            for child in action_list.get_children():
                action_list.remove(child)
            empty_row = Gtk.ListBoxRow()
            wrapper = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            wrapper.get_style_context().add_class("account-row")
            glyph = Gtk.Label(label="󰄬")
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            title_label = Gtk.Label(label=tr("settings.action_history.empty", "Aucune action récente."))
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            note_label = Gtk.Label(label=tr("settings.action_history.empty_note", "Les actions lancées depuis Paramètres apparaîtront ici."))
            note_label.set_xalign(0)
            note_label.get_style_context().add_class("settings-row-note")
            labels.pack_start(title_label, False, False, 0)
            labels.pack_start(note_label, False, False, 0)
            wrapper.pack_start(glyph, False, False, 0)
            wrapper.pack_start(labels, True, True, 0)
            empty_row.add(wrapper)
            action_list.add(empty_row)
            action_list.show_all()
            show_feedback(tr("settings.action_history.cleared", "Historique vidé."), "success")

        copy_button = Gtk.Button(label=tr("settings.copy", "Copier"))
        copy_button.get_style_context().add_class("action-button")
        copy_button.connect("clicked", copy_history)
        clear_button = Gtk.Button(label=tr("settings.clear", "Effacer"))
        clear_button.get_style_context().add_class("action-button")
        clear_button.connect("clicked", clear_history)
        button_row.pack_start(copy_button, False, False, 0)
        button_row.pack_start(clear_button, False, False, 0)

        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)
        box.pack_start(scroller, True, True, 0)
        box.pack_start(button_row, False, False, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def action_button(label: str, command: str, feedback: str | None = None) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.set_can_focus(True)
        button.get_style_context().add_class("action-button")
        button.set_tooltip_text(tr("settings.action.tooltip", "Lancer cette action SevenOS"))

        def sensitive_action(command_text: str) -> tuple[str, str, str] | None:
            stripped = command_text.strip()
            if stripped.startswith("seven-power lock"):
                return (
                    tr("settings.confirm.lock.title", "Verrouiller la session ?"),
                    tr("settings.confirm.lock.note", "Les apps restent ouvertes, mais tu devras entrer ton mot de passe pour revenir."),
                    tr("settings.lock", "Verrouiller"),
                )
            if stripped.startswith("seven profile migrate-aliases"):
                return (
                    tr("settings.confirm.aliases.title", "Nettoyer les anciens noms ?"),
                    tr("settings.confirm.aliases.note", "SevenOS retirera les anciens alias de profils pour éviter les confusions dans les mini OS."),
                    tr("settings.repair", "Réparer"),
                )
            if stripped.startswith("seven profile requirements") and "--apply" in stripped:
                return (
                    tr("settings.confirm.requirements.title", "Installer les besoins essentiels ?"),
                    tr("settings.confirm.requirements.note", "SevenOS peut installer des paquets manquants pour rendre les mini OS complets sur cette machine."),
                    tr("settings.install", "Installer"),
                )
            if stripped.startswith("seven migrate backup"):
                return (
                    tr("settings.confirm.backup.title", "Créer une sauvegarde maintenant ?"),
                    tr("settings.confirm.backup.note", "SevenOS va préparer une sauvegarde de migration et afficher le résultat dans Paramètres."),
                    tr("settings.create", "Créer"),
                )
            return None

        def confirm_sensitive(command_text: str) -> bool:
            payload = sensitive_action(command_text)
            if not payload:
                return True
            title_text, note_text, accept_label = payload
            dialog = Gtk.MessageDialog(
                transient_for=window,
                flags=Gtk.DialogFlags.MODAL,
                message_type=Gtk.MessageType.QUESTION,
                buttons=Gtk.ButtonsType.NONE,
                text=title_text,
            )
            dialog.get_style_context().add_class("settings-dialog")
            dialog.format_secondary_text(note_text)
            dialog.add_button(tr("settings.cancel", "Annuler"), Gtk.ResponseType.CANCEL)
            continue_button = dialog.add_button(accept_label, Gtk.ResponseType.ACCEPT)
            continue_button.get_style_context().add_class("suggested-action")
            response = dialog.run()
            dialog.destroy()
            return response == Gtk.ResponseType.ACCEPT

        def clicked(_button, cmd=command, feedback_text=feedback) -> None:
            if button_recently_triggered(_button):
                pulse_button(_button, 160)
                return
            if not confirm_sensitive(cmd):
                pulse_button(_button, 180)
                show_feedback(tr("settings.action_cancelled", "Action annulée."), "warning")
                return
            if cmd.strip().startswith("seven update"):
                pulse_button(_button)
                if feedback_text:
                    show_feedback(feedback_text)
                GLib.idle_add(lambda: (show_update_manager(), False)[1])
                return
            if handle_graphical_action(cmd):
                pulse_button(_button)
                if feedback_text:
                    show_feedback(feedback_text)
                return
            mark_action_running(_button, feedback_text or tr("settings.action_started", "Action lancée."))
            if should_show_output(cmd):
                GLib.idle_add(lambda: (show_command_output(cmd, _button.get_label()), False)[1])
            else:
                GLib.idle_add(lambda: (run_detached(cmd), False)[1])

        button.connect("clicked", clicked)
        sensitive = sensitive_action(command)
        if sensitive:
            button.set_tooltip_text(f"{sensitive[0]} · {sensitive[2]}")
        return button

    def callback_button(label: str, tooltip: str, callback, feedback: str | None = None) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.set_can_focus(True)
        button.get_style_context().add_class("action-button")
        button.set_tooltip_text(tooltip)

        def clicked(_button) -> None:
            if button_recently_triggered(_button):
                pulse_button(_button, 160)
                return
            pulse_button(_button)
            if feedback:
                show_feedback(feedback)
            try:
                callback()
            except Exception as exc:
                show_feedback(tr("settings.action_failed", "Action impossible pour le moment."), "error")

        button.connect("clicked", clicked)
        return button

    def page_button(label: str, target: str) -> Gtk.Button:
        return callback_button(
            label,
            f"settings:{target}",
            lambda page_name=target: activate_page(page_name, nav_by_target[page_name]),
            page_opened_message(target),
        )

    def copy_system_summary() -> None:
        about = system_about()
        summary = "\n".join(
            [
                f"SevenOS: {about['release']}",
                f"Appareil: {about['hostname']}",
                f"Base: {about['kernel']}",
                f"Session: {about['session']}",
                f"Espace: {about['profile']}",
                f"État: {about['readiness']}",
            ]
        )
        clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        clipboard.set_text(summary, -1)
        clipboard.store()
        notify("Réglages SevenOS", tr("settings.system_summary_copied", "Résumé copié."))
        show_feedback(tr("settings.system_info_copied", "Résumé copié."), "success")

    def quick_dot(icon: str, tooltip: str, command: str) -> Gtk.Button:
        button = Gtk.Button(label=icon)
        button.get_style_context().add_class("quick-dot")
        button.set_tooltip_text(tooltip)

        def clicked(_button, cmd=command) -> None:
            parts = cmd.strip().split()
            if len(parts) == 2 and parts[0] in {"seven-settings", "seven-settings-native"} and parts[1] in nav_by_target:
                activate_page(parts[1], nav_by_target[parts[1]])
                show_feedback(page_opened_message(parts[1]))
                return
            if cmd.strip().startswith("seven update"):
                show_update_manager()
                return
            if handle_graphical_action(cmd):
                return
            if should_show_output(cmd):
                show_command_output(cmd, tooltip)
                return
            run_detached(cmd)

        button.connect("clicked", clicked)
        return button

    def quick_strip(items: list[tuple[str, str, str]]) -> Gtk.Box:
        strip = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        strip.set_halign(Gtk.Align.START)
        strip.get_style_context().add_class("quick-strip")
        for icon, tooltip, command in items:
            strip.pack_start(quick_dot(icon, tooltip, command), False, False, 0)
        return strip

    def file_wallpaper_button(label: str) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("action-button")

        def choose(_button) -> None:
            dialog = Gtk.FileChooserDialog(
                title=tr("settings.choose_image", "Choisir un fond d’écran SevenOS"),
                parent=window,
                action=Gtk.FileChooserAction.OPEN,
                buttons=(f"_{tr('settings.cancel', 'Annuler')}", Gtk.ResponseType.CANCEL, f"_{tr('settings.set_wallpaper', 'Définir le fond')}", Gtk.ResponseType.ACCEPT),
            )
            image_filter = Gtk.FileFilter()
            image_filter.set_name("Images")
            for mime in ("image/png", "image/jpeg", "image/webp", "image/svg+xml"):
                image_filter.add_mime_type(mime)
            dialog.add_filter(image_filter)
            preview = Gtk.Image()
            preview.set_size_request(220, 124)
            dialog.set_preview_widget(preview)

            def update_preview(file_dialog) -> None:
                filename = file_dialog.get_preview_filename()
                if not filename:
                    file_dialog.set_preview_widget_active(False)
                    return
                try:
                    pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(filename, 220, 124, True)
                    preview.set_from_pixbuf(pixbuf)
                    file_dialog.set_preview_widget_active(True)
                except Exception:
                    file_dialog.set_preview_widget_active(False)

            dialog.connect("update-preview", update_preview)
            response = dialog.run()
            filename = dialog.get_filename()
            dialog.destroy()
            if response == Gtk.ResponseType.ACCEPT and filename:
                subprocess.Popen([str(ROOT / "bin/seven-wallpaper"), "set", filename], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
                notify(tr("settings.title", "Réglages SevenOS"), tr("settings.wallpaper_updated", "Fond d’écran mis à jour."))

        button.connect("clicked", choose)
        return button

    def show_wallpaper_collection_dialog(_button=None) -> None:
        payload = run_json_timeout([str(ROOT / "bin/seven-wallpaper"), "collection-list"], {}, timeout=1.2)
        items = payload.get("items") if isinstance(payload.get("items"), list) else []
        dialog = Gtk.Dialog(title=tr("settings.wallpaper_collection", "Collection SevenOS"), transient_for=window, modal=True)
        dialog.set_default_size(840, 700)
        box = style_dialog(dialog)
        hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        hero.get_style_context().add_class("wallpaper-hero")
        hero_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        hero_text.set_hexpand(True)
        title = Gtk.Label(label=tr("settings.wallpaper_collection", "Collection SevenOS"))
        title.set_xalign(0)
        title.get_style_context().add_class("wallpaper-hero-title")
        note = Gtk.Label(label=tr(
            "settings.wallpaper_collection.note",
            "{count} fonds dynamiques SevenOS, avec ambiances claires, sombres et équilibrées.",
            count=len(items),
        ))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("dialog-note")
        hero_text.pack_start(title, False, False, 0)
        hero_text.pack_start(note, False, False, 0)
        hero.pack_start(hero_text, True, True, 0)
        choose_file = file_wallpaper_button(tr("settings.choose_image", "Choisir une image"))
        hero.pack_start(choose_file, False, False, 0)

        active_filter = {"tone": "all", "family": "all", "query": ""}
        selected = {"item": items[0] if items else None}
        rotation_selection: set[str] = set()
        rotation_mode = {"enabled": False}
        wallpaper_buttons: dict[str, Gtk.Button] = {}
        tool_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        tool_row.get_style_context().add_class("wallpaper-tool-row")
        tone_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        family_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        tone_buttons: dict[str, Gtk.Button] = {}
        family_buttons: dict[str, Gtk.Button] = {}
        search_entry = Gtk.SearchEntry()
        search_entry.set_placeholder_text(tr("settings.wallpaper.search", "Rechercher un style, une couleur, un moment..."))
        search_entry.set_hexpand(True)
        search_entry.get_style_context().add_class("wallpaper-search")
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.set_size_request(700, 338)
        grid = Gtk.Grid(column_spacing=10, row_spacing=10)
        grid.set_margin_top(4)
        grid.set_margin_bottom(8)
        grid.set_margin_start(2)
        grid.set_margin_end(2)

        preview_card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        preview_card.get_style_context().add_class("wallpaper-preview-card")
        preview_frame = Gtk.Box()
        preview_frame.get_style_context().add_class("wallpaper-preview-frame")
        preview_frame.set_halign(Gtk.Align.START)
        preview_frame.set_valign(Gtk.Align.CENTER)
        preview_image = Gtk.Image()
        preview_frame.pack_start(preview_image, True, True, 0)
        preview_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        preview_text.set_hexpand(True)
        preview_title = Gtk.Label()
        preview_title.set_xalign(0)
        preview_title.get_style_context().add_class("wallpaper-hero-title")
        preview_meta = Gtk.Label()
        preview_meta.set_xalign(0)
        preview_meta.set_line_wrap(True)
        preview_meta.get_style_context().add_class("dialog-note")
        preview_hint = Gtk.Label(label=tr("settings.wallpaper.preview_hint", "Sélectionne un visuel, puis applique-le quand le rendu te convient."))
        preview_hint.set_xalign(0)
        preview_hint.set_line_wrap(True)
        preview_hint.get_style_context().add_class("wallpaper-collection-note")
        preview_text.pack_start(preview_title, False, False, 0)
        preview_text.pack_start(preview_meta, False, False, 0)
        preview_text.pack_start(preview_hint, False, False, 0)
        preview_card.pack_start(preview_frame, False, False, 0)
        preview_card.pack_start(preview_text, True, True, 0)
        rotation_panel = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        rotation_panel.get_style_context().add_class("wallpaper-rotation-panel")
        rotation_panel.set_halign(Gtk.Align.FILL)
        rotation_panel.set_hexpand(True)
        rotation_toggle = Gtk.ToggleButton(label=tr("settings.wallpaper.rotation_select", "Sélection rotation"))
        rotation_toggle.get_style_context().add_class("wallpaper-filter")
        rotation_toggle.set_tooltip_text(tr("settings.wallpaper.rotation_select.tooltip", "Activer le mode de sélection des fonds à faire tourner."))
        rotation_count = Gtk.Label(label=tr("settings.wallpaper.rotation_count", "{count} sélectionné(s)", count=0))
        rotation_count.set_xalign(0)
        rotation_count.get_style_context().add_class("wallpaper-collection-note")
        rotation_status = Gtk.Label()
        rotation_status.set_xalign(0)
        rotation_status.get_style_context().add_class("wallpaper-collection-note")
        interval_spin = Gtk.SpinButton.new_with_range(30, 86400, 30)
        interval_spin.set_value(900)
        interval_spin.set_numeric(True)
        interval_spin.set_tooltip_text(tr("settings.wallpaper.rotation_interval", "Durée entre deux fonds, en secondes."))
        interval_combo = Gtk.ComboBoxText()
        for seconds, label in (
            (300, tr("settings.wallpaper.rotation.5min", "5 min")),
            (900, tr("settings.wallpaper.rotation.15min", "15 min")),
            (1800, tr("settings.wallpaper.rotation.30min", "30 min")),
            (3600, tr("settings.wallpaper.rotation.1h", "1 h")),
            (10800, tr("settings.wallpaper.rotation.3h", "3 h")),
        ):
            interval_combo.append(str(seconds), label)
        interval_combo.set_active_id("900")
        rotation_apply = Gtk.Button(label=tr("settings.wallpaper.rotation_apply", "Activer la rotation"))
        rotation_apply.get_style_context().add_class("primary-action")
        rotation_next = Gtk.Button(label=tr("settings.wallpaper.rotation_next", "Suivant"))
        rotation_next.get_style_context().add_class("action-button")
        rotation_next.set_tooltip_text(tr("settings.wallpaper.rotation_next.tooltip", "Passer au fond suivant de la rotation."))
        rotation_visible = Gtk.Button(label=tr("settings.wallpaper.rotation_visible", "Sélectionner visibles"))
        rotation_visible.get_style_context().add_class("action-button")
        rotation_visible.set_tooltip_text(tr("settings.wallpaper.rotation_visible.tooltip", "Ajouter tous les fonds visibles à la rotation."))
        rotation_clear = Gtk.Button(label=tr("settings.clear", "Effacer"))
        rotation_clear.get_style_context().add_class("action-button")
        rotation_clear.set_tooltip_text(tr("settings.wallpaper.rotation_clear.tooltip", "Retirer tous les fonds sélectionnés pour la rotation."))
        rotation_stop = Gtk.Button(label=tr("settings.wallpaper.rotation_stop", "Désactiver"))
        rotation_stop.get_style_context().add_class("action-button")
        rotation_stop.set_tooltip_text(tr("settings.wallpaper.rotation_stop.tooltip", "Désactiver la rotation automatique des fonds."))
        rotation_panel.pack_start(rotation_toggle, False, False, 0)
        rotation_panel.pack_start(rotation_count, True, True, 0)
        rotation_panel.pack_start(rotation_status, True, True, 0)
        rotation_panel.pack_start(Gtk.Label(label=tr("settings.wallpaper.rotation_every", "Toutes les")), False, False, 0)
        rotation_panel.pack_start(interval_combo, False, False, 0)
        rotation_panel.pack_start(interval_spin, False, False, 0)
        rotation_panel.pack_start(Gtk.Label(label=tr("settings.seconds", "s")), False, False, 0)
        rotation_panel.pack_start(rotation_visible, False, False, 0)
        rotation_panel.pack_start(rotation_clear, False, False, 0)
        rotation_panel.pack_start(rotation_next, False, False, 0)
        rotation_panel.pack_start(rotation_stop, False, False, 0)
        rotation_panel.pack_start(rotation_apply, False, False, 0)
        preset_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        preset_row.get_style_context().add_class("wallpaper-preset-row")
        preset_label = Gtk.Label(label=tr("settings.wallpaper.presets", "Ambiances"))
        preset_label.set_xalign(0)
        preset_label.get_style_context().add_class("wallpaper-collection-note")
        preset_row.pack_start(preset_label, False, False, 0)

        visible_slugs: list[str] = []
        rotation_payload = run_json_timeout([str(ROOT / "bin/seven-wallpaper"), "rotation", "status"], {}, timeout=0.8)
        if isinstance(rotation_payload, dict):
            rotation_mode["enabled"] = rotation_payload.get("enabled") is True
            saved_slugs = rotation_payload.get("slugs") if isinstance(rotation_payload.get("slugs"), list) else []
            rotation_selection.update(str(slug) for slug in saved_slugs if slug)
            try:
                saved_interval = max(30, int(rotation_payload.get("interval") or 900))
                interval_spin.set_value(saved_interval)
                interval_combo.set_active_id(str(saved_interval))
            except Exception:
                pass
            rotation_toggle.set_active(rotation_mode["enabled"])

        def wallpaper_svg_path(item: dict) -> Path:
            svg = str(item.get("svg") or "")
            return ROOT / "identity/wallpaper/dynamic" / svg

        def scaled_wallpaper_pixbuf(item: dict, width: int, height: int):
            try:
                return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(wallpaper_svg_path(item)), width, height, True)
            except Exception:
                return None

        def refresh_preview() -> None:
            item = selected.get("item")
            if not isinstance(item, dict):
                preview_title.set_text(tr("settings.wallpaper.no_selection", "Aucun fond sélectionné"))
                preview_meta.set_text("")
                preview_image.clear()
                apply_button.set_sensitive(False)
                apply_button.set_label(tr("settings.set_wallpaper", "Définir le fond"))
                apply_button.set_tooltip_text(tr("settings.wallpaper.no_selection", "Aucun fond sélectionné"))
                return
            title_text = str(item.get("title") or item.get("slug") or "")
            tone = str(item.get("tone") or "")
            style = str(item.get("style") or "")
            moment = str(item.get("moment") or "")
            family = str(item.get("family") or "")
            preview_title.set_text(title_text)
            preview_meta.set_text(f"{tone} · {family} · {moment}\n{style}\n{tr('settings.wallpaper.double_click_hint', 'Astuce : double-clic sur une miniature pour appliquer rapidement.')}")
            short_title = title_text if len(title_text) <= 22 else f"{title_text[:21]}…"
            apply_button.set_sensitive(True)
            apply_button.set_label(tr("settings.set_wallpaper_named", "Définir {name}", name=short_title))
            apply_button.set_tooltip_text(tr("settings.set_wallpaper_named_full", "Définir “{name}” comme fond d’écran.", name=title_text))
            pixbuf = scaled_wallpaper_pixbuf(item, 290, 164)
            if pixbuf is not None:
                preview_image.set_from_pixbuf(pixbuf)
            else:
                preview_image.clear()
            for slug, button in wallpaper_buttons.items():
                if slug == str(item.get("slug") or ""):
                    button.get_style_context().add_class("selected")
                else:
                    button.get_style_context().remove_class("selected")
                if slug in rotation_selection:
                    button.get_style_context().add_class("rotation-selected")
                else:
                    button.get_style_context().remove_class("rotation-selected")

        def refresh_rotation_count() -> None:
            rotation_count.set_text(tr("settings.wallpaper.rotation_count", "{count} sélectionné(s)", count=len(rotation_selection)))
            seconds = int(interval_spin.get_value())
            rotation_apply.set_sensitive(len(rotation_selection) >= 2)
            rotation_apply.set_tooltip_text(
                tr("settings.wallpaper.rotation_apply_ready", "Activer la rotation avec {count} fonds.", count=len(rotation_selection))
                if len(rotation_selection) >= 2
                else tr("settings.wallpaper.rotation_apply_disabled", "Sélectionne au moins deux fonds pour activer la rotation.")
            )
            if rotation_mode["enabled"]:
                rotation_status.set_text(tr("settings.wallpaper.rotation_active", "Rotation active · {count} fonds · {seconds}s", count=len(rotation_selection), seconds=seconds))
            else:
                rotation_status.set_text(tr("settings.wallpaper.rotation_inactive", "Rotation désactivée"))
            refresh_preview()

        def set_rotation_preset(name: str, seconds: int, slugs: list[str]) -> None:
            rotation_mode["enabled"] = True
            rotation_toggle.set_active(True)
            rotation_selection.clear()
            rotation_selection.update(slugs)
            interval_spin.set_value(seconds)
            interval_combo.set_active_id(str(seconds))
            refresh_rotation_count()
            show_feedback(tr("settings.wallpaper.preset_ready", "Ambiance {name} prête. Tu peux l’activer ou l’ajuster.", name=name))

        def apply_wallpaper(slug: str, label: str) -> None:
            subprocess.Popen(
                [str(ROOT / "bin/seven-wallpaper"), "collection", slug],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
            preview_hint.set_text(tr("settings.wallpaper_collection.applied", "Fond demandé : {name}", name=label))
            show_feedback(tr("settings.wallpaper_collection.applied", "Fond demandé : {name}", name=label))

        def apply_selected(_button=None) -> None:
            item = selected.get("item")
            if not isinstance(item, dict):
                show_feedback(tr("settings.wallpaper.no_selection", "Aucun fond sélectionné"))
                return
            apply_wallpaper(str(item.get("slug") or ""), str(item.get("title") or item.get("slug") or ""))

        def choose_item(item: dict) -> None:
            selected["item"] = item
            slug = str(item.get("slug") or "")
            if rotation_mode["enabled"] and slug:
                if slug in rotation_selection:
                    rotation_selection.remove(slug)
                else:
                    rotation_selection.add(slug)
                refresh_rotation_count()
                return
            refresh_preview()

        def wallpaper_choice_widget(item: dict) -> Gtk.Button:
            slug = str(item.get("slug") or "")
            label = str(item.get("title") or slug)
            tone = str(item.get("tone") or "")
            style = str(item.get("style") or "")
            button = Gtk.Button()
            button.get_style_context().add_class("wallpaper-choice")
            if tone in {"light", "balanced", "dark"}:
                button.get_style_context().add_class(f"tone-{tone}")
            content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
            thumb_frame = Gtk.Box()
            thumb_frame.get_style_context().add_class("wallpaper-thumb-frame")
            thumb_frame.set_halign(Gtk.Align.CENTER)
            pixbuf = scaled_wallpaper_pixbuf(item, 185, 104)
            if pixbuf is not None:
                thumb_frame.pack_start(Gtk.Image.new_from_pixbuf(pixbuf), True, True, 0)
            else:
                fallback = Gtk.Label(label="◈")
                fallback.get_style_context().add_class("wallpaper-hero-title")
                thumb_frame.pack_start(fallback, True, True, 0)
            title_label = Gtk.Label(label=label)
            title_label.set_xalign(0)
            title_label.set_ellipsize(Pango.EllipsizeMode.END)
            title_label.get_style_context().add_class("wallpaper-thumb-title")
            meta = Gtk.Label(label=f"{tone} · {style}")
            meta.set_xalign(0)
            meta.set_ellipsize(Pango.EllipsizeMode.END)
            meta.get_style_context().add_class("wallpaper-thumb-meta")
            content.pack_start(thumb_frame, False, False, 0)
            content.pack_start(title_label, False, False, 0)
            content.pack_start(meta, False, False, 0)
            button.add(content)
            button.set_tooltip_text(
                f"{label}\n{tone} · {style}\n"
                + tr("settings.wallpaper.choice.tooltip", "Clic pour prévisualiser, double-clic pour appliquer.")
            )
            button.connect("clicked", lambda _button, item_payload=item: choose_item(item_payload))

            def on_button_press(_button, event, item_payload=item) -> bool:
                if event.type == Gdk.EventType._2BUTTON_PRESS:
                    choose_item(item_payload)
                    apply_wallpaper(str(item_payload.get("slug") or ""), str(item_payload.get("title") or item_payload.get("slug") or ""))
                    return True
                return False

            button.connect("button-press-event", on_button_press)
            wallpaper_buttons[slug] = button
            return button

        def rebuild_grid() -> None:
            for child in list(grid.get_children()):
                grid.remove(child)
            wallpaper_buttons.clear()
            visible_slugs.clear()
            filtered = [
                item for item in items
                if isinstance(item, dict)
                and (active_filter["tone"] == "all" or str(item.get("tone") or "") == active_filter["tone"])
                and (active_filter["family"] == "all" or str(item.get("family") or "") == active_filter["family"])
                and (
                    not active_filter["query"]
                    or active_filter["query"] in " ".join(
                        str(item.get(key) or "").lower()
                        for key in ("slug", "title", "family", "style", "moment", "tone", "accent", "secondary")
                    )
                )
            ]
            if not filtered:
                empty = Gtk.Label(label=tr("settings.wallpaper_collection.empty", "Aucun fond ne correspond à ce filtre."))
                empty.set_xalign(0)
                empty.get_style_context().add_class("wallpaper-empty")
                grid.attach(empty, 0, 0, 3, 1)
                grid.show_all()
                return
            for index, item in enumerate(filtered):
                slug = str(item.get("slug") or "")
                if slug:
                    visible_slugs.append(slug)
                grid.attach(wallpaper_choice_widget(item), index % 3, index // 3, 1, 1)
            if isinstance(selected.get("item"), dict) and selected["item"] not in filtered:
                selected["item"] = filtered[0]
            refresh_preview()
            grid.show_all()

        def set_tone_filter(tone: str) -> None:
            active_filter["tone"] = tone
            for key, button in tone_buttons.items():
                if key == tone:
                    button.get_style_context().add_class("active")
                else:
                    button.get_style_context().remove_class("active")
            rebuild_grid()

        def set_family_filter(family: str) -> None:
            active_filter["family"] = family
            for key, button in family_buttons.items():
                if key == family:
                    button.get_style_context().add_class("active")
                else:
                    button.get_style_context().remove_class("active")
            rebuild_grid()

        def on_search_changed(entry) -> None:
            active_filter["query"] = entry.get_text().strip().lower()
            rebuild_grid()

        search_entry.connect("search-changed", on_search_changed)

        def on_rotation_toggle(button) -> None:
            rotation_mode["enabled"] = button.get_active()
            if rotation_mode["enabled"] and isinstance(selected.get("item"), dict):
                slug = str(selected["item"].get("slug") or "")
                if slug:
                    rotation_selection.add(slug)
            refresh_rotation_count()

        def on_interval_preset(combo) -> None:
            value = combo.get_active_id()
            if value:
                interval_spin.set_value(int(value))
                refresh_rotation_count()

        def select_visible(_button=None) -> None:
            rotation_mode["enabled"] = True
            rotation_toggle.set_active(True)
            rotation_selection.update(visible_slugs)
            refresh_rotation_count()

        def clear_rotation_selection(_button=None) -> None:
            rotation_selection.clear()
            refresh_rotation_count()

        def apply_rotation(_button=None) -> None:
            if len(rotation_selection) < 2:
                show_feedback(tr("settings.wallpaper.rotation_needs_more", "Sélectionne au moins deux fonds pour créer une rotation."))
                return
            interval = int(interval_spin.get_value())
            slugs = sorted(rotation_selection)
            subprocess.Popen(
                [str(ROOT / "bin/seven-wallpaper"), "rotation", "set", str(interval), *slugs],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
            show_feedback(tr("settings.wallpaper.rotation_started", "Rotation activée avec {count} fonds.", count=len(slugs)))
            rotation_mode["enabled"] = True
            refresh_rotation_count()

        def stop_rotation(_button=None) -> None:
            subprocess.Popen(
                [str(ROOT / "bin/seven-wallpaper"), "rotation", "off"],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
            rotation_mode["enabled"] = False
            rotation_toggle.set_active(False)
            show_feedback(tr("settings.wallpaper.rotation_stopped", "Rotation des fonds désactivée."))
            refresh_rotation_count()

        def next_rotation(_button=None) -> None:
            subprocess.Popen(
                [str(ROOT / "bin/seven-wallpaper"), "rotation", "once"],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
            show_feedback(tr("settings.wallpaper.rotation_next_started", "Fond suivant demandé."))

        rotation_toggle.connect("toggled", on_rotation_toggle)
        interval_combo.connect("changed", on_interval_preset)
        rotation_visible.connect("clicked", select_visible)
        rotation_clear.connect("clicked", clear_rotation_selection)
        rotation_apply.connect("clicked", apply_rotation)
        rotation_stop.connect("clicked", stop_rotation)
        rotation_next.connect("clicked", next_rotation)

        for preset_name, seconds, slugs in (
            (tr("settings.wallpaper.preset.day", "Journée"), 900, ["prism-dawn", "aurora-morning", "orbit-noon", "terra-afternoon", "kente-golden", "prism-dusk", "aurora-night"]),
            (tr("settings.wallpaper.preset.calm", "Calme"), 1800, ["terra-mist", "aurora-dawn", "prism-morning", "terra-golden", "orbit-dusk", "aurora-night"]),
            (tr("settings.wallpaper.preset.focus", "Focus"), 1800, ["prism-morning", "orbit-noon", "terra-afternoon", "prism-dusk", "orbit-night"]),
            (tr("settings.wallpaper.preset.night", "Nocturne"), 3600, ["aurora-dusk", "prism-night", "orbit-midnight", "terra-night", "kente-midnight"]),
            (tr("settings.wallpaper.preset.vivid", "Énergie"), 900, ["aurora-golden", "kente-noon", "orbit-afternoon", "prism-golden", "terra-dusk"]),
        ):
            preset_button = Gtk.Button(label=preset_name)
            preset_button.get_style_context().add_class("wallpaper-filter")
            preset_button.set_tooltip_text(tr("settings.wallpaper.rotation_preset.tooltip", "Préparer une rotation {name}.", name=preset_name))
            preset_button.connect("clicked", lambda _button, label=preset_name, delay=seconds, picks=slugs: set_rotation_preset(label, delay, picks))
            preset_row.pack_start(preset_button, False, False, 0)

        tone_counts: dict[str, int] = {"all": len(items), "light": 0, "balanced": 0, "dark": 0}
        for item in items:
            if isinstance(item, dict):
                tone = str(item.get("tone") or "")
                if tone in tone_counts:
                    tone_counts[tone] += 1

        for tone, label in (
            ("all", tr("settings.all", "Tous")),
            ("light", tr("settings.light_mode", "Mode clair")),
            ("balanced", tr("settings.wallpaper_balanced", "Équilibré")),
            ("dark", tr("settings.dark_mode", "Mode sombre")),
        ):
            filter_button = Gtk.Button(label=f"{label} · {tone_counts.get(tone, 0)}")
            filter_button.get_style_context().add_class("wallpaper-filter")
            filter_button.set_tooltip_text(tr("settings.wallpaper.filter_tone", "Filtrer les fonds par ambiance : {tone}", tone=label))
            filter_button.connect("clicked", lambda _button, item_tone=tone: set_tone_filter(item_tone))
            tone_buttons[tone] = filter_button
            tone_bar.pack_start(filter_button, False, False, 0)

        family_counts: dict[str, int] = {"all": len(items)}
        for item in items:
            if isinstance(item, dict):
                family = str(item.get("family") or "")
                if family:
                    family_counts[family] = family_counts.get(family, 0) + 1

        for family in ["all"] + sorted(key for key in family_counts if key != "all"):
            label = tr("settings.all", "Tous") if family == "all" else family.title()
            filter_button = Gtk.Button(label=f"{label} · {family_counts.get(family, 0)}")
            filter_button.get_style_context().add_class("wallpaper-filter")
            filter_button.set_tooltip_text(tr("settings.wallpaper.filter_family", "Filtrer les fonds par famille : {family}", family=label))
            filter_button.connect("clicked", lambda _button, item_family=family: set_family_filter(item_family))
            family_buttons[family] = filter_button
            family_bar.pack_start(filter_button, False, False, 0)

        tool_row.pack_start(tone_bar, False, False, 0)
        tool_row.pack_start(search_entry, True, True, 0)

        close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
        close_button.get_style_context().add_class("action-button")
        close_button.connect("clicked", lambda _button: dialog.destroy())
        apply_button = Gtk.Button(label=tr("settings.set_wallpaper", "Définir le fond"))
        apply_button.get_style_context().add_class("primary-action")
        apply_button.connect("clicked", apply_selected)
        action_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        action_row.set_halign(Gtk.Align.END)
        action_row.pack_start(close_button, False, False, 0)
        action_row.pack_start(apply_button, False, False, 0)
        scroller.add(grid)
        box.pack_start(hero, False, False, 0)
        box.pack_start(preview_card, False, False, 0)
        box.pack_start(tool_row, False, False, 0)
        box.pack_start(family_bar, False, False, 0)
        box.pack_start(preset_row, False, False, 0)
        box.pack_start(rotation_panel, False, False, 0)
        box.pack_start(scroller, True, True, 0)
        box.pack_end(action_row, False, False, 0)
        set_tone_filter("all")
        set_family_filter("all")
        refresh_rotation_count()

        def wallpaper_dialog_key(_dialog, event) -> bool:
            ctrl = bool(event.state & Gdk.ModifierType.CONTROL_MASK)
            if ctrl and event.keyval in {Gdk.KEY_f, Gdk.KEY_F, Gdk.KEY_l, Gdk.KEY_L, Gdk.KEY_k, Gdk.KEY_K}:
                search_entry.grab_focus()
                search_entry.select_region(0, -1)
                show_feedback(tr("settings.search.ready", "Recherche prête."))
                return True
            if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter} and not search_entry.has_focus():
                apply_selected()
                return True
            return False

        dialog.connect("key-press-event", wallpaper_dialog_key)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def import_fonts_button(label: str) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("action-button")

        def choose(_button) -> None:
            dialog = Gtk.FileChooserDialog(
                title=tr("settings.import_font_files", "Importer des polices"),
                parent=window,
                action=Gtk.FileChooserAction.OPEN,
                buttons=(f"_{tr('settings.cancel', 'Annuler')}", Gtk.ResponseType.CANCEL, f"_{tr('settings.import', 'Importer')}", Gtk.ResponseType.ACCEPT),
            )
            dialog.set_select_multiple(True)
            font_filter = Gtk.FileFilter()
            font_filter.set_name("Fonts")
            for pattern in ("*.ttf", "*.otf", "*.ttc"):
                font_filter.add_pattern(pattern)
            dialog.add_filter(font_filter)
            response = dialog.run()
            filenames = dialog.get_filenames()
            dialog.destroy()
            if response == Gtk.ResponseType.ACCEPT and filenames:
                subprocess.Popen([str(ROOT / "scripts/fonts.sh"), "import", *filenames], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
                notify("SevenOS Fonts", tr_text("Fonts imported and cache refreshed."))

        button.connect("clicked", choose)
        return button

    def setting_card(icon: str, title: str, note: str, buttons: list[Gtk.Button]) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.get_style_context().add_class("settings-card")
        icon_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        icon_box.set_halign(Gtk.Align.CENTER)
        icon_box.set_valign(Gtk.Align.CENTER)
        icon_box.get_style_context().add_class("icon-pill")
        icon_label = Gtk.Label(label=icon)
        icon_box.pack_start(icon_label, True, True, 0)
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        text_box.set_hexpand(True)
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("card-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("card-note")
        text_box.pack_start(title_label, False, False, 0)
        text_box.pack_start(note_label, False, False, 0)
        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_valign(Gtk.Align.CENTER)
        for button in buttons:
            actions.pack_start(button, False, False, 0)
        card.pack_start(icon_box, False, False, 0)
        card.pack_start(text_box, True, True, 0)
        card.pack_start(actions, False, False, 0)
        return card

    def settings_row(icon: str, title: str, note: str, controls: list[Gtk.Widget]) -> Gtk.Box:
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        row.set_can_focus(True)
        row.set_tooltip_text(f"{title}\n{note}")
        row.get_style_context().add_class("settings-row")
        if controls:
            row.get_style_context().add_class("actionable-row")
        glyph = Gtk.Label(label=icon)
        glyph.set_halign(Gtk.Align.CENTER)
        glyph.set_valign(Gtk.Align.CENTER)
        glyph.get_style_context().add_class("settings-row-icon")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        labels.set_hexpand(True)
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.set_ellipsize(Pango.EllipsizeMode.END)
        title_label.set_max_width_chars(42)
        title_label.get_style_context().add_class("settings-row-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.set_max_width_chars(72)
        note_label.get_style_context().add_class("settings-row-note")
        labels.pack_start(title_label, False, False, 0)
        labels.pack_start(note_label, False, False, 0)
        multi_controls = len(controls) > 1
        control_orientation = Gtk.Orientation.VERTICAL if multi_controls else Gtk.Orientation.HORIZONTAL
        control_box = Gtk.Box(orientation=control_orientation, spacing=6)
        control_box.set_halign(Gtk.Align.END)
        control_box.set_valign(Gtk.Align.CENTER)
        control_box.set_size_request(126 if multi_controls else 112, -1)
        control_box.get_style_context().add_class("settings-row-controls")
        if multi_controls:
            control_box.get_style_context().add_class("multi")
        for control in controls:
            control.set_halign(Gtk.Align.FILL if isinstance(control, Gtk.Button) else Gtk.Align.END)
            control.set_valign(Gtk.Align.CENTER)
            if isinstance(control, Gtk.Button):
                control.set_size_request(104 if multi_controls else 92, 28)
            control_box.pack_start(control, False, False, 0)
        if controls:
            row.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
            row.set_tooltip_text(
                f"{title}\n{note}\n"
                + tr("settings.row.action_hint", "Entrée, Espace ou double-clic pour lancer l’action principale.")
            )
        row.pack_start(glyph, False, False, 0)
        row.pack_start(labels, True, True, 0)
        row.pack_start(control_box, False, False, 0)

        def activate_default_control() -> bool:
            for control in controls:
                if isinstance(control, Gtk.Button) and control.get_sensitive():
                    control.clicked()
                    return True
                if isinstance(control, Gtk.Switch) and control.get_sensitive():
                    control.set_active(not control.get_active())
                    return True
            return False

        def key_press(_row, event) -> bool:
            if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter, Gdk.KEY_space):
                return activate_default_control()
            return False

        def button_press(_row, event) -> bool:
            if event.button == 1:
                row.grab_focus()
            if event.button == 1 and event.type == Gdk.EventType.DOUBLE_BUTTON_PRESS:
                return activate_default_control()
            return False

        row.connect("key-press-event", key_press)
        row.connect("button-press-event", button_press)
        return row

    def settings_group(container: Gtk.Box, title: str, rows: list[Gtk.Widget]) -> Gtk.Box:
        group = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        group.set_size_request(content_width, -1)
        group.set_can_focus(True)
        group.get_style_context().add_class("settings-group")
        if title:
            heading = Gtk.Label(label=title.upper())
            heading.set_xalign(0)
            heading.get_style_context().add_class("section-label")
            container.pack_start(heading, False, False, 0)
        for index, row in enumerate(rows):
            if index == len(rows) - 1:
                row.get_style_context().add_class("last-row")
            group.pack_start(row, False, False, 0)
        container.pack_start(group, False, False, 0)
        return group

    def show_package_removal_dialog() -> None:
        dialog = Gtk.Dialog(
            title=tr("settings.package_remove.title", "Supprimer une application"),
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
        )
        dialog.set_default_size(560, 430)
        box = style_dialog(dialog)
        box.set_spacing(12)
        box.set_border_width(16)

        title = Gtk.Label(label=tr("settings.package_remove.title", "Supprimer une application"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label(
            label=tr(
                "settings.package_remove.note",
                "Choisis l’espace SevenOS et le paquet à retirer. SevenOS affiche d’abord l’impact, puis lance la suppression sans ouvrir le terminal.",
            )
        )
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")

        controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        profile_combo = Gtk.ComboBoxText()
        catalog = profile_catalog()
        naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
        profile_order = ["equinox", "baobab", "forge", "shield", "studio", "atlas", "pulse"]
        active_key = active_profile_key()
        active_index = 0
        for index, key in enumerate(profile_order):
            profile_combo.append(key, str(naming.get(key) or key.title()))
            if key == active_key:
                active_index = index
        profile_combo.set_active(active_index)
        profile_combo.set_tooltip_text(tr("settings.package_remove.profile.tooltip", "Choisir l’espace SevenOS où le paquet sera retiré."))

        package_entry = Gtk.Entry()
        package_entry.set_placeholder_text(tr("settings.package_remove.placeholder", "Nom du paquet, ex. htop"))
        package_entry.get_style_context().add_class("settings-entry")
        package_entry.set_hexpand(True)
        package_entry.set_tooltip_text(tr("settings.package_remove.entry.tooltip", "Tape un nom de paquet ou choisis-le dans la liste. Entrée prévisualise."))
        controls.pack_start(profile_combo, False, False, 0)
        controls.pack_start(package_entry, True, True, 0)

        status = Gtk.Label(label=tr("settings.package_remove.ready", "Prêt à prévisualiser."))
        status.set_xalign(0)
        status.get_style_context().add_class("settings-inline-status")

        package_list = Gtk.ListBox()
        package_list.get_style_context().add_class("package-result-list")
        package_list.set_selection_mode(Gtk.SelectionMode.NONE)
        package_list_scroller = Gtk.ScrolledWindow()
        package_list_scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        package_list_scroller.set_min_content_height(96)
        package_list_scroller.get_style_context().add_class("package-result-panel")
        package_list_scroller.add(package_list)

        buffer = Gtk.TextBuffer()
        buffer.set_text(tr("settings.package_remove.output", "Le résultat de la prévisualisation apparaîtra ici."))
        text_view = Gtk.TextView(buffer=buffer)
        text_view.set_editable(False)
        text_view.set_cursor_visible(False)
        text_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.set_min_content_height(150)
        scroller.get_style_context().add_class("command-output")
        scroller.add(text_view)

        button_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        preview_button = Gtk.Button(label=tr("settings.preview", "Prévisualiser"))
        preview_button.get_style_context().add_class("action-button")
        preview_button.set_tooltip_text(tr("settings.package_remove.preview.tooltip", "Afficher l’impact avant suppression."))
        inventory_button = Gtk.Button(label=tr("settings.package_remove.inventory", "Voir les paquets"))
        inventory_button.get_style_context().add_class("action-button")
        inventory_button.set_tooltip_text(tr("settings.package_remove.inventory.tooltip", "Ouvrir la liste complète des paquets de cet espace."))
        remove_button = Gtk.Button(label=tr("settings.delete", "Supprimer"))
        remove_button.get_style_context().add_class("action-button")
        remove_button.get_style_context().add_class("destructive-action")
        remove_button.set_tooltip_text(tr("settings.package_remove.delete.tooltip", "Disponible après une prévisualisation sans blocage."))
        close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
        close_button.get_style_context().add_class("action-button")
        close_button.connect("clicked", lambda _button: dialog.destroy())

        def selected_profile() -> str:
            return profile_combo.get_active_id() or active_key or "equinox"

        def package_name() -> str:
            return package_entry.get_text().strip()

        def validate_package() -> str | None:
            package = package_name()
            if not package:
                status.set_text(tr("settings.package_remove.missing", "Entre le nom du paquet à supprimer."))
                return None
            if not re.match(r"^[A-Za-z0-9@._+-]+$", package):
                status.set_text(tr("settings.package_remove.invalid", "Nom de paquet invalide."))
                return None
            return package

        def clear_package_list() -> None:
            for child in list(package_list.get_children()):
                package_list.remove(child)

        def add_package_result(item: dict) -> None:
            name = str(item.get("name") or "")
            if not name:
                return
            version = str(item.get("version") or "")
            description = str(item.get("description") or "")
            row = Gtk.ListBoxRow()
            button = Gtk.Button()
            button.get_style_context().add_class("package-result-button")
            wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            title_label = Gtk.Label(label=f"{name} {version}".strip())
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("settings-row-title")
            note_label = Gtk.Label(label=description or tr("settings.package_remove.installed", "Installé"))
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.set_max_width_chars(70)
            note_label.get_style_context().add_class("settings-row-note")
            wrapper.pack_start(title_label, False, False, 0)
            wrapper.pack_start(note_label, False, False, 0)
            button.add(wrapper)

            def choose_package(_button: Gtk.Button, package: str = name) -> None:
                package_entry.set_text(package)
                status.set_text(tr("settings.package_remove.selected", "{package} sélectionné.", package=package))
                package_entry.grab_focus()
                package_entry.set_position(-1)
                show_feedback(tr("settings.package_remove.selected", "{package} sélectionné.", package=package))

            button.connect("clicked", choose_package)
            row.set_selectable(True)
            row.set_activatable(True)
            row.set_tooltip_text(tr("settings.package_remove.row.tooltip", "Choisir ce paquet pour le prévisualiser."))
            row.add(button)
            package_list.add(row)

        package_search_generation = {"value": 0}
        package_preview_generation = {"value": 0}
        last_preview: dict[str, object] = {"profile": "", "package": "", "payload": None}
        remove_button.set_sensitive(False)

        def invalidate_preview() -> None:
            last_preview.update({"profile": "", "package": "", "payload": None})
            remove_button.set_sensitive(False)

        def refresh_package_results(*_args) -> None:
            invalidate_preview()
            package_search_generation["value"] += 1
            generation = package_search_generation["value"]
            profile = selected_profile()
            query = package_name()
            command = [str(ROOT / "bin/sevenpkg"), "profile-packages", profile, "--limit", "12", "--json"]
            if query:
                command.extend(["--query", query])
            status.set_text(tr("settings.package_remove.searching", "Recherche des paquets installés…"))

            def apply_results(payload: dict, expected_generation: int) -> bool:
                if expected_generation != package_search_generation["value"]:
                    return False
                clear_package_list()
                profiles = payload.get("profiles") if isinstance(payload, dict) else []
                packages = []
                if profiles and isinstance(profiles[0], dict):
                    packages = profiles[0].get("packages") or []
                for item in packages[:12]:
                    if isinstance(item, dict):
                        add_package_result(item)
                if not packages:
                    row = Gtk.ListBoxRow()
                    label = Gtk.Label(label=tr("settings.package_remove.no_results", "Aucun paquet trouvé dans cet espace."))
                    label.set_xalign(0)
                    label.get_style_context().add_class("settings-row-note")
                    row.add(label)
                    package_list.add(row)
                package_list.show_all()
                status.set_text(tr("settings.package_remove.ready", "Prêt à prévisualiser."))
                return False

            def worker() -> None:
                payload = run_json_timeout(command, {}, timeout=2.5)
                GLib.idle_add(apply_results, payload, generation)

            threading.Thread(target=worker, daemon=True).start()

        def removal_preview_text(payload: dict) -> str:
            lines = [
                tr("settings.package_remove.preview_title", "Prévisualisation SevenOS"),
                "",
                f"{tr('settings.profile', 'Profil')}: {payload.get('profile', selected_profile())}",
                f"{tr('settings.scope', 'Portée')}: {payload.get('profile_scope', payload.get('impact', ''))}",
                f"{tr('settings.rootfs', 'RootFS')}: {payload.get('rootfs', '')}",
            ]
            blockers = payload.get("blockers") or []
            warnings = payload.get("warnings") or []
            commands = payload.get("commands") or []
            if blockers:
                lines.extend(["", tr("settings.blocked", "Blocage:")])
                lines.extend(f"- {item}" for item in blockers)
            if warnings:
                lines.extend(["", tr("settings.warnings", "Avertissements:")])
                lines.extend(f"- {item}" for item in warnings)
            if commands:
                lines.extend(["", tr("settings.package_remove.commands", "Ce que SevenOS lancera:")])
                for command in commands:
                    lines.append("  " + " ".join(str(part) for part in command))
            else:
                lines.append("")
                lines.append(tr("settings.package_remove.no_command", "Aucune commande ne sera lancée tant que le blocage n’est pas corrigé."))
            return "\n".join(lines)

        def preview_remove(_button: Gtk.Button) -> None:
            package = validate_package()
            if not package:
                return
            profile = selected_profile()
            package_preview_generation["value"] += 1
            generation = package_preview_generation["value"]
            preview_button.set_sensitive(False)
            remove_button.set_sensitive(False)
            status.set_text(tr("settings.package_remove.preview_running", "Prévisualisation en cours…"))

            def apply_preview(payload: dict, expected_generation: int) -> bool:
                if expected_generation != package_preview_generation["value"]:
                    return False
                preview_button.set_sensitive(True)
                if payload:
                    blockers = payload.get("blockers") or []
                    last_preview.update({"profile": profile, "package": package, "payload": payload})
                    remove_button.set_sensitive(not bool(blockers))
                    status.set_text(
                        tr("settings.package_remove.preview_blocked", "Suppression bloquée.") if blockers
                        else tr("settings.package_remove.preview_ready", "Prévisualisation prête.")
                    )
                    buffer.set_text(removal_preview_text(payload))
                else:
                    last_preview.update({"profile": "", "package": "", "payload": None})
                    remove_button.set_sensitive(False)
                    status.set_text(tr("settings.package_remove.preview_failed", "Prévisualisation indisponible."))
                    buffer.set_text("")
                return False

            def worker() -> None:
                payload = run_json_timeout(
                    [str(ROOT / "bin/sevenpkg"), "remove", "--profile", profile, package, "--preview", "--json"],
                    {},
                    timeout=3.0,
                )
                GLib.idle_add(apply_preview, payload, generation)

            threading.Thread(target=worker, daemon=True).start()

        def show_inventory(_button: Gtk.Button) -> None:
            profile = selected_profile()
            query = package_name()
            query_flag = f" --query {shlex.quote(query)}" if query else ""
            show_command_output(f"{shlex.quote(str(ROOT / 'bin/sevenpkg'))} profile-packages {shlex.quote(profile)}{query_flag} --limit 80", tr("settings.package_remove.inventory", "Voir les paquets"))

        def run_remove(_button: Gtk.Button) -> None:
            package = validate_package()
            if not package:
                return
            profile = selected_profile()
            payload = last_preview.get("payload")
            if (
                not isinstance(payload, dict)
                or last_preview.get("profile") != profile
                or last_preview.get("package") != package
                or payload.get("blockers")
            ):
                status.set_text(tr("settings.package_remove.preview_required", "Prévisualise ce paquet avant de le supprimer."))
                remove_button.set_sensitive(False)
                return
            confirm = Gtk.Dialog(
                title=tr("settings.package_remove.confirm", "Supprimer {package} ?", package=package),
                transient_for=dialog,
                flags=Gtk.DialogFlags.MODAL,
            )
            confirm.set_default_size(430, 230)
            confirm_box = style_dialog(confirm)
            confirm_box.set_spacing(12)
            confirm_box.set_border_width(18)
            confirm_title = Gtk.Label(label=tr("settings.package_remove.confirm", "Supprimer {package} ?", package=package))
            confirm_title.set_xalign(0)
            confirm_title.get_style_context().add_class("hero-title")
            confirm_note = Gtk.Label(
                label=tr(
                    "settings.package_remove.confirm_note",
                    "SevenOS retirera ce paquet de {profile}. L’opération sera suivie dans une fenêtre graphique.",
                    profile=profile,
                )
            )
            confirm_note.set_xalign(0)
            confirm_note.set_line_wrap(True)
            confirm_note.get_style_context().add_class("hero-note")
            confirm_hint = Gtk.Label(label=tr("settings.package_remove.confirm_hint", "La suppression ne démarre qu’après cette confirmation."))
            confirm_hint.set_xalign(0)
            confirm_hint.get_style_context().add_class("settings-inline-status")
            confirm_actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            confirm_actions.set_halign(Gtk.Align.END)
            cancel_button = Gtk.Button(label=tr("settings.cancel", "Annuler"))
            cancel_button.get_style_context().add_class("action-button")
            cancel_button.connect("clicked", lambda _button: confirm.response(Gtk.ResponseType.CANCEL))
            delete_button = Gtk.Button(label=tr("settings.delete", "Supprimer"))
            delete_button.get_style_context().add_class("action-button")
            delete_button.get_style_context().add_class("destructive-action")
            delete_button.connect("clicked", lambda _button: confirm.response(Gtk.ResponseType.ACCEPT))
            confirm_actions.pack_start(cancel_button, False, False, 0)
            confirm_actions.pack_start(delete_button, False, False, 0)
            confirm_box.pack_start(confirm_title, False, False, 0)
            confirm_box.pack_start(confirm_note, False, False, 0)
            confirm_box.pack_start(confirm_hint, False, False, 0)
            confirm_box.pack_end(confirm_actions, False, False, 0)
            confirm.connect("response", lambda _dialog, _response: confirm.hide())
            confirm.show_all()
            response = confirm.run()
            confirm.destroy()
            if response != Gtk.ResponseType.ACCEPT:
                status.set_text(tr("settings.package_remove.cancelled", "Suppression annulée."))
                return
            command = f"{shlex.quote(str(ROOT / 'bin/sevenpkg'))} remove --profile {shlex.quote(profile)} {shlex.quote(package)}"
            dialog.destroy()
            show_command_output(command, tr("settings.package_remove.title", "Supprimer une application"))

        preview_button.connect("clicked", preview_remove)
        inventory_button.connect("clicked", show_inventory)
        remove_button.connect("clicked", run_remove)
        close_button.connect("clicked", lambda _button: dialog.destroy())
        package_entry.connect("activate", lambda _entry: preview_remove(preview_button))
        package_entry.connect("changed", refresh_package_results)
        profile_combo.connect("changed", refresh_package_results)

        def package_row_activated(_list_box, row) -> None:
            child = row.get_child()
            if isinstance(child, Gtk.Button):
                child.clicked()
                preview_remove(preview_button)

        package_list.connect("row-activated", package_row_activated)

        def package_remove_key(_dialog, event) -> bool:
            ctrl = bool(event.state & Gdk.ModifierType.CONTROL_MASK)
            if ctrl and event.keyval in {Gdk.KEY_i, Gdk.KEY_I}:
                show_inventory(inventory_button)
                return True
            if ctrl and event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter} and remove_button.get_sensitive():
                run_remove(remove_button)
                return True
            return False

        dialog.connect("key-press-event", package_remove_key)
        button_row.pack_start(preview_button, False, False, 0)
        button_row.pack_start(inventory_button, False, False, 0)
        button_row.pack_start(remove_button, False, False, 0)
        button_row.pack_start(close_button, False, False, 0)

        box.pack_start(title, False, False, 0)
        box.pack_start(note, False, False, 0)
        box.pack_start(controls, False, False, 0)
        box.pack_start(package_list_scroller, False, False, 0)
        box.pack_start(status, False, False, 0)
        box.pack_start(scroller, True, True, 0)
        box.pack_start(button_row, False, False, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()
        refresh_package_results()

    def general_jump_strip(targets: dict[str, Gtk.Widget]) -> Gtk.Box:
        strip = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        strip.set_size_request(content_width, -1)
        strip.get_style_context().add_class("quick-strip")
        strip.get_style_context().add_class("settings-jump-strip")
        entries = [
            ("󰐃", tr("settings.jump.usage", "Mode"), "usage"),
            ("󰮍", tr("settings.jump.mini_os", "Mini OS"), "mini-os"),
            ("󰩂", tr("settings.jump.maintenance", "Entretien"), "maintenance"),
            ("◈", tr("settings.jump.prism", "Prism"), "prism"),
            ("󰆴", tr("settings.jump.removal", "Suppression"), "removal"),
            ("󰙅", tr("settings.jump.atlas", "Atlas"), "atlas"),
            ("󰁯", tr("settings.jump.backup", "Backup"), "backup"),
            ("󰜉", tr("settings.jump.motion", "Animations"), "motion"),
        ]

        def jump_to(_button: Gtk.Button, key: str, label: str) -> None:
            target = targets.get(key)
            if target is None:
                show_feedback(tr("settings.general_jump_pending", "{section} sera prêt dans un instant.", section=label))
                return
            target.grab_focus()
            scrolled = pages.get("general", (None, None))[1]
            if scrolled is not None:
                def scroll_to_target() -> bool:
                    adjustment = scrolled.get_vadjustment()
                    allocation = target.get_allocation()
                    target_y = max(0, allocation.y - 12)
                    upper = max(adjustment.get_lower(), adjustment.get_upper() - adjustment.get_page_size())
                    adjustment.set_value(min(target_y, upper))
                    return False

                GLib.idle_add(scroll_to_target)
            show_feedback(tr("settings.general_jump", "Section ouverte : {section}", section=label))

        for icon, label, key in entries:
            button = Gtk.Button(label=f"{icon} {label}")
            button.set_tooltip_text(tr("settings.general_jump_tooltip", "Aller à {section}", section=label))
            button.get_style_context().add_class("action-button")
            button.get_style_context().add_class("jump-button")
            button.connect("clicked", jump_to, key, label)
            strip.pack_start(button, False, False, 0)
        return strip

    def run_prism_setting(command: str, message: str) -> None:
        def work() -> None:
            subprocess.run(
                ["bash", "-lc", command],
                cwd=ROOT,
                env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
                timeout=4.0,
            )
            GLib.idle_add(lambda: (show_feedback(message), False)[1])

        threading.Thread(target=work, daemon=True).start()

    def prism_settings_group(container: Gtk.Box) -> Gtk.Box:
        state = smart_window_state()
        overlay = state.get("overlay", {}) if isinstance(state.get("overlay"), dict) else {}
        traffic = state.get("traffic_lights", {}) if isinstance(state.get("traffic_lights"), dict) else {}
        service = smart_window_service_state()
        effect = str(overlay.get("effect") or "on")
        mode = str(state.get("mode") or "smart")
        placement = str(overlay.get("placement") or "adaptive-active-window-top-left-or-manual")
        native = bool(overlay.get("native"))
        hypr = bool(state.get("hyprland"))
        service_label = {
            "active": tr("settings.prism.active", "actif"),
            "inactive": tr("settings.prism.inactive", "inactif"),
            "failed": tr("settings.prism.failed", "en erreur"),
            "unknown": tr("settings.unknown", "inconnu"),
        }.get(service, service)
        effect_label = tr("settings.enabled", "Activé") if effect == "on" else tr("settings.disabled", "Désactivé")
        native_label = tr("settings.ready", "Prêt") if native else tr("settings.unavailable", "Indisponible")
        hypr_label = "Hyprland OK" if hypr else tr("settings.unavailable", "Indisponible")
        item_payload = overlay.get("items", {}) if isinstance(overlay.get("items"), dict) else {}
        prism_items = item_payload.get("items") if isinstance(item_payload.get("items"), list) else []
        item_keys = {str(item.get("key") or "") for item in prism_items if isinstance(item, dict)}
        item_count = int(item_payload.get("count") or len(prism_items))
        item_max = int(item_payload.get("max_items") or 7)
        presets = [
            ("settings", "◈", tr("settings.prism.item.settings", "Paramètres"), "#6EA8FF", "seven-settings prism"),
            ("accessibility", "⌁", tr("settings.prism.item.accessibility", "Accessibilité"), "#33D6A6", "seven-settings general"),
            ("apps", "▦", tr("settings.prism.item.apps", "Apps"), "#A78BFA", "seven-overview apps"),
            ("terminal", "⌘", "Terminal", "#F472B6", "seven-terminal"),
            ("files", "▣", tr("settings.files", "Fichiers"), "#38BDF8", "seven-files"),
            ("help", "?", tr("settings.help", "Aide"), "#FBBF24", "seven-help-native"),
            ("launchpad", "✦", "Launchpad", "#FB7185", "seven-overview apps"),
        ]
        preset_map = {
            key: {"key": key, "icon": icon, "label": label, "label_en": label, "accent": accent, "command": command}
            for key, icon, label, accent, command in presets
        }
        for item in prism_items:
            if not isinstance(item, dict):
                continue
            key = str(item.get("key") or "").strip()
            if not key or key in preset_map:
                continue
            preset_map[key] = {
                "key": key,
                "icon": str(item.get("icon") or "•")[:2],
                "label": str(item.get("label") or key),
                "label_en": str(item.get("label_en") or item.get("label") or key),
                "accent": str(item.get("accent") or "#6EA8FF"),
                "command": str(item.get("command") or ""),
                "custom": True,
            }

        def color_from_hex(value: str) -> tuple[float, float, float]:
            raw = str(value or "#6EA8FF").strip().lstrip("#")
            if len(raw) == 3:
                raw = "".join(ch * 2 for ch in raw)
            try:
                return (int(raw[0:2], 16) / 255.0, int(raw[2:4], 16) / 255.0, int(raw[4:6], 16) / 255.0)
            except Exception:
                return (0.43, 0.66, 1.0)

        def prism_preview(items: list[dict], title: str, note: str) -> Gtk.Box:
            import cairo
            import math

            preview = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            preview.get_style_context().add_class("prism-preview-card")
            canvas = Gtk.DrawingArea()
            canvas.set_size_request(190, 92)
            text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
            text.set_valign(Gtk.Align.CENTER)
            title_label = Gtk.Label(label=title)
            title_label.set_xalign(0)
            title_label.get_style_context().add_class("prism-preview-title")
            note_label = Gtk.Label(label=note)
            note_label.set_xalign(0)
            note_label.set_line_wrap(True)
            note_label.get_style_context().add_class("prism-preview-note")
            text.pack_start(title_label, False, False, 0)
            text.pack_start(note_label, False, False, 0)

            def draw(widget, cr) -> bool:
                allocation = widget.get_allocation()
                width = allocation.width
                height = allocation.height
                cx = width / 2
                cy = height / 2
                rx = width * 0.34
                ry = height * 0.32
                active_count = min(len(items), 7)
                points = [
                    (
                        cx + math.cos(-math.pi / 2 + index * 2 * math.pi / 7) * rx,
                        cy + math.sin(-math.pi / 2 + index * 2 * math.pi / 7) * ry,
                    )
                    for index in range(7)
                ]
                cr.save()
                glow = cairo.RadialGradient(cx, cy, 2, cx, cy, width * 0.46)
                glow.add_color_stop_rgba(0, 0.43, 0.66, 1.0, 0.18)
                glow.add_color_stop_rgba(1, 0, 0, 0, 0)
                cr.set_source(glow)
                cr.arc(cx, cy, width * 0.46, 0, 6.28318)
                cr.fill()
                cr.set_source_rgba(1, 1, 1, 0.16)
                cr.set_line_width(1.0)
                cr.move_to(*points[0])
                for point in points[1:]:
                    cr.line_to(*point)
                cr.close_path()
                cr.stroke()
                for index, point in enumerate(points):
                    active = index < active_count
                    color = color_from_hex(str(items[index].get("accent") or "#6EA8FF")) if active else (0.43, 0.66, 1.0)
                    cr.set_line_width(1.2 if active else 0.7)
                    cr.set_source_rgba(color[0], color[1], color[2], 0.52 if active else 0.10)
                    cr.move_to(cx, cy)
                    cr.line_to(*point)
                    cr.stroke()
                cr.set_source_rgba(1, 1, 1, 0.76)
                cr.arc(cx, cy, 3.0, 0, 6.28318)
                cr.fill()
                cr.select_font_face("Sans", cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_BOLD)
                cr.set_font_size(9.0)
                for index, (px, py) in enumerate(points):
                    active = index < active_count
                    color = color_from_hex(str(items[index].get("accent") or "#6EA8FF")) if active else (0.43, 0.66, 1.0)
                    radius = 10.5 if active else 4.0
                    cr.set_source_rgba(color[0], color[1], color[2], 0.25 if active else 0.06)
                    cr.arc(px, py, radius + 4, 0, 6.28318)
                    cr.fill()
                    cr.set_source_rgba(0.03, 0.04, 0.08, 0.70 if active else 0.28)
                    cr.arc(px, py, radius, 0, 6.28318)
                    cr.fill_preserve()
                    cr.set_source_rgba(color[0], color[1], color[2], 0.88 if active else 0.22)
                    cr.set_line_width(1.0)
                    cr.stroke()
                    if active:
                        icon = str(items[index].get("icon") or "•")[:2]
                        xb, yb, tw, th, _xa, _ya = cr.text_extents(icon)
                        cr.set_source_rgba(1, 1, 1, 0.82)
                        cr.move_to(px - tw / 2 - xb, py - th / 2 - yb)
                        cr.show_text(icon)
                cr.restore()
                return True

            canvas.connect("draw", draw)
            preview.pack_start(canvas, False, False, 0)
            preview.pack_start(text, True, True, 0)
            preview.queue_prism_draw = canvas.queue_draw  # type: ignore[attr-defined]
            return preview

        on_button = callback_button(
            tr("settings.enable", "Activer"),
            "seven-window controls-effect on",
            lambda: run_prism_setting(
                "seven-window controls-effect on",
                tr("settings.prism.effect_enabled", "Effet électrique du Prism activé."),
            ),
        )
        off_button = callback_button(
            tr("settings.disable", "Désactiver"),
            "seven-window controls-effect off",
            lambda: run_prism_setting(
                "seven-window controls-effect off",
                tr("settings.prism.effect_disabled", "Effet électrique du Prism désactivé."),
            ),
        )
        start_service = callback_button(
            tr("settings.enable", "Activer"),
            "seven-window controls-start",
            lambda: run_prism_setting(
                "seven-window controls-start",
                tr("settings.prism.service_enabled", "Prism SevenDecor activé."),
            ),
        )
        stop_service = callback_button(
            tr("settings.disable", "Désactiver"),
            "seven-window controls-stop",
            lambda: run_prism_setting(
                "seven-window controls-stop",
                tr("settings.prism.service_disabled", "Prism SevenDecor désactivé."),
            ),
        )
        reset_button = callback_button(
            tr("settings.reset", "Réinitialiser"),
            "seven-window controls-reset-hidden && seven-window controls-unlock",
            lambda: run_prism_setting(
                "seven-window controls-reset-hidden && seven-window controls-unlock",
                tr("settings.prism.reset_done", "Cible, masquages et position Prism réinitialisés."),
            ),
        )
        clear_items = callback_button(
            tr("settings.clear", "Effacer"),
            "seven-window controls-item clear",
            lambda: run_prism_setting(
                "seven-window controls-item clear",
                tr("settings.prism.items_cleared", "Éléments Prism effacés."),
            ),
        )
        daily_items = callback_button(
            tr("settings.prism.preset.daily", "Quotidien"),
            "seven-window controls-item set daily",
            lambda: run_prism_setting(
                "seven-window controls-item set daily",
                tr("settings.prism.preset_applied", "Preset Prism appliqué."),
            ),
        )
        dev_items = callback_button(
            tr("settings.prism.preset.dev", "Dev"),
            "seven-window controls-item set dev",
            lambda: run_prism_setting(
                "seven-window controls-item set dev",
                tr("settings.prism.preset_applied", "Preset Prism appliqué."),
            ),
        )
        clean_items = callback_button(
            tr("settings.prism.preset.clean", "Compact"),
            "seven-window controls-item set clean",
            lambda: run_prism_setting(
                "seven-window controls-item set clean",
                tr("settings.prism.preset_applied", "Preset Prism appliqué."),
            ),
        )
        manage_items = callback_button(
            tr("settings.manage", "Gérer"),
            "seven-window controls-items",
            lambda: show_prism_items_dialog(presets, item_keys, item_max),
        )

        def show_prism_items_dialog(preset_rows: list[tuple[str, str, str, str, str]], active_keys: set[str], max_items: int) -> None:
            current_order = [str(item.get("key") or "") for item in prism_items if isinstance(item, dict)]
            selected_order = [key for key in current_order if key in preset_map]
            for key in preset_map:
                if key in active_keys and key not in selected_order:
                    selected_order.append(key)
            selected = set(selected_order)
            dialog = Gtk.Dialog(title=tr("settings.prism.items", "Éléments ajoutés"), transient_for=window, modal=True)
            box = style_dialog(dialog)
            title = Gtk.Label(label=tr("settings.prism.items", "Éléments ajoutés"))
            title.set_xalign(0)
            title.get_style_context().add_class("dialog-title")
            note = Gtk.Label(label=tr(
                "settings.prism.items_picker.note",
                "Choisis jusqu’à {max} éléments. Ils deviennent des sommets cliquables autour du centre du Prism.",
                max=max_items,
            ))
            note.set_xalign(0)
            note.set_line_wrap(True)
            note.get_style_context().add_class("dialog-note")
            count_label = Gtk.Label()
            count_label.set_xalign(0)
            count_label.get_style_context().add_class("card-note")
            selected_preview_items = [preset_map[key] for key in selected_order if key in preset_map]
            preview = prism_preview(
                selected_preview_items,
                tr("settings.prism.preview.dialog", "Forme actuelle"),
                tr(
                    "settings.prism.preview.dialog.note",
                    "Chaque choix remplit un sommet. Le Prism garde au maximum sept accès rapides.",
                ),
            )
            grid = Gtk.Grid(column_spacing=10, row_spacing=10)
            grid.get_style_context().add_class("settings-grid")
            order_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
            recipes = {
                "daily": ["settings", "terminal", "files", "apps", "help"],
                "dev": ["terminal", "files", "apps", "settings", "help", "accessibility", "launchpad"],
                "clean": ["settings", "terminal", "files"],
            }
            preset_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

            def update_count() -> None:
                count_label.set_text(tr("settings.prism.items_count", "{count}/{max} sommets utilisés", count=len(selected), max=max_items))
                selected_preview_items[:] = [preset_map[key] for key in selected_order if key in preset_map]
                if hasattr(preview, "queue_prism_draw"):
                    preview.queue_prism_draw()  # type: ignore[attr-defined]

            def rebuild_order() -> None:
                for child in list(order_box.get_children()):
                    order_box.remove(child)
                if not selected_order:
                    empty = Gtk.Label(label=tr("settings.prism.order.empty", "Aucun sommet ajouté."))
                    empty.set_xalign(0)
                    empty.get_style_context().add_class("prism-preview-note")
                    order_box.pack_start(empty, False, False, 0)
                for index, key in enumerate(selected_order[:max_items]):
                    item = preset_map.get(key, {})
                    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
                    row.get_style_context().add_class("prism-order-row")
                    badge = Gtk.Label(label=str(index + 1))
                    badge.set_halign(Gtk.Align.CENTER)
                    badge.set_valign(Gtk.Align.CENTER)
                    badge.get_style_context().add_class("prism-order-index")
                    labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
                    labels.set_hexpand(True)
                    label = Gtk.Label(label=f"{item.get('icon', '•')} {item.get('label', key)}")
                    label.set_xalign(0)
                    label.get_style_context().add_class("prism-order-label")
                    command_label = Gtk.Label(label=str(item.get("command") or tr("settings.prism.command_missing", "Commande non définie")))
                    command_label.set_xalign(0)
                    command_label.set_ellipsize(Pango.EllipsizeMode.END)
                    command_label.get_style_context().add_class("prism-order-command")
                    labels.pack_start(label, False, False, 0)
                    labels.pack_start(command_label, False, False, 0)
                    test = Gtk.Button(label="▶")
                    test.get_style_context().add_class("action-button")
                    test.set_tooltip_text(tr("settings.prism.test", "Tester ce sommet"))
                    test.set_sensitive(bool(str(item.get("command") or "").strip()))
                    up = Gtk.Button(label="↑")
                    up.get_style_context().add_class("action-button")
                    up.set_sensitive(index > 0)
                    down = Gtk.Button(label="↓")
                    down.get_style_context().add_class("action-button")
                    down.set_sensitive(index < len(selected_order) - 1)
                    remove = Gtk.Button(label="×")
                    remove.get_style_context().add_class("action-button")
                    row.pack_start(badge, False, False, 0)
                    row.pack_start(labels, True, True, 0)
                    row.pack_start(test, False, False, 0)
                    row.pack_start(up, False, False, 0)
                    row.pack_start(down, False, False, 0)
                    row.pack_start(remove, False, False, 0)
                    order_box.pack_start(row, False, False, 0)
                    test.connect("clicked", lambda _button, item_key=key: test_local(item_key))
                    up.connect("clicked", lambda _button, item_key=key: move_local(item_key, "up"))
                    down.connect("clicked", lambda _button, item_key=key: move_local(item_key, "down"))
                    remove.connect("clicked", lambda _button, item_key=key: remove_local(item_key))
                order_box.show_all()

            def refresh_all_buttons() -> None:
                for item_key, (button, item_label) in buttons.items():
                    set_button_state(button, item_key, item_label)
                update_count()
                rebuild_order()

            def set_button_state(button: Gtk.Button, key: str, label: str) -> None:
                active = key in selected
                button.set_label(("✓ " if active else "＋ ") + label)
                if active:
                    button.get_style_context().add_class("selected")
                else:
                    button.get_style_context().remove_class("selected")

            buttons: dict[str, tuple[Gtk.Button, str]] = {}

            def toggle_item(key: str, label: str) -> None:
                if key in selected:
                    selected.remove(key)
                    if key in selected_order:
                        selected_order.remove(key)
                    command = f"seven-window controls-item remove {key}"
                    message = tr("settings.prism.item_removed", "Élément retiré du Prism : {item}", item=label)
                else:
                    if len(selected) >= max_items:
                        show_feedback(tr("settings.prism.items_full", "Prism complet"))
                        return
                    selected.add(key)
                    selected_order.append(key)
                    command = f"seven-window controls-item add {key}"
                    message = tr("settings.prism.item_added", "Élément ajouté au Prism : {item}", item=label)
                run_prism_setting(command, message)
                refresh_all_buttons()

            def apply_recipe(recipe: str, label: str) -> None:
                selected.clear()
                selected_order[:] = recipes.get(recipe, [])[:max_items]
                selected.update(selected_order)
                run_prism_setting(
                    f"seven-window controls-item set {recipe}",
                    tr("settings.prism.preset_named", "Preset appliqué : {name}", name=label),
                )
                refresh_all_buttons()
                show_feedback(tr("settings.prism.recipe_ready", "Prism ajusté : {name}", name=label), "success")

            def move_local(key: str, direction: str) -> None:
                if key not in selected_order:
                    return
                index = selected_order.index(key)
                if direction == "up" and index > 0:
                    selected_order[index - 1], selected_order[index] = selected_order[index], selected_order[index - 1]
                elif direction == "down" and index < len(selected_order) - 1:
                    selected_order[index + 1], selected_order[index] = selected_order[index], selected_order[index + 1]
                else:
                    return
                run_prism_setting(
                    f"seven-window controls-item move {key} {direction}",
                    tr("settings.prism.order_changed", "Ordre du Prism mis à jour."),
                )
                refresh_all_buttons()

            def test_local(key: str) -> None:
                item = preset_map.get(key, {})
                command = str(item.get("command") or "").strip()
                if not command:
                    show_feedback(tr("settings.prism.command_missing", "Commande non définie"))
                    return
                run_detached(command)
                show_feedback(tr("settings.prism.test_started", "Test lancé : {item}", item=str(item.get("label") or key)))

            def remove_local(key: str) -> None:
                if key in selected:
                    selected.remove(key)
                if key in selected_order:
                    selected_order.remove(key)
                label = str(preset_map.get(key, {}).get("label") or key)
                run_prism_setting(
                    f"seven-window controls-item remove {shlex.quote(key)}",
                    tr("settings.prism.item_removed", "Élément retiré du Prism : {item}", item=label),
                )
                refresh_all_buttons()

            for recipe, label in (
                ("daily", tr("settings.prism.preset.daily", "Quotidien")),
                ("dev", tr("settings.prism.preset.dev", "Dev")),
                ("clean", tr("settings.prism.preset.clean", "Compact")),
            ):
                preset_button = Gtk.Button(label=label)
                preset_button.get_style_context().add_class("action-button")
                preset_button.set_tooltip_text(tr("settings.prism.preset.tooltip", "Remplir le Prism avec une sélection cohérente."))
                preset_button.connect("clicked", lambda _button, item_recipe=recipe, item_label=label: apply_recipe(item_recipe, item_label))
                preset_bar.pack_start(preset_button, False, False, 0)

            def custom_key(label: str) -> str:
                return re.sub(r"[^a-zA-Z0-9_.-]+", "-", label.strip().lower()).strip("-")[:32]

            def show_custom_item_dialog() -> None:
                if len(selected) >= max_items:
                    show_feedback(tr("settings.prism.items_full", "Prism complet"))
                    return
                custom = Gtk.Dialog(title=tr("settings.prism.custom", "Action personnalisée"), transient_for=dialog, modal=True)
                custom_box = style_dialog(custom)
                custom_title = Gtk.Label(label=tr("settings.prism.custom", "Action personnalisée"))
                custom_title.set_xalign(0)
                custom_title.get_style_context().add_class("dialog-title")
                custom_note = Gtk.Label(label=tr(
                    "settings.prism.custom.note",
                    "Ajoute un accès rapide vers une application, une commande ou une surface SevenOS.",
                ))
                custom_note.set_xalign(0)
                custom_note.set_line_wrap(True)
                custom_note.get_style_context().add_class("dialog-note")
                label_entry = Gtk.Entry()
                label_entry.set_placeholder_text(tr("settings.prism.custom.label", "Nom affiché"))
                label_entry.set_tooltip_text(tr("settings.prism.custom.label.tooltip", "Nom court affiché sur le sommet du Prism."))
                icon_entry = Gtk.Entry()
                icon_entry.set_placeholder_text(tr("settings.prism.custom.icon", "Icône courte"))
                icon_entry.set_tooltip_text(tr("settings.prism.custom.icon.tooltip", "Un symbole ou deux lettres maximum."))
                command_entry = Gtk.Entry()
                command_entry.set_placeholder_text(tr("settings.prism.custom.command", "Commande, ex: firefox"))
                command_entry.set_tooltip_text(tr("settings.prism.custom.command.tooltip", "Commande lancée quand ce sommet est cliqué."))
                accent_entry = Gtk.Entry()
                accent_entry.set_placeholder_text("#6EA8FF")
                accent_entry.set_text("#6EA8FF")
                accent_entry.set_tooltip_text(tr("settings.prism.custom.accent.tooltip", "Couleur du sommet, au format hexadécimal."))
                status = Gtk.Label()
                status.set_xalign(0)
                status.get_style_context().add_class("prism-preview-note")
                suggestion_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=7)
                suggestion_row.set_tooltip_text(tr("settings.prism.custom.suggestions", "Suggestions rapides"))
                swatch_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=7)
                add_button = Gtk.Button(label=tr("settings.add", "Ajouter"))
                add_button.get_style_context().add_class("action-button")
                cancel_button = Gtk.Button(label=tr("settings.cancel", "Annuler"))
                cancel_button.get_style_context().add_class("action-button")
                test_button = Gtk.Button(label=tr("settings.prism.custom.check", "Vérifier"))
                test_button.get_style_context().add_class("action-button")
                buttons_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
                buttons_row.pack_start(cancel_button, False, False, 0)
                buttons_row.pack_start(test_button, False, False, 0)
                buttons_row.pack_start(add_button, False, False, 0)

                def command_status_text(command: str) -> tuple[bool, str]:
                    command = command.strip()
                    if not command:
                        return False, tr("settings.prism.custom.command_missing", "Commande requise.")
                    try:
                        parts = shlex.split(command)
                    except ValueError:
                        return True, tr("settings.prism.custom.shell_command", "Commande shell acceptée; elle sera lancée telle quelle.")
                    if not parts:
                        return False, tr("settings.prism.custom.command_missing", "Commande requise.")
                    executable = parts[0]
                    if "/" in executable:
                        exists = Path(executable).exists()
                    else:
                        exists = shutil.which(executable) is not None
                    if exists:
                        return True, tr("settings.prism.custom.command_ok", "Commande trouvée.")
                    if any(token in command for token in (" ", "&&", "|", ";")):
                        return True, tr("settings.prism.custom.command_warn", "Commande non trouvée directement; lancement via shell.")
                    return False, tr("settings.prism.custom.command_unknown", "Commande introuvable.")

                def refresh_custom_status(*_args) -> None:
                    label = label_entry.get_text().strip()
                    command = command_entry.get_text().strip()
                    key = custom_key(label)
                    ok, message = command_status_text(command)
                    if key and key in selected:
                        message = tr("settings.prism.custom.exists", "Cet élément existe déjà.")
                        ok = False
                    add_button.set_sensitive(bool(key and label and command and ok and len(selected) < max_items))
                    status.set_text(message if command else tr("settings.prism.custom.ready", "Renseigne un nom et une commande."))

                def apply_suggestion(label: str, icon: str, command: str, accent: str) -> None:
                    label_entry.set_text(label)
                    icon_entry.set_text(icon)
                    command_entry.set_text(command)
                    accent_entry.set_text(accent)
                    command_entry.grab_focus()
                    command_entry.select_region(0, -1)
                    refresh_custom_status()

                for label, icon, command, accent in (
                    ("Navigateur", "B", "xdg-open https://", "#6EA8FF"),
                    ("Terminal", "⌘", "seven-terminal", "#F472B6"),
                    ("Fichiers", "▣", "seven-files", "#38BDF8"),
                    ("Store", "▦", "seven store open", "#A78BFA"),
                    ("Aide", "?", "seven-help-native", "#FBBF24"),
                ):
                    suggestion = Gtk.Button(label=f"{icon} {label}")
                    suggestion.get_style_context().add_class("prism-suggestion")
                    suggestion.connect("clicked", lambda _button, l=label, i=icon, c=command, a=accent: apply_suggestion(l, i, c, a))
                    suggestion_row.pack_start(suggestion, False, False, 0)

                for accent in ("#6EA8FF", "#33D6A6", "#A78BFA", "#F472B6", "#38BDF8", "#FBBF24", "#FB7185"):
                    swatch = Gtk.Button(label="●")
                    swatch.get_style_context().add_class("prism-swatch")
                    swatch.set_tooltip_text(accent)
                    swatch.connect("clicked", lambda _button, value=accent: (accent_entry.set_text(value), refresh_custom_status()))
                    swatch_row.pack_start(swatch, False, False, 0)

                def add_custom(_button: Gtk.Button) -> None:
                    label = label_entry.get_text().strip()
                    command = command_entry.get_text().strip()
                    icon = (icon_entry.get_text().strip() or "•")[:2]
                    accent = accent_entry.get_text().strip() or "#6EA8FF"
                    key = custom_key(label)
                    ok, message = command_status_text(command)
                    if not key or not label or not command:
                        status.set_text(tr("settings.prism.custom.invalid", "Nom et commande sont requis."))
                        return
                    if not ok:
                        status.set_text(message)
                        return
                    if key in selected:
                        status.set_text(tr("settings.prism.custom.exists", "Cet élément existe déjà."))
                        return
                    item = {"key": key, "icon": icon, "label": label, "label_en": label, "accent": accent, "custom": True}
                    item["command"] = command
                    preset_map[key] = item
                    selected.add(key)
                    selected_order.append(key)
                    run_prism_setting(
                        "seven-window controls-item custom "
                        f"{shlex.quote(key)} {shlex.quote(label)} {shlex.quote(icon)} {shlex.quote(command)} {shlex.quote(accent)}",
                        tr("settings.prism.item_added", "Élément ajouté au Prism : {item}", item=label),
                    )
                    custom.destroy()
                    refresh_all_buttons()

                def check_custom(_button: Gtk.Button) -> None:
                    _ok, message = command_status_text(command_entry.get_text())
                    status.set_text(message)

                add_button.connect("clicked", add_custom)
                test_button.connect("clicked", check_custom)
                cancel_button.connect("clicked", lambda _button: custom.destroy())
                label_entry.connect("changed", refresh_custom_status)
                command_entry.connect("changed", refresh_custom_status)
                accent_entry.connect("changed", refresh_custom_status)
                icon_entry.connect("changed", refresh_custom_status)
                for entry in (label_entry, icon_entry, command_entry, accent_entry):
                    entry.connect("activate", lambda _entry: add_custom(add_button) if add_button.get_sensitive() else refresh_custom_status())
                for widget in (custom_title, custom_note, suggestion_row, label_entry, icon_entry, command_entry, accent_entry, swatch_row, status, buttons_row):
                    custom_box.pack_start(widget, False, False, 0)

                def custom_dialog_key(_dialog, event) -> bool:
                    if event.keyval == Gdk.KEY_Escape:
                        custom.response(Gtk.ResponseType.CLOSE)
                        return True
                    if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter} and add_button.get_sensitive():
                        add_custom(add_button)
                        return True
                    return False

                custom.connect("key-press-event", custom_dialog_key)
                custom.connect("response", lambda _dialog, _response: custom.destroy())
                refresh_custom_status()
                custom.show_all()

            custom_button = Gtk.Button(label=tr("settings.prism.custom", "Action personnalisée"))
            custom_button.get_style_context().add_class("action-button")
            custom_button.set_tooltip_text(tr("settings.prism.custom.tooltip", "Ajouter une application ou commande au Prism."))
            custom_button.connect("clicked", lambda _button: show_custom_item_dialog())
            preset_bar.pack_start(custom_button, False, False, 0)

            for index, (key, icon, label, _accent, _command) in enumerate(preset_rows):
                button = Gtk.Button()
                button.get_style_context().add_class("action-button")
                button.get_style_context().add_class("prism-item-choice")
                set_button_state(button, key, f"{icon} {label}")
                button.set_tooltip_text(tr("settings.prism.choice.tooltip", "Ajouter ou retirer {item} du Prism.", item=label))
                button.connect("clicked", lambda _button, item_key=key, item_label=label: toggle_item(item_key, item_label))
                buttons[key] = (button, f"{icon} {label}")
                grid.attach(button, index % 2, index // 2, 1, 1)

            close_button = Gtk.Button(label=tr("settings.close", "Fermer"))
            close_button.get_style_context().add_class("action-button")
            close_button.connect("clicked", lambda _button: dialog.destroy())
            box.pack_start(title, False, False, 0)
            box.pack_start(note, False, False, 0)
            box.pack_start(count_label, False, False, 0)
            box.pack_start(preview, False, False, 0)
            box.pack_start(preset_bar, False, False, 0)
            box.pack_start(grid, False, False, 0)
            box.pack_start(order_box, False, False, 0)
            box.pack_end(close_button, False, False, 0)
            refresh_all_buttons()

            def prism_items_key(_dialog, event) -> bool:
                key_map = {
                    Gdk.KEY_1: "daily",
                    Gdk.KEY_2: "dev",
                    Gdk.KEY_3: "clean",
                }
                if event.keyval in key_map:
                    recipe = key_map[event.keyval]
                    label = {
                        "daily": tr("settings.prism.preset.daily", "Quotidien"),
                        "dev": tr("settings.prism.preset.dev", "Dev"),
                        "clean": tr("settings.prism.preset.clean", "Compact"),
                    }.get(recipe, recipe)
                    apply_recipe(recipe, label)
                    return True
                if event.keyval in {Gdk.KEY_plus, Gdk.KEY_KP_Add, Gdk.KEY_a, Gdk.KEY_A}:
                    show_custom_item_dialog()
                    return True
                return False

            dialog.connect("key-press-event", prism_items_key)
            dialog.connect("response", lambda _dialog, _response: dialog.destroy())
            dialog.show_all()

        preview_items = prism_items if prism_items else [preset_map[key] for key in ("settings", "terminal", "files") if key in preset_map]
        preview_note = tr(
            "settings.prism.preview.note",
            "{count}/{max} sommets configurés · Service {service} · Effet {effect}",
            count=item_count,
            max=item_max,
            service=service_label,
            effect=effect_label,
        )
        preview_row = prism_preview(
            preview_items,
            tr("settings.prism.preview.title", "Prism actif"),
            preview_note,
        )

        return settings_group(
            container,
            tr("settings.prism.section", "Prism SevenDecor"),
            [
                preview_row,
                settings_row(
                    "◈",
                    tr("settings.prism.status", "Prism flottant"),
                    tr(
                        "settings.prism.status.note",
                        "État : {service} · Mode : {mode} · {hypr} · Surface : {native}",
                        service=service_label,
                        mode=mode,
                        hypr=hypr_label,
                        native=native_label,
                    ),
                    [
                        start_service,
                        stop_service,
                        action_button(tr("settings.status", "Voir"), "seven-window controls-status"),
                    ],
                ),
                settings_row(
                    "󰇄",
                    tr("settings.prism.electric", "Effet électrique"),
                    tr(
                        "settings.prism.electric.note",
                        "Impulsions discrètes depuis les sommets vers le centre. État actuel : {state}.",
                        state=effect_label,
                    ),
                    [on_button, off_button],
                ),
                settings_row(
                    "󰌾",
                    tr("settings.prism.motion_safety", "Confort visuel"),
                    tr(
                        "settings.prism.motion_safety.note",
                        "L’effet suit les animations SevenOS et se coupe avec le mode réduit/off.",
                    ),
                    [
                        action_button(tr("settings.motion_reduced", "Réduit"), "seven motion reduced"),
                        action_button(tr("settings.motion_premium", "Premium"), "seven motion premium"),
                    ],
                ),
                settings_row(
                    "󰁨",
                    tr("settings.prism.target", "Cible et position"),
                    tr(
                        "settings.prism.target.note",
                        "Placement : {placement}. Clic droit/appui long ouvre split, scratchpad, lock cible et reset.",
                        placement=placement,
                    ),
                    [
                        action_button(tr("settings.open", "Ouvrir"), "seven-window advanced-menu"),
                        reset_button,
                    ],
                ),
                settings_row(
                    "󰚀",
                    tr("settings.prism.actions", "Pastilles"),
                    tr(
                        "settings.prism.actions.note",
                        "Rouge : {red} · Jaune : {yellow} · Vert : {green} · double vert : plein écran.",
                        red=traffic.get("red", "close"),
                        yellow=traffic.get("yellow", "toggle-floating"),
                        green=traffic.get("green", "smart-maximize"),
                    ),
                    [
                        action_button(tr("settings.open_help", "Aide"), "seven help Smart Window System"),
                    ],
                ),
                settings_row(
                    "✦",
                    tr("settings.prism.items", "Éléments ajoutés"),
                    tr(
                        "settings.prism.items.note",
                        "{count}/{max} sommets utilisés. Chaque ajout devient un sommet relié au centre du Prism.",
                        count=item_count,
                        max=item_max,
                    ),
                    [
                        action_button(tr("settings.status", "Voir"), "seven-window controls-items"),
                        manage_items,
                        clear_items,
                    ],
                ),
                settings_row(
                    "󰐕",
                    tr("settings.prism.presets", "Presets rapides"),
                    tr(
                        "settings.prism.presets.note",
                        "Prépare le Prism selon l’usage sans ouvrir la gestion détaillée.",
                    ),
                    [
                        daily_items,
                        dev_items,
                        clean_items,
                    ],
                ),
            ],
        )

    def mini_os_capability_panel() -> Gtk.Box:
        catalog = profile_catalog()
        profile_defs = catalog.get("profiles", {}) if isinstance(catalog.get("profiles"), dict) else {}
        naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
        current_key = active_profile_key()
        borrowed = set(runtime_capabilities())
        profile_icons = {
            "baobab": "󰣇",
            "forge": "󰅩",
            "shield": "󰒃",
            "studio": "󰏗",
            "atlas": "󰙅",
            "pulse": "󰊴",
            "equinox": "󰐃",
        }

        panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        panel.set_size_request(content_width, -1)
        panel.get_style_context().add_class("settings-card")

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title_box.set_hexpand(True)
        title = Gtk.Label(label=tr("settings.capability_injection", "Ajouter des outils d’un autre espace"))
        title.set_xalign(0)
        title.get_style_context().add_class("card-title")
        note = Gtk.Label(
            label=tr(
                "settings.capability_injection.note",
                "Choisis quelques outils utiles d’un autre espace sans quitter l’espace actuel.",
            )
        )
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("card-note")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(note, False, False, 0)
        header.pack_start(title_box, True, True, 0)
        current = Gtk.Label(label=f"{tr('settings.current', 'Current')}: {naming.get(current_key, current_key.title())}")
        current.get_style_context().add_class("card-note")
        header.pack_start(current, False, False, 0)
        panel.pack_start(header, False, False, 0)

        options = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        options.get_style_context().add_class("settings-group")
        checks: dict[str, Gtk.CheckButton] = {}
        install_missing = Gtk.CheckButton(label=tr("settings.install_missing_requirements", "Préparer automatiquement ce qui manque"))
        install_missing.set_active(True)
        install_missing.set_tooltip_text(tr("settings.install_missing_requirements.note", "SevenOS vérifie et prépare les éléments nécessaires pour les espaces sélectionnés."))
        summary_label = Gtk.Label()
        summary_label.set_xalign(0)
        summary_label.set_line_wrap(True)
        summary_label.get_style_context().add_class("settings-inline-status")
        friendly_notes = {
            "equinox": tr("settings.space.equinox.note", "Bureau quotidien, fichiers, apps et réglages."),
            "baobab": tr("settings.space.baobab.note", "Patrimoine, oralité, langues, récits et mémoire culturelle."),
            "studio": tr("settings.space.studio.note", "Images, vidéos, captures et fichiers créatifs."),
            "atlas": tr("settings.space.atlas.note", "Documents, scans, OCR, cartes, annotations et références."),
            "pulse": tr("settings.space.pulse.note", "Jeux, captures et confort de jeu."),
            "forge": tr("settings.space.forge.note", "Outils de développement avancés."),
            "shield": tr("settings.space.shield.note", "Outils de vérification et protection avancés."),
        }
        intent_presets = [
            ("󰏗", tr("settings.intent.create", "Créer"), ["studio"]),
            ("󰊴", tr("settings.intent.play", "Jouer"), ["pulse"]),
            ("󰙅", tr("settings.intent.atlas", "Explorer et organiser"), ["atlas"]),
            ("󰣇", tr("settings.intent.culture", "Lire et collecter"), ["baobab"]),
        ]

        def selected_caps() -> list[str]:
            return [key for key, check in checks.items() if check.get_active()]

        def update_summary(_widget=None) -> None:
            caps = selected_caps()
            if not caps:
                summary_label.set_text(tr("settings.capability_summary.none", "Aucun outil ajouté: ton espace reste simple et séparé."))
                return
            names = ", ".join(str(naming.get(key) or key.title()) for key in caps)
            summary_label.set_text(
                tr(
                    "settings.capability_summary",
                    "{profile} aura aussi accès à: {capabilities}.",
                    profile=naming.get(current_key, current_key.title()),
                    capabilities=names,
                )
            )

        order = ["forge", "shield", "studio", "baobab", "pulse", "atlas", "equinox"]
        for key in order:
            if key == current_key:
                continue
            data = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
            capabilities = data.get("capabilities", []) if isinstance(data.get("capabilities"), list) else []
            summary = friendly_notes.get(key) or ", ".join(str(item).replace("-", " ") for item in capabilities[:4])
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            row.get_style_context().add_class("settings-row")
            glyph = Gtk.Label(label=profile_icons.get(key, "󰐃"))
            glyph.get_style_context().add_class("settings-row-icon")
            labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            labels.set_hexpand(True)
            row_title = Gtk.Label(label=str(naming.get(key) or data.get("title") or key.title()))
            row_title.set_xalign(0)
            row_title.get_style_context().add_class("settings-row-title")
            row_note = Gtk.Label(label=summary or str(data.get("purpose") or ""))
            row_note.set_xalign(0)
            row_note.set_line_wrap(True)
            row_note.set_max_width_chars(70)
            row_note.get_style_context().add_class("settings-row-note")
            labels.pack_start(row_title, False, False, 0)
            labels.pack_start(row_note, False, False, 0)
            check = Gtk.CheckButton()
            check.set_active(key in borrowed)
            check.set_tooltip_text(tr("settings.borrow_capability", "Ajouter ces outils à l’espace actuel"))
            check.connect("toggled", update_summary)
            checks[key] = check
            center_command = str((data.get("profile_surfaces") or {}).get("center") or data.get("center_command") or f"seven-mini-os-center {key}")
            center_button = action_button(tr("settings.center", "Ouvrir"), center_command)
            row.pack_start(glyph, False, False, 0)
            row.pack_start(labels, True, True, 0)
            row.pack_start(center_button, False, False, 0)
            row.pack_start(check, False, False, 0)
            options.pack_start(row, False, False, 0)
        panel.pack_start(options, False, False, 0)
        panel.pack_start(summary_label, False, False, 0)
        panel.pack_start(install_missing, False, False, 0)
        update_summary()

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_halign(Gtk.Align.END)

        preset_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        preset_row.set_halign(Gtk.Align.START)

        def select_preset(keys: list[str]) -> None:
            for profile_key, check in checks.items():
                check.set_active(profile_key in keys)
            update_summary()
            names = ", ".join(str(naming.get(key) or key.title()) for key in keys)
            show_feedback(tr("settings.intent_selected", "SevenOS a préparé la sélection: {items}.", items=names))

        for glyph, label, keys in intent_presets:
            preset_row.pack_start(callback_button(f"{glyph} {label}", f"sélectionner {label}", lambda _keys=keys: select_preset(_keys)), False, False, 0)
        panel.pack_start(preset_row, False, False, 0)

        def apply_caps() -> None:
            caps = selected_caps()
            shell_parts: list[str] = []
            if install_missing.get_active():
                for cap in caps:
                    shell_parts.append(f"seven profile requirements {cap} --apply --yes")
            shell_parts.append(" ".join(["seven", "mini-os", "activate", current_key, *caps, "--yes", "--json"]))
            command = " && ".join(shell_parts)
            subprocess.Popen(["bash", "-lc", command], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            label = ", ".join(caps) if caps else tr("settings.no_borrowed_capability", "aucun outil ajouté")
            show_feedback(
                tr(
                    "settings.capability_apply_requested",
                    "Demande envoyée pour {profile}: {capabilities}.",
                    profile=naming.get(current_key, current_key.title()),
                    capabilities=label,
                )
            )

        def reset_caps() -> None:
            for check in checks.values():
                check.set_active(False)
            apply_caps()

        def preview_caps() -> None:
            caps = selected_caps()
            if caps:
                names = ", ".join(str(naming.get(key) or key.title()) for key in caps)
                requirements = (
                    tr("settings.requirements_will_install", "ce qui manque sera préparé automatiquement")
                    if install_missing.get_active()
                    else tr("settings.requirements_manual", "les éléments manquants seront à préparer plus tard")
                )
                message = tr(
                    "settings.capability_preview_detail",
                    "{profile} pourra utiliser: {capabilities}. SevenOS gardera ton espace actuel et préparera seulement ce que tu demandes; {requirements}.",
                    profile=naming.get(current_key, current_key.title()),
                    capabilities=names,
                    requirements=requirements,
                )
            else:
                message = tr(
                    "settings.capability_preview_reset",
                    "{profile} reviendra à un espace simple, sans outil ajouté.",
                    profile=naming.get(current_key, current_key.title()),
                )
            show_feedback(
                tr(
                    "settings.capability_preview",
                    "Aperçu: {details}",
                    details=message,
                )
            )

        actions.pack_start(callback_button(tr("settings.preview", "Aperçu"), "voir les outils à ajouter", preview_caps), False, False, 0)
        actions.pack_start(callback_button(tr("settings.reset", "Réinitialiser"), "retirer les outils ajoutés", reset_caps), False, False, 0)
        actions.pack_start(callback_button(tr("settings.apply", "Appliquer"), "ajouter les outils sélectionnés", apply_caps), False, False, 0)
        panel.pack_start(actions, False, False, 0)
        return panel

    def region_selector_card() -> Gtk.Box:
        prefs = read_region_prefs()
        options = {
            "region": [("France", "France"), ("United States", "United States"), ("Côte d’Ivoire", "Côte d’Ivoire"), ("System", tr("language.system_default", "System default"))],
            "time_format": [("24h", "24h"), ("12h", "12h")],
            "date_format": [("DD/MM/YYYY", "DD/MM/YYYY"), ("MM/DD/YYYY", "MM/DD/YYYY"), ("YYYY-MM-DD", "YYYY-MM-DD")],
            "week_start": [("Monday", tr("settings.monday", "Monday")), ("Sunday", tr("settings.sunday", "Sunday"))],
            "units": [("metric", tr("settings.metric", "Metric")), ("imperial", tr("settings.imperial", "Imperial"))],
        }

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("settings-card")
        title = Gtk.Label(label=tr("settings.region_formats", "Région et formats"))
        title.set_xalign(0)
        title.get_style_context().add_class("card-title")
        note = Gtk.Label(label=tr("settings.region_formats.note", "Choisir les formats quotidiens sans changer le clavier."))
        note.set_xalign(0)
        note.get_style_context().add_class("card-note")
        card.pack_start(title, False, False, 0)
        card.pack_start(note, False, False, 0)

        grid = Gtk.Grid()
        grid.set_column_spacing(10)
        grid.set_row_spacing(8)
        for index, (key, label_text) in enumerate(
            [
                ("region", tr("settings.region", "Région")),
                ("time_format", tr("settings.time_format", "Heure")),
                ("date_format", tr("settings.date_format", "Date")),
                ("week_start", tr("settings.week_start", "Début de semaine")),
                ("units", tr("settings.units", "Unités")),
            ]
        ):
            label = Gtk.Label(label=label_text)
            label.set_xalign(0)
            label.get_style_context().add_class("card-note")
            combo = Gtk.ComboBoxText()
            active = 0
            for option_index, (value, option_label) in enumerate(options[key]):
                combo.append(value, option_label)
                if prefs.get(key) == value:
                    active = option_index
            combo.set_active(active)
            def update_region(widget, pref_key=key) -> None:
                write_region_pref(pref_key, widget.get_active_id() or "")
                show_feedback(
                    tr(
                        "settings.region_updated",
                        "Formats régionaux actualisés. Les nouvelles fenêtres SevenOS utiliseront ces préférences.",
                    )
                )

            combo.connect("changed", update_region)
            grid.attach(label, 0, index, 1, 1)
            grid.attach(combo, 1, index, 1, 1)
        card.pack_start(grid, False, False, 0)
        return card

    def default_app_card(icon: str, title: str, note: str, desktop_id: str, mimes: tuple[str, ...]) -> Gtk.Box:
        current = xdg_default(mimes[0])
        return settings_row(
            icon,
            title,
            f"{note} · {tr('settings.current', 'Current')}: {current}",
            [
                callback_button(
                    tr("settings.set_default", "Set default"),
                    f"xdg-mime default {desktop_id}",
                    lambda app=desktop_id, targets=mimes: set_xdg_default(app, *targets),
                    tr("settings.default_updated", "Default application updated."),
                )
            ],
        )

    def language_selector_card() -> Gtk.Box:
        payload = language_state()
        languages = payload.get("languages", [])
        if not isinstance(languages, list) or not languages:
            languages = [{"locale": "C.UTF-8", "label": tr("language.system_default", "System default"), "current": True}]
        current = str(payload.get("current", "C.UTF-8"))

        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("settings-card")

        icon_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        icon_box.set_halign(Gtk.Align.CENTER)
        icon_box.set_valign(Gtk.Align.CENTER)
        icon_box.get_style_context().add_class("icon-pill")
        icon_box.pack_start(Gtk.Label(label="󰗊"), True, True, 0)

        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        text_box.set_hexpand(True)
        title_label = Gtk.Label(label=tr("settings.language", "Langue"))
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("card-title")
        note_label = Gtk.Label(label=tr("settings.language.note", "{label} · appliqué aux nouvelles fenêtres", label=payload.get("label", current)))
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("card-note")
        text_box.pack_start(title_label, False, False, 0)
        text_box.pack_start(note_label, False, False, 0)

        selector = Gtk.ComboBoxText()
        active_index = 0
        installed_by_locale: dict[str, bool] = {}
        for index, item in enumerate(languages):
            locale_name = str(item.get("locale", "C.UTF-8"))
            label = str(item.get("label", locale_name))
            installed = bool(item.get("installed", True))
            installed_by_locale[locale_name] = installed
            suffix = locale_name if installed else f"{locale_name} · {tr_text('installable')}"
            selector.append(locale_name, f"{label} · {suffix}")
            if locale_name == current or item.get("current"):
                active_index = index
        selector.set_active(active_index)
        selector.set_tooltip_text("seven language set <locale>")

        ready = {"value": False}

        def mark_ready() -> bool:
            ready["value"] = True
            return False

        def change_language(widget) -> None:
            if not ready["value"]:
                return
            locale_name = widget.get_active_id()
            if not locale_name:
                return
            run_detached(f"seven language set {locale_name}")
            if installed_by_locale.get(locale_name, True):
                notify("SevenOS Language", tr_text("Langue actualisée pour les nouvelles fenêtres.") + " " + tr("language.needs_restart", "Certaines apps ouvertes doivent être relancées pour appliquer toute la langue."))
                show_feedback(tr("language.needs_restart", "Certaines apps ouvertes doivent être relancées pour appliquer toute la langue."))
            else:
                notify("SevenOS Language", tr("settings.language_generate_apply", "SevenOS prépare cette langue, puis l’applique."))
                show_feedback(tr("settings.language_generate_apply", "SevenOS prépare cette langue, puis l’applique."))

        selector.connect("changed", change_language)
        GLib.idle_add(mark_ready)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_valign(Gtk.Align.CENTER)
        actions.pack_start(selector, False, False, 0)
        actions.pack_start(action_button(tr("settings.status", "Voir"), "seven language status"), False, False, 0)
        actions.pack_start(action_button(tr("settings.check", "Vérifier"), "seven language doctor"), False, False, 0)

        card.pack_start(icon_box, False, False, 0)
        card.pack_start(text_box, True, True, 0)
        card.pack_start(actions, False, False, 0)
        return card

    def slider_card(icon: str, title: str, note: str, value: int, callback) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        card.get_style_context().add_class("scale-card")
        icon_label = Gtk.Label(label=icon)
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        labels.set_size_request(170, -1)
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("card-title")
        note_label = Gtk.Label(label=note)
        note_label.set_xalign(0)
        note_label.get_style_context().add_class("card-note")
        labels.pack_start(title_label, False, False, 0)
        labels.pack_start(note_label, False, False, 0)
        scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
        scale.set_value(value)
        scale.set_hexpand(True)
        scale.connect("value-changed", lambda widget: callback(widget.get_value()))
        card.pack_start(icon_label, False, False, 0)
        card.pack_start(labels, False, False, 0)
        card.pack_start(scale, True, True, 0)
        return card

    def monitor_resolution_card() -> Gtk.Box:
        monitor_options = monitors_state()
        resolution_options = [
            ("preferred", tr("settings.resolution_preferred", "Preferred")),
            ("3840x2160", "3840x2160"),
            ("2560x1440", "2560x1440"),
            ("1920x1080", "1920x1080"),
            ("1600x900", "1600x900"),
            ("1366x768", "1366x768"),
            ("1280x720", "1280x720"),
        ]
        scale_options = [("1", "100%"), ("1.25", "125%"), ("1.5", "150%"), ("1.75", "175%"), ("2", "200%")]

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("settings-card")
        title = Gtk.Label(label=tr("settings.monitor_resolution", "Taille et résolution de l’écran"))
        title.set_xalign(0)
        title.get_style_context().add_class("card-title")
        note = Gtk.Label(label=tr("settings.monitor_resolution.note", "Choisir une résolution, puis l’appliquer à l’affichage SevenOS."))
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("card-note")
        card.pack_start(title, False, False, 0)
        card.pack_start(note, False, False, 0)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        monitor_combo = Gtk.ComboBoxText()
        for item in monitor_options:
            monitor_combo.append(item["name"], item["label"])
        monitor_combo.set_active(0)

        resolution_combo = Gtk.ComboBoxText()
        active_resolution = monitor_options[0].get("resolution", "preferred")
        resolution_active = 0
        for index, (value, label) in enumerate(resolution_options):
            resolution_combo.append(value, label)
            if value == active_resolution:
                resolution_active = index
        resolution_combo.set_active(resolution_active)

        scale_combo = Gtk.ComboBoxText()
        active_scale = monitor_options[0].get("scale", "1")
        scale_active = 0
        for index, (value, label) in enumerate(scale_options):
            scale_combo.append(value, label)
            if value == active_scale:
                scale_active = index
        scale_combo.set_active(scale_active)

        def apply_monitor() -> None:
            monitor_name = monitor_combo.get_active_id() or ""
            resolution = resolution_combo.get_active_id() or "preferred"
            scale = scale_combo.get_active_id() or "1"
            write_monitor_rule(monitor_name, resolution, scale)
            run_detached(session_refresh_command())
            show_feedback(tr("settings.monitor_applied", "Affichage appliqué. SevenOS actualise l’écran."))

        row.pack_start(monitor_combo, True, True, 0)
        row.pack_start(resolution_combo, False, False, 0)
        row.pack_start(scale_combo, False, False, 0)
        row.pack_start(callback_button(tr("settings.apply", "Appliquer"), "apply SevenOS monitor rule", apply_monitor), False, False, 0)
        row.pack_start(
            callback_button(
                tr("settings.restore", "Restaurer"),
                "restore previous SevenOS monitor rule",
                lambda: (restore_monitor_rule() and run_detached(session_refresh_command())),
                tr("settings.monitor_restore", "La configuration précédente est restaurée quand une sauvegarde existe."),
            ),
            False,
            False,
            0,
        )
        card.pack_start(row, False, False, 0)
        return card

    def theme_preview_card() -> Gtk.Box:
        profile_theme_file = ROOT / "identity/profile-themes.json"
        try:
            profile_theme_payload = json.loads(profile_theme_file.read_text(encoding="utf-8")) if profile_theme_file.exists() else {}
        except Exception:
            profile_theme_payload = {}
        profile_themes = profile_theme_payload.get("profiles", {}) if isinstance(profile_theme_payload.get("profiles"), dict) else {}
        profile_order = ["equinox", "baobab", "forge", "shield", "studio", "atlas", "pulse"]
        selected = {"mode": theme_mode, "profile": active_profile_key()}

        def profile_override(key: str) -> dict:
            data = profile_themes.get(key, {}) if isinstance(profile_themes.get(key), dict) else {}
            return {
                "profile": key,
                "title": str(data.get("label") or key.title()),
                "accent": str(data.get("accent") or "#8B7CFF"),
                "secondary": str(data.get("secondary") or "#6EA8FF"),
                "mood": str(data.get("ui_mood") or ""),
            }

        def contract_for_selection() -> dict:
            return seven_theme.resolved_theme(
                "settings",
                selected["mode"],
                profile_override=profile_override(selected["profile"]),
            )

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.set_size_request(content_width, -1)
        card.get_style_context().add_class("theme-preview-card")

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title_box.set_hexpand(True)
        title = Gtk.Label(label=tr("settings.theme_preview", "Theme preview"))
        title.set_xalign(0)
        title.get_style_context().add_class("hero-title")
        note = Gtk.Label()
        note.set_xalign(0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("hero-note")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(note, False, False, 0)
        header.pack_start(title_box, True, True, 0)
        apply_button = Gtk.Button(label=tr("settings.apply_now", "Appliquer maintenant"))
        apply_button.get_style_context().add_class("action-button")
        header.pack_start(apply_button, False, False, 0)
        card.pack_start(header, False, False, 0)

        sync_strip = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        sync_strip.get_style_context().add_class("theme-sync-strip")
        sync_icon = Gtk.Label(label="●")
        sync_icon.get_style_context().add_class("settings-row-icon")
        sync_status = Gtk.Label()
        sync_status.set_xalign(0)
        sync_status.set_line_wrap(True)
        sync_status.get_style_context().add_class("card-note")
        sync_strip.pack_start(sync_icon, False, False, 0)
        sync_strip.pack_start(sync_status, True, True, 0)
        card.pack_start(sync_strip, False, False, 0)

        controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        controls.set_halign(Gtk.Align.START)
        dark_button = Gtk.Button(label=tr("settings.dark_mode", "Mode sombre"))
        dark_button.get_style_context().add_class("action-button")
        light_button = Gtk.Button(label=tr("settings.light_mode", "Mode clair"))
        light_button.get_style_context().add_class("action-button")
        profile_combo = Gtk.ComboBoxText()
        active_index = 0
        for index, key in enumerate(profile_order):
            data = profile_themes.get(key, {}) if isinstance(profile_themes.get(key), dict) else {}
            profile_combo.append(key, str(data.get("label") or key.title()))
            if key == selected["profile"]:
                active_index = index
        profile_combo.set_active(active_index)
        collection_button = Gtk.Button(label=tr("settings.wallpaper_collection", "Collection SevenOS"))
        collection_button.get_style_context().add_class("action-button")
        wallpaper_button = Gtk.Button(label=tr("settings.choose_image", "Choisir une image"))
        wallpaper_button.get_style_context().add_class("action-button")
        controls.pack_start(dark_button, False, False, 0)
        controls.pack_start(light_button, False, False, 0)
        controls.pack_start(profile_combo, False, False, 0)
        controls.pack_start(collection_button, False, False, 0)
        controls.pack_start(wallpaper_button, False, False, 0)
        card.pack_start(controls, False, False, 0)

        preview = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=9)
        preview.get_style_context().add_class("theme-preview-window")
        toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        toolbar.get_style_context().add_class("theme-preview-toolbar")
        toolbar.pack_start(Gtk.Label(label="  7  SevenOS"), False, False, 8)
        profile_badge = Gtk.Label()
        toolbar.pack_end(profile_badge, False, False, 8)
        preview.pack_start(toolbar, False, False, 0)

        mock_body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
        mock_sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
        mock_sidebar.get_style_context().add_class("theme-preview-sidebar")
        for _ in range(3):
            pill = Gtk.Box()
            pill.get_style_context().add_class("theme-preview-pill")
            mock_sidebar.pack_start(pill, False, False, 0)
        mock_content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        mock_content.set_hexpand(True)
        mock_content.get_style_context().add_class("theme-preview-content")
        for index in range(2):
            pill = Gtk.Box()
            pill.get_style_context().add_class("theme-preview-pill")
            if index == 1:
                pill.get_style_context().add_class("alt")
            mock_content.pack_start(pill, False, False, 0)
        mock_body.pack_start(mock_sidebar, False, False, 0)
        mock_body.pack_start(mock_content, True, True, 0)
        preview.pack_start(mock_body, True, True, 0)
        card.pack_start(preview, False, False, 0)

        swatches = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
        swatches.get_style_context().add_class("theme-swatch-row")
        swatch_dots: list[Gtk.Box] = []
        for klass in ("swatch-accent", "swatch-secondary", "swatch-wallpaper", "swatch-cyan"):
            dot = Gtk.Box()
            dot.get_style_context().add_class("theme-swatch")
            dot.get_style_context().add_class(klass)
            swatch_dots.append(dot)
            swatches.pack_start(dot, False, False, 0)
        details = Gtk.Label()
        details.set_xalign(0)
        details.set_line_wrap(True)
        details.get_style_context().add_class("card-note")
        swatches.pack_start(details, True, True, 0)
        card.pack_start(swatches, False, False, 0)

        def refresh_preview(apply_css: bool = True) -> None:
            contract = contract_for_selection()
            palette = contract.get("palette", {}) if isinstance(contract.get("palette"), dict) else {}
            wallpaper = contract.get("wallpaper", {}) if isinstance(contract.get("wallpaper"), dict) else {}
            toolkits = contract.get("toolkits", {}) if isinstance(contract.get("toolkits"), dict) else {}
            transition = contract.get("transition", {}) if isinstance(contract.get("transition"), dict) else {}
            wallpaper_image = str(wallpaper.get("image") or "")
            wallpaper_name = Path(wallpaper_image).name if wallpaper_image else tr("settings.wallpaper_dynamic", "dynamic wallpaper")
            profile_title = str(contract.get("profile_title") or selected["profile"].title())
            active_mode = current_theme_mode()
            active_profile = active_profile_key()
            note.set_text(
                tr(
                    "settings.theme_preview.note",
                    "{mode} · {profile} · ambiance du fond: {source}",
                    mode=str(contract.get("mode_label") or selected["mode"]),
                    profile=profile_title,
                    source=str(wallpaper.get("source") or "fallback"),
                )
            )
            profile_badge.set_text(str(contract.get("profile") or selected["profile"]).upper())
            for dot, tooltip in zip(
                swatch_dots,
                (
                    f"{tr('settings.profile_accent', 'Accent du profil')}: {palette.get('accent', '')}",
                    f"{tr('settings.profile_secondary', 'Couleur secondaire')}: {palette.get('secondary', '')}",
                    f"{tr('settings.wallpaper_accent', 'Accent du fond')}: {palette.get('wallpaper_accent', '')}",
                    f"{tr('settings.wallpaper_cyan', 'Cyan du fond')}: {palette.get('wallpaper_cyan', '')}",
                ),
            ):
                dot.set_tooltip_text(tooltip)
            details.set_text(
                tr(
                    "settings.theme_preview.details",
                    "Icônes: {icons} · Apparence apps: {kvantum} · Fond: {wallpaper}",
                    icons=str(toolkits.get("icon_theme") or tr("settings.unknown", "Inconnu")),
                    kvantum=str(toolkits.get("kvantum_theme") or tr("settings.unknown", "Inconnu")),
                    wallpaper=wallpaper_name,
                )
            )
            for css_class in ("active", "preview", "running"):
                sync_strip.get_style_context().remove_class(css_class)
            transition_state = str(transition.get("state") or "")
            if transition_state == "running":
                sync_strip.get_style_context().add_class("running")
                sync_icon.set_text("●")
                sync_status.set_text(
                    tr(
                        "settings.theme_sync.running",
                        "Synchronisation en cours: {stage}. Les surfaces SevenOS se réalignent.",
                        stage=str(transition.get("stage") or tr("settings.operation.running", "En cours")),
                    )
                )
            elif selected["mode"] == active_mode and selected["profile"] == active_profile:
                sync_strip.get_style_context().add_class("active")
                sync_icon.set_text("✓")
                sync_status.set_text(tr("settings.theme_sync.active", "Actif sur ce système. Les apps ouvertes au prochain lancement suivront ce thème."))
            else:
                sync_strip.get_style_context().add_class("preview")
                sync_icon.set_text("◌")
                sync_status.set_text(
                    tr(
                        "settings.theme_sync.preview",
                        "Aperçu seulement. Le système reste en {mode} jusqu’à l’application.",
                        mode=active_mode,
                    )
                )
            if apply_css:
                provider.load_from_data(
                    (
                        seven_theme.gtk_app_css(
                            "settings",
                            selected["mode"],
                            profile_override=profile_override(selected["profile"]),
                        )
                        + seven_theme.surface_css("settings", mode=selected["mode"])
                        + settings_local_css()
                    ).encode("utf-8")
                )
                window.get_style_context().remove_class("theme-dark")
                window.get_style_context().remove_class("theme-light")
                window.get_style_context().add_class(f"theme-{selected['mode']}")

        def preview_mode(mode: str) -> None:
            selected["mode"] = mode
            refresh_preview()
            show_feedback(tr("settings.preview_updated", "Aperçu actualisé. Applique quand le rendu te convient."))

        def preview_profile(widget) -> None:
            selected["profile"] = widget.get_active_id() or selected["profile"]
            refresh_preview()
            show_feedback(tr("settings.preview_updated", "Aperçu actualisé. Applique quand le rendu te convient."))

        def choose_wallpaper(_button) -> None:
            dialog = Gtk.FileChooserDialog(
                title=tr("settings.choose_image", "Choisir un fond d’écran SevenOS"),
                parent=window,
                action=Gtk.FileChooserAction.OPEN,
                buttons=(f"_{tr('settings.cancel', 'Annuler')}", Gtk.ResponseType.CANCEL, f"_{tr('settings.set_wallpaper', 'Définir le fond')}", Gtk.ResponseType.ACCEPT),
            )
            image_filter = Gtk.FileFilter()
            image_filter.set_name("Images")
            for mime in ("image/png", "image/jpeg", "image/webp", "image/svg+xml"):
                image_filter.add_mime_type(mime)
            dialog.add_filter(image_filter)
            response = dialog.run()
            filename = dialog.get_filename()
            dialog.destroy()
            if response == Gtk.ResponseType.ACCEPT and filename:
                subprocess.Popen([str(ROOT / "bin/seven-wallpaper"), "set", filename], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
                show_feedback(tr("settings.wallpaper_preview_requested", "Fond d’écran demandé. L’aperçu utilisera la nouvelle palette après préparation."))

        def apply_theme_selection(_button) -> None:
            apply_button.set_sensitive(False)
            apply_button.get_style_context().add_class("busy")
            sync_strip.get_style_context().remove_class("active")
            sync_strip.get_style_context().remove_class("preview")
            sync_strip.get_style_context().add_class("running")
            sync_icon.set_text("●")
            sync_status.set_text(tr("settings.theme_sync.launching", "Préparation du changement de thème…"))
            profile = shlex.quote(selected["profile"])
            mode = shlex.quote(selected["mode"])
            command = (
                f"SEVENOS_THEME_MODE={mode} ./install.sh theme {mode} && "
                f"seven profile activate {profile} && "
                f"seven-wallpaper profile {profile} && "
                "seven-profile-theme apply && "
                "seven language apply --live"
            )
            show_command_output(root_shell(command), tr("settings.theme_apply", "Appliquer le thème"))
            show_feedback(tr("settings.theme_apply_requested", "Theme, profile and wallpaper changes are being applied."))

            def poll_theme_transition(count: int = 0) -> bool:
                refresh_preview(apply_css=False)
                transition = seven_theme.resolved_theme(
                    "settings",
                    selected["mode"],
                    profile_override=profile_override(selected["profile"]),
                ).get("transition", {})
                state = str(transition.get("state") or "") if isinstance(transition, dict) else ""
                if state in {"success", "failed"} or count >= 18:
                    apply_button.set_sensitive(True)
                    apply_button.get_style_context().remove_class("busy")
                    refresh_preview(apply_css=False)
                    return False
                GLib.timeout_add_seconds(1, lambda: poll_theme_transition(count + 1))
                return False

            GLib.timeout_add_seconds(1, poll_theme_transition)

        dark_button.connect("clicked", lambda _button: preview_mode("dark"))
        light_button.connect("clicked", lambda _button: preview_mode("light"))
        profile_combo.connect("changed", preview_profile)
        collection_button.connect("clicked", show_wallpaper_collection_dialog)
        wallpaper_button.connect("clicked", choose_wallpaper)
        apply_button.connect("clicked", apply_theme_selection)
        refresh_preview(apply_css=False)
        return card

