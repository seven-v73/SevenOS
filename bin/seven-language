#!/usr/bin/env python3
"""SevenOS user language manager."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import shutil
import subprocess
import sys
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr, tr_text  # noqa: E402

CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
PREF_FILE = CONFIG_DIR / "language.conf"
ENV_FILE = CONFIG_DIR / "language.env"
ENVIRONMENT_D_FILE = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "environment.d/sevenos-language.conf"
DRY_RUN = os.environ.get("SEVENOS_DRY_RUN") == "1"

PREFERRED_LOCALES = ("en_US.UTF-8", "fr_FR.UTF-8")

LABEL_KEYS = {
    "C.UTF-8": "language.system_default",
    "C": "language.system_default",
    "en_US.UTF-8": "language.english_us",
    "en_GB.UTF-8": "language.english_us",
    "fr_FR.UTF-8": "language.french_fr",
    "fr_CA.UTF-8": "language.french_ca",
    "es_ES.UTF-8": "language.spanish_es",
    "de_DE.UTF-8": "language.german",
    "it_IT.UTF-8": "language.italian",
    "pt_BR.UTF-8": "language.portuguese_br",
    "ar_SA.UTF-8": "language.arabic",
    "zh_CN.UTF-8": "language.chinese_simplified",
    "ja_JP.UTF-8": "language.japanese",
}

FALLBACK_LABELS = {
    "language.system_default": "System default",
    "language.english_us": "English (United States)",
    "language.french_fr": "French (France)",
    "language.french_ca": "French (Canada)",
    "language.spanish_es": "Spanish (Spain)",
    "language.german": "German",
    "language.italian": "Italian",
    "language.portuguese_br": "Portuguese (Brazil)",
    "language.arabic": "Arabic",
    "language.chinese_simplified": "Chinese (Simplified)",
    "language.japanese": "Japanese",
}


def normalize_locale(value: str) -> str:
    value = value.strip()
    if not value:
        return "C.UTF-8"
    if value == "C.utf8":
        return "C.UTF-8"
    if value.lower().endswith(".utf8"):
        return f"{value[:-5]}.UTF-8"
    return value


def command_output(command: list[str]) -> str:
    result = subprocess.run(command, text=True, capture_output=True, check=False)
    return result.stdout.strip()


def installed_locales() -> list[str]:
    raw = command_output(["locale", "-a"]) if shutil.which("locale") else ""
    locales = []
    for line in raw.splitlines():
        item = normalize_locale(line)
        if item == "POSIX":
            continue
        if item not in locales:
            locales.append(item)
    if "C.UTF-8" not in locales and "C" in locales:
        locales.insert(0, "C.UTF-8")
    if not locales:
        locales = ["C.UTF-8"]
    return sorted(locales, key=lambda item: (item in ("C", "C.UTF-8"), item.lower()))


def visible_locales() -> list[tuple[str, bool]]:
    installed = installed_locales()
    merged = []
    for locale_name in [*PREFERRED_LOCALES, *installed]:
        if locale_name not in [item[0] for item in merged]:
            merged.append((locale_name, locale_name in installed))
    return merged


def label_for(locale_name: str) -> str:
    key = LABEL_KEYS.get(locale_name)
    if key:
        return tr(key, FALLBACK_LABELS.get(key, locale_name))
    return locale_name.replace("_", " ").replace(".UTF-8", "")


def read_prefs() -> dict[str, str]:
    prefs: dict[str, str] = {}
    if not PREF_FILE.exists():
        return prefs
    for line in PREF_FILE.read_text(encoding="utf-8", errors="ignore").splitlines():
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        prefs[key.strip()] = value.strip().strip("'\"")
    return prefs


def current_locale() -> str:
    prefs = read_prefs()
    for key in ("SEVENOS_LANGUAGE", "LANG"):
        if prefs.get(key):
            return normalize_locale(prefs[key])
    return normalize_locale(os.environ.get("LANG", "C.UTF-8"))


def language_code(locale_name: str) -> str:
    if locale_name.startswith("C"):
        return "C"
    return locale_name.split("_", 1)[0].split(".", 1)[0]


def catalog_health() -> dict[str, object]:
    catalog_dir = ROOT / "identity" / "i18n"
    catalogs: dict[str, dict[str, object]] = {}
    raw: dict[str, dict[str, dict[str, str]]] = {}
    for language in ("en", "fr"):
        path = catalog_dir / f"{language}.json"
        data: dict[str, object] = {}
        if path.exists():
            try:
                loaded = json.loads(path.read_text(encoding="utf-8"))
                if isinstance(loaded, dict):
                    data = loaded
            except Exception:
                data = {}
        translations = data.get("translations", {})
        text = data.get("text", {})
        raw[language] = {
            "translations": translations if isinstance(translations, dict) else {},
            "text": text if isinstance(text, dict) else {},
        }
        catalogs[language] = {
            "present": path.exists(),
            "translations": len(raw[language]["translations"]),
            "text": len(raw[language]["text"]),
        }
    missing = {
        "fr": sorted((set(raw["en"]["translations"]) | set(raw["en"]["text"])) - (set(raw["fr"]["translations"]) | set(raw["fr"]["text"]))),
        "en": sorted((set(raw["fr"]["translations"]) | set(raw["fr"]["text"])) - (set(raw["en"]["translations"]) | set(raw["en"]["text"]))),
    }
    return {"catalogs": catalogs, "missing": missing, "complete": not missing["fr"] and not missing["en"]}


def language_entries() -> list[dict[str, object]]:
    current = current_locale()
    entries = []
    for locale_name, installed in visible_locales():
        entries.append(
            {
                "locale": locale_name,
                "label": label_for(locale_name),
                "language": language_code(locale_name),
                "current": locale_name == current,
                "installed": installed,
            }
        )
    return entries


def status_payload() -> dict[str, object]:
    current = current_locale()
    locales = installed_locales()
    catalog_dir = ROOT / "identity" / "i18n"
    health = catalog_health()
    systemd_env = systemd_user_environment()
    profile_states = []
    profiles_dir = host_home() / ".config/sevenos/profiles"
    for profile in ("equinox", "baobab", "forge", "shield", "studio", "atlas", "pulse"):
        path = profiles_dir / profile / "sevenos/language.env"
        profile_states.append(
            {
                "profile": profile,
                "path": str(path),
                "locale": language_file_locale(path),
                "synced": language_file_locale(path) == current,
            }
        )
    return {
        "schema": "sevenos.language.v1",
        "current": current,
        "label": label_for(current),
        "language": language_code(current),
        "available": [item[0] for item in visible_locales()],
        "generated": locales,
        "languages": language_entries(),
        "default_language_packs": [
            {
                "locale": locale_name,
                "language": language_code(locale_name),
                "label": label_for(locale_name),
                "generated": locale_name in locales,
                "selectable": True,
                "catalog": bool(health["catalogs"].get(language_code(locale_name), {}).get("present")),
            }
            for locale_name in PREFERRED_LOCALES
        ],
        "config": str(PREF_FILE),
        "env_file": str(ENV_FILE),
        "environment_d": {
            "path": str(ENVIRONMENT_D_FILE),
            "locale": language_file_locale(ENVIRONMENT_D_FILE),
            "synced": language_file_locale(ENVIRONMENT_D_FILE) == current,
        },
        "systemd_environment": {
            "values": systemd_env,
            "synced": systemd_env.get("SEVENOS_LANGUAGE") == current
            and systemd_env.get("LANG") == current
            and systemd_env.get("LANGUAGE") == language_code(current),
        },
        "profiles": profile_states,
        "catalog_dir": str(catalog_dir),
        "catalogs": {
            "en": (catalog_dir / "en.json").exists(),
            "fr": (catalog_dir / "fr.json").exists(),
            "baobab": (catalog_dir / "baobab").is_dir(),
        },
        "catalog_health": health,
        "separated_preferences": {
            "ui_language": True,
            "region_formats": True,
            "keyboard_layout": True,
            "units": True,
        },
        "active": current in locales,
    }


def file_contains(path: Path, needle: str) -> bool:
    if not path.exists():
        return False
    try:
        return needle in path.read_text(encoding="utf-8", errors="ignore")
    except Exception:
        return False


RUNTIME_MARKERS = {
    "en": (
        "Vue d’ensemble",
        "Général",
        "Fond d’écran",
        "Écrans",
        "Langue",
        "Paramètres",
        "Téléchargements",
        "Dossiers",
        "Préparer",
        "Fermer",
    ),
    "fr": (
        "Overview",
        "General",
        "Wallpaper",
        "Displays",
        "Language",
        "Settings",
        "Downloads",
        "Folders",
        "Prepare",
        "Close",
    ),
}


def runtime_language_files() -> list[Path]:
    home = host_home()
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", home / ".config"))
    candidates = [
        config_home / "waybar/config",
        config_home / "waybar/config.jsonc",
        config_home / "sevenos/window-prism-items.json",
        config_home / "sevenos/widgets.json",
        config_home / "sevenos/desktop-widgets.json",
    ]
    profiles_dir = config_home / "sevenos/profiles"
    if profiles_dir.exists():
        candidates.extend(sorted(profiles_dir.glob("*/waybar/config.jsonc")))
        candidates.extend(sorted(profiles_dir.glob("*/sevenos/*.json")))
    return [path for path in candidates if path.exists() and path.is_file()]


def runtime_language_audit() -> dict[str, object]:
    current = current_locale()
    lang = language_code(current)
    markers = RUNTIME_MARKERS.get(lang, ())
    findings = []
    checked = runtime_language_files()
    for path in checked:
        try:
            if path.stat().st_size > 1024 * 1024:
                continue
            text = path.read_text(encoding="utf-8", errors="ignore")
        except Exception:
            continue
        matched = [marker for marker in markers if marker in text]
        if matched:
            findings.append({"path": str(path), "markers": matched[:8]})
    return {
        "schema": "sevenos.language-runtime-audit.v1",
        "current": current,
        "language": lang,
        "checked": [str(path) for path in checked],
        "findings": findings,
        "state": "ok" if not findings else "attention",
        "repair": ["seven language repair", "seven-waybar repair"],
    }


def language_file_locale(path: Path) -> str:
    if not path.exists():
        return ""
    try:
        for line in path.read_text(encoding="utf-8", errors="ignore").splitlines():
            line = line.strip()
            if line.startswith("export "):
                line = line[len("export ") :].strip()
            if line.startswith("SEVENOS_LANGUAGE=") or line.startswith("LANG="):
                return normalize_locale(line.split("=", 1)[1].strip().strip("'\""))
    except Exception:
        return ""
    return ""


def systemd_user_environment() -> dict[str, str]:
    if not shutil.which("systemctl"):
        return {}
    result = subprocess.run(["systemctl", "--user", "show-environment"], text=True, capture_output=True, check=False)
    out: dict[str, str] = {}
    if result.returncode != 0:
        return out
    for line in result.stdout.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        if key in {"SEVENOS_LANGUAGE", "LANG", "LANGUAGE", "LC_MESSAGES", "LC_ALL"}:
            out[key] = value
    return out


def doctor_payload() -> dict[str, object]:
    status = status_payload()
    packs = status["default_language_packs"]
    locale_gen = ROOT / "archiso/profile/airootfs/etc/locale.gen"
    installer_lib = ROOT / "installer/lib.sh"
    checks = []
    for pack in packs:
        locale_name = str(pack["locale"])
        language = str(pack["language"])
        checks.extend(
            [
                {
                    "id": f"{language}.catalog",
                    "label": f"{locale_name} translation catalog",
                    "state": "ok" if pack.get("catalog") else "missing",
                },
                {
                    "id": f"{language}.generated",
                    "label": f"{locale_name} generated on this machine",
                    "state": "ok" if pack.get("generated") else "installable",
                },
                {
                    "id": f"{language}.iso-locale",
                    "label": f"{locale_name} enabled in ISO locale.gen",
                    "state": "ok" if file_contains(locale_gen, f"{locale_name} UTF-8") else "missing",
                },
                {
                    "id": f"{language}.installer",
                    "label": f"{locale_name} offered by installer",
                    "state": "ok" if file_contains(installer_lib, locale_name) else "missing",
                },
            ]
        )
    checks.append(
        {
            "id": "catalog.coverage",
            "label": "French and English catalogs have matching keys",
            "state": "ok" if status["catalog_health"].get("complete") else "missing",
            "missing": status["catalog_health"].get("missing", {}),
        }
    )
    checks.append(
        {
            "id": "waybar.dynamic",
            "label": "Waybar language module is dynamic",
            "state": "ok" if (ROOT / "bin/seven-waybar-language").exists() else "missing",
        }
    )
    checks.append(
        {
            "id": "cli.language-env",
            "label": "SevenOS command wrappers load language.env",
            "state": "ok"
            if file_contains(ROOT / "scripts/install-cli.sh", "sevenos/language.env")
            and file_contains(ROOT / "scripts/install-cli.sh", "seven-waybar-language")
            else "missing",
        }
    )
    active_env = Path(os.environ.get("XDG_CONFIG_HOME", str(host_home() / ".config"))) / "sevenos/language.env"
    checks.append(
        {
            "id": "session.language-env",
            "label": "SevenOS session language.env exports SEVENOS_LANGUAGE",
            "state": "ok" if language_file_locale(active_env) == status["current"] else "missing",
            "expected": status["current"],
            "actual": language_file_locale(active_env),
        }
    )
    environment_d = Path(os.environ.get("XDG_CONFIG_HOME", str(host_home() / ".config"))) / "environment.d/sevenos-language.conf"
    checks.append(
        {
            "id": "session.environment-d",
            "label": "SevenOS language persists through systemd user environment.d",
            "state": "ok" if language_file_locale(environment_d) == status["current"] else "missing",
            "expected": status["current"],
            "actual": language_file_locale(environment_d),
        }
    )
    systemd_env = systemd_user_environment()
    checks.append(
        {
            "id": "session.systemd-env",
            "label": "Current user services see the active SevenOS language",
            "state": "ok"
            if systemd_env.get("SEVENOS_LANGUAGE") == status["current"]
            and systemd_env.get("LANG") == status["current"]
            and systemd_env.get("LANGUAGE") == language_code(str(status["current"]))
            else "missing",
            "expected": {
                "SEVENOS_LANGUAGE": status["current"],
                "LANG": status["current"],
                "LANGUAGE": language_code(str(status["current"])),
            },
            "actual": systemd_env,
        }
    )
    service_files = [
        ROOT / "systemd/user/sevenos-waybar.service",
        ROOT / "systemd/user/sevenos-wallpaper.service",
        ROOT / "systemd/user/sevenos-polkit-agent.service",
        ROOT / "systemd/user/sevenos-hyprsunset.service",
    ]
    checks.append(
        {
            "id": "services.language-env",
            "label": "SevenOS user services load language.env",
            "state": "ok" if all(file_contains(path, "sevenos/language.env") for path in service_files) else "missing",
        }
    )
    native_missing = []
    language_markers = ("seven_i18n", "SEVENOS_LANGUAGE", "LANG_CODE", "language_code", "tr_text", "tr(")
    for path in sorted((ROOT / "bin").glob("*native")):
        if path.is_file() and not any(file_contains(path, marker) for marker in language_markers):
            native_missing.append(path.name)
    checks.append(
        {
            "id": "native-surfaces.i18n",
            "label": "Native SevenOS app surfaces expose language/i18n hooks",
            "state": "ok" if not native_missing else "missing",
            "missing": native_missing,
        }
    )
    checks.append(
        {
            "id": "mini-os.public-surfaces.i18n",
            "label": "Public mini OS centers and context menus follow system language",
            "state": "ok"
            if file_contains(ROOT / "bin/seven-mini-os-center", "language_code")
            and file_contains(ROOT / "bin/seven-mini-os-center", "def t(")
            and file_contains(ROOT / "bin/seven-profile-center-native", "PUBLIC_PROFILE_DETAILS")
            and file_contains(ROOT / "bin/seven-profile-center-native", "language_code")
            and file_contains(ROOT / "bin/seven-mini-context-menu-native", "language_code")
            else "missing",
        }
    )
    checks.append(
        {
            "id": "waybar.app-menu.i18n",
            "label": "Waybar app menu labels follow system language",
            "state": "ok"
            if file_contains(ROOT / "bin/seven_waybar_app_profiles.py", "FR_TO_EN")
            and file_contains(ROOT / "bin/seven_waybar_app_profiles.py", "language_code")
            and file_contains(ROOT / "bin/seven_waybar_app_profiles.py", "localize_items")
            and file_contains(ROOT / "bin/seven-waybar-status", "ui(")
            else "missing",
        }
    )
    checks.append(
        {
            "id": "mini-os.language-env",
            "label": "Mini OS runners inherit the host language contract",
            "state": "ok"
            if file_contains(ROOT / "bin/seven-profile-run", "read_language_env")
            and file_contains(ROOT / "bin/seven-profile-run", "SEVENOS_LANGUAGE")
            and file_contains(ROOT / "bin/seven-profile-launch", "read_language_env")
            and file_contains(ROOT / "bin/seven-profile-launch", "LC_MESSAGES")
            else "missing",
        }
    )
    profile_missing = []
    profile_mismatched = []
    profiles_dir = host_home() / ".config/sevenos/profiles"
    for profile in ("equinox", "baobab", "forge", "shield", "studio", "atlas", "pulse"):
        path = profiles_dir / profile / "sevenos/language.env"
        if not file_contains(path, "export SEVENOS_LANGUAGE="):
            profile_missing.append(profile)
        elif language_file_locale(path) != status["current"]:
            profile_mismatched.append({"profile": profile, "actual": language_file_locale(path)})
    checks.append(
        {
            "id": "mini-os.language-projection",
            "label": "Mini OS profile configs contain projected system language",
            "state": "ok" if not profile_missing and not profile_mismatched else "missing",
            "missing": profile_missing,
            "mismatched": profile_mismatched,
            "expected": status["current"],
        }
    )
    runtime_audit = runtime_language_audit()
    checks.append(
        {
            "id": "runtime.generated-labels",
            "label": "Generated runtime labels match the active language",
            "state": "ok" if runtime_audit.get("state") == "ok" else "missing",
            "findings": runtime_audit.get("findings", []),
        }
    )
    blocking = [item for item in checks if item["state"] == "missing"]
    ready = not blocking
    return {
        "schema": "sevenos.language-doctor.v1",
        "ready": ready,
        "state": "ready" if ready else "partial",
        "current": status["current"],
        "default_language_packs": packs,
        "checks": checks,
        "repair": [
            "./install.sh cli",
            "seven language ensure en_US.UTF-8",
            "seven language ensure fr_FR.UTF-8",
            "seven language switch en_US.UTF-8",
            "seven language switch fr_FR.UTF-8",
            "systemctl --user daemon-reload",
            "seven-waybar repair",
        ],
    }


def write_shell_hook(path: Path) -> None:
    start = "# >>> SevenOS language"
    end = "# <<< SevenOS language"
    block = "\n".join(
        [
            start,
            'if [ -r "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.env" ]; then',
            '  . "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.env"',
            "fi",
            end,
            "",
        ]
    )
    existing = path.read_text(encoding="utf-8", errors="ignore") if path.exists() else ""
    if start in existing and end in existing:
        before = existing.split(start, 1)[0].rstrip()
        after = existing.split(end, 1)[1].lstrip()
        content = f"{before}\n\n{block}{after}"
    else:
        content = f"{existing.rstrip()}\n\n{block}" if existing.strip() else block
    path.write_text(content, encoding="utf-8")


def import_environment(locale_name: str) -> None:
    env = {
        **os.environ,
        "SEVENOS_LANGUAGE": locale_name,
        "LANG": locale_name,
        "LANGUAGE": language_code(locale_name),
        "LC_MESSAGES": locale_name,
    }
    env.pop("LC_ALL", None)
    if shutil.which("systemctl"):
        subprocess.run(
            [
                "systemctl",
                "--user",
                "set-environment",
                f"SEVENOS_LANGUAGE={locale_name}",
                f"LANG={locale_name}",
                f"LANGUAGE={language_code(locale_name)}",
                f"LC_MESSAGES={locale_name}",
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        subprocess.run(["systemctl", "--user", "unset-environment", "LC_ALL"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
    commands = [
        ["systemctl", "--user", "import-environment", "SEVENOS_LANGUAGE", "LANG", "LANGUAGE", "LC_MESSAGES"],
        ["dbus-update-activation-environment", "--systemd", "SEVENOS_LANGUAGE", "LANG", "LANGUAGE", "LC_MESSAGES"],
    ]
    for command in commands:
        if shutil.which(command[0]):
            subprocess.run(command, env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


def write_language_files(directory: Path, locale_name: str) -> None:
    lang = language_code(locale_name)
    directory.mkdir(parents=True, exist_ok=True)
    (directory / "language.conf").write_text(
        "\n".join(
            [
                "# SevenOS language preference",
                f"SEVENOS_LANGUAGE={shlex.quote(locale_name)}",
                f"LANG={shlex.quote(locale_name)}",
                "",
            ]
        ),
        encoding="utf-8",
    )
    (directory / "language.env").write_text(
        "\n".join(
            [
                "# SevenOS language session environment",
                "unset LC_ALL",
                f"export SEVENOS_LANGUAGE={shlex.quote(locale_name)}",
                f"export LANG={shlex.quote(locale_name)}",
                f"export LANGUAGE={shlex.quote(lang)}",
                f"export LC_MESSAGES={shlex.quote(locale_name)}",
                "",
            ]
        ),
        encoding="utf-8",
    )


def write_environment_d(locale_name: str) -> None:
    lang = language_code(locale_name)
    ENVIRONMENT_D_FILE.parent.mkdir(parents=True, exist_ok=True)
    ENVIRONMENT_D_FILE.write_text(
        "\n".join(
            [
                "# SevenOS language session environment",
                f"SEVENOS_LANGUAGE={locale_name}",
                f"LANG={locale_name}",
                f"LANGUAGE={lang}",
                f"LC_MESSAGES={locale_name}",
                "",
            ]
        ),
        encoding="utf-8",
    )


def project_language_to_profiles(locale_name: str) -> None:
    profiles_dir = CONFIG_DIR / "profiles"
    if not profiles_dir.exists():
        return
    for profile_dir in profiles_dir.iterdir():
        if not profile_dir.is_dir():
            continue
        write_language_files(profile_dir / "sevenos", locale_name)


def notify(locale_name: str, quiet: bool = False) -> None:
    if quiet:
        return
    if shutil.which("notify-send"):
        subprocess.Popen(
            ["notify-send", "SevenOS Language", f"Language set to {label_for(locale_name)}"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )


def host_home() -> Path:
    env_home = os.environ.get("SEVENOS_HOST_HOME")
    if env_home:
        return Path(env_home)
    home = Path.home()
    text = str(home)
    marker = "/.local/share/sevenos/profile-containers/"
    if marker in text:
        return Path(text.split(marker, 1)[0])
    return home


def run_live_command(
    label: str,
    command: list[str],
    quiet: bool = False,
    ok_codes: set[int] | None = None,
    skipped_codes: set[int] | None = None,
) -> dict[str, object]:
    ok_codes = ok_codes or {0}
    skipped_codes = skipped_codes or set()
    if DRY_RUN:
        if not quiet:
            print(f"DRY-RUN > Language > {label}: {' '.join(command)}")
        return {"label": label, "command": command, "state": "dry-run"}
    if not shutil.which(command[0]):
        return {"label": label, "command": command, "state": "missing"}
    result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
    if result.returncode in ok_codes:
        state = "ok"
    elif result.returncode in skipped_codes:
        state = "skipped"
    else:
        state = "failed"
    return {"label": label, "command": command, "state": state, "code": result.returncode}


def apply_live_payload() -> dict[str, object]:
    current = current_locale()
    lang = language_code(current)
    host = host_home()
    project_language_to_profiles(current)
    write_environment_d(current)
    import_environment(current)
    commands = [
        (
            "profile-theme",
            [
                "env",
                f"SEVENOS_HOST_HOME={host}",
                f"SEVENOS_HOST_CONFIG_HOME={host / '.config'}",
                f"SEVENOS_HOST_DATA_HOME={host / '.local/share'}",
                f"XDG_CONFIG_HOME={host / '.config'}",
                f"XDG_DATA_HOME={host / '.local/share'}",
                str(ROOT / "bin/seven-profile-theme"),
                "apply",
            ],
            {0},
            {1},
        ),
        ("waybar", [str(ROOT / "bin/seven-waybar"), "repair"], {0}, set()),
        ("notifications", ["systemctl", "--user", "restart", "sevenos-notifications.service"], {0}, {1}),
        ("shell-panel", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-shell-panel"], {0}, {1}),
        ("quick-settings", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-quick-settings-native"], {0}, {1}),
        ("spotlight", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-spotlight-native"], {0}, {1}),
        ("launchpad", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-launchpad-native"], {0}, {1}),
        ("settings", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-settings-native"], {0}, {1}),
        ("help", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-help-native"], {0}, {1}),
        ("reader", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-reader-native"], {0}, {1}),
        ("store", ["pkill", "-u", os.environ.get("USER", ""), "-f", "seven-store-native"], {0}, {1}),
    ]
    results = []
    for label, command, ok_codes, skipped_codes in commands:
        if "" in command:
            results.append({"label": label, "command": command, "state": "skipped"})
            continue
        results.append(run_live_command(label, command, quiet=True, ok_codes=ok_codes, skipped_codes=skipped_codes))
    failed = [item for item in results if item.get("state") == "failed"]
    return {
        "schema": "sevenos.language.apply.v1",
        "locale": current,
        "language": lang,
        "live": True,
        "results": results,
        "ready": not failed,
        "failed": failed,
        "needs_reopen": [
            "Seven Files",
            "Seven Reader",
            "SevenStore",
            "Seven Terminal",
            "Settings if already open",
        ],
    }


def apply_live(json_mode: bool = False) -> int:
    payload = apply_live_payload()
    if json_mode:
        print(json.dumps(payload, ensure_ascii=False))
    else:
        print(f"[SevenOS] OK: {tr_text('Language applied to live SevenOS surfaces.')}")
        print(f"[SevenOS] NOTE: {tr('language.needs_restart', 'Some open apps need to be reopened to fully switch language.')}")
        for item in results:
            print(f"  {item['label']}: {item['state']}")
    if shutil.which("notify-send") and not DRY_RUN:
        subprocess.Popen(
            ["notify-send", "SevenOS Language", tr_text("Language applied to live SevenOS surfaces.")],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    return 0 if payload.get("ready") else 1


def ensure_language(locale_name: str) -> int:
    normalized = normalize_locale(locale_name)
    if normalized in installed_locales():
        print(f"[SevenOS] OK: {normalized} is already generated.")
        return 0
    if normalized not in PREFERRED_LOCALES:
        print(f"[SevenOS] ERROR: {normalized} is not in the SevenOS default language catalog.")
        return 1
    if DRY_RUN:
        print(f"DRY-RUN > Language > Enable {normalized} in /etc/locale.gen")
        print("DRY-RUN > Language > Run locale-gen")
        return 0

    locale_line = f"{normalized} UTF-8"
    enable_script = "\n".join(
        [
            "set -e",
            f"if grep -q '^{locale_line}$' /etc/locale.gen; then",
            "  true",
            f"elif grep -q '^#{locale_line}$' /etc/locale.gen; then",
            f"  sed -i 's/^#{locale_line}$/{locale_line}/' /etc/locale.gen",
            "else",
            f"  printf '\\n{locale_line}\\n' >> /etc/locale.gen",
            "fi",
            "locale-gen",
        ]
    )
    if shutil.which("sudo"):
        print(f"[SevenOS] Generating locale: {normalized}")
        print("[SevenOS] Admin rights may be requested.")
        result = subprocess.run(["sudo", "sh", "-lc", enable_script], check=False)
        if result.returncode != 0:
            print(f"[SevenOS] ERROR: locale generation failed for {normalized}.")
            return result.returncode
        if normalized in installed_locales():
            print(f"[SevenOS] OK: {normalized} generated.")
            return 0
        print(f"[SevenOS] ERROR: locale-gen finished but {normalized} is still not listed by locale -a.")
        return 1

    if os.geteuid() == 0:
        result = subprocess.run(["sh", "-lc", enable_script], check=False)
        if result.returncode != 0:
            return result.returncode
        print(f"[SevenOS] OK: {normalized} generated.")
        return 0

    print(f"[SevenOS] WARN: {normalized} is not generated yet.")
    print("[SevenOS] Run with admin rights:")
    print(f"  sudo sh -lc \"sed -i 's/^#{locale_line}$/{locale_line}/' /etc/locale.gen || printf '\\n{locale_line}\\n' >> /etc/locale.gen; locale-gen\"")
    print(f"Then apply it with: seven language switch {normalized}")
    print("[SevenOS] OK: Guidance shown. No language change was applied yet.")
    return 0


def set_language(locale_name: str, quiet: bool = False) -> int:
    normalized = normalize_locale(locale_name)
    lang = language_code(normalized)
    if DRY_RUN:
        if not quiet and normalized not in installed_locales():
            print(f"DRY-RUN > Language > Enable {normalized} in /etc/locale.gen")
            print("DRY-RUN > Language > Run locale-gen")
        if not quiet:
            print(f"DRY-RUN > Language > Set {normalized}")
            print(f"DRY-RUN > Language > Write {PREF_FILE}")
            print(f"DRY-RUN > Language > Import session environment")
        return 0

    installed = installed_locales()
    if normalized not in installed:
        if not quiet:
            print(f"[SevenOS] WARN: {normalized} is not generated yet. SevenOS will generate it first.")
        ensure_result = ensure_language(normalized)
        if ensure_result != 0:
            return ensure_result
        installed = installed_locales()
        if normalized not in installed:
            if not quiet:
                print(f"[SevenOS] ERROR: language locale is still unavailable: {normalized}")
            return 1

    write_language_files(CONFIG_DIR, normalized)
    write_environment_d(normalized)
    project_language_to_profiles(normalized)
    for shell_file in (Path.home() / ".bashrc", Path.home() / ".zshrc"):
        write_shell_hook(shell_file)
    import_environment(normalized)
    notify(normalized, quiet=quiet)
    if not quiet:
        print(f"[SevenOS] OK: Language set to {label_for(normalized)} ({normalized}).")
        print(f"[SevenOS] {tr('language.needs_restart', 'Some open apps need to be reopened to fully switch language.')}")
        print("[SevenOS] Tip: seven language repair")
    return 0


def switch_language(locale_name: str, json_mode: bool = False) -> int:
    normalized = normalize_locale(locale_name)
    if json_mode and normalized not in installed_locales():
        print(
            json.dumps(
                {
                    "schema": "sevenos.language-switch.v1",
                    "locale": normalized,
                    "ready": False,
                    "error": "locale-not-generated",
                    "repair": [f"seven language ensure {normalized}", f"seven language switch {normalized}"],
                },
                ensure_ascii=False,
            )
        )
        return 1
    set_code = set_language(locale_name, quiet=json_mode)
    if set_code != 0:
        return set_code
    apply_payload = apply_live_payload() if json_mode else None
    apply_code = 0 if json_mode and apply_payload and apply_payload.get("ready") else apply_live(json_mode=False) if not json_mode else 1
    payload = doctor_payload()
    if json_mode:
        print(
            json.dumps(
                {
                    "schema": "sevenos.language-switch.v1",
                    "locale": current_locale(),
                    "apply": apply_payload,
                    "apply_code": apply_code,
                    "doctor": payload,
                    "ready": apply_code == 0 and payload.get("ready"),
                },
                ensure_ascii=False,
            )
        )
    elif payload.get("ready"):
        print(f"[SevenOS] OK: Language switch complete: {label_for(current_locale())}.")
    else:
        print("[SevenOS] WARN: Language switched, but doctor still sees items to refresh.")
    return apply_code if apply_code != 0 else (0 if payload.get("ready") else 1)


def repair_language(json_mode: bool = False) -> int:
    payload = apply_live_payload()
    doctor = doctor_payload()
    audit = runtime_language_audit()
    ready = payload.get("ready") and doctor.get("ready") and audit.get("state") == "ok"
    if json_mode:
        print(json.dumps({"schema": "sevenos.language-repair.v1", "apply": payload, "doctor": doctor, "audit": audit, "ready": ready}, ensure_ascii=False))
    else:
        print(f"[SevenOS] OK: Language repair applied for {label_for(current_locale())}.")
        for item in payload["results"]:
            print(f"  {item['label']}: {item['state']}")
        if not doctor.get("ready"):
            print("[SevenOS] WARN: Some language checks still need attention.")
        if audit.get("state") != "ok":
            print("[SevenOS] WARN: Some generated labels still look stale; reopen affected surfaces or run seven-waybar repair.")
    return 0 if ready else 1


def print_status() -> None:
    payload = status_payload()
    print(tr("language.title", "SevenOS Language"))
    print("================")
    print(f"{tr('language.current', 'Current')}:   {payload['label']}")
    print(f"{tr('language.locale', 'Locale')}:    {payload['current']}")
    print(f"{tr('language.available', 'Available')}: {len(payload['languages'])}")
    print(f"\n{tr('language.languages', 'Languages')}:")
    for item in payload["languages"]:
        marker = "*" if item["current"] else " "
        state = "OK" if item["installed"] else "installable"
        print(f" {marker} {item['locale']:<16} {item['label']} [{state}]")


def print_doctor() -> int:
    payload = doctor_payload()
    print("SevenOS Language Doctor")
    print("=======================")
    for item in payload["checks"]:
        state = item["state"]
        marker = "OK" if state == "ok" else "TODO" if state == "installable" else "MISS"
        print(f"[{marker}] {item['label']}")
    print(f"\nState: {payload['state']}")
    if not payload["ready"]:
        print("Repair:")
        for command in payload["repair"]:
            print(f"  {command}")
    return 0 if payload["ready"] else 1


def print_audit() -> int:
    payload = runtime_language_audit()
    print("SevenOS Language Runtime Audit")
    print("==============================")
    print(f"Current: {payload['current']}")
    print(f"Checked: {len(payload['checked'])}")
    if not payload["findings"]:
        print("State: ok")
        return 0
    print("State: attention")
    for item in payload["findings"]:
        print(f"- {item['path']}: {', '.join(item['markers'])}")
    print("Repair:")
    for command in payload["repair"]:
        print(f"  {command}")
    return 1


def open_menu() -> int:
    entries = language_entries()
    lines = [f"{item['label']}|{item['locale']}" for item in entries]
    if DRY_RUN:
        print("DRY-RUN > Language > Open language chooser")
        return 0
    if not shutil.which("rofi"):
        print_status()
        return 0
    result = subprocess.run(
        ["rofi", "-dmenu", "-i", "-p", "Language", "-theme", "sevenos"],
        input="\n".join(line.split("|", 1)[0] for line in lines),
        text=True,
        capture_output=True,
        check=False,
    )
    choice = result.stdout.strip()
    if result.returncode != 0 or not choice:
        return 0
    selected = next((line.split("|", 1)[1] for line in lines if line.startswith(f"{choice}|")), "")
    return switch_language(selected) if selected else 0


def main() -> int:
    parser = argparse.ArgumentParser(description="SevenOS language manager")
    parser.add_argument("action", nargs="?", default="status", choices=("status", "list", "set", "switch", "ensure", "menu", "apply", "repair", "audit", "doctor"))
    parser.add_argument("locale", nargs="?")
    parser.add_argument("--json", action="store_true", help="print machine-readable output")
    parser.add_argument("--live", action="store_true", help="restart visible SevenOS surfaces after a language change")
    args = parser.parse_args()

    if args.action == "status":
        if args.json:
            print(json.dumps(status_payload(), ensure_ascii=False))
        else:
            print_status()
        return 0
    if args.action == "doctor":
        if args.json:
            payload = doctor_payload()
            print(json.dumps(payload, ensure_ascii=False))
            return 0 if payload["ready"] else 1
        return print_doctor()
    if args.action == "audit":
        payload = runtime_language_audit()
        if args.json:
            print(json.dumps(payload, ensure_ascii=False))
            return 0 if payload["state"] == "ok" else 1
        return print_audit()
    if args.action == "list":
        payload = {"schema": "sevenos.language-list.v1", "languages": language_entries()}
        if args.json:
            print(json.dumps(payload, ensure_ascii=False))
        else:
            for item in payload["languages"]:
                print(f"{item['locale']}\t{item['label']}")
        return 0
    if args.action == "menu":
        return open_menu()
    if args.action == "apply":
        return apply_live(args.json)
    if args.action == "repair":
        return repair_language(args.json)
    if args.action == "ensure":
        if not args.locale:
            parser.error("ensure requires a locale, for example: seven-language ensure fr_FR.UTF-8")
        return ensure_language(args.locale)
    if args.action == "switch":
        if not args.locale:
            parser.error("switch requires a locale, for example: seven-language switch en_US.UTF-8")
        return switch_language(args.locale, json_mode=args.json)
    if not args.locale:
        parser.error("set requires a locale, for example: seven-language set en_US.UTF-8")
    return set_language(args.locale)


if __name__ == "__main__":
    raise SystemExit(main())
