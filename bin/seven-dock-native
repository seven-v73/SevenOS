    }
    .dock-icon.windows {
      background: linear-gradient(180deg, rgba(137,180,250,0.98), rgba(40,105,215,0.92));
    }
    .dock-icon.recorder {
      background: linear-gradient(180deg, rgba(255,140,132,0.98), rgba(192,55,60,0.92));
    }
    .dock-icon.studio {
      background: linear-gradient(180deg, rgba(245,194,231,0.98), rgba(138,92,220,0.90));
    }
    .dock-icon.folder {
      background: linear-gradient(180deg, rgba(112,210,255,0.98), rgba(72,154,224,0.90));
    }
    .dock-dot {
      min-width: 5px;
      min-height: 5px;
      border-radius: 999px;
      background: rgba(24, 36, 47, 0.82);
      margin-top: 4px;
    }
    .dock-dot.idle {
      background: transparent;
    }
    .dock-badge {
      min-width: 17px;
      min-height: 17px;
      border-radius: 999px;
      padding: 0 5px;
      color: white;
      background: rgba(214, 58, 52, 0.96);
      font-size: 10px;
      font-weight: 500;
      margin-left: 36px;
      margin-bottom: -18px;
    }
    .dock-instance-badge {
      min-width: 17px;
      min-height: 17px;
      border-radius: 999px;
      padding: 0 5px;
      color: white;
      background: rgba(47, 123, 255, 0.96);
      font-size: 10px;
      font-weight: 500;
      margin-left: 36px;
      margin-bottom: -18px;
    }
    .dock-separator {
      min-width: 1px;
      min-height: 40px;
      margin: 9px 3px 0 3px;
      background: rgba(34, 49, 59, 0.18);
    }
    .dock-preview {
      padding: 8px;
      border-radius: 16px;
      background: rgba(245,250,252,0.96);
      border: 1px solid rgba(255,255,255,0.82);
    }
    .dock-preview-title {
      color: rgba(24,36,47,0.92);
      font-size: 12px;
      font-weight: 500;
    }
    .dock-preview-meta {
      color: rgba(78,95,107,0.86);
      font-size: 10px;
    }
    .dock-preview-row {
      min-width: 220px;
      min-height: 30px;
      border-radius: 10px;
      padding: 4px 8px;
      color: rgba(24,36,47,0.90);
      background: transparent;
    }
    .dock-preview-row:hover,
    .dock-preview-row.active-window {
      background: rgba(77,163,255,0.14);
    }
    """
    if seven_theme.current_theme_mode() == "dark":
        css += """
        .dock-shell {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.045)),
            rgba(15,18,26,0.72);
          border-color: rgba(255,255,255,0.14);
        }
        .dock-tile:hover {
          background: rgba(255,255,255,0.09);
        }
        .dock-icon {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.07)),
            rgba(22,26,36,0.88);
          border-color: rgba(255,255,255,0.12);
        }
        .dock-dot { background: rgba(245,247,250,0.80); }
        .dock-separator { background: rgba(255,255,255,0.14); }
        .dock-preview {
          background: rgba(18,19,26,0.94);
          border-color: rgba(255,255,255,0.12);
        }
        .dock-preview-title, .dock-preview-row { color: rgba(245,247,250,0.92); }
        .dock-preview-meta { color: rgba(245,247,250,0.58); }
        """

    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    force_window = os.environ.get("SEVENOS_DOCK_FORCE_WINDOW") == "1"
    window = Gtk.Window(title="Seven Dock")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_default_size(dock_width, dock_height)
    window.set_size_request(dock_width, dock_height)
    window.set_app_paintable(True)
    window.set_accept_focus(False)
    window.set_focus_on_map(False)
    window.set_keep_above(True)
    if not force_window:
        window.set_skip_taskbar_hint(True)
        window.set_skip_pager_hint(True)
    window.set_wmclass("SevenDockNative", "SevenDockNative")
    window.get_style_context().add_class("seven-dock")
    if autohide:
        window.set_opacity(0.18)

    try:
        if force_window:
            raise RuntimeError("window fallback requested")
        import gi as _gi

        _gi.require_version("GtkLayerShell", "0.1")
        from gi.repository import GtkLayerShell

        GtkLayerShell.init_for_window(window)
        if hasattr(GtkLayerShell, "set_namespace"):
            GtkLayerShell.set_namespace(window, "sevenos-dock")
        GtkLayerShell.set_layer(window, GtkLayerShell.Layer.OVERLAY)
        GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.BOTTOM, True)
        GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.LEFT, True)
        GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.RIGHT, True)
        GtkLayerShell.set_margin(window, GtkLayerShell.Edge.BOTTOM, DOCK_MARGIN)
        GtkLayerShell.set_exclusive_zone(window, dock_height + DOCK_MARGIN if reserve_space else 0)
        GtkLayerShell.set_keyboard_interactivity(window, False)
        layer_shell_mode = True
    except Exception:
        layer_shell_mode = False
        width, height = monitor_width, monitor_height
        window.move(max(0, int((width - dock_width) / 2)), max(0, height - dock_height - DOCK_MARGIN))

    shell = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=5)
    shell.set_halign(Gtk.Align.CENTER)
    shell.set_size_request(dock_width, dock_height)
    shell.get_style_context().add_class("dock-shell")
    if dock_overflow:
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.NEVER)
        scroll.set_size_request(dock_width, dock_height)
        scroll.add(shell)
        window.add(scroll)
    else:
        window.add(shell)

    hide_source = {"id": 0}
    fade_source = {"id": 0}
    # UX contract: window.set_opacity(0.18 if autohide else 1.0)
    opacity_state = {"value": 0.18 if autohide else 1.0}

    def animate_dock_opacity(target: float) -> bool:
        current = float(opacity_state["value"])
        if abs(current - target) <= DOCK_FADE_STEP:
            opacity_state["value"] = target
            window.set_opacity(target)
            fade_source["id"] = 0
            return False
        current = current + DOCK_FADE_STEP if current < target else current - DOCK_FADE_STEP
        opacity_state["value"] = current
        window.set_opacity(current)
        return True

    def fade_dock_to(target: float) -> bool:
        if fade_source["id"]:
            GLib.source_remove(fade_source["id"])
            fade_source["id"] = 0
        fade_source["id"] = GLib.timeout_add(DOCK_FADE_STEP_MS, animate_dock_opacity, target)
        return False

    def reveal_dock(*_args) -> bool:
        if hide_source["id"]:
            GLib.source_remove(hide_source["id"])
            hide_source["id"] = 0
        fade_dock_to(1.0)
        return False

    def dim_dock() -> bool:
        hide_source["id"] = 0
        fade_dock_to(0.18 if autohide else 1.0)
        return False

    def schedule_dim(*_args) -> bool:
        if not autohide:
            return False
        if hide_source["id"]:
            GLib.source_remove(hide_source["id"])
        hide_source["id"] = GLib.timeout_add(650, dim_dock)
        return False

    if autohide:
        window.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
        shell.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
        window.connect("enter-notify-event", reveal_dock)
        window.connect("leave-notify-event", schedule_dim)
        shell.connect("enter-notify-event", reveal_dock)
        shell.connect("leave-notify-event", schedule_dim)

    grouped_clients_state: dict[str, list[dict[str, object]]] = {}
    compact_tiles = dock_overflow or monitor_width < 900

    def render_shell() -> bool:
        nonlocal grouped_clients_state
        for child in shell.get_children():
            shell.remove(child)
        grouped_clients_state = clients_by_tile(hyprland_clients())
        groups = tile_groups(config, grouped_clients_state)
        for group_index, group in enumerate(groups):
            if group_index > 0 and group:
                separator = Gtk.Box()
                separator.get_style_context().add_class("dock-separator")
                shell.pack_start(separator, False, False, 0)
            for tile in group:
                add_tile(shell, tile, config, Gtk, Gdk, GLib, grouped_clients_state, compact=compact_tiles)
        shell.show_all()
        return True

    def on_destroy(_window):
        clear_dock_state()
        Gtk.main_quit()

    window.connect("destroy", on_destroy)
    render_shell()
    window.show_all()
    window.resize(dock_width, dock_height)
    if force_window:
        width, height = monitor_width, monitor_height
        window.move(max(0, int((width - dock_width) / 2)), max(0, height - dock_height - DOCK_MARGIN))
        GLib.timeout_add(350, place_hyprland_window)
    window.present()
    write_dock_state(
        {
            "schema": "sevenos.dock.runtime.v1",
            "pid": os.getpid(),
            "profile": bound_profile,
            "policy": "visible-on-all-workspaces-until-profile-change",
            "layer_shell": layer_shell_mode,
            "reserve_space": reserve_space,
            "width": dock_width,
            "height": dock_height,
        }
    )

    def enforce_profile_scope() -> bool:
        if active_profile_key() != bound_profile:
            window.close()
            return False
        return True

    GLib.timeout_add_seconds(1, enforce_profile_scope)
    GLib.timeout_add_seconds(2, render_shell)
    Gtk.main()
    return 0


def add_tile(shell, tile: dict[str, object], config: dict[str, object], Gtk, Gdk, GLib, grouped_clients: dict[str, list[dict[str, object]]], compact: bool = False) -> None:
    event = Gtk.EventBox()
    event.set_visible_window(False)
    window_count = int(tile.get("window_count", 0) or 0)
    tooltip_parts = [str(tile["title"])]
    if window_count:
        tooltip_parts.append(f"{window_count} window{'s' if window_count > 1 else ''}")
    if tile.get("launching"):
        tooltip_parts.append("launching")
    if not tile.get("available", True):
        tooltip_parts.append("unavailable")
    event.set_tooltip_text(" · ".join(tooltip_parts))
    event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.KEY_PRESS_MASK)
    event.set_can_focus(True)
    event.connect("button-press-event", lambda widget, event_data, dock_tile=tile: on_tile_click(widget, event_data, dock_tile, config, Gtk, GLib, grouped_clients))
    event.connect("key-press-event", lambda widget, key_event, dock_tile=tile: on_tile_key(widget, key_event, dock_tile, config, Gtk, Gdk, GLib, grouped_clients))
    button_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    button_box.set_halign(Gtk.Align.CENTER)
    button_box.get_style_context().add_class("dock-tile")
    event.dock_tile_box = button_box
    setup_tile_dnd(event, tile, config, Gtk, Gdk, GLib)
    if window_count:
        button_box.get_style_context().add_class("running")
    if tile.get("active"):
        button_box.get_style_context().add_class("active")
    if tile.get("launching"):
        button_box.get_style_context().add_class("launching")
        GLib.timeout_add(120, animate_launch_feedback, button_box, GLib)
    if not tile.get("available", True):
        button_box.get_style_context().add_class("unavailable")

    icon_stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    icon_stack.set_halign(Gtk.Align.CENTER)

    badge_count = window_count if window_count > 1 else notification_count() if tile.get("id") == "hub" else 0
    if badge_count > 0:
        badge = Gtk.Label(label=str(min(badge_count, 99)))
        badge.set_halign(Gtk.Align.END)
        badge.get_style_context().add_class("dock-instance-badge" if window_count > 1 else "dock-badge")
        icon_stack.pack_start(badge, False, False, 0)

    icon_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    icon_box.set_halign(Gtk.Align.CENTER)
    icon_box.set_valign(Gtk.Align.CENTER)
    icon_box.get_style_context().add_class("dock-icon")
    icon_box.get_style_context().add_class(str(tile.get("style", "default")))
    icon = Gtk.Image.new_from_icon_name(str(tile["icon"]), Gtk.IconSize.DIALOG)
    icon.set_pixel_size(30 if compact else 34)
    icon_box.pack_start(icon, True, True, 0)
    icon_stack.pack_start(icon_box, False, False, 0)

    event.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
    event.connect(
        "enter-notify-event",
        lambda widget, _event, image=icon, box=icon_box, dock_tile=tile: on_tile_hover(widget, image, box, dock_tile, grouped_clients, Gtk, True, compact),
    )
    event.connect(
        "leave-notify-event",
        lambda widget, _event, image=icon, box=icon_box, dock_tile=tile: on_tile_hover(widget, image, box, dock_tile, grouped_clients, Gtk, False, compact),
    )

    dot = Gtk.Box()
    dot.get_style_context().add_class("dock-dot")
    if not window_count and not tile_running(tile):
        dot.get_style_context().add_class("idle")
    dot.set_halign(Gtk.Align.CENTER)

    button_box.pack_start(icon_stack, False, False, 0)
    button_box.pack_start(dot, False, False, 0)
    event.add(button_box)
    shell.pack_start(event, False, False, 0)


def magnify_tile(icon, icon_box, active: bool, compact: bool = False) -> bool:
    idle_icon = 30 if compact else 34
    active_icon = 35 if compact else 39
    idle_box = 45 if compact else 50
    active_box = 50 if compact else 56
    icon.set_pixel_size(active_icon if active else idle_icon)
    icon_box.set_size_request(active_box if active else idle_box, active_box if active else idle_box)
    return False


def on_tile_hover(widget, icon, icon_box, tile: dict[str, object], grouped_clients: dict[str, list[dict[str, object]]], Gtk, active: bool, compact: bool) -> bool:
    magnify_tile(icon, icon_box, active, compact)
    if active:
        show_window_preview(widget, tile, grouped_clients, Gtk)
    else:
        close_window_preview()
    return False


def flash_tile(widget, class_name: str, GLib, duration_ms: int = TILE_FEEDBACK_MS) -> bool:
    box = getattr(widget, "dock_tile_box", None)
    if box is None:
        return False
    style = box.get_style_context()
    style.add_class(class_name)

    def clear_class() -> bool:
        style.remove_class(class_name)
        return False

    GLib.timeout_add(duration_ms, clear_class)
    return False


def animate_launch_feedback(tile_box, GLib) -> bool:
    if tile_box is None:
        return False
    style = tile_box.get_style_context()
    style.add_class("launch-feedback")

    def clear_feedback() -> bool:
        style.remove_class("launch-feedback")
        return False

    GLib.timeout_add(520, clear_feedback)
    return False


def close_window_preview() -> bool:
    global PREVIEW_POPOVER
    if PREVIEW_POPOVER is not None:
        try:
            PREVIEW_POPOVER.popdown()
            PREVIEW_POPOVER.destroy()
        except Exception:
            pass
        PREVIEW_POPOVER = None
    return False


def show_window_preview(widget, tile: dict[str, object], grouped_clients: dict[str, list[dict[str, object]]], Gtk) -> bool:
    global PREVIEW_POPOVER
    windows = grouped_clients.get(str(tile.get("id", "")), [])
    if not windows:
        close_window_preview()
        return False

    close_window_preview()
    windows = sorted(windows, key=lambda item: int(item.get("focusHistoryID", 9999) or 9999))
    popover = Gtk.Popover(relative_to=widget)
    popover.set_position(Gtk.PositionType.TOP)
    popover.set_modal(False)
    popover.get_style_context().add_class("dock-preview")

    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
    title = Gtk.Label(label=str(tile.get("title", tr_text("App"))))
    title.set_xalign(0)
    title.get_style_context().add_class("dock-preview-title")
    meta = Gtk.Label(label=f"{len(windows)} window{'s' if len(windows) > 1 else ''}")
    meta.set_xalign(0)
    meta.get_style_context().add_class("dock-preview-meta")
    box.pack_start(title, False, False, 0)
    box.pack_start(meta, False, False, 0)

    for client in windows[:5]:
        label_text = str(client.get("title") or client.get("class") or tile.get("title", tr_text("Window")))
        if len(label_text) > 46:
            label_text = label_text[:43].rstrip() + "..."
        row = Gtk.Button(label=label_text)
        row.set_relief(Gtk.ReliefStyle.NONE)
        row.set_halign(Gtk.Align.FILL)
        row.get_child().set_xalign(0)
        row.get_style_context().add_class("dock-preview-row")
        if int(client.get("focusHistoryID", 9999) or 9999) == 0:
            row.get_style_context().add_class("active-window")
        row.connect("clicked", lambda _row, selected=client: (focus_client(selected), close_window_preview()))
        box.pack_start(row, False, False, 0)

    popover.add(box)
    popover.show_all()
    popover.popup()
    PREVIEW_POPOVER = popover
    return False


def tile_running(tile: dict[str, object]) -> bool:
    if tile.get("kind") == "folder":
        return False
    processes = [str(process) for process in tile.get("processes", [])]
    return process_running(processes)


def setup_tile_dnd(widget, tile: dict[str, object], config: dict[str, object], Gtk, Gdk, GLib) -> None:
    tile_target = Gtk.TargetEntry.new(DOCK_TILE_TARGET, Gtk.TargetFlags.SAME_APP, 1)
    uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 2)
    text_target = Gtk.TargetEntry.new("text/plain", 0, 3)
    widget.drag_source_set(Gdk.ModifierType.BUTTON1_MASK, [tile_target], Gdk.DragAction.MOVE)
    widget.drag_dest_set(Gtk.DestDefaults.ALL, [tile_target, uri_target, text_target], Gdk.DragAction.MOVE | Gdk.DragAction.COPY)
    widget.connect("drag-data-get", lambda _widget, _context, data, _info, _time, dock_tile=tile: data.set_text(str(dock_tile.get("id", "")), -1))
    widget.connect("drag-data-received", lambda drag_widget, context, _x, _y, data, info, time_value, dock_tile=tile: on_tile_drop(drag_widget, context, data, info, time_value, dock_tile, config, Gtk, GLib))
    widget.connect("drag-motion", lambda drag_widget, context, _x, _y, time_value, dock_tile=tile: on_tile_drag_motion(drag_widget, context, time_value, dock_tile, Gdk, GLib))
    widget.connect("drag-leave", lambda drag_widget, _context, _time, dock_tile=tile: cancel_spring_loaded(dock_tile, GLib, drag_widget))


def on_tile_drag_motion(widget, context, time_value: int, tile: dict[str, object], Gdk, GLib) -> bool:
    box = getattr(widget, "dock_tile_box", None)
    if box is not None:
        box.get_style_context().add_class("drag-target")
    if tile.get("kind") == "folder":
        tile_id = str(tile.get("id", ""))
        if tile_id and tile_id not in SPRING_OPEN:
            if box is not None:
                box.get_style_context().add_class("spring-armed")
            SPRING_OPEN[tile_id] = GLib.timeout_add(SPRING_LOADED_DELAY_MS, spring_open_folder, tile)
    try:
        context.drag_status(Gdk.DragAction.COPY, time_value)
    except Exception:
        pass
    return False


def cancel_spring_loaded(tile: dict[str, object], GLib, widget=None) -> None:
    tile_id = str(tile.get("id", ""))
    source_id = SPRING_OPEN.pop(tile_id, 0)
    if source_id:
        try:
            GLib.source_remove(source_id)
        except Exception:
            pass
    box = getattr(widget, "dock_tile_box", None)
    if box is not None:
        style = box.get_style_context()
        style.remove_class("drag-target")
        style.remove_class("spring-armed")


def spring_open_folder(tile: dict[str, object]) -> bool:
    tile_id = str(tile.get("id", ""))
    SPRING_OPEN.pop(tile_id, None)
    if tile.get("kind") != "folder":
        return False
    path = str(tile.get("path") or Path.home())
    if path:
        run_action(["seven-files", path])
    return False


def on_tile_drop(widget, context, data, info: int, time_value: int, target_tile: dict[str, object], config: dict[str, object], Gtk, GLib) -> None:
    cancel_spring_loaded(target_tile, GLib, widget)
    handled = False
    if info == 1:
        source_id = str(data.get_text() or "").strip()
        handled = move_tile_to_target(source_id, str(target_tile.get("id", "")), config)
    elif info == 2:
        handled = handle_file_drop(target_tile, [str(uri) for uri in data.get_uris()])
    elif info == 3:
        text = str(data.get_text() or "").strip()
        uris = [line for line in text.splitlines() if line.startswith("file://")]
        handled = handle_file_drop(target_tile, uris)
    context.finish(handled, False, time_value)


def move_tile_to_target(source_id: str, target_id: str, config: dict[str, object]) -> bool:
    if not source_id or not target_id or source_id == target_id:
        return False
    catalog = tile_catalog()
    if source_id not in catalog:
        return False
    profile = active_profile_key()
    pinned = effective_pinned_ids(config, profile)
    if source_id in pinned:
        pinned.remove(source_id)
    if target_id in pinned:
        pinned.insert(pinned.index(target_id), source_id)
    else:
        pinned.append(source_id)
    save_profile_pins(config, profile, pinned)
    return True


def file_paths_from_uris(uris: list[str]) -> list[str]:
    paths: list[str] = []
    for uri in uris:
        parsed = urllib.parse.urlparse(uri)
        if parsed.scheme != "file":
            continue
        path = urllib.parse.unquote(parsed.path)
        if path:
            paths.append(path)
    return paths


def handle_file_drop(tile: dict[str, object], uris: list[str]) -> bool:
    paths = file_paths_from_uris(uris)
    if not paths:
        return False
    tile_id = str(tile.get("id", ""))
    LAUNCHING[tile_id] = time.monotonic()
    if tile_id == "files":
        run_action(["seven-files", paths[0]])
        return True
    if tile_id == "reader":
        for path in paths[:4]:
            run_action(["seven-reader", path])
        return True
    if tile_id in {"browser", "studio"}:
        for path in paths[:4]:
            run_action(["xdg-open", path])
        return True
    return False


def on_tile_click(widget, event, tile: dict[str, object], config: dict[str, object], Gtk, GLib, grouped_clients: dict[str, list[dict[str, object]]]) -> bool:
    if getattr(event, "button", 0) == 1 and isinstance(tile.get("command"), list):
        flash_tile(widget, "pressed", GLib)
        if tile.get("window_count") and focus_tile_window(tile, grouped_clients):
            return True
        if not tile.get("available", True):
            show_context_menu(widget, tile, config, Gtk, event)
            return True
        LAUNCHING[str(tile.get("id", ""))] = time.monotonic()
        animate_launch_feedback(getattr(widget, "dock_tile_box", None), GLib)
        run_action([str(part) for part in tile["command"]])
        return True
    if getattr(event, "button", 0) == 3:
        show_context_menu(widget, tile, config, Gtk, event)
        return True
    return False


def on_tile_key(widget, event, tile: dict[str, object], config: dict[str, object], Gtk, Gdk, GLib, grouped_clients: dict[str, list[dict[str, object]]]) -> bool:
    if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter, Gdk.KEY_space}:
        class Event:
            button = 1
        return on_tile_click(widget, Event(), tile, config, Gtk, GLib, grouped_clients)
    if event.keyval in {Gdk.KEY_Menu, Gdk.KEY_F10}:
        show_context_menu(widget, tile, config, Gtk, event)
        return True
    return False


def show_context_menu(widget, tile: dict[str, object], config: dict[str, object], Gtk, event) -> None:
    menu = Gtk.Menu()

    def item(label: str, callback) -> None:
        menu_item = Gtk.MenuItem(label=label)
        menu_item.connect("activate", lambda _item: callback())
        menu.append(menu_item)

    if tile.get("window_count"):
        item(tr_text("Show Windows"), lambda: run_action(["seven-overview", "windows"]))
        item(tr_text("Focus"), lambda: focus_tile_window(tile, clients_by_tile(hyprland_clients())))
    if tile.get("available", True):
        item(tr_text("Open {item}", item=tile.get("title", tr_text("Item"))), lambda: run_action([str(part) for part in tile.get("command", [])]))
    else:
        item(tr_text("Unavailable"), lambda: None)

    if tile.get("kind") == "folder":
        path = str(tile.get("path", Path.home()))
        item(tr_text("Open in Seven Files"), lambda: run_action(["seven-files", path]))
        item(tr_text("Reveal in Files"), lambda: run_action(["xdg-open", path]))
    else:
        if tile_running(tile):
            processes = [str(process) for process in tile.get("processes", [])]
            item(tr_text("Quit"), lambda: quit_processes(processes, force=False))
            item(tr_text("Force Quit"), lambda: quit_processes(processes, force=True))

    tile_id = str(tile.get("id", ""))
    pinned = [str(item_id) for item_id in config.get("pinned", [])]
    if tile.get("kind") == "app" or tile.get("kind") == "system":
        if tile_id in pinned:
            item(tr_text("Remove from Dock"), lambda: update_pinned(tile_id, keep=False))
            item(tr_text("Move Left"), lambda: move_pinned(tile_id, -1))
            item(tr_text("Move Right"), lambda: move_pinned(tile_id, 1))
        else:
            item(tr_text("Keep in Dock"), lambda: update_pinned(tile_id, keep=True))

    item(tr_text("Dock Settings"), lambda: run_action(["seven-dock", "settings"]))
    menu.show_all()
    try:
        menu.popup_at_pointer(event)
    except Exception:
        menu.popup(None, None, None, None, getattr(event, "button", 3), getattr(event, "time", 0))


def quit_processes(processes: list[str], force: bool) -> None:
    signal = "-9" if force else "-TERM"
    for process in processes:
        subprocess.run(["pkill", signal, "-u", os.environ.get("USER", ""), "-x", process], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


def update_pinned(tile_id: str, keep: bool) -> None:
    config = load_config()
    pinned = [str(item) for item in config.get("pinned", [])]
    if keep and tile_id not in pinned:
        pinned.append(tile_id)
    if not keep:
        pinned = [item for item in pinned if item != tile_id]
    config["pinned"] = pinned
    save_config(config)


def move_pinned(tile_id: str, direction: int) -> None:
    config = load_config()
    profile = active_profile_key()
    pinned = effective_pinned_ids(config, profile)
    if tile_id not in pinned:
        return
    index = pinned.index(tile_id)
    target = max(0, min(len(pinned) - 1, index + direction))
    if target == index:
        return
    pinned[index], pinned[target] = pinned[target], pinned[index]
    save_profile_pins(config, profile, pinned)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("--limits", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    if args.probe:
        return probe()
    if args.limits:
        payload = dock_limits_payload()
        if args.json:
            print(json.dumps(payload, indent=2, ensure_ascii=False))
        else:
            dock = payload["dock"]
            tiles = payload["tiles"]
            print(f"SevenOS Dock: {dock['width']}x{dock['height']} / max {dock['max_width']} px")
            print(f"Tiles: {tiles['total']} ({tiles['pinned']} pinned, {tiles['folders']} folders, {tiles['system']} system)")
            print(f"Overflow: {'yes' if dock['overflow'] else 'no'}")
        return 0
    return run_dock()


if __name__ == "__main__":
    raise SystemExit(main())
