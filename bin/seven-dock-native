#!/usr/bin/env python3
"""SevenOS native dock surface."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
import urllib.parse
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "scripts"))
from seven_i18n import tr_text  # noqa: E402
import seven_theme  # noqa: E402


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin").is_dir():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin").is_dir():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin").is_dir():
            return candidate
    return Path.home()


ROOT = resolve_root()
CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config")))
CONFIG_PATH = CONFIG_HOME / "sevenos/dock.json"
PROFILE_ENV_PATH = CONFIG_HOME / "sevenos/profile.env"
PROFILE_UI_PATH = CONFIG_HOME / "sevenos/profile-ui.json"
DOCK_STATE_PATH = Path(os.environ.get("XDG_RUNTIME_DIR", f"/tmp/sevenos-{os.getuid()}")) / "sevenos-dock-state.json"
DOCK_HEIGHT = 82
DOCK_MARGIN = 22
DOCK_TILE_STEP = 61
DOCK_SEPARATOR_STEP = 14
DOCK_HORIZONTAL_PADDING = 22
LAUNCHING_TTL = 6.0
LAUNCHING: dict[str, float] = {}
DOCK_FADE_STEP_MS = 16
DOCK_FADE_STEP = 0.08
TILE_FEEDBACK_MS = 180
SPRING_LOADED_DELAY_MS = 700
SPRING_OPEN: dict[str, int] = {}
PREVIEW_POPOVER = None
DOCK_TILE_TARGET = "SEVENOS_DOCK_TILE"
URI_LIST_TARGET = "text/uri-list"

PROFILE_PINNED = {
    "equinox": ["files", "apps", "browser", "terminal", "spotlight", "hub"],
    "baobab": ["files", "apps", "reader", "store", "terminal", "spotlight", "hub"],
    "forge": ["files", "terminal", "browser", "apps", "hub", "settings"],
    "shield": ["shield", "terminal", "files", "browser", "spotlight", "hub"],
    "studio": ["files", "browser", "store", "recorder", "spotlight", "hub"],
    "windows": ["windows", "files", "terminal", "browser", "settings", "hub"],
    "pulse": ["browser", "terminal", "apps", "recorder", "settings", "hub"],
}

CLASS_TILE_HINTS = {
    "code": "studio",
    "codium": "studio",
    "google-chrome": "browser",
    "firefox": "browser",
    "brave-browser": "browser",
    "chromium": "browser",
    "kitty": "terminal",
    "seven-terminal-native": "terminal",
    "seven-files-native": "files",
    "org.gnome.nautilus": "files",
    "nautilus": "files",
    "seven-reader-native": "reader",
    "seven-store-native": "store",
    "virt-manager": "windows",
}


DEFAULT_CONFIG = {
    "position": "bottom",
    "size": "compact",
    "magnification": True,
    "autohide": False,
    "reserve_space": True,
    "pinned": ["files", "apps", "browser", "terminal", "spotlight", "hub"],
    "profile_pins": {},
    "folders": ["downloads", "home"],
}


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def command_available(command: str) -> bool:
    return subprocess.run(["sh", "-lc", f"command -v {command}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0


def load_config() -> dict[str, object]:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        save_config(DEFAULT_CONFIG)
        return dict(DEFAULT_CONFIG)
    try:
        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
    except Exception:
        data = {}
    config = dict(DEFAULT_CONFIG)
    config.update({key: value for key, value in data.items() if key in DEFAULT_CONFIG})
    return config


def save_config(config: dict[str, object]) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(config, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def active_profile_key() -> str:
    try:
        for raw in PROFILE_ENV_PATH.read_text(encoding="utf-8").splitlines():
            if raw.startswith("SEVENOS_ACTIVE_PROFILE="):
                return raw.split("=", 1)[1].strip().strip('"') or "equinox"
    except OSError:
        pass
    try:
        data = json.loads(PROFILE_UI_PATH.read_text(encoding="utf-8"))
        return str(data.get("profile") or "equinox")
    except Exception:
        return "equinox"


def write_dock_state(payload: dict[str, object]) -> None:
    try:
        DOCK_STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
        DOCK_STATE_PATH.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    except OSError:
        pass


def clear_dock_state() -> None:
    try:
        DOCK_STATE_PATH.unlink()
    except OSError:
        pass


def process_running(names: list[str]) -> bool:
    for name in names:
        result = subprocess.run(
            ["pgrep", "-u", os.environ.get("USER", ""), "-x", name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            return True
    return False


def notification_count() -> int:
    for command in (["swaync-client", "-c"], ["makoctl", "list"]):
        try:
            result = subprocess.run(command, text=True, capture_output=True, check=False, timeout=0.35)
        except subprocess.TimeoutExpired:
            continue
        if result.returncode == 0 and result.stdout.strip().isdigit():
            return int(result.stdout.strip())
    return 0


def resolve_command(command: list[str]) -> list[str]:
    if not command:
        return []
    local = ROOT / "bin" / command[0]
    if local.exists():
        return [str(local), *command[1:]]
    return command


def run_action(command: list[str]) -> None:
    if not command:
        return
    subprocess.Popen(resolve_command(command), cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def command_ready(command: list[str]) -> bool:
    if not command:
        return False
    if command[0] in {"xdg-open", "sh", "bash"}:
        return command_available(command[0])
    return (ROOT / "bin" / command[0]).exists() or command_available(command[0])


def hyprland_clients() -> list[dict[str, object]]:
    if not os.environ.get("HYPRLAND_INSTANCE_SIGNATURE") or not command_available("hyprctl"):
        return []
    try:
        return json.loads(
            subprocess.run(["hyprctl", "clients", "-j"], text=True, capture_output=True, check=False, timeout=0.45).stdout
            or "[]"
        )
    except Exception:
        return []


def client_tile_id(client: dict[str, object]) -> str | None:
    client_class = str(client.get("class") or client.get("initialClass") or "").casefold()
    title = str(client.get("title") or "").casefold()
    for key, tile_id in CLASS_TILE_HINTS.items():
        if key in client_class:
            return tile_id
    if "seven files" in title:
        return "files"
    if "seven reader" in title:
        return "reader"
    if "seven store" in title:
        return "store"
    if "terminal" in title:
        return "terminal"
    return None


def clients_by_tile(clients: list[dict[str, object]]) -> dict[str, list[dict[str, object]]]:
    grouped: dict[str, list[dict[str, object]]] = {}
    for client in clients:
        tile_id = client_tile_id(client)
        if not tile_id:
            continue
        grouped.setdefault(tile_id, []).append(client)
    return grouped


def focus_client(client: dict[str, object]) -> bool:
    address = str(client.get("address") or "").strip()
    if not address or not command_available("hyprctl"):
        return False
    subprocess.run(["hyprctl", "dispatch", "focuswindow", f"address:{address}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
    return True


def focus_tile_window(tile: dict[str, object], grouped_clients: dict[str, list[dict[str, object]]]) -> bool:
    windows = grouped_clients.get(str(tile.get("id", "")), [])
    if not windows:
        return False
    windows = sorted(windows, key=lambda item: int(item.get("focusHistoryID", 9999) or 9999))
    return focus_client(windows[0])


def place_hyprland_window() -> bool:
    if not os.environ.get("HYPRLAND_INSTANCE_SIGNATURE") or not command_available("hyprctl"):
        return False
    try:
        clients = json.loads(subprocess.run(["hyprctl", "clients", "-j"], text=True, capture_output=True, check=False, timeout=0.5).stdout or "[]")
        monitors = json.loads(subprocess.run(["hyprctl", "monitors", "-j"], text=True, capture_output=True, check=False, timeout=0.5).stdout or "[]")
    except Exception:
        return True
    dock = next((client for client in clients if client.get("pid") == os.getpid() or client.get("title") == "Seven Dock"), None)
    if not dock:
        return True
    monitor_id = dock.get("monitor", 0)
    monitor = next((item for item in monitors if item.get("id") == monitor_id), monitors[0] if monitors else {})
    width = int(monitor.get("width", 1920))
    height = int(monitor.get("height", 1080))
    scale = float(monitor.get("scale", 1) or 1)
    mon_x = int(monitor.get("x", 0))
    mon_y = int(monitor.get("y", 0))
    size = dock.get("size", [592, 91])
    dock_w = int(size[0])
    dock_h = int(size[1])
    target_x = mon_x + max(0, int((width / scale - dock_w) / 2))
    target_y = mon_y + max(0, int(height / scale - dock_h - 22))
    address = dock.get("address")
    if address:
        subprocess.run(["hyprctl", "dispatch", "movewindowpixel", f"exact {target_x} {target_y},address:{address}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=0.5)
        if not dock.get("pinned"):
            subprocess.run(["hyprctl", "dispatch", "pin", f"address:{address}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=0.5)
    return False


def monitor_bounds(Gdk=None) -> tuple[int, int]:
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE") and command_available("hyprctl"):
        try:
            monitors = json.loads(
                subprocess.run(["hyprctl", "monitors", "-j"], text=True, capture_output=True, check=False, timeout=0.5).stdout
                or "[]"
            )
            focused = next((item for item in monitors if item.get("focused")), monitors[0] if monitors else {})
            width = int(float(focused.get("width", 1920)) / float(focused.get("scale", 1) or 1))
            height = int(float(focused.get("height", 1080)) / float(focused.get("scale", 1) or 1))
            return max(320, width), max(240, height)
        except Exception:
            pass
    if Gdk:
        screen = Gdk.Screen.get_default()
        if screen:
            return max(320, screen.get_width()), max(240, screen.get_height())
    return 1920, 1080


def dock_dimensions(config: dict[str, object], monitor_width: int) -> tuple[int, int, bool]:
    pinned, folders, system = dock_tiles(config)
    groups = [group for group in (pinned, folders, system) if group]
    tile_count = sum(len(group) for group in groups)
    separator_count = max(0, len(groups) - 1)
    natural_width = DOCK_HORIZONTAL_PADDING + tile_count * DOCK_TILE_STEP + separator_count * DOCK_SEPARATOR_STEP
    max_width = max(320, monitor_width - DOCK_MARGIN * 2)
    width = max(320, min(natural_width, max_width))
    return width, DOCK_HEIGHT, natural_width > max_width


def dock_limits_payload() -> dict[str, object]:
    config = load_config()
    active_profile = active_profile_key()
    monitor_width, monitor_height = monitor_bounds()
    pinned, folders, system = dock_tiles(config)
    groups = [group for group in (pinned, folders, system) if group]
    width, height, overflow = dock_dimensions(config, monitor_width)
    reserve_space = bool(config.get("reserve_space", True)) and not bool(config.get("autohide", False))
    autohide = bool(config.get("autohide", False))
    layer_shell_available = False
    try:
        import gi

        gi.require_version("GtkLayerShell", "0.1")
        from gi.repository import GtkLayerShell  # noqa: F401

        layer_shell_available = True
    except Exception:
        layer_shell_available = False
    return {
        "schema": "sevenos.dock.limits.v1",
        "monitor": {"width": monitor_width, "height": monitor_height},
        "dock": {
            "width": width,
            "height": height,
            "max_width": max(320, monitor_width - DOCK_MARGIN * 2),
            "margin": DOCK_MARGIN,
            "overflow": overflow,
            "reserve_space": reserve_space,
            "exclusive_zone": height + DOCK_MARGIN if reserve_space else 0,
            "layer_shell_available": layer_shell_available,
            "overlay_fallback": not layer_shell_available,
        },
        "tiles": {
            "pinned": len(pinned),
            "folders": len(folders),
            "system": len(system),
            "total": sum(len(group) for group in groups),
            "separators": max(0, len(groups) - 1),
            "profile_pins": PROFILE_PINNED.get(active_profile, PROFILE_PINNED["equinox"]),
        },
        "config": {
            "position": config.get("position", "bottom"),
            "autohide": bool(config.get("autohide", False)),
            "reserve_space": bool(config.get("reserve_space", True)),
            "magnification": bool(config.get("magnification", True)),
        },
        "scope": {
            "active_profile": active_profile,
            "policy": "visible-on-all-workspaces-until-profile-change",
            "state_file": str(DOCK_STATE_PATH),
        },
        "live": {
            "hyprland_clients": len(hyprland_clients()),
            "features": [
                "window-counts",
                "active-window-state",
                "focus-existing-window",
                "live-unpinned-apps",
                "drag-reorder",
                "file-drop-open",
                "hover-window-preview",
                "spring-loaded-folders",
                "animated-autohide",
                "press-launch-feedback",
                "drag-target-feedback",
            ],
        },
    }


