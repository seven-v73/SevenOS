#!/usr/bin/env python3
"""SevenOS native dock surface."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin").is_dir():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin").is_dir():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin").is_dir():
            return candidate
    return Path.home()


ROOT = resolve_root()
CONFIG_PATH = Path.home() / ".config/sevenos/dock.json"


DEFAULT_CONFIG = {
    "position": "bottom",
    "size": "compact",
    "magnification": True,
    "autohide": False,
    "pinned": ["files", "apps", "browser", "terminal", "spotlight", "hub"],
    "folders": ["downloads", "home"],
}


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def command_available(command: str) -> bool:
    return subprocess.run(["sh", "-lc", f"command -v {command}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0


def load_config() -> dict[str, object]:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        save_config(DEFAULT_CONFIG)
        return dict(DEFAULT_CONFIG)
    try:
        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
    except Exception:
        data = {}
    config = dict(DEFAULT_CONFIG)
    config.update({key: value for key, value in data.items() if key in DEFAULT_CONFIG})
    return config


def save_config(config: dict[str, object]) -> None:
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(config, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


def process_running(names: list[str]) -> bool:
    for name in names:
        result = subprocess.run(
            ["pgrep", "-u", os.environ.get("USER", ""), "-x", name],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            return True
    return False


def notification_count() -> int:
    for command in (["swaync-client", "-c"], ["makoctl", "list"]):
        result = subprocess.run(command, text=True, capture_output=True, check=False)
        if result.returncode == 0 and result.stdout.strip().isdigit():
            return int(result.stdout.strip())
    return 0


def resolve_command(command: list[str]) -> list[str]:
    if not command:
        return []
    local = ROOT / "bin" / command[0]
    if local.exists():
        return [str(local), *command[1:]]
    return command


def run_action(command: list[str]) -> None:
    if not command:
        return
    subprocess.Popen(resolve_command(command), cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def tile_catalog() -> dict[str, dict[str, object]]:
    browser = ["xdg-open", "https://www.google.com"]
    return {
        "files": {"id": "files", "title": "Files", "icon": "system-file-manager", "style": "files", "command": ["seven-files"], "processes": ["seven-files-native", "nautilus"], "kind": "app"},
        "apps": {"id": "apps", "title": "Apps", "icon": "view-app-grid-symbolic", "style": "apps", "command": ["seven-overview", "apps"], "processes": ["seven-launchpad-native"], "kind": "system"},
        "browser": {"id": "browser", "title": "Browser", "icon": "web-browser", "style": "browser", "command": browser, "processes": ["firefox", "brave", "chromium", "google-chrome-stable"], "kind": "app"},
        "terminal": {"id": "terminal", "title": "Terminal", "icon": "utilities-terminal", "style": "terminal", "command": ["seven-terminal", "classic"], "processes": ["seven-terminal-native", "kitty"], "kind": "app"},
        "spotlight": {"id": "spotlight", "title": "Spotlight", "icon": "system-search", "style": "spotlight", "command": ["seven-spotlight"], "processes": ["rofi"], "kind": "system"},
        "hub": {"id": "hub", "title": "Hub", "icon": "preferences-system", "style": "hub", "command": ["seven", "hub"], "processes": ["seven-hub-native"], "kind": "app"},
        "settings": {"id": "settings", "title": "Settings", "icon": "emblem-system", "style": "settings", "command": ["seven-settings"], "processes": ["seven-settings-native", "pavucontrol", "nm-connection-editor"], "kind": "system"},
        "downloads": {"id": "downloads", "title": "Downloads", "icon": "folder-download", "style": "folder", "command": ["xdg-open", str(Path.home() / "Downloads")], "path": str(Path.home() / "Downloads"), "kind": "folder"},
        "home": {"id": "home", "title": "Home", "icon": "user-home", "style": "folder", "command": ["xdg-open", str(Path.home())], "path": str(Path.home()), "kind": "folder"},
    }


def dock_tiles(config: dict[str, object]) -> tuple[list[dict[str, object]], list[dict[str, object]], list[dict[str, object]]]:
    catalog = tile_catalog()
    pinned = [catalog[tile_id] for tile_id in config.get("pinned", []) if tile_id in catalog]
    folders = [catalog[tile_id] for tile_id in config.get("folders", []) if tile_id in catalog]
    system = [catalog["settings"]]
    return pinned, folders, system


def run_dock() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenDockNative")
    GLib.set_application_name("Seven Dock")
    try:
        Gdk.set_program_class("SevenDockNative")
    except Exception:
        pass

    config = load_config()

    css = """
    window.seven-dock {
      background: transparent;
    }
    .dock-shell {
      min-height: 78px;
      padding: 6px 11px 5px 11px;
      border-radius: 25px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.70), rgba(196,225,239,0.36)),
        rgba(255,255,255,0.40);
      border: 1px solid rgba(255,255,255,0.82);
    }
    .dock-tile {
      min-width: 56px;
      min-height: 66px;
      border-radius: 18px;
      background: transparent;
      padding: 0;
    }
    .dock-tile:hover {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.46), rgba(255,255,255,0.18)),
        rgba(255,255,255,0.18);
    }
    .dock-icon {
      min-width: 50px;
      min-height: 50px;
      border-radius: 15px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(230,241,247,0.78)),
        rgba(255,255,255,0.76);
      border: 1px solid rgba(255,255,255,0.78);
    }
    .dock-icon.files {
      background: linear-gradient(180deg, rgba(112,210,255,0.96), rgba(32,132,225,0.88));
    }
    .dock-icon.apps {
      background: linear-gradient(135deg, rgba(255,246,222,0.98), rgba(204,222,238,0.88));
    }
    .dock-icon.browser {
      background: linear-gradient(180deg, rgba(94,192,255,0.96), rgba(43,114,224,0.90));
    }
    .dock-icon.terminal {
      background: linear-gradient(180deg, rgba(70,80,96,0.98), rgba(33,39,50,0.96));
    }
    .dock-icon.spotlight {
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(205,223,238,0.90));
    }
    .dock-icon.hub {
      background: linear-gradient(180deg, rgba(225,202,158,0.98), rgba(125,95,57,0.92));
    }
    .dock-icon.settings {
      background: linear-gradient(180deg, rgba(240,245,248,0.98), rgba(146,160,170,0.88));
    }
    .dock-icon.folder {
      background: linear-gradient(180deg, rgba(112,210,255,0.98), rgba(72,154,224,0.90));
    }
    .dock-dot {
      min-width: 5px;
      min-height: 5px;
      border-radius: 999px;
      background: rgba(24, 36, 47, 0.82);
      margin-top: 4px;
    }
    .dock-dot.idle {
      background: transparent;
    }
    .dock-badge {
      min-width: 17px;
      min-height: 17px;
      border-radius: 999px;
      padding: 0 5px;
      color: white;
      background: rgba(214, 58, 52, 0.96);
      font-size: 10px;
      font-weight: 500;
      margin-left: 36px;
      margin-bottom: -18px;
    }
    .dock-separator {
      min-width: 1px;
      min-height: 40px;
      margin: 9px 3px 0 3px;
      background: rgba(34, 49, 59, 0.18);
    }
    """

    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title="Seven Dock")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_skip_taskbar_hint(True)
    window.set_skip_pager_hint(True)
    window.set_wmclass("SevenDockNative", "SevenDockNative")
    window.get_style_context().add_class("seven-dock")

    try:
        import gi as _gi

        _gi.require_version("GtkLayerShell", "0.1")
        from gi.repository import GtkLayerShell

        GtkLayerShell.init_for_window(window)
        GtkLayerShell.set_layer(window, GtkLayerShell.Layer.TOP)
        GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.BOTTOM, True)
        GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.LEFT, False)
        GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.RIGHT, False)
        GtkLayerShell.set_margin(window, GtkLayerShell.Edge.BOTTOM, 11)
        GtkLayerShell.set_keyboard_interactivity(window, False)
    except Exception:
        window.set_position(Gtk.WindowPosition.CENTER)

    shell = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=5)
    shell.get_style_context().add_class("dock-shell")
    window.add(shell)

    pinned_tiles, folder_tiles, system_tiles = dock_tiles(config)
    for group_index, group in enumerate((pinned_tiles, folder_tiles, system_tiles)):
        if group_index > 0 and group:
            separator = Gtk.Box()
            separator.get_style_context().add_class("dock-separator")
            shell.pack_start(separator, False, False, 0)
        for tile in group:
            add_tile(shell, tile, config, Gtk, Gdk)

    window.connect("destroy", Gtk.main_quit)
    window.show_all()
    window.resize(540, 82)
    Gtk.main()
    return 0


def add_tile(shell, tile: dict[str, object], config: dict[str, object], Gtk, Gdk) -> None:
    event = Gtk.EventBox()
    event.set_visible_window(False)
    event.set_tooltip_text(str(tile["title"]))
    event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
    event.connect("button-press-event", lambda widget, event_data, dock_tile=tile: on_tile_click(widget, event_data, dock_tile, config, Gtk))

    button_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    button_box.set_halign(Gtk.Align.CENTER)
    button_box.get_style_context().add_class("dock-tile")

    icon_stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    icon_stack.set_halign(Gtk.Align.CENTER)

    badge_count = notification_count() if tile.get("id") == "hub" else 0
    if badge_count > 0:
        badge = Gtk.Label(label=str(min(badge_count, 99)))
        badge.set_halign(Gtk.Align.END)
        badge.get_style_context().add_class("dock-badge")
        icon_stack.pack_start(badge, False, False, 0)

    icon_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    icon_box.set_halign(Gtk.Align.CENTER)
    icon_box.set_valign(Gtk.Align.CENTER)
    icon_box.get_style_context().add_class("dock-icon")
    icon_box.get_style_context().add_class(str(tile.get("style", "default")))
    icon = Gtk.Image.new_from_icon_name(str(tile["icon"]), Gtk.IconSize.DIALOG)
    icon.set_pixel_size(34)
    icon_box.pack_start(icon, True, True, 0)
    icon_stack.pack_start(icon_box, False, False, 0)

    event.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
    event.connect("enter-notify-event", lambda _widget, _event, image=icon, box=icon_box: magnify_tile(image, box, True))
    event.connect("leave-notify-event", lambda _widget, _event, image=icon, box=icon_box: magnify_tile(image, box, False))

    dot = Gtk.Box()
    dot.get_style_context().add_class("dock-dot")
    if not tile_running(tile):
        dot.get_style_context().add_class("idle")
    dot.set_halign(Gtk.Align.CENTER)

    button_box.pack_start(icon_stack, False, False, 0)
    button_box.pack_start(dot, False, False, 0)
    event.add(button_box)
    shell.pack_start(event, False, False, 0)


def magnify_tile(icon, icon_box, active: bool) -> bool:
    icon.set_pixel_size(39 if active else 34)
    icon_box.set_size_request(56 if active else 50, 56 if active else 50)
    return False


def tile_running(tile: dict[str, object]) -> bool:
    if tile.get("kind") == "folder":
        return False
    processes = [str(process) for process in tile.get("processes", [])]
    return process_running(processes)


def on_tile_click(widget, event, tile: dict[str, object], config: dict[str, object], Gtk) -> bool:
    if getattr(event, "button", 0) == 1 and isinstance(tile.get("command"), list):
        run_action([str(part) for part in tile["command"]])
        return True
    if getattr(event, "button", 0) == 3:
        show_context_menu(widget, tile, config, Gtk, event)
        return True
    return False


def show_context_menu(widget, tile: dict[str, object], config: dict[str, object], Gtk, event) -> None:
    menu = Gtk.Menu()

    def item(label: str, callback) -> None:
        menu_item = Gtk.MenuItem(label=label)
        menu_item.connect("activate", lambda _item: callback())
        menu.append(menu_item)

    item(f"Open {tile.get('title', 'Item')}", lambda: run_action([str(part) for part in tile.get("command", [])]))

    if tile.get("kind") == "folder":
        path = str(tile.get("path", Path.home()))
        item("Open in Seven Files", lambda: run_action(["seven-files", path]))
        item("Reveal in Files", lambda: run_action(["xdg-open", path]))
    else:
        item("Show Windows", lambda: run_action(["seven-overview", "windows"]))
        if tile_running(tile):
            processes = [str(process) for process in tile.get("processes", [])]
            item("Quit", lambda: quit_processes(processes, force=False))
            item("Force Quit", lambda: quit_processes(processes, force=True))

    tile_id = str(tile.get("id", ""))
    pinned = [str(item_id) for item_id in config.get("pinned", [])]
    if tile.get("kind") == "app" or tile.get("kind") == "system":
        if tile_id in pinned:
            item("Remove from Dock", lambda: update_pinned(tile_id, keep=False))
        else:
            item("Keep in Dock", lambda: update_pinned(tile_id, keep=True))

    item("Dock Settings", lambda: run_action(["seven-dock", "settings"]))
    menu.show_all()
    try:
        menu.popup_at_pointer(event)
    except Exception:
        menu.popup(None, None, None, None, getattr(event, "button", 3), getattr(event, "time", 0))


def quit_processes(processes: list[str], force: bool) -> None:
    signal = "-9" if force else "-TERM"
    for process in processes:
        subprocess.run(["pkill", signal, "-u", os.environ.get("USER", ""), "-x", process], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


def update_pinned(tile_id: str, keep: bool) -> None:
    config = load_config()
    pinned = [str(item) for item in config.get("pinned", [])]
    if keep and tile_id not in pinned:
        pinned.append(tile_id)
    if not keep:
        pinned = [item for item in pinned if item != tile_id]
    config["pinned"] = pinned
    save_config(config)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    args = parser.parse_args()
    if args.probe:
        return probe()
    return run_dock()


if __name__ == "__main__":
    raise SystemExit(main())
