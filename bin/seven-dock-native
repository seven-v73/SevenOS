        "downloads": {"id": "downloads", "title": tr_text("Downloads"), "icon": "folder-download", "style": "folder", "command": ["xdg-open", str(Path.home() / "Downloads")], "path": str(Path.home() / "Downloads"), "kind": "folder"},
        "home": {"id": "home", "title": tr_text("Home"), "icon": "user-home", "style": "folder", "command": ["xdg-open", str(Path.home())], "path": str(Path.home()), "kind": "folder"},
    }


def effective_pinned_ids(config: dict[str, object], profile: str | None = None) -> list[str]:
    profile = profile or active_profile_key()
    profile_pins = config.get("profile_pins", {})
    if isinstance(profile_pins, dict) and isinstance(profile_pins.get(profile), list):
        base_ids = [str(item) for item in profile_pins.get(profile, [])]
    else:
        base_ids = list(PROFILE_PINNED.get(profile, PROFILE_PINNED["equinox"]))
    for tile_id in config.get("pinned", []):
        tile_id = str(tile_id)
        if tile_id not in base_ids:
            base_ids.append(tile_id)
    return list(dict.fromkeys(base_ids))


def save_profile_pins(config: dict[str, object], profile: str, pinned_ids: list[str]) -> None:
    profile_pins = config.get("profile_pins", {})
    if not isinstance(profile_pins, dict):
        profile_pins = {}
    profile_pins[profile] = list(dict.fromkeys(pinned_ids))
    config["profile_pins"] = profile_pins
    save_config(config)


def dock_tiles(config: dict[str, object]) -> tuple[list[dict[str, object]], list[dict[str, object]], list[dict[str, object]]]:
    catalog = tile_catalog()
    pinned = [catalog[tile_id] for tile_id in effective_pinned_ids(config) if tile_id in catalog]
    folders = [catalog[tile_id] for tile_id in config.get("folders", []) if tile_id in catalog]
    system = [catalog["settings"]]
    return pinned, folders, system


def enrich_tile(tile: dict[str, object], grouped_clients: dict[str, list[dict[str, object]]]) -> dict[str, object]:
    enriched = dict(tile)
    tile_id = str(tile.get("id", ""))
    windows = grouped_clients.get(tile_id, [])
    active = any(int(client.get("focusHistoryID", 9999) or 9999) == 0 for client in windows)
    enriched["window_count"] = len(windows)
    enriched["active"] = active
    enriched["launching"] = time.monotonic() - LAUNCHING.get(tile_id, 0) < LAUNCHING_TTL
    enriched["available"] = tile.get("kind") == "folder" or command_ready([str(part) for part in tile.get("command", [])])
    return enriched


def tile_groups(config: dict[str, object], grouped_clients: dict[str, list[dict[str, object]]]) -> tuple[list[dict[str, object]], list[dict[str, object]], list[dict[str, object]], list[dict[str, object]]]:
    catalog = tile_catalog()
    pinned, folders, system = dock_tiles(config)
    known_ids = {str(tile.get("id", "")) for group in (pinned, folders, system) for tile in group}
    live = [
        catalog[tile_id]
        for tile_id, windows in grouped_clients.items()
        if tile_id in catalog and tile_id not in known_ids and windows
    ]
    order = {tile_id: index for index, tile_id in enumerate(["browser", "terminal", "files", "reader", "store", "studio", "shield", "windows"])}
    live.sort(key=lambda tile: order.get(str(tile.get("id", "")), 99))
    return (
        [enrich_tile(tile, grouped_clients) for tile in pinned],
        [enrich_tile(tile, grouped_clients) for tile in live],
        [enrich_tile(tile, grouped_clients) for tile in folders],
        [enrich_tile(tile, grouped_clients) for tile in system],
    )


def run_dock() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenDockNative")
    GLib.set_application_name("Seven Dock")
    try:
        Gdk.set_program_class("SevenDockNative")
    except Exception:
        pass

    config = load_config()
    bound_profile = active_profile_key()
    monitor_width, monitor_height = monitor_bounds(Gdk)
    dock_width, dock_height, dock_overflow = dock_dimensions(config, monitor_width)
    reserve_space = bool(config.get("reserve_space", True)) and not bool(config.get("autohide", False))
    autohide = bool(config.get("autohide", False))

    css = seven_theme.gtk_app_css("dock") + """
    * { font-family: "SF Pro Display", "SF UI Display", "San Francisco", system-ui, sans-serif; }
    window.seven-dock {
      background: transparent;
    }
    .dock-shell {
      min-height: 78px;
      padding: 6px 11px 5px 11px;
      border-radius: 25px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.70), rgba(196,225,239,0.36)),
        rgba(255,255,255,0.40);
      border: 1px solid rgba(255,255,255,0.82);
      transition: background 150ms ease-out, border-color 150ms ease-out;
    }
    .dock-tile {
      min-width: 56px;
      min-height: 66px;
      border-radius: 18px;
      background: transparent;
      padding: 0;
      transition: background 120ms ease-out, opacity 120ms ease-out;
    }
    .dock-tile:hover {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.46), rgba(255,255,255,0.18)),
        rgba(255,255,255,0.18);
    }
    .dock-tile.running .dock-icon {
      border-color: rgba(77,163,255,0.82);
    }
    .dock-tile.active {
      background: rgba(77,163,255,0.15);
    }
    .dock-tile.pressed {
      background:
        linear-gradient(180deg, rgba(47,123,255,0.20), rgba(255,255,255,0.16)),
        rgba(47,123,255,0.12);
    }
    .dock-tile.launching .dock-icon {
      border-color: rgba(249,226,175,0.88);
    }
    .dock-tile.launch-feedback .dock-icon {
      border-color: rgba(249,226,175,0.96);
      background:
        linear-gradient(180deg, rgba(255,246,215,0.98), rgba(255,255,255,0.74)),
