#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT/hyprland/rofi" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/../hyprland/rofi" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -d "$candidate/hyprland/rofi" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-apps: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
THEME="$CONFIG_HOME/rofi/apps.rasi"
action="${1:-open}"
format="${2:-}"
if [[ "$format" == "--json" && "$action" == "list" ]]; then
  action="json"
fi

catalog() {
  ROOT_DIR="$ROOT_DIR" python - <<'PY'
from importlib.machinery import SourceFileLoader
import os
from pathlib import Path

root = Path(os.environ["ROOT_DIR"])
module = SourceFileLoader("seven_launchpad_native", str(root / "bin/seven-launchpad-native")).load_module()
for app in module.load_apps():
    values = [
        app.get("name", ""),
        app.get("desktop_id", ""),
        app.get("path", ""),
        app.get("comment", ""),
        app.get("categories", ""),
        app.get("icon", ""),
    ]
    print("\t".join(str(value).replace("\t", " ") for value in values))
PY
}

catalog_json() {
  catalog | python -c '
import json
import sys

apps = []
for line in sys.stdin:
    parts = line.rstrip("\n").split("\t")
    if len(parts) < 6:
        continue
    name, desktop_id, path, comment, categories, icon = parts[:6]
    category_items = [item for item in categories.split(";") if item]
    apps.append(
        {
            "name": name,
            "desktop_id": desktop_id,
            "path": path,
            "comment": comment,
            "categories": category_items,
            "icon": icon,
        }
    )

print(json.dumps({"schema": "sevenos.apps.v1", "count": len(apps), "apps": apps}, ensure_ascii=False, indent=2))
'
}

launch_desktop() {
  local desktop_id="$1"
  local desktop_path="$2"

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'launch %q %q\n' "$desktop_id" "$desktop_path"
    return 0
  fi

  if command -v gtk-launch >/dev/null 2>&1; then
    gtk-launch "${desktop_id%.desktop}" >/dev/null 2>&1 && return 0
    gtk-launch "$desktop_id" >/dev/null 2>&1 && return 0
  fi

  if command -v gio >/dev/null 2>&1; then
    gio launch "$desktop_path" >/dev/null 2>&1 && return 0
  fi

  if command -v dex >/dev/null 2>&1; then
    dex "$desktop_path" >/dev/null 2>&1 && return 0
  fi

  printf 'seven-apps: could not launch %s\n' "$desktop_id" >&2
  return 1
}

close_existing_launchpad() {
  command -v hyprctl >/dev/null 2>&1 || return 1
  python - <<'PY'
import json
import subprocess
import sys

try:
    result = subprocess.run(["hyprctl", "clients", "-j"], capture_output=True, text=True, check=False)
    clients = json.loads(result.stdout or "[]")
except Exception:
    sys.exit(1)

for client in clients:
    if client.get("class") != "SevenLaunchpadNative":
        continue
    address = str(client.get("address", "")).strip()
    if not address:
        continue
    subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{address}"], check=False)
    sys.exit(0)

sys.exit(1)
PY
}

open_apps() {
  local catalog_file menu_file selected_index selected_line desktop_id desktop_path native
  native="$ROOT_DIR/bin/seven-launchpad-native"

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    catalog_file="$(mktemp)"
    trap 'rm -f "$catalog_file"' RETURN
    catalog > "$catalog_file"
    printf 'seven-apps catalog %s applications\n' "$(wc -l < "$catalog_file")"
    printf 'native Launchpad if GTK is available, Rofi fallback with %q and desktop icon metadata\n' "$THEME"
    return 0
  fi

  if close_existing_launchpad; then
    return 0
  fi

  if [[ -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
    exec "$native"
  fi

  catalog_file="$(mktemp)"
  menu_file="$(mktemp)"
  trap 'rm -f "$catalog_file" "$menu_file"' RETURN
  catalog > "$catalog_file"

  if ! command -v rofi >/dev/null 2>&1; then
    printf 'seven-apps: rofi is required for the graphical app launcher\n' >&2
    exit 1
  fi

  python - "$catalog_file" > "$menu_file" <<'PY'
import sys

def fallback_icon(categories):
    cats = {item for item in categories.split(";") if item}
    if "Development" in cats:
        return "applications-development"
    if "Graphics" in cats or "AudioVideo" in cats:
        return "applications-graphics"
    if "Network" in cats:
        return "applications-internet"
    if "System" in cats or "Settings" in cats:
        return "preferences-system"
    if "Utility" in cats:
        return "applications-utilities"
    if "Game" in cats:
        return "applications-games"
    if "Office" in cats:
        return "applications-office"
    return "application-x-executable"

with open(sys.argv[1], "r", encoding="utf-8", errors="replace") as handle:
    for line in handle:
        parts = line.rstrip("\n").split("\t")
        if len(parts) < 6:
            continue
        name, desktop_id, _path, _comment, _categories, icon = parts[:6]
        if not icon or icon == "application-x-executable":
            icon = fallback_icon(_categories)
        label = name
        print(f"{label}\0icon\x1f{icon}")
PY

  selected_index="$(
    rofi -dmenu -show-icons -p "Apps" -mesg "SevenOS application library" -format i -theme "$THEME" < "$menu_file" 2>/dev/null || true
  )"

  [[ "$selected_index" =~ ^[0-9]+$ ]] || exit 0
  selected_line="$(sed -n "$((selected_index + 1))p" "$catalog_file")"
  [[ -n "$selected_line" ]] || exit 0

  desktop_id="$(printf '%s\n' "$selected_line" | awk -F '\t' '{print $2}')"
  desktop_path="$(printf '%s\n' "$selected_line" | awk -F '\t' '{print $3}')"
  launch_desktop "$desktop_id" "$desktop_path"
}

case "$action" in
  open|apps|launchpad)
    open_apps
    ;;
  list)
    catalog
    ;;
  json)
    catalog_json
    ;;
  refresh)
    "$ROOT_DIR/bin/seven-launchpad-native" --refresh
    ;;
  count)
    catalog | wc -l
    ;;
  doctor)
    if [[ "$format" == "--json" ]]; then
      "$ROOT_DIR/bin/seven-launchpad-native" --doctor --json
      exit $?
    fi
    count="$(catalog | wc -l)"
    printf 'SevenOS Apps: %s desktop applications indexed\n' "$count"
    if [[ "$count" -eq 0 ]]; then
      printf 'No .desktop applications found. Check XDG_DATA_DIRS and installed packages.\n' >&2
      exit 1
    fi
    ;;
  *)
    printf 'Usage: seven-apps [open|list|json|refresh|count|doctor]\n' >&2
    exit 2
    ;;
esac
