#!/usr/bin/env python3
"""SevenOS native notification center.

This surface is intentionally content-first: notifications are the main body,
while controls live as compact icon buttons. Rofi remains only a fallback in
the caller when GTK is unavailable.
"""

from __future__ import annotations

import json
import os
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven-waybar-notifications").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven-waybar-notifications").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven-waybar-notifications").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr_text  # noqa: E402
import seven_theme  # noqa: E402

STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "sevenos"
DND_FILE = STATE_DIR / "notifications.dnd"


@dataclass
class Notification:
    app: str
    title: str
    body: str


def run_notification_action(action: str) -> None:
    command = ROOT / "bin/seven-waybar-notifications"
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_NOTIFICATIONS_NATIVE": "0"}
    subprocess.Popen(
        [str(command), action],
        cwd=ROOT,
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def dismiss_all_notifications() -> None:
    if command_available("swaync-client"):
        subprocess.run(["timeout", "1s", "swaync-client", "-sw", "-C"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        subprocess.run(["timeout", "1s", "swaync-client", "-C"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
    if command_available("makoctl"):
        subprocess.run(["makoctl", "dismiss", "--all"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


def dnd_enabled() -> bool:
    return DND_FILE.exists()


def command_available(command: str) -> bool:
    return subprocess.run(["bash", "-lc", f"command -v {command} >/dev/null 2>&1"], check=False).returncode == 0


def mako_running() -> bool:
    return subprocess.run(["pgrep", "-x", "mako"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0


def swaync_running() -> bool:
    return subprocess.run(["pgrep", "-x", "swaync"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0


def backend_state() -> tuple[str, str]:
    if not command_available("mako") and not command_available("swaync"):
        return "missing", tr_text("Service missing")
    if swaync_running():
        return "running", tr_text("Ready")
    if mako_running():
        return "running", tr_text("Ready")
    return "inactive", tr_text("Service stopped")


def _walk_notifications(value: object, rows: list[Notification]) -> None:
    if isinstance(value, dict):
        summary = str(value.get("summary") or value.get("title") or "").strip()
        body = str(value.get("body") or value.get("text") or "").strip()
        app = str(value.get("app-name") or value.get("app_name") or value.get("app") or "Notification").strip()
        if summary or body:
            rows.append(Notification(app=app or tr_text("Notifications"), title=summary or app or tr_text("Notifications"), body=body))
        for child in value.values():
            _walk_notifications(child, rows)
    elif isinstance(value, list):
        for child in value:
            _walk_notifications(child, rows)


def load_notifications() -> list[Notification]:
    if command_available("swaync-client"):
        result = subprocess.run(
            ["timeout", "0.8s", "swaync-client", "-sw", "-c"],
            text=True,
            capture_output=True,
            check=False,
        )
        count = result.stdout.strip()
        if count.isdigit() and int(count) > 0:
            return [
                Notification(
                    app=tr_text("Notification Center"),
                    title=tr_text("{count} active", count=int(count)),
                    body=tr_text("Use the clear button to dismiss all visible notifications."),
                )
            ]

    if not command_available("makoctl"):
        return []
    result = subprocess.run(["makoctl", "list"], text=True, capture_output=True, check=False)
    raw = result.stdout.strip()
    if not raw or raw in {"[]", "{}"}:
        return []
    rows: list[Notification] = []
    try:
        _walk_notifications(json.loads(raw), rows)
    except Exception:
        for line in raw.splitlines():
            clean = re.sub(r"\s+", " ", line).strip()
            if clean and clean not in {"[]", "{}"}:
                rows.append(Notification(app=tr_text("Notifications"), title=clean[:72], body=""))
    seen: set[tuple[str, str, str]] = set()
    unique: list[Notification] = []
    for row in rows:
        key = (row.app, row.title, row.body)
        if key in seen:
            continue
        seen.add(key)
        unique.append(row)
    return unique[:7]


def visible_notification_count(rows: list[Notification]) -> int:
    if rows and rows[0].app == tr_text("Notification Center"):
        match = re.search(r"\d+", rows[0].title)
        if match:
            return int(match.group(0))
    return len(rows)

def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenNotificationCenterNative")
    GLib.set_application_name(f"SevenOS {tr_text('Notifications')}")
    try:
        Gdk.set_program_class("SevenNotificationCenterNative")
    except Exception:
        pass

    css = seven_theme.gtk_app_css("notification-center") + """
    * { font-family: "SF Pro Display", "SF UI Display", "San Francisco", system-ui, sans-serif; }
    window.notification-center-window { background: transparent; }
    .notification-root {
      padding: 18px;
      border-radius: 30px;
      background:
        radial-gradient(ellipse at 14% 0%, alpha(@seven_wallpaper_accent, 0.14), transparent 42%),
        radial-gradient(ellipse at 86% 0%, alpha(@seven_wallpaper_secondary, 0.10), transparent 40%),
        @seven_panel;
      border: 1px solid @seven_border;
    }
    .header {
      padding: 2px 2px 14px 2px;
    }
    .header-title {
      color: @seven_text;
      font-size: 19px;
      font-weight: 500;
    }
    .header-subtitle {
      color: @seven_muted;
      font-size: 12px;
    }
    .dnd-pill {
      min-height: 30px;
      padding: 0 12px;
      border-radius: 999px;
      background: alpha(@seven_text, 0.065);
      border: 1px solid @seven_border;
      color: @seven_text;
      font-size: 11px;
      font-weight: 500;
    }
    .header-action,
    .close-action {
      min-width: 34px;
      min-height: 34px;
      padding: 0;
      border-radius: 999px;
      background: alpha(@seven_text, 0.055);
      border: 1px solid @seven_border;
      color: @seven_text;
      font-size: 15px;
      font-weight: 500;
    }
    .header-action:hover,
    .close-action:hover {
      background: alpha(@seven_accent, 0.12);
      border-color: alpha(@seven_accent, 0.26);
    }
    .content-frame {
      min-height: 338px;
      margin-top: 2px;
      margin-bottom: 10px;
    }
    .notification-card {
      min-height: 84px;
      padding: 13px;
      margin-bottom: 9px;
      border-radius: 22px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .notification-card:hover {
      background: @seven_hover;
      border-color: alpha(@seven_accent, 0.28);
    }
    .notification-icon {
      min-width: 42px;
      min-height: 42px;
      border-radius: 14px;
      background: alpha(@seven_accent, 0.12);
      color: @seven_accent;
      font-size: 17px;
    }
    .notification-title {
      color: @seven_text;
      font-size: 14px;
      font-weight: 500;
    }
    .notification-body,
    .notification-app {
      color: @seven_muted;
      font-size: 11px;
    }
    .empty-box {
      min-height: 320px;
      padding: 24px;
      border-radius: 24px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .empty-glyph {
      color: rgba(64,88,104,0.72);
      font-size: 44px;
    }
    .empty-title {
      color: rgba(16,27,34,0.92);
      font-size: 16px;
      font-weight: 500;
    }
    .empty-subtitle {
      color: rgba(43,58,68,0.58);
      font-size: 12px;
    }
    .primary-action {
      min-height: 34px;
      padding: 0 15px;
      border-radius: 999px;
      background: rgba(255,255,255,0.72);
      border: 1px solid rgba(91,127,166,0.28);
      color: rgba(16,27,34,0.92);
      font-size: 12px;
      font-weight: 500;
    }
    .primary-action:hover {
      background: rgba(255,255,255,0.94);
    }
    .action-strip {
      padding-top: 2px;
    }
    .action-button {
      min-width: 52px;
      min-height: 42px;
      padding: 0;
      border-radius: 16px;
      background: rgba(255,255,255,0.56);
      border: 1px solid rgba(255,255,255,0.76);
      color: rgba(24,39,49,0.86);
    }
    .action-button:hover {
      background: rgba(255,255,255,0.86);
      border-color: rgba(91,127,166,0.30);
    }
    .action-glyph {
      font-size: 17px;
      font-weight: 500;
    }
    """
    if seven_theme.current_theme_mode() == "dark":
        css += """
        .notification-root {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.035)),
            rgba(16,18,25,0.94);
          border-color: rgba(255,255,255,0.12);
        }
        .header-title, .notification-title, .empty-title, .primary-action { color: rgba(245,247,250,0.96); }
        .header-subtitle, .notification-body, .notification-app, .empty-subtitle { color: rgba(245,247,250,0.60); }
        .dnd-pill, .notification-card, .empty-box, .primary-action, .action-button, .header-action, .close-action {
          background: rgba(255,255,255,0.07);
          border-color: rgba(255,255,255,0.10);
          color: rgba(245,247,250,0.88);
        }
        .notification-card:hover, .primary-action:hover, .action-button:hover, .header-action:hover, .close-action:hover {
          background: rgba(77,163,255,0.13);
          border-color: rgba(77,163,255,0.24);
        }
        .notification-icon, .empty-glyph { color: rgba(126,206,255,0.86); background: rgba(77,163,255,0.12); }
        """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    state_key, state_label = backend_state()
    notifications = load_notifications()
    notification_count = visible_notification_count(notifications)

    window = Gtk.Window(title=f"SevenOS {tr_text('Notifications')}")
    window.set_wmclass("SevenNotificationCenterNative", "SevenNotificationCenterNative")
    window.set_decorated(False)
    window.set_resizable(False)
    if os.environ.get("SEVENOS_NOTIFICATION_CENTER_KEEP_ABOVE") == "1":
        window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(460, 540)
    window.get_style_context().add_class("notification-center-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    root.get_style_context().add_class("notification-root")
    window.add(root)

    header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    header.get_style_context().add_class("header")
    root.pack_start(header, False, False, 0)

    title_stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
    title = Gtk.Label(label=tr_text("Notifications"), xalign=0)
    title.get_style_context().add_class("header-title")
    title_stack.pack_start(title, False, False, 0)
    subtitle_text = tr_text("{count} active", count=notification_count) if notifications else state_label
    subtitle = Gtk.Label(label=subtitle_text, xalign=0)
    subtitle.get_style_context().add_class("header-subtitle")
    title_stack.pack_start(subtitle, False, False, 0)
    header.pack_start(title_stack, True, True, 0)

    dnd = Gtk.Label(label=tr_text("Focus On") if dnd_enabled() else tr_text("Focus Off"))
    dnd.get_style_context().add_class("dnd-pill")
    header.pack_end(dnd, False, False, 0)

    close_button = build_header_button(Gtk, "×", tr_text("Close"), lambda _button: window.destroy(), "close-action")
    header.pack_end(close_button, False, False, 0)

    if notifications:
        clear_button = build_header_button(
            Gtk,
            "⌫",
            tr_text("Dismiss visible notifications"),
            lambda _button: on_action_clicked(window, GLib, "dismiss"),
            "header-action",
        )
        header.pack_end(clear_button, False, False, 0)

    if notifications:
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_min_content_height(338)
        scroll.set_max_content_height(338)
        scroll.get_style_context().add_class("content-frame")
        list_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        scroll.add(list_box)
        root.pack_start(scroll, True, True, 0)
        for item in notifications:
            list_box.pack_start(build_notification_card(Gtk, item), False, False, 0)
    else:
        root.pack_start(build_empty_state(Gtk, state_key), True, True, 0)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
    actions.set_halign(Gtk.Align.CENTER)
    actions.get_style_context().add_class("action-strip")
    root.pack_end(actions, False, False, 0)

    actions_model = [
        ("+", tr_text("Send test notification"), "test"),
        ("↺", tr_text("Restore last notification"), "restore"),
        ("☾", tr_text("Toggle Do Not Disturb"), "toggle-dnd"),
        ("⟳", tr_text("Restart notification service"), "restart"),
    ]
    for glyph, tooltip, action in actions_model:
        button = Gtk.Button()
        button.get_style_context().add_class("action-button")
        button.set_tooltip_text(tooltip)
        label = Gtk.Label(label=glyph)
        label.get_style_context().add_class("action-glyph")
        button.add(label)
        button.connect("clicked", lambda _button, act=action: on_action_clicked(window, GLib, act))
        actions.pack_start(button, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect(
        "focus-out-event",
        lambda *_args: False if os.environ.get("SEVENOS_NOTIFICATION_CENTER_STICKY") == "1" else (GLib.timeout_add(180, lambda: (Gtk.main_quit(), False)[1]), False)[1],
    )
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def build_header_button(Gtk, glyph: str, tooltip: str, callback, style_class: str):
    button = Gtk.Button()
    button.get_style_context().add_class(style_class)
    button.set_tooltip_text(tooltip)
    label = Gtk.Label(label=glyph)
    label.get_style_context().add_class("action-glyph")
    button.add(label)
    button.connect("clicked", callback)
    return button


def on_action_clicked(window, GLib, action: str) -> None:
    if action == "dismiss":
        dismiss_all_notifications()
    else:
        run_notification_action(action)
    if action in {"dismiss", "restore", "toggle-dnd", "start", "restart"}:
        GLib.timeout_add(450, lambda: (window.destroy(), False)[1])


def build_notification_card(Gtk, item: Notification):
    card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    card.get_style_context().add_class("notification-card")

    icon = Gtk.Label(label="!")
    icon.get_style_context().add_class("notification-icon")
    card.pack_start(icon, False, False, 0)

    text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    title = Gtk.Label(label=item.title, xalign=0)
    title.set_ellipsize(3)
    title.get_style_context().add_class("notification-title")
    text.pack_start(title, False, False, 0)
    app = Gtk.Label(label=item.app, xalign=0)
    app.get_style_context().add_class("notification-app")
    text.pack_start(app, False, False, 0)
    if item.body:
        body = Gtk.Label(label=item.body, xalign=0)
        body.set_ellipsize(3)
        body.set_line_wrap(True)
        body.set_max_width_chars(48)
        body.get_style_context().add_class("notification-body")
        text.pack_start(body, False, False, 0)
    card.pack_start(text, True, True, 0)
    return card


def build_empty_state(Gtk, state_key: str):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    box.set_valign(Gtk.Align.CENTER)
    box.set_halign(Gtk.Align.FILL)
    box.get_style_context().add_class("empty-box")

    if state_key == "missing":
        glyph_text = "!"
        title_text = tr_text("Notification backend missing")
        subtitle_text = tr_text("Install SwayNC or Mako to receive alerts and make this center live.")
        primary_label = tr_text("Install")
        primary_action = "install"
    elif state_key == "inactive":
        glyph_text = "▶"
        title_text = tr_text("Notifications are stopped")
        subtitle_text = tr_text("Start the notification service to receive system alerts.")
        primary_label = tr_text("Start")
        primary_action = "start"
    else:
        glyph_text = "◌"
        title_text = tr_text("No notifications")
        subtitle_text = tr_text("SevenOS will surface important events here.")
        primary_label = tr_text("Test")
        primary_action = "test"

    glyph = Gtk.Label(label=glyph_text)
    glyph.get_style_context().add_class("empty-glyph")
    box.pack_start(glyph, False, False, 0)
    title = Gtk.Label(label=title_text)
    title.get_style_context().add_class("empty-title")
    box.pack_start(title, False, False, 0)
    subtitle = Gtk.Label(label=subtitle_text)
    subtitle.get_style_context().add_class("empty-subtitle")
    box.pack_start(subtitle, False, False, 0)
    primary = Gtk.Button(label=primary_label)
    primary.get_style_context().add_class("primary-action")
    primary.connect("clicked", lambda _button, act=primary_action: run_notification_action(act))
    box.pack_start(primary, False, False, 8)
    return box


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    return run()


if __name__ == "__main__":
    raise SystemExit(main())
