render_specialized_style() {
  local key="$1"
  PROFILE_KEY="$key" python - <<'PY'
import os

key = os.environ["PROFILE_KEY"]
common = """
* {
  border: none;
  border-radius: 0;
  min-height: 0;
  font-family: "Noto Sans", "Noto Sans Symbols", "Noto Color Emoji", sans-serif;
}

#custom-wifi.connected,
#custom-bluetooth.connected,
#custom-bluetooth.on,
#custom-vpn.active,
#custom-gamemode {
  color: @accent;
}

#custom-wifi.idle,
#custom-wifi.weak,
#custom-bluetooth.off {
  color: @warn;
}

#custom-wifi.missing,
#custom-wifi.off,
#custom-bluetooth.missing,
#battery.critical {
  color: @danger;
}

#custom-vpn.hidden,
#custom-recorder.hidden,
#custom-media.stopped,
#custom-media.paused {
  opacity: 0.36;
}

tooltip {
  background: @tooltip_bg;
  color: @text;
  border: 1px solid @line;
  border-radius: @radius;
}
"""

styles = {
    "forge": {
        "accent": "#F6B44B",
        "warn": "#F9E2AF",
        "danger": "#FF6B5E",
        "text": "#F8EEDB",
        "tooltip_bg": "rgba(24, 20, 16, 0.96)",
        "line": "rgba(246, 180, 75, 0.42)",
        "radius": "3px",
        "css": """
window#waybar {
  background: linear-gradient(90deg, rgba(15, 14, 12, 0.94), rgba(38, 28, 18, 0.94));
  color: @text;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  border-bottom: 2px solid @accent;
}

#custom-identity {
  background: @accent;
  color: #15120E;
  font-weight: 800;
  font-size: 12px;
  margin: 4px 0 4px 6px;
  padding: 0 16px;
  border-radius: 2px 0 0 2px;
}

#custom-project,
#custom-context,
#custom-containers,
