    catalog = json.loads((root / "profiles/catalog.json").read_text(encoding="utf-8"))
except Exception:
    catalog = {}
catalog_profile = (catalog.get("profiles") or {}).get(key, {})
state_dir = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
try:
