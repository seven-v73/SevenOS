apply_profile() {
  local mode config_base style_base key profile_ui
  key="$(profile_key)"
  profile_ui="$CONFIG_HOME/sevenos/profiles/$key/profile-ui.json"
  mode="$(theme_mode)"
  config_base="$(base_config "$mode")"
  style_base="$(base_style "$mode")"
  local profile_waybar_config="$CONFIG_HOME/sevenos/profiles/$key/baobab/waybar/config.jsonc"
  local profile_waybar_style="$CONFIG_HOME/sevenos/profiles/$key/baobab/waybar/style.css"
  local profile_fontconfig="$CONFIG_HOME/sevenos/profiles/$key/baobab/fonts/fonts.conf"
  local concept_waybar_dir="$CONFIG_HOME/sevenos/profiles/$key/waybar"
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    if [[ "$key" == "baobab" && -s "$profile_waybar_config" && -s "$profile_waybar_style" ]]; then
      printf 'project Baobab Waybar config from %q to %q\n' "$profile_waybar_config" "$WAYBAR_CONFIG"
      printf 'project Baobab Waybar style from %q to %q\n' "$profile_waybar_style" "$WAYBAR_STYLE"
    elif is_specialized_waybar_profile "$key"; then
      printf 'render %s concept Waybar config to %q and project to %q\n' "$key" "$concept_waybar_dir/config.jsonc" "$WAYBAR_CONFIG"
      printf 'render %s concept Waybar style to %q and project to %q\n' "$key" "$concept_waybar_dir/style.css" "$WAYBAR_STYLE"
    else
      printf 'render profile Waybar config from %q to %q\n' "$config_base" "$WAYBAR_CONFIG"
      printf 'render profile Waybar style from %q to %q\n' "$style_base" "$WAYBAR_STYLE"
    fi
    status
    return 0
  fi
  mkdir -p "$(dirname "$WAYBAR_CONFIG")"
  mkdir -p "$(dirname "$PROFILE_UI")"
  mkdir -p "$(dirname "$profile_ui")"
  if [[ "$key" == "baobab" && -s "$profile_waybar_config" && -s "$profile_waybar_style" ]]; then
    project_baobab_waybar_config "$profile_waybar_config" > "$WAYBAR_CONFIG"
    project_baobab_waybar_style "$profile_waybar_style" > "$WAYBAR_STYLE"
    if [[ -s "$profile_fontconfig" ]]; then
      mkdir -p "$CONFIG_HOME/fontconfig/conf.d"
      cp "$profile_fontconfig" "$CONFIG_HOME/fontconfig/conf.d/70-sevenos-baobab-fonts.conf"
    fi
  elif is_specialized_waybar_profile "$key"; then
    mkdir -p "$concept_waybar_dir"
    render_specialized_config "$key" | tee "$concept_waybar_dir/config.jsonc" > "$WAYBAR_CONFIG"
    render_specialized_style "$key" | tee "$concept_waybar_dir/style.css" > "$WAYBAR_STYLE"
    rm -f "$CONFIG_HOME/fontconfig/conf.d/70-sevenos-baobab-fonts.conf" 2>/dev/null || true
  else
    render_config "$mode" "$config_base" > "$WAYBAR_CONFIG"
    render_style "$mode" "$style_base" > "$WAYBAR_STYLE"
    rm -f "$CONFIG_HOME/fontconfig/conf.d/70-sevenos-baobab-fonts.conf" 2>/dev/null || true
  fi
  if [[ "$mode" == "light" ]]; then
    append_light_legibility_lock
  fi
  PROFILE_JSON="$(profile_json)" MODE="$mode" ROOT_DIR="$ROOT_DIR" python - <<'PY' | tee "$PROFILE_UI" > "$profile_ui"
