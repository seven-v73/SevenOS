#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="${SEVENOS_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
host_home() {
  local home="${SEVENOS_HOST_HOME:-$HOME}"
  case "$home" in
    */.local/share/sevenos/profile-containers/*/home)
      printf '%s\n' "${home%%/.local/share/sevenos/profile-containers/*}"
      ;;
    *)
      printf '%s\n' "$home"
      ;;
  esac
}

HOST_HOME="$(host_home)"
if [[ -n "${SEVENOS_HOST_CONFIG_HOME:-}" ]]; then
  CONFIG_HOME="$SEVENOS_HOST_CONFIG_HOME"
elif [[ "$HOME" == */.local/share/sevenos/profile-containers/*/home ]]; then
  CONFIG_HOME="$HOST_HOME/.config"
else
  CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
fi
THEME_CONF="$CONFIG_HOME/sevenos/theme.conf"
WAYBAR_CONFIG="$CONFIG_HOME/waybar/config.jsonc"
WAYBAR_STYLE="$CONFIG_HOME/waybar/style.css"
PROFILE_UI="$CONFIG_HOME/sevenos/profile-ui.json"

active_profile_key() {
  local state_file="$CONFIG_HOME/sevenos/profile.env"
  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
    printf '%s' "${SEVENOS_ACTIVE_PROFILE:-equinox}"
  else
    printf 'equinox'
  fi
}

profile_theme_conf() {
  printf '%s/sevenos/profiles/%s/theme.conf' "$CONFIG_HOME" "$(active_profile_key)"
}

theme_mode() {
  local mode
  if [[ -f "$THEME_CONF" ]]; then
    mode="$(awk -F= 'tolower($1) ~ /^(mode|theme_mode|sevenos_theme_mode)$/ {print $2; exit}' "$THEME_CONF" | tr -d '[:space:]\"')"
  else
    mode=""
  fi
  case "$mode" in
    dark|light) printf '%s' "$mode" ;;
    *) printf 'dark' ;;
  esac
}

profile_json() {
  "$ROOT_DIR/profiles/profile-manager.sh" current --json
}

profile_key() {
  PROFILE_JSON="$(profile_json)" python - <<'PY'
import json
import os

print(json.loads(os.environ["PROFILE_JSON"]).get("key", "equinox"))
PY
}

base_config() {
  local mode="$1"
  if [[ "$mode" == "light" ]]; then
    printf '%s/hyprland-light/waybar/config.jsonc\n' "$ROOT_DIR"
  else
    printf '%s/hyprland/waybar/config.jsonc\n' "$ROOT_DIR"
  fi
}

base_style() {
  local mode="$1"
  if [[ "$mode" == "light" ]]; then
    printf '%s/hyprland-light/waybar/style.css\n' "$ROOT_DIR"
  else
    printf '%s/hyprland/waybar/style.css\n' "$ROOT_DIR"
  fi
}

render_config() {
  local mode="$1"
  local base="$2"
  PROFILE_JSON="$(profile_json)" BASE_CONFIG="$base" python - <<'PY'
import json
import os
from pathlib import Path

profile = json.loads(os.environ["PROFILE_JSON"])
config = json.loads(Path(os.environ["BASE_CONFIG"]).read_text(encoding="utf-8"))
modules = {item.strip() for item in str(profile.get("waybar_modules", "")).split(",") if item.strip()}
essential_left = {"spotlight"}
essential_right = {"system-status"}
modules |= essential_left | essential_right

recorder_command = "sh -lc 'cmd=\"${SEVENOS_HOST_HOME:-$HOME}/.local/bin/seven-waybar-status\"; [ -x \"$cmd\" ] || cmd=seven-waybar-status; exec \"$cmd\" recorder'"
recorder_click = "sh -lc 'PATH=\"${SEVENOS_HOST_HOME:-$HOME}/.local/bin:$PATH\"; exec seven-recorder ACTION'"

left = ["custom/sevenos", "custom/recorder", "hyprland/window", "custom/app-file", "custom/app-edit", "custom/app-view", "custom/app-extra", "custom/app-more", "custom/app-tools", "custom/app-window", "custom/app-help"]
config["modules-left"] = left
config["modules-center"] = ["hyprland/workspaces"]
config["hyprland/window"] = {
    "format": "{class}",
    "max-length": 18,
    "separate-outputs": True,
    "rewrite": {
        "^$": "Bureau",
        "^code$": "Code",
        "^Code$": "Code",
        "^chromium$": "Chromium",
        "^Chromium$": "Chromium",
        "^google-chrome$": "Chrome",
        "^Google-chrome$": "Chrome",
        "^firefox$": "Firefox",
        "^Firefox$": "Firefox",
        "^kitty$": "Terminal",
        "^SevenTerminalNative$": "Terminal",
        "^SevenFilesNative$": "Seven Files",
        "^org\\.gnome\\.Nautilus$": "Files",
        "^Nautilus$": "Files",
    },
}
config["custom/app-menu"] = {
    "exec": "seven-waybar-status app-menu",
    "return-type": "json",
    "interval": 10,
    "signal": 8,
    "tooltip": True,
    "on-click": "seven-waybar-action app-menu",
    "on-click-right": "seven-waybar-action app-menu-window",
}
for item in ("file", "edit", "view", "extra", "tools", "window", "help"):
    key_name = f"custom/app-{item}"
    config[key_name] = {
        "exec": f"seven-waybar-status app-menu-item {item}",
        "return-type": "json",
        "interval": 10,
        "signal": 8,
        "tooltip": True,
        "on-click": f"seven-waybar-action app-{item}",
        "on-click-right": "seven-waybar-action app-menu-window" if item == "window" else "seven-waybar-action app-menu",
    }
config["custom/app-help"]["on-click-right"] = "seven-help"
config["custom/app-more"] = {
    "exec": "seven-waybar-status app-menu-more",
    "return-type": "json",
    "interval": 10,
    "signal": 8,
    "tooltip": True,
    "on-click": "seven-waybar-action app-menu",
    "on-click-right": "seven-waybar-action app-menu-window",
}

config["modules-right"] = [
    "custom/profile",
    "custom/media",
    "custom/system-status",
    "custom/wifi",
    "custom/bluetooth",
    "custom/spotlight",
    "clock",
    "custom/control-center",
]
config["tray"] = {"icon-size": 14, "spacing": 6}
config["custom/system-status"] = {
    "exec": "seven-waybar-status system-status",
    "return-type": "json",
    "interval": 3,
    "tooltip": True,
    "on-click": "seven-quick-settings",
    "on-click-right": "seven-settings",
    "on-click-middle": "seven-waybar repair",
}
config["custom/mini-context"] = {
    "exec": "seven-waybar-status mini-context",
    "return-type": "json",
    "interval": 4,
    "signal": 8,
    "tooltip": True,
    "on-click": "seven-waybar-action mini-context",
    "on-click-right": "seven-mini-os-center",
}
config["custom/recorder"] = {
    "exec": recorder_command,
    "return-type": "json",
    "format": "{}",
    "interval": 2,
    "tooltip": True,
    "on-click": recorder_click.replace("ACTION", "area"),
    "on-click-right": recorder_click.replace("ACTION", "panel"),
    "on-click-middle": recorder_click.replace("ACTION", "full"),
}

key = profile.get("key", "equinox")
label = profile.get("label") or profile.get("title") or key.title()
icon = profile.get("waybar_icon") or profile.get("icon") or "7"
short = profile.get("short_label") or key[:3].upper()
config.setdefault("custom/sevenos", {})["exec"] = "seven-waybar-status sevenos"
config.setdefault("custom/sevenos", {})["return-type"] = "json"
config.setdefault("custom/sevenos", {})["interval"] = 3
config.setdefault("custom/sevenos", {})["tooltip"] = True
config.setdefault("custom/sevenos", {})["on-click"] = "seven-waybar-action sevenos-menu"
config.setdefault("custom/sevenos", {})["on-click-right"] = "seven-profile-center-native"
config.setdefault("custom/sevenos", {})["on-click-middle"] = "seven-spotlight field"
config.setdefault("custom/spotlight", {})["format"] = "󰍉"

print(json.dumps(config, indent=2, ensure_ascii=False))
PY
}

