refresh_specialized_waybars() {
  local key dir
  for key in forge shield studio windows pulse; do
    dir="$CONFIG_HOME/sevenos/profiles/$key/waybar"
    mkdir -p "$dir"
    render_specialized_config "$key" > "$dir/config.jsonc"
    render_specialized_style "$key" > "$dir/style.css"
  done
  local baobab_dir="$CONFIG_HOME/sevenos/profiles/baobab/baobab/waybar"
  if [[ -s "$baobab_dir/config.jsonc" && -s "$baobab_dir/style.css" ]]; then
    local tmp_config tmp_style
    tmp_config="$(mktemp)"
    tmp_style="$(mktemp)"
    project_baobab_waybar_config "$baobab_dir/config.jsonc" > "$tmp_config"
    project_baobab_waybar_style "$baobab_dir/style.css" > "$tmp_style"
    mv "$tmp_config" "$baobab_dir/config.jsonc"
    mv "$tmp_style" "$baobab_dir/style.css"
  fi
}

audit_waybars() {
  CONFIG_HOME="$CONFIG_HOME" python - <<'PY'
import json
import os
import re
from pathlib import Path

config_home = Path(os.environ["CONFIG_HOME"])
profiles = {
    "forge": {"position": "top", "max_modules": 20, "identity": "Forge", "required": {"custom/project", "custom/containers", "custom/services"}},
    "shield": {"position": "top", "max_modules": 19, "identity": "Shield", "required": {"custom/scope", "custom/vpn", "custom/recorder"}},
    "studio": {"position": "top", "max_modules": 19, "identity": "Studio", "required": {"custom/canvas", "custom/media", "custom/recorder"}},
    "windows": {"position": "top", "max_modules": 19, "identity": "Windows", "required": {"custom/windows-home", "custom/apps", "custom/windows-folders"}},
    "pulse": {"position": "top", "max_modules": 20, "identity": "Pulse", "required": {"custom/performance", "custom/gamemode", "custom/recorder"}},
    "baobab": {"position": "top", "max_modules": 19, "identity": "Baobab", "identity_module": "custom/baobab", "root": "baobab/waybar", "required": {"custom/memory", "custom/language", "custom/sound", "custom/ai"}},
}
common_required = {"hyprland/window", "custom/app-file", "custom/app-edit", "custom/app-view", "custom/app-more", "custom/mini-context", "custom/system-status", "clock", "tray", "custom/profile-switch", "custom/experience", "custom/spotlight"}
css_tokens = re.compile(r"@(accent|warn|danger|text|tooltip_bg|line|radius)\\b")
errors = []
warnings = []

for key, spec in profiles.items():
    root = config_home / "sevenos" / "profiles" / key / spec.get("root", "waybar")
    cfg_path = root / "config.jsonc"
    css_path = root / "style.css"
    if not cfg_path.exists() or not css_path.exists():
        errors.append(f"{key}: missing isolated waybar files")
        continue
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception as exc:
        errors.append(f"{key}: invalid JSON: {exc}")
        continue
    css = css_path.read_text(encoding="utf-8")
    modules = cfg.get("modules-left", []) + cfg.get("modules-center", []) + cfg.get("modules-right", [])
    module_set = set(modules)
    missing = (spec["required"] | common_required) - module_set
    if missing:
        errors.append(f"{key}: missing modules {', '.join(sorted(missing))}")
    if cfg.get("position") != spec["position"]:
        errors.append(f"{key}: position {cfg.get('position')} != {spec['position']}")
    if cfg.get("height") != 30:
        errors.append(f"{key}: height {cfg.get('height')} != 30")
    if len(modules) > spec["max_modules"]:
        warnings.append(f"{key}: dense layout ({len(modules)} modules)")
    if "custom/recorder" in module_set:
        left = cfg.get("modules-left", [])
        right = cfg.get("modules-right", [])
        recorder = cfg.get("custom/recorder") or {}
        if "custom/recorder" in right:
            errors.append(f"{key}: recorder must stay on the left for stable visibility")
        if "custom/recorder" not in left:
            errors.append(f"{key}: recorder is configured but not visible on the left")
        elif left.index("custom/recorder") > 1:
            warnings.append(f"{key}: recorder is visible but should stay near identity")
        if recorder.get("format") != "{}":
            errors.append(f"{key}: recorder format must be compact JSON text")
        if int(recorder.get("interval", 99)) > 2:
            errors.append(f"{key}: recorder interval is too slow for dynamic state")
        if ".local/bin/seven-waybar-status" not in str(recorder.get("exec", "")):
            errors.append(f"{key}: recorder must prefer the user-local status helper")
    identity_module = spec.get("identity_module", "custom/identity")
    identity_cfg = cfg.get(identity_module) or {}
    identity = identity_cfg.get("format", "")
    identity_exec = identity_cfg.get("exec", "")
    if identity != spec["identity"] and identity_exec != "seven-waybar-status sevenos":
        errors.append(f"{key}: identity label {identity!r} != {spec['identity']!r}")
    switch = (cfg.get("custom/profile-switch") or {}).get("format", "")
    if len(str(switch)) > 8:
        warnings.append(f"{key}: profile switch label may be too wide ({switch!r})")
    if css_tokens.search(css):
        errors.append(f"{key}: unresolved CSS theme tokens")
    if key == "studio" and "color: #322336;" in css:
        errors.append("studio: dark text token leaks into menu bar")
    if "tooltip" not in css or "window#waybar" not in css:
        errors.append(f"{key}: incomplete CSS structure")
    if "#custom-wifi.weak" not in css:
        errors.append(f"{key}: weak Wi-Fi state is not styled")
    print(f"{key}: OK · {cfg.get('position')} · {len(modules)} modules · {css_path}")

if warnings:
    print("Warnings:")
    for item in warnings:
        print(f"- {item}")
if errors:
    print("Errors:")
    for item in errors:
        print(f"- {item}")
    raise SystemExit(1)
print("Waybar UX audit: ready")
PY
}

case "${1:-status}" in
  status) status ;;
  json) profile_json ;;
  apply) apply_profile ;;
  refresh-waybars) refresh_specialized_waybars ;;
  audit-waybars) audit_waybars ;;
  *)
    printf 'Usage: seven-profile-theme [status|json|apply|refresh-waybars|audit-waybars]\n' >&2
    exit 2
    ;;
esac
