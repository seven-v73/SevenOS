append_light_legibility_lock() {
  cat >> "$WAYBAR_STYLE" <<'EOF'

/* SevenOS light legibility lock: final pass on active Waybar file. */
window#waybar {
  color: rgba(6, 10, 20, 0.98);
  border-bottom: 1px solid rgba(6, 10, 20, 0.24);
  background:
    linear-gradient(180deg, rgba(210, 220, 236, 0.96), rgba(166, 184, 214, 0.90)),
    rgba(142, 164, 200, 0.92);
  box-shadow:
    0 1px 0 rgba(255, 255, 255, 0.72),
    0 10px 28px rgba(20, 30, 54, 0.24);
}

window#waybar label,
#window,
#custom-app-menu,
#custom-app-file,
#custom-app-edit,
#custom-app-view,
#custom-app-extra,
#custom-app-more,
