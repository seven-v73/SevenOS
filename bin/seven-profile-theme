status() {
  local mode profile
  mode="$(theme_mode)"
  profile="$(profile_json)"
  PROFILE_JSON="$profile" MODE="$mode" PROFILE_THEME_CONF="$(profile_theme_conf)" python - <<'PY'
import json
import os

profile = json.loads(os.environ["PROFILE_JSON"])
print(f"{profile.get('title', profile.get('key'))} · {os.environ['MODE']} · {profile.get('waybar_modules', '')}")
print(f"profile theme: {os.environ['PROFILE_THEME_CONF']}")
PY
}

project_baobab_waybar_config() {
  local source_config="$1"
  BAOBAB_CONFIG="$source_config" python - <<'PY'
import json
import os
from pathlib import Path

cfg = json.loads(Path(os.environ["BAOBAB_CONFIG"]).read_text(encoding="utf-8"))
cfg["height"] = 30
cfg["spacing"] = 4
cfg["margin-top"] = 0
cfg["margin-left"] = 0
cfg["margin-right"] = 0
modules = cfg.get("modules-left", []) + cfg.get("modules-center", []) + cfg.get("modules-right", [])
cfg["modules-center"] = ["hyprland/workspaces"]
cfg["modules-right"] = [module for module in cfg.get("modules-right", []) if module != "custom/os-switch"]
cfg["modules-right"] = [module for module in cfg.get("modules-right", []) if module not in {"custom/wifi", "custom/bluetooth", "pulseaudio", "battery"}]
right = cfg.setdefault("modules-right", [])
for module in ("custom/memory", "custom/language", "custom/sound", "custom/ai"):
    if module in modules and module not in right:
        right.append(module)
for module in ("custom/profile", "custom/mini-context"):
    if module in right:
        right.remove(module)
    right.insert(0, module)
if "custom/media" in modules and "custom/media" not in cfg.get("modules-right", []):
    right = cfg.setdefault("modules-right", [])
    insert_at = right.index("custom/system-status") if "custom/system-status" in right else len(right)
    right.insert(insert_at, "custom/media")
if "hyprland/window" not in cfg.get("modules-left", []):
    cfg.setdefault("modules-left", []).insert(1, "hyprland/window")
app_menu_items = ["custom/app-file", "custom/app-edit", "custom/app-view", "custom/app-extra", "custom/app-more", "custom/app-tools", "custom/app-window", "custom/app-help"]
visible_app_menu_items = ["custom/app-file", "custom/app-edit", "custom/app-view", "custom/app-more"]
left = cfg.setdefault("modules-left", [])
left[:] = [item for item in left if item in {"custom/baobab", "hyprland/window"}]
insert_at = left.index("hyprland/window") + 1 if "hyprland/window" in left else 1
for item in reversed(visible_app_menu_items):
    left.insert(insert_at, item)
if "custom/experience" not in modules:
    right = cfg.setdefault("modules-right", [])
    insert_at = right.index("clock") if "clock" in right else len(right)
    right.insert(insert_at, "custom/experience")
if "custom/system-status" not in cfg.get("modules-right", []):
    right = cfg.setdefault("modules-right", [])
    insert_at = right.index("clock") if "clock" in right else len(right)
    right.insert(insert_at, "custom/system-status")
if "custom/spotlight" not in cfg.get("modules-right", []):
    right = cfg.setdefault("modules-right", [])
    insert_at = right.index("clock") if "clock" in right else len(right)
    right.insert(insert_at, "custom/spotlight")
if "tray" not in cfg.get("modules-right", []):
    right = cfg.setdefault("modules-right", [])
    insert_at = right.index("custom/spotlight") if "custom/spotlight" in right else len(right)
    right.insert(insert_at, "tray")
if "custom/profile-switch" not in cfg.get("modules-right", []):
    right = cfg.setdefault("modules-right", [])
    insert_at = right.index("clock") if "clock" in right else len(right)
    right.insert(insert_at, "custom/profile-switch")
cfg["hyprland/window"] = {
    "format": "{class}",
    "max-length": 18,
    "separate-outputs": True,
    "rewrite": {
        "^$": "Bureau",
        "^code$": "Code",
        "^Code$": "Code",
        "^chromium$": "Chromium",
        "^Chromium$": "Chromium",
        "^google-chrome$": "Chrome",
        "^Google-chrome$": "Chrome",
        "^firefox$": "Firefox",
        "^Firefox$": "Firefox",
        "^kitty$": "Terminal",
        "^SevenTerminalNative$": "Terminal",
        "^SevenFilesNative$": "Seven Files",
        "^org\\.gnome\\.Nautilus$": "Files",
        "^Nautilus$": "Files",
    },
}
cfg["custom/app-menu"] = {
    "exec": "seven-waybar-status app-menu",
    "return-type": "json",
    "interval": 10,
    "signal": 8,
    "tooltip": True,
    "on-click": "seven-waybar-action app-menu",
    "on-click-right": "seven-waybar-action app-menu-window",
}
cfg["custom/mini-context"] = {
    "exec": "seven-waybar-status mini-context",
    "return-type": "json",
    "interval": 4,
    "signal": 8,
    "tooltip": True,
    "on-click": "seven-waybar-action mini-context",
    "on-click-right": "seven-mini-os-center",
}
for item in ("file", "edit", "view", "extra", "tools", "window", "help"):
    cfg[f"custom/app-{item}"] = {
        "exec": f"seven-waybar-status app-menu-item {item}",
        "return-type": "json",
        "interval": 10,
        "signal": 8,
        "tooltip": True,
        "on-click": f"seven-waybar-action app-{item}",
        "on-click-right": "seven-waybar-action app-menu-window" if item == "window" else ("seven-help" if item == "help" else "seven-waybar-action app-menu"),
    }
cfg["custom/app-more"] = {
    "exec": "seven-waybar-status app-menu-more",
    "return-type": "json",
    "interval": 10,
    "signal": 8,
    "tooltip": True,
    "on-click": "seven-waybar-action app-menu",
    "on-click-right": "seven-waybar-action app-menu-window",
}
cfg["tray"] = {"icon-size": 14, "spacing": 6}
cfg["custom/experience"] = {
    "exec": "seven-waybar-status experience",
    "return-type": "json",
    "interval": 8,
    "tooltip": True,
    "on-click": "seven experience warmup",
    "on-click-right": "seven experience events",
    "on-click-middle": "seven experience recommend",
}
cfg["custom/system-status"] = {
    "exec": "seven-waybar-status system-status",
    "return-type": "json",
    "interval": 3,
    "tooltip": True,
    "on-click": "seven-quick-settings",
    "on-click-right": "seven-settings",
    "on-click-middle": "seven-waybar repair",
}
cfg["custom/spotlight"] = {
    "format": "󰍉",
    "tooltip": "Spotlight SevenOS",
    "on-click": "seven-spotlight field",
}
cfg.setdefault("custom/profile-switch", {})["format"] = "OS"
cfg.setdefault("custom/language", {})["exec"] = "seven-waybar-language"
cfg.setdefault("custom/language", {})["return-type"] = "json"
cfg.setdefault("custom/language", {})["interval"] = 30
cfg.setdefault("custom/language", {})["tooltip"] = True
cfg.setdefault("custom/language", {})["on-click"] = "seven-language menu"
cfg.setdefault("custom/language", {})["on-click-right"] = "seven-settings general"
cfg.setdefault("custom/memory", {})["exec"] = "seven baobab capability-doctor --json >/dev/null 2>&1 && echo '󰧑' || echo '󰧑 off'"
cfg.setdefault("custom/memory", {})["tooltip"] = "Mémoire Baobab · capacité locale"
cfg.setdefault("custom/sound", {})["exec"] = "find \"/home/seven/Baobab/Sound\" \"/home/seven/.local/share/sevenos/profiles/baobab/baobab/sound\" -maxdepth 1 -type f 2>/dev/null | grep -q . && echo '󰝚' || echo '󰝚 off'"
cfg.setdefault("custom/sound", {})["tooltip"] = "Paysages sonores Baobab"
cfg.setdefault("custom/ai", {})["exec"] = "command -v ollama >/dev/null 2>&1 && echo '󰚩' || echo '󰚩 off'"
cfg.setdefault("custom/ai", {})["tooltip"] = "Seven Baobab AI local"
preferred_right = [
    "custom/memory",
    "custom/language",
    "custom/sound",
    "custom/ai",
    "custom/mini-context",
    "custom/system-status",
    "custom/experience",
    "tray",
    "custom/spotlight",
    "clock",
    "custom/profile-switch",
]
existing_right = cfg.get("modules-right", [])
cfg["modules-right"] = [module for module in preferred_right if module in existing_right]
print(json.dumps(cfg, indent=2, ensure_ascii=False))
PY
}

