insert_at = config["modules-left"].index("hyprland/window") + 1 if "hyprland/window" in config["modules-left"] else 1
for item in reversed(visible_app_menu_items):
    config["modules-left"].insert(insert_at, item)
for name, payload in spec["custom"].items():
    config[f"custom/{name}"] = payload
if "custom/recorder" in config.get("modules-right", []) or "custom/recorder" in config.get("modules-left", []):
    config["custom/recorder"] = recorder_module
    config["modules-right"] = [item for item in config["modules-right"] if item != "custom/recorder"]
    config["modules-left"] = [item for item in config["modules-left"] if item != "custom/recorder"]
    insert_at = 1 if config["modules-left"] else 0
    config["modules-left"].insert(insert_at, "custom/recorder")
if "custom/experience" not in config["modules-right"]:
    insert_at = config["modules-right"].index("clock") if "clock" in config["modules-right"] else len(config["modules-right"])
    config["modules-right"].insert(insert_at, "custom/experience")
if "custom/mini-context" not in config["modules-right"]:
    insert_at = config["modules-right"].index("custom/system-status") if "custom/system-status" in config["modules-right"] else 0
    config["modules-right"].insert(insert_at, "custom/mini-context")
if "custom/spotlight" not in config["modules-right"]:
    insert_at = config["modules-right"].index("clock") if "clock" in config["modules-right"] else len(config["modules-right"])
    config["modules-right"].insert(insert_at, "custom/spotlight")
if "tray" not in config["modules-right"]:
    insert_at = config["modules-right"].index("custom/spotlight") if "custom/spotlight" in config["modules-right"] else len(config["modules-right"])
    config["modules-right"].insert(insert_at, "tray")
config["tray"] = {"icon-size": 14, "spacing": 6}
config["custom/experience"] = {
    "exec": "seven-waybar-status experience",
    "return-type": "json",
    "interval": 8,
    "tooltip": True,
    "on-click": "seven experience warmup",
    "on-click-right": "seven experience events",
    "on-click-middle": "seven experience recommend",
}
print(json.dumps(config, indent=2, ensure_ascii=False))
PY
}

