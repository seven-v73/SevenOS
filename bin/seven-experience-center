    def refresh_context_labels() -> bool:
        live_context = current_context()
        context_label.set_text(f"{live_context.get('time', '')} · {live_context.get('language_label', '')}")
        context_label.set_tooltip_text(f"{live_context.get('date', '')} · {live_context.get('timezone', '')} · {live_context.get('language_raw', '')}")
        moment_value.set_text(str(live_context.get("moment") or tr("Maintenant", "Now")))
        time_value.set_text(str(live_context.get("time") or "--:--"))
        return True

