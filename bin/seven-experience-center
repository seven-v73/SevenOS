    def metric(value: str, label: str) -> tuple[Gtk.Label, Gtk.Label]:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        card.get_style_context().add_class("experience-metric")
        card.set_hexpand(True)
        value_label = Gtk.Label(label=value)
        value_label.set_xalign(0)
        value_label.get_style_context().add_class("experience-metric-value")
        label_widget = Gtk.Label(label=label)
        label_widget.set_xalign(0)
        label_widget.get_style_context().add_class("experience-small")
        card.pack_start(value_label, False, False, 0)
        card.pack_start(label_widget, False, False, 0)
        metrics.pack_start(card, True, True, 0)
        return value_label, label_widget

