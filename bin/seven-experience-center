    def confirm_and_run(command: str, title_text: str, detail: str = "") -> None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(520, 260)
        box = dialog.get_content_area()
        box.set_border_width(16)
        box.set_spacing(10)
        box.get_style_context().add_class("experience-shell")
        heading = Gtk.Label(label=title_text)
        heading.set_xalign(0)
        heading.get_style_context().add_class("experience-section")
        text = Gtk.Label(label=detail or tr("SevenOS va lancer cette action en arrière-plan.", "SevenOS will launch this action in the background."))
        text.set_xalign(0)
        text.set_line_wrap(True)
        text.get_style_context().add_class("experience-note")
        command_label = Gtk.Label(label=command)
        command_label.set_xalign(0)
        command_label.set_selectable(True)
        command_label.get_style_context().add_class("experience-small")
        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.set_halign(Gtk.Align.END)
        cancel = Gtk.Button(label=tr("Annuler", "Cancel"))
        cancel.get_style_context().add_class("experience-pill")
        launch = Gtk.Button(label=tr("Lancer", "Run"))
        launch.get_style_context().add_class("experience-pill")
        launch.get_style_context().add_class("primary")
        cancel.connect("clicked", lambda _button: dialog.response(Gtk.ResponseType.CANCEL))
        launch.connect("clicked", lambda _button: (run_detached(command), dialog.response(Gtk.ResponseType.OK)))
        actions.pack_start(cancel, False, False, 0)
        actions.pack_start(launch, False, False, 0)
        box.pack_start(heading, False, False, 0)
        box.pack_start(text, False, False, 0)
        box.pack_start(command_label, False, False, 0)
        box.pack_end(actions, False, False, 0)
        dialog.connect("response", lambda _dialog, _response: dialog.destroy())
        dialog.show_all()

    def button(label: str, command: str, detail: str = "", primary: bool = False, confirm: bool = False) -> Gtk.Button:
        item = Gtk.Button(label=label)
        item.get_style_context().add_class("experience-pill")
        if primary:
            item.get_style_context().add_class("primary")
        item.set_tooltip_text(command)
        item.connect("clicked", lambda _button: confirm_and_run(command, label, detail) if confirm else run_detached(command))
        return item

    def page_box(name: str) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.set_border_width(2)
        stack.add_named(box, name)
        return box

    def add_nav(name: str, icon: str, label: str) -> None:
        nav = Gtk.Button(label=f"{icon}  {label}")
        nav.get_style_context().add_class("experience-nav")
        nav.set_halign(Gtk.Align.FILL)
        nav.connect("clicked", lambda clicked: activate(name))
        nav_buttons[name] = nav
        sidebar.pack_start(nav, False, False, 0)

    def activate(name: str) -> None:
        stack.set_visible_child_name(name)
        for key, nav in nav_buttons.items():
            if key == name:
                nav.get_style_context().add_class("active")
            else:
                nav.get_style_context().remove_class("active")

    def action_row(parent: Gtk.Box, title_text: str, note_text: str, actions: list[tuple[str, str, str, bool]], glyph: str = "•", primary: bool = False) -> None:
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=11)
        card.get_style_context().add_class("experience-card")
        if primary:
            card.get_style_context().add_class("primary")
        icon = Gtk.Label(label=glyph)
        icon.get_style_context().add_class("experience-glyph")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        labels.set_hexpand(True)
        title_label = Gtk.Label(label=title_text)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("experience-section")
        note_label = Gtk.Label(label=note_text)
        note_label.set_xalign(0)
        note_label.set_line_wrap(True)
        note_label.get_style_context().add_class("experience-small")
        labels.pack_start(title_label, False, False, 0)
        labels.pack_start(note_label, False, False, 0)
        flow = Gtk.FlowBox()
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(4)
        flow.set_column_spacing(8)
        flow.set_row_spacing(8)
        for action_label, command, action_detail, needs_confirm in actions:
            flow.add(button(action_label, command, action_detail, primary=False, confirm=needs_confirm))
        labels.pack_start(flow, False, False, 4)
        card.pack_start(icon, False, False, 0)
        card.pack_start(labels, True, True, 0)
        parent.pack_start(card, False, False, 0)

    def recommendation_strip(parent: Gtk.Box) -> None:
        wrapper = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        wrapper.get_style_context().add_class("experience-recommendation")
        title_text = Gtk.Label(label=tr("Prochaines actions recommandées", "Recommended next actions"))
