        title_text.get_style_context().add_class("experience-section")
        note_text = Gtk.Label(label=tr("SevenOS priorise ce qui augmente la confiance sans te forcer à ouvrir un terminal.", "SevenOS prioritizes what increases trust without forcing you to open a terminal."))
        note_text.set_xalign(0)
        note_text.set_line_wrap(True)
        note_text.get_style_context().add_class("experience-small")
        wrapper.pack_start(title_text, False, False, 0)
        wrapper.pack_start(note_text, False, False, 0)
        flow = Gtk.FlowBox()
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(2)
        flow.set_column_spacing(8)
        flow.set_row_spacing(8)
        for item in data.get("recommendations", [])[:4]:
            flow.add(button(str(item.get("title") or ""), str(item.get("command") or ""), str(item.get("detail") or ""), confirm=bool(item.get("confirm"))))
        wrapper.pack_start(flow, False, False, 0)
        parent.pack_start(wrapper, False, False, 0)

