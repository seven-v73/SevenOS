def mission_flow_state(profile: str, profile_health: dict | None = None, bridge_graph: dict | None = None) -> dict:
    profile_title = PROFILES.get(profile, PROFILES["equinox"])[0]
    profiles = {}
    if isinstance(profile_health, dict):
        for item in profile_health.get("profiles", []):
            if isinstance(item, dict) and item.get("key"):
                profiles[str(item["key"])] = item
    bridge_ready = {}
    if isinstance(bridge_graph, dict):
        for item in bridge_graph.get("nodes", []):
            if isinstance(item, dict) and item.get("id"):
                bridge_ready[str(item["id"])] = bool(item.get("ready"))

    def step(profile_key: str, title: str, detail: str, command: str, output: str = "", handoff: str = "") -> dict:
        profile_data = PROFILES.get(profile_key, PROFILES["equinox"])
        profile_state = profiles.get(profile_key, {})
        ready = profile_state.get("state") in {"OK", "READY", "ready"} if profile_state else True
        bridge = bridge_ready.get(profile_key, True)
        return {
            "profile": profile_key,
            "profile_title": profile_data[0],
            "icon": profile_data[2],
            "accent": profile_data[3],
            "title": title,
            "detail": detail,
            "command": command,
            "output": output,
            "handoff": handoff,
            "ready": bool(ready and bridge),
            "state": "OK" if ready and bridge else "INFO",
            "profile_state": str(profile_state.get("state", "OK" if ready else "INFO")),
            "bridge_ready": bool(bridge),
        }

