    intent_hint = Gtk.Label(label=tr("Exemples : wifi, thème clair, sauvegarde, jeu sur l’histoire du Mali, publier un site, confidentialité.", "Examples: wifi, light theme, backup, game about Mali history, publish a site, privacy."))
    intent_hint.set_xalign(0)
    intent_hint.set_line_wrap(True)
    intent_hint.get_style_context().add_class("experience-small")
    intent_entry = Gtk.Entry()
    intent_entry.set_placeholder_text(tr("Que veux-tu faire ?", "What do you want to do?"))
    intent_entry.get_style_context().add_class("experience-entry")
    intent_result_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    intent_search_card.pack_start(intent_label, False, False, 0)
    intent_search_card.pack_start(intent_hint, False, False, 0)
    intent_search_card.pack_start(intent_entry, False, False, 0)
    intent_search_card.pack_start(intent_result_box, False, False, 0)
    intent_page.pack_start(intent_search_card, False, False, 0)

    def render_intent_result(query: str) -> None:
        for child in list(intent_result_box.get_children()):
            intent_result_box.remove(child)
        result = resolve_intent(data, query)
        match_item = result.get("match") if isinstance(result.get("match"), dict) else None
        if match_item:
            kind_label = tr("Mission Equinox", "Equinox mission") if match_item.get("kind") == "mission" or match_item.get("steps") else tr("Meilleur parcours", "Best route")
            action_row(
                intent_result_box,
                kind_label,
                f"{match_item.get('title', '')} · {match_item.get('detail', '')}",
                [(tr("Lancer", "Run"), str(match_item.get("command", "")), str(match_item.get("detail", "")), bool(match_item.get("confirm")))],
                "◇",
                True,
            )
            for index, step_item in enumerate(match_item.get("steps", []) if isinstance(match_item.get("steps"), list) else [], 1):
                note = str(step_item.get("detail", ""))
                if step_item.get("output"):
                    note = f"{note}\n{tr('Sortie attendue', 'Expected output')}: {step_item.get('output')}"
                action_row(
                    intent_result_box,
                    f"{index}. {step_item.get('profile_title', '')} · {step_item.get('title', '')}",
                    note,
                    [(tr("Ouvrir cette étape", "Open this step"), str(step_item.get("command", "")), str(step_item.get("detail", "")), False)],
                    str(step_item.get("icon", "●")),
                    step_item.get("ready") is True,
                )
        elif query.strip():
            action_row(
                intent_result_box,
                tr("Aucun parcours exact", "No exact route"),
                tr("Essaie avec des mots comme wifi, thème, sauvegarde, apps, fichiers, privacy ou performance.", "Try words like wifi, theme, backup, apps, files, privacy or performance."),
                [(tr("Aide guidée", "Guided help"), "seven learning --gui", "", False)],
                "󰌵",
            )
        intent_result_box.show_all()

    intent_entry.connect("changed", lambda entry: render_intent_result(entry.get_text()))
    initial_intent_query = str(intent_result.get("query") or "")
    if initial_intent_query:
        intent_entry.set_text(initial_intent_query)
    else:
        render_intent_result("")
    for item in intent_palette.get("items", []):
        action_row(
            intent_page,
            str(item.get("title", "")),
            str(item.get("detail", "")),
            [(tr("Lancer", "Run"), str(item.get("command", "")), str(item.get("detail", "")), bool(item.get("confirm")))],
            "●",
        )

        action_row(
            missions_page,
            str(missions.get("title") or "Equinox Mission Planner"),
            f"{missions.get('summary') or ''}\n{tr('Préparation', 'Readiness')}: {missions.get('ready_profiles', 0)}/{missions.get('total_profiles', 0)} · bridge={missions.get('bridge_state', 'unknown')}",
            [(tr("Rechercher une intention", "Search an intent"), "seven intent --gui", "", False), (tr("Mémoire de travail", "Workspace memory"), "seven experience workspace", "", False)],
            "󰐃",
            True,
    )
    for item in missions.get("items", []):
        steps = item.get("steps", []) if isinstance(item.get("steps"), list) else []
        route = " → ".join(str(step_item.get("profile_title", "")) for step_item in steps[:6])
        action_row(
            missions_page,
            str(item.get("title", "")),
            f"{item.get('state', 'INFO')} · {item.get('ready_steps', 0)}/{item.get('total_steps', 0)} {tr('étapes prêtes', 'ready steps')}\n{item.get('detail', '')}\n{route}",
            [(tr("Commencer", "Start"), str(item.get("command", "")), str(item.get("detail", "")), bool(item.get("confirm"))), (tr("Chercher similaire", "Search similar"), f"seven experience-center intent {item.get('title', '')!r} --gui", "", False)],
            "◇",
            item.get("key") in {"mali-game", "publish-web"},
        )
        for index, step_item in enumerate(steps[:4], 1):
            action_row(
                missions_page,
                f"{index}. {step_item.get('profile_title', '')}",
                f"{step_item.get('state', 'INFO')} · {step_item.get('title', '')} · {step_item.get('detail', '')}\n{tr('Sortie attendue', 'Expected output')}: {step_item.get('output', '')}",
                [(tr("Ouvrir", "Open"), str(step_item.get("command", "")), str(step_item.get("detail", "")), False)],
                str(step_item.get("icon", "●")),
                step_item.get("ready") is True,
            )
    learning = data.get("learning", {}) if isinstance(data.get("learning"), dict) else {}
    action_row(
        learning_page,
        tr("Décrire le besoin, pas la commande", "Describe the need, not the command"),
        tr(
            "SevenOS transforme les problèmes courants en parcours sûrs : réparer, vérifier, revenir en arrière, changer d’espace ou lire les accès sensibles.",
            "SevenOS turns common problems into safe journeys: repair, verify, roll back, switch spaces or review sensitive access.",
        ),
        [(tr("Rapport de confiance", "Trust report"), "seven trust --gui", "", False), (tr("Aide complète", "Full help"), "seven-help-native", "", False)],
        "󰌵",
        True,
    )
    for item in learning.get("guides", []):
        action_row(
            learning_page,
            str(item.get("title", "")),
            str(item.get("intent", "")),
            [(tr("Lancer le parcours", "Start journey"), str(item.get("command", "")), str(item.get("intent", "")), bool(item.get("confirm")))],
            "◇" if item.get("safe") else "󰁯",
            bool(item.get("safe")),
        )
    device = data.get("device_continuity", {}) if isinstance(data.get("device_continuity"), dict) else {}
    action_row(
        device_page,
        tr("Continuité sans surprise", "Continuity without surprises"),
        tr(
            f"{device.get('ready_count', 0)}/{device.get('total', 0)} bases prêtes sur {device.get('device', 'SevenOS')}. Rien n’est partagé sans action explicite.",
            f"{device.get('ready_count', 0)}/{device.get('total', 0)} foundations ready on {device.get('device', 'SevenOS')}. Nothing is shared without an explicit action.",
        ),
        [(tr("Réseau", "Network"), "seven settings network", "", False), (tr("Sauvegarder", "Back up"), "seven recovery backup", "", True), ("SevenCloud", "seven cloud status", "", False)],
        "󰀂",
        True,
    )
    for item in device.get("checks", []):
        action_row(
            device_page,
            str(item.get("title", "")),
            f"{item.get('state', 'INFO')} · {item.get('detail', '')}",
            [(tr("Ouvrir", "Open"), str(item.get("command", "seven settings")), str(item.get("detail", "")), False)],
            "●",
            item.get("state") == "OK",
        )
    for item in device.get("actions", []):
        action_row(
            device_page,
            str(item.get("title", "")),
            str(item.get("detail", "")),
            [(tr("Lancer", "Run"), str(item.get("command", "")), str(item.get("detail", "")), bool(item.get("confirm")))],
            "◇",
        )
    action_row(
        overview,
        "Rescue Mode",
        tr("Réparer sans toucher aux fichiers personnels : thème, barre, Prism, réseau et diagnostic.", "Repair without touching personal files: theme, bar, Prism, network and diagnostics."),
        [
            (tr("Réparer l’interface", "Repair interface"), "seven repair ux --apply && seven theme sync && seven-waybar repair", tr("Réapplique les surfaces SevenOS sans supprimer tes données.", "Reapplies SevenOS surfaces without deleting your data."), True),
            ("Wi-Fi", "seven settings network", tr("Ouvre le panneau réseau.", "Opens the network panel."), False),
            (tr("Sauvegarder", "Back up"), "seven recovery backup", tr("Crée une sauvegarde locale SevenOS.", "Creates a local SevenOS backup."), True),
        ],
        "󰜉",
        True,
    )
    action_row(
        overview,
        "Time Machine",
        tr(f"{data['time_machine']['backup_count']} sauvegarde(s) locale(s). Prévisualise, sauvegarde ou prépare un rollback.", f"{data['time_machine']['backup_count']} local backup set(s). Preview, back up or prepare rollback."),
        [
            (tr("Créer sauvegarde", "Create backup"), "seven recovery backup", tr("Crée un point de retour local.", "Creates a local return point."), True),
            (tr("Plan restauration", "Restore plan"), "seven manifest restore-plan", "", False),
            ("Rollback", "seven update rollback", tr("Prépare un retour arrière après mise à jour.", "Prepares rollback after an update."), True),
        ],
        "󰁯",
    )

    action_row(
        time_machine,
        tr("Sauvegardes locales", "Local backups"),
        tr(
            f"{data['time_machine']['backup_count']} sauvegarde(s) disponible(s) dans {data['time_machine']['path']}.",
            f"{data['time_machine']['backup_count']} backup set(s) available in {data['time_machine']['path']}.",
        ),
        [
            (tr("Créer sauvegarde", "Create backup"), "seven recovery backup", tr("Crée un nouveau point de retour.", "Creates a new return point."), True),
            (tr("Plan restauration", "Restore plan"), "seven manifest restore-plan", tr("Montre ce qui serait restauré avant action.", "Shows what would be restored before action."), False),
        ],
        "󰁯",
        True,
    )
    action_row(
        time_machine,
        tr("Rollback après mise à jour", "Post-update rollback"),
        tr("Préparer un retour arrière si une mise à jour rend l’expérience instable.", "Prepare a rollback if an update makes the experience unstable."),
        [
            ("Rollback", "seven update rollback", tr("Action sensible: SevenOS demande confirmation avant lancement.", "Sensitive action: SevenOS asks for confirmation before launch."), True),
            (tr("Historique", "History"), "seven timeline", "", False),
        ],
        "󰕒",
    )
    action_row(
        time_machine,
        tr("Mémoire de configuration", "Configuration memory"),
        tr("Conserver les réglages SevenOS, mini OS, thème, Prism et préférences avant les gros changements.", "Keep SevenOS settings, Mini OS, theme, Prism and preferences before major changes."),
        [
            (tr("Sauvegarde migration", "Migration backup"), "seven migrate backup", "", True),
            (tr("État système", "System state"), "seven status", "", False),
        ],
        "󰒓",
    )

    for item in data["rescue"]["checks"]:
        action_row(rescue, item["title"], item["detail"], [(tr("Ouvrir", "Open"), item["command"], item["detail"], item["title"] in {tr("Interface", "Interface"), tr("Sauvegarde", "Backup")})], "󰄬", item["state"] == "WARN")

    action_row(
        rescue,
        tr("Premiers secours complets", "Complete first aid"),
        tr("Contrôle léger, réparation UX, thème, barre et raccourcis dans le bon ordre.", "Light check, UX repair, theme, bar and shortcuts in the right order."),
        [
            (tr("Vérifier", "Check"), "seven smoke doctor", "", False),
            (tr("Réparer expérience", "Repair experience"), "seven repair ux --apply && seven theme sync && seven-waybar repair && seven hypr lua apply", tr("Répare les surfaces principales puis reconstruit les raccourcis.", "Repairs main surfaces then rebuilds shortcuts."), True),
        ],
        "󰩂",
        True,
    )

    for item in data["journeys"]["items"]:
        action_row(continuity, item["title"], f"{item['intent']} · {item['note']}", [(tr("Préparer", "Prepare"), item["open"], item["note"], False), (tr("Activer", "Activate"), item["command"], item["note"], True)], item["icon"], item["key"] == data.get("active_profile"))
    for route in data["continuity"]["routes"]:
        action_row(continuity, f"{route['from'].title()} → {route['to'].title()}", route["intent"], [(tr("Voir le pont", "Show bridge"), "seven bridge graph", "", False), (tr("Boîte d’envoi", "Outbox"), "seven bridge outbox", "", False)], "󰁔")

    for item in data["permissions"]["checks"]:
        action_row(privacy, item["title"], f"{item['state']} · {item['detail']}", [(tr("Ouvrir", "Open"), item["command"], item["detail"], False)], "󰌾", item["state"] == "WARN")
    action_row(privacy, "Privacy Report", tr("Rapport simple des permissions, services actifs, accès et recommandations Shield.", "Simple report of permissions, active services, access and Shield recommendations."), [(tr("Ouvrir rapport", "Open report"), "seven privacy-report --gui", "", False), (tr("Confidentialité", "Privacy"), "seven settings privacy", "", False)], "󰒃")
    privacy_report = data.get("privacy_report", {}) if isinstance(data.get("privacy_report"), dict) else {}
    action_row(
        privacy_report_page,
        "Privacy Report",
        tr(
            f"{privacy_report.get('running_user_services', 0)} service(s) utilisateur actif(s) · {privacy_report.get('sensitive_events', 0)} événement(s) sensible(s) récents.",
            f"{privacy_report.get('running_user_services', 0)} active user service(s) · {privacy_report.get('sensitive_events', 0)} recent sensitive event(s).",
        ),
        [(tr("Confidentialité", "Privacy"), "seven settings privacy", "", False), ("Shield", "seven shield audit", "", False), ("SevenAI", "seven ai provider", "", False)],
        "󰒃",
        True,
    )
    for item in privacy_report.get("checks", []):
        action_row(privacy_report_page, str(item.get("title", "")), f"{item.get('state', 'INFO')} · {item.get('detail', '')}", [(tr("Ouvrir", "Open"), str(item.get("command", "seven permissions")), "", False)], "󰌾", item.get("state") == "WARN")

    if data["timeline"]["events"]:
        for event in data["timeline"]["events"][-10:]:
            title_text = str(event.get("source") or event.get("type") or "SevenOS")
            detail = f"{event.get('timestamp', '')} · {event.get('message', '')}".strip(" ·")
            action_row(timeline, title_text, detail, [(tr("Événements", "Events"), "seven events list", "", False)], "●")
    else:
        action_row(timeline, tr("Aucun événement récent", "No recent event"), tr("SevenOS affichera ici les changements importants dès qu’ils existent.", "SevenOS will show important changes here when they exist."), [(tr("Actualiser", "Refresh"), "seven events list", "", False)], "󰋚")
    action_row(timeline, "Workspace Memory", tr("Retrouver ou restaurer le contexte utile des mini OS.", "Recover or restore useful Mini OS context."), [(tr("Voir mémoire", "Show memory"), "seven-window memory --json", "", False), (tr("Restaurer", "Restore"), "seven-window restore", "", True), (tr("Préparer continuité", "Prepare continuity"), "seven experience workspace", "", False)], "󰘳")

    section_aliases = {"journeys": "continuity", "continuity": "continuity", "missions": "missions", "differentiators": "differentiators", "universes": "universes", "permissions": "privacy", "memory": "timeline"}
    activate(section if section in nav_buttons else section_aliases.get(section, "overview"))

    window.show_all()
    Gtk.main()
    return 0


