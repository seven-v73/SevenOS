def device_continuity_state(profile: str) -> dict:
    hostname = simple_out(["hostname"], "SevenOS", timeout=0.8)
    network_ready = command_exists("nmcli")
    ssh_ready = command_exists("ssh") and command_exists("scp")
    rsync_ready = command_exists("rsync")
    avahi_ready = command_exists("avahi-browse") or Path("/usr/lib/systemd/system/avahi-daemon.service").exists()
    syncthing_ready = command_exists("syncthing")
    sevencloud_ready = (ROOT / "bin/seven-cloud").exists() or (ROOT / "scripts/seven-cloud.sh").exists()
    checks = [
        {
            "key": "identity",
            "title": tr("Identité de l’appareil", "Device identity"),
            "state": "OK" if hostname else "WARN",
            "detail": tr(f"Nom local: {hostname}", f"Local name: {hostname}"),
            "command": "hostnamectl",
        },
        {
            "key": "network",
            "title": tr("Réseau local", "Local network"),
            "state": "OK" if network_ready else "WARN",
            "detail": tr("Le réseau peut être inspecté avant tout partage.", "Network can be inspected before any sharing."),
            "command": "seven settings network",
        },
        {
            "key": "nearby",
            "title": tr("Découverte d’appareils proches", "Nearby device discovery"),
            "state": "OK" if avahi_ready else "INFO",
            "detail": tr("Découverte locale disponible si l’utilisateur l’active.", "Local discovery is available if the user enables it."),
            "command": "systemctl status avahi-daemon",
        },
        {
            "key": "transfer",
            "title": tr("Transfert sécurisé", "Secure transfer"),
            "state": "OK" if ssh_ready or rsync_ready else "INFO",
            "detail": tr("SSH/SCP ou rsync peuvent transporter des fichiers explicitement choisis.", "SSH/SCP or rsync can carry explicitly chosen files."),
            "command": "seven files",
        },
        {
            "key": "sync",
            "title": tr("Synchronisation continue", "Continuous sync"),
            "state": "OK" if syncthing_ready or sevencloud_ready else "INFO",
            "detail": tr("Syncthing ou SevenCloud peuvent devenir le chemin opt-in.", "Syncthing or SevenCloud can become the opt-in path."),
            "command": "seven settings backup",
        },
    ]
    actions = [
        {
            "title": tr("Voir l’état réseau", "Show network state"),
            "command": "seven settings network",
            "detail": tr("Ouvre les réglages réseau avant tout partage.", "Opens network settings before any sharing."),
            "confirm": False,
        },
        {
            "title": tr("Préparer une sauvegarde portable", "Prepare a portable backup"),
            "command": "seven recovery backup",
            "detail": tr("Crée un point de retour local transportable.", "Creates a portable local return point."),
            "confirm": True,
        },
        {
            "title": tr("Ouvrir les fichiers", "Open files"),
            "command": "seven files",
            "detail": tr("Choisir explicitement ce qui doit être déplacé.", "Explicitly choose what should be moved."),
            "confirm": False,
        },
        {
            "title": tr("Consulter SevenCloud", "Review SevenCloud"),
            "command": "seven cloud status",
            "detail": tr("Vérifie la disponibilité cloud sans activer de synchronisation forcée.", "Checks cloud availability without forcing sync."),
            "confirm": False,
        },
    ]
    return {
        "title": "SevenOS Device Continuity",
        "profile": profile,
        "device": hostname,
        "ready_count": sum(1 for item in checks if item.get("state") == "OK"),
        "total": len(checks),
        "checks": checks,
        "actions": actions,
    }


