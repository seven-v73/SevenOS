def resolve_intent(data: dict, query: str) -> dict:
    query_norm = " ".join(query.lower().strip().split())
    intents = (data.get("intent_palette") or {}).get("items", [])
    missions = (data.get("missions") or {}).get("items", [])
    candidates = [
        {**item, "kind": "mission", "weight": 2}
        for item in missions
    ] + [
        {**item, "kind": "intent", "weight": 1}
        for item in intents
    ]
    if not query_norm:
        return {"query": query, "match": None, "items": missions[:3] + intents[:3]}
    scored: list[tuple[int, dict]] = []
    for item in candidates:
        haystack = " ".join([str(item.get("title", "")), str(item.get("detail", "")), " ".join(item.get("aliases", []))]).lower()
        score = 0
        for word in query_norm.split():
            if word in haystack:
                score += 3 if word in " ".join(item.get("aliases", [])).lower() else 1
        if query_norm in haystack:
            score += 5
        score *= int(item.get("weight", 1))
        if score:
            scored.append((score, item))
    scored.sort(key=lambda pair: pair[0], reverse=True)
    match = scored[0][1] if scored else None
    return {"query": query, "match": match, "items": [item for _score, item in scored[:5]] or missions[:3] + intents[:3]}


def resolve_mission(data: dict, query: str) -> dict:
    query_norm = " ".join(query.lower().strip().split())
    missions = (data.get("missions") or {}).get("items", [])
    if not query_norm:
        return {"query": query, "match": None, "items": missions}
    scored: list[tuple[int, dict]] = []
    for item in missions:
        haystack = " ".join([
            str(item.get("key", "")),
            str(item.get("title", "")),
            str(item.get("detail", "")),
            " ".join(item.get("aliases", [])),
        ]).lower()
        score = 0
        if query_norm == str(item.get("key", "")).lower():
            score += 20
        if query_norm in haystack:
            score += 8
        for word in query_norm.split():
            if word in haystack:
                score += 3 if word in " ".join(item.get("aliases", [])).lower() else 1
        if score:
            scored.append((score, item))
    scored.sort(key=lambda pair: pair[0], reverse=True)
    return {
        "query": query,
        "match": scored[0][1] if scored else None,
        "items": [item for _score, item in scored[:5]] or missions,
    }


def payload() -> dict:
    context = current_context()
    profile = active_profile()
    profile_title = PROFILES[profile][0]
    backups = migration_count()
    events = recent_events(10)
    memory = workspace_memory()
    permissions = permissions_state()
    report = trust_report(backups, events, memory, permissions, profile)
    personal_setup = personal_setup_state(profile, backups, memory)
    privacy_report = privacy_report_state(permissions, events)
    learning = learning_layer_state(profile)
    device_continuity = device_continuity_state(profile)
    daily_briefing = daily_briefing_state(profile, report, personal_setup, privacy_report, device_continuity, events, backups, context)
    intent_palette = intent_palette_state(profile)
    profile_health = run_json([str(ROOT / "bin/seven"), "profile", "health", "--json"], {}, timeout=3.5)
    bridge_graph = run_json([str(ROOT / "bin/seven"), "bridge", "graph", "--json"], {}, timeout=3.5)
    missions = mission_flow_state(profile, profile_health, bridge_graph)
    differentiators = run_json(
        [str(ROOT / "scripts/differentiators.sh"), "json"],
        {"checks": [], "summary": {}, "score": 0, "state": "unknown"},
        timeout=10,
        env_extra={"SEVENOS_DIFFERENTIATORS_FROM_PUBLIC": "1"},
    )
    universes = run_json(
        [str(ROOT / "scripts/universes.sh"), "json"],
        {"universes": [], "summary": {}, "score": 0, "state": "unknown"},
        timeout=10,
        env_extra={"SEVENOS_UNIVERSES_FROM_EXPERIENCE": "1"},
    )
    recommendations = recommended_actions(report, backups, events, memory)
    care_plan = care_plan_state(daily_briefing, recommendations, personal_setup)
    rescue_checks = [
        {"title": tr("Interface", "Interface"), "state": "OK", "detail": tr("Réparation non destructive disponible.", "Non-destructive repair available."), "command": "seven repair ux --apply && seven theme sync && seven-waybar repair"},
        {"title": tr("Réseau", "Network"), "state": "OK" if command_exists("nmcli") else "WARN", "detail": tr("Panneau Wi-Fi et diagnostic réseau.", "Wi-Fi panel and network diagnostics."), "command": "seven settings network"},
        {"title": tr("Sauvegarde", "Backup"), "state": "OK" if backups else "INFO", "detail": tr(f"{backups} sauvegarde(s) trouvée(s).", f"{backups} backup set(s) found."), "command": "seven recovery backup"},
        {"title": "Prism", "state": "OK", "detail": tr("Contrôle fenêtre et identité SevenOS.", "Window control and SevenOS identity."), "command": "seven settings prism"},
    ]
    return {
        "schema": "sevenos.experience-center.v1",
        "state": "ready",
        "context": context,
        "active_profile": profile,
        "active_profile_title": profile_title,
        "trust": report,
        "briefing": daily_briefing,
        "care_plan": care_plan,
        "recommendations": recommendations,
        "setup": personal_setup,
        "privacy_report": privacy_report,
        "sections": ["briefing", "care", "trust", "differentiators", "universes", "setup", "intent", "missions", "learning", "device-continuity", "privacy-report", "rescue", "time-machine", "timeline", "permissions", "journeys", "continuity", "memory"],
        "learning": learning,
        "intent_palette": intent_palette,
        "missions": missions,
        "differentiators": differentiators,
        "universes": universes,
        "device_continuity": device_continuity,
        "rescue": {"title": "SevenOS Rescue Mode", "checks": rescue_checks},
        "time_machine": {
            "title": "SevenOS Time Machine",
            "backup_count": backups,
            "path": str(MIGRATION_DIR),
            "commands": ["seven recovery backup", "seven manifest restore-plan", "seven update rollback"],
        },
        "timeline": {"title": "SevenOS Activity Timeline", "events": events, "path": str(EVENT_FILE)},
        "permissions": {"title": "SevenOS Permissions Center", "checks": permissions},
        "journeys": {"title": "SevenOS Focus Journeys", "items": journey_rows()},
        "continuity": {
            "title": "SevenOS App Continuity",
            "routes": [
                {"from": "atlas", "to": "studio", "intent": tr("éditer un document ou une image", "edit a document or image"), "command": "seven bridge send --from atlas --to studio <file>"},
                {"from": "atlas", "to": "baobab", "intent": tr("archiver une source culturelle", "archive a cultural source"), "command": "seven bridge send --from atlas --to baobab <file>"},
                {"from": "forge", "to": "shield", "intent": tr("analyser un artefact ou paquet", "analyze an artifact or package"), "command": "seven bridge send --from forge --to shield <file>"},
                {"from": "studio", "to": "pulse", "intent": tr("préparer capture ou média de jeu", "prepare capture or gaming media"), "command": "seven bridge send --from studio --to pulse <file>"},
            ],
        },
        "memory": {
            "title": "SevenOS Workspace Memory",
            "path": str(WORKSPACE_MEMORY),
            "state": "OK" if memory else "INFO",
            "profiles": memory.get("profiles", {}) if isinstance(memory.get("profiles"), dict) else {},
            "command": "seven-window memory --json",
        },
    }


def emit_event(message: str, command: str = "") -> None:
    try:
        subprocess.run([str(ROOT / "scripts/events.sh"), "log", "--source", "experience-center", "--type", "ui", "--message", message, "--command", command, "--state", "OK"], cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, check=False, timeout=2)
    except Exception:
        pass


def run_detached(command: str) -> None:
    emit_event(tr("Action lancée depuis Experience Center.", "Action launched from Experience Center."), command)
    subprocess.Popen(["bash", "-lc", command], cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)


def print_human(data: dict, section: str = "status") -> None:
    context = data.get("context", {}) if isinstance(data.get("context"), dict) else {}
    print("SevenOS Experience Center")
    print("=========================")
    print(f"{tr('Profil actif', 'Active profile')}: {data.get('active_profile_title')}")
    if context:
        print(f"{tr('Contexte', 'Context')}: {context.get('time')} · {context.get('language_label')} · {context.get('timezone')}")
    print(f"{tr('État', 'State')}: {data.get('state')}")
    trust = data.get("trust", {}) if isinstance(data.get("trust"), dict) else {}
    if trust:
        print(f"{tr('Confiance', 'Trust')}: {trust.get('score', 0)}% · {trust.get('label', '')}")
    print()
    if section == "status" and data.get("recommendations"):
        print(tr("Actions recommandées", "Recommended Actions"))
        for item in data["recommendations"][:3]:
            print(f"  - {item.get('title')}: {item.get('detail')}")
        print()
    if section in {"briefing"}:
        briefing = data.get("briefing", {}) if isinstance(data.get("briefing"), dict) else {}
        print(tr("Briefing quotidien", "Daily Briefing"))
        print(f"  {briefing.get('headline', '')}")
        for item in briefing.get("checks", []):
            print(f"  {item.get('state', 'INFO'):<4} {item.get('title')}: {item.get('detail')}")
        print()
        print(tr("À faire ensuite", "Next actions"))
        for item in briefing.get("next_actions", []):
            print(f"  - {item.get('title')}: {item.get('command')}")
    if section in {"care"}:
        care = data.get("care_plan", {}) if isinstance(data.get("care_plan"), dict) else {}
        print("SevenOS Care Plan")
        for label, key in ((tr("Maintenant", "Now"), "now"), (tr("Ensuite", "Next"), "next"), (tr("Déjà sain", "Healthy"), "healthy")):
            print(label)
            for item in care.get(key, []):
                print(f"  {item.get('state', 'INFO'):<4} {item.get('title')}: {item.get('detail')}")
                print(f"      {item.get('command')}")
    if section in {"trust"} and trust:
        print(tr("Rapport de confiance", "Trust Report"))
        checks = trust.get("checks", {}) if isinstance(trust.get("checks"), dict) else {}
        for key, ok in checks.items():
            marker = "OK" if ok else "INFO"
            print(f"  {marker:<4} {key.replace('_', ' ')}")
    if section in {"differentiators"}:
        differentiators = data.get("differentiators", {}) if isinstance(data.get("differentiators"), dict) else {}
        summary = differentiators.get("summary", {}) if isinstance(differentiators.get("summary"), dict) else {}
        print("SevenOS Differentiators")
        print(f"  {differentiators.get('state', 'unknown')} · {differentiators.get('score', 0)}% · {summary.get('ok', 0)}/{summary.get('pillars', 0)}")
        for item in differentiators.get("checks", []):
            print(f"  {item.get('state', 'PART'):<4} {item.get('title')}: {item.get('goal')}")
            print(f"      {item.get('ready', 0)}/{item.get('total', 0)} · {item.get('command', '')}")
    if section in {"universes"}:
        universes = data.get("universes", {}) if isinstance(data.get("universes"), dict) else {}
        summary = universes.get("summary", {}) if isinstance(universes.get("summary"), dict) else {}
        print("SevenOS Universes")
        print(f"  {universes.get('state', 'unknown')} · {universes.get('score', 0)}% · {summary.get('ready', 0)}/{summary.get('universes', 0)}")
        core = universes.get("core", {}) if isinstance(universes.get("core"), dict) else {}
        if core:
            print(f"  {'OK' if core.get('ready') else 'PART':<4} {core.get('title')}: {core.get('role')}")
        for item in universes.get("universes", []):
            active = " · actif" if item.get("active") else ""
            caps = ", ".join(str(cap) for cap in item.get("capabilities", [])[:3])
            print(f"  {item.get('state', 'PART'):<4} {item.get('title')}: {item.get('role')}{active}")
            print(f"      {item.get('installed', 0)}/{item.get('total', 0)} · {caps}")
    if section in {"setup"}:
        setup = data.get("setup", {}) if isinstance(data.get("setup"), dict) else {}
        print(tr("Configuration personnelle", "Personal Setup"))
        print(f"  {setup.get('percent', 0)}% · {setup.get('ready', 0)}/{setup.get('total', 0)}")
        for item in setup.get("steps", []):
            print(f"  {item.get('state', 'INFO'):<4} {item.get('title')}: {item.get('detail')}")
    if section in {"privacy-report"}:
        report = data.get("privacy_report", {}) if isinstance(data.get("privacy_report"), dict) else {}
        print("Privacy Report")
        for item in report.get("checks", []):
            print(f"  {item.get('state', 'INFO'):<4} {item.get('title')}: {item.get('detail')}")
    if section in {"learning"}:
        learning = data.get("learning", {}) if isinstance(data.get("learning"), dict) else {}
        print(tr("Aide contextuelle", "Context Help"))
        for item in learning.get("guides", []):
            print(f"  - {item.get('title')}: {item.get('intent')}")
            print(f"    {item.get('command')}")
    if section in {"device-continuity"}:
        continuity_state = data.get("device_continuity", {}) if isinstance(data.get("device_continuity"), dict) else {}
        print(tr("Continuité appareils", "Device Continuity"))
        print(f"  {continuity_state.get('ready_count', 0)}/{continuity_state.get('total', 0)} · {continuity_state.get('device', '')}")
        for item in continuity_state.get("checks", []):
            print(f"  {item.get('state', 'INFO'):<4} {item.get('title')}: {item.get('detail')}")
    if section in {"intent"}:
        intent = data.get("intent_result") if isinstance(data.get("intent_result"), dict) else {}
        if intent.get("query"):
            print(f"{tr('Intention', 'Intent')}: {intent.get('query')}")
        match = intent.get("match") if isinstance(intent.get("match"), dict) else None
        if match:
            print(f"  {tr('Meilleur parcours', 'Best route')}: {match.get('title')}")
            print(f"  {match.get('detail')}")
            print(f"  {match.get('command')}")
            for index, step_item in enumerate(match.get("steps", []) if isinstance(match.get("steps"), list) else [], 1):
                print(f"    {index}. {step_item.get('profile_title')}: {step_item.get('title')}")
                print(f"       {step_item.get('detail')}")
                if step_item.get("output"):
                    print(f"       {tr('Sortie attendue', 'Expected output')}: {step_item.get('output')}")
        else:
            print(tr("Intentions disponibles", "Available intents"))
            palette = data.get("intent_palette", {}) if isinstance(data.get("intent_palette"), dict) else {}
            for item in palette.get("items", [])[:8]:
                print(f"  - {item.get('title')}: {item.get('detail')}")
    if section in {"status", "missions"}:
        print("\nEquinox Mission Planner")
        missions = data.get("missions", {}) if isinstance(data.get("missions"), dict) else {}
        mission_result = data.get("mission_result") if isinstance(data.get("mission_result"), dict) else {}
        mission_match = mission_result.get("match") if isinstance(mission_result.get("match"), dict) else None
        print(f"  {missions.get('summary', '')}")
        print(f"  {tr('Préparation', 'Readiness')}: {missions.get('ready_profiles', 0)}/{missions.get('total_profiles', 0)} · bridge={missions.get('bridge_state', 'unknown')}")
        visible_missions = [mission_match] if mission_match else missions.get("items", [])[:6]
        if mission_result.get("query") and not mission_match:
            print(f"  {tr('Aucune mission exacte, suggestions', 'No exact mission, suggestions')}: {mission_result.get('query')}")
            visible_missions = mission_result.get("items", [])[:5]
        for item in visible_missions:
            print(f"  - {item.get('title')}: {item.get('detail')}")
            print(f"    {item.get('state', 'INFO')} · {item.get('ready_steps', 0)}/{item.get('total_steps', 0)} {tr('étapes prêtes', 'ready steps')}")
            steps = item.get("steps", []) if isinstance(item.get("steps"), list) else []
            if steps:
                print("    " + " -> ".join(str(step_item.get("profile_title", "")) for step_item in steps))
                for index, step_item in enumerate(steps, 1):
                    print(f"      {index}. {step_item.get('profile_title')}: {step_item.get('title')}")
                    print(f"         {step_item.get('detail')}")
                    if step_item.get("output"):
                        print(f"         {tr('Sortie attendue', 'Expected output')}: {step_item.get('output')}")
                    if step_item.get("handoff"):
                        print(f"         {tr('Passage', 'Handoff')}: {step_item.get('handoff')}")
            if item.get("command"):
                print(f"    {tr('Démarrer', 'Start')}: {item.get('command')}")
    if section in {"status", "rescue"}:
        print("Rescue")
        for item in data["rescue"]["checks"]:
            print(f"  {item['state']:<4} {item['title']}: {item['detail']}")
    if section in {"status", "time-machine"}:
        print(f"\nTime Machine: {data['time_machine']['backup_count']} backup(s)")
    if section in {"status", "timeline"}:
        print("\nTimeline")
        for item in data["timeline"]["events"][-5:]:
            print(f"  {item.get('timestamp', '')} {item.get('source', 'sevenos')}: {item.get('message', '')}")
    if section in {"status", "permissions"}:
        print("\nPermissions")
        for item in data["permissions"]["checks"]:
            print(f"  {item['state']:<4} {item['title']}: {item['detail']}")
    if section in {"status", "journeys"}:
        print("\nFocus Journeys")
        for item in data["journeys"]["items"]:
            print(f"  {item['icon']} {item['title']}: {item['intent']}")
    if section in {"status", "continuity"}:
        print("\nApp Continuity")
        for item in data["continuity"]["routes"]:
            print(f"  {item['from']} -> {item['to']}: {item['intent']}")
            print(f"    {item['command']}")
    if section in {"status", "memory"}:
        print("\nWorkspace Memory")
        print(f"  {data['memory']['state']}: {data['memory']['path']}")
        print(f"  command: {data['memory']['command']}")


def main() -> int:
    args = sys.argv[1:]
    if "--probe" in args:
        print(json.dumps({"schema": "sevenos.experience-center.probe.v1", "state": "OK", "root": str(ROOT)}, ensure_ascii=False))
        return 0
    data = payload()
    intent_query = ""
    if "intent" in args:
        try:
            idx = args.index("intent")
            intent_query = " ".join(item for item in args[idx + 1:] if not item.startswith("--"))
        except ValueError:
            intent_query = ""
        data["intent_result"] = resolve_intent(data, intent_query)
    if "mission" in args or "missions" in args:
        marker = "mission" if "mission" in args else "missions"
        try:
            idx = args.index(marker)
            mission_query = " ".join(item for item in args[idx + 1:] if not item.startswith("--"))
        except ValueError:
            mission_query = ""
        data["mission_result"] = resolve_mission(data, mission_query)
    if "--json" in args or "json" in args:
        print(json.dumps(data, indent=2, ensure_ascii=False))
        return 0
    section = next((item for item in args if item in {"status", "briefing", "care", "trust", "differentiators", "universes", "setup", "personal-setup", "intent", "missions", "learning", "device-continuity", "privacy-report", "rescue", "time-machine", "timeline", "permissions", "journeys", "continuity", "memory"}), "status")
    if section == "personal-setup":
        section = "setup"
    if "--gui" not in args or not (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        print_human(data, section)
        return 0

    ensure_gi_python()
    import gi

    gi.require_version("Gtk", "3.0")
    gi.require_version("Gdk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    css_prefix = seven_theme.gtk_app_css("experience-center", theme_mode()) if seven_theme else ""
    css = (css_prefix + """
