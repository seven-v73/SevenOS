#!/usr/bin/env python3
"""SevenOS Experience Center: Rescue, Time Machine, Timeline and Focus Journeys."""

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python3")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python.resolve():
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.execve(str(system_python), [str(system_python), str(Path(__file__).resolve()), *sys.argv[1:]], {**os.environ, "SEVENOS_GI_PYTHON": "1"})


def resolve_root() -> Path:
    env = os.environ.get("SEVENOS_ROOT")
    if env and (Path(env) / "bin/seven").exists():
        return Path(env).resolve()
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin/seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "sevenos"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache")))
DATA_DIR = Path(os.environ.get("XDG_DATA_HOME", str(Path.home() / ".local/share"))) / "sevenos"
EVENT_FILE = STATE_DIR / "events.jsonl"
SETTINGS_ACTION_LOG = CACHE_DIR / "settings-actions.log"
MIGRATION_DIR = DATA_DIR / "migrations"
WORKSPACE_MEMORY = STATE_DIR / "workspace-memory.json"
THEME_PREFS = CONFIG_DIR / "theme-preferences.json"
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme  # noqa: E402
except Exception:  # pragma: no cover
    seven_theme = None


def language_code() -> str:
    language = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG", "en_US.UTF-8")
    config = CONFIG_DIR / "language.conf"
    if not os.environ.get("SEVENOS_LANGUAGE") and config.exists():
        for raw in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = raw.partition("=")
            if key.strip() in {"SEVENOS_LANGUAGE", "LANG"}:
                language = value.strip().strip("'\"")
                break
    return "fr" if language.lower().startswith("fr") else "en"


LANG = language_code()


def tr(fr: str, en: str) -> str:
    return fr if LANG == "fr" else en


def theme_mode() -> str:
    if seven_theme:
        return seven_theme.current_theme_mode()
    value = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    return value if value in {"dark", "light"} else "dark"


def current_context() -> dict:
    raw_lang = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG", "en_US.UTF-8")
    config = CONFIG_DIR / "language.conf"
    if not os.environ.get("SEVENOS_LANGUAGE") and config.exists():
        for raw in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = raw.partition("=")
            if key.strip() in {"SEVENOS_LANGUAGE", "LANG"}:
                raw_lang = value.strip().strip("'\"")
                break
    active_lang = "fr" if raw_lang.lower().startswith("fr") else "en"
    timezone = os.environ.get("TZ", "")
    try:
        result = subprocess.run(["timedatectl", "show", "-p", "Timezone", "--value"], text=True, capture_output=True, check=False, timeout=0.8)
        timezone = result.stdout.strip() or timezone
    except Exception:
        pass
    timezone = timezone or "local"
    hour = int(time.strftime("%H"))
    if 5 <= hour < 12:
        moment = "Matin" if active_lang == "fr" else "Morning"
        greeting = "Bonjour" if active_lang == "fr" else "Good morning"
    elif 12 <= hour < 18:
        moment = "Après-midi" if active_lang == "fr" else "Afternoon"
        greeting = "Bon après-midi" if active_lang == "fr" else "Good afternoon"
    elif 18 <= hour < 23:
        moment = "Soir" if active_lang == "fr" else "Evening"
        greeting = "Bonsoir" if active_lang == "fr" else "Good evening"
    else:
        moment = "Nuit" if active_lang == "fr" else "Night"
        greeting = "Bonne nuit" if active_lang == "fr" else "Good night"
    return {
        "language": active_lang,
        "language_raw": raw_lang,
        "language_label": "Français" if active_lang == "fr" else "English",
        "time": time.strftime("%H:%M"),
        "date": time.strftime("%Y-%m-%d"),
        "timezone": timezone,
        "moment": moment,
        "greeting": greeting,
    }


PROFILES = {
    "equinox": ("Equinox", tr("Bureau quotidien et équilibre système.", "Daily desktop and system balance."), "󰐃", "#8B7CFF"),
    "baobab": ("Baobab", tr("Culture, mémoire, langues et transmission.", "Culture, memory, languages and transmission."), "󰣇", "#A6E3A1"),
    "forge": ("Forge", tr("Code, services, livraison et projets web.", "Code, services, deployment and web projects."), "󰅩", "#F9E2AF"),
    "shield": ("Shield", tr("Protection, audit autorisé et confiance.", "Protection, authorized audit and trust."), "󰒃", "#00FFB3"),
    "studio": ("Studio", tr("Création visuelle, son, vidéo et assets.", "Visual creation, sound, video and assets."), "󰏗", "#CBA6F7"),
    "atlas": ("Atlas", tr("Documents, cartes, OCR et références.", "Documents, maps, OCR and references."), "󰙅", "#5AD7B7"),
    "pulse": ("Pulse", tr("Jeux, captures et performance fluide.", "Gaming, capture and smooth performance."), "󰊴", "#00D4FF"),
}


def run_json(command: list[str], fallback: dict | None = None, timeout: float = 3.5, env_extra: dict | None = None) -> dict:
    try:
        result = subprocess.run(command, cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT), **(env_extra or {})}, text=True, capture_output=True, check=False, timeout=timeout)
        return json.loads(result.stdout or "{}") if result.stdout.strip() else (fallback or {})
    except Exception:
        return fallback or {}


def command_exists(command: str) -> bool:
    return any((Path(item) / command).exists() for item in os.environ.get("PATH", "").split(os.pathsep) if item)


def simple_out(command: list[str], fallback: str = "", timeout: float = 1.0) -> str:
    try:
        result = subprocess.run(command, cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, text=True, capture_output=True, check=False, timeout=timeout)
        return result.stdout.strip() or fallback
    except Exception:
        return fallback


def active_profile() -> str:
    data = run_json([str(ROOT / "bin/seven"), "profile", "current", "--json"], timeout=2.0)
    key = str(data.get("key") or data.get("profile") or "equinox").lower()
    return key if key in PROFILES else "equinox"


def migration_count() -> int:
    if not MIGRATION_DIR.is_dir():
        return 0
    return len([item for item in MIGRATION_DIR.iterdir() if item.is_dir()])


def recent_events(limit: int = 8) -> list[dict]:
    events: list[dict] = []
    if EVENT_FILE.exists():
        for raw in EVENT_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()[-limit:]:
            try:
                payload = json.loads(raw)
            except json.JSONDecodeError:
                continue
            if isinstance(payload, dict):
                events.append(payload)
    if SETTINGS_ACTION_LOG.exists() and len(events) < limit:
        blocks = SETTINGS_ACTION_LOG.read_text(encoding="utf-8", errors="ignore").split("--- SevenOS Settings action ---")
        for block in blocks[-limit:]:
            lines = [line.strip() for line in block.splitlines() if line.strip()]
            command = next((line[2:] for line in lines if line.startswith("$ ")), "")
            stamp = next((line.partition("=")[2] for line in lines if line.startswith("time=")), "")
            state = next((line.partition("=")[2] for line in lines if line.startswith("exit=")), "started")
            if command:
                events.append({"timestamp": stamp, "source": "settings", "type": "action", "state": state, "message": command, "command": command})
    return events[-limit:]


def workspace_memory() -> dict:
    if WORKSPACE_MEMORY.exists():
        try:
            data = json.loads(WORKSPACE_MEMORY.read_text(encoding="utf-8"))
            return data if isinstance(data, dict) else {}
        except Exception:
            return {}
    return {}


def current_theme() -> str:
    if THEME_PREFS.exists():
        try:
            data = json.loads(THEME_PREFS.read_text(encoding="utf-8"))
            value = str(data.get("mode") or data.get("preferred") or "").lower()
            if value in {"light", "dark"}:
                return value
        except Exception:
            pass
    value = f"{os.environ.get('SEVENOS_THEME', '')} {os.environ.get('GTK_THEME', '')}".lower()
    return "light" if "light" in value else "dark"


def permissions_state() -> list[dict]:
    flatpak_ready = command_exists("flatpak")
    portal_ready = command_exists("xdg-desktop-portal") or Path("/usr/lib/xdg-desktop-portal").exists()
    microphone = Path("/dev/snd").exists()
    camera = any(Path("/dev").glob("video*"))
    return [
        {"key": "portal", "title": tr("Portails système", "System portals"), "state": "OK" if portal_ready else "WARN", "detail": tr("Demandes caméra, écran, fichiers et permissions via portail.", "Camera, screen, files and permissions through portal."), "command": "seven settings privacy"},
        {"key": "flatpak", "title": "Flatpak", "state": "OK" if flatpak_ready else "WARN", "detail": tr("Permissions applicatives vérifiables pour les apps sandboxées.", "Inspectable app permissions for sandboxed apps."), "command": "seven store"},
        {"key": "microphone", "title": tr("Micro", "Microphone"), "state": "OK" if microphone else "INFO", "detail": tr("Contrôle via Son et Confidentialité.", "Controlled through Sound and Privacy."), "command": "seven settings sound"},
        {"key": "camera", "title": tr("Caméra", "Camera"), "state": "OK" if camera else "INFO", "detail": tr("Accès visible seulement si un périphérique existe.", "Access is visible only when a device exists."), "command": "seven settings privacy"},
    ]


def journey_rows() -> list[dict]:
    rows = []
    for key, (title, note, icon, accent) in PROFILES.items():
        intent = {
            "equinox": tr("Me recentrer", "Recenter"),
            "baobab": tr("Explorer une mémoire", "Explore memory"),
            "forge": tr("Coder et livrer", "Code and deploy"),
            "shield": tr("Vérifier prudemment", "Verify safely"),
            "studio": tr("Créer un rendu", "Create output"),
            "atlas": tr("Étudier et classer", "Study and classify"),
            "pulse": tr("Jouer sans friction", "Play smoothly"),
        }.get(key, title)
        rows.append({"key": key, "title": title, "intent": intent, "note": note, "icon": icon, "accent": accent, "command": f"seven profile activate {key}", "open": f"seven experience focus {key}"})
    return rows


def trust_report(backups: int, events: list[dict], memory: dict, permissions: list[dict], profile: str) -> dict:
    checks = {
        "rescue": True,
        "backup": backups > 0,
        "timeline": bool(events),
        "permissions": all(item.get("state") != "WARN" for item in permissions),
        "workspace_memory": bool(memory),
        "profile_context": profile in PROFILES,
    }
    score = round(sum(1 for ok in checks.values() if ok) / max(1, len(checks)) * 100)
    if score >= 86:
        label = tr("Très rassurant", "Very reassuring")
        state = "ready"
    elif score >= 66:
        label = tr("Bon, à compléter", "Good, can improve")
        state = "attention"
    else:
        label = tr("À préparer", "Needs setup")
        state = "setup"
    return {
        "score": score,
        "label": label,
        "state": state,
        "checks": checks,
    }


def recommended_actions(report: dict, backups: int, events: list[dict], memory: dict) -> list[dict]:
    actions: list[dict] = []
    if backups <= 0:
        actions.append({
            "title": tr("Créer un premier point de retour", "Create a first return point"),
            "detail": tr("Time Machine devient vraiment utile dès qu’une sauvegarde locale existe.", "Time Machine becomes truly useful once a local backup exists."),
            "command": "seven recovery backup",
            "confirm": True,
            "priority": 1,
        })
    if not events:
        actions.append({
            "title": tr("Activer la lecture de la timeline", "Open the timeline"),
            "detail": tr("SevenOS affichera ici les actions importantes et les changements récents.", "SevenOS will show important actions and recent changes here."),
            "command": "seven events list",
            "confirm": False,
            "priority": 2,
        })
    if not memory:
        actions.append({
            "title": tr("Préparer la mémoire de travail", "Prepare workspace memory"),
            "detail": tr("Chaque mini OS pourra reprendre son contexte utile après un changement d’espace.", "Each Mini OS can resume useful context after switching spaces."),
            "command": "seven experience workspace",
            "confirm": False,
            "priority": 3,
        })
    if report.get("score", 0) < 100:
        actions.append({
            "title": tr("Faire un contrôle léger", "Run a light check"),
            "detail": tr("Vérifie l’état sans modifier la machine.", "Checks state without modifying the machine."),
            "command": "seven smoke doctor",
            "confirm": False,
            "priority": 4,
        })
    if not actions:
        actions.append({
            "title": tr("Tout est calme", "Everything is calm"),
            "detail": tr("Tu peux ouvrir les parcours focus ou continuer ton activité.", "You can open focus journeys or continue your activity."),
            "command": "seven journeys",
            "confirm": False,
            "priority": 1,
        })
    return actions[:4]


def personal_setup_state(profile: str, backups: int, memory: dict) -> dict:
    language = language_code()
    theme = current_theme()
    profile_title = PROFILES.get(profile, PROFILES["equinox"])[0]
    steps = [
        {"key": "language", "title": tr("Langue système", "System language"), "state": "OK", "detail": language.upper(), "command": "seven settings general"},
        {"key": "theme", "title": tr("Thème", "Theme"), "state": "OK", "detail": theme, "command": "seven settings appearance"},
        {"key": "profile", "title": "Mini OS", "state": "OK" if profile in PROFILES else "WARN", "detail": profile_title, "command": "seven settings profiles"},
        {"key": "prism", "title": "Prism", "state": "OK", "detail": tr("Réglable depuis Paramètres.", "Configurable from Settings."), "command": "seven settings prism"},
        {"key": "backup", "title": "Time Machine", "state": "OK" if backups else "INFO", "detail": tr(f"{backups} sauvegarde(s).", f"{backups} backup set(s)."), "command": "seven recovery backup"},
        {"key": "memory", "title": tr("Mémoire de travail", "Workspace memory"), "state": "OK" if memory else "INFO", "detail": tr("Contexte prêt." if memory else "À préparer.", "Context ready." if memory else "Can be prepared."), "command": "seven experience workspace"},
        {"key": "help", "title": tr("Aide", "Help"), "state": "OK", "detail": "Super+H · seven help", "command": "seven-help-native"},
    ]
    ready = sum(1 for item in steps if item["state"] == "OK")
    return {"title": "SevenOS Personal Setup", "ready": ready, "total": len(steps), "percent": round(ready / max(1, len(steps)) * 100), "steps": steps}


def privacy_report_state(permissions: list[dict], events: list[dict]) -> dict:
    user_services = simple_out(["systemctl", "--user", "--no-pager", "--plain", "--type=service", "--state=running", "list-units"], "", timeout=1.2)
    running_services = max(0, len([line for line in user_services.splitlines() if ".service" in line]))
    recent_sensitive = [
        event for event in events
        if any(word in str(event.get("message", "")).lower() for word in ("sudo", "install", "update", "permission", "privacy", "shield", "flatpak"))
    ]
    checks = [
        {"title": tr("Permissions apps", "App permissions"), "state": "OK" if all(item.get("state") != "WARN" for item in permissions) else "WARN", "detail": tr("Portails, Flatpak, micro et caméra inspectables.", "Portals, Flatpak, microphone and camera are inspectable."), "command": "seven permissions"},
        {"title": tr("Services utilisateur", "User services"), "state": "OK", "detail": tr(f"{running_services} service(s) utilisateur actifs.", f"{running_services} active user service(s)."), "command": "systemctl --user --type=service --state=running"},
        {"title": tr("Événements sensibles", "Sensitive events"), "state": "INFO" if recent_sensitive else "OK", "detail": tr(f"{len(recent_sensitive)} événement(s) à relire.", f"{len(recent_sensitive)} event(s) to review."), "command": "seven timeline"},
        {"title": "Shield", "state": "OK", "detail": tr("Audit accessible depuis Shield.", "Audit available through Shield."), "command": "seven shield audit"},
        {"title": "SevenAI", "state": "OK", "detail": tr("Données locales et provider visibles.", "Local data and provider are visible."), "command": "seven ai provider"},
    ]
    return {"title": "SevenOS Privacy Report", "checks": checks, "running_user_services": running_services, "sensitive_events": len(recent_sensitive)}


def daily_briefing_state(profile: str, trust: dict, setup: dict, privacy_report: dict, device: dict, events: list[dict], backups: int, context: dict) -> dict:
    connectivity = simple_out(["nmcli", "-t", "-f", "CONNECTIVITY", "general"], "", timeout=0.8) if command_exists("nmcli") else ""
    network_state = "OK" if connectivity in {"full", "limited", "portal"} else ("INFO" if not connectivity else "WARN")
    battery_status = simple_out(["bash", "-lc", "for b in /sys/class/power_supply/BAT*/capacity; do [ -r \"$b\" ] && cat \"$b\" && exit 0; done"], "", timeout=0.8)
    battery_note = tr("Secteur ou batterie non détectée.", "AC power or battery not detected.")
    battery_state = "OK"
    if battery_status.isdigit():
        pct = int(battery_status)
        battery_note = tr(f"{pct}% disponible.", f"{pct}% available.")
        battery_state = "WARN" if pct < 20 else "OK"
    profile_title = PROFILES.get(profile, PROFILES["equinox"])[0]
    trust_score = int(trust.get("score", 0) or 0)
    setup_percent = int(setup.get("percent", 0) or 0)
    privacy_sensitive = int(privacy_report.get("sensitive_events", 0) or 0)
    device_ready = int(device.get("ready_count", 0) or 0)
    device_total = int(device.get("total", 0) or 0)
    checks = [
        {
            "key": "context",
            "title": tr("Temps et langue", "Time and language"),
            "state": "OK",
            "detail": tr(
                f"{context.get('time')} · {context.get('language_label')} · {context.get('timezone')}",
                f"{context.get('time')} · {context.get('language_label')} · {context.get('timezone')}",
            ),
            "command": "seven settings general",
        },
        {
            "key": "profile",
            "title": tr("Espace actif", "Active space"),
            "state": "OK",
            "detail": tr(f"{profile_title} est prêt pour le contexte actuel.", f"{profile_title} is ready for the current context."),
            "command": "seven settings profiles",
        },
        {
            "key": "trust",
            "title": tr("Confiance système", "System trust"),
            "state": "OK" if trust_score >= 86 else "INFO",
            "detail": tr(f"{trust_score}% · {trust.get('label', '')}", f"{trust_score}% · {trust.get('label', '')}"),
            "command": "seven trust --gui",
        },
        {
            "key": "setup",
            "title": tr("Configuration personnelle", "Personal setup"),
            "state": "OK" if setup_percent >= 85 else "INFO",
            "detail": tr(f"{setup_percent}% configuré.", f"{setup_percent}% configured."),
            "command": "seven personal-setup --gui",
        },
        {
            "key": "network",
            "title": tr("Réseau", "Network"),
            "state": network_state,
            "detail": tr(f"Connectivité: {connectivity or 'non vérifiée'}.", f"Connectivity: {connectivity or 'not checked'}."),
            "command": "seven settings network",
        },
        {
            "key": "power",
            "title": tr("Énergie", "Power"),
            "state": battery_state,
            "detail": battery_note,
            "command": "seven settings power",
        },
        {
            "key": "backup",
            "title": "Time Machine",
            "state": "OK" if backups else "INFO",
            "detail": tr(f"{backups} point(s) de retour local.", f"{backups} local return point(s)."),
            "command": "seven time-machine --gui",
        },
        {
            "key": "privacy",
            "title": tr("Confidentialité", "Privacy"),
            "state": "INFO" if privacy_sensitive else "OK",
            "detail": tr(f"{privacy_sensitive} événement(s) sensible(s) récent(s).", f"{privacy_sensitive} recent sensitive event(s)."),
            "command": "seven privacy-report --gui",
        },
        {
            "key": "devices",
            "title": tr("Continuité appareils", "Device continuity"),
            "state": "OK" if device_ready == device_total else "INFO",
            "detail": tr(f"{device_ready}/{device_total} bases prêtes.", f"{device_ready}/{device_total} foundations ready."),
            "command": "seven device-continuity --gui",
        },
    ]
    attention = [item for item in checks if item["state"] != "OK"]
    headline = (
        tr(f"{context.get('greeting')}. SevenOS est prêt.", f"{context.get('greeting')}. SevenOS is ready.")
        if not attention
        else tr(f"{context.get('greeting')}. SevenOS est prêt, avec quelques points à revoir.", f"{context.get('greeting')}. SevenOS is ready, with a few points to review.")
    )
    next_actions = [
        {"title": item["title"], "detail": item["detail"], "command": item["command"], "confirm": item["key"] == "backup"}
        for item in attention[:3]
    ]
    if not next_actions:
        next_actions = [
            {"title": tr("Ouvrir les parcours focus", "Open focus journeys"), "detail": tr("Choisir un rythme adapté à l’activité du moment.", "Choose a rhythm for the current activity."), "command": "seven journeys --gui", "confirm": False},
            {"title": tr("Ouvrir la palette d’intentions", "Open intent palette"), "detail": tr("Chercher une action par besoin humain.", "Search actions by human need."), "command": "seven intent --gui", "confirm": False},
        ]
    return {
        "title": "SevenOS Daily Briefing",
        "headline": headline,
        "context": context,
        "profile": profile,
        "profile_title": profile_title,
        "event_count": len(events),
        "checks": checks,
        "next_actions": next_actions,
    }


def care_plan_state(briefing: dict, recommendations: list[dict], setup: dict) -> dict:
    checks = briefing.get("checks", []) if isinstance(briefing.get("checks"), list) else []
    now = [
        {
            "title": item.get("title", ""),
            "detail": item.get("detail", ""),
            "command": item.get("command", "seven briefing --gui"),
            "confirm": item.get("key") == "backup",
            "state": item.get("state", "INFO"),
        }
        for item in checks
        if item.get("state") == "WARN"
    ]
    if not now:
        now = [
            {
                "title": item.get("title", ""),
                "detail": item.get("detail", ""),
                "command": item.get("command", "seven briefing --gui"),
                "confirm": bool(item.get("confirm")),
                "state": "INFO",
            }
            for item in briefing.get("next_actions", [])[:2]
        ]
    next_items = [
        {
            "title": item.get("title", ""),
            "detail": item.get("detail", ""),
            "command": item.get("command", "seven experience-center --gui"),
            "confirm": bool(item.get("confirm")),
            "state": "INFO",
        }
        for item in recommendations[:3]
    ]
    setup_steps = setup.get("steps", []) if isinstance(setup.get("steps"), list) else []
    if len(next_items) < 3:
        for step in setup_steps:
            if step.get("state") != "OK":
                next_items.append({
                    "title": step.get("title", ""),
                    "detail": step.get("detail", ""),
                    "command": step.get("command", "seven personal-setup --gui"),
                    "confirm": step.get("key") == "backup",
                    "state": step.get("state", "INFO"),
                })
            if len(next_items) >= 3:
                break
    healthy = [
        {
            "title": item.get("title", ""),
            "detail": item.get("detail", ""),
            "command": item.get("command", "seven briefing --gui"),
            "state": "OK",
            "confirm": False,
        }
        for item in checks
        if item.get("state") == "OK"
    ][:5]
    if not now:
        now = [{
            "title": tr("Tout est stable maintenant", "Everything is stable now"),
            "detail": tr("Aucune action urgente. Tu peux continuer ou ouvrir les parcours focus.", "No urgent action. You can continue or open focus journeys."),
            "command": "seven journeys --gui",
            "confirm": False,
            "state": "OK",
        }]
    return {
        "title": "SevenOS Care Plan",
        "now": now[:3],
        "next": next_items[:4],
        "healthy": healthy,
    }


