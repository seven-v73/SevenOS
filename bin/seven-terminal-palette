#!/usr/bin/env bash
# seven-terminal-palette: quick action layer for Seven Terminal.
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT/bin" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/../bin" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -d "$candidate/bin" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  printf '%s\n' "$HOME"
}

ROOT_DIR="$(resolve_root)"

lang_is_fr() {
  local lang="${SEVENOS_LANGUAGE:-${LANG:-}}"
  [[ "${lang,,}" == fr* ]]
}

last_history_command() {
  local history_file="${HISTFILE:-$HOME/.bash_history}"
  if [[ -r "$history_file" ]]; then
    tail -n 40 "$history_file" | sed '/^[[:space:]]*$/d' | tail -n 1
  fi
}

copy_text() {
  local text="$1"
  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$text" | wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$text" | xclip -selection clipboard
  else
    printf '%s\n' "$text"
  fi
}

native_actions() {
  local native="$ROOT_DIR/bin/seven-actions-native"
  [[ "${SEVENOS_TERMINAL_PALETTE_LEGACY:-0}" != "1" ]] || return 1
  [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]] || return 1
  if [[ -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
    setsid -f "$native" --query terminal --category Desktop --title "Seven Terminal" >/tmp/sevenos-terminal-palette.log 2>&1 || true
    return 0
  fi
  if command -v seven-actions-native >/dev/null 2>&1 && seven-actions-native --probe >/dev/null 2>&1; then
    setsid -f seven-actions-native --query terminal --category Desktop --title "Seven Terminal" >/tmp/sevenos-terminal-palette.log 2>&1 || true
    return 0
  fi
  return 1
}

run_terminal() {
  local title="$1"
  local command="$2"
  if command -v seven-terminal >/dev/null 2>&1; then
    seven-terminal focus -- bash -lc "$command"
  elif command -v kitty >/dev/null 2>&1; then
    kitty --title "$title" bash -lc "$command"
  else
    sh -lc "$command"
  fi
}

actions() {
  if lang_is_fr; then
    cat <<'EOF'
Ouvrir le dossier courant	Ouvrir ce dossier dans Seven Files
Copier le chemin courant	Copier le dossier de travail
Copier la dernière commande	Copier la dernière commande shell
Expliquer la dernière commande	Demander à SevenAI d’expliquer la commande ou l’erreur
Doctor terminal	Afficher l’état de Seven Terminal
Doctor système	Lancer les diagnostics SevenOS
Basculer: Equinox	Ouvrir le terminal du mini OS actif
Basculer: Forge	Ouvrir le terminal développement
Basculer: Shield	Ouvrir le terminal sécurité et réseau
Basculer: Focus	Ouvrir le terminal calme
Basculer: Admin	Ouvrir le terminal système prudent
Thème: Sombre	Appliquer le thème sombre SevenOS
Thème: Clair	Appliquer le thème clair SevenOS
EOF
  else
    cat <<'EOF'
Open Current Folder	Open the current directory in Seven Files
Copy Current Path	Copy the current working directory
Copy Last Command	Copy the last shell history command
Explain Last Command	Ask SevenAI to explain the last command or error
Terminal Doctor	Show Seven Terminal status and checks
System Doctor	Run SevenOS post-install diagnostics
Switch: Equinox	Open the active mini OS terminal
Switch: Forge	Open development terminal
Switch: Shield	Open security and network terminal
Switch: Focus	Open quiet focus terminal
Switch: Admin	Open cautious system-control terminal
Theme: Dark	Apply SevenOS dark theme
Theme: Light	Apply SevenOS light theme
EOF
  fi
}

choose_action() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    actions
    return 0
  fi

  if native_actions; then
    return 1
  fi

  if command -v rofi >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    local message
    message="Quick actions for Seven Terminal"
    lang_is_fr && message="Actions rapides pour Seven Terminal"
    actions | rofi -dmenu -i -p "Seven Terminal" -mesg "$message" -theme "$ROOT_DIR/hyprland/rofi/spotlight.rasi" 2>/dev/null || true
  else
    actions
  fi
}

if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
  actions
  exit 0
fi
selection="$(choose_action || true)"
case "$selection" in
  "Open Current Folder"*|"Ouvrir le dossier courant"*) seven-files "${PWD:-$HOME}" ;;
  "Copy Current Path"*|"Copier le chemin courant"*) copy_text "${PWD:-$HOME}" ;;
  "Copy Last Command"*|"Copier la dernière commande"*) copy_text "$(last_history_command)" ;;
  "Explain Last Command"*|"Expliquer la dernière commande"*)
    last="$(last_history_command)"
    if [[ -n "$last" ]]; then
      run_terminal "SevenAI Terminal" "seven ai \"explique cette commande terminal et les risques possibles: $last\"; printf '\nPress Enter to close...'; read -r"
    else
      run_terminal "SevenAI Terminal" "seven ai terminal; printf '\nPress Enter to close...'; read -r"
    fi
    ;;
  "Terminal Doctor"*|"Doctor terminal"*) run_terminal "Seven Terminal Doctor" "seven-terminal status; printf '\n'; seven identity visuals; printf '\nPress Enter to close...'; read -r" ;;
  "System Doctor"*|"Doctor système"*) run_terminal "SevenOS Doctor" "seven post-install; printf '\nPress Enter to close...'; read -r" ;;
  "Switch: Equinox"*|"Basculer: Equinox"*) seven-terminal ;;
  "Switch: Forge"*|"Basculer: Forge"*) seven-terminal forge ;;
  "Switch: Shield"*|"Switch: Cyber"*|"Basculer: Shield"*) seven-terminal cyber ;;
  "Switch: Focus"*|"Basculer: Focus"*) seven-terminal focus ;;
  "Switch: Admin"*|"Basculer: Admin"*) seven-terminal admin ;;
  "Theme: Dark"*|"Thème: Sombre"*) "$ROOT_DIR/install.sh" theme dark ;;
  "Theme: Light"*|"Thème: Clair"*) "$ROOT_DIR/install.sh" theme light ;;
  ""|*) exit 0 ;;
esac
