#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/bin/seven-dock-native" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/seven-dock-native" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -x "$candidate/bin/seven-dock-native" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root || true)"
native="${ROOT_DIR:+$ROOT_DIR/bin/seven-dock-native}"
config_file="$HOME/.config/sevenos/dock.json"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp/sevenos-$(id -u)}"
pid_file="$runtime_dir/sevenos-dock.pid"
state_file="$runtime_dir/sevenos-dock-state.json"
profile_change_scope="scope=closing-on-profile-change"

active_profile() {
  local profile_env="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/profile.env"
  if [[ -f "$profile_env" ]]; then
    # shellcheck disable=SC1090
    source "$profile_env"
    printf '%s' "${SEVENOS_ACTIVE_PROFILE:-equinox}"
  else
    printf 'equinox'
  fi
}

experience_event() {
  local kind="$1"
  local label="$2"
  if [[ -n "${ROOT_DIR:-}" && -x "$ROOT_DIR/scripts/shell-experience.sh" ]]; then
    "$ROOT_DIR/scripts/shell-experience.sh" "$kind" "$label" >/dev/null 2>&1 || true
  fi
}

is_running() {
  [[ -s "$pid_file" ]] || return 1
  local pid
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

kill_dock_processes() {
  local pid cmdline
  while read -r pid; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    [[ "$pid" != "$$" && "$pid" != "${PPID:-}" ]] || continue
    cmdline="$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null || true)"
    if [[ "$cmdline" == *"seven-dock-native"* ]] || [[ -n "${native:-}" && "$cmdline" == *"$native"* ]]; then
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done < <(pgrep -u "$USER" -f 'seven-dock-native|SevenDockNative' 2>/dev/null || true)
}

open_dock() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'DRY-RUN > Dock > Open SevenOS Dock\n'
    return 0
  fi
  experience_event launch "Seven Dock"
  if is_running; then
    return 0
  fi
  if [[ -n "$native" && -x "$native" ]]; then
    mkdir -p "$runtime_dir"
    rm -f "$state_file"
    SEVENOS_ROOT="$ROOT_DIR" setsid "$native" >/tmp/sevenos-dock.log 2>&1 &
    printf '%s\n' "$!" > "$pid_file"
    sleep 0.25
    if ! is_running; then
      printf 'seven-dock: dock failed to stay open; see /tmp/sevenos-dock.log\n' >&2
      return 1
    fi
  else
    printf 'seven-dock: seven-dock-native not found\n' >&2
    return 1
  fi
}

close_dock() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'DRY-RUN > Dock > Close SevenOS Dock\n'
    return 0
  fi
  experience_event focus "Seven Dock closed"
  if is_running; then
    kill "$(cat "$pid_file")" >/dev/null 2>&1 || true
  fi
  kill_dock_processes
  rm -f "$pid_file" "$state_file"
}

case "${1:-toggle}" in
  open|show|start)
    open_dock
    ;;
  close|hide|stop)
    close_dock
    ;;
  restart|repair|reopen)
    close_dock
    open_dock
    ;;
  toggle)
    if is_running; then
      close_dock
    else
      open_dock
    fi
    ;;
  status)
    if is_running; then
      if [[ -s "$state_file" ]]; then
        python - "$state_file" "$(active_profile)" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    data = {}
profile = data.get("profile") or "unknown"
current = sys.argv[2]
scope = "active" if profile == current else "closing-on-profile-change"
print(f"SevenOS Dock: RUN profile={profile} current={current} scope={scope}")
PY
      else
        printf 'SevenOS Dock: RUN profile=%s scope=unknown\n' "$(active_profile)"
      fi
    else
      printf 'SevenOS Dock: MISS\n'
    fi
    ;;
  settings)
    mkdir -p "$(dirname "$config_file")"
    if [[ ! -s "$config_file" ]]; then
      cat > "$config_file" <<'JSON'
{
  "position": "bottom",
  "size": "compact",
  "magnification": true,
  "autohide": false,
  "reserve_space": true,
  "pinned": ["files", "apps", "browser", "terminal", "spotlight", "hub"],
  "profile_pins": {},
  "folders": ["downloads", "home"]
}
JSON
    fi
    printf 'SevenOS Dock Settings\n'
    printf '=====================\n'
    cat "$config_file"
    ;;
  limits|doctor)
    if [[ -n "$native" && -x "$native" ]]; then
      "$native" --limits --json
    else
      printf 'seven-dock: seven-dock-native not found\n' >&2
      exit 1
    fi
    ;;
  pin)
    shift || true
    tile="${1:-}"
    if [[ -z "$tile" ]]; then
      printf 'Usage: seven-dock pin <files|apps|browser|terminal|spotlight|hub|settings>\n' >&2
      exit 1
    fi
    python - "$config_file" "$tile" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
tile = sys.argv[2]
path.parent.mkdir(parents=True, exist_ok=True)
data = json.loads(path.read_text()) if path.exists() else {}
pinned = data.get("pinned", ["files", "apps", "browser", "terminal", "spotlight", "hub"])
if tile not in pinned:
    pinned.append(tile)
data["pinned"] = pinned
data.setdefault("profile_pins", {})
data.setdefault("position", "bottom")
data.setdefault("size", "compact")
data.setdefault("magnification", True)
data.setdefault("autohide", False)
data.setdefault("reserve_space", True)
data.setdefault("folders", ["downloads", "home"])
path.write_text(json.dumps(data, indent=2) + "\n")
PY
    ;;
  unpin)
    shift || true
    tile="${1:-}"
    if [[ -z "$tile" ]]; then
      printf 'Usage: seven-dock unpin <id>\n' >&2
      exit 1
    fi
    python - "$config_file" "$tile" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
tile = sys.argv[2]
data = json.loads(path.read_text()) if path.exists() else {}
data["pinned"] = [item for item in data.get("pinned", []) if item != tile]
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(json.dumps(data, indent=2) + "\n")
PY
    ;;
  --probe)
    if [[ -n "$native" && -x "$native" ]]; then
      "$native" --probe
    else
      printf 'MISS: seven-dock-native not found\n' >&2
      exit 1
    fi
    ;;
  *)
    printf 'Usage: seven-dock [toggle|open|close|restart|repair|status|settings|limits|doctor|pin <id>|unpin <id>|--probe]\n' >&2
    exit 1
    ;;
esac
