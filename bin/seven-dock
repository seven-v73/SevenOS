#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" ]] &&
     { [[ -x "$SEVENOS_ROOT/bin/seven-dock-canvas" ]] || [[ -x "$SEVENOS_ROOT/bin/seven-dock-native" ]]; }; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/seven-dock-canvas" || -x "$script_dir/seven-dock-native" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -x "$candidate/bin/seven-dock-canvas" || -x "$candidate/bin/seven-dock-native" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root || true)"
canvas="${ROOT_DIR:+$ROOT_DIR/bin/seven-dock-canvas}"
native="${ROOT_DIR:+$ROOT_DIR/bin/seven-dock-native}"
config_file="$HOME/.config/sevenos/dock.json"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp/sevenos-$(id -u)}"
pid_file="$runtime_dir/sevenos-dock.pid"
state_file="$runtime_dir/sevenos-dock-state.json"
profile_change_scope="scope=closing-on-profile-change"

default_config_json() {
  cat <<'JSON'
{
  "enabled": true,
  "position": "bottom",
  "size": "compact",
  "magnification": true,
  "effect": "magnetic",
  "autohide": true,
  "autohide_delay": 2.25,
  "reserve_space": false,
  "pinned": ["files", "apps", "browser", "terminal", "spotlight", "hub"],
  "profile_pins": {},
  "folders": ["downloads", "home"]
}
JSON
}

ensure_config() {
  mkdir -p "$(dirname "$config_file")"
  if [[ ! -s "$config_file" ]]; then
    default_config_json > "$config_file"
  fi
}

config_enabled() {
  ensure_config
  python - "$config_file" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    data = {}
print("yes" if data.get("enabled", True) is not False else "no")
PY
}

set_config_value() {
  local key="$1"
  local value="$2"
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'DRY-RUN > Dock > Set %s %s\n' "$key" "$value"
    return 0
  fi
  ensure_config
  python - "$config_file" "$key" "$value" <<'PY'
import json, sys
from pathlib import Path

path = Path(sys.argv[1])
key = sys.argv[2]
raw = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    data = {}

def as_bool(value):
    return str(value).lower() in {"1", "true", "yes", "on", "enable", "enabled"}

if key in {"enabled", "autohide", "reserve_space", "magnification"}:
    data[key] = as_bool(raw)
elif key == "autohide_delay":
    try:
        data[key] = max(0.5, min(8.0, float(raw)))
    except Exception:
        data[key] = 2.25
elif key == "effect":
    value = str(raw).lower()
    if value in {"off", "disabled", "disable"}:
        value = "none"
    if value in {"soft", "calm", "focus"}:
        value = "gentle"
    data[key] = value if value in {"magnetic", "gentle", "none"} else "magnetic"
    data["magnification"] = data[key] != "none"
else:
    data[key] = raw

data.setdefault("enabled", True)
data.setdefault("position", "bottom")
data.setdefault("size", "compact")
data.setdefault("effect", "magnetic" if data.get("magnification", True) else "none")
data.setdefault("autohide_delay", 2.25)
data.setdefault("pinned", ["files", "apps", "browser", "terminal", "spotlight", "hub"])
data.setdefault("profile_pins", {})
data.setdefault("folders", ["downloads", "home"])
path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
PY
}

dock_binary() {
  local renderer="${SEVENOS_DOCK_RENDERER:-canvas}"
  case "$renderer" in
    canvas)
      if [[ -n "${canvas:-}" && -x "$canvas" ]] && "$canvas" --probe >/dev/null 2>&1; then
        printf '%s\n' "$canvas"
        return 0
      fi
      ;;
    native|gtk|gtk3)
      if [[ -n "${native:-}" && -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
        printf '%s\n' "$native"
        return 0
      fi
      ;;
  esac
  if [[ -n "${canvas:-}" && -x "$canvas" ]] && "$canvas" --probe >/dev/null 2>&1; then
    printf '%s\n' "$canvas"
    return 0
  fi
  if [[ -n "${native:-}" && -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
    printf '%s\n' "$native"
    return 0
  fi
  return 1
}

active_profile() {
  local profile_env="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/profile.env"
  if [[ -f "$profile_env" ]]; then
    # shellcheck disable=SC1090
    source "$profile_env"
    printf '%s' "${SEVENOS_ACTIVE_PROFILE:-equinox}"
  else
    printf 'equinox'
  fi
}

experience_event() {
  local kind="$1"
  local label="$2"
  if [[ -n "${ROOT_DIR:-}" && -x "$ROOT_DIR/scripts/shell-experience.sh" ]]; then
    "$ROOT_DIR/scripts/shell-experience.sh" "$kind" "$label" >/dev/null 2>&1 || true
  fi
}

is_running() {
  [[ -s "$pid_file" ]] || return 1
  local pid
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1
}

kill_dock_processes() {
  local pid cmdline
  while read -r pid; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    [[ "$pid" != "$$" && "$pid" != "${PPID:-}" ]] || continue
    cmdline="$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null || true)"
    if [[ "$cmdline" == *"seven-dock-canvas"* ]] ||
       [[ "$cmdline" == *"seven-dock-native"* ]] ||
       [[ -n "${canvas:-}" && "$cmdline" == *"$canvas"* ]] ||
       [[ -n "${native:-}" && "$cmdline" == *"$native"* ]]; then
      kill "$pid" >/dev/null 2>&1 || true
    fi
  done < <(pgrep -u "$USER" -f 'seven-dock-canvas|SevenDockCanvas|seven-dock-native|SevenDockNative' 2>/dev/null || true)
}

open_dock() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'DRY-RUN > Dock > Open SevenOS Dock\n'
    return 0
  fi
  if [[ "$(config_enabled)" != "yes" ]]; then
    printf 'SevenOS Dock: disabled\n'
    return 0
  fi
  experience_event launch "Seven Dock"
  if is_running; then
    return 0
  fi
  local binary
  if binary="$(dock_binary)"; then
    mkdir -p "$runtime_dir"
    rm -f "$state_file"
    SEVENOS_ROOT="$ROOT_DIR" setsid "$binary" >/tmp/sevenos-dock.log 2>&1 &
    printf '%s\n' "$!" > "$pid_file"
    sleep 0.25
    if ! is_running; then
      printf 'seven-dock: dock failed to stay open; see /tmp/sevenos-dock.log\n' >&2
      return 1
    fi
  else
    printf 'seven-dock: no usable dock renderer found\n' >&2
    return 1
  fi
}

close_dock() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'DRY-RUN > Dock > Close SevenOS Dock\n'
    return 0
  fi
  experience_event focus "Seven Dock closed"
  if is_running; then
    kill "$(cat "$pid_file")" >/dev/null 2>&1 || true
  fi
  kill_dock_processes
  rm -f "$pid_file" "$state_file"
}

case "${1:-toggle}" in
  open|show|start)
    open_dock
    ;;
  close|hide|stop)
    close_dock
    ;;
  restart|repair|reopen)
    close_dock
    open_dock
    ;;
  toggle)
    if is_running; then
      close_dock
    else
      open_dock
    fi
    ;;
  status)
    if is_running; then
      if [[ -s "$state_file" ]]; then
        python - "$state_file" "$(active_profile)" <<'PY'
import json
import sys

try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    data = {}
profile = data.get("profile") or "unknown"
current = sys.argv[2]
scope = "active" if profile == current else "closing-on-profile-change"
print(f"SevenOS Dock: RUN profile={profile} current={current} scope={scope}")
PY
      else
        printf 'SevenOS Dock: RUN profile=%s scope=unknown\n' "$(active_profile)"
      fi
    else
      printf 'SevenOS Dock: MISS\n'
    fi
    ;;
  settings)
    ensure_config
    printf 'SevenOS Dock Settings\n'
    printf '=====================\n'
    cat "$config_file"
    ;;
  enable)
    set_config_value enabled true
    open_dock
    ;;
  disable)
    set_config_value enabled false
    close_dock
    ;;
  set)
    shift || true
    key="${1:-}"
    value="${2:-}"
    case "$key" in
      enabled|autohide|reserve_space|magnification|effect|autohide_delay)
        [[ -n "$value" ]] || { printf 'Usage: seven-dock set %s <value>\n' "$key" >&2; exit 1; }
        set_config_value "$key" "$value"
        if is_running; then
          close_dock
          open_dock
        fi
        ;;
      delay)
        [[ -n "$value" ]] || { printf 'Usage: seven-dock set delay <seconds>\n' >&2; exit 1; }
        set_config_value autohide_delay "$value"
        if is_running; then close_dock; open_dock; fi
        ;;
      *)
        printf 'Usage: seven-dock set <enabled|autohide|autohide_delay|delay|effect|magnification|reserve_space> <value>\n' >&2
        exit 1
        ;;
    esac
    ;;
  autohide)
    shift || true
    value="${1:-toggle}"
    if [[ "$value" == "toggle" ]]; then
      current="$(python - "$config_file" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    data = {}
print("off" if data.get("autohide", True) else "on")
PY
)"
      value="$current"
    fi
    case "$value" in
      on|true|1|enable|enabled) set_config_value autohide true ;;
      off|false|0|disable|disabled) set_config_value autohide false ;;
      *) printf 'Usage: seven-dock autohide <on|off|toggle>\n' >&2; exit 1 ;;
    esac
    if is_running; then close_dock; open_dock; fi
    ;;
  delay|hide-delay|autohide-delay)
    shift || true
    value="${1:-}"
    [[ -n "$value" ]] || { printf 'Usage: seven-dock delay <seconds>\n' >&2; exit 1; }
    set_config_value autohide_delay "$value"
    if is_running; then close_dock; open_dock; fi
    ;;
  effect)
    shift || true
    value="${1:-}"
    [[ -n "$value" ]] || { printf 'Usage: seven-dock effect <magnetic|gentle|none>\n' >&2; exit 1; }
    set_config_value effect "$value"
    if is_running; then close_dock; open_dock; fi
    ;;
  limits|doctor)
    if binary="$(dock_binary)"; then
      "$binary" --limits --json
    else
      printf 'seven-dock: no usable dock renderer found\n' >&2
      exit 1
    fi
    ;;
  pin)
    shift || true
    tile="${1:-}"
    if [[ -z "$tile" ]]; then
      printf 'Usage: seven-dock pin <files|apps|browser|terminal|spotlight|hub|settings>\n' >&2
      exit 1
    fi
    python - "$config_file" "$tile" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
tile = sys.argv[2]
path.parent.mkdir(parents=True, exist_ok=True)
data = json.loads(path.read_text()) if path.exists() else {}
pinned = data.get("pinned", ["files", "apps", "browser", "terminal", "spotlight", "hub"])
if tile not in pinned:
    pinned.append(tile)
data["pinned"] = pinned
data.setdefault("profile_pins", {})
data.setdefault("enabled", True)
data.setdefault("position", "bottom")
data.setdefault("size", "compact")
data.setdefault("magnification", True)
data.setdefault("effect", "magnetic")
data.setdefault("autohide", True)
data.setdefault("autohide_delay", 2.25)
data.setdefault("reserve_space", False)
data.setdefault("folders", ["downloads", "home"])
path.write_text(json.dumps(data, indent=2) + "\n")
PY
    ;;
  unpin)
    shift || true
    tile="${1:-}"
    if [[ -z "$tile" ]]; then
      printf 'Usage: seven-dock unpin <id>\n' >&2
      exit 1
    fi
    python - "$config_file" "$tile" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
tile = sys.argv[2]
data = json.loads(path.read_text()) if path.exists() else {}
data["pinned"] = [item for item in data.get("pinned", []) if item != tile]
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(json.dumps(data, indent=2) + "\n")
PY
    ;;
  --probe)
    if binary="$(dock_binary)"; then
      "$binary" --probe
    else
      printf 'MISS: no usable dock renderer found\n' >&2
      exit 1
    fi
    ;;
  *)
    printf 'Usage: seven-dock [toggle|open|close|enable|disable|autohide <on|off|toggle>|delay <seconds>|effect <magnetic|gentle|none>|set <key> <value>|restart|repair|status|settings|limits|doctor|pin <id>|unpin <id>|--probe]\n' >&2
    printf 'Env: SEVENOS_DOCK_RENDERER=canvas|native\n' >&2
    exit 1
    ;;
esac
