    def render_activity(self) -> None:
        self.active_nav = "activity"
        self.update_nav_state()
        self.set_view("activity")
        self.clear()
        self.section(self.tx("Activity", "Activité"))
        events = self.payload.get("recent_activity", [])
        summary = self.payload.get("summary", {}) if isinstance(self.payload.get("summary"), dict) else {}
        success = sum(1 for item in events if item.get("status") in {"ok", "ready"})
        failed = sum(1 for item in events if item.get("status") == "failed")
        self.content.pack_start(self.stats_flow([
            (tr_text("Events"), str(summary.get("activity", len(events))), tr_text("recent Store actions"), "document-open-recent"),
            (tr_text("Succeeded"), str(success), tr_text("completed or already ready"), "emblem-default"),
            (tr_text("Needs Review"), str(failed), tr_text("failed actions to inspect"), "dialog-warning"),
            (tr_text("Retention"), "120", tr_text("latest local events kept"), "drive-harddisk"),
        ]), False, False, 0)
        self.content.pack_start(self.action_card("Open activity log", "Show the local SevenStore activity timeline in terminal details.", ["LOCAL", "AUDIT"], "document-open-recent", "seven store activity"), False, False, 0)
        if not events:
            self.content.pack_start(self.card("No activity yet", "Install, repair, remove or associate apps with profiles to build a local Store timeline.", ["EMPTY"]), False, False, 0)
        else:
            self.section("Recent")
            for event in events[:30]:
                card = self.activity_card(event)
                self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def activity_card(self, event: dict) -> Gtk.EventBox:
        timestamp = event.get("time", 0)
        try:
            when = dt.datetime.fromtimestamp(int(timestamp)).strftime("%Y-%m-%d %H:%M")
        except Exception:
            when = tr_text("Unknown time")
        action = str(event.get("action") or "action").title()
        source = str(event.get("source") or "SevenStore")
        app_id = str(event.get("id") or "")
        status = str(event.get("status") or "ok").upper()
        profile = event.get("profile")
        desc = f"{when} · {source}"
        if profile:
            desc = f"{desc} · {profile}"
        badges = [status, source.upper()]
        card = self.card(f"{action}: {app_id}", desc, badges, {"source": source, "icon": "document-open-recent"})
        return card

