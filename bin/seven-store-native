    def render_category_search(self, query: str, title: str) -> None:
        self.search_for(query, run=False)
        self.clear()
        self.section(title)
        self.content.pack_start(self.card(title, tr_text("Curated results from SevenStore sources. Use the filters after search to narrow source and trust."), ["CURATED"], {"source": "category", "icon": "view-grid"}), False, False, 0)
        self.content.show_all()
        self.on_search(self.search_entry)

    def search_for(self, query: str, run: bool = True) -> None:
        if self.search_timeout_id:
            GLib.source_remove(self.search_timeout_id)
            self.search_timeout_id = 0
        self.search_entry.set_text(query)
        if run:
            self.on_search(self.search_entry)

    def render_updates(self) -> None:
        self.set_view("updates")
        self.clear()
        self.section("Updates")
        summary = self.payload.get("summary", {}) if isinstance(self.payload.get("summary"), dict) else {}
        modules = self.payload.get("modules", [])
        apps = self.payload.get("apps", [])
        ready = int(summary.get("modules_ready") or 0)
        total = int(summary.get("modules") or len(modules))
        missing = max(total - ready, 0)
        flatpak_ready = tr_text("Ready") if summary.get("flatpak_ready") else tr_text("Needs setup")
        self.content.pack_start(self.stats_flow([
            (tr_text("Bundles"), f"{ready}/{total}", tr_text("SevenOS profile groups ready"), "preferences-system"),
            (tr_text("Needs Attention"), str(missing), tr_text("missing or incomplete bundles"), "dialog-warning"),
            (tr_text("Flatpak"), str(flatpak_ready), tr_text("sandboxed source state"), "security-high"),
            (tr_text("Installed Apps"), str(summary.get("installed_apps", 0)), tr_text("library launchers visible"), "emblem-default"),
        ]), False, False, 0)
        self.content.pack_start(self.card("Update review", f"{len(modules)} SevenOS bundles and {len(apps)} app-source entries are visible. SevenStore previews state before broad changes.", ["READY", "PREVIEW"]), False, False, 0)
        self.section("Safe actions")
        for card in (
            self.action_card("Preview system updates", "Show package and Flatpak update candidates without applying changes.", ["PREVIEW"], "software-update-available", "checkupdates 2>/dev/null || true; printf '\\nFlatpak updates:\\n'; flatpak remote-ls --updates 2>/dev/null || true"),
            self.action_card("SevenOS package status", "Inspect installed/missing SevenOS package groups.", ["LOCAL"], "preferences-system", "sevenpkg status"),
            self.action_card("Flatpak status", "Inspect sandboxed app source state.", ["SANDBOXED"], "security-high", "seven flatpak status || flatpak list"),
            self.action_card("Store doctor", "Run store readiness checks before broad updates.", ["DOCTOR"], "system-search", "seven store doctor"),
        ):
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_activity(self) -> None:
        self.set_view("activity")
        self.clear()
        self.section("Activity")
        events = self.payload.get("recent_activity", [])
        summary = self.payload.get("summary", {}) if isinstance(self.payload.get("summary"), dict) else {}
        success = sum(1 for item in events if item.get("status") in {"ok", "ready"})
        failed = sum(1 for item in events if item.get("status") == "failed")
        self.content.pack_start(self.stats_flow([
            (tr_text("Events"), str(summary.get("activity", len(events))), tr_text("recent Store actions"), "document-open-recent"),
            (tr_text("Succeeded"), str(success), tr_text("completed or already ready"), "emblem-default"),
            (tr_text("Needs Review"), str(failed), tr_text("failed actions to inspect"), "dialog-warning"),
            (tr_text("Retention"), "120", tr_text("latest local events kept"), "drive-harddisk"),
        ]), False, False, 0)
        self.content.pack_start(self.action_card("Open activity log", "Show the local SevenStore activity timeline in terminal details.", ["LOCAL", "AUDIT"], "document-open-recent", "seven store activity"), False, False, 0)
        if not events:
            self.content.pack_start(self.card("No activity yet", "Install, repair, remove or associate apps with profiles to build a local Store timeline.", ["EMPTY"]), False, False, 0)
        else:
            self.section("Recent")
            for event in events[:30]:
                card = self.activity_card(event)
                self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def activity_card(self, event: dict) -> Gtk.EventBox:
        timestamp = event.get("time", 0)
        try:
            when = dt.datetime.fromtimestamp(int(timestamp)).strftime("%Y-%m-%d %H:%M")
        except Exception:
            when = tr_text("Unknown time")
        action = str(event.get("action") or "action").title()
        source = str(event.get("source") or "SevenStore")
        app_id = str(event.get("id") or "")
        status = str(event.get("status") or "ok").upper()
        profile = event.get("profile")
        desc = f"{when} · {source}"
        if profile:
            desc = f"{desc} · {profile}"
        badges = [status, source.upper()]
        card = self.card(f"{action}: {app_id}", desc, badges, {"source": source, "icon": "document-open-recent"})
        return card

    def render_permissions(self) -> None:
        self.set_view("permissions")
        self.clear()
        self.section("Privacy & Permissions")
        installed = self.payload.get("installed_library", [])
        sandboxed = [item for item in installed if item.get("source") == "flatpak"]
        local = [item for item in installed if item.get("source") == "desktop"]
        self.content.pack_start(self.stats_flow([
            (tr_text("Sandboxed"), str(len(sandboxed)), tr_text("Flatpak apps with reviewable permissions"), "security-high"),
            (tr_text("Local"), str(len(local)), tr_text("desktop apps outside Flatpak isolation"), "drive-harddisk"),
            (tr_text("Community"), "AUR", tr_text("shown only in Advanced search"), "applications-development"),
            (tr_text("System"), "Admin", tr_text("global packages require authorization"), "preferences-system"),
        ]), False, False, 0)
        self.content.pack_start(self.card("Permission model", "SevenStore separates sandboxed desktop apps, local launchers, community packages and system packages so risky actions stay explicit.", ["PRIVACY", "TRUST"]), False, False, 0)
        self.section("Review tools")
        for card in (
            self.action_card("Sandboxed apps", "List Flatpak apps. Use Flatseal when installed for detailed permission editing.", ["FLATPAK", "SANDBOXED"], "security-high", "flatpak list --app; printf '\\nTip: install Flatseal for visual permission control.\\n'"),
            self.action_card("Local launchers", "Show desktop apps visible to SevenStore and Launchpad.", ["LOCAL"], "emblem-default", "seven store library"),
            self.action_card("System packages", "Inspect SevenOS package groups that may affect the whole OS.", ["SYSTEM", "ADMIN"], "preferences-system", "sevenpkg status"),
        ):
            self.content.pack_start(card, False, False, 0)
        if sandboxed:
            self.section("Sandboxed Library")
            for item in sandboxed[:18]:
                card = self.card(item.get("name", item.get("key", "")), item.get("summary", ""), self.state_badges_for(item), item)
                card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
                self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_vm(self) -> None:
        self.set_view("vm")
        self.clear()
        self.section("Windows Bridge Apps")
        self.content.pack_start(self.card("VM-first compatibility", "Installers and Windows apps should be routed through SevenOS Windows Bridge instead of being mixed with Linux packages.", ["VM", "WINDOWS"]), False, False, 0)
        self.content.show_all()

    def render_ai(self) -> None:
        self.set_view("ai")
        self.clear()
        self.section("AI Picks")
        self.content.pack_start(self.card("Profile-aware recommendations", "SevenAI will recommend apps by context, active profile and workflow. The contract is ready; the recommender can plug into this surface next.", ["AI OPTIMIZED"]), False, False, 0)
        self.content.show_all()

    def on_search(self, _entry: Gtk.SearchEntry) -> None:
        query = self.search_entry.get_text().strip()
        if not query:
            self.render_home()
            return
        self.search_generation += 1
        generation = self.search_generation
        self.clear()
        self.render_search_loading(query)
        self.content.show_all()
        threading.Thread(target=self.search_worker, args=(query, generation), daemon=True).start()

    def on_search_changed(self, _entry: Gtk.SearchEntry) -> None:
        if self.search_timeout_id:
            GLib.source_remove(self.search_timeout_id)
        self.search_timeout_id = GLib.timeout_add(320, self.run_debounced_search)

    def run_debounced_search(self) -> bool:
        self.search_timeout_id = 0
        query = self.search_entry.get_text().strip()
        if not query:
            self.render_home()
        elif len(query) >= 2:
            self.on_search(self.search_entry)
        return False

    def render_search_loading(self, query: str) -> None:
        panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        panel.get_style_context().add_class("loading-panel")
        panel.pack_start(self.label(tr_text("Searching SevenStore"), "section-title"), False, False, 0)
        panel.pack_start(self.label(tr_text("Looking across system packages, sandboxed apps and community sources for {query}.", query=query), "muted"), False, False, 0)
        pulse = Gtk.ProgressBar()
        pulse.pulse()
        panel.pack_start(pulse, False, False, 0)
        self.content.pack_start(panel, False, False, 0)
        self.content.pack_start(self.stats_flow([
            (tr_text("System"), "Pacman", tr_text("official repositories"), "preferences-system"),
            (tr_text("Sandboxed"), "Flatpak", tr_text("desktop app source"), "security-high"),
            (tr_text("Community"), "AUR", tr_text("advanced results"), "applications-development"),
            (tr_text("Profile"), self.active_profile_key().title(), tr_text("ranking hints active"), "emblem-default"),
        ]), False, False, 0)

    def search_worker(self, query: str, generation: int) -> None:
        payload = run_json([str(ROOT / "scripts/store.sh"), "search", query, "--json"], {"results": []})
        GLib.idle_add(self.render_search_results, query, payload, generation)

    def render_search_results(self, query: str, payload: dict, generation: int) -> bool:
        if generation != self.search_generation:
            return False
        self.clear()
        self.section(f"Results for {query}")
        results = payload.get("results", [])
        if not self.advanced_mode:
            results = [item for item in results if item.get("beginner_visible", True)]
        results = self.apply_source_filter(results)
        self.content.pack_start(self.filter_row(query), False, False, 0)
        if not results:
            self.render_empty_search(query, payload)
        for item in results:
            summary = item.get("summary") or item.get("version") or item.get("source", "")
            card = self.card(item.get("name", item.get("id", "")), summary, item.get("badges", []), item)
            card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()
        return False

    def render_empty_search(self, query: str, payload: dict) -> None:
        sources = payload.get("sources", {}) if isinstance(payload.get("sources"), dict) else {}
        self.content.pack_start(self.card("No visible result", "Try a simpler app name, switch source filter, or enable Advanced mode for CLI tools, libraries and community packages.", ["EMPTY"], {"source": "collection", "icon": "system-search"}), False, False, 0)
        self.section("Try next")
        suggestions = [
            (tr_text("Show all sources"), "all"),
            (tr_text("Graphical apps"), "graphical"),
            (tr_text("Sandboxed apps"), "flatpak"),
            (tr_text("Community results"), "aur"),
        ]
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        row.get_style_context().add_class("filter-row")
        for label, source in suggestions:
            button = Gtk.Button(label=label)
            button.connect("clicked", lambda _button, value=source: self.set_source_filter(value, query))
            row.pack_start(button, False, False, 0)
        self.content.pack_start(row, False, False, 0)
        source_text = ", ".join(f"{key}: {'ready' if value else 'missing'}" for key, value in sources.items()) or tr_text("Source status unavailable")
        self.content.pack_start(self.label(source_text, "muted"), False, False, 0)

    def apply_source_filter(self, results: list[dict]) -> list[dict]:
        if self.source_filter == "all":
            return self.rank_results_for_profile(results)
        if self.source_filter == "graphical":
            filtered = [item for item in results if item.get("kind") == "graphical" or item.get("desktop_id") or item.get("source") == "flatpak"]
            return self.rank_results_for_profile(filtered)
        return self.rank_results_for_profile([item for item in results if str(item.get("source", "")).lower() == self.source_filter])

    def rank_results_for_profile(self, results: list[dict]) -> list[dict]:
        profile = self.active_profile_key()
        hints = {
            "forge": ("code", "git", "docker", "node", "python", "terminal", "editor", "sdk"),
            "shield": ("wireshark", "nmap", "forensic", "security", "audit", "network"),
            "studio": ("design", "graphics", "video", "audio", "photo", "obs", "blender", "krita"),
            "pulse": ("steam", "lutris", "game", "proton", "mango", "gamescope"),
            "baobab": ("reader", "book", "language", "culture", "dictionary", "map"),
            "windows": ("windows", "wine", "bottles", "vm", "bridge"),
        }.get(profile, ())

        def score(item: dict) -> tuple[int, int, int, int, str]:
            haystack = " ".join(str(item.get(key, "")) for key in ("name", "id", "summary", "source", "kind")).lower()
            bonus = 1 if any(token in haystack for token in hints) else 0
            installed = 1 if item.get("installed") else 0
            graphical = 1 if item.get("kind") == "graphical" or item.get("source") == "flatpak" else 0
            return (-bonus, -installed, -graphical, -int(item.get("quality_score") or 0), str(item.get("name") or "").lower())

        return sorted(results, key=score)

    def filter_row(self, query: str) -> Gtk.Box:
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        row.get_style_context().add_class("filter-row")
        for key, label in (
            ("all", tr_text("All")),
            ("graphical", tr_text("Apps")),
            ("flatpak", tr_text("Sandboxed")),
            ("pacman", tr_text("System")),
            ("aur", tr_text("Community")),
        ):
            button = Gtk.Button(label=label)
            if key == self.source_filter:
                button.get_style_context().add_class("active")
            button.connect("clicked", lambda _button, value=key: self.set_source_filter(value, query))
            row.pack_start(button, False, False, 0)
        note = self.label(tr_text("Advanced mode reveals CLI tools, libraries and community packages."), "muted")
        row.pack_start(note, True, True, 0)
        return row

    def set_source_filter(self, value: str, query: str) -> None:
        self.source_filter = value
        if query:
            self.on_search(self.search_entry)

    def metadata_grid(self, item: dict) -> Gtk.Box:
        grid = Gtk.Grid(column_spacing=12, row_spacing=8)
        grid.get_style_context().add_class("metadata-grid")
        source = str(item.get("source") or item.get("category") or "SevenOS")
        version = str(item.get("version") or item.get("quality_label") or "Current")
        kind = str(item.get("kind") or ("graphical" if item.get("desktop_id") else "package"))
        size = str(item.get("size") or item.get("download_size") or "Calculated during install")
        rows = [
            (tr_text("Source"), self.public_source_label(source)),
            (tr_text("Version"), version),
            (tr_text("Type"), kind.title()),
            (tr_text("Size"), size),
        ]
        for row_index, (label_text, value_text) in enumerate(rows):
            label = self.label(label_text, "metadata-label")
            value = self.label(value_text, "metadata-value")
            grid.attach(label, 0, row_index, 1, 1)
            grid.attach(value, 1, row_index, 1, 1)
        return grid

    def permission_summary(self, item: dict) -> Gtk.Box:
        source = str(item.get("source") or "").lower()
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("permission-panel")
        box.pack_start(self.label(tr_text("Privacy & permissions"), "store-row-title"), False, False, 0)
        if source == "flatpak":
            rows = [
                (tr_text("Sandbox"), tr_text("Isolated by default")),
                (tr_text("Files"), tr_text("Review with Flatseal after install")),
                (tr_text("Devices"), tr_text("Limited unless the app requests access")),
            ]
        elif source == "aur":
            rows = [
                (tr_text("Build script"), tr_text("Community maintained")),
                (tr_text("System"), tr_text("May compile or install dependencies")),
                (tr_text("Review"), tr_text("Recommended before continuing")),
            ]
        elif source == "pacman":
            rows = [
                (tr_text("System"), tr_text("Official package route")),
                (tr_text("Admin"), tr_text("May require authorization")),
                (tr_text("Updates"), tr_text("Managed by system upgrades")),
            ]
        elif source == "profile":
            rows = [
                (tr_text("Scope"), tr_text("Mini OS capability bundle")),
                (tr_text("Apps"), tr_text("Curated by SevenOS profile")),
                (tr_text("Rollback"), tr_text("Managed by profile tools")),
            ]
        else:
            rows = [
                (tr_text("Source"), tr_text("Local metadata")),
                (tr_text("Install"), tr_text("Preview required")),
                (tr_text("Privacy"), tr_text("No account required")),
            ]
        for key, value in rows:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            row.pack_start(self.label(key, "metadata-label"), False, False, 0)
            row.pack_start(self.label(value, "metadata-value"), True, True, 0)
            box.pack_start(row, False, False, 0)
        return box

    def source_identity(self, item: dict) -> str:
        source = str(item.get("source") or "").lower()
        if source == "flatpak":
            return tr_text("Publisher: Flathub or app upstream · Install path: sandboxed desktop app")
        if source == "pacman":
            return tr_text("Publisher: Arch/SevenOS repositories · Install path: system package")
        if source == "aur":
            return tr_text("Publisher: community build recipe · Install path: advanced review")
        if source == "vm":
            return tr_text("Publisher: Windows Bridge · Install path: isolated VM workflow")
        if source == "profile":
            return tr_text("Publisher: SevenOS profile catalog · Install path: mini OS bundle")
        return tr_text("Publisher: SevenStore local catalog · Install path: preview first")

    def trust_summary(self, item: dict) -> str:
        source = str(item.get("source") or "").lower()
        if source == "flatpak":
            return tr_text("Sandboxed app. Permissions are isolated by Flatpak and can be reviewed later.")
        if source == "pacman":
            return tr_text("System source. Installs globally and may require administrator authorization.")
        if source == "aur":
            return tr_text("Community source. Review the install plan before continuing.")
        if source == "vm":
            return tr_text("Windows Bridge route. Keep Windows apps isolated from native packages.")
        if source == "profile":
            return tr_text("Mini OS profile bundle. Adds curated capabilities for this SevenOS mode.")
        return tr_text("SevenStore will show source and trust before installation.")

    def preview_copy(self, item: dict) -> str:
        source = str(item.get("source") or "SevenOS").lower()
        if item.get("installed"):
            return tr_text("Installed and available from Launchpad or Spotlight.")
        if source == "flatpak":
            return tr_text("Sandboxed graphical app with a safer desktop install path.")
        if source == "aur":
            return tr_text("Community package. Advanced mode recommended before install.")
        if source == "pacman":
            return tr_text("Native system package integrated with SevenOS.")
        return tr_text("SevenStore preview uses local metadata until screenshots are cached.")

    def render_detail(self, item: dict | None) -> None:
        self.clear(self.detail_box)
        if not item:
            self.detail_box.pack_start(self.label("Select an app", "section-title"), False, False, 0)
            self.detail_box.pack_start(self.label("Search or open a collection to inspect source, trust and installation plan.", "muted"), False, False, 0)
            self.detail_box.show_all()
            return
        name = item.get("name") or item.get("title") or item.get("key") or item.get("id") or "App"
        detail_hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        detail_hero.get_style_context().add_class("detail-hero")
        detail_hero.pack_start(self.icon_frame(self.icon_name_for(item), 46), False, False, 0)
        detail_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        detail_text.pack_start(self.label(str(name), "title"), False, False, 0)
        detail_text.pack_start(self.label(str(item.get("summary") or item.get("description") or "SevenStore item."), "muted"), False, False, 0)
        if item.get("installed"):
            detail_text.pack_start(self.label("Installed and ready", "success"), False, False, 0)
        detail_hero.pack_start(detail_text, True, True, 0)
        self.detail_box.pack_start(detail_hero, False, False, 0)
        badges = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        for badge in item.get("badges", []):
            badges.pack_start(self.label(self.public_badge_label(str(badge)), "badge"), False, False, 0)
        self.detail_box.pack_start(badges, False, False, 0)
        source = item.get("source") or item.get("category") or "SevenOS"
        self.detail_box.pack_start(self.label(f"Source: {self.public_source_label(str(source))}", "muted"), False, False, 0)
        self.detail_box.pack_start(self.metadata_grid(item), False, False, 0)
        self.detail_box.pack_start(self.label(self.source_identity(item), "store-source"), False, False, 0)
        quality = item.get("quality_score")
        if quality:
            self.detail_box.pack_start(self.label(f"Quality score: {quality}/100 · {item.get('quality_label', 'Ready')}", "quality"), False, False, 0)
        self.detail_box.pack_start(self.label(self.trust_summary(item), "risk-low" if str(source).lower() in {"flatpak", "pacman", "profile", "desktop"} else "risk-medium"), False, False, 0)
        self.detail_box.pack_start(self.permission_summary(item), False, False, 0)
        explanation = item.get("explanation")
        if explanation:
            self.detail_box.pack_start(self.label(str(explanation), "muted"), False, False, 0)
        preview = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        preview.get_style_context().add_class("preview-panel")
        preview.pack_start(self.icon_frame(self.icon_name_for(item), 52), False, False, 0)
        preview.pack_start(self.label(str(name), "store-row-title", 0.5), False, False, 0)
        preview.pack_start(self.label(self.preview_copy(item), "store-source", 0.5), False, False, 0)
        self.detail_box.pack_start(preview, False, False, 0)
        shots = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        shots.get_style_context().add_class("screenshot-strip")
        for label in (tr_text("Overview"), tr_text("Trust"), tr_text("Install")):
            shots.pack_start(self.label(label, "badge", 0.5), True, True, 0)
        self.detail_box.pack_start(shots, False, False, 0)
        command = item.get("install_command") or item.get("command") or ""
        install_command = self.install_command_for(item)
        open_command = self.open_command_for(item)
        if item.get("installed") and open_command and item.get("kind") == "graphical":
            self.detail_box.pack_start(self.command_button(tr_text("Open"), open_command, primary=True), False, False, 0)
            self.detail_box.pack_start(self.label(tr_text("Already installed. Launch it directly from here, Launchpad or Spotlight."), "muted"), False, False, 0)
        elif item.get("installed"):
            self.detail_box.pack_start(self.label(tr_text("Installed technical component. It does not expose a normal graphical launcher."), "muted"), False, False, 0)
        elif command:
            self.detail_box.pack_start(self.label(tr_text("Install plan"), "section-title"), False, False, 0)
            self.detail_box.pack_start(self.label(install_command or command, "muted"), False, False, 0)
            plan_button = Gtk.Button(label=tr_text("Preview plan"))
            plan_button.get_style_context().add_class("primary")
            plan_button.connect("clicked", lambda _button, cmd=install_command or command: self.queue_operation(tr_text("Preview install plan"), f"{cmd} --dry-run" if " install-app " in cmd else cmd))
            self.detail_box.pack_start(plan_button, False, False, 0)
        if install_command and not item.get("installed"):
            install_button = Gtk.Button(label=tr_text("Install on system"))
            install_button.get_style_context().add_class("primary")
            install_button.connect("clicked", lambda _button, cmd=install_command, app=str(name): self.queue_operation(tr_text("Install {app}", app=app), cmd))
            self.detail_box.pack_start(install_button, False, False, 0)

            profile = self.active_profile_key()
            if item.get("source") in {"pacman", "aur", "flatpak", "vm"}:
                profile_command = f"{install_command} --profile {shlex.quote(profile)}"
                profile_button = Gtk.Button(label=tr_text("Install for {profile}", profile=profile.title()))
                profile_button.connect("clicked", lambda _button, cmd=profile_command, app=str(name): self.queue_operation(tr_text("Install {app}", app=app), cmd))
                self.detail_box.pack_start(profile_button, False, False, 0)
        if item.get("source") in {"pacman", "aur", "flatpak"} and item.get("id"):
            actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            profile = self.active_profile_key()
            in_profile = self.item_profile_membership(item, profile)
            profile_label = tr_text("Remove from {profile}", profile=profile.title()) if in_profile else tr_text("Add to {profile}", profile=profile.title())
            profile_command = ["seven", "store", "remove-profile" if in_profile else "add-profile", profile, item.get("source"), item.get("id")]
            actions.pack_start(self.command_button(profile_label, shell_quote(profile_command), visible_terminal=True), True, True, 0)
            actions.pack_start(self.command_button(tr_text("Repair"), shell_quote(["seven", "store", "repair-app", item.get("source"), item.get("id")]), visible_terminal=True), True, True, 0)
            if item.get("installed"):
                actions.pack_start(self.command_button(tr_text("Remove"), shell_quote(["seven", "store", "remove-app", item.get("source"), item.get("id")]), visible_terminal=True), True, True, 0)
            self.detail_box.pack_start(actions, False, False, 0)
            profile_note = tr_text("This app is already part of the active mini OS.") if in_profile else tr_text("Associate this app with the active mini OS to keep it in that profile library.")
            self.detail_box.pack_start(self.label(profile_note, "muted"), False, False, 0)
        profile_open_command = item.get("open_command") if item.get("source") == "profile" else ""
        if profile_open_command:
            self.detail_box.pack_start(self.command_button(tr_text("Open profile center"), profile_open_command, visible_terminal=True), False, False, 0)
        recs = item.get("recommendations") or []
        if recs:
            self.detail_box.pack_start(self.label(tr_text("Related apps"), "section-title"), False, False, 0)
            self.detail_box.pack_start(self.label(", ".join(recs), "muted"), False, False, 0)
        self.detail_box.show_all()

    def install_command_for(self, item: dict) -> str:
        source = item.get("source")
        app_id = item.get("id") or item.get("key") or item.get("name")
        if source in {"pacman", "aur", "flatpak", "vm"} and app_id:
            return shell_quote(["seven", "store", "install-app", source, app_id])
        if source == "profile" and app_id:
            return shell_quote(["seven", "profile", "install", app_id])
        if item.get("key") and item.get("command", "").startswith("sevenpkg install"):
            return shell_quote(["seven", "store", "install", item["key"]])
        return ""

    def open_command_for(self, item: dict) -> str:
        source = item.get("source")
        app_id = item.get("id") or item.get("key") or item.get("name")
        if source in {"pacman", "aur", "flatpak"} and app_id:
            return shell_quote(["seven", "store", "open-app", source, app_id])
        return str(item.get("open_command") or "")


def main() -> int:
    parser = argparse.ArgumentParser(description="SevenStore AppCenter")
    parser.add_argument("action", nargs="?", default="open", choices=("open", "status"))
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    if args.probe:
        return probe()
    if args.json:
        payload = run_json([str(ROOT / "scripts/store.sh"), "json"], {"schema": "sevenos.store.v1", "state": "MISS"})
        available, error = gtk_available()
        print(json.dumps({"schema": "sevenos.store-native.v1", "native": available, "error": error, "store": payload}, indent=2))
        return 0
    if args.action == "status":
        print("SevenStore")
        print("==========")
        print("Status: OK" if probe() == 0 else "Status: MISS")
        return 0
    app = SevenStore()
    return app.run([])


if __name__ == "__main__":
    raise SystemExit(main())
