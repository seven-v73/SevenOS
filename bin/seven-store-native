.root {
  background:
    radial-gradient(circle at 14% 0%, rgba(137,180,250,0.26), transparent 32%),
    radial-gradient(circle at 100% 10%, rgba(203,166,247,0.22), transparent 30%),
    linear-gradient(135deg, #10131e, #151722 54%, #0c101b);
}
.topbar {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.12);
