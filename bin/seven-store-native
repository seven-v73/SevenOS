    def store_health_panel(self) -> Gtk.FlowBox:
        summary = self.payload.get("summary", {}) if isinstance(self.payload.get("summary"), dict) else {}
        modules_ready = int(summary.get("modules_ready") or 0)
        modules = int(summary.get("modules") or 0)
        installed = int(summary.get("installed_apps") or len(self.payload.get("installed_library", [])))
        flatpak_ready = bool(summary.get("flatpak_ready"))
        activity = int(summary.get("activity") or len(self.payload.get("recent_activity", [])))
        rootfs_ready = int(summary.get("rootfs_ready") or 0)
        rootfs_total = int(summary.get("rootfs_total") or 0)
        duplicates = int(summary.get("rootfs_duplicates") or 0)
        rows = [
            (self.tx("Catalog", "Catalogue"), f"{modules_ready}/{modules}" if modules else self.tx("Ready", "Prêt"), self.tx("SevenOS bundles", "bundles SevenOS"), "view-grid"),
            (self.tx("Library", "Bibliothèque"), str(installed), self.tx("visible apps", "apps visibles"), "emblem-default"),
            (self.tx("Sandbox", "Sandbox"), self.tx("Ready", "Prête") if flatpak_ready else self.tx("Setup", "À configurer"), self.tx("Flatpak source", "source Flatpak"), "security-high"),
            (self.tx("RootFS", "RootFS"), f"{rootfs_ready}/{rootfs_total}" if rootfs_total else self.tx("Ready", "Prêt"), self.tx("mini OS ready", "mini OS prêts"), "drive-harddisk"),
            (self.tx("Duplication", "Duplication"), str(duplicates), self.tx("tracked packages", "paquets suivis"), "view-list"),
            (self.tx("Activity", "Activité"), str(activity), self.tx("recent actions", "actions récentes"), "document-open-recent"),
        ]
        flow = Gtk.FlowBox()
        flow.get_style_context().add_class("store-health")
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_min_children_per_line(2)
        flow.set_max_children_per_line(4)
        for title, value, desc, icon in rows:
            tile = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            tile.get_style_context().add_class("health-tile")
            tile.pack_start(self.icon_frame(icon, 24), False, False, 0)
            text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text.pack_start(self.label(str(value), "health-value"), False, False, 0)
            text.pack_start(self.label(f"{title} · {desc}", "health-label"), False, False, 0)
            tile.pack_start(text, True, True, 0)
            flow.add(tile)
        return flow

