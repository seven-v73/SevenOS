#!/usr/bin/env python3
"""SevenStore AppCenter surface."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import shlex
import subprocess
import sys
import threading
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()
    here = Path(__file__).resolve()
    if (here.parent.parent / "install.sh").is_file():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "install.sh").is_file():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import language_code, tr_text  # noqa: E402
import seven_theme  # noqa: E402

CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos"
PROFILE_UI_FILE = CONFIG_DIR / "profile-ui.json"
STORE_CACHE_FILE = CACHE_DIR / "store-native.json"
STORE_CACHE_TTL = int(os.environ.get("SEVENOS_STORE_NATIVE_CACHE_TTL", "300"))


def read_profile_ui() -> dict:
    try:
        data = json.loads(PROFILE_UI_FILE.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def ensure_gtk_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        probe = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if probe.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    available, error = gtk_available()
    if available:
        print("OK")
        return 0
    print(f"MISS: {error}", file=sys.stderr)
    return 1


def gtk_available() -> tuple[bool, str]:
    ensure_gtk_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        return False, str(exc)
    return True, ""


def run_json(command: list[str], fallback):
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            text=True,
            capture_output=True,
            check=False,
            timeout=18,
        )
        if result.returncode != 0:
            return fallback
        return json.loads(result.stdout)
    except Exception:
        return fallback


def cache_age(path: Path) -> float:
    try:
        return max(0.0, dt.datetime.now().timestamp() - path.stat().st_mtime)
    except Exception:
        return 999999.0


def cached_store_payload(refresh: bool = False) -> dict:
    fallback = {"schema": "sevenos.store.v1", "state": "MISS", "summary": {}, "modules": [], "apps": [], "profile_collections": {}}
    if not refresh and os.environ.get("SEVENOS_STORE_REFRESH") != "1" and STORE_CACHE_FILE.is_file() and cache_age(STORE_CACHE_FILE) <= STORE_CACHE_TTL:
        try:
            data = json.loads(STORE_CACHE_FILE.read_text(encoding="utf-8"))
            if isinstance(data, dict):
                return data
        except Exception:
            pass
    payload = run_json([str(ROOT / "scripts/store.sh"), "json"], fallback)
    if isinstance(payload, dict):
        try:
            CACHE_DIR.mkdir(parents=True, exist_ok=True)
            tmp = STORE_CACHE_FILE.with_suffix(".json.tmp")
            tmp.write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
            tmp.replace(STORE_CACHE_FILE)
        except Exception:
            pass
        return payload
    return fallback


def run_text(command: list[str]) -> str:
    result = subprocess.run(
        command,
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        text=True,
        capture_output=True,
        check=False,
        timeout=18,
    )
    return result.stdout.strip() or result.stderr.strip()


def open_visible(command: str) -> None:
    wrapped = f"cd {shlex.quote(str(ROOT))} && {command}; printf '\\nPress Enter to close...'; read -r"
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    for candidate in (
        ["seven-terminal", "focus", "--", "bash", "-lc", wrapped],
        ["kitty", "--title", "SevenStore", "bash", "-lc", wrapped],
        ["foot", "-e", "bash", "-lc", wrapped],
    ):
        if subprocess.run(["bash", "-lc", f"command -v {shlex.quote(candidate[0])} >/dev/null 2>&1"], check=False).returncode == 0:
            subprocess.Popen(candidate, cwd=ROOT, env=env)
            return
    subprocess.Popen(["bash", "-lc", wrapped], cwd=ROOT, env=env)


def open_hidden(command: str) -> None:
    subprocess.Popen(["bash", "-lc", command], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def shell_quote(command: list[str]) -> str:
    return " ".join(shlex.quote(str(part)) for part in command if str(part))


ensure_gtk_python()

import gi  # noqa: E402

gi.require_version("Gdk", "3.0")
gi.require_version("Gtk", "3.0")
from gi.repository import Gdk, GLib, Gtk  # noqa: E402


CSS = seven_theme.surface_css("store")


class SevenStore(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="os.seven.SevenStore")
        self.window: Gtk.ApplicationWindow | None = None
        self.payload: dict = {}
        self.results: list[dict] = []
        self.content = Gtk.Box()
        self.detail_box = Gtk.Box()
        self.operation_box = Gtk.Box()
        self.operation_title = Gtk.Label()
        self.operation_state = Gtk.Label()
        self.operation_progress = Gtk.ProgressBar()
        self.operation_action = Gtk.Button()
        self.operation_cancel = Gtk.Button()
        self.current_operation_command = ""
        self.current_operation_visible = True
        self.search_entry = Gtk.SearchEntry()
        self.search_timeout_id = 0
        self.search_generation = 0
        self.advanced_mode = False
        self.source_filter = "all"
        self.current_view = "home"
        self.nav_buttons: dict[str, Gtk.Button] = {}
        self.active_nav = "discover"
        self._profiles_cache: list[dict] | None = None

    def tx(self, en: str, fr: str, **values: object) -> str:
        text = fr if language_code().startswith("fr") else en
        return text.format(**values) if values else text

    def do_activate(self) -> None:
        if self.window:
            self.window.present()
            return

        provider = Gtk.CssProvider()
        css = seven_theme.gtk_app_css("store") + CSS
        provider.load_from_data(css.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.payload = cached_store_payload()

        self.window = Gtk.ApplicationWindow(application=self)
        self.window.set_name("seven-store")
        self.window.get_style_context().add_class("seven-store")
        self.window.set_title("SevenStore")
        self.window.set_default_size(1080, 680)
        self.window.set_wmclass("SevenStoreNative", "SevenStoreNative")

        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        root.get_style_context().add_class("root")
        self.window.add(root)

        root.pack_start(self.sidebar(), False, False, 0)

        main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        main.set_margin_top(18)
        main.set_margin_bottom(18)
        main.set_margin_start(18)
        main.set_margin_end(18)
        root.pack_start(main, True, True, 0)

        main.pack_start(self.topbar(), False, False, 0)
        main.pack_start(self.operation_panel(), False, False, 0)

        body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        main.pack_start(body, True, True, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        self.content.set_margin_bottom(8)
        scroller.add(self.content)
        body.pack_start(scroller, True, True, 0)

        self.detail_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.detail_box.set_size_request(320, -1)
        self.detail_box.get_style_context().add_class("detail")
        body.pack_start(self.detail_box, False, False, 0)

        self.render_home()
        self.render_detail(None)
        self.window.show_all()

    def sidebar(self) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_size_request(188, -1)
        box.get_style_context().add_class("sidebar")

        brand = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        brand.get_style_context().add_class("store-brand")
        logo = Gtk.Image.new_from_icon_name("seven-store", Gtk.IconSize.DIALOG)
        logo.set_pixel_size(30)
        brand.pack_start(logo, False, False, 0)
        brand_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        brand_text.pack_start(self.label("SevenStore", "store-brand-title"), False, False, 0)
        brand_text.pack_start(self.label(self.tx("Software Center", "Centre logiciel"), "store-brand-subtitle"), False, False, 0)
        brand.pack_start(brand_text, True, True, 0)
        box.pack_start(brand, False, False, 6)

        for key, icon, label, action in (
            ("discover", "go-home-symbolic", self.tx("Discover", "Découvrir"), self.render_home),
            ("apps", "view-grid-symbolic", self.tx("Categories", "Catégories"), self.render_categories),
            ("installed", "emblem-default-symbolic", self.tx("Installed", "Installées"), self.render_installed),
            ("updates", "software-update-available-symbolic", self.tx("Updates", "Mises à jour"), self.render_updates),
            ("profiles", "preferences-system-symbolic", self.tx("Mini OS", "Mini OS"), self.render_profiles),
            ("permissions", "security-high-symbolic", self.tx("Trust", "Confiance"), self.render_permissions),
            ("activity", "document-open-recent-symbolic", self.tx("Activity", "Activité"), self.render_activity),
        ):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.set_halign(Gtk.Align.FILL)
            image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
            image.set_pixel_size(16)
            row.pack_start(image, False, False, 0)
            button_label = Gtk.Label(label=label)
            button_label.set_xalign(0)
            button_label.set_halign(Gtk.Align.FILL)
            button_label.get_style_context().add_class("sidebar-label")
            row.pack_start(button_label, True, True, 0)
            button = Gtk.Button()
            button.add(row)
            button.connect("clicked", lambda _button, nav=key, callback=action: self.navigate(nav, callback))
            self.nav_buttons[key] = button
            box.pack_start(button, False, False, 0)
        self.update_nav_state()

        footer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        footer.get_style_context().add_class("sidebar-footer")
        footer.pack_start(self.label(self.active_profile_key().title(), "sidebar-footer-title"), False, False, 0)
        footer.pack_start(self.label(self.tx("Recommendations adapt to this Mini OS.", "Les recommandations suivent ce Mini OS."), "muted"), False, False, 0)
        box.pack_end(footer, False, False, 0)
        return box

    def navigate(self, key: str, callback) -> None:
        self.active_nav = key
        self.update_nav_state()
        callback()

    def update_nav_state(self) -> None:
        for key, button in self.nav_buttons.items():
            context = button.get_style_context()
            if key == self.active_nav:
                context.add_class("active")
            else:
                context.remove_class("active")

    def topbar(self) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("topbar")
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        title = Gtk.Label(label="SevenStore", xalign=0)
        title.get_style_context().add_class("title")
        caption = Gtk.Label(label=self.tx("Apps, Mini OS profiles and trusted installs", "Apps, Mini OS et installations de confiance"), xalign=0)
        caption.get_style_context().add_class("caption")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(caption, False, False, 0)
        box.pack_start(title_box, False, False, 0)
        self.search_entry.get_style_context().add_class("search")
        self.search_entry.set_placeholder_text(self.tx("Search apps, tools, games...", "Rechercher apps, outils, jeux..."))
        self.search_entry.connect("activate", self.on_search)
        self.search_entry.connect("search-changed", self.on_search_changed)
        box.pack_start(self.search_entry, True, True, 0)
        profile = Gtk.Label(label=f"{self.active_profile_label()} · {self.active_profile_key().title()}")
        profile.get_style_context().add_class("badge")
        box.pack_start(profile, False, False, 0)
        mode = Gtk.CheckButton(label=self.tx("Advanced", "Avancé"))
        mode.get_style_context().add_class("mode-toggle")
        mode.set_active(self.advanced_mode)
        mode.connect("toggled", self.on_mode_toggled)
        box.pack_start(mode, False, False, 0)
        refresh = Gtk.Button(label=self.tx("Refresh", "Actualiser"))
        refresh.get_style_context().add_class("ghost")
        refresh.connect("clicked", self.refresh_catalog)
        box.pack_start(refresh, False, False, 0)
        return box

    def operation_panel(self) -> Gtk.Box:
        self.operation_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        self.operation_box.get_style_context().add_class("operation-panel")
        self.operation_box.set_no_show_all(True)
        text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        self.operation_title = Gtk.Label(label=tr_text("Ready"), xalign=0)
        self.operation_title.get_style_context().add_class("operation-title")
        self.operation_state = Gtk.Label(label=tr_text("No install is running."), xalign=0)
        self.operation_state.get_style_context().add_class("operation-state")
        text.pack_start(self.operation_title, False, False, 0)
        text.pack_start(self.operation_state, False, False, 0)
        self.operation_box.pack_start(text, True, True, 0)
        self.operation_progress = Gtk.ProgressBar()
        self.operation_progress.set_size_request(190, -1)
        self.operation_box.pack_start(self.operation_progress, False, False, 0)
        details = Gtk.Button(label=tr_text("Details"))
        details.get_style_context().add_class("ghost")
        details.connect("clicked", self.show_operation_details)
        self.operation_box.pack_start(details, False, False, 0)
        self.operation_action = Gtk.Button(label=tr_text("Continue"))
        self.operation_action.get_style_context().add_class("primary")
        self.operation_action.connect("clicked", self.run_queued_operation)
        self.operation_box.pack_start(self.operation_action, False, False, 0)
        self.operation_cancel = Gtk.Button(label=tr_text("Cancel"))
        self.operation_cancel.get_style_context().add_class("ghost")
        self.operation_cancel.connect("clicked", self.cancel_operation)
        self.operation_box.pack_start(self.operation_cancel, False, False, 0)
        self.operation_box.hide()
        return self.operation_box

    def queue_operation(self, title: str, command: str, visible_terminal: bool = True) -> None:
        self.current_operation_command = command
        self.current_operation_visible = visible_terminal
        self.operation_title.set_text(title)
        self.operation_state.set_text(tr_text("Preparing install plan..."))
        self.operation_progress.set_fraction(0.12)
        self.operation_box.show_all()
        self.operation_action.set_sensitive(False)
        self.operation_action.set_label(tr_text("Preparing"))

        steps = [
            (0.28, tr_text("Resolving source and trust metadata...")),
            (0.52, tr_text("Preparing system authorization...")),
            (0.78, tr_text("Ready for your confirmation.")),
        ]

        def advance(index: int = 0) -> bool:
            if index >= len(steps):
                self.operation_progress.set_fraction(0.92)
                self.operation_state.set_text(tr_text("Review is ready. Continue only when you want to execute this action."))
                self.operation_action.set_label(tr_text("Continue"))
                self.operation_action.set_sensitive(True)
                return False
            fraction, message = steps[index]
            self.operation_progress.set_fraction(fraction)
            self.operation_state.set_text(message)
            GLib.timeout_add(260, advance, index + 1)
            return False

        GLib.timeout_add(180, advance, 0)

    def run_queued_operation(self, _button: Gtk.Button) -> None:
        if not self.current_operation_command:
            return
        self.operation_action.set_sensitive(False)
        self.operation_progress.set_fraction(1.0)
        self.operation_state.set_text(tr_text("Installer opened. SevenStore will keep this action visible here."))
        if self.current_operation_visible:
            open_visible(self.current_operation_command)
        else:
            open_hidden(self.current_operation_command)

    def operation_details_command(self) -> str:
        command = self.current_operation_command.strip()
        if not command:
            return ""
        if " install-app " in f" {command} " and "--dry-run" not in command:
            return f"{command} --dry-run"
        text = f"SevenStore action preview\\n\\nCommand:\\n{command}\\n"
        return f"printf '%s\\n' {shlex.quote(text)}"

    def show_operation_details(self, _button: Gtk.Button) -> None:
        command = self.operation_details_command()
        if command:
            open_visible(command)

    def cancel_operation(self, _button: Gtk.Button) -> None:
        self.current_operation_command = ""
        self.operation_state.set_text(tr_text("Action cancelled."))
        self.operation_progress.set_fraction(0)
        self.operation_box.hide()

    def active_profile_label(self) -> str:
        profile = self.active_profile_key()
        if not profile:
            return "EQX"
        profiles = self.profiles_payload()
        for item in profiles if isinstance(profiles, list) else []:
            if item.get("key") == profile:
                return str(item.get("short_label") or item.get("key") or "EQX").upper()
        return "EQX"

    def active_profile_key(self) -> str:
        profiles = self.profiles_payload()
        for item in profiles if isinstance(profiles, list) else []:
            if item.get("active"):
                return str(item.get("key") or "equinox")
        return "equinox"

    def profiles_payload(self) -> list[dict]:
        if self._profiles_cache is None:
            payload = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
            self._profiles_cache = payload if isinstance(payload, list) else []
        return self._profiles_cache

    def clear(self, box: Gtk.Box | None = None) -> None:
        target = box or self.content
        for child in list(target.get_children()):
            target.remove(child)

    def set_view(self, name: str) -> None:
        self.current_view = name

    def refresh_catalog(self, _button: Gtk.Button | None = None) -> None:
        self.operation_title.set_text(tr_text("Refreshing SevenStore"))
        self.operation_state.set_text(tr_text("Refreshing app catalog, Launchpad and Spotlight indexes..."))
        self.operation_progress.set_fraction(0.18)
        self.operation_box.show_all()
        self.operation_action.set_sensitive(False)
        self.operation_action.set_label(tr_text("Refreshing"))
        threading.Thread(target=self.refresh_worker, daemon=True).start()

    def refresh_worker(self) -> None:
        run_text([str(ROOT / "scripts/store.sh"), "refresh"])
        payload = cached_store_payload(refresh=True)
        GLib.idle_add(self.finish_refresh, payload)

    def finish_refresh(self, payload: dict) -> bool:
        self.payload = payload if isinstance(payload, dict) else self.payload
        self.operation_progress.set_fraction(1.0)
        self.operation_state.set_text(tr_text("Catalog refreshed."))
        self.operation_action.set_label(tr_text("Done"))
        query = self.search_entry.get_text().strip()
        if query:
            self.on_search(self.search_entry)
        else:
            self.render_current_view()
        return False

    def render_current_view(self) -> None:
        view = self.current_view
        if view == "installed":
            self.render_installed()
        elif view == "updates":
            self.render_updates()
        elif view == "activity":
            self.render_activity()
        elif view == "profiles":
            self.render_profiles()
        elif view == "permissions":
            self.render_permissions()
        elif view == "vm":
            self.render_vm()
        elif view == "categories":
            self.render_categories()
        elif view == "modules":
            self.render_modules()
        elif view == "ai":
            self.render_ai()
        else:
            self.render_home()

    def label(self, text: str, css: str | None = None, xalign: float = 0) -> Gtk.Label:
        label = Gtk.Label(label=text)
        label.set_xalign(xalign)
        label.set_line_wrap(True)
        if css:
            label.get_style_context().add_class(css)
        return label

    def icon_name_for(self, item: dict | None, fallback: str = "system-software-install") -> str:
        if not item:
            return fallback
        explicit = str(item.get("icon") or "").strip()
        if explicit:
            return explicit
        raw = str(item.get("id") or item.get("key") or item.get("name") or item.get("title") or "").lower()
        source = str(item.get("source") or "").lower()
        aliases = {
            "vlc": "vlc",
            "firefox": "firefox",
            "chromium": "chromium",
            "discord": "discord",
            "telegram": "telegram",
            "steam": "steam",
            "lutris": "lutris",
            "blender": "blender",
            "gimp": "gimp",
            "krita": "krita",
            "inkscape": "inkscape",
            "obs-studio": "com.obsproject.Studio",
            "kdenlive": "kdenlive",
            "code": "visual-studio-code",
            "vscode": "visual-studio-code",
            "libreoffice": "libreoffice-startcenter",
            "thunderbird": "thunderbird",
            "spotify": "spotify",
            "wireshark": "wireshark",
            "wireshark-qt": "wireshark",
            "equinox": "preferences-system",
            "forge": "applications-development",
            "shield": "security-high",
            "studio": "applications-graphics",
            "atlas": "folder-documents",
            "pulse": "applications-games",
            "baobab": "accessories-dictionary",
        }
        candidates = [raw, raw.removesuffix("-bin"), raw.removesuffix("-git")]
        for candidate in candidates:
            if candidate in aliases:
                return aliases[candidate]
        if source == "flatpak" and raw:
            return raw
        if source == "aur":
            return "applications-development"
        if source == "profile":
            return "preferences-system"
        return fallback

    def icon_frame(self, icon_name: str, size: int = 42) -> Gtk.Box:
        frame = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        frame.set_halign(Gtk.Align.CENTER)
        frame.set_valign(Gtk.Align.CENTER)
        frame.get_style_context().add_class("app-icon-frame")
        image = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        image.set_pixel_size(size)
        image.set_halign(Gtk.Align.CENTER)
        image.set_valign(Gtk.Align.CENTER)
        frame.pack_start(image, True, True, 0)
        return frame

    def command_button(self, label: str, command: str, primary: bool = False, visible_terminal: bool = False) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("primary" if primary else "ghost")
        if visible_terminal:
            button.connect("clicked", lambda _button, cmd=command, name=label: self.queue_operation(name, cmd))
        else:
            button.connect("clicked", lambda _button, cmd=command: subprocess.Popen(["bash", "-lc", cmd], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}))
        return button

    def on_mode_toggled(self, button: Gtk.CheckButton) -> None:
        self.advanced_mode = button.get_active()
        query = self.search_entry.get_text().strip()
        if query:
            self.on_search(self.search_entry)
        else:
            self.render_home()

    def render_home(self) -> None:
        self.active_nav = "discover"
        self.update_nav_state()
        self.set_view("home")
        self.clear()
        profile_ui = read_profile_ui()
        home = profile_ui.get("home_screen") if isinstance(profile_ui.get("home_screen"), dict) else {}
        profile_title = profile_ui.get("title") or self.active_profile_label()
        store_collection = home.get("store_collection") or "Profile Apps"
        editorial = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        editorial.get_style_context().add_class("editorial-hero")
        editorial.pack_start(self.label(self.tx("SevenOS reference space for software", "L’espace logiciel de référence SevenOS"), "editorial-kicker"), False, False, 0)
        editorial.pack_start(self.label("SevenStore", "editorial-title"), False, False, 0)
        editorial.pack_start(self.label(self.tx(
            "{profile}: discover, install and keep apps scoped to the right Mini OS.",
            "{profile} : découvrir, installer et garder les apps dans le bon Mini OS.",
            profile=profile_title,
        ), "editorial-copy"), False, False, 0)
        action_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        for label, query in (
            (self.tx("Browser", "Navigateur"), "browser"),
            (self.tx("Office", "Bureau"), "office document"),
            (self.tx("Code", "Code"), "code editor docker"),
            (self.tx("Media", "Média"), "video music"),
        ):
            button = Gtk.Button(label=label)
            button.get_style_context().add_class("ghost")
            button.connect("clicked", lambda _button, q=query: self.search_for(q))
            action_row.pack_start(button, False, False, 0)
        editorial.pack_start(action_row, False, False, 0)
        self.content.pack_start(editorial, False, False, 0)

        self.content.pack_start(self.store_health_panel(), False, False, 0)
        self.content.pack_start(self.workflow_panel(), False, False, 0)
        self.content.pack_start(self.source_guide_panel(), False, False, 0)

        if home:
            self.section(self.tx("Active Mini OS", "Mini OS actif"))
            active = self.card(str(home.get("title", profile_title)), str(home.get("focus", "")), ["ACTIVE", f"AUTONOMY {home.get('autonomy_score', 0)}%"], {"source": "profile", "key": profile_ui.get("profile", "equinox")})
            active.connect("button-press-event", lambda *_: open_hidden(str(profile_ui.get("center_command") or "seven-profile-center-native")))
            self.content.pack_start(active, False, False, 0)
        active_profile_apps = self.profile_app_entries(self.active_profile_key())
        if active_profile_apps:
            self.section(self.tx("Mini OS Library", "Bibliothèque Mini OS"))
            self.content.pack_start(self.card(
                self.tx("{count} apps for {profile}", "{count} apps pour {profile}", count=len(active_profile_apps), profile=self.active_profile_key().title()),
                self.tx("Apps explicitly associated with this Mini OS. They stay visible here even when the broader catalog changes.", "Apps associées à ce Mini OS. Elles restent visibles ici même si le catalogue global évolue."),
                ["PROFILE", "LIBRARY"],
                {"source": "profile", "key": self.active_profile_key()},
            ), False, False, 0)
            for item in active_profile_apps[:6]:
                card = self.card(item.get("name", item.get("id", "")), item.get("summary", ""), self.state_badges_for(item), item)
                card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
                self.content.pack_start(card, False, False, 0)
        self.section(self.tx("Recommended now", "Recommandé maintenant"))
        featured = Gtk.FlowBox()
        featured.set_selection_mode(Gtk.SelectionMode.NONE)
        featured.set_min_children_per_line(2)
        featured.set_max_children_per_line(3)
        for title, desc, query, icon in self.recommended_tiles():
            card = self.feature_card(title, desc, ["CURATED"], {"icon": icon, "source": "collection"})
            card.connect("button-press-event", lambda _w, _e, q=query: self.search_for(q))
            featured.add(card)
        self.content.pack_start(featured, False, False, 0)
        self.content.show_all()

    def workflow_panel(self) -> Gtk.Box:
        panel = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        panel.get_style_context().add_class("workflow-panel")
        for index, (title, note, icon) in enumerate((
            (self.tx("Discover", "Découvrir"), self.tx("Search by intent, not package names.", "Chercher par besoin, pas par nom de paquet."), "system-search"),
            (self.tx("Review", "Vérifier"), self.tx("Source, permissions and Mini OS scope stay visible.", "Source, permissions et portée Mini OS restent visibles."), "security-high"),
            (self.tx("Install", "Installer"), self.tx("SevenStore queues a clear plan before execution.", "SevenStore prépare un plan clair avant l’exécution."), "system-software-install"),
        ), start=1):
            step = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            step.get_style_context().add_class("workflow-step")
            badge = self.label(str(index), "workflow-index", 0.5)
            step.pack_start(badge, False, False, 0)
            step.pack_start(self.icon_frame(icon, 20), False, False, 0)
            text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            text.pack_start(self.label(title, "workflow-title"), False, False, 0)
            text.pack_start(self.label(note, "workflow-note"), False, False, 0)
            step.pack_start(text, True, True, 0)
            panel.pack_start(step, True, True, 0)
        return panel

