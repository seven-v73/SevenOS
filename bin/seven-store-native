    def feature_card(self, title: str, description: str, badges: list[str] | None = None, item: dict | None = None) -> Gtk.EventBox:
        event = self.card(title, description, badges, item)
        child = event.get_child()
        if child:
            child.get_style_context().add_class("feature-card")
        return event

    def action_card(self, title: str, description: str, badges: list[str], icon: str, command: str) -> Gtk.EventBox:
        card = self.card(title, description, badges, {"source": "category", "icon": icon})
        card.connect("button-press-event", lambda _w, _e, cmd=command, label=title: self.queue_operation(label, cmd))
        return card

    def stats_flow(self, rows: list[tuple[str, str, str, str]]) -> Gtk.FlowBox:
        flow = Gtk.FlowBox()
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_min_children_per_line(2)
        flow.set_max_children_per_line(4)
        for title, value, desc, icon in rows:
            flow.add(self.feature_card(f"{value} {title}", desc, ["STATUS"], {"icon": icon, "source": "collection"}))
        return flow

    def profile_app_entries(self, profile: str) -> list[dict]:
        raw = self.payload.get("profile_apps", {})
        entries = raw.get(profile, []) if isinstance(raw, dict) else []
        if not isinstance(entries, list):
            return []
        library_index = {}
        for item in self.payload.get("installed_library", []):
            for key in (item.get("id"), item.get("key"), item.get("desktop_id"), item.get("name")):
                if key:
                    library_index[str(key).lower()] = item
        resolved = []
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            app_id = str(entry.get("id") or "")
            source = str(entry.get("source") or "")
            match = library_index.get(app_id.lower())
            if match:
                row = dict(match)
                row.setdefault("source", source)
                row["profile"] = profile
            else:
                row = {
                    "id": app_id,
                    "key": app_id,
                    "name": app_id,
                    "source": source,
                    "summary": tr_text("Associated with this mini OS. Install or repair it from SevenStore if it is not available yet."),
                    "badges": ["PROFILE", source.upper()],
                    "profile": profile,
                }
            resolved.append(row)
        return resolved

    def profile_app_count(self, profile: str) -> int:
        raw = self.payload.get("profile_apps", {})
        entries = raw.get(profile, []) if isinstance(raw, dict) else []
        return len(entries) if isinstance(entries, list) else 0

    def item_profile_membership(self, item: dict, profile: str) -> bool:
        app_id = str(item.get("id") or item.get("key") or item.get("name") or "")
        source = str(item.get("source") or "")
        if not app_id or not source:
            return False
        raw = self.payload.get("profile_apps", {})
        entries = raw.get(profile, []) if isinstance(raw, dict) else []
        if not isinstance(entries, list):
            return False
        aliases = {app_id, app_id.removesuffix(".desktop")}
        desktop_id = item.get("desktop_id")
        if desktop_id:
            aliases.add(str(desktop_id))
            aliases.add(str(desktop_id).removesuffix(".desktop"))
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            if str(entry.get("source") or "") == source and str(entry.get("id") or "") in aliases:
                return True
        return False

    def section(self, text: str) -> None:
        self.content.pack_start(self.label(text, "section-title"), False, False, 0)

    def public_source_label(self, source: str, installed: bool = False) -> str:
        labels = {
            "pacman": "SEVENOS SYSTEM",
            "aur": "COMMUNITY SOURCE",
            "flatpak": "SANDBOXED APP",
            "vm": "WINDOWS BRIDGE",
            "profile": "MINI OS",
            "collection": "COLLECTION",
            "category": "CATEGORY",
        }
        label = labels.get(str(source).lower(), str(source or "SevenOS").upper())
        if installed:
            label = f"{label} · INSTALLED"
        return label

    def public_badge_label(self, badge: str) -> str:
        labels = {
            "PACMAN": "SYSTEM",
            "AUR": "COMMUNITY",
            "FLATPAK": "SANDBOXED",
            "LINUX": "NATIVE",
        }
        return labels.get(str(badge).upper(), str(badge))

    def state_badges_for(self, item: dict) -> list[str]:
        badges = list(item.get("badges", []) or [])
        source = str(item.get("source") or "").lower()
        if item.get("installed") and "INSTALLED" not in badges:
            badges.insert(0, "INSTALLED")
        if source == "desktop" and "LOCAL" not in badges:
            badges.append("LOCAL")
        if item.get("kind") == "graphical" and "GRAPHICAL" not in badges:
            badges.append("GRAPHICAL")
        return badges[:5]

    def library_stats(self, apps: list[dict]) -> Gtk.FlowBox:
        total = len(apps)
        sandboxed = sum(1 for item in apps if item.get("source") == "flatpak")
        local = sum(1 for item in apps if item.get("source") == "desktop")
        graphical = sum(1 for item in apps if item.get("kind") == "graphical")
        stats = Gtk.FlowBox()
        stats.set_selection_mode(Gtk.SelectionMode.NONE)
        stats.set_min_children_per_line(2)
        stats.set_max_children_per_line(4)
        for title, value, desc, icon in (
            (tr_text("Installed"), str(total), tr_text("desktop launchers detected"), "emblem-default"),
            (tr_text("Graphical"), str(graphical), tr_text("ready for Launchpad"), "applications-other"),
            (tr_text("Sandboxed"), str(sandboxed), tr_text("Flatpak isolated apps"), "security-high"),
            (tr_text("Local"), str(local), tr_text("system desktop entries"), "drive-harddisk"),
        ):
            stats.add(self.feature_card(f"{value} {title}", desc, ["LIBRARY"], {"icon": icon, "source": "collection"}))
        return stats

    def app_group_title(self, source: str) -> str:
        labels = {
            "flatpak": tr_text("Sandboxed Apps"),
            "desktop": tr_text("Local Applications"),
            "pacman": tr_text("System Packages"),
            "aur": tr_text("Community Apps"),
        }
        return labels.get(source, source.title() if source else tr_text("Other"))

    def availability_text(self, item: dict | None) -> str:
        if not item:
            return ""
        if item.get("installed") and item.get("kind") == "graphical":
            return tr_text("Ready to open")
        if item.get("installed"):
            return tr_text("Installed component")
        source = str(item.get("source") or "").lower()
        if source == "flatpak":
            return tr_text("Sandbox install")
        if source == "aur":
            return tr_text("Review required")
        if source in {"pacman", "profile"}:
            return tr_text("Available")
        return tr_text("Preview first")

    def card(self, title: str, description: str, badges: list[str] | None = None, item: dict | None = None, action_label: str | None = None) -> Gtk.EventBox:
        event = Gtk.EventBox()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("card")
        if item and item.get("source"):
            box.get_style_context().add_class(f"source-{str(item.get('source')).lower()}")
            box.get_style_context().add_class(self.trust_class_for(item))
        event.add(box)
        box.pack_start(self.icon_frame(self.icon_name_for(item)), False, False, 0)
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        text_box.pack_start(self.label(title, "store-row-title"), False, False, 0)
        if item and item.get("source"):
            source_text = self.public_source_label(str(item.get("source", "")), bool(item.get("installed")))
            text_box.pack_start(self.label(source_text, "store-source"), False, False, 0)
        text_box.pack_start(self.label(description or "No description available.", "muted"), False, False, 0)
        if item:
            text_box.pack_start(self.label(self.availability_text(item), "availability"), False, False, 0)
        badge_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        for badge in badges or []:
            pill = self.label(self.public_badge_label(str(badge)), "badge")
            badge_row.pack_start(pill, False, False, 0)
        text_box.pack_start(badge_row, False, False, 0)
        if action_label:
            button = Gtk.Button(label=action_label)
            button.get_style_context().add_class("primary")
            text_box.pack_start(button, False, False, 0)
        box.pack_start(text_box, True, True, 0)
        if item:
            meta = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
            meta.set_halign(Gtk.Align.END)
            meta.set_valign(Gtk.Align.CENTER)
            meta.get_style_context().add_class("card-meta")
            meta.pack_start(self.label(self.trust_short_label(item), "card-trust", 1), False, False, 0)
            if item.get("quality_score"):
                meta.pack_start(self.label(f"{item.get('quality_score')}/100", "card-score", 1), False, False, 0)
            box.pack_start(meta, False, False, 0)
        chevron = Gtk.Label(label="›")
        chevron.get_style_context().add_class("card-chevron")
        box.pack_start(chevron, False, False, 0)
        return event

    def trust_class_for(self, item: dict) -> str:
        source = str(item.get("source") or "").lower()
        if item.get("installed") or source in {"pacman", "flatpak", "profile", "desktop", "collection", "category"}:
            return "trust-high"
        if source == "aur":
            return "trust-review"
        return "trust-preview"

    def trust_short_label(self, item: dict) -> str:
        if item.get("installed"):
            return self.tx("Ready", "Prête")
        source = str(item.get("source") or "").lower()
        if source == "flatpak":
            return self.tx("Sandbox", "Sandbox")
        if source == "pacman":
            return self.tx("System", "Système")
        if source == "aur":
            return self.tx("Review", "Revue")
        if source == "profile":
            return self.tx("Mini OS", "Mini OS")
        return self.tx("Preview", "Aperçu")

    def render_profiles(self) -> None:
        self.active_nav = "profiles"
        self.update_nav_state()
        self.set_view("profiles")
        self.clear()
        self.section(self.tx("Mini OS collections", "Collections Mini OS"))
        active_profile = self.active_profile_key()
        active_entries = self.profile_app_entries(active_profile)
        self.content.pack_start(self.stats_flow([
            (tr_text("Active"), active_profile.title(), tr_text("current mini OS"), "preferences-system"),
            (tr_text("Apps"), str(len(active_entries)), tr_text("associated with active mini OS"), "emblem-default"),
            (tr_text("Profiles"), str(len(self.payload.get("profile_collections", {}))), tr_text("curated SevenOS modes"), "view-grid"),
            (tr_text("Activity"), str(self.payload.get("summary", {}).get("activity", 0)), tr_text("recent Store actions"), "document-open-recent"),
        ]), False, False, 0)
        if active_entries:
            self.section(f"{active_profile.title()} apps")
            for item in active_entries[:12]:
                card = self.card(item.get("name", item.get("id", "")), item.get("summary", ""), self.state_badges_for(item), item)
                card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
                self.content.pack_start(card, False, False, 0)
        self.section("Collections")
        for key, item in self.payload.get("profile_collections", {}).items():
            badges = ["PROFILE", item.get("accent", "seven").upper()]
            count = self.profile_app_count(key)
            if count:
                badges.append(f"{count} APPS")
            card = self.card(item["title"], item["description"], badges, {"key": key, "source": "profile"})
            card.connect("button-press-event", lambda _widget, _event, profile=key: self.render_profile_detail(profile))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

