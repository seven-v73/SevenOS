#!/usr/bin/env python3
"""SevenStore AppCenter surface."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import shlex
import subprocess
import sys
import threading
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()
    here = Path(__file__).resolve()
    if (here.parent.parent / "install.sh").is_file():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "install.sh").is_file():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr_text  # noqa: E402
import seven_theme  # noqa: E402

CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
PROFILE_UI_FILE = CONFIG_DIR / "profile-ui.json"


def read_profile_ui() -> dict:
    try:
        data = json.loads(PROFILE_UI_FILE.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def ensure_gtk_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        probe = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if probe.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    available, error = gtk_available()
    if available:
        print("OK")
        return 0
    print(f"MISS: {error}", file=sys.stderr)
    return 1


def gtk_available() -> tuple[bool, str]:
    ensure_gtk_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        return False, str(exc)
    return True, ""


def run_json(command: list[str], fallback):
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            text=True,
            capture_output=True,
            check=False,
            timeout=18,
        )
        if result.returncode != 0:
            return fallback
        return json.loads(result.stdout)
    except Exception:
        return fallback


def run_text(command: list[str]) -> str:
    result = subprocess.run(
        command,
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        text=True,
        capture_output=True,
        check=False,
        timeout=18,
    )
    return result.stdout.strip() or result.stderr.strip()


def open_visible(command: str) -> None:
    wrapped = f"cd {shlex.quote(str(ROOT))} && {command}; printf '\\nPress Enter to close...'; read -r"
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    for candidate in (
        ["seven-terminal", "focus", "--", "bash", "-lc", wrapped],
        ["kitty", "--title", "SevenStore", "bash", "-lc", wrapped],
        ["foot", "-e", "bash", "-lc", wrapped],
    ):
        if subprocess.run(["bash", "-lc", f"command -v {shlex.quote(candidate[0])} >/dev/null 2>&1"], check=False).returncode == 0:
            subprocess.Popen(candidate, cwd=ROOT, env=env)
            return
    subprocess.Popen(["bash", "-lc", wrapped], cwd=ROOT, env=env)


def open_hidden(command: str) -> None:
    subprocess.Popen(["bash", "-lc", command], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def shell_quote(command: list[str]) -> str:
    return " ".join(shlex.quote(str(part)) for part in command if str(part))


ensure_gtk_python()

import gi  # noqa: E402

gi.require_version("Gdk", "3.0")
gi.require_version("Gtk", "3.0")
from gi.repository import Gdk, GLib, Gtk  # noqa: E402


CSS = seven_theme.surface_css("store")


class SevenStore(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="os.seven.SevenStore")
        self.window: Gtk.ApplicationWindow | None = None
        self.payload: dict = {}
        self.results: list[dict] = []
        self.content = Gtk.Box()
        self.detail_box = Gtk.Box()
        self.operation_box = Gtk.Box()
        self.operation_title = Gtk.Label()
        self.operation_state = Gtk.Label()
        self.operation_progress = Gtk.ProgressBar()
        self.operation_action = Gtk.Button()
        self.operation_cancel = Gtk.Button()
        self.current_operation_command = ""
        self.current_operation_visible = True
        self.search_entry = Gtk.SearchEntry()
        self.search_timeout_id = 0
        self.search_generation = 0
        self.advanced_mode = False
        self.source_filter = "all"
        self.current_view = "home"

    def do_activate(self) -> None:
        if self.window:
            self.window.present()
            return

        provider = Gtk.CssProvider()
        css = seven_theme.gtk_app_css("store") + CSS
        provider.load_from_data(css.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.payload = run_json([str(ROOT / "scripts/store.sh"), "json"], {"summary": {}, "modules": [], "apps": [], "profile_collections": {}})

        self.window = Gtk.ApplicationWindow(application=self)
        self.window.set_name("seven-store")
        self.window.get_style_context().add_class("seven-store")
        self.window.set_title("SevenStore")
        self.window.set_default_size(1180, 740)
        self.window.set_wmclass("SevenStoreNative", "SevenStoreNative")

        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        root.get_style_context().add_class("root")
        self.window.add(root)

        root.pack_start(self.sidebar(), False, False, 0)

        main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        main.set_margin_top(18)
        main.set_margin_bottom(18)
        main.set_margin_start(18)
        main.set_margin_end(18)
        root.pack_start(main, True, True, 0)

        main.pack_start(self.topbar(), False, False, 0)
        main.pack_start(self.operation_panel(), False, False, 0)

        body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        main.pack_start(body, True, True, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        self.content.set_margin_bottom(8)
        scroller.add(self.content)
        body.pack_start(scroller, True, True, 0)

        self.detail_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.detail_box.set_size_request(320, -1)
        self.detail_box.get_style_context().add_class("detail")
        body.pack_start(self.detail_box, False, False, 0)

        self.render_home()
        self.render_detail(None)
        self.window.show_all()

    def sidebar(self) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_size_request(190, -1)
        box.get_style_context().add_class("sidebar")
        for icon, label, action in (
            ("go-home-symbolic", tr_text("Discover"), self.render_home),
            ("view-grid-symbolic", tr_text("Apps"), self.render_categories),
            ("applications-games-symbolic", tr_text("Games"), lambda: self.render_category_search("steam lutris gamescope", "Games")),
            ("applications-graphics-symbolic", tr_text("Create"), lambda: self.render_category_search("design graphics photo video audio", "Create")),
            ("applications-development-symbolic", tr_text("Develop"), lambda: self.render_category_search("code editor terminal docker sdk", "Develop")),
            ("security-high-symbolic", tr_text("Security"), lambda: self.render_category_search("wireshark nmap forensic", "Security")),
            ("emblem-default-symbolic", tr_text("Installed"), self.render_installed),
            ("software-update-available-symbolic", tr_text("Updates"), self.render_updates),
            ("document-open-recent-symbolic", tr_text("Activity"), self.render_activity),
            ("preferences-system-symbolic", tr_text("Profiles"), self.render_profiles),
            ("security-high-symbolic", tr_text("Privacy"), self.render_permissions),
            ("computer-symbolic", tr_text("Windows"), self.render_vm),
        ):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.set_halign(Gtk.Align.FILL)
            image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
            image.set_pixel_size(16)
            row.pack_start(image, False, False, 0)
            button_label = Gtk.Label(label=label)
            button_label.set_xalign(0)
            button_label.set_halign(Gtk.Align.FILL)
            button_label.get_style_context().add_class("sidebar-label")
            row.pack_start(button_label, True, True, 0)
            button = Gtk.Button()
            button.add(row)
            button.connect("clicked", lambda _button, callback=action: callback())
            box.pack_start(button, False, False, 0)
        box.pack_end(Gtk.Label(label=tr_text("SevenOS AppCenter")), False, False, 0)
        return box

    def topbar(self) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("topbar")
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        title = Gtk.Label(label="SevenStore", xalign=0)
        title.get_style_context().add_class("title")
        caption = Gtk.Label(label=tr_text("Apps, profiles and trusted installs"), xalign=0)
        caption.get_style_context().add_class("caption")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(caption, False, False, 0)
        box.pack_start(title_box, False, False, 0)
        self.search_entry.get_style_context().add_class("search")
        self.search_entry.set_placeholder_text(tr_text("Search apps, tools, games..."))
        self.search_entry.connect("activate", self.on_search)
        self.search_entry.connect("search-changed", self.on_search_changed)
        box.pack_start(self.search_entry, True, True, 0)
        profile = Gtk.Label(label=self.active_profile_label())
        profile.get_style_context().add_class("badge")
        box.pack_start(profile, False, False, 0)
        mode = Gtk.CheckButton(label=tr_text("Advanced"))
        mode.get_style_context().add_class("mode-toggle")
        mode.set_active(self.advanced_mode)
        mode.connect("toggled", self.on_mode_toggled)
        box.pack_start(mode, False, False, 0)
        refresh = Gtk.Button(label=tr_text("Refresh"))
        refresh.get_style_context().add_class("ghost")
        refresh.connect("clicked", self.refresh_catalog)
        box.pack_start(refresh, False, False, 0)
        return box

    def operation_panel(self) -> Gtk.Box:
        self.operation_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        self.operation_box.get_style_context().add_class("operation-panel")
        self.operation_box.set_no_show_all(True)
        text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        self.operation_title = Gtk.Label(label=tr_text("Ready"), xalign=0)
        self.operation_title.get_style_context().add_class("operation-title")
        self.operation_state = Gtk.Label(label=tr_text("No install is running."), xalign=0)
        self.operation_state.get_style_context().add_class("operation-state")
        text.pack_start(self.operation_title, False, False, 0)
        text.pack_start(self.operation_state, False, False, 0)
        self.operation_box.pack_start(text, True, True, 0)
        self.operation_progress = Gtk.ProgressBar()
        self.operation_progress.set_size_request(190, -1)
        self.operation_box.pack_start(self.operation_progress, False, False, 0)
        details = Gtk.Button(label=tr_text("Details"))
        details.get_style_context().add_class("ghost")
        details.connect("clicked", self.show_operation_details)
        self.operation_box.pack_start(details, False, False, 0)
        self.operation_action = Gtk.Button(label=tr_text("Continue"))
        self.operation_action.get_style_context().add_class("primary")
        self.operation_action.connect("clicked", self.run_queued_operation)
        self.operation_box.pack_start(self.operation_action, False, False, 0)
        self.operation_cancel = Gtk.Button(label=tr_text("Cancel"))
        self.operation_cancel.get_style_context().add_class("ghost")
        self.operation_cancel.connect("clicked", self.cancel_operation)
        self.operation_box.pack_start(self.operation_cancel, False, False, 0)
        self.operation_box.hide()
        return self.operation_box

    def queue_operation(self, title: str, command: str, visible_terminal: bool = True) -> None:
        self.current_operation_command = command
        self.current_operation_visible = visible_terminal
        self.operation_title.set_text(title)
        self.operation_state.set_text(tr_text("Preparing install plan..."))
        self.operation_progress.set_fraction(0.12)
        self.operation_box.show_all()
        self.operation_action.set_sensitive(False)
        self.operation_action.set_label(tr_text("Preparing"))

        steps = [
            (0.28, tr_text("Resolving source and trust metadata...")),
            (0.52, tr_text("Preparing system authorization...")),
            (0.78, tr_text("Ready for your confirmation.")),
        ]

        def advance(index: int = 0) -> bool:
            if index >= len(steps):
                self.operation_progress.set_fraction(0.92)
                self.operation_state.set_text(tr_text("Review is ready. Continue only when you want to execute this action."))
                self.operation_action.set_label(tr_text("Continue"))
                self.operation_action.set_sensitive(True)
                return False
            fraction, message = steps[index]
            self.operation_progress.set_fraction(fraction)
            self.operation_state.set_text(message)
            GLib.timeout_add(260, advance, index + 1)
            return False

        GLib.timeout_add(180, advance, 0)

    def run_queued_operation(self, _button: Gtk.Button) -> None:
        if not self.current_operation_command:
            return
        self.operation_action.set_sensitive(False)
        self.operation_progress.set_fraction(1.0)
        self.operation_state.set_text(tr_text("Installer opened. SevenStore will keep this action visible here."))
        if self.current_operation_visible:
            open_visible(self.current_operation_command)
        else:
            open_hidden(self.current_operation_command)

    def operation_details_command(self) -> str:
        command = self.current_operation_command.strip()
        if not command:
            return ""
        if " install-app " in f" {command} " and "--dry-run" not in command:
            return f"{command} --dry-run"
        text = f"SevenStore action preview\\n\\nCommand:\\n{command}\\n"
        return f"printf '%s\\n' {shlex.quote(text)}"

    def show_operation_details(self, _button: Gtk.Button) -> None:
        command = self.operation_details_command()
        if command:
            open_visible(command)

    def cancel_operation(self, _button: Gtk.Button) -> None:
        self.current_operation_command = ""
        self.operation_state.set_text(tr_text("Action cancelled."))
        self.operation_progress.set_fraction(0)
        self.operation_box.hide()

    def active_profile_label(self) -> str:
        profile = self.active_profile_key()
        if not profile:
            return "EQX"
        profiles = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
        for item in profiles if isinstance(profiles, list) else []:
            if item.get("key") == profile:
                return str(item.get("short_label") or item.get("key") or "EQX").upper()
        return "EQX"

    def active_profile_key(self) -> str:
        profiles = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
        for item in profiles if isinstance(profiles, list) else []:
            if item.get("active"):
                return str(item.get("key") or "equinox")
        return "equinox"

    def clear(self, box: Gtk.Box | None = None) -> None:
        target = box or self.content
        for child in list(target.get_children()):
            target.remove(child)

    def set_view(self, name: str) -> None:
        self.current_view = name

    def refresh_catalog(self, _button: Gtk.Button | None = None) -> None:
        self.operation_title.set_text(tr_text("Refreshing SevenStore"))
        self.operation_state.set_text(tr_text("Refreshing app catalog, Launchpad and Spotlight indexes..."))
        self.operation_progress.set_fraction(0.18)
        self.operation_box.show_all()
        self.operation_action.set_sensitive(False)
        self.operation_action.set_label(tr_text("Refreshing"))
        threading.Thread(target=self.refresh_worker, daemon=True).start()

    def refresh_worker(self) -> None:
        run_text([str(ROOT / "scripts/store.sh"), "refresh"])
        payload = run_json([str(ROOT / "scripts/store.sh"), "json"], {"summary": {}, "modules": [], "apps": [], "profile_collections": {}})
        GLib.idle_add(self.finish_refresh, payload)

    def finish_refresh(self, payload: dict) -> bool:
        self.payload = payload if isinstance(payload, dict) else self.payload
        self.operation_progress.set_fraction(1.0)
        self.operation_state.set_text(tr_text("Catalog refreshed."))
        self.operation_action.set_label(tr_text("Done"))
        query = self.search_entry.get_text().strip()
        if query:
            self.on_search(self.search_entry)
        else:
            self.render_current_view()
        return False

    def render_current_view(self) -> None:
        view = self.current_view
        if view == "installed":
            self.render_installed()
        elif view == "updates":
            self.render_updates()
        elif view == "activity":
            self.render_activity()
        elif view == "profiles":
            self.render_profiles()
        elif view == "permissions":
            self.render_permissions()
        elif view == "vm":
            self.render_vm()
        elif view == "categories":
            self.render_categories()
        elif view == "modules":
            self.render_modules()
        elif view == "ai":
            self.render_ai()
        else:
            self.render_home()

    def label(self, text: str, css: str | None = None, xalign: float = 0) -> Gtk.Label:
        label = Gtk.Label(label=text)
        label.set_xalign(xalign)
        label.set_line_wrap(True)
        if css:
            label.get_style_context().add_class(css)
        return label

    def icon_name_for(self, item: dict | None, fallback: str = "system-software-install") -> str:
        if not item:
            return fallback
        explicit = str(item.get("icon") or "").strip()
        if explicit:
            return explicit
        raw = str(item.get("id") or item.get("key") or item.get("name") or item.get("title") or "").lower()
        source = str(item.get("source") or "").lower()
        aliases = {
            "vlc": "vlc",
            "firefox": "firefox",
            "chromium": "chromium",
            "discord": "discord",
            "telegram": "telegram",
            "steam": "steam",
            "lutris": "lutris",
            "blender": "blender",
            "gimp": "gimp",
            "krita": "krita",
            "inkscape": "inkscape",
            "obs-studio": "com.obsproject.Studio",
            "kdenlive": "kdenlive",
            "code": "visual-studio-code",
            "vscode": "visual-studio-code",
            "libreoffice": "libreoffice-startcenter",
            "thunderbird": "thunderbird",
            "spotify": "spotify",
            "wireshark": "wireshark",
            "wireshark-qt": "wireshark",
            "equinox": "preferences-system",
            "forge": "applications-development",
            "shield": "security-high",
            "studio": "applications-graphics",
            "windows": "computer",
            "pulse": "applications-games",
            "baobab": "accessories-dictionary",
        }
        candidates = [raw, raw.removesuffix("-bin"), raw.removesuffix("-git")]
        for candidate in candidates:
            if candidate in aliases:
                return aliases[candidate]
        if source == "flatpak" and raw:
            return raw
        if source == "aur":
            return "applications-development"
        if source == "profile":
            return "preferences-system"
        return fallback

    def icon_frame(self, icon_name: str, size: int = 42) -> Gtk.Box:
        frame = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        frame.set_halign(Gtk.Align.CENTER)
        frame.set_valign(Gtk.Align.CENTER)
        frame.get_style_context().add_class("app-icon-frame")
        image = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        image.set_pixel_size(size)
        image.set_halign(Gtk.Align.CENTER)
        image.set_valign(Gtk.Align.CENTER)
        frame.pack_start(image, True, True, 0)
        return frame

    def command_button(self, label: str, command: str, primary: bool = False, visible_terminal: bool = False) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("primary" if primary else "ghost")
        if visible_terminal:
            button.connect("clicked", lambda _button, cmd=command, name=label: self.queue_operation(name, cmd))
        else:
            button.connect("clicked", lambda _button, cmd=command: subprocess.Popen(["bash", "-lc", cmd], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}))
        return button

    def on_mode_toggled(self, button: Gtk.CheckButton) -> None:
        self.advanced_mode = button.get_active()
        query = self.search_entry.get_text().strip()
        if query:
            self.on_search(self.search_entry)
        else:
            self.render_home()

    def render_home(self) -> None:
        self.set_view("home")
        self.clear()
        profile_ui = read_profile_ui()
        home = profile_ui.get("home_screen") if isinstance(profile_ui.get("home_screen"), dict) else {}
        profile_title = profile_ui.get("title") or self.active_profile_label()
        store_collection = home.get("store_collection") or "Profile Apps"
        editorial = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        editorial.get_style_context().add_class("editorial-hero")
        editorial.pack_start(self.label(tr_text("TODAY IN SEVENSTORE"), "editorial-kicker"), False, False, 0)
        editorial.pack_start(self.label(str(store_collection), "editorial-title"), False, False, 0)
        editorial.pack_start(self.label(tr_text("Curated apps for your active mini OS, with source trust and profile-aware install routes before anything changes."), "editorial-copy"), False, False, 0)
        action_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        for label, query in (
            (tr_text("Recommended"), store_collection),
            (tr_text("Installed"), "installed"),
            (tr_text("Sandboxed"), "flatpak"),
        ):
            button = Gtk.Button(label=label)
            button.get_style_context().add_class("ghost")
            if query == "installed":
                button.connect("clicked", lambda _button: self.render_installed())
            else:
                button.connect("clicked", lambda _button, q=query: self.search_for(q))
            action_row.pack_start(button, False, False, 0)
        editorial.pack_start(action_row, False, False, 0)
        self.content.pack_start(editorial, False, False, 0)
        hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
        hero.get_style_context().add_class("hero")
        hero_icon = self.icon_frame("system-software-install", 48)
        hero_icon.get_style_context().add_class("hero-icon")
        hero.pack_start(hero_icon, False, False, 0)
        hero_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        hero_text.pack_start(self.label(f"The SevenOS AppCenter · {profile_title}", "title"), False, False, 0)
        hero_text.pack_start(self.label(f"{store_collection}: install apps with clear icons, trusted sources and profile-aware recommendations. New apps appear in Launchpad and Spotlight after install.", "muted"), False, False, 0)
        hero.pack_start(hero_text, True, True, 0)
        self.content.pack_start(hero, False, False, 0)
        if home:
            self.section("Active mini OS")
            active = self.card(str(home.get("title", profile_title)), str(home.get("focus", "")), ["ACTIVE", f"AUTONOMY {home.get('autonomy_score', 0)}%"], {"source": "profile", "key": profile_ui.get("profile", "equinox")})
            active.connect("button-press-event", lambda *_: open_hidden(str(profile_ui.get("center_command") or "seven-profile-center-native")))
            self.content.pack_start(active, False, False, 0)
        active_profile_apps = self.profile_app_entries(self.active_profile_key())
        if active_profile_apps:
            self.section("Mini OS Library")
            self.content.pack_start(self.card(f"{len(active_profile_apps)} apps for {self.active_profile_key().title()}", "Apps explicitly associated with this mini OS. They stay visible here even when the broader catalog changes.", ["PROFILE", "LIBRARY"], {"source": "profile", "key": self.active_profile_key()}), False, False, 0)
            for item in active_profile_apps[:6]:
                card = self.card(item.get("name", item.get("id", "")), item.get("summary", ""), self.state_badges_for(item), item)
                card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
                self.content.pack_start(card, False, False, 0)
        self.section("Featured profile collections")
        grid = Gtk.FlowBox()
        grid.set_selection_mode(Gtk.SelectionMode.NONE)
        grid.set_min_children_per_line(2)
        grid.set_max_children_per_line(3)
        for key, item in self.payload.get("profile_collections", {}).items():
            card = self.card(item["title"], item["description"], ["PROFILE", item.get("accent", "seven").upper()], {"key": key, "source": "profile"})
            card.connect("button-press-event", lambda _widget, _event, profile=key: self.render_profile_detail(profile))
            grid.add(card)
        self.content.pack_start(grid, False, False, 0)
        self.section("Recommended now")
        featured = Gtk.FlowBox()
        featured.set_selection_mode(Gtk.SelectionMode.NONE)
        featured.set_min_children_per_line(2)
        featured.set_max_children_per_line(3)
        for title, desc, query, icon in self.recommended_tiles():
            card = self.feature_card(title, desc, ["CURATED"], {"icon": icon, "source": "collection"})
            card.connect("button-press-event", lambda _w, _e, q=query: self.search_for(q))
            featured.add(card)
        self.content.pack_start(featured, False, False, 0)
        self.section("Collections")
        collections = Gtk.FlowBox()
        collections.set_selection_mode(Gtk.SelectionMode.NONE)
        collections.set_min_children_per_line(2)
        collections.set_max_children_per_line(3)
        for title, desc, icon in (
            ("Start with SevenOS", "Essential apps for a clean first setup.", "starred"),
            ("Creator Studio", "Design, video, image and capture workflows.", "applications-graphics"),
            ("Pulse Gaming", "Launchers, overlays and low-latency tools.", "applications-games"),
            ("Cyber Authorized", "Security tools with clear advanced-user boundaries.", "security-high"),
            ("African Learning", "Reading, language and cultural knowledge tools.", "accessories-dictionary"),
            ("Developer Web", "Editors, terminals, SDKs and containers.", "applications-development"),
        ):
            collections.add(self.card(title, desc, ["COLLECTION"], {"icon": icon, "source": "collection"}))
        self.content.pack_start(collections, False, False, 0)
        self.section("Trust model")
        self.content.pack_start(self.card("Install with confidence", "SevenOS separates system components, sandboxed apps and community sources before anything changes.", ["TRUSTED", "SANDBOXED", "COMMUNITY"]), False, False, 0)
        self.content.show_all()

    def recommended_tiles(self) -> list[tuple[str, str, str, str]]:
        profile = self.active_profile_key()
        by_profile = {
            "forge": [("Ship faster", "Editors, containers and project tooling.", "code docker git", "applications-development")],
            "shield": [("Authorized audit", "Security tools with clear boundaries.", "wireshark nmap forensic", "security-high")],
            "studio": [("Creator desk", "Design, video, audio and capture apps.", "design video audio obs", "applications-graphics")],
            "windows": [("Bridge ready", "Windows compatibility and VM-first workflows.", "windows bridge bottles wine", "computer")],
            "pulse": [("Play smooth", "Launchers, overlays and performance helpers.", "steam lutris gamescope", "applications-games")],
            "baobab": [("Culture library", "Reading, language and memory tools.", "reader books language", "accessories-dictionary")],
        }
        common = [
            ("Essentials", "A calm first setup for daily use.", "browser office media", "starred"),
            ("Sandboxed apps", "Flatpak-first graphical applications.", "flatpak graphical", "system-software-install"),
        ]
        return by_profile.get(profile, []) + common

    def feature_card(self, title: str, description: str, badges: list[str] | None = None, item: dict | None = None) -> Gtk.EventBox:
        event = self.card(title, description, badges, item)
        child = event.get_child()
        if child:
            child.get_style_context().add_class("feature-card")
        return event

    def action_card(self, title: str, description: str, badges: list[str], icon: str, command: str) -> Gtk.EventBox:
        card = self.card(title, description, badges, {"source": "category", "icon": icon})
        card.connect("button-press-event", lambda _w, _e, cmd=command, label=title: self.queue_operation(label, cmd))
        return card

    def stats_flow(self, rows: list[tuple[str, str, str, str]]) -> Gtk.FlowBox:
        flow = Gtk.FlowBox()
        flow.set_selection_mode(Gtk.SelectionMode.NONE)
        flow.set_min_children_per_line(2)
        flow.set_max_children_per_line(4)
        for title, value, desc, icon in rows:
            flow.add(self.feature_card(f"{value} {title}", desc, ["STATUS"], {"icon": icon, "source": "collection"}))
        return flow

    def profile_app_entries(self, profile: str) -> list[dict]:
        raw = self.payload.get("profile_apps", {})
        entries = raw.get(profile, []) if isinstance(raw, dict) else []
        if not isinstance(entries, list):
            return []
        library_index = {}
        for item in self.payload.get("installed_library", []):
            for key in (item.get("id"), item.get("key"), item.get("desktop_id"), item.get("name")):
                if key:
                    library_index[str(key).lower()] = item
        resolved = []
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            app_id = str(entry.get("id") or "")
            source = str(entry.get("source") or "")
            match = library_index.get(app_id.lower())
            if match:
                row = dict(match)
                row.setdefault("source", source)
                row["profile"] = profile
            else:
                row = {
                    "id": app_id,
                    "key": app_id,
                    "name": app_id,
                    "source": source,
                    "summary": tr_text("Associated with this mini OS. Install or repair it from SevenStore if it is not available yet."),
                    "badges": ["PROFILE", source.upper()],
                    "profile": profile,
                }
            resolved.append(row)
        return resolved

    def profile_app_count(self, profile: str) -> int:
        raw = self.payload.get("profile_apps", {})
        entries = raw.get(profile, []) if isinstance(raw, dict) else []
        return len(entries) if isinstance(entries, list) else 0

    def item_profile_membership(self, item: dict, profile: str) -> bool:
        app_id = str(item.get("id") or item.get("key") or item.get("name") or "")
        source = str(item.get("source") or "")
        if not app_id or not source:
            return False
        raw = self.payload.get("profile_apps", {})
        entries = raw.get(profile, []) if isinstance(raw, dict) else []
        if not isinstance(entries, list):
            return False
        aliases = {app_id, app_id.removesuffix(".desktop")}
        desktop_id = item.get("desktop_id")
        if desktop_id:
            aliases.add(str(desktop_id))
            aliases.add(str(desktop_id).removesuffix(".desktop"))
        for entry in entries:
            if not isinstance(entry, dict):
                continue
            if str(entry.get("source") or "") == source and str(entry.get("id") or "") in aliases:
                return True
        return False

    def section(self, text: str) -> None:
        self.content.pack_start(self.label(text, "section-title"), False, False, 0)

    def public_source_label(self, source: str, installed: bool = False) -> str:
        labels = {
            "pacman": "SEVENOS SYSTEM",
            "aur": "COMMUNITY SOURCE",
            "flatpak": "SANDBOXED APP",
            "vm": "WINDOWS BRIDGE",
            "profile": "MINI OS",
            "collection": "COLLECTION",
            "category": "CATEGORY",
        }
        label = labels.get(str(source).lower(), str(source or "SevenOS").upper())
        if installed:
            label = f"{label} · INSTALLED"
        return label

    def public_badge_label(self, badge: str) -> str:
        labels = {
            "PACMAN": "SYSTEM",
            "AUR": "COMMUNITY",
            "FLATPAK": "SANDBOXED",
            "LINUX": "NATIVE",
        }
        return labels.get(str(badge).upper(), str(badge))

    def state_badges_for(self, item: dict) -> list[str]:
        badges = list(item.get("badges", []) or [])
        source = str(item.get("source") or "").lower()
        if item.get("installed") and "INSTALLED" not in badges:
            badges.insert(0, "INSTALLED")
        if source == "desktop" and "LOCAL" not in badges:
            badges.append("LOCAL")
        if item.get("kind") == "graphical" and "GRAPHICAL" not in badges:
            badges.append("GRAPHICAL")
        return badges[:5]

    def library_stats(self, apps: list[dict]) -> Gtk.FlowBox:
        total = len(apps)
        sandboxed = sum(1 for item in apps if item.get("source") == "flatpak")
        local = sum(1 for item in apps if item.get("source") == "desktop")
        graphical = sum(1 for item in apps if item.get("kind") == "graphical")
        stats = Gtk.FlowBox()
        stats.set_selection_mode(Gtk.SelectionMode.NONE)
        stats.set_min_children_per_line(2)
        stats.set_max_children_per_line(4)
        for title, value, desc, icon in (
            (tr_text("Installed"), str(total), tr_text("desktop launchers detected"), "emblem-default"),
            (tr_text("Graphical"), str(graphical), tr_text("ready for Launchpad"), "applications-other"),
            (tr_text("Sandboxed"), str(sandboxed), tr_text("Flatpak isolated apps"), "security-high"),
            (tr_text("Local"), str(local), tr_text("system desktop entries"), "drive-harddisk"),
        ):
            stats.add(self.feature_card(f"{value} {title}", desc, ["LIBRARY"], {"icon": icon, "source": "collection"}))
        return stats

    def app_group_title(self, source: str) -> str:
        labels = {
            "flatpak": tr_text("Sandboxed Apps"),
            "desktop": tr_text("Local Applications"),
            "pacman": tr_text("System Packages"),
            "aur": tr_text("Community Apps"),
        }
        return labels.get(source, source.title() if source else tr_text("Other"))

    def availability_text(self, item: dict | None) -> str:
        if not item:
            return ""
        if item.get("installed") and item.get("kind") == "graphical":
            return tr_text("Ready to open")
        if item.get("installed"):
            return tr_text("Installed component")
        source = str(item.get("source") or "").lower()
        if source == "flatpak":
            return tr_text("Sandbox install")
        if source == "aur":
            return tr_text("Review required")
        if source in {"pacman", "profile"}:
            return tr_text("Available")
        return tr_text("Preview first")

    def card(self, title: str, description: str, badges: list[str] | None = None, item: dict | None = None, action_label: str | None = None) -> Gtk.EventBox:
        event = Gtk.EventBox()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("card")
        event.add(box)
        box.pack_start(self.icon_frame(self.icon_name_for(item)), False, False, 0)
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        text_box.pack_start(self.label(title, "store-row-title"), False, False, 0)
        if item and item.get("source"):
            source_text = self.public_source_label(str(item.get("source", "")), bool(item.get("installed")))
            text_box.pack_start(self.label(source_text, "store-source"), False, False, 0)
        text_box.pack_start(self.label(description or "No description available.", "muted"), False, False, 0)
        if item:
            text_box.pack_start(self.label(self.availability_text(item), "availability"), False, False, 0)
        badge_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        for badge in badges or []:
            pill = self.label(self.public_badge_label(str(badge)), "badge")
            badge_row.pack_start(pill, False, False, 0)
        text_box.pack_start(badge_row, False, False, 0)
        if action_label:
            button = Gtk.Button(label=action_label)
            button.get_style_context().add_class("primary")
            text_box.pack_start(button, False, False, 0)
        box.pack_start(text_box, True, True, 0)
        return event

    def render_profiles(self) -> None:
        self.set_view("profiles")
        self.clear()
        self.section("Profile collections")
        active_profile = self.active_profile_key()
        active_entries = self.profile_app_entries(active_profile)
        self.content.pack_start(self.stats_flow([
            (tr_text("Active"), active_profile.title(), tr_text("current mini OS"), "preferences-system"),
            (tr_text("Apps"), str(len(active_entries)), tr_text("associated with active mini OS"), "emblem-default"),
            (tr_text("Profiles"), str(len(self.payload.get("profile_collections", {}))), tr_text("curated SevenOS modes"), "view-grid"),
            (tr_text("Activity"), str(self.payload.get("summary", {}).get("activity", 0)), tr_text("recent Store actions"), "document-open-recent"),
        ]), False, False, 0)
        if active_entries:
            self.section(f"{active_profile.title()} apps")
            for item in active_entries[:12]:
                card = self.card(item.get("name", item.get("id", "")), item.get("summary", ""), self.state_badges_for(item), item)
                card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
                self.content.pack_start(card, False, False, 0)
        self.section("Collections")
        for key, item in self.payload.get("profile_collections", {}).items():
            badges = ["PROFILE", item.get("accent", "seven").upper()]
            count = self.profile_app_count(key)
            if count:
                badges.append(f"{count} APPS")
            card = self.card(item["title"], item["description"], badges, {"key": key, "source": "profile"})
            card.connect("button-press-event", lambda _widget, _event, profile=key: self.render_profile_detail(profile))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_profile_detail(self, profile: str) -> None:
        item = self.payload.get("profile_collections", {}).get(profile, {})
        self.render_detail({
            "name": item.get("title", profile),
            "key": profile,
            "summary": item.get("description", ""),
            "source": "profile",
            "badges": ["PROFILE", item.get("accent", "seven").upper()],
            "install_command": f"seven profile install {profile}",
            "open_command": f"seven profile center {profile}",
        })

    def render_modules(self) -> None:
        self.set_view("modules")
        self.clear()
        self.section("Installed profile bundles")
        for item in self.payload.get("modules", []):
            desc = f"{item.get('installed', 0)}/{item.get('total', 0)} packages · {item.get('description', '')}"
            card = self.card(item.get("title", item.get("key", "")), desc, item.get("badges", []), item)
            card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_installed(self) -> None:
        self.set_view("installed")
        self.clear()
        self.section("Library")
        apps = sorted(self.payload.get("installed_library", []), key=lambda item: (str(item.get("source", "")), str(item.get("name", "")).lower()))
        self.content.pack_start(self.library_stats(apps), False, False, 0)
        if not apps:
            self.content.pack_start(self.card("No installed desktop app found", "SevenStore did not find desktop launchers yet. Try refreshing Launchpad after installing apps.", ["EMPTY"]), False, False, 0)
        grouped: dict[str, list[dict]] = {}
        for item in apps[:120]:
            grouped.setdefault(str(item.get("source") or "other"), []).append(item)
        for source in ("flatpak", "desktop", "pacman", "aur", "other"):
            rows = grouped.get(source, [])
            if not rows:
                continue
            self.section(self.app_group_title(source))
            for item in rows:
                card = self.card(item.get("name", item.get("key", "")), item.get("summary", ""), self.state_badges_for(item), item)
                card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
                self.content.pack_start(card, False, False, 0)
        self.content.show_all()

