            "shield": [(self.tx("Authorized audit", "Audit autorisé"), self.tx("Security tools with clear boundaries.", "Outils sécurité avec limites claires."), "wireshark nmap forensic", "security-high")],
            "studio": [(self.tx("Creator desk", "Atelier création"), self.tx("Design, video, audio and capture apps.", "Design, vidéo, audio et capture."), "design video audio obs", "applications-graphics")],
            "atlas": [(self.tx("Explore clearly", "Explorer clairement"), self.tx("Documents, maps, OCR and references.", "Documents, cartes, OCR et références."), "documents maps ocr reference", "folder-documents")],
            "pulse": [(self.tx("Play smooth", "Jouer fluide"), self.tx("Launchers, overlays and performance helpers.", "Launchers, overlays et performance."), "steam lutris gamescope", "applications-games")],
            "baobab": [(self.tx("Culture library", "Bibliothèque culture"), self.tx("Reading, language and memory tools.", "Lecture, langues et mémoire."), "reader books language", "accessories-dictionary")],
        }
        common = [
            (self.tx("Essentials", "Essentiels"), self.tx("A calm first setup for daily use.", "Une base calme pour l’usage quotidien."), "browser office media", "starred"),
            (self.tx("Sandboxed apps", "Apps sandboxées"), self.tx("Flatpak-first graphical applications.", "Applications graphiques en priorité Flatpak."), "flatpak graphical", "system-software-install"),
