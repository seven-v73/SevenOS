#!/usr/bin/env python3
"""SevenStore AppCenter surface."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import subprocess
import sys
import threading
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()
    here = Path(__file__).resolve()
    if (here.parent.parent / "install.sh").is_file():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "install.sh").is_file():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr_text  # noqa: E402
import seven_theme  # noqa: E402

CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
PROFILE_UI_FILE = CONFIG_DIR / "profile-ui.json"


def read_profile_ui() -> dict:
    try:
        data = json.loads(PROFILE_UI_FILE.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def ensure_gtk_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        probe = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if probe.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    available, error = gtk_available()
    if available:
        print("OK")
        return 0
    print(f"MISS: {error}", file=sys.stderr)
    return 1


def gtk_available() -> tuple[bool, str]:
    ensure_gtk_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        return False, str(exc)
    return True, ""


def run_json(command: list[str], fallback):
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            text=True,
            capture_output=True,
            check=False,
            timeout=18,
        )
        if result.returncode != 0:
            return fallback
        return json.loads(result.stdout)
    except Exception:
        return fallback


def run_text(command: list[str]) -> str:
    result = subprocess.run(
        command,
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        text=True,
        capture_output=True,
        check=False,
        timeout=18,
    )
    return result.stdout.strip() or result.stderr.strip()


def open_visible(command: str) -> None:
    wrapped = f"cd {shlex.quote(str(ROOT))} && {command}; printf '\\nPress Enter to close...'; read -r"
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    for candidate in (
        ["seven-terminal", "focus", "--", "bash", "-lc", wrapped],
        ["kitty", "--title", "SevenStore", "bash", "-lc", wrapped],
        ["foot", "-e", "bash", "-lc", wrapped],
    ):
        if subprocess.run(["bash", "-lc", f"command -v {shlex.quote(candidate[0])} >/dev/null 2>&1"], check=False).returncode == 0:
            subprocess.Popen(candidate, cwd=ROOT, env=env)
            return
    subprocess.Popen(["bash", "-lc", wrapped], cwd=ROOT, env=env)


def open_hidden(command: str) -> None:
    subprocess.Popen(["bash", "-lc", command], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def shell_quote(command: list[str]) -> str:
    return " ".join(shlex.quote(str(part)) for part in command if str(part))


ensure_gtk_python()

import gi  # noqa: E402

gi.require_version("Gdk", "3.0")
gi.require_version("Gtk", "3.0")
from gi.repository import Gdk, GLib, Gtk  # noqa: E402


CSS = seven_theme.surface_css("store")


class SevenStore(Gtk.Application):
    def __init__(self) -> None:
        super().__init__(application_id="os.seven.SevenStore")
        self.window: Gtk.ApplicationWindow | None = None
        self.payload: dict = {}
        self.results: list[dict] = []
        self.content = Gtk.Box()
        self.detail_box = Gtk.Box()
        self.search_entry = Gtk.SearchEntry()
        self.search_timeout_id = 0
        self.advanced_mode = False

    def do_activate(self) -> None:
        if self.window:
            self.window.present()
            return

        provider = Gtk.CssProvider()
        css = seven_theme.gtk_app_css("store") + CSS
        provider.load_from_data(css.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.payload = run_json([str(ROOT / "scripts/store.sh"), "json"], {"summary": {}, "modules": [], "apps": [], "profile_collections": {}})

        self.window = Gtk.ApplicationWindow(application=self)
        self.window.set_name("seven-store")
        self.window.get_style_context().add_class("seven-store")
        self.window.set_title("SevenStore")
        self.window.set_default_size(1180, 740)
        self.window.set_wmclass("SevenStoreNative", "SevenStoreNative")

        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        root.get_style_context().add_class("root")
        self.window.add(root)

        root.pack_start(self.sidebar(), False, False, 0)

        main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        main.set_margin_top(18)
        main.set_margin_bottom(18)
        main.set_margin_start(18)
        main.set_margin_end(18)
        root.pack_start(main, True, True, 0)

        main.pack_start(self.topbar(), False, False, 0)

        body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
        main.pack_start(body, True, True, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        self.content.set_margin_bottom(8)
        scroller.add(self.content)
        body.pack_start(scroller, True, True, 0)

        self.detail_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.detail_box.set_size_request(320, -1)
        self.detail_box.get_style_context().add_class("detail")
        body.pack_start(self.detail_box, False, False, 0)

        self.render_home()
        self.render_detail(None)
        self.window.show_all()

    def sidebar(self) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_size_request(190, -1)
        box.get_style_context().add_class("sidebar")
        for icon, label, action in (
            ("go-home-symbolic", tr_text("Home"), self.render_home),
            ("preferences-system-symbolic", tr_text("Profiles"), self.render_profiles),
            ("emblem-default-symbolic", tr_text("Installed"), self.render_installed),
            ("software-update-available-symbolic", tr_text("Updates"), self.render_updates),
            ("view-grid-symbolic", tr_text("Categories"), self.render_categories),
            ("security-high-symbolic", tr_text("Permissions"), self.render_permissions),
            ("computer-symbolic", tr_text("VM Apps"), self.render_vm),
            ("starred-symbolic", tr_text("AI Picks"), self.render_ai),
        ):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.set_halign(Gtk.Align.FILL)
            image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
            image.set_pixel_size(16)
            row.pack_start(image, False, False, 0)
            button_label = Gtk.Label(label=label)
            button_label.set_xalign(0)
            button_label.set_halign(Gtk.Align.FILL)
            button_label.get_style_context().add_class("sidebar-label")
            row.pack_start(button_label, True, True, 0)
            button = Gtk.Button()
            button.add(row)
            button.connect("clicked", lambda _button, callback=action: callback())
            box.pack_start(button, False, False, 0)
        box.pack_end(Gtk.Label(label=tr_text("SevenOS AppCenter")), False, False, 0)
        return box

    def topbar(self) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("topbar")
        title = Gtk.Label(label="SevenStore")
        title.get_style_context().add_class("title")
        box.pack_start(title, False, False, 0)
        self.search_entry.get_style_context().add_class("search")
        self.search_entry.set_placeholder_text(tr_text("Search apps, tools, games..."))
        self.search_entry.connect("activate", self.on_search)
        self.search_entry.connect("search-changed", self.on_search_changed)
        box.pack_start(self.search_entry, True, True, 0)
        profile = Gtk.Label(label=self.active_profile_label())
        profile.get_style_context().add_class("badge")
        box.pack_start(profile, False, False, 0)
        mode = Gtk.CheckButton(label=tr_text("Advanced"))
        mode.get_style_context().add_class("mode-toggle")
        mode.set_active(self.advanced_mode)
        mode.connect("toggled", self.on_mode_toggled)
        box.pack_start(mode, False, False, 0)
        return box

    def active_profile_label(self) -> str:
        profile = self.active_profile_key()
        if not profile:
            return "EQX"
        profiles = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
        for item in profiles if isinstance(profiles, list) else []:
            if item.get("key") == profile:
                return str(item.get("short_label") or item.get("key") or "EQX").upper()
        return "EQX"

    def active_profile_key(self) -> str:
        profiles = run_json([str(ROOT / "bin/seven"), "profile", "status", "--json"], [])
        for item in profiles if isinstance(profiles, list) else []:
            if item.get("active"):
                return str(item.get("key") or "equinox")
        return "equinox"

    def clear(self, box: Gtk.Box | None = None) -> None:
        target = box or self.content
        for child in list(target.get_children()):
            target.remove(child)

    def label(self, text: str, css: str | None = None, xalign: float = 0) -> Gtk.Label:
        label = Gtk.Label(label=text)
        label.set_xalign(xalign)
        label.set_line_wrap(True)
        if css:
            label.get_style_context().add_class(css)
        return label

    def icon_name_for(self, item: dict | None, fallback: str = "system-software-install") -> str:
        if not item:
            return fallback
        explicit = str(item.get("icon") or "").strip()
        if explicit:
            return explicit
        raw = str(item.get("id") or item.get("key") or item.get("name") or item.get("title") or "").lower()
        source = str(item.get("source") or "").lower()
        aliases = {
            "vlc": "vlc",
            "firefox": "firefox",
            "chromium": "chromium",
            "discord": "discord",
            "telegram": "telegram",
            "steam": "steam",
            "lutris": "lutris",
            "blender": "blender",
            "gimp": "gimp",
            "krita": "krita",
            "inkscape": "inkscape",
            "obs-studio": "com.obsproject.Studio",
            "kdenlive": "kdenlive",
            "code": "visual-studio-code",
            "vscode": "visual-studio-code",
            "libreoffice": "libreoffice-startcenter",
            "thunderbird": "thunderbird",
            "spotify": "spotify",
            "wireshark": "wireshark",
            "wireshark-qt": "wireshark",
            "equinox": "preferences-system",
            "forge": "applications-development",
            "shield": "security-high",
            "studio": "applications-graphics",
            "windows": "computer",
            "pulse": "applications-games",
            "baobab": "accessories-dictionary",
        }
        candidates = [raw, raw.removesuffix("-bin"), raw.removesuffix("-git")]
        for candidate in candidates:
            if candidate in aliases:
                return aliases[candidate]
        if source == "flatpak" and raw:
            return raw
        if source == "aur":
            return "applications-development"
        if source == "profile":
            return "preferences-system"
        return fallback

    def icon_frame(self, icon_name: str, size: int = 42) -> Gtk.Box:
        frame = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        frame.set_halign(Gtk.Align.CENTER)
        frame.set_valign(Gtk.Align.CENTER)
        frame.get_style_context().add_class("app-icon-frame")
        image = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        image.set_pixel_size(size)
        image.set_halign(Gtk.Align.CENTER)
        image.set_valign(Gtk.Align.CENTER)
        frame.pack_start(image, True, True, 0)
        return frame

    def command_button(self, label: str, command: str, primary: bool = False, visible_terminal: bool = False) -> Gtk.Button:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("primary" if primary else "ghost")
        if visible_terminal:
            button.connect("clicked", lambda _button, cmd=command: open_visible(cmd))
        else:
            button.connect("clicked", lambda _button, cmd=command: subprocess.Popen(["bash", "-lc", cmd], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}))
        return button

    def on_mode_toggled(self, button: Gtk.CheckButton) -> None:
        self.advanced_mode = button.get_active()
        query = self.search_entry.get_text().strip()
        if query:
            self.on_search(self.search_entry)
        else:
            self.render_home()

    def render_home(self) -> None:
        self.clear()
        profile_ui = read_profile_ui()
        home = profile_ui.get("home_screen") if isinstance(profile_ui.get("home_screen"), dict) else {}
        profile_title = profile_ui.get("title") or self.active_profile_label()
        store_collection = home.get("store_collection") or "Profile Apps"
        hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
        hero.get_style_context().add_class("hero")
        hero_icon = self.icon_frame("system-software-install", 48)
        hero_icon.get_style_context().add_class("hero-icon")
        hero.pack_start(hero_icon, False, False, 0)
        hero_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        hero_text.pack_start(self.label(f"The SevenOS AppCenter · {profile_title}", "title"), False, False, 0)
        hero_text.pack_start(self.label(f"{store_collection}: install apps with clear icons, trusted sources and profile-aware recommendations. New apps appear in Launchpad and Spotlight after install.", "muted"), False, False, 0)
        hero.pack_start(hero_text, True, True, 0)
        self.content.pack_start(hero, False, False, 0)
        if home:
            self.section("Active mini OS")
            active = self.card(str(home.get("title", profile_title)), str(home.get("focus", "")), ["ACTIVE", f"AUTONOMY {home.get('autonomy_score', 0)}%"], {"source": "profile", "key": profile_ui.get("profile", "equinox")})
            active.connect("button-press-event", lambda *_: open_hidden(str(profile_ui.get("center_command") or "seven-profile-center-native")))
            self.content.pack_start(active, False, False, 0)
        self.section("Featured profile collections")
        grid = Gtk.FlowBox()
        grid.set_selection_mode(Gtk.SelectionMode.NONE)
        grid.set_min_children_per_line(2)
        grid.set_max_children_per_line(3)
        for key, item in self.payload.get("profile_collections", {}).items():
            card = self.card(item["title"], item["description"], ["PROFILE", item.get("accent", "seven").upper()], {"key": key, "source": "profile"})
            card.connect("button-press-event", lambda _widget, _event, profile=key: self.render_profile_detail(profile))
            grid.add(card)
        self.content.pack_start(grid, False, False, 0)
        self.section("Collections")
        collections = Gtk.FlowBox()
        collections.set_selection_mode(Gtk.SelectionMode.NONE)
        collections.set_min_children_per_line(2)
        collections.set_max_children_per_line(3)
        for title, desc, icon in (
            ("Start with SevenOS", "Essential apps for a clean first setup.", "starred"),
            ("Creator Studio", "Design, video, image and capture workflows.", "applications-graphics"),
            ("Pulse Gaming", "Launchers, overlays and low-latency tools.", "applications-games"),
            ("Cyber Authorized", "Security tools with clear advanced-user boundaries.", "security-high"),
            ("African Learning", "Reading, language and cultural knowledge tools.", "accessories-dictionary"),
            ("Developer Web", "Editors, terminals, SDKs and containers.", "applications-development"),
        ):
            collections.add(self.card(title, desc, ["COLLECTION"], {"icon": icon, "source": "collection"}))
        self.content.pack_start(collections, False, False, 0)
        self.section("Trust model")
        self.content.pack_start(self.card("Install with confidence", "SevenOS separates system components, sandboxed apps and community sources before anything changes.", ["TRUSTED", "SANDBOXED", "COMMUNITY"]), False, False, 0)
        self.content.show_all()

    def section(self, text: str) -> None:
        self.content.pack_start(self.label(text, "section-title"), False, False, 0)

    def public_source_label(self, source: str, installed: bool = False) -> str:
        labels = {
            "pacman": "SEVENOS SYSTEM",
            "aur": "COMMUNITY SOURCE",
            "flatpak": "SANDBOXED APP",
            "vm": "WINDOWS BRIDGE",
            "profile": "MINI OS",
            "collection": "COLLECTION",
            "category": "CATEGORY",
        }
        label = labels.get(str(source).lower(), str(source or "SevenOS").upper())
        if installed:
            label = f"{label} · INSTALLED"
        return label

    def public_badge_label(self, badge: str) -> str:
        labels = {
            "PACMAN": "SYSTEM",
            "AUR": "COMMUNITY",
            "FLATPAK": "SANDBOXED",
            "LINUX": "NATIVE",
        }
        return labels.get(str(badge).upper(), str(badge))

    def card(self, title: str, description: str, badges: list[str] | None = None, item: dict | None = None, action_label: str | None = None) -> Gtk.EventBox:
        event = Gtk.EventBox()
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("card")
        event.add(box)
        box.pack_start(self.icon_frame(self.icon_name_for(item)), False, False, 0)
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        text_box.pack_start(self.label(title, "store-row-title"), False, False, 0)
        if item and item.get("source"):
            source_text = self.public_source_label(str(item.get("source", "")), bool(item.get("installed")))
            text_box.pack_start(self.label(source_text, "store-source"), False, False, 0)
        text_box.pack_start(self.label(description or "No description available.", "muted"), False, False, 0)
        badge_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        for badge in badges or []:
            pill = self.label(self.public_badge_label(str(badge)), "badge")
            badge_row.pack_start(pill, False, False, 0)
        text_box.pack_start(badge_row, False, False, 0)
        if action_label:
            button = Gtk.Button(label=action_label)
            button.get_style_context().add_class("primary")
            text_box.pack_start(button, False, False, 0)
        box.pack_start(text_box, True, True, 0)
        return event

    def render_profiles(self) -> None:
        self.clear()
        self.section("Profile collections")
        for key, item in self.payload.get("profile_collections", {}).items():
            card = self.card(item["title"], item["description"], ["PROFILE", item.get("accent", "seven").upper()], {"key": key, "source": "profile"})
            card.connect("button-press-event", lambda _widget, _event, profile=key: self.render_profile_detail(profile))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_profile_detail(self, profile: str) -> None:
        item = self.payload.get("profile_collections", {}).get(profile, {})
        self.render_detail({
            "name": item.get("title", profile),
            "key": profile,
            "summary": item.get("description", ""),
            "source": "profile",
            "badges": ["PROFILE", item.get("accent", "seven").upper()],
            "install_command": f"seven profile install {profile}",
            "open_command": f"seven profile center {profile}",
        })

    def render_modules(self) -> None:
        self.clear()
        self.section("Installed profile bundles")
        for item in self.payload.get("modules", []):
            desc = f"{item.get('installed', 0)}/{item.get('total', 0)} packages · {item.get('description', '')}"
            card = self.card(item.get("title", item.get("key", "")), desc, item.get("badges", []), item)
            card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_installed(self) -> None:
        self.clear()
        self.section("Installed applications")
        apps = self.payload.get("installed_library", [])
        if not apps:
            self.content.pack_start(self.card("No installed desktop app found", "SevenStore did not find desktop launchers yet. Try refreshing Launchpad after installing apps.", ["EMPTY"]), False, False, 0)
        for item in apps[:80]:
            card = self.card(item.get("name", item.get("key", "")), item.get("summary", ""), item.get("badges", []), item)
            card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_categories(self) -> None:
        self.clear()
        self.section("Categories")
        for title, query, desc, icon in (
            ("Video & Media", "video player editor", "Players, editors and streaming tools.", "applications-multimedia"),
            ("Design", "design graphics photo", "Image, vector, typography and creative apps.", "applications-graphics"),
            ("Developer", "code editor terminal docker", "Code, SDKs, containers and local servers.", "applications-development"),
            ("Gaming", "steam lutris gamescope", "Game launchers and performance helpers.", "applications-games"),
            ("Security", "wireshark nmap forensic", "Authorized audit and network tools.", "security-high"),
            ("Learning", "reader books language", "Reading, office and learning surfaces.", "accessories-dictionary"),
        ):
            card = self.card(title, desc, ["CATEGORY"], {"icon": icon, "source": "category"})
            card.connect("button-press-event", lambda _w, _e, q=query: (self.search_entry.set_text(q), self.on_search(self.search_entry)))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()

    def render_updates(self) -> None:
        self.clear()
        self.section("Updates")
        self.content.pack_start(self.card("System update plan", "SevenStore will surface SevenOS system, app-source and profile bundle updates here. For now, use Seven Doctor or sevenpkg status.", ["PLANNED", "SAFE"]), False, False, 0)
        self.content.show_all()

    def render_permissions(self) -> None:
        self.clear()
        self.section("Permissions")
        self.content.pack_start(self.card("Seven Permissions Manager", "Future sandbox overrides, microphone/camera/file access and app permissions will live here.", ["SANDBOXED", "PERMISSIONS"]), False, False, 0)
        self.content.show_all()

    def render_vm(self) -> None:
        self.clear()
        self.section("Windows Bridge Apps")
        self.content.pack_start(self.card("VM-first compatibility", "Installers and Windows apps should be routed through SevenOS Windows Bridge instead of being mixed with Linux packages.", ["VM", "WINDOWS"]), False, False, 0)
        self.content.show_all()

    def render_ai(self) -> None:
        self.clear()
        self.section("AI Picks")
        self.content.pack_start(self.card("Profile-aware recommendations", "SevenAI will recommend apps by context, active profile and workflow. The contract is ready; the recommender can plug into this surface next.", ["AI OPTIMIZED"]), False, False, 0)
        self.content.show_all()

    def on_search(self, _entry: Gtk.SearchEntry) -> None:
        query = self.search_entry.get_text().strip()
        if not query:
            self.render_home()
            return
        self.clear()
        self.section(f"Searching for {query}...")
        self.content.show_all()
        threading.Thread(target=self.search_worker, args=(query,), daemon=True).start()

    def on_search_changed(self, _entry: Gtk.SearchEntry) -> None:
        if self.search_timeout_id:
            GLib.source_remove(self.search_timeout_id)
        self.search_timeout_id = GLib.timeout_add(320, self.run_debounced_search)

    def run_debounced_search(self) -> bool:
        self.search_timeout_id = 0
        query = self.search_entry.get_text().strip()
        if not query:
            self.render_home()
        elif len(query) >= 2:
            self.on_search(self.search_entry)
        return False

    def search_worker(self, query: str) -> None:
        payload = run_json([str(ROOT / "scripts/store.sh"), "search", query, "--json"], {"results": []})
        GLib.idle_add(self.render_search_results, query, payload)

    def render_search_results(self, query: str, payload: dict) -> bool:
        self.clear()
        self.section(f"Results for {query}")
        results = payload.get("results", [])
        if not self.advanced_mode:
            results = [item for item in results if item.get("beginner_visible", True)]
        if not results:
            self.content.pack_start(self.card("No beginner-safe result", "Try another app name or enable Advanced mode to see command-line tools, libraries and community sources.", ["EMPTY"]), False, False, 0)
        for item in results:
            summary = item.get("summary") or item.get("version") or item.get("source", "")
            card = self.card(item.get("name", item.get("id", "")), summary, item.get("badges", []), item)
            card.connect("button-press-event", lambda _widget, _event, row=item: self.render_detail(row))
            self.content.pack_start(card, False, False, 0)
        self.content.show_all()
        return False

    def render_detail(self, item: dict | None) -> None:
        self.clear(self.detail_box)
        if not item:
            self.detail_box.pack_start(self.label("Select an app", "section-title"), False, False, 0)
            self.detail_box.pack_start(self.label("Search or open a collection to inspect source, trust and installation plan.", "muted"), False, False, 0)
            self.detail_box.show_all()
            return
        name = item.get("name") or item.get("title") or item.get("key") or item.get("id") or "App"
        detail_hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        detail_hero.get_style_context().add_class("detail-hero")
        detail_hero.pack_start(self.icon_frame(self.icon_name_for(item), 46), False, False, 0)
        detail_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        detail_text.pack_start(self.label(str(name), "title"), False, False, 0)
        detail_text.pack_start(self.label(str(item.get("summary") or item.get("description") or "SevenStore item."), "muted"), False, False, 0)
        if item.get("installed"):
            detail_text.pack_start(self.label("Installed and ready", "success"), False, False, 0)
        detail_hero.pack_start(detail_text, True, True, 0)
        self.detail_box.pack_start(detail_hero, False, False, 0)
        badges = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        for badge in item.get("badges", []):
            badges.pack_start(self.label(self.public_badge_label(str(badge)), "badge"), False, False, 0)
        self.detail_box.pack_start(badges, False, False, 0)
        source = item.get("source") or item.get("category") or "SevenOS"
        self.detail_box.pack_start(self.label(f"Source: {self.public_source_label(str(source))}", "muted"), False, False, 0)
        quality = item.get("quality_score")
        if quality:
            self.detail_box.pack_start(self.label(f"Quality score: {quality}/100 · {item.get('quality_label', 'Ready')}", "quality"), False, False, 0)
        explanation = item.get("explanation")
        if explanation:
            self.detail_box.pack_start(self.label(str(explanation), "muted"), False, False, 0)
        preview = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        preview.get_style_context().add_class("preview-panel")
        preview.pack_start(self.icon_frame(self.icon_name_for(item), 52), False, False, 0)
        preview.pack_start(self.label("Preview card", "store-source", 0.5), False, False, 0)
        self.detail_box.pack_start(preview, False, False, 0)
        command = item.get("install_command") or item.get("command") or ""
        install_command = self.install_command_for(item)
        open_command = self.open_command_for(item)
        if item.get("installed") and open_command and item.get("kind") == "graphical":
            self.detail_box.pack_start(self.command_button(tr_text("Open"), open_command, primary=True), False, False, 0)
            self.detail_box.pack_start(self.label(tr_text("Already installed. Launch it directly from here, Launchpad or Spotlight."), "muted"), False, False, 0)
        elif item.get("installed"):
            self.detail_box.pack_start(self.label(tr_text("Installed technical component. It does not expose a normal graphical launcher."), "muted"), False, False, 0)
        elif command:
            self.detail_box.pack_start(self.label(tr_text("Install plan"), "section-title"), False, False, 0)
            self.detail_box.pack_start(self.label(install_command or command, "muted"), False, False, 0)
            plan_button = Gtk.Button(label=tr_text("Preview plan"))
            plan_button.get_style_context().add_class("primary")
            plan_button.connect("clicked", lambda _button, cmd=install_command or command: open_visible(f"{cmd} --dry-run" if " install-app " in cmd else cmd))
            self.detail_box.pack_start(plan_button, False, False, 0)
        if install_command and not item.get("installed"):
            install_button = Gtk.Button(label=tr_text("Install on system"))
            install_button.get_style_context().add_class("primary")
            install_button.connect("clicked", lambda _button, cmd=install_command: open_visible(cmd))
            self.detail_box.pack_start(install_button, False, False, 0)

            profile = self.active_profile_key()
            if item.get("source") in {"pacman", "aur", "flatpak", "vm"}:
                profile_command = f"{install_command} --profile {shlex.quote(profile)}"
                profile_button = Gtk.Button(label=tr_text("Install for {profile}", profile=profile.title()))
                profile_button.connect("clicked", lambda _button, cmd=profile_command: open_visible(cmd))
                self.detail_box.pack_start(profile_button, False, False, 0)
        if item.get("source") in {"pacman", "aur", "flatpak"} and item.get("id"):
            actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            profile = self.active_profile_key()
            actions.pack_start(self.command_button(tr_text("Add to profile"), shell_quote(["seven", "store", "add-profile", profile, item.get("source"), item.get("id")]), visible_terminal=True), True, True, 0)
            actions.pack_start(self.command_button(tr_text("Repair"), shell_quote(["seven", "store", "repair-app", item.get("source"), item.get("id")]), visible_terminal=True), True, True, 0)
            if item.get("installed"):
                actions.pack_start(self.command_button(tr_text("Remove"), shell_quote(["seven", "store", "remove-app", item.get("source"), item.get("id")]), visible_terminal=True), True, True, 0)
            self.detail_box.pack_start(actions, False, False, 0)
        profile_open_command = item.get("open_command") if item.get("source") == "profile" else ""
        if profile_open_command:
            self.detail_box.pack_start(self.command_button(tr_text("Open profile center"), profile_open_command, visible_terminal=True), False, False, 0)
        recs = item.get("recommendations") or []
        if recs:
            self.detail_box.pack_start(self.label(tr_text("Related apps"), "section-title"), False, False, 0)
            self.detail_box.pack_start(self.label(", ".join(recs), "muted"), False, False, 0)
        self.detail_box.show_all()

    def install_command_for(self, item: dict) -> str:
        source = item.get("source")
        app_id = item.get("id") or item.get("key") or item.get("name")
        if source in {"pacman", "aur", "flatpak", "vm"} and app_id:
            return shell_quote(["seven", "store", "install-app", source, app_id])
        if source == "profile" and app_id:
            return shell_quote(["seven", "profile", "install", app_id])
        if item.get("key") and item.get("command", "").startswith("sevenpkg install"):
            return shell_quote(["seven", "store", "install", item["key"]])
        return ""

    def open_command_for(self, item: dict) -> str:
        source = item.get("source")
        app_id = item.get("id") or item.get("key") or item.get("name")
        if source in {"pacman", "aur", "flatpak"} and app_id:
            return shell_quote(["seven", "store", "open-app", source, app_id])
        return str(item.get("open_command") or "")


def main() -> int:
    parser = argparse.ArgumentParser(description="SevenStore AppCenter")
    parser.add_argument("action", nargs="?", default="open", choices=("open", "status"))
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    if args.probe:
        return probe()
    if args.json:
        payload = run_json([str(ROOT / "scripts/store.sh"), "json"], {"schema": "sevenos.store.v1", "state": "MISS"})
        available, error = gtk_available()
        print(json.dumps({"schema": "sevenos.store-native.v1", "native": available, "error": error, "store": payload}, indent=2))
        return 0
    if args.action == "status":
        print("SevenStore")
        print("==========")
        print("Status: OK" if probe() == 0 else "Status: MISS")
        return 0
    app = SevenStore()
    return app.run([])


if __name__ == "__main__":
    raise SystemExit(main())
