#!/usr/bin/env python3
import os
import json
import shutil
import subprocess
import sys
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "bin/seven").is_file():
        return Path(env_root).resolve()

    script_dir = Path(__file__).resolve().parent
    if Path(script_dir, "seven").is_file():
        return script_dir.parent

    for candidate in (Path("/opt/SevenOS"), Path.home() / "SevenOS", Path.home() / "Code/OS/SevenOS"):
        if Path(candidate, "bin/seven").is_file():
            return candidate

    return Path.cwd()


ROOT = resolve_root()


def dry_run() -> bool:
    return os.environ.get("SEVENOS_DRY_RUN") == "1"


def dry_line(surface: str, action: str) -> None:
    print(f"DRY-RUN > Shell Panel > {surface} > {action}")


def gtk_available() -> tuple[bool, str]:
    if dry_run():
        return True, "dry-run"

    try:
        import gi  # noqa: F401

        gi.require_version("Gtk", "4.0")
        gi.require_version("Adw", "1")
        from gi.repository import Adw, Gtk  # noqa: F401
    except Exception as error:
        return False, str(error)

    return True, "native-ready"


def run_action(*command: str) -> None:
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    command = tuple(resolve_command(command))

    if dry_run():
        dry_line("Action", " ".join(command))
        return

    subprocess.Popen(command, cwd=ROOT, env=env)


def resolve_command(command: tuple[str, ...]) -> list[str]:
    if not command:
        return []
    first = command[0]
    local = ROOT / "bin" / first
    if local.is_file():
        return [str(local), *command[1:]]
    if first == "seven" and (ROOT / "bin" / "seven").is_file():
        return [str(ROOT / "bin" / "seven"), *command[1:]]
    return list(command)


def active_profile() -> dict[str, str]:
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    profile_file = config_home / "sevenos" / "profile.json"
    if profile_file.is_file():
        try:
            payload = json.loads(profile_file.read_text(encoding="utf-8"))
            return {
                "key": str(payload.get("key") or "baobab"),
                "title": str(payload.get("title") or "Baobab"),
                "workspace": str(payload.get("workspace") or str(Path.home() / "SevenOS")),
            }
        except Exception:
            pass
    return {"key": "baobab", "title": "Baobab", "workspace": str(Path.home() / "SevenOS")}


QUICK_ACTIONS = [
    ("󰒓", "Control Center", "Dashboard and system state", ["seven", "hub"]),
    ("󰀻", "Apps", "Open application overview", ["seven-overview", "apps"]),
    ("󰖲", "Windows", "Switch open windows", ["seven-overview", "windows"]),
    ("󰤨", "Network", "Wi-Fi and connections", ["seven-waybar-action", "network"]),
    ("󰕾", "Audio", "Mixer and PipeWire controls", ["seven-waybar-action", "audio"]),
    ("󰉋", "Files", "Open profile workspace", ["seven-files", "profile"]),
    ("󰍛", "Monitor", "CPU, memory and processes", ["seven-waybar-action", "system"]),
    ("󰐥", "Power", "Lock, reboot and shutdown", ["seven-power"]),
]

PROFILE_ACTIONS = {
    "baobab": [
        ("󰒓", "Welcome", "Open SevenOS first-run guide", ["seven-welcome"]),
        ("󰉋", "Workspace", "Open your SevenOS home workspace", ["seven", "profile", "open", "baobab"]),
    ],
    "forge": [
        ("󰅩", "Forge", "Open development workspace", ["seven", "profile", "open", "forge"]),
        ("󰡨", "Containers", "Inspect Docker and Podman tooling", ["seven", "deploy", "detect", "."]),
