def main() -> int:
    saved_profile = str(load_state().get("profile", "studio"))
    profile = sys.argv[1] if len(sys.argv) > 1 and not sys.argv[1].startswith("--") else saved_profile
    if "--probe" in sys.argv:
        print("OK")
        return 0
    return build_ui(profile)


if __name__ == "__main__":
    raise SystemExit(main())
