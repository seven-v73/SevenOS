#!/usr/bin/env python3
"""Native SevenOS guided pack chooser."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import language_code  # noqa: E402
import seven_theme  # noqa: E402

LANG_CODE = language_code()
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
STATE_FILE = CONFIG_DIR / "profile-packs-native.json"


def t(fr: str, en: str) -> str:
    return fr if LANG_CODE == "fr" else en


def load_state() -> dict:
    try:
        data = json.loads(STATE_FILE.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def save_state(**updates) -> None:
    data = load_state()
    data.update(updates)
    try:
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        STATE_FILE.write_text(json.dumps(data, indent=2, sort_keys=True), encoding="utf-8")
    except Exception:
        pass


def profile_title(profile: str) -> str:
    try:
        catalog = json.loads((ROOT / "profiles/catalog.json").read_text(encoding="utf-8"))
        return str((catalog.get("profile_naming") or {}).get(profile, profile.title()))
    except Exception:
        return profile.title()


def profile_names() -> dict[str, str]:
    try:
        catalog = json.loads((ROOT / "profiles/catalog.json").read_text(encoding="utf-8"))
        names = catalog.get("profile_naming") if isinstance(catalog.get("profile_naming"), dict) else {}
        return {str(key): str(value) for key, value in names.items()}
    except Exception:
        return {}


def profile_health(profile: str) -> dict:
    data = run_json("mini-doctor", profile, "--json")
    summary = data.get("summary") if isinstance(data.get("summary"), dict) else {}
    return {
        "ready": bool(data.get("ready")),
        "required": int(summary.get("required", 0) or 0),
        "required_missing": int(summary.get("required_missing", 0) or 0),
        "optional_missing": int(summary.get("optional_missing", 0) or 0),
    }


def run_json(*args: str) -> dict:
    try:
        out = subprocess.check_output([str(ROOT / "bin/seven"), *args], cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
        return json.loads(out)
    except Exception:
        return {}


def run_detached(command: str) -> None:
    subprocess.Popen(["bash", "-lc", command], cwd=ROOT, env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, start_new_session=True)


def terminal_command(profile: str, command: str) -> str:
    safe = command.replace("'", "'\"'\"'")
    return f"seven-terminal {profile} -- bash -lc '{safe}; echo; read -r -p \"{t('Entrée pour fermer...', 'Enter to close...')}\"'"


def copy_command(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", "wl-copy || xclip -selection clipboard || true"],
        stdin=subprocess.PIPE,
        text=True,
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
    ).communicate(command)


def status_text(pack: dict) -> str:
    state = pack.get("state")
    missing = pack.get("missing", []) if isinstance(pack.get("missing"), list) else []
    if state == "ready":
        return t("Prêt", "Ready")
    if state == "action":
        return t("Guidé", "Guided")
    return t(f"{len(missing)} élément(s) à installer", f"{len(missing)} item(s) to install")


def impact_text(value: str) -> str:
    return {
        "small": t("léger", "small"),
        "medium": t("moyen", "medium"),
        "large": t("large", "large"),
        "huge": t("très large", "huge"),
    }.get(value, value)


def pack_sort_key(pack: dict) -> tuple[int, int, str]:
    return (
        0 if pack.get("recommended") and pack.get("state") != "ready" else 1,
        0 if pack.get("state") != "ready" else 1,
        str(pack.get("id", "")),
    )


def pack_matches(pack: dict, query: str, filter_id: str) -> bool:
    if filter_id == "recommended" and not pack.get("recommended"):
        return False
    if filter_id == "missing" and pack.get("state") == "ready":
        return False
    if filter_id == "ready" and pack.get("state") != "ready":
        return False
    query = query.strip().lower()
    if not query:
        return True
    parts = [
        str(pack.get("id", "")),
        str(pack.get("title", "")),
        str(pack.get("description", "")),
        str(pack.get("audience", "")),
        str(pack.get("scope", "")),
        " ".join(str(item) for item in pack.get("packages", []) if isinstance(pack.get("packages"), list)),
        " ".join(str(item) for item in pack.get("missing", []) if isinstance(pack.get("missing"), list)),
    ]
    return query in " ".join(parts).lower()


def command_dialog(Gtk, parent, profile: str, pack: dict, install: bool) -> None:
    pack_id = str(pack.get("id"))
    action = "install --yes" if install else "install --dry-run"
    command = f"seven profile-packs {action} {profile} {pack_id}"
    title = t("Installer ce pack", "Install this pack") if install else t("Aperçu du pack", "Pack preview")
    dialog = Gtk.Dialog(title=title, transient_for=parent, modal=True)
    dialog.set_default_size(560, 360)
    dialog.get_style_context().add_class("command-dialog")
    dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
    dialog.add_button(t("Copier", "Copy"), 10)
    dialog.add_button(t("Ouvrir Terminal", "Open Terminal"), Gtk.ResponseType.OK)

    box = dialog.get_content_area()
    box.set_spacing(12)
    box.set_border_width(16)

    heading = Gtk.Label(label=str(pack.get("title") or pack_id), xalign=0)
    heading.get_style_context().add_class("dialog-title")
    box.pack_start(heading, False, False, 0)

    warning_bits = []
    if str(pack.get("impact")) == "huge":
        warning_bits.append(t("Pack très large: vérifie l'espace disque et les conflits possibles.", "Huge pack: check disk space and possible conflicts."))
    if str(pack.get("scope", "")).startswith("host"):
        warning_bits.append(t("Portée host: ce choix peut toucher l'environnement global.", "Host scope: this can affect the global environment."))
    if not warning_bits:
        warning_bits.append(t("SevenOS ouvrira le terminal pour garder les logs et les demandes de mot de passe visibles.", "SevenOS will open Terminal so logs and password prompts remain visible."))
    warning = Gtk.Label(label="\n".join(warning_bits), xalign=0)
    warning.set_line_wrap(True)
    warning.get_style_context().add_class("dialog-note")
    box.pack_start(warning, False, False, 0)

    command_box = Gtk.Label(label=command, xalign=0)
    command_box.set_selectable(True)
    command_box.set_line_wrap(True)
    command_box.get_style_context().add_class("command-box")
    box.pack_start(command_box, False, False, 0)

    missing = pack.get("missing", []) if isinstance(pack.get("missing"), list) else []
    if missing:
        preview = ", ".join(str(item) for item in missing[:8])
        if len(missing) > 8:
            preview += f" +{len(missing) - 8}"
        missing_label = Gtk.Label(label=t(f"À préparer: {preview}", f"To prepare: {preview}"), xalign=0)
        missing_label.set_line_wrap(True)
        missing_label.get_style_context().add_class("missing")
        box.pack_start(missing_label, False, False, 0)

    dialog.show_all()
    response = dialog.run()
    dialog.destroy()
    if response == 10:
        copy_command(command)
    elif response == Gtk.ResponseType.OK:
        run_detached(terminal_command(profile, command))


def recommended_dialog(Gtk, parent, profile: str, packs: list[dict], install: bool) -> None:
    selected = [pack for pack in packs if pack.get("recommended") and pack.get("state") != "ready"]
    command = f"seven profile-packs install-recommended {profile} {'--yes' if install else '--dry-run'}"
    title = t("Préparer les packs recommandés", "Prepare recommended packs") if install else t("Aperçu des recommandations", "Recommended preview")
    dialog = Gtk.Dialog(title=title, transient_for=parent, modal=True)
    dialog.set_default_size(600, 430)
    dialog.get_style_context().add_class("command-dialog")
    dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
    dialog.add_button(t("Copier", "Copy"), 10)
    dialog.add_button(t("Ouvrir Terminal", "Open Terminal"), Gtk.ResponseType.OK)

    box = dialog.get_content_area()
    box.set_spacing(12)
    box.set_border_width(16)

    heading = Gtk.Label(label=t("Recommandations SevenOS", "SevenOS recommendations"), xalign=0)
    heading.get_style_context().add_class("dialog-title")
    box.pack_start(heading, False, False, 0)

    if not selected:
        note = Gtk.Label(label=t("Tous les packs recommandés sont déjà prêts pour cet espace.", "All recommended packs are already ready for this space."), xalign=0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("dialog-note")
        box.pack_start(note, False, False, 0)
    else:
        warnings = []
        if any(str(pack.get("impact")) == "huge" for pack in selected):
            warnings.append(t("Au moins un pack est très large.", "At least one pack is huge."))
        if any(str(pack.get("scope", "")).startswith("host") for pack in selected):
            warnings.append(t("Au moins un pack touche l'environnement host.", "At least one pack affects the host environment."))
        warnings.append(t("SevenOS ouvrira le terminal pour garder les logs et sudo visibles.", "SevenOS will open Terminal to keep logs and sudo visible."))
        note = Gtk.Label(label="\n".join(warnings), xalign=0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("dialog-note")
        box.pack_start(note, False, False, 0)

        list_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        list_box.get_style_context().add_class("recommendation-list")
        box.pack_start(list_box, False, False, 0)
        for pack in selected:
            missing = pack.get("missing", []) if isinstance(pack.get("missing"), list) else []
            label = str(pack.get("title") or pack.get("id"))
            detail = t(f"{impact_text(str(pack.get('impact', 'medium')))} · {len(missing)} élément(s)", f"{impact_text(str(pack.get('impact', 'medium')))} · {len(missing)} item(s)")
            row = Gtk.Label(label=f"{label}  ·  {detail}", xalign=0)
            row.get_style_context().add_class("recommendation-row")
            list_box.pack_start(row, False, False, 0)

    command_box = Gtk.Label(label=command, xalign=0)
    command_box.set_selectable(True)
    command_box.set_line_wrap(True)
    command_box.get_style_context().add_class("command-box")
    box.pack_start(command_box, False, False, 0)

    dialog.show_all()
    response = dialog.run()
    dialog.destroy()
    if response == 10:
        copy_command(command)
    elif response == Gtk.ResponseType.OK:
        run_detached(terminal_command(profile, command))


def build_ui(profile: str) -> int:
    save_state(profile=profile)
    ensure_gi_python()
    import gi  # noqa: WPS433

    gi.require_version("Gtk", "3.0")
    from gi.repository import Gtk, Gdk  # noqa: WPS433

    data = run_json("profile-packs", "status", profile, "--json")
    packs = list(((data.get("profiles") or {}).get(profile) or []))
    summary = ((data.get("summary") or {}).get(profile) or {})
    health = profile_health(profile)
    packs.sort(key=pack_sort_key)

    provider = Gtk.CssProvider()
    provider.load_from_data((seven_theme.gtk_app_css("profile-packs") + css()).encode("utf-8"))
    Gdk.Screen.get_default()
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
    win = Gtk.Window(title=t("Packs SevenOS", "SevenOS Packs"))
    win.set_default_size(920, 680)
    win.set_position(Gtk.WindowPosition.CENTER)
    win.get_style_context().add_class("packs-window")
    win.get_style_context().add_class("seven-window")
    win.connect("destroy", Gtk.main_quit)
    win.connect("key-press-event", lambda _window, event: (win.destroy(), True)[1] if event.keyval == Gdk.KEY_Escape else False)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
    root.set_border_width(18)
    root.get_style_context().add_class("seven-root")
    win.add(root)

    header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    root.pack_start(header, False, False, 0)

    title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    title_box.set_hexpand(True)
    header.pack_start(title_box, True, True, 0)
    kicker = Gtk.Label(label=f"{profile_title(profile)} · {t('packs guidés', 'guided packs')}", xalign=0)
    kicker.get_style_context().add_class("kicker")
    title = Gtk.Label(label=t("Choisir ce qui complète cet espace", "Choose what completes this space"), xalign=0)
    title.get_style_context().add_class("title")
    ready = int(summary.get("ready", 0) or 0)
    total = int(summary.get("packs", len(packs)) or len(packs))
    recommended_missing = int(summary.get("recommended_missing", 0) or 0)
    subtitle = Gtk.Label(label=t(f"{ready}/{total} prêts · {recommended_missing} recommandé(s) à préparer", f"{ready}/{total} ready · {recommended_missing} recommended to prepare"), xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    title_box.pack_start(kicker, False, False, 0)
    title_box.pack_start(title, False, False, 0)
    title_box.pack_start(subtitle, False, False, 0)

    refresh = Gtk.Button(label=t("Rafraîchir", "Refresh"))
    refresh.get_style_context().add_class("pill")
    refresh.connect("clicked", lambda *_: (win.destroy(), build_ui(profile)))
    header.pack_end(refresh, False, False, 0)

    stats = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_start(stats, False, False, 0)
    base_label = t("Socle prêt", "Base ready") if health["ready"] else t("Socle à préparer", "Base needs setup")
    base_detail = t(f"{health['required'] - health['required_missing']}/{health['required']} essentiels", f"{health['required'] - health['required_missing']}/{health['required']} essentials")
    stat_rows = [
        (base_label, base_detail, "good" if health["ready"] else "warn"),
        (t("Packs prêts", "Packs ready"), f"{ready}/{total}", "good" if ready == total else "neutral"),
        (t("Recommandés", "Recommended"), str(recommended_missing), "warn" if recommended_missing else "good"),
    ]
    for head, detail, state in stat_rows:
        chip = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        chip.set_hexpand(True)
        chip.get_style_context().add_class("stat-chip")
        chip.get_style_context().add_class(f"stat-{state}")
        h = Gtk.Label(label=head, xalign=0)
        h.get_style_context().add_class("stat-head")
        d = Gtk.Label(label=detail, xalign=0)
        d.get_style_context().add_class("stat-detail")
        chip.pack_start(h, False, False, 0)
        chip.pack_start(d, False, False, 0)
        stats.pack_start(chip, True, True, 0)

    switcher = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=7)
    root.pack_start(switcher, False, False, 0)
    names = profile_names()
    for key in ("forge", "shield", "studio", "pulse", "atlas"):
        label = str(names.get(key, key.title())).split()[0]
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("space-pill")
        if key == profile:
            button.get_style_context().add_class("active-space")
        button.connect("clicked", lambda _button, value=key: (win.destroy(), build_ui(value)))
        switcher.pack_start(button, False, False, 0)

    guidance = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    guidance.get_style_context().add_class("guidance")
    root.pack_start(guidance, False, False, 0)
    guidance_rows = [
        (t("Recommandé", "Recommended"), t("utile pour ce mini OS", "useful for this mini OS")),
        (t("Option", "Optional"), t("à installer selon ton usage", "install for your workflow")),
        (t("Host", "Host"), t("peut toucher Equinox/global", "may affect Equinox/global")),
    ]
    for head, detail in guidance_rows:
        item = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        item.set_hexpand(True)
        item.get_style_context().add_class("guidance-item")
        h = Gtk.Label(label=head, xalign=0)
        h.get_style_context().add_class("guidance-head")
        d = Gtk.Label(label=detail, xalign=0)
        d.get_style_context().add_class("guidance-detail")
        item.pack_start(h, False, False, 0)
        item.pack_start(d, False, False, 0)
        guidance.pack_start(item, True, True, 0)

    controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_start(controls, False, False, 0)

    active_filter = {"id": "all"}
    saved_state = load_state()
    saved_filter = str(saved_state.get("filter", "all"))
    if saved_filter not in {"all", "recommended", "missing", "ready"}:
        saved_filter = "all"
    search = Gtk.SearchEntry()
    search.set_placeholder_text(t("Rechercher un pack, outil ou usage", "Search a pack, tool or use"))
    search.get_style_context().add_class("pack-search")
    search.set_tooltip_text(t("Ctrl+F pour chercher", "Ctrl+F to search"))
    search.set_hexpand(True)
    controls.pack_start(search, True, True, 0)

    def on_shortcut(_window, event) -> bool:
        state = event.state & Gtk.accelerator_get_default_mod_mask()
        if state == Gdk.ModifierType.CONTROL_MASK and event.keyval in {Gdk.KEY_f, Gdk.KEY_F}:
            search.grab_focus()
            return True
        if state == Gdk.ModifierType.CONTROL_MASK and event.keyval in {Gdk.KEY_r, Gdk.KEY_R}:
            win.destroy()
            build_ui(profile)
            return True
        return False

    win.connect("key-press-event", on_shortcut)

    filters = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
    controls.pack_end(filters, False, False, 0)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    root.pack_start(scroller, True, True, 0)

    grid = Gtk.Grid()
    grid.set_column_spacing(12)
    grid.set_row_spacing(12)
    scroller.add(grid)

    empty = Gtk.Label(label=t("Aucun pack ne correspond à cette recherche. Efface la recherche ou change de filtre.", "No pack matches this search. Clear the search or change filter."))
    empty.get_style_context().add_class("empty-state")
    result_label = Gtk.Label(label="", xalign=0)
    result_label.get_style_context().add_class("result-count")
    root.pack_start(result_label, False, False, 0)

    def render() -> None:
        for child in list(grid.get_children()):
            grid.remove(child)
        query = search.get_text() if hasattr(search, "get_text") else ""
        visible = [pack for pack in packs if pack_matches(pack, query, active_filter["id"])]
        result_label.set_label(t(f"{len(visible)} pack(s) affiché(s)", f"{len(visible)} pack(s) shown"))
        if not visible:
            grid.attach(empty, 0, 0, 2, 1)
        else:
            for index, pack in enumerate(visible):
                grid.attach(pack_card(Gtk, win, profile, pack), index % 2, index // 2, 1, 1)
        grid.show_all()

    def set_filter(filter_id: str) -> None:
        active_filter["id"] = filter_id
        save_state(profile=profile, filter=filter_id)
        for child in filters.get_children():
            child.get_style_context().remove_class("active-filter")
            if getattr(child, "seven_filter_id", "") == filter_id:
                child.get_style_context().add_class("active-filter")
        render()

    filter_rows = [
        ("all", t("Tous", "All")),
        ("recommended", t("Recommandés", "Recommended")),
        ("missing", t("À préparer", "To prepare")),
        ("ready", t("Prêts", "Ready")),
    ]
    for filter_id, label in filter_rows:
        button = Gtk.Button(label=label)
        button.seven_filter_id = filter_id
        button.get_style_context().add_class("filter-pill")
        button.connect("clicked", lambda _button, value=filter_id: set_filter(value))
        filters.pack_start(button, False, False, 0)
    search.connect("search-changed", lambda *_: render())
    set_filter(saved_filter)

    footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_end(footer, False, False, 0)
    preview = Gtk.Button(label=t("Prévisualiser recommandés", "Preview recommended"))
    preview.get_style_context().add_class("pill")
    preview.connect("clicked", lambda *_: recommended_dialog(Gtk, win, profile, packs, False))
    footer.pack_start(preview, True, True, 0)
    if recommended_missing:
        install_rec = Gtk.Button(label=t("Préparer recommandés", "Prepare recommended"))
        install_rec.get_style_context().add_class("pill")
        install_rec.get_style_context().add_class("primary-pill")
        install_rec.connect("clicked", lambda *_: recommended_dialog(Gtk, win, profile, packs, True))
        footer.pack_start(install_rec, True, True, 0)
    close = Gtk.Button(label=t("Fermer", "Close"))
    close.get_style_context().add_class("pill")
    close.connect("clicked", lambda *_: win.destroy())
    footer.pack_end(close, False, False, 0)

    win.show_all()
    Gtk.main()
    return 0


def pack_card(Gtk, parent, profile: str, pack: dict):
    card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
    card.set_hexpand(True)
    card.get_style_context().add_class("pack-card")
    if pack.get("recommended"):
        card.get_style_context().add_class("recommended")
    if pack.get("state") == "ready":
        card.get_style_context().add_class("ready")

    top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    card.pack_start(top, False, False, 0)
    title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
    title_box.set_hexpand(True)
    top.pack_start(title_box, True, True, 0)

    title = Gtk.Label(label=str(pack.get("title") or pack.get("id")), xalign=0)
    title.get_style_context().add_class("pack-title")
    meta = Gtk.Label(label=f"{impact_text(str(pack.get('impact', 'medium')))} · {pack.get('scope', 'profile-rootfs')} · {status_text(pack)}", xalign=0)
    meta.get_style_context().add_class("pack-meta")
    title_box.pack_start(title, False, False, 0)
    title_box.pack_start(meta, False, False, 0)

    badge = Gtk.Label(label=t("Recommandé", "Recommended") if pack.get("recommended") else t("Option", "Optional"))
    badge.get_style_context().add_class("badge")
    top.pack_end(badge, False, False, 0)

    body = Gtk.Label(label=str(pack.get("description") or ""), xalign=0)
    body.set_line_wrap(True)
    body.set_max_width_chars(44)
    body.get_style_context().add_class("pack-body")
    card.pack_start(body, False, False, 0)

    audience = Gtk.Label(label=t(f"Usage: {pack.get('audience') or 'général'}", f"For: {pack.get('audience') or 'general'}"), xalign=0)
    audience.get_style_context().add_class("pack-meta")
    card.pack_start(audience, False, False, 0)

    packages = pack.get("packages", []) if isinstance(pack.get("packages"), list) else []
    detect_scope = str(pack.get("detect_scope") or "profile")
    source_hint = t("profil", "profile") if detect_scope == "profile" else t("host", "host")
    package_count = len(packages) if packages else len(pack.get("detect_packages", []) if isinstance(pack.get("detect_packages"), list) else [])
    detail = Gtk.Label(label=t(f"{package_count} outil(s) · vérification {source_hint}", f"{package_count} tool(s) · {source_hint} check"), xalign=0)
    detail.get_style_context().add_class("pack-detail")
    card.pack_start(detail, False, False, 0)

    missing = pack.get("missing", []) if isinstance(pack.get("missing"), list) else []
    if missing:
        preview = ", ".join(str(item) for item in missing[:5])
        if len(missing) > 5:
            preview += f" +{len(missing) - 5}"
        miss = Gtk.Label(label=t(f"À ajouter: {preview}", f"To add: {preview}"), xalign=0)
        miss.set_line_wrap(True)
        miss.get_style_context().add_class("missing")
        card.pack_start(miss, False, False, 0)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    card.pack_end(actions, False, False, 0)
    preview_button = Gtk.Button(label=t("Aperçu", "Preview"))
    preview_button.get_style_context().add_class("pill")
    preview_button.connect("clicked", lambda *_: command_dialog(Gtk, parent, profile, pack, False))
    actions.pack_start(preview_button, True, True, 0)
    install = Gtk.Button(label=t("Installer", "Install") if pack.get("state") != "ready" else t("Prêt", "Ready"))
    install.get_style_context().add_class("pill")
    if pack.get("state") == "ready":
        install.set_sensitive(False)
        install.get_style_context().add_class("ready-pill")
    else:
        install.connect("clicked", lambda *_: command_dialog(Gtk, parent, profile, pack, True))
    actions.pack_start(install, True, True, 0)
    return card


