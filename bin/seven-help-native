class HelpApp:
    def __init__(self, initial: str = "start"):
        ensure_gi_python()
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gdk, Gtk, Pango

        self.Gdk = Gdk
        self.Gtk = Gtk
        self.Pango = Pango
        self.sections = SECTIONS
        self.current_id = initial if any(section["id"] == initial for section in self.sections) else "start"
        self.rows = []

    def css(self) -> str:
        base = seven_theme.gtk_app_css("help") if seven_theme else ""
        return base + """
        window.help-window {
          background: @seven_bg;
          color: @seven_text;
        }
        .help-shell {
          background:
            radial-gradient(ellipse at 12% 0%, alpha(@seven_wallpaper_accent, 0.16), transparent 42%),
            radial-gradient(ellipse at 88% 0%, alpha(@seven_wallpaper_secondary, 0.12), transparent 40%),
            @seven_bg;
        }
        .help-sidebar {
          background: @seven_sidebar;
          border-right: 1px solid @seven_border;
          padding: 16px;
        }
        .help-brand {
          color: @seven_text;
          font: 600 22px "SF Pro Display", "SF Pro Text", sans-serif;
        }
        .help-subtitle, .help-muted {
          color: @seven_muted;
          font: 500 11px "SF Pro Text", sans-serif;
        }
        .help-search {
          min-height: 38px;
          border-radius: 12px;
          background: @seven_panel_2;
          color: @seven_text;
          border: 1px solid @seven_border;
          padding: 0 12px;
        }
        .help-nav {
          background: transparent;
        }
        .help-nav row {
          min-height: 52px;
          border-radius: 12px;
          margin: 2px 0;
          padding: 0;
          background: transparent;
          color: @seven_text;
        }
        .help-nav row:hover {
          background: @seven_hover;
        }
        .help-nav row:selected {
          background: @seven_selected;
        }
        .help-content {
          background: transparent;
          padding: 24px;
        }
        .hero {
          border-radius: 18px;
          background:
            linear-gradient(135deg, alpha(@seven_wallpaper_accent, 0.20), alpha(@seven_wallpaper_secondary, 0.12)),
            @seven_panel;
          border: 1px solid @seven_border;
          padding: 22px;
        }
        .hero-title {
          color: @seven_text;
          font: 600 28px "SF Pro Display", "SF Pro Text", sans-serif;
        }
        .hero-subtitle {
          color: @seven_muted;
          font: 500 13px "SF Pro Text", sans-serif;
        }
        .help-card {
          border-radius: 14px;
          background: @seven_panel;
          border: 1px solid @seven_border;
          padding: 16px;
        }
        .card-title {
          color: @seven_text;
          font: 600 14px "SF Pro Text", sans-serif;
        }
        .body-text {
          color: @seven_text;
          font: 500 12px "SF Pro Text", sans-serif;
        }
        .command {
          font: 600 12px "SF Mono", "JetBrainsMono Nerd Font", monospace;
          color: @seven_text;
          background: @seven_panel_2;
          border: 1px solid @seven_border;
          border-radius: 10px;
          padding: 9px 10px;
        }
        button.action {
          min-height: 34px;
          border-radius: 999px;
          background: @seven_panel_2;
          color: @seven_text;
          border: 1px solid @seven_border;
          padding: 0 12px;
          font: 600 11px "SF Pro Text", sans-serif;
        }
        button.action:hover {
          background: @seven_hover;
        }
        button.primary {
          background: alpha(@seven_accent, 0.22);
          border-color: alpha(@seven_accent, 0.36);
        }
        """

    def run(self) -> int:
        Gtk = self.Gtk
        Gdk = self.Gdk

        provider = Gtk.CssProvider()
        provider.load_from_data(self.css().encode("utf-8"))
        screen = Gdk.Screen.get_default()
        if screen is None:
            print("MISS: no graphical screen is available for SevenOS Help", file=sys.stderr)
            return 1
        Gtk.StyleContext.add_provider_for_screen(screen, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.window = Gtk.Window(title=t("Aide SevenOS", "SevenOS Help"))
        self.window.set_wmclass("seven-help-native", "SevenHelpNative")
        screen_width = screen.get_width() if screen else 1280
        screen_height = screen.get_height() if screen else 720
        compact_screen = screen_width < 1120 or screen_height < 680
        default_width = min(980, max(680, int(screen_width * 0.74)))
        default_height = min(660, max(480, int(screen_height * 0.72)))
        min_width = 660 if compact_screen else 800
        min_height = 460 if compact_screen else 520
        sidebar_width = 236 if compact_screen else 280
        self.window.set_default_size(default_width, default_height)
        self.window.set_size_request(min_width, min_height)
        self.window.set_position(Gtk.WindowPosition.CENTER)
        self.window.get_style_context().add_class("help-window")
        self.window.connect("destroy", Gtk.main_quit)
        self.window.connect("key-press-event", self.on_key_press)

        shell = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        shell.get_style_context().add_class("help-shell")
        self.window.add(shell)

        sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        sidebar.get_style_context().add_class("help-sidebar")
        sidebar.set_size_request(sidebar_width, -1)
        shell.pack_start(sidebar, False, False, 0)

        brand = Gtk.Label(label="SevenOS", xalign=0)
        brand.get_style_context().add_class("help-brand")
        sidebar.pack_start(brand, False, False, 0)

        subtitle = Gtk.Label(label=t("Manuel local, actions et architecture", "Local manual, actions and architecture"), xalign=0)
        subtitle.get_style_context().add_class("help-subtitle")
        subtitle.set_line_wrap(True)
        sidebar.pack_start(subtitle, False, False, 0)

        self.search = Gtk.SearchEntry()
        self.search.get_style_context().add_class("help-search")
        self.search.set_placeholder_text(t("Rechercher dans SevenOS", "Search SevenOS"))
        self.search.connect("search-changed", self.on_search)
        sidebar.pack_start(self.search, False, False, 4)

        self.nav = Gtk.ListBox()
        self.nav.get_style_context().add_class("help-nav")
        self.nav.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.nav.connect("row-selected", self.on_select)
        nav_scroll = Gtk.ScrolledWindow()
        nav_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        nav_scroll.add(self.nav)
        sidebar.pack_start(nav_scroll, True, True, 0)

        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        sidebar.pack_start(footer, False, False, 0)
        footer.pack_start(self.action_button("󰖟", "Spotlight", "seven-spotlight", True), True, True, 0)
        footer.pack_start(self.action_button("󰒃", "Doctor", "seven doctor", False), True, True, 0)

        self.stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        shell.pack_start(self.stack, True, True, 0)

        self.populate_nav()
        self.render_current()
        self.window.show_all()
        self.select_current_row()
        Gtk.main()
        return 0

    def on_key_press(self, _window, event) -> bool:
        key_name = (self.Gdk.keyval_name(event.keyval) or "").lower()
        if key_name == "escape":
            self.window.close()
            return True
        if key_name in {"slash", "f"} and event.state & self.Gdk.ModifierType.CONTROL_MASK:
            self.search.grab_focus()
            return True
        return False

    def populate_nav(self) -> None:
        Gtk = self.Gtk
        for child in list(self.nav.get_children()):
            self.nav.remove(child)
        self.rows = []
        query = self.search.get_text().strip().lower() if hasattr(self, "search") else ""
        for section in self.sections:
            haystack = " ".join([
                section["title"],
                section["subtitle"],
                " ".join(section["body"]),
                " ".join(command for command, _label in section["commands"]),
            ]).lower()
            if query and query not in haystack:
                continue
            row = Gtk.ListBoxRow()
            row.seven_id = section["id"]
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            box.set_margin_top(8)
            box.set_margin_bottom(8)
            box.set_margin_start(10)
            box.set_margin_end(10)
            icon = Gtk.Label(label=section["icon"])
            icon.set_size_request(28, -1)
            text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
            title = Gtk.Label(label=section["title"], xalign=0)
            title.get_style_context().add_class("card-title")
            subtitle = Gtk.Label(label=section["subtitle"], xalign=0)
            subtitle.get_style_context().add_class("help-muted")
            subtitle.set_ellipsize(self.Pango.EllipsizeMode.END)
            text.pack_start(title, False, False, 0)
            text.pack_start(subtitle, False, False, 0)
            box.pack_start(icon, False, False, 0)
            box.pack_start(text, True, True, 0)
            row.add(box)
            self.nav.add(row)
            self.rows.append(row)
        self.nav.show_all()
        self.select_current_row()

    def select_current_row(self) -> None:
        for row in self.rows:
            if getattr(row, "seven_id", "") == self.current_id:
                self.nav.select_row(row)
                return
        if self.rows:
            self.nav.select_row(self.rows[0])

    def on_search(self, _entry) -> None:
        self.populate_nav()

    def on_select(self, _listbox, row) -> None:
        if row is None:
            return
        self.current_id = row.seven_id
        self.render_current()

    def current_section(self) -> dict:
        for section in self.sections:
            if section["id"] == self.current_id:
                return section
        return self.sections[0]

    def clear_content(self) -> None:
        for child in list(self.stack.get_children()):
            self.stack.remove(child)

    def render_current(self) -> None:
        Gtk = self.Gtk
        section = self.current_section()
        self.clear_content()

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        content.get_style_context().add_class("help-content")
        scroll.add(content)
        self.stack.pack_start(scroll, True, True, 0)

        hero = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        hero.get_style_context().add_class("hero")
        title = Gtk.Label(label=f"{section['icon']}  {section['title']}", xalign=0)
        title.get_style_context().add_class("hero-title")
        subtitle = Gtk.Label(label=section["subtitle"], xalign=0)
        subtitle.get_style_context().add_class("hero-subtitle")
        subtitle.set_line_wrap(True)
        hero.pack_start(title, False, False, 0)
        hero.pack_start(subtitle, False, False, 0)
        content.pack_start(hero, False, False, 0)

        body_card = self.card(t("Comprendre", "Understand"))
        for paragraph in section["body"]:
            label = Gtk.Label(label=paragraph, xalign=0)
            label.get_style_context().add_class("body-text")
            label.set_line_wrap(True)
            label.set_selectable(True)
            body_card.pack_start(label, False, False, 5)
        content.pack_start(body_card, False, False, 0)

        action_box = self.card(t("Actions rapides", "Quick Actions"))
        actions_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        for icon, label, command in section["actions"]:
            actions_row.pack_start(self.action_button(icon, label, command, False), False, False, 0)
        action_box.pack_start(actions_row, False, False, 6)
        content.pack_start(action_box, False, False, 0)

        command_card = self.card(t("Commandes utiles", "Useful Commands"))
        for command, description in section["commands"]:
            command_card.pack_start(self.command_row(command, description), False, False, 5)
        content.pack_start(command_card, False, False, 0)

        self.stack.show_all()

    def card(self, title: str):
        Gtk = self.Gtk
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("help-card")
        label = Gtk.Label(label=title, xalign=0)
        label.get_style_context().add_class("card-title")
        card.pack_start(label, False, False, 0)
        return card

    def command_row(self, command: str, description: str):
        Gtk = self.Gtk
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        label_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        command_label = Gtk.Label(label=command, xalign=0)
        command_label.get_style_context().add_class("command")
        command_label.set_selectable(True)
        desc = Gtk.Label(label=description, xalign=0)
        desc.get_style_context().add_class("help-muted")
        desc.set_line_wrap(True)
        label_box.pack_start(command_label, False, False, 0)
        label_box.pack_start(desc, False, False, 0)
        row.pack_start(label_box, True, True, 0)
        copy = self.action_button("󰆏", t("Copier", "Copy"), f"copy:{command}", False)
        run = self.action_button("󰐊", t("Lancer", "Run"), command, True)
        row.pack_start(copy, False, False, 0)
        row.pack_start(run, False, False, 0)
        return row

    def action_button(self, icon: str, label: str, command: str, primary: bool):
        Gtk = self.Gtk
        button = Gtk.Button(label=f"{icon} {label}")
        button.get_style_context().add_class("action")
        if primary:
            button.get_style_context().add_class("primary")
        button.set_tooltip_text(command)
        button.connect("clicked", lambda *_: self.activate(command))
        return button

    def activate(self, command: str) -> None:
        if command.startswith("copy:"):
            clipboard = self.Gtk.Clipboard.get(self.Gdk.SELECTION_CLIPBOARD)
            clipboard.set_text(command[5:], -1)
            clipboard.store()
            return
        text_commands = (
            "seven ",
            "sevenpkg ",
            "scripts/",
            "./install.sh ",
            "SEVENOS_TERMINAL_ALPHA=",
            "SEVENOS_TERMINAL_TRANSPARENT=",
        )
        if command.startswith(text_commands):
            terminal_command(command)
        else:
            run_detached(command)


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gdk, Gtk

        app = HelpApp("start")
        provider = Gtk.CssProvider()
        provider.load_from_data(app.css().encode("utf-8"))
        if Gdk.Screen.get_default() is None and os.environ.get("SEVENOS_HELP_REQUIRE_SCREEN") == "1":
            raise RuntimeError("no graphical screen is available")
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    initial = sys.argv[1] if len(sys.argv) > 1 else "start"
    aliases = {
        "install": "start",
        "quick": "start",
        "commands": "start",
        "shortcuts": "shortcuts",
        "waybar": "waybar",
        "mini-os-collaboration": "mini-os",
        "files": "apps",
        "reader": "apps",
        "terminal": "apps",
        "ai": "apps",
        "questions": "faq",
        "glossary": "faq",
        "vocabulary": "faq",
        "vocabulaire": "faq",
        "diagnostics": "repair",
        "troubleshooting": "repair",
        "windows": "start",
        "server": "server",
        "deploy": "server",
        "hosting": "server",
        "domain": "server",
        "dns": "server",
        "core": "core",
        "seven-core": "core",
        "sevenbus": "core",
        "shell": "shell",
        "ags": "shell",
        "quality": "system",
        "public-quality": "system",
        "public-experience": "system",
    }
    return HelpApp(aliases.get(initial, initial)).run()


if __name__ == "__main__":
    raise SystemExit(main())
