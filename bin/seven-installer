#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="${SEVENOS_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"

usage() {
  cat <<'EOF'
SevenOS graphical installer launcher

Usage:
  seven-installer [open|gui|status|portal|guide] [--json]

This launcher prefers Calamares when it is available in the live ISO. When the
graphical runtime is missing, it falls back to the SevenOS guided installer
status instead of pretending a destructive installer is ready.
EOF
}

JSON_OUTPUT=0
ARGS=()
for arg in "$@"; do
  case "$arg" in
    --json|json) JSON_OUTPUT=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done
set -- "${ARGS[@]}"

run_or_print() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf '%q ' "$@"
    printf '\n'
    return 0
  fi
  exec "$@"
}

status_json() {
  local calamares_state archinstall_state release_state runtime_payload runtime_state runtime_route runtime_readiness runtime_next
  command -v calamares >/dev/null 2>&1 && calamares_state="OK" || calamares_state="MISS"
  command -v archinstall >/dev/null 2>&1 && archinstall_state="OK" || archinstall_state="MISS"
  runtime_payload="$("$ROOT_DIR/scripts/installer-stack.sh" runtime --json 2>/dev/null || printf '{}')"
  runtime_state="$(printf '%s\n' "$runtime_payload" | python -c 'import json,sys; data=json.load(sys.stdin); print(data.get("state","unknown"))' 2>/dev/null || printf unknown)"
  runtime_route="$(printf '%s\n' "$runtime_payload" | python -c 'import json,sys; data=json.load(sys.stdin); print(data.get("route","unknown"))' 2>/dev/null || printf unknown)"
  runtime_readiness="$(printf '%s\n' "$runtime_payload" | python -c 'import json,sys; data=json.load(sys.stdin); print(data.get("readiness","unknown"))' 2>/dev/null || printf unknown)"
  runtime_next="$(printf '%s\n' "$runtime_payload" | python -c 'import json,sys; data=json.load(sys.stdin); print(json.dumps(data.get("next", [])))' 2>/dev/null || printf '[]')"
  if [[ "$calamares_state" == "OK" ]]; then
    release_state="graphical-ready"
  elif [[ "$archinstall_state" == "OK" ]]; then
    release_state="tui-release-ready"
  else
    release_state="foundation"
  fi
  CALAMARES_STATE="$calamares_state" \
  ARCHINSTALL_STATE="$archinstall_state" \
  RELEASE_STATE="$release_state" \
  RUNTIME_STATE="$runtime_state" \
  RUNTIME_ROUTE="$runtime_route" \
  RUNTIME_READINESS="$runtime_readiness" \
  RUNTIME_NEXT="$runtime_next" \
  python - <<'PY'
import json
import os

calamares = os.environ.get("CALAMARES_STATE", "MISS")
archinstall = os.environ.get("ARCHINSTALL_STATE", "MISS")
runtime_state = os.environ.get("RUNTIME_STATE", "unknown")
runtime_route = os.environ.get("RUNTIME_ROUTE", "unknown")
runtime_readiness = os.environ.get("RUNTIME_READINESS", "unknown")
try:
    runtime_next = json.loads(os.environ.get("RUNTIME_NEXT", "[]"))
except json.JSONDecodeError:
    runtime_next = []

if calamares == "OK":
    state = "graphical-ready"
    route = "calamares"
elif archinstall == "OK":
    state = "guided-tui-ready" if runtime_state in {"missing-source", "unknown"} else "graphical-runtime-candidate"
    route = "sevenos-guided-tui"
else:
    state = "foundation" if runtime_state in {"missing-source", "unknown"} else "graphical-runtime-candidate"
    route = "status-only"

print(json.dumps({
    "schema": "sevenos.installer-portal.v1",
    "state": state,
    "route": route,
    "calamares_runtime": calamares,
    "runtime_source": {
        "state": runtime_state,
        "route": runtime_route,
        "readiness": runtime_readiness,
    },
    "archinstall_runtime": archinstall,
    "release_state": os.environ.get("RELEASE_STATE", "foundation"),
    "safe_by_default": True,
    "destructive_actions_require_confirmation": True,
    "commands": {
        "open": "seven-installer open",
        "status": "seven-installer status",
        "graphical": "seven installer graphical",
        "release": "seven installer release",
        "guide": "seven-installer guide",
    },
    "next": runtime_next,
}, indent=2))
PY
}

status() {
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    status_json
    return 0
  fi

  printf 'SevenOS Graphical Installer\n'
  printf '===========================\n'
  PORTAL_JSON="$(status_json)" python - <<'PY'
import json
import os

data = json.loads(os.environ["PORTAL_JSON"])
runtime = data.get("runtime_source", {})
print(f"state:     {data.get('state')}")
print(f"route:     {data.get('route')}")
print(f"graphical: {data.get('calamares_runtime')}")
print(f"source:    {runtime.get('state')} ({runtime.get('route')})")
if data.get("route") == "calamares":
    print("command:   calamares -d")
else:
    print("fallback:  seven installer release")
PY
}

portal() {
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    status_json
    return 0
  fi
  PORTAL_JSON="$(status_json)" python - <<'PY'
import json
import os

data = json.loads(os.environ["PORTAL_JSON"])
print("SevenOS Installer Portal")
print("========================")
print(f"State: {data.get('state')}")
print(f"Route: {data.get('route')}")
print(f"Graphical runtime: {data.get('calamares_runtime')}")
runtime = data.get("runtime_source", {})
print(f"Runtime source: {runtime.get('state')} ({runtime.get('readiness')})")
print(f"Guided runtime: {data.get('archinstall_runtime')}")
print(f"Release gate: {data.get('release_state')}")
print()
print("Safe path:")
if data.get("route") == "calamares":
    print("  seven-installer open")
elif data.get("route") == "sevenos-guided-tui":
    print("  seven installer plan")
    print("  seven installer doctor")
else:
    print("  seven installer release")
for item in data.get("next", [])[:2]:
    print(f"  {item.get('command')}")
PY
}

open_installer() {
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    status_json
    return 0
  fi

  if [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" && -x "$ROOT_DIR/bin/seven-installer-native" ]]; then
    run_or_print "$ROOT_DIR/bin/seven-installer-native"
    return 0
  fi

  if command -v calamares >/dev/null 2>&1; then
    if command -v pkexec >/dev/null 2>&1; then
      run_or_print pkexec calamares -d
    else
      run_or_print calamares -d
    fi
    return 0
  fi

  printf 'SevenOS graphical installer runtime is not installed yet.\n'
  printf 'Use the current safe installer path:\n\n'
  "$ROOT_DIR/scripts/installer-stack.sh" runtime
  printf '\n'
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf 'seven installer release\n'
    return 0
  fi
  "$ROOT_DIR/bin/seven" installer release
}

case "${1:-open}" in
  open) open_installer ;;
  gui) "$ROOT_DIR/bin/seven-installer-native" ;;
  status) status ;;
  portal) portal ;;
  guide) "$ROOT_DIR/bin/seven" installer guide ;;
  -h|--help|help) usage ;;
  *)
    printf 'seven-installer: unknown action: %s\n' "$1" >&2
    usage
    exit 1
    ;;
esac
