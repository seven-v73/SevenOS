    preview_visible_pref = bool(prefs.get("preview_visible", True))
    operation_active = False
    operation_cancel_requested = False
    operation_pause_requested = False
    selection_anchor: Path | None = None
    rubberband_origin: tuple[int, int] | None = None
    rubberband_rect = {"x": 0, "y": 0, "w": 0, "h": 0, "active": False}
    spring_open_state = {"id": 0, "target": None, "widget": None}
    hover_preview_state = {"id": 0}
