    def mini_os_resource_root(profile: str | None = None) -> Path:
        profile_key = (profile or active_profile or "equinox").strip().lower()
        if grouped_resources or profile_key == "equinox":
            return Path.home()
        return Path.home() / ".local/share/sevenos/profile-containers" / profile_key / "home"

    def active_resource_places() -> list[dict[str, object]]:
        root = mini_os_resource_root()
        profile_key = active_profile.strip().lower() or "equinox"
        style = f"mini-os-row mini-{profile_key}"
        label_suffix = "" if grouped_resources or profile_key == "equinox" else f" · {profile_label(profile_key)}"
        return [
            {
                "label": f"{t('Accueil', 'Home')}{label_suffix}",
                "icon": "user-home",
                "path": root,
                "tooltip": tr_text("Current resource home. Toggle shared resources from System actions."),
                "style": style,
            },
            {"label": t("Téléchargements", "Downloads"), "icon": "folder-download", "path": root / "Downloads", "tooltip": tr_text("Downloads for the active mini OS"), "style": style},
            {"label": "Documents", "icon": "folder-documents", "path": root / "Documents", "tooltip": tr_text("Documents for the active mini OS"), "style": style},
            {"label": "Code", "icon": "folder-development", "path": root / "Code", "tooltip": tr_text("Code and projects for the active mini OS"), "style": style},
            {"label": t("Musique", "Music"), "icon": "folder-music", "path": root / "Music", "tooltip": tr_text("Music for the active mini OS"), "style": style},
            {"label": t("Images", "Pictures"), "icon": "folder-pictures", "path": root / "Pictures", "tooltip": tr_text("Pictures for the active mini OS"), "style": style},
            {"label": t("Vidéos", "Videos"), "icon": "folder-videos", "path": root / "Videos", "tooltip": tr_text("Videos for the active mini OS"), "style": style},
        ]

    add_place(t("Récents", "Recents"), "document-open-recent", RECENTS_SENTINEL)
    add_place("Applications", "applications-system", Path("/usr/share/applications"))
    add_heading(t("Ressources", "Resources"))
    resources_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar_content.pack_start(resources_box, False, False, 0)
    resource_rows: list[Gtk.Button] = []

    def render_resource_rows() -> None:
        for row in list(resource_rows):
            if row in sidebar_buttons:
                sidebar_buttons.remove(row)
            resources_box.remove(row)
        resource_rows.clear()
        for place in active_resource_places():
            row = add_place(
                str(place["label"]),
                str(place["icon"]),
                place["path"],
                resources_box,
                str(place["tooltip"]),
                style_class=str(place["style"]),
                ensure_dir=True,
            )
            row.profile_resource = True
            resource_rows.append(row)
        resources_box.show_all()

    render_resource_rows()
    add_heading(t("Favoris", "Favorites"))
    favorite_rows: list[Gtk.Button] = []
    favorites_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar_content.pack_start(favorites_box, False, False, 0)

    def render_favorite_rows() -> None:
        for row in list(favorite_rows):
            if row in sidebar_buttons:
                sidebar_buttons.remove(row)
            favorites_box.remove(row)
        favorite_rows.clear()
        for favorite in favorite_paths():
            row = add_place(favorite.name or str(favorite), "emblem-favorite", favorite, favorites_box)
            favorite_rows.append(row)
        favorites_box.show_all()

    render_favorite_rows()
    add_heading("Mini OS")
    mini_os_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar_content.pack_start(mini_os_box, False, False, 0)
    mini_os_rows: list[Gtk.Button] = []

    def render_mini_os_rows() -> None:
        for row in list(mini_os_rows):
            if row in sidebar_buttons:
                sidebar_buttons.remove(row)
            mini_os_box.remove(row)
        mini_os_rows.clear()
        for place in mini_os_places():
            profile = str(place["profile"])
            path = place["path"]
            row = add_place(
                str(place["label"]),
                str(place["icon"]),
                path,
                mini_os_box,
                str(place["tooltip"]),
                style_class=f"mini-os-row mini-{profile}",
                ensure_dir=profile != "equinox",
            )
            row.mini_os_profile = profile
            mini_os_rows.append(row)
        mini_os_box.show_all()

    render_mini_os_rows()
    add_heading(t("Emplacements", "Locations"))
    locations_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar_content.pack_start(locations_box, False, False, 0)
    location_rows: list[Gtk.Button] = []
    add_heading(t("Disques", "Drives"))
    drives_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar_content.pack_start(drives_box, False, False, 0)
    drive_rows: list[Gtk.Button] = []
    drive_scan_state = {"loaded": False, "pending": 0}
    drive_error_state = {"title": "", "message": "", "detail": ""}

    def schedule_drive_scan(delay_ms: int = 360) -> None:
        if drive_scan_state.get("pending"):
            return

        def run_scan() -> bool:
            drive_scan_state["pending"] = 0
            render_location_rows(True)
            return False

        drive_scan_state["pending"] = GLib.timeout_add(delay_ms, run_scan)

    def render_location_rows(load_drives: bool = False) -> None:
        for row in list(location_rows):
            if row in sidebar_buttons:
                sidebar_buttons.remove(row)
            locations_box.remove(row)
        for row in list(drive_rows):
            if row in sidebar_buttons:
                sidebar_buttons.remove(row)
            drives_box.remove(row)
        location_rows.clear()
        drive_rows.clear()
        for label, icon, target, tooltip, device, mounted_path, ejectable in [
            (Path.home().name, "user-home", Path.home(), "", "", str(Path.home()), False),
            ("SevenOS", "drive-harddisk", Path("/"), "", "", "/", False),
            *[(network_label(uri), "network-server", uri, uri, "", "", False) for uri in network_places()],
            (t("Connecter un serveur", "Connect to Server"), "network-server", "seven://connect-server", "", "", "", False),
        ]:
            row = add_place(label, icon, target, locations_box, tooltip, device, mounted_path, ejectable)
            location_rows.append(row)
        drive_locations = []
        if load_drives:
            drive_scan_state["loaded"] = True
            drive_locations = mounted_locations()
        for label, icon, target, tooltip, device, mounted_path, ejectable in drive_locations:
            row = add_place(label, icon, target, drives_box, tooltip, device, mounted_path, ejectable)
            drive_rows.append(row)
        if not load_drives and not drive_scan_state.get("loaded"):
            row = add_place(
                t("Recherche de disques", "Scanning drives"),
                "view-refresh-symbolic",
                "seven://refresh-volumes",
                drives_box,
                t("Seven Files affiche d'abord la fenêtre, puis charge les disques.", "Seven Files shows the window first, then loads drives."),
                "",
                "",
                False,
            )
            drive_rows.append(row)
            schedule_drive_scan()
        elif not drive_locations:
            row = add_place(
                t("Actualiser les disques", "Refresh drives"),
                "view-refresh-symbolic",
                "seven://refresh-volumes",
                drives_box,
                t("Branche un disque puis actualise la liste.", "Plug a drive, then refresh the list."),
                "",
                "",
                False,
            )
            drive_rows.append(row)
        panel_row = add_place(
            t("Gérer les disques", "Manage drives"),
            "drive-harddisk-symbolic",
            "seven://drive-panel",
            drives_box,
            t("Monter, ouvrir, éjecter ou diagnostiquer les volumes externes.", "Mount, open, eject, or diagnose external volumes."),
            "",
            "",
            False,
        )
        drive_rows.append(panel_row)
        locations_box.show_all()
        drives_box.show_all()

    render_location_rows(False)
    try:
        volume_monitor = Gio.VolumeMonitor.get()
        volume_monitor.connect("mount-added", lambda *_: GLib.idle_add(lambda: render_location_rows(True) or False))
        volume_monitor.connect("mount-removed", lambda *_: GLib.idle_add(lambda: render_location_rows(True) or False))
        volume_monitor.connect("volume-added", lambda *_: GLib.idle_add(lambda: render_location_rows(True) or False))
        volume_monitor.connect("volume-removed", lambda *_: GLib.idle_add(lambda: render_location_rows(True) or False))
        volume_monitor.connect("volume-changed", lambda *_: GLib.idle_add(lambda: render_location_rows(True) or False))
    except Exception:
        pass

