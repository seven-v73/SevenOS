        menu.show_all()
        try:
            menu.popup_at_pointer(event)
        except Exception:
            menu.popup(None, None, None, None, getattr(event, "button", 0), getattr(event, "time", Gtk.get_current_event_time()))

    def setup_file_tile_dnd(widget, child, path: Path):
        uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 1)
        widget.drag_source_set(Gdk.ModifierType.BUTTON1_MASK, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
        widget.connect("drag-data-get", lambda _widget, _context, data, _info, _time: on_file_drag_data_get(data))
        if path.is_dir():
            widget.drag_dest_set(Gtk.DestDefaults.ALL, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
            widget.connect("drag-motion", lambda target_widget, context, _x, _y, time_value: on_drop_motion(target_widget, context, time_value))
            widget.connect("drag-leave", lambda target_widget, _context, _time: cancel_spring_open(target_widget))
            widget.connect("drag-data-received", lambda target_widget, context, _x, _y, data, _info, time_value, target=path: on_file_drop(target_widget, context, data, time_value, target))

    def setup_current_drop_target(widget):
        uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 1)
        widget.drag_dest_set(Gtk.DestDefaults.ALL, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
        widget.connect("drag-motion", lambda target_widget, context, _x, _y, time_value: on_drop_motion(target_widget, context, time_value))
        widget.connect("drag-leave", lambda target_widget, _context, _time: cancel_spring_open(target_widget))
        widget.connect("drag-data-received", lambda target_widget, context, _x, _y, data, _info, time_value: on_file_drop(target_widget, context, data, time_value, current))

    def on_file_drag_data_get(data) -> None:
        paths = selected_paths()
        if not paths:
            target = selected_path()
            paths = [target] if target else []
        data.set_uris([file_uri(path) for path in paths if path.exists()])

    def on_drop_motion(widget, context, time_value: int) -> bool:
        try:
            context.drag_status(Gdk.DragAction.MOVE, time_value)
        except Exception:
            pass
        try:
            widget.get_style_context().add_class("drop-target")
        except Exception:
            pass
        try:
            widget.file_child.get_style_context().add_class("drop-target")
        except Exception:
            pass
        schedule_spring_open(widget)
        return True

    def cancel_spring_open(widget=None) -> None:
        if spring_open_state["id"]:
            GLib.source_remove(spring_open_state["id"])
            spring_open_state["id"] = 0
        target_widget = widget or spring_open_state.get("widget")
        for css_class in ("spring-armed", "drop-target"):
            try:
                target_widget.get_style_context().remove_class(css_class)
            except Exception:
                pass
            try:
                target_widget.file_child.get_style_context().remove_class(css_class)
            except Exception:
                pass
        spring_open_state["target"] = None
        spring_open_state["widget"] = None

    def schedule_spring_open(widget) -> None:
        target = getattr(widget, "spring_target", None)
        if not isinstance(target, Path) or not target.exists() or not target.is_dir() or target == current:
            return
        if spring_open_state["target"] == target and spring_open_state["id"]:
            return
        cancel_spring_open()
        spring_open_state["target"] = target
        spring_open_state["widget"] = widget
        try:
            widget.get_style_context().add_class("spring-armed")
        except Exception:
            pass
        try:
            widget.file_child.get_style_context().add_class("spring-armed")
        except Exception:
            pass

        def spring_open() -> bool:
            spring_open_state["id"] = 0
            if target.exists() and target.is_dir():
                navigate(target)
                status_label.set_text(f"Spring opened {target.name}")
            cancel_spring_open(widget)
            return False

        spring_open_state["id"] = GLib.timeout_add(SPRING_OPEN_DELAY_MS, spring_open)

    def move_or_copy_paths(paths: list[Path], destination_dir: Path, move: bool, label: str):
        sources = [path for path in paths if path.exists() and path.parent != destination_dir]
        if not sources:
            status_label.set_text("Nothing to move")
            return
        conflict_policy = conflict_policy_for(sources, destination_dir)
        if conflict_policy == "cancel":
            set_status(f"{label} cancelled")
            return

        def worker(cancelled, report):
            completed = 0
            total = len(sources)
            undo_created: list[str] = []
            undo_moves: list[tuple[str, str]] = []
            total_bytes = max(1, sum(path_total_bytes(source) for source in sources if source.exists()))
            done_bytes = 0
            started_at = time.monotonic()

            def progress(delta: int, item_name: str = "") -> None:
                nonlocal done_bytes
                done_bytes = min(total_bytes, done_bytes + max(0, delta))
                report(done_bytes, total_bytes, operation_eta_label(label, done_bytes, total_bytes, started_at, item_name))

            for index, source in enumerate(sources, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                destination = destination_for_policy(source, destination_dir, conflict_policy)
                if destination is None:
                    progress(path_total_bytes(source), source.name)
                    continue
                try:
                    if move:
                        original = str(source)
                        shutil.move(str(source), str(destination))
                        undo_moves.append((original, str(destination)))
                        progress(path_total_bytes(destination), destination.name)
                    elif source.is_dir():
                        copy_path_streamed(source, destination, cancelled, progress)
                        undo_created.append(str(destination))
                    else:
                        copy_path_streamed(source, destination, cancelled, progress)
                        undo_created.append(str(destination))
                    completed += 1
                    report(done_bytes, total_bytes, f"{label} {index}/{total} · {format_size(done_bytes)}")
                except InterruptedError:
                    return OPERATION_CANCELLED
                except OSError:
                    progress(path_total_bytes(source), source.name)
                    report(done_bytes, total_bytes, f"{label} issue {index}/{total}")
            return {"count": completed, "created": undo_created, "moves": undo_moves}

        def done(result):
            if result == OPERATION_CANCELLED:
                finish_operation(f"{label} cancelled")
            else:
                completed = int(result.get("count", 0)) if isinstance(result, dict) else int(result or 0)
                if isinstance(result, dict):
                    if move and result.get("moves"):
                        record_undo(f"{label} {completed} item(s)", "moved", result.get("moves"))
                    elif not move and result.get("created"):
                        record_undo(f"{label} {completed} item(s)", "copied", result.get("created"))
                finish_operation(f"{label} {completed} item(s)")
            if split_visible:
                render_split()

        run_background(f"{label} {len(sources)} item(s)", worker, done)

    def copy_selected_to_split(move: bool = False) -> bool:
        paths = selected_paths()
        if not paths:
            set_status("Select item(s) to send to split view")
            return True
        move_or_copy_paths(paths, split_current, move=move, label="Moved" if move else "Copied")
        return True

    def on_file_drop(widget, context, data, time_value: int, destination: Path) -> None:
        cancel_spring_open(widget)
        try:
            widget.file_child.get_style_context().remove_class("drop-target")
        except Exception:
            pass
        paths = [path for path in file_paths_from_uri_payload("\n".join(data.get_uris())) if path.exists()]
        try:
            move = context.get_selected_action() == Gdk.DragAction.MOVE
        except Exception:
            move = True
        if destination.exists() and destination.is_dir():
            move_or_copy_paths(paths, destination, move=True if move else False, label="Moved" if move else "Copied")
            context.finish(bool(paths), False, time_value)
        else:
            context.finish(False, False, time_value)

    def on_sidebar_drop(widget, context, data, time_value: int, target: Path | str) -> None:
        cancel_spring_open(widget)
        widget.get_style_context().remove_class("drop-target")
        paths = [path for path in file_paths_from_uri_payload("\n".join(data.get_uris())) if path.exists()]
        destination = target if isinstance(target, Path) else Path(urllib.parse.urlparse(str(target)).path)
        if destination.exists() and destination.is_dir():
            move_or_copy_paths(paths, destination, move=True, label="Moved")
            context.finish(bool(paths), False, time_value)
        else:
            context.finish(False, False, time_value)

    def on_tile_button(event, child, path: Path) -> bool:
        nonlocal selection_anchor
        if getattr(event, "button", 0) == 3:
            flash_tile(child)
            flow.select_child(child)
            selection_anchor = path
            update_preview(path)
            show_context_menu(path, event)
            return True
        if getattr(event, "button", 0) == 2:
            flash_tile(child)
            if path.is_dir():
                new_tab(path)
            elif is_previewable(path):
                open_quicklook_preview(path)
            else:
                open_file(path)
            return True
        if getattr(event, "button", 0) == 1:
            flash_tile(child)
            range_extend_mask = Gdk.ModifierType.CONTROL_MASK | Gdk.ModifierType.SHIFT_MASK
            range_extend = (event.state & range_extend_mask) == range_extend_mask or bool(event.state & Gdk.ModifierType.SHIFT_MASK)
            if getattr(event, "type", None) == Gdk.EventType._2BUTTON_PRESS:
                flow.unselect_all()
                flow.select_child(child)
                update_preview(path)
                open_selected(path)
            elif range_extend:
                children = flow.get_children()
                anchor_child = next((item for item in children if getattr(item, "path", None) == selection_anchor), None)
                if anchor_child and anchor_child in children and child in children:
                    start = children.index(anchor_child)
                    end = children.index(child)
                    flow.unselect_all()
                    for item in children[min(start, end): max(start, end) + 1]:
                        flow.select_child(item)
                    update_preview_multiple([item.path for item in flow.get_selected_children()])
                else:
                    flow.select_child(child)
                    update_preview(path)
                selection_anchor = selection_anchor or path
            elif event.state & Gdk.ModifierType.CONTROL_MASK:
                if child in flow.get_selected_children():
                    flow.unselect_child(child)
                else:
                    flow.select_child(child)
                selected = flow.get_selected_children()
                if len(selected) > 1:
                    update_preview_multiple([item.path for item in selected])
                elif selected:
                    update_preview(selected[0].path)
                else:
                    update_preview(current)
                selection_anchor = path
            else:
                flow.unselect_all()
                flow.select_child(child)
                selection_anchor = path
                update_preview(path)
            return True
        return False

    def open_selected(path: Path | None = None):
        target = path or selected_path()
        if not target:
            return
        activate_tile_feedback(target)
        if target.is_dir():
            navigate(target)
        else:
            open_file(target)

    def remember_drive_error(title: str, message: str, detail: str = "") -> None:
        drive_error_state.update({"title": title, "message": message, "detail": detail})
        set_status(message)
        notify_system(title, message)
        if detail:
            print(f"Seven Files drive error: {detail}", file=sys.stderr)

    def show_drive_error_details() -> bool:
        detail = drive_error_state.get("detail", "") or drive_error_state.get("message", "")
        dialog = Gtk.Dialog(title=drive_error_state.get("title") or t("Détails du disque", "Drive details"), transient_for=window, modal=True)
        dialog.set_default_size(520, 320)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        box = decorate_dialog(
            dialog,
            drive_error_state.get("title") or t("Problème de disque", "Drive issue"),
            drive_error_state.get("message") or t("Aucun détail récent.", "No recent details."),
            "dialog-warning-symbolic",
        )
        text = Gtk.TextView()
        text.set_editable(False)
        text.set_cursor_visible(False)
        text.get_style_context().add_class("files-detail-log")
        text.get_buffer().set_text(detail or t("Aucun détail disponible.", "No detail available."))
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroller.add(text)
        box.pack_start(scroller, True, True, 0)
        copy_btn = Gtk.Button(label=t("Copier les détails", "Copy Details"))
        copy_btn.get_style_context().add_class("selection-action")
        copy_btn.connect("clicked", lambda *_: copy_text(detail))
        box.pack_start(copy_btn, False, False, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()
        return True

    def mount_device_and_open(uri: str) -> None:
        parsed = urllib.parse.urlparse(uri)
        params = urllib.parse.parse_qs(parsed.query)
        device = urllib.parse.unquote(params.get("device", [""])[0])
        label = urllib.parse.unquote(params.get("label", [""])[0])
        if not device.startswith("/dev/"):
            remember_drive_error(tr_text("Drive issue"), tr_text("Cannot mount this device"), device)
            return
        set_status(tr_text("Mounting {name}...", name=label or device))

        def worker() -> None:
            mountpoint = ""
            error = ""
            started_agent = start_polkit_agent()
            if shutil.which("udisksctl"):
                try:
                    result = subprocess.run(
                        ["udisksctl", "mount", "-b", device],
                        text=True,
                        capture_output=True,
                        check=False,
                        timeout=30,
                    )
                    text = (result.stdout or "") + "\n" + (result.stderr or "")
                    if result.returncode == 0:
                        for token in text.replace("\n", " ").split():
                            cleaned = token.rstrip(".")
                            if cleaned.startswith(("/run/media/", "/media/", "/mnt/")):
                                mountpoint = cleaned
                                break
                    else:
                        error = text.strip()
                        if "NotAuthorizedCanObtain" in error and not started_agent:
                            error = tr_text("Polkit authentication agent is not running.")
                except Exception as exc:
                    error = str(exc)
            if not mountpoint and shutil.which("lsblk"):
                try:
                    result = subprocess.run(
                        ["lsblk", "-J", "-o", "PATH,MOUNTPOINTS", device],
                        text=True,
                        capture_output=True,
                        check=False,
                        timeout=2.5,
                    )
                    payload = json.loads(result.stdout or "{}")
                    for item in payload.get("blockdevices", []) if isinstance(payload.get("blockdevices"), list) else []:
                        for point in mountpoints_for(item):
                            mountpoint = point
                            break
                except Exception:
                    pass

            def finish() -> bool:
                if mountpoint and Path(mountpoint).exists():
                    render_location_rows(True)
                    navigate(Path(mountpoint))
                    drive_error_state.update({"title": "", "message": "", "detail": ""})
                    set_status(tr_text("Mounted {name}", name=label or Path(mountpoint).name))
                else:
                    if "NotAuthorized" in error or "authentication agent" in error:
                        message = tr_text("Mount needs authorization. SevenOS started Polkit; click the disk again.")
                    elif "hibernated" in error.lower() or "unsafe state" in error.lower() or "fast startup" in error.lower():
                        message = tr_text("Windows left this disk locked. Disable Fast Startup or shut Windows down fully.")
                    else:
                        message = tr_text("Mount failed. Install/enable udisks2 or check Windows fast startup.")
                    remember_drive_error(tr_text("Mount failed"), message, error or device)
                return False

            GLib.idle_add(finish)

        threading.Thread(target=worker, daemon=True).start()

    def unmount_device_and_refresh(device: str, label: str = "", mounted_path: str = "") -> None:
        if not device.startswith("/dev/"):
            remember_drive_error(tr_text("Drive issue"), tr_text("Cannot unmount this device"), device)
            return
        set_status(tr_text("Unmounting {name}...", name=label or device))

        def worker() -> None:
            error = ""
            ok = False
            started_agent = start_polkit_agent()
            if shutil.which("udisksctl"):
                try:
                    result = subprocess.run(
                        ["udisksctl", "unmount", "-b", device],
                        text=True,
                        capture_output=True,
                        check=False,
                        timeout=30,
                    )
                    ok = result.returncode == 0
                    if not ok:
                        error = ((result.stdout or "") + "\n" + (result.stderr or "")).strip()
                        if "NotAuthorizedCanObtain" in error and not started_agent:
                            error = tr_text("Polkit authentication agent is not running.")
                except Exception as exc:
                    error = str(exc)
            else:
                error = tr_text("udisksctl is not installed.")

            def finish() -> bool:
                render_location_rows(True)
                if ok:
                    if mounted_path and str(current).startswith(str(Path(mounted_path))):
                        navigate(Path.home())
                    drive_error_state.update({"title": "", "message": "", "detail": ""})
                    set_status(tr_text("Unmounted {name}", name=label or device))
                    notify_system(tr_text("Volume unmounted"), label or device)
                else:
                    if "busy" in error.lower():
                        message = tr_text("Unmount failed. Close files or terminals using this volume.")
                    elif "NotAuthorized" in error or "authentication agent" in error:
                        message = tr_text("Unmount needs authorization. SevenOS started Polkit; try again.")
                    else:
                        message = tr_text("Unmount failed.")
                    remember_drive_error(tr_text("Unmount failed"), message, error or device)
                return False

            GLib.idle_add(finish)

        threading.Thread(target=worker, daemon=True).start()

    def eject_device_and_refresh(device: str, label: str = "", mounted_path: str = "") -> None:
        if not device.startswith("/dev/"):
            remember_drive_error(tr_text("Drive issue"), tr_text("Cannot eject this device"), device)
            return
        if not confirm_dialog(
            tr_text("Eject Volume"),
            tr_text("Seven Files will safely unmount and power off {name}.", name=label or device),
            tr_text("Eject"),
        ):
            return
        set_status(tr_text("Ejecting {name}...", name=label or device))

        def worker() -> None:
            error = ""
            ok = False
            start_polkit_agent()
            if shutil.which("udisksctl"):
                try:
                    unmount = subprocess.run(
                        ["udisksctl", "unmount", "-b", device],
                        text=True,
                        capture_output=True,
                        check=False,
                        timeout=30,
                    )
                    unmount_text = ((unmount.stdout or "") + "\n" + (unmount.stderr or "")).strip()
                    if unmount.returncode not in {0, 1} and unmount_text:
                        error = unmount_text
                    power = subprocess.run(
                        ["udisksctl", "power-off", "-b", device],
                        text=True,
                        capture_output=True,
                        check=False,
                        timeout=30,
                    )
                    ok = power.returncode == 0
                    if not ok:
                        error = ((power.stdout or "") + "\n" + (power.stderr or "")).strip() or error
                except Exception as exc:
                    error = str(exc)
            else:
                error = tr_text("udisksctl is not installed.")

            def finish() -> bool:
                render_location_rows(True)
                if ok:
                    if mounted_path and str(current).startswith(str(Path(mounted_path))):
                        navigate(Path.home())
                    drive_error_state.update({"title": "", "message": "", "detail": ""})
                    set_status(tr_text("Ejected {name}", name=label or device))
                    notify_system(tr_text("Volume ejected"), label or device)
                else:
                    if "busy" in error.lower():
                        message = tr_text("Eject failed. Close files or terminals using this volume.")
                    elif "NotAuthorized" in error or "authentication" in error:
                        message = tr_text("Eject needs authorization. SevenOS started Polkit; try again.")
                    else:
                        message = tr_text("Eject failed.")
                    remember_drive_error(tr_text("Eject failed"), message, error or device)
                return False

            GLib.idle_add(finish)

        threading.Thread(target=worker, daemon=True).start()

    def show_drive_panel() -> bool:
        render_location_rows(True)
        dialog = Gtk.Dialog(title=t("Disques", "Drives"), transient_for=window, modal=True)
        dialog.set_default_size(460, 360)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(14)
        content.set_margin_bottom(12)
        content.set_margin_start(14)
        content.set_margin_end(14)
        title = Gtk.Label(label=t("Volumes externes", "External volumes"))
        title.set_xalign(0)
        title.get_style_context().add_class("dialog-title")
        hint = Gtk.Label(
            label=t(
                "Branche un disque, puis monte-le ou éjecte-le depuis ici. Les erreurs restent visibles sans casser la fenêtre.",
                "Plug a drive, then mount or eject it here. Errors stay visible without breaking the window.",
            )
        )
        hint.set_xalign(0)
        hint.set_line_wrap(True)
        hint.get_style_context().add_class("dialog-subtitle")
        content.pack_start(title, False, False, 0)
        content.pack_start(hint, False, False, 0)
        if drive_error_state.get("message"):
            error_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            error_row.get_style_context().add_class("inspector-card")
            error_icon = Gtk.Image.new_from_icon_name("dialog-warning-symbolic", Gtk.IconSize.MENU)
            error_icon.set_pixel_size(18)
            error_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            error_title = Gtk.Label(label=drive_error_state.get("title") or t("Dernier problème", "Last issue"))
            error_title.set_xalign(0)
            error_title.get_style_context().add_class("preview-value")
            error_message = Gtk.Label(label=drive_error_state.get("message") or "")
            error_message.set_xalign(0)
            error_message.set_line_wrap(True)
            error_message.get_style_context().add_class("preview-hint")
            error_text.pack_start(error_title, False, False, 0)
            error_text.pack_start(error_message, False, False, 0)
            details_btn = Gtk.Button(label=t("Détails", "Details"))
            details_btn.get_style_context().add_class("selection-action")
            details_btn.connect("clicked", lambda *_: show_drive_error_details())
            error_row.pack_start(error_icon, False, False, 0)
            error_row.pack_start(error_text, True, True, 0)
            error_row.pack_start(details_btn, False, False, 0)
            content.pack_start(error_row, False, False, 0)
        rows = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        content.pack_start(rows, True, True, 4)
        drive_locations = mounted_locations()
        if not drive_locations:
            empty = Gtk.Label(label=t("Aucun volume externe détecté pour l'instant.", "No external volume detected yet."))
            empty.set_xalign(0)
            empty.get_style_context().add_class("preview-hint")
            rows.pack_start(empty, False, False, 12)
        for label, icon, target, tooltip, device, mounted_path, ejectable in drive_locations:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.get_style_context().add_class("inspector-card")
            image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
            image.set_pixel_size(18)
            text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            name = Gtk.Label(label=label)
            name.set_xalign(0)
            name.get_style_context().add_class("preview-value")
            detail = Gtk.Label(label=mounted_path or device or tooltip)
            detail.set_xalign(0)
            detail.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
            detail.get_style_context().add_class("preview-hint")
            text_box.pack_start(name, False, False, 0)
            text_box.pack_start(detail, False, False, 0)
            row.pack_start(image, False, False, 0)
            row.pack_start(text_box, True, True, 0)

            if str(target).startswith("seven://mount"):
                button = Gtk.Button(label=t("Monter", "Mount"))
                button.connect("clicked", lambda _button, uri=str(target): (dialog.destroy(), mount_device_and_open(uri)))
            else:
                button = Gtk.Button(label=t("Ouvrir", "Open"))
                button.connect("clicked", lambda _button, path=target: (dialog.destroy(), navigate_uri_or_path(path)))
            button.get_style_context().add_class("selection-action")
            row.pack_start(button, False, False, 0)
            if device and mounted_path:
                unmount_btn = Gtk.Button(label=t("Démonter", "Unmount"))
                unmount_btn.get_style_context().add_class("selection-action")
                unmount_btn.connect(
                    "clicked",
                    lambda _button, dev=device, name_label=label, mount_path=mounted_path: (
                        dialog.destroy(),
                        unmount_device_and_refresh(dev, name_label, mount_path),
                    ),
                )
                row.pack_start(unmount_btn, False, False, 0)
            if ejectable and device:
                eject_btn = Gtk.Button(label=t("Éjecter", "Eject"))
                eject_btn.get_style_context().add_class("selection-action")
                eject_btn.connect(
                    "clicked",
                    lambda _button, dev=device, name_label=label, mount_path=mounted_path: (
                        dialog.destroy(),
                        eject_device_and_refresh(dev, name_label, mount_path),
                    ),
                )
                row.pack_start(eject_btn, False, False, 0)
            rows.pack_start(row, False, False, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()
        return True

    def navigate_uri_or_path(target: Path | str):
        if isinstance(target, Path):
            navigate(target)
            return
        uri = str(target)
        if uri.startswith("file://"):
            navigate(Path(urllib.parse.unquote(urllib.parse.urlparse(uri).path)))
        elif uri.startswith(("smb://", "sftp://", "ftp://", "dav://")):
            subprocess.Popen(["gio", "open", uri] if shutil.which("gio") else ["xdg-open", uri], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            status_label.set_text(f"Opening network location {uri}")
        elif uri.startswith("seven://mount"):
            mount_device_and_open(uri)
        elif uri == "seven://refresh-volumes":
            render_location_rows(True)
            set_status(tr_text("Drive list refreshed"))
        elif uri == "seven://drive-panel":
            show_drive_panel()
        elif uri == "seven://connect-server":
            connect_to_server()
        else:
            navigate(Path(uri).expanduser())

    def navigate(path: Path):
        nonlocal current, virtual_location
        if path == RECENTS_SENTINEL:
            if virtual_location != "recent":
                history.append(current)
                future.clear()
            virtual_location = "recent"
            render()
            return
        if not path.exists() or not path.is_dir():
            return
        set_busy_cursor(tr_text("Opening {name}...", name=path.name or str(path)), 360)
        if path != current or virtual_location:
            history.append(current)
            future.clear()
            current = path
            virtual_location = ""
            remember_recent(path)
        render()

    def go_back():
        nonlocal current, virtual_location
        if history:
            future.append(current)
            current = history.pop()
            virtual_location = ""
            render()

    def go_forward():
        nonlocal current, virtual_location
        if future:
            history.append(current)
            current = future.pop()
            virtual_location = ""
            render()

    def set_search_query(entry):
        nonlocal search_query
        search_query = entry.get_text().strip()
        entry.set_icon_sensitive(Gtk.EntryIconPosition.SECONDARY, bool(search_query))
        entry.get_style_context().add_class("search-active") if search_query else entry.get_style_context().remove_class("search-active")
        if search_render_state["id"]:
            GLib.source_remove(search_render_state["id"])

        def apply_search() -> bool:
            search_render_state["id"] = 0
            render()
            return False

        search_render_state["id"] = GLib.timeout_add(120, apply_search)

    def clear_search() -> bool:
        search_entry.set_text("")
        search_entry.grab_focus()
        search_entry.set_position(0)
        return True

    def entry_has_focus() -> bool:
        focus = window.get_focus()
        return isinstance(focus, Gtk.Entry)

    def cycle_sort_mode():
        nonlocal sort_mode
        try:
            index = sort_order.index(sort_mode)
        except ValueError:
            index = 0
        sort_mode = sort_order[(index + 1) % len(sort_order)]
        sort_button.set_label(sort_labels.get(sort_mode, "A-Z"))
        save_preferences()
        render()

    def set_sort_mode(mode: str) -> None:
        nonlocal sort_mode
        sort_mode = mode if mode in sort_order else "name"
        sort_button.set_label(sort_labels.get(sort_mode, "A-Z"))
        save_preferences()
        render()

    def show_sort_menu(button) -> bool:
        menu = Gtk.Menu()
        for mode in sort_order:
            item = Gtk.CheckMenuItem(label=sort_labels.get(mode, mode.title()))
            item.set_active(mode == sort_mode)
            item.connect("activate", lambda menu_item, selected=mode: set_sort_mode(selected) if menu_item.get_active() else None)
            menu.append(item)
        menu.show_all()
        try:
            menu.popup_at_widget(button, Gdk.Gravity.SOUTH_WEST, Gdk.Gravity.NORTH_WEST, None)
        except Exception:
            menu.popup(None, None, None, None, 0, Gtk.get_current_event_time())
        return True

    def show_go_panel() -> bool:
        dialog = Gtk.Dialog(title=t("Aller", "Go"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        dialog.set_default_size(560, 520)
        box = decorate_dialog(dialog, t("Aller", "Go"), t("Favoris, récents, Mini OS et emplacements réseau.", "Favorites, recents, Mini OS and network locations."), "go-jump-symbolic")
        entry = Gtk.Entry()
        entry.get_style_context().add_class("files-dialog-entry")
        entry.set_placeholder_text(t("Rechercher lieux, favoris, récents ou réseau", "Search places, favorites, recents or network"))
        entry.set_icon_from_icon_name(Gtk.EntryIconPosition.PRIMARY, "edit-find-symbolic")
        box.pack_start(entry, False, False, 0)
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        listbox = Gtk.ListBox()
        listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        scroller.add(listbox)
        box.pack_start(scroller, True, True, 0)

        places: list[tuple[str, str, Path | str]] = [
            ("SevenOS", "/", Path("/")),
        ]
        places.extend((str(item["label"]), str(item["path"]), item["path"]) for item in active_resource_places())
        if not grouped_resources and active_profile != "equinox":
            places.extend(
                [
                    (t("Accueil partagé", "Shared Home"), str(Path.home()), Path.home()),
                    (t("Téléchargements partagés", "Shared Downloads"), str(Path.home() / "Downloads"), Path.home() / "Downloads"),
                    (t("Documents partagés", "Shared Documents"), str(Path.home() / "Documents"), Path.home() / "Documents"),
                ]
            )
        places.extend((f"{t('Favori', 'Favorite')} · {path.name}", str(path), path) for path in favorite_paths())
        places.extend((f"{t('Récent', 'Recent')} · {path.name}", str(path), path) for path in recent_paths()[:20])
        places.extend((f"{t('Réseau', 'Network')} · {network_label(uri)}", uri, uri) for uri in network_places())

        def open_place(target: Path | str) -> None:
            dialog.destroy()
            navigate_uri_or_path(target)

        def rebuild(*_args) -> None:
            for row in list(listbox.get_children()):
                listbox.remove(row)
            query = entry.get_text().strip().casefold()
            matches = [item for item in places if not query or query in item[0].casefold() or query in item[1].casefold()][:22]
            if not matches:
                row = Gtk.ListBoxRow()
                row.set_selectable(False)
                label = Gtk.Label(label=t("Aucun emplacement correspondant", "No matching places"))
                label.get_style_context().add_class("preview-hint")
                label.set_margin_top(18)
                label.set_margin_bottom(18)
                row.add(label)
                listbox.add(row)
            for title, subtitle, target in matches:
                row = Gtk.ListBoxRow()
                row.target = target
                row.get_style_context().add_class("files-list-row")
                item_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                item_box.set_margin_top(8)
                item_box.set_margin_bottom(8)
                item_box.set_margin_start(10)
                item_box.set_margin_end(10)
                title_label = Gtk.Label(label=title)
                title_label.set_xalign(0)
                title_label.get_style_context().add_class("preview-value")
                subtitle_label = Gtk.Label(label=subtitle)
                subtitle_label.set_xalign(0)
                subtitle_label.get_style_context().add_class("preview-hint")
                item_box.pack_start(title_label, False, False, 0)
                item_box.pack_start(subtitle_label, False, False, 0)
                row.add(item_box)
                listbox.add(row)
            listbox.show_all()
            first = listbox.get_row_at_index(0)
            if first and hasattr(first, "target"):
                listbox.select_row(first)

        def activate_first() -> bool:
            row = listbox.get_selected_row() or listbox.get_row_at_index(0)
            if row and hasattr(row, "target"):
                open_place(row.target)
            return True

        listbox.connect("row-activated", lambda _box, row: open_place(row.target) if hasattr(row, "target") else None)
        entry.connect("changed", rebuild)
        entry.connect("activate", lambda *_: activate_first())
        rebuild()
        dialog.show_all()
        entry.grab_focus()
        response = dialog.run()
        if response == Gtk.ResponseType.CLOSE:
            dialog.destroy()
        return True

    def command_actions() -> list[tuple[str, str, object]]:
        paths = selected_paths()
        target = paths[0] if paths else None
        actions: list[tuple[str, str, object]] = []

        def add(title: str, subtitle: str, callback, enabled: bool = True) -> None:
            if enabled:
                actions.append((title, subtitle, callback))

        add(t("Ouvrir", "Open"), t("Ouvrir l'élément sélectionné", "Open selected item"), lambda: open_selected(), bool(target))
        add("Quick Look", t("Prévisualiser le fichier sélectionné", "Preview selected file"), lambda: open_quicklook_preview(target), bool(target and is_previewable(target)))
        add(t("Ouvrir app Windows", "Open Windows App"), t("Lancer .exe/.msi via Bottles, Wine ou Lutris", "Run selected .exe/.msi through Bottles, Wine or Lutris"), lambda: open_windows_compat(target), bool(target and is_windows_app_file(target)))
        add(t("Ouvrir Windows avec Bottles", "Open Windows App with Bottles"), t("Utiliser Bottles pour une expérience Windows plus guidée", "Use Bottles for a friendlier Windows app bottle flow"), lambda: open_windows_compat(target, "bottles"), bool(target and is_windows_app_file(target)))
        add(t("Ouvrir Windows avec Wine", "Open Windows App with Wine"), t("Utiliser Wine directement pour installateurs et apps portables", "Use Wine directly for installers and portable apps"), lambda: open_windows_compat(target, "wine"), bool(target and is_windows_app_file(target)))
        add(t("Ouvrir Windows avec Lutris", "Open Windows App with Lutris"), t("Utiliser Lutris pour jeux ou installateurs DirectX", "Use Lutris for game or DirectX-heavy installers"), lambda: open_windows_compat(target, "lutris"), bool(target and is_windows_app_file(target)))
        add(t("Ouvrir avec", "Open With"), t("Utiliser l'application système par défaut", "Use the default system app"), lambda: open_externally(target), bool(target and target.is_file()))
        add(t("Renommer", "Rename"), t("Renommer l'élément sélectionné", "Rename selected item"), lambda: rename_path(target), bool(target))
        add(t("Informations", "Properties"), t("Inspecter l'élément ou le dossier courant", "Inspect selected item or current folder"), lambda: properties_dialog(target or current))
        add(t("Guide Seven Files", "Seven Files Guide"), t("Raccourcis, dossiers Mini OS et volumes", "Learn core shortcuts, mini OS folders and volume actions"), show_files_guide)
        add(t("Copier", "Copy"), t("Copier la sélection", "Copy selected item(s)"), copy_selected, bool(paths))
        add(t("Couper", "Cut"), t("Couper la sélection", "Cut selected item(s)"), cut_selected, bool(paths))
        add(t("Coller", "Paste"), t("Coller ici les éléments du presse-papiers", "Paste clipboard item(s) here"), paste_items)
        add(t("Mettre à la corbeille", "Move to Trash"), t("Envoyer la sélection à la corbeille", "Send selected item(s) to Trash"), trash_selected, bool(paths))
        add(t("Annuler dernière action", "Undo Last Action"), t("Annuler la dernière action compatible", "Reverse the last supported file action"), undo_last_action, bool(undo_stack))
        add(t("Aller", "Go"), t("Ouvrir récents, favoris et réseau", "Open recents, favorites and network places"), show_go_panel)
        add(t("Nouveau dossier", "New Folder"), t("Créer un dossier ici", "Create a folder in the current location"), create_folder)
        add(t("Nouveau fichier", "New File"), t("Créer un fichier ici", "Create a file in the current location"), create_file)
        add(t("Ouvrir le terminal ici", "Open Terminal Here"), t("Lancer Seven Terminal dans ce dossier", "Launch Seven Terminal in this folder"), lambda: open_terminal_here(current))
        add(t("Aller à un chemin", "Go to Path"), t("Saisir un chemin du système de fichiers", "Type a filesystem path"), show_location_entry)
        add(t("Se connecter à un serveur", "Connect to Server"), t("Ouvrir SMB, SFTP, WebDAV ou FTP", "Open SMB, SFTP, WebDAV or FTP"), connect_to_server)
        add(
            t("Utiliser les ressources partagées", "Use Shared Resources") if not grouped_resources else t("Utiliser les ressources Mini OS", "Use Mini OS Resources"),
            t("Basculer entre bibliothèque globale et dossiers Mini OS", "Switch between global folders and active mini OS folders"),
            toggle_grouped_resources,
        )
        add(t("Afficher fichiers cachés", "Toggle Hidden Files"), t("Afficher ou masquer les fichiers point", "Show or hide dotfiles"), toggle_hidden)
        add(t("Afficher barre latérale", "Toggle Sidebar"), t("Afficher ou masquer la navigation gauche", "Show or hide the left navigation sidebar"), toggle_sidebar_visibility)
        add(t("Afficher inspecteur", "Toggle Preview"), t("Afficher ou masquer le panneau d'inspection", "Show or hide the right inspector panel"), toggle_preview_visibility)
        add(t("Actualiser le dossier", "Refresh Folder"), t("Recharger dossier et volumes", "Reload current folder and volumes"), refresh_current)
        add(t("Actualiser index recherche", "Refresh Search Index"), t("Reconstruire le cache de recherche local", "Rebuild local search cache"), reindex_now)
        add(t("Nettoyer cache aperçus", "Clean Thumbnail Cache"), t("Supprimer les aperçus générés", "Clear generated image, PDF and video previews"), clean_thumbnail_cache)
        add(t("Réinitialiser session", "Reset Saved Session"), t("Effacer onglets et taille enregistrés", "Clear saved tabs and window size"), reset_saved_session)
        add(t("Calculer la taille", "Calculate Size"), t("Mesurer dossier sélectionné ou courant", "Measure selected folder or current folder"), lambda: calculate_size_for_path(target or current))
        add(t("Vue scindée", "Split View"), t("Activer/désactiver la vue côte à côte", "Toggle side-by-side file view"), toggle_split_view)
        add(t("Copier vers split", "Copy to Split"), t("Copier la sélection vers le panneau split", "Copy selected item(s) to split pane"), lambda: copy_selected_to_split(False), bool(paths and split_visible))
        add(t("Déplacer vers split", "Move to Split"), t("Déplacer la sélection vers le panneau split", "Move selected item(s) to split pane"), lambda: copy_selected_to_split(True), bool(paths and split_visible))
        add(t("Compresser", "Compress"), t("Créer une archive depuis la sélection", "Create an archive from selection"), compress_selected, bool(paths))
        add(t("Copier SHA256", "Copy SHA256"), t("Calculer l'empreinte du fichier", "Hash selected file"), hash_selected, bool(target and target.is_file()))
        add(t("Demander à SevenAI", "Ask SevenAI"), t("Analyser la sélection avec SevenAI", "Analyze selection with SevenAI"), sevenai_selected, bool(paths))
        add(t("Vue grille", "Grid View"), t("Passer en disposition grille", "Switch to grid layout"), lambda: set_view_mode("grid"))
        add(t("Vue liste", "List View"), t("Passer en disposition liste", "Switch to list layout"), lambda: set_view_mode("list"))
        add(t("Vue compacte", "Compact View"), t("Passer en disposition compacte", "Switch to compact layout"), lambda: set_view_mode("compact"))
        for mode in sort_order:
            add(t("Trier par {label}", "Sort by {label}", label=sort_labels.get(mode, mode.title())), t("Changer l'ordre du dossier courant", "Change current folder ordering"), lambda selected=mode: set_sort_mode(selected))
        return actions

    def show_command_palette() -> bool:
        dialog = Gtk.Dialog(title=t("Actions Seven Files", "Seven Files Actions"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        dialog.set_default_size(520, 520)
        box = decorate_dialog(dialog, t("Actions Seven Files", "Seven Files Actions"), t("Recherche rapide des commandes utiles.", "Fast search for useful commands."), "open-menu-symbolic")
        entry = Gtk.Entry()
        entry.get_style_context().add_class("files-dialog-entry")
        entry.set_placeholder_text(t("Rechercher une action", "Search actions"))
        entry.set_icon_from_icon_name(Gtk.EntryIconPosition.PRIMARY, "edit-find-symbolic")
        box.pack_start(entry, False, False, 0)
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        listbox = Gtk.ListBox()
        listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        scroller.add(listbox)
        box.pack_start(scroller, True, True, 0)
        actions = command_actions()

        def run_action(callback) -> None:
            dialog.destroy()
            callback()

        def rebuild(*_args) -> None:
            for row in list(listbox.get_children()):
                listbox.remove(row)
            query = entry.get_text().strip().casefold()
            matches = [
                item for item in actions
                if not query or query in item[0].casefold() or query in item[1].casefold()
            ][:18]
            if not matches:
                row = Gtk.ListBoxRow()
                row.set_selectable(False)
                label = Gtk.Label(label=t("Aucune action correspondante", "No matching actions"))
                label.get_style_context().add_class("preview-hint")
                label.set_margin_top(18)
                label.set_margin_bottom(18)
                row.add(label)
                listbox.add(row)
            for title, subtitle, callback in matches:
                row = Gtk.ListBoxRow()
                row.action_callback = callback
                row.get_style_context().add_class("files-list-row")
                item_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                item_box.set_margin_top(8)
                item_box.set_margin_bottom(8)
                item_box.set_margin_start(10)
                item_box.set_margin_end(10)
                title_label = Gtk.Label(label=title)
                title_label.set_xalign(0)
                title_label.get_style_context().add_class("preview-value")
                subtitle_label = Gtk.Label(label=subtitle)
                subtitle_label.set_xalign(0)
                subtitle_label.get_style_context().add_class("preview-hint")
                item_box.pack_start(title_label, False, False, 0)
                item_box.pack_start(subtitle_label, False, False, 0)
                row.add(item_box)
                listbox.add(row)
            listbox.show_all()
            first = listbox.get_row_at_index(0)
            if first and getattr(first, "action_callback", None):
                listbox.select_row(first)

        def activate_first() -> bool:
            row = listbox.get_selected_row() or listbox.get_row_at_index(0)
            callback = getattr(row, "action_callback", None) if row else None
            if callback:
                run_action(callback)
            return True

        listbox.connect("row-activated", lambda _box, row: run_action(row.action_callback) if getattr(row, "action_callback", None) else None)
        entry.connect("changed", rebuild)
        entry.connect("activate", lambda *_: activate_first())
        rebuild()
        dialog.show_all()
        entry.grab_focus()
        response = dialog.run()
        if response == Gtk.ResponseType.CLOSE:
            dialog.destroy()
        return True

    def activate(_flow, child):
        if child is None:
            return
        open_selected(child.path)

    def update_selection_bar(paths: list[Path]) -> None:
        if not paths:
            selection_label.set_text(t("Aucune sélection", "No selection"))
            for button in selection_primary_buttons + [selection_more_btn]:
                button.hide()
            selection_bar.show()
            return
        files = [path for path in paths if path.is_file()]
        folders = [path for path in paths if path.is_dir()]
        total = 0
        for path in files:
            try:
                total += path.stat().st_size
            except OSError:
                pass
        parts = [tr_text("{count} selected", count=len(paths))]
        if files:
            parts.append(tr_text("{count} file(s)", count=len(files)))
        if folders:
            parts.append(tr_text("{count} folder(s)", count=len(folders)))
        if total:
            parts.append(format_size(total))
        if len(paths) == 1:
            parts.append(kind_label(paths[0]))
        parts.append(t("actions dans ...", "actions in ..."))
        selection_label.set_text(" · ".join(parts))
        selection_bar.show()
        if len(paths) == 1 and paths[0].is_dir():
            selection_primary_buttons[0].set_label(t("Ouvrir", "Open"))
            selection_primary_buttons[0].set_tooltip_text(t("Ouvrir le dossier", "Open folder"))
            selection_primary_buttons[1].set_label(t("Copier", "Copy"))
            selection_primary_buttons[1].set_tooltip_text(t("Copier le dossier", "Copy folder"))
        elif len(paths) == 1 and is_windows_app_file(paths[0]):
            selection_primary_buttons[0].set_label(t("Windows", "Windows"))
            selection_primary_buttons[0].set_tooltip_text(t("Lancer via Wine, Bottles ou Lutris", "Run through Wine, Bottles or Lutris"))
            selection_primary_buttons[1].set_label(t("Copier", "Copy"))
            selection_primary_buttons[1].set_tooltip_text(t("Copier le fichier", "Copy file"))
        elif len(paths) == 1:
            selection_primary_buttons[0].set_label(t("Aperçu", "Preview") if is_previewable(paths[0]) else t("Ouvrir", "Open"))
            selection_primary_buttons[0].set_tooltip_text(t("Prévisualiser ou ouvrir", "Preview or open"))
            selection_primary_buttons[1].set_label(t("Copier", "Copy"))
            selection_primary_buttons[1].set_tooltip_text(t("Copier le fichier", "Copy file"))
        else:
            selection_primary_buttons[0].set_label(t("Ouvrir", "Open"))
            selection_primary_buttons[0].set_tooltip_text(t("Ouvrir le premier élément", "Open first item"))
            selection_primary_buttons[1].set_label(t("Copier", "Copy"))
            selection_primary_buttons[1].set_tooltip_text(t("Copier la sélection", "Copy selection"))
        width = window.get_size()[0]
        for button in selection_primary_buttons:
            button.set_visible(width >= 560)
        selection_more_btn.set_visible(True)
        selection_bar.show()

    def selection_changed(flow_box):
        selected = flow_box.get_selected_children()
        selected_paths_for_bar = [child.path for child in selected]
        update_selection_bar(selected_paths_for_bar)
        location = "Recents" if virtual_location == "recent" else str(current)
        if len(selected) > 1:
            update_preview_multiple(selected_paths_for_bar)
            width = window.get_size()[0]
            selected_text = t("{count} sélectionnés", "{count} selected", count=len(selected))
            status_label.set_text(
                f"{selected_text} · {Path(location).name or location}" if width < 760 else f"{selected_text}  |  {location}"
            )
        elif selected:
            update_preview(selected[0].path)
            status_label.set_text(t("Sélection · {name}", "Selected · {name}", name=selected[0].path.name or str(selected[0].path)))
        else:
            update_preview_multiple(recent_paths()) if virtual_location == "recent" else update_preview(current)

    def toggle_sidebar_visibility() -> bool:
        nonlocal sidebar_visible_pref, runtime_sidebar_visible
        sidebar_visible_pref = not sidebar_visible_pref
        runtime_sidebar_visible = sidebar_visible_pref
        if runtime_sidebar_visible:
            sidebar.show_all()
        sidebar.set_visible(runtime_sidebar_visible)
        adapt_layout(window, type("SevenFilesLayoutEvent", (), {"width": window.get_size()[0], "height": window.get_size()[1]})())
        save_preferences()
        set_status(tr_text("Sidebar shown") if sidebar_visible_pref else tr_text("Sidebar hidden"))
        return True

    def toggle_preview_visibility() -> bool:
        nonlocal preview_visible_pref, runtime_preview_visible
        preview_visible_pref = not preview_visible_pref
        runtime_preview_visible = preview_visible_pref
        width, height = window.get_size()
        if runtime_preview_visible and width < 960:
            window.unmaximize()
            window.resize(max(COMFORT_WINDOW_SIZE[0], width), max(height, DEFAULT_WINDOW_SIZE[1]))
            preview.set_visible(True)
            set_status(t("Inspecteur ouvert avec plus d'espace", "Inspector opened with more room"))
        else:
            preview.set_visible(runtime_preview_visible)
            set_status(tr_text("Preview shown") if preview_visible_pref else tr_text("Preview hidden"))
        next_width, next_height = window.get_size()
        layout_width = COMFORT_WINDOW_SIZE[0] if runtime_preview_visible and width < 960 else max(width, next_width)
        adapt_layout(window, type("SevenFilesLayoutEvent", (), {"width": layout_width, "height": max(height, next_height)})())
        if runtime_preview_visible:
            preview.set_visible(True)
        save_preferences()
        return True

    def toggle_grouped_resources() -> bool:
        nonlocal grouped_resources
        grouped_resources = not grouped_resources
        save_preferences()
        render_resource_rows()
        render()
        set_status(
            tr_text("Shared resource folders enabled")
            if grouped_resources
            else tr_text("Mini OS resource folders enabled")
        )
        return True

    def start_inline_search(event) -> bool:
        if event.state & (
            Gdk.ModifierType.CONTROL_MASK
            | Gdk.ModifierType.MOD1_MASK
            | Gdk.ModifierType.SUPER_MASK
            | Gdk.ModifierType.META_MASK
        ):
            return False
        if event.keyval in (
            Gdk.KEY_Return,
            Gdk.KEY_KP_Enter,
            Gdk.KEY_space,
            Gdk.KEY_Tab,
            Gdk.KEY_BackSpace,
            Gdk.KEY_Delete,
            Gdk.KEY_Escape,
            Gdk.KEY_Left,
            Gdk.KEY_Right,
            Gdk.KEY_Up,
            Gdk.KEY_Down,
            Gdk.KEY_Home,
            Gdk.KEY_End,
            Gdk.KEY_Page_Up,
            Gdk.KEY_Page_Down,
        ):
            return False
        codepoint = Gdk.keyval_to_unicode(event.keyval)
        if not codepoint:
            return False
        char = chr(codepoint)
        if not char.isprintable() or char.isspace():
            return False
        search_entry.grab_focus()
        search_entry.set_text(char)
        search_entry.set_position(-1)
        set_status(t("Recherche instantanée", "Instant search"))
        return True

    def on_key(_window, event):
        if entry_has_focus():
            if event.state & Gdk.ModifierType.CONTROL_MASK:
                if event.keyval in (Gdk.KEY_f, Gdk.KEY_F):
                    search_entry.grab_focus()
                    search_entry.select_region(0, -1)
                    return True
                if event.keyval in (Gdk.KEY_l, Gdk.KEY_L):
                    show_location_entry()
                    return True
                return False
            if event.keyval == Gdk.KEY_Escape:
                if window.get_focus() == search_entry:
                    clear_search()
                    flow.grab_focus()
                    return True
                if window.get_focus() == location_entry:
                    hide_location_entry()
                    return True
            return False
        if event.keyval == Gdk.KEY_Escape:
            if flow.get_selected_children():
                flow.unselect_all()
                update_selection_bar([])
                render()
                flow.grab_focus()
                return True
            if search_query:
                clear_search()
                flow.grab_focus()
                return True
            window.close()
            return True
        if event.keyval == Gdk.KEY_BackSpace:
            go_back()
            return True
        if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            if event.state & Gdk.ModifierType.CONTROL_MASK:
                target = selected_path()
                if target and target.is_dir():
                    new_tab(target)
                    return True
            open_selected()
            return True
        if start_inline_search(event):
            return True
        if event.keyval == Gdk.KEY_Delete:
            trash_selected()
            return True
        if event.keyval == Gdk.KEY_F2:
            target = selected_path()
            if target:
                rename_path(target)
            return True
        if event.keyval == Gdk.KEY_space:
            target = selected_path()
            if target and target.suffix.lower() in READER_SUFFIXES:
                open_in_reader(target)
                return True
            if target and is_previewable(target):
                open_quicklook_preview(target)
                return True
        if event.keyval in (Gdk.KEY_Menu, Gdk.KEY_F10) and (
            event.keyval == Gdk.KEY_Menu or event.state & Gdk.ModifierType.SHIFT_MASK
        ):
            target = selected_path()
            if target:
                show_context_menu(target, event)
                return True
        if event.keyval in (
            Gdk.KEY_Left,
            Gdk.KEY_Right,
            Gdk.KEY_Up,
            Gdk.KEY_Down,
            Gdk.KEY_Home,
            Gdk.KEY_End,
            Gdk.KEY_Page_Up,
            Gdk.KEY_Page_Down,
        ):
            move_keyboard_selection(event.keyval)
            return True
        if event.state & Gdk.ModifierType.CONTROL_MASK:
            if event.keyval in (Gdk.KEY_z, Gdk.KEY_Z):
                undo_last_action()
                return True
            if event.keyval in (Gdk.KEY_k, Gdk.KEY_K):
                show_command_palette()
                return True
            if event.state & Gdk.ModifierType.SHIFT_MASK and event.keyval in (Gdk.KEY_n, Gdk.KEY_N):
                create_folder()
                return True
            if event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
                copy_selected()
                return True
            if event.keyval in (Gdk.KEY_x, Gdk.KEY_X):
                cut_selected()
                return True
            if event.keyval in (Gdk.KEY_v, Gdk.KEY_V):
                paste_items()
                return True
            if event.keyval in (Gdk.KEY_t, Gdk.KEY_T):
                new_tab(current)
                return True
            if event.keyval in (Gdk.KEY_w, Gdk.KEY_W):
                close_tab()
                return True
            if event.keyval in (Gdk.KEY_a, Gdk.KEY_A):
                flow.select_all()
                return True
            if event.keyval in (Gdk.KEY_f, Gdk.KEY_F):
                search_entry.grab_focus()
                search_entry.select_region(0, -1)
                return True
            if event.keyval in (Gdk.KEY_h, Gdk.KEY_H):
                toggle_hidden()
                return True
            if event.keyval in (Gdk.KEY_n, Gdk.KEY_N):
                create_file()
                return True
            if event.keyval in (Gdk.KEY_r, Gdk.KEY_R):
                refresh_current()
                return True
            if event.keyval in (Gdk.KEY_l, Gdk.KEY_L):
                show_location_entry()
                return True
            if event.keyval in (Gdk.KEY_g, Gdk.KEY_G):
                show_go_panel()
                return True
            if event.keyval in (Gdk.KEY_i, Gdk.KEY_I):
                toggle_preview_visibility()
                return True
            if event.keyval in (Gdk.KEY_b, Gdk.KEY_B):
                toggle_sidebar_visibility()
                return True
            if event.keyval in (Gdk.KEY_d, Gdk.KEY_D):
                toggle_split_view()
                return True
        if event.state & Gdk.ModifierType.MOD1_MASK and event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
            compress_selected()
            return True
        if event.state & Gdk.ModifierType.MOD1_MASK and event.keyval in (Gdk.KEY_s, Gdk.KEY_S):
            calculate_size_for_path()
            return True
        return False

    def adapt_layout(_window, event):
        width = getattr(event, "width", DEFAULT_WINDOW_SIZE[0])
        height = getattr(event, "height", DEFAULT_WINDOW_SIZE[1])
        compact = width < 760 or height < 420
        actions_group.set_visible(width >= 900 and not compact)
        view_group.set_visible(width >= 960 and not compact)
        context_chips.set_visible(width >= 960)
        search_entry.set_visible(width >= 920)
        sort_button.set_visible(width >= 760)
        for button in selection_primary_buttons:
            button.set_visible(width >= 560)
        selection_more_btn.set_visible(bool(flow.get_selected_children()))
        if len(tabs) <= 1 and width < 900:
            tabbar.set_visible(False)
        elif tabs:
            tabbar.set_visible(True)
        def apply_sidebar_visibility(visible: bool) -> None:
            if visible:
                sidebar.show_all()
            sidebar.set_visible(visible)

        if width < MIN_WINDOW_SIZE[0]:
            sidebar.set_visible(False)
            preview.set_visible(False)
            search_entry.set_size_request(52, 22)
            location_entry.set_size_request(130, 24)
            sort_button.set_size_request(34, 24)
        elif width < 960:
            apply_sidebar_visibility(runtime_sidebar_visible)
            preview.set_visible(False)
            search_entry.set_size_request(58, 22)
            location_entry.set_size_request(150, 24)
            sort_button.set_size_request(36, 24)
        else:
            apply_sidebar_visibility(runtime_sidebar_visible)
            preview.set_visible(runtime_preview_visible)
            search_entry.set_size_request(76, 22)
            location_entry.set_size_request(220, 24)
            sort_button.set_size_request(38, 24)
        return False

    def ensure_child_visible(child) -> bool:
        if not child:
            return False
        adjustment = scroller.get_vadjustment()
        allocation = child.get_allocation()
        child_top = allocation.y
        child_bottom = allocation.y + allocation.height
        visible_top = adjustment.get_value()
        visible_bottom = visible_top + adjustment.get_page_size()
        padding = 18
        if child_top < visible_top + padding:
            adjustment.set_value(max(adjustment.get_lower(), child_top - padding))
        elif child_bottom > visible_bottom - padding:
            max_value = max(adjustment.get_lower(), adjustment.get_upper() - adjustment.get_page_size())
            adjustment.set_value(min(max_value, max(adjustment.get_lower(), child_bottom - adjustment.get_page_size() + padding)))
        return False

    def move_keyboard_selection(keyval: int):
        children = flow.get_children()
        if not children:
            return
        selected = flow.get_selected_children()
        if selected and selected[0] in children:
            index = children.index(selected[0])
        else:
            index = 0
        columns = 1 if view_mode == "list" else 2 if view_mode == "compact" else max(1, min(current_grid_columns(), len(children)))
        if keyval == Gdk.KEY_Home:
            index = 0
        elif keyval == Gdk.KEY_End:
            index = len(children) - 1
        elif keyval == Gdk.KEY_Page_Up:
            index = max(0, index - max(columns * 3, 1))
        elif keyval == Gdk.KEY_Page_Down:
            index = min(len(children) - 1, index + max(columns * 3, 1))
        elif keyval == Gdk.KEY_Left:
            index = max(0, index - 1)
        elif keyval == Gdk.KEY_Right:
            index = min(len(children) - 1, index + 1)
        elif keyval == Gdk.KEY_Up:
            index = max(0, index - columns)
        elif keyval == Gdk.KEY_Down:
            index = min(len(children) - 1, index + columns)
        child = children[index]
        flow.select_child(child)
        child.grab_focus()
        update_preview(child.path)
        GLib.idle_add(lambda: ensure_child_visible(child))

    def rects_intersect(a: tuple[int, int, int, int], b: tuple[int, int, int, int]) -> bool:
        ax, ay, aw, ah = a
        bx, by, bw, bh = b
        return ax < bx + bw and ax + aw > bx and ay < by + bh and ay + ah > by

    def update_rubberband_widget() -> None:
        x = rubberband_rect["x"]
        y = rubberband_rect["y"]
        w = max(1, rubberband_rect["w"])
        h = max(1, rubberband_rect["h"])
        rubberband.set_margin_start(x)
        rubberband.set_margin_top(y)
        rubberband.set_size_request(w, h)
        rubberband.set_visible(bool(rubberband_rect["active"]))
        rubberband.queue_draw()

    def select_children_in_rect() -> None:
        area = (rubberband_rect["x"], rubberband_rect["y"], rubberband_rect["w"], rubberband_rect["h"])
        flow.unselect_all()
        selected = []
        for child in flow.get_children():
            alloc = child.get_allocation()
            child_rect = (alloc.x, alloc.y, alloc.width, alloc.height)
            if rects_intersect(area, child_rect):
                flow.select_child(child)
                selected.append(child.path)
        if len(selected) > 1:
            update_preview_multiple(selected)
        elif selected:
            update_preview(selected[0])
        else:
            update_preview(current)

    def on_flow_button_press(_flow, event) -> bool:
        nonlocal rubberband_origin
        if getattr(event, "button", 0) != 1:
            return False
        try:
            if flow.get_child_at_pos(int(event.x), int(event.y)) is not None:
                return False
        except Exception:
            pass
        rubberband_origin = (int(event.x), int(event.y))
        rubberband_rect.update({"x": int(event.x), "y": int(event.y), "w": 1, "h": 1, "active": True})
        update_rubberband_widget()
        flow.grab_focus()
        return True

    def on_flow_motion(_flow, event) -> bool:
        if rubberband_origin is None:
            return False
        origin_x, origin_y = rubberband_origin
        x = int(min(origin_x, event.x))
        y = int(min(origin_y, event.y))
        w = int(abs(event.x - origin_x))
        h = int(abs(event.y - origin_y))
        rubberband_rect.update({"x": x, "y": y, "w": w, "h": h, "active": True})
        update_rubberband_widget()
        select_children_in_rect()
        return True

    def on_flow_button_release(_flow, event) -> bool:
        nonlocal rubberband_origin
        if rubberband_origin is None or getattr(event, "button", 0) != 1:
            return False
        select_children_in_rect()
        rubberband_origin = None
        rubberband_rect["active"] = False
        update_rubberband_widget()
        return True

    search_entry.connect("changed", set_search_query)
    search_entry.connect(
        "icon-release",
        lambda _entry, position, _event: clear_search() if position == Gtk.EntryIconPosition.SECONDARY else False,
    )
    search_entry.connect(
        "key-press-event",
        lambda _entry, event: clear_search() if event.keyval == Gdk.KEY_Escape else False,
    )
    location_entry.connect("activate", lambda *_: commit_location_entry())
    location_entry.connect("focus-out-event", lambda *_: hide_location_entry())
    location_entry.connect(
        "key-press-event",
        lambda _entry, event: hide_location_entry() if event.keyval == Gdk.KEY_Escape else False,
    )
    sort_button.connect("clicked", lambda button: show_sort_menu(button))
    sort_button.connect("pressed", lambda widget: press_feedback(widget))
    sort_button.connect("released", lambda widget: release_feedback(widget))
    setup_current_drop_target(flow)
    flow.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK | Gdk.EventMask.POINTER_MOTION_MASK)
    flow.connect("button-press-event", on_flow_button_press)
    flow.connect("motion-notify-event", on_flow_motion)
    flow.connect("button-release-event", on_flow_button_release)
    flow.connect("child-activated", activate)
    flow.connect("selected-children-changed", selection_changed)
    flow.connect("key-press-event", on_key)
    split_flow.connect("child-activated", lambda _flow, child: navigate_split(child.path) if child and child.path.is_dir() else None)
    window.connect("key-press-event", on_key)
    window.connect("configure-event", adapt_layout)

    def on_destroy(_window) -> None:
        monitor = folder_monitor_state.get("monitor")
        if monitor:
            try:
                monitor.cancel()
            except Exception:
                pass
        if folder_monitor_state["render_id"]:
            try:
                GLib.source_remove(folder_monitor_state["render_id"])
            except Exception:
                pass
        save_session()
        Gtk.main_quit()

    window.connect("destroy", on_destroy)
    restored_size = restore_session(explicit_start)
    if not tabs:
        tabs.append({"path": current, "virtual": virtual_location, "history": [], "future": []})
    requested_size = restored_size or screen_window_size()
    if runtime_sidebar_visible and requested_size[0] < DEFAULT_WINDOW_SIZE[0]:
        requested_size = (DEFAULT_WINDOW_SIZE[0], requested_size[1])
    initial_size = compact_window_size(*requested_size)
    window.set_default_size(*initial_size)
    window.resize(*initial_size)
    render()
    root.show_all()
    sidebar.set_visible(runtime_sidebar_visible)
    actions_group.set_visible(False)
    view_group.set_visible(False)
    context_chips.set_visible(False)
    preview.set_visible(False)
    if len(tabs) <= 1:
        tabbar.set_visible(False)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.unfullscreen()
    window.unmaximize()
    window.resize(*initial_size)
    adapt_layout(window, type("SevenFilesInitialLayout", (), {"width": initial_size[0], "height": initial_size[1]})())
    window.show()
    if restored_size:
        set_status(tr_text("Restored previous Seven Files session"))
    Gtk.main()
    return 0


def toggle_zoom_or_tile(window) -> None:
    window.present()
    target_width, target_height = COMFORT_WINDOW_SIZE
    try:
        screen = Gdk.Screen.get_default()
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() if display else None
        if monitor is None and display is not None:
            monitor = display.get_monitor_at_point(0, 0)
        if monitor is not None:
            workarea = monitor.get_workarea()
            target_width = min(COMFORT_WINDOW_SIZE[0], max(DEFAULT_WINDOW_SIZE[0], workarea.width - 96))
            target_height = min(COMFORT_WINDOW_SIZE[1], max(DEFAULT_WINDOW_SIZE[1], workarea.height - 104))
        elif screen is not None:
            target_width = min(COMFORT_WINDOW_SIZE[0], max(DEFAULT_WINDOW_SIZE[0], screen.get_width() - 96))
            target_height = min(COMFORT_WINDOW_SIZE[1], max(DEFAULT_WINDOW_SIZE[1], screen.get_height() - 104))
    except Exception:
        pass
    width, _height = window.get_size()
    if width >= target_width - 20:
        window.resize(*DEFAULT_WINDOW_SIZE)
    else:
        window.unmaximize()
        window.resize(target_width, target_height)


def minimize_window(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        for command in (
            ["hyprctl", "dispatch", "movetoworkspacesilent", "special:seven"],
            ["hyprctl", "dispatch", "movetoworkspace", "special:seven"],
        ):
            result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                return
    window.iconify()


def format_size(size: int) -> str:
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{size} B"


def begin_move(window, event) -> bool:
    if getattr(event, "button", 0) == 1:
        window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
        return True
    return False


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("path", nargs="?", default="")
    args = parser.parse_args()
    if args.probe:
        return probe()
    return run_files(args.path)


if __name__ == "__main__":
    raise SystemExit(main())
