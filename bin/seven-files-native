    def update_sidebar():
        for row in sidebar_buttons:
            ctx = row.get_style_context()
            place_path = getattr(row, "place_path", None)
            is_mini_os_row = bool(getattr(row, "mini_os_profile", ""))
            in_mini_os_root = False
            if is_mini_os_row and isinstance(place_path, Path):
                try:
                    profile = str(getattr(row, "mini_os_profile", ""))
                    in_mini_os_root = current == place_path or (profile != "equinox" and current.is_relative_to(place_path))
                except Exception:
                    in_mini_os_root = False
            if (virtual_location == "recent" and place_path == RECENTS_SENTINEL) or place_path == current or in_mini_os_root:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")

    def tab_title(path: Path, virtual: str = "") -> str:
        if virtual == "recent":
            return "Recents"
        return "Home" if path == Path.home() else (path.name or "SevenOS")

    def sync_current_tab() -> None:
        if not tabs:
            return
        tabs[active_tab_index] = {
            "path": current,
            "virtual": virtual_location,
            "history": list(history),
            "future": list(future),
        }

    def show_tab_menu(button, index: int, event) -> bool:
        menu = Gtk.Menu()
        tab = tabs[index]
        path = tab.get("path", Path.home())
        actions = [
            ("Open Tab", lambda: switch_tab(index)),
            ("Duplicate Tab", lambda: new_tab(path, str(tab.get("virtual", "")))),
            ("Close Tab", lambda: close_tab(index)),
        ]
        if isinstance(path, Path):
            actions.append(("Add Tab Folder to Favorites", lambda: add_favorite_path(path)))
        for label, callback in actions:
            item = Gtk.MenuItem(label=label)
            item.connect("activate", lambda _item, action=callback: action())
            menu.append(item)
        menu.show_all()
        try:
            menu.popup_at_pointer(event)
        except AttributeError:
            menu.popup(None, None, None, None, getattr(event, "button", 0), getattr(event, "time", Gtk.get_current_event_time()))
        return True

    def render_tabs() -> None:
        for child in tabbar.get_children():
            tabbar.remove(child)
        if len(tabs) <= 1 and window.get_size()[0] < 900:
            tabbar.set_visible(False)
            return
        tabbar.set_visible(True)
        for index, tab in enumerate(tabs):
            label = tab_title(tab.get("path", Path.home()), str(tab.get("virtual", "")))
            button = Gtk.Button(label=label)
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("files-tab")
            if index == active_tab_index:
                button.get_style_context().add_class("active")
            button.connect("clicked", lambda _button, tab_index=index: switch_tab(tab_index))
            button.connect(
                "button-press-event",
                lambda widget, event, tab_index=index: close_tab(tab_index)
                if getattr(event, "button", 0) == 2
                else show_tab_menu(widget, tab_index, event)
                if getattr(event, "button", 0) == 3
                else False,
            )
            tabbar.pack_start(button, False, False, 0)
        add_button = Gtk.Button(label="+")
        add_button.set_relief(Gtk.ReliefStyle.NONE)
        add_button.get_style_context().add_class("files-tab")
        add_button.set_tooltip_text(tr_text("New tab"))
        add_button.connect("clicked", lambda *_: new_tab(current))
        tabbar.pack_start(add_button, False, False, 0)
        tabbar.show_all()

    def current_scope_label(global_query: bool = False, tag_query: bool = False) -> str:
        if global_query:
            return t("Recherche globale", "Global search")
        if tag_query:
            return t("Tags", "Tags")
        if virtual_location == "recent":
            return t("Récents", "Recents")
        return t("Local", "Local")

    def view_mode_label() -> str:
        return {
            "grid": t("Grille", "Grid"),
            "list": t("Liste", "List"),
            "compact": t("Compact", "Compact"),
        }.get(view_mode, view_mode.title())

    def update_context_strip(total_entries: int, global_query: bool = False, tag_query: bool = False) -> None:
        for chip in context_chips.get_children():
            context_chips.remove(chip)
        context_title.set_text(path_label(current) if virtual_location != "recent" else t("Récents", "Recents"))
        context_subtitle.set_text(str(current) if virtual_location != "recent" else t("Documents et dossiers ouverts récemment", "Recently opened files and folders"))
        resource_text = t("Partagé", "Shared") if grouped_resources or active_profile == "equinox" else profile_title(active_profile, profile_ui)
        chips = [
            f"{total_entries} {t('éléments', 'items')}",
            current_scope_label(global_query, tag_query),
            view_mode_label(),
            resource_text,
        ]
        for text in chips:
            chip = Gtk.Label(label=text)
            chip.get_style_context().add_class("files-context-chip")
            context_chips.pack_start(chip, False, False, 0)
        context_chips.show_all()

    def switch_tab(index: int) -> bool:
        nonlocal current, virtual_location, history, future, active_tab_index
        if index < 0 or index >= len(tabs) or index == active_tab_index:
            return False
        sync_current_tab()
        active_tab_index = index
        tab = tabs[index]
        current = tab.get("path", Path.home())
        virtual_location = str(tab.get("virtual", ""))
        history = list(tab.get("history", []))
        future = list(tab.get("future", []))
        clear_search()
        render()
        return True

    def new_tab(path: Path | None = None, virtual: str = "") -> bool:
        nonlocal current, virtual_location, history, future, active_tab_index
        sync_current_tab()
        tabs.append({"path": path or Path.home(), "virtual": virtual, "history": [], "future": []})
        active_tab_index = len(tabs) - 1
        current = path or Path.home()
        virtual_location = virtual
        history = []
        future = []
        clear_search()
        render()
        return True

    def close_tab(index: int | None = None) -> bool:
        nonlocal current, virtual_location, history, future, active_tab_index
        if len(tabs) <= 1:
            window.close()
            return True
        target = active_tab_index if index is None else index
        if target < 0 or target >= len(tabs):
            return False
        tabs.pop(target)
        if target < active_tab_index:
            active_tab_index -= 1
        active_tab_index = min(active_tab_index, len(tabs) - 1)
        tab = tabs[active_tab_index]
        current = tab.get("path", Path.home())
        virtual_location = str(tab.get("virtual", ""))
        history = list(tab.get("history", []))
        future = list(tab.get("future", []))
        render()
        return True

    def show_history_menu(button, items: list[Path], reverse: bool = True) -> bool:
        menu = Gtk.Menu()
        source = list(reversed(items)) if reverse else list(items)
        for path in source[:12]:
            item = Gtk.MenuItem(label=tab_title(path))
            item.connect("activate", lambda _item, target=path: navigate(target))
            menu.append(item)
        if not source:
            item = Gtk.MenuItem(label=tr_text("No history"))
            item.set_sensitive(False)
            menu.append(item)
        menu.show_all()
        try:
            menu.popup_at_widget(button, Gdk.Gravity.SOUTH_WEST, Gdk.Gravity.NORTH_WEST, None)
        except Exception:
            menu.popup(None, None, None, None, 0, Gtk.get_current_event_time())
        return True

    back_btn.connect("button-press-event", lambda button, event: show_history_menu(button, history) if getattr(event, "button", 0) == 3 else False)
    forward_btn.connect("button-press-event", lambda button, event: show_history_menu(button, future, reverse=False) if getattr(event, "button", 0) == 3 else False)

    def press_feedback(widget) -> bool:
        widget.get_style_context().add_class("pressed")
        return False

    def release_feedback(widget) -> bool:
        widget.get_style_context().remove_class("pressed")
        return False

    def set_busy_cursor(message: str = "", duration_ms: int = 520) -> None:
        if message:
            status_label.set_text(message)
        gdk_window = window.get_window()
        display = Gdk.Display.get_default()
        if not gdk_window or not display:
            return
        cursor = Gdk.Cursor.new_from_name(display, "progress") or Gdk.Cursor.new_from_name(display, "watch")
        if cursor:
            gdk_window.set_cursor(cursor)
            if feedback_state["cursor_id"]:
                try:
                    GLib.source_remove(feedback_state["cursor_id"])
                except Exception:
                    pass

            def clear_cursor() -> bool:
                feedback_state["cursor_id"] = 0
                if window.get_window():
                    window.get_window().set_cursor(None)
                return False

            feedback_state["cursor_id"] = GLib.timeout_add(duration_ms, clear_cursor)

    def flash_status() -> bool:
        if feedback_state["flash_id"]:
            try:
                GLib.source_remove(feedback_state["flash_id"])
            except Exception:
                pass
        statusbar.get_style_context().add_class("status-flash")

        def clear_flash() -> bool:
            feedback_state["flash_id"] = 0
            statusbar.get_style_context().remove_class("status-flash")
            return False

        feedback_state["flash_id"] = GLib.timeout_add(STATUS_FLASH_MS, clear_flash)
        return False

    def set_status(message: str) -> None:
        status_label.set_text(message)
        toast_label.set_text(message)
        toast_revealer.set_reveal_child(True)
        if feedback_state["toast_id"]:
            try:
                GLib.source_remove(feedback_state["toast_id"])
            except Exception:
                pass

        def hide_toast() -> bool:
            feedback_state["toast_id"] = 0
            toast_revealer.set_reveal_child(False)
            return False

        feedback_state["toast_id"] = GLib.timeout_add(1900, hide_toast)
        flash_status()

    def record_undo(label: str, action: str, payload: object) -> None:
        undo_stack.append({"label": label, "action": action, "payload": payload})
        del undo_stack[:-12]
        update_operation_queue(tr_text("Undo available: {label}", label=label))

    def remove_path_for_undo(path: Path) -> None:
        if not path.exists() and not path.is_symlink():
            return
        if path.is_dir() and not path.is_symlink():
            shutil.rmtree(path)
        else:
            path.unlink()

    def undo_last_action() -> bool:
        if not undo_stack:
            set_status(tr_text("Nothing to undo"))
            return True
        entry = undo_stack.pop()
        label = str(entry.get("label") or "action")
        action = str(entry.get("action") or "")
        payload = entry.get("payload")
        try:
            if action in {"created", "duplicated", "copied"}:
                paths = [Path(str(item)) for item in payload or []]
                for path in reversed(paths):
                    remove_path_for_undo(path)
            elif action in {"renamed", "moved"}:
                moves = payload if isinstance(payload, list) else []
                for source_text, destination_text in reversed(moves):
                    source = Path(str(source_text))
                    destination = Path(str(destination_text))
                    if destination.exists() and not source.exists():
                        source.parent.mkdir(parents=True, exist_ok=True)
                        shutil.move(str(destination), str(source))
            else:
                set_status(tr_text("Undo is not available for this action"))
                return True
            render()
            set_status(tr_text("Undid {label}", label=label))
        except Exception as exc:
            set_status(f"Undo failed: {exc}")
        return True

    def flash_tile(child) -> None:
        child.get_style_context().add_class("pressed")

        def clear_pressed() -> bool:
            child.get_style_context().remove_class("pressed")
            return False

        GLib.timeout_add(CLICK_FEEDBACK_MS, clear_pressed)

    def activate_tile_feedback(path: Path) -> None:
        for child in flow.get_children():
            if getattr(child, "path", None) == path:
                child.get_style_context().add_class("activating")

                def clear_active(tile=child) -> bool:
                    tile.get_style_context().remove_class("activating")
                    return False

                GLib.timeout_add(STATUS_FLASH_MS, clear_active)
                break

    def path_label(path: Path) -> str:
        if virtual_location == "recent":
            return "Recents"
        if path == Path.home():
            return "Home"
        if path == Path(path.anchor):
            return "SevenOS"
        return path.name or str(path)

    def update_breadcrumbs():
        for child in breadcrumb_box.get_children():
            breadcrumb_box.remove(child)
        breadcrumb_box.set_visible(not location_entry.get_visible())
        def show_breadcrumb_menu(button, event, target: Path) -> bool:
            menu = Gtk.Menu()
            try:
                child_dirs = sorted(
                    [item for item in target.iterdir() if item.is_dir() and (show_hidden or not item.name.startswith("."))],
                    key=lambda item: item.name.casefold(),
                )[:18]
            except OSError:
                child_dirs = []
            if child_dirs:
                children_item = Gtk.MenuItem(label=tr_text("Open Child Folder"))
                children_menu = Gtk.Menu()
                for child_dir in child_dirs:
                    item = Gtk.MenuItem(label=child_dir.name)
                    item.connect("activate", lambda _item, destination=child_dir: navigate(destination))
                    children_menu.append(item)
                children_item.set_submenu(children_menu)
                menu.append(children_item)
                menu.append(Gtk.SeparatorMenuItem())
            for label, callback in (
                ("Open", lambda: navigate(target)),
                ("Open in New Tab", lambda: new_tab(target)),
                ("Open in Split", lambda: open_path_in_split(target)),
                ("Add to Favorites", lambda: add_favorite_path(target)),
                ("Copy Path", lambda: copy_path(target)),
            ):
                item = Gtk.MenuItem(label=label)
                item.connect("activate", lambda _item, action=callback: action())
                menu.append(item)
            menu.show_all()
            try:
                menu.popup_at_pointer(event)
            except AttributeError:
                menu.popup(None, None, None, None, getattr(event, "button", 0), getattr(event, "time", Gtk.get_current_event_time()))
            return True

        if virtual_location == "recent":
            button = Gtk.Button(label=tr_text("Recents"))
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("breadcrumb-button")
            button.set_size_request(-1, 24)
            button.connect("pressed", lambda widget: press_feedback(widget))
            button.connect("released", lambda widget: release_feedback(widget))
            breadcrumb_box.pack_start(button, False, False, 0)
            breadcrumb_box.show_all()
            return
        home = Path.home()
        try:
            relative_to_home = current.relative_to(home)
            parts = [Path(current.anchor), home]
            cursor = home
            for segment in relative_to_home.parts:
                cursor = cursor / segment
                if cursor != home:
                    parts.append(cursor)
        except ValueError:
            parts = []
            cursor = current
            while True:
                if cursor != home.parent:
                    parts.append(cursor)
                if cursor.parent == cursor:
                    break
                cursor = cursor.parent
            parts.reverse()
        if len(parts) > 5:
            parts = [parts[0], *parts[-4:]]
        for index, part in enumerate(parts):
            button = Gtk.Button(label=path_label(part))
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("breadcrumb-button")
            button.set_size_request(-1, 22)
            button.connect("clicked", lambda _button, target=part: navigate(target))
            button.connect(
                "button-press-event",
                lambda widget, event, target=part: show_breadcrumb_menu(widget, event, target)
                if getattr(event, "button", 0) == 3
                else False,
            )
            button.connect("pressed", lambda widget: press_feedback(widget))
            button.connect("released", lambda widget: release_feedback(widget))
            breadcrumb_box.pack_start(button, False, False, 0)
            if index < len(parts) - 1:
                sep = Gtk.Label(label="›")
                sep.get_style_context().add_class("files-status-label")
                breadcrumb_box.pack_start(sep, False, False, 0)
        breadcrumb_box.show_all()

    def show_location_entry() -> bool:
        location_entry.set_text(str(current))
        breadcrumb_box.set_visible(False)
        location_entry.show()
        location_entry.grab_focus()
        location_entry.select_region(0, -1)
        for button in breadcrumb_box.get_children():
            button.get_style_context().add_class("path-editing")
        return True

    def hide_location_entry() -> bool:
        location_entry.hide()
        breadcrumb_box.set_visible(True)
        for button in breadcrumb_box.get_children():
            button.get_style_context().remove_class("path-editing")
        return True

    def commit_location_entry() -> bool:
        raw = location_entry.get_text().strip()
        hide_location_entry()
        if not raw:
            return True
        target = Path(raw).expanduser()
        if target.exists() and target.is_dir():
            navigate(target)
        else:
            set_status(f"Folder not found: {target}")
        return True

    def sort_entries(entries: list[Path]) -> list[Path]:
        mode = sort_mode

        def safe_stat(path: Path):
            try:
                return path.stat()
            except OSError:
                return None

        if mode == "modified":
            return sorted(entries, key=lambda p: (not p.is_dir(), -(safe_stat(p).st_mtime if safe_stat(p) else 0), p.name.casefold()))
        if mode == "size":
            return sorted(entries, key=lambda p: (not p.is_dir(), -(safe_stat(p).st_size if safe_stat(p) and p.is_file() else 0), p.name.casefold()))
        if mode == "kind":
            return sorted(entries, key=lambda p: (not p.is_dir(), p.suffix.casefold(), p.name.casefold()))
        return sorted(entries, key=lambda p: (not p.is_dir(), p.name.casefold()))

    def save_preferences():
        write_json(
            PREFS_CACHE,
            {
                "view_mode": view_mode,
                "sort_mode": sort_mode,
                "show_hidden": show_hidden,
                "sidebar_visible": sidebar_visible_pref,
                "preview_visible": preview_visible_pref,
                "grouped_resources": grouped_resources,
            },
        )

    def tab_to_json(tab: dict[str, object]) -> dict[str, object]:
        path = tab.get("path", Path.home())
        return {
            "path": str(path) if isinstance(path, Path) else str(Path.home()),
            "virtual": str(tab.get("virtual", "")),
            "history": [str(item) for item in tab.get("history", []) if isinstance(item, Path)],
            "future": [str(item) for item in tab.get("future", []) if isinstance(item, Path)],
        }

    def tab_from_json(payload: object) -> dict[str, object] | None:
        if not isinstance(payload, dict):
            return None
        virtual = str(payload.get("virtual", ""))
        path = Path(str(payload.get("path") or Path.home())).expanduser()
        if virtual != "recent" and (not path.exists() or not path.is_dir()):
            return None
        history_items = []
        for item in payload.get("history", []):
            candidate = Path(str(item)).expanduser()
            if candidate.exists() and candidate.is_dir():
                history_items.append(candidate)
        future_items = []
        for item in payload.get("future", []):
            candidate = Path(str(item)).expanduser()
            if candidate.exists() and candidate.is_dir():
                future_items.append(candidate)
        return {"path": path, "virtual": virtual, "history": history_items[-16:], "future": future_items[-16:]}

    def save_session() -> None:
        sync_current_tab()
        width, height = window.get_size()
        width, height = clamp_window_size(width, height)
        write_json(
            SESSION_CACHE,
            {
                "active_tab": active_tab_index,
                "tabs": [tab_to_json(tab) for tab in tabs],
                "window": {"width": width, "height": height},
                "profile": active_profile,
                "updated_at": int(time.time()),
            },
        )

    def restore_session(explicit_start: bool = False) -> tuple[int, int] | None:
        nonlocal current, virtual_location, history, future, active_tab_index
        if explicit_start or os.environ.get("SEVENOS_FILES_RESTORE", "1") == "0":
            return None
        payload = load_json(SESSION_CACHE, {})
        if not isinstance(payload, dict):
            return None
        restored_tabs = [tab for tab in (tab_from_json(item) for item in payload.get("tabs", [])) if tab]
        if not restored_tabs:
            return None
        tabs.clear()
        tabs.extend(restored_tabs[:8])
        active_tab_index = max(0, min(int(payload.get("active_tab", 0) or 0), len(tabs) - 1))
        active_tab = tabs[active_tab_index]
        current = active_tab.get("path", Path.home())
        virtual_location = str(active_tab.get("virtual", ""))
        history = list(active_tab.get("history", []))
        future = list(active_tab.get("future", []))
        window_data = payload.get("window", {})
        if isinstance(window_data, dict):
            width = int(window_data.get("width", DEFAULT_WINDOW_SIZE[0]) or DEFAULT_WINDOW_SIZE[0])
            height = int(window_data.get("height", DEFAULT_WINDOW_SIZE[1]) or DEFAULT_WINDOW_SIZE[1])
            return clamp_window_size(width, height)
        return None

    def clamp_window_size(width: int, height: int) -> tuple[int, int]:
        return compact_window_size(width, height)

    def recent_paths() -> list[Path]:
        data = load_json(RECENTS_CACHE, [])
        paths = []
        for item in data:
            path = Path(str(item))
            if path.exists() and path not in paths:
                paths.append(path)
        return paths[:80]

    def remember_recent(path: Path):
        if not path.exists():
            return
        paths = [str(path.resolve())]
        paths.extend(str(item.resolve()) for item in recent_paths() if item.resolve() != path.resolve())
        write_json(RECENTS_CACHE, paths[:80])

    def profile_roots() -> list[Path]:
        roots = [mini_os_resource_root(), *(Path(str(item["path"])) for item in active_resource_places())]
        if grouped_resources or active_profile == "equinox":
            roots.extend([Path.home(), Path.home() / "Documents", Path.home() / "Downloads", Path.home() / "Projects"])
        profile_specific = {
            "baobab": [Path.home() / "Baobab"],
            "forge": [Path.home() / "Code"],
            "shield": [Path.home() / "Shield"],
            "studio": [Path.home() / "Studio"],
            "pulse": [Path.home() / "Games"],
            "atlas": [Path.home() / "Atlas"],
        }
        roots.extend(profile_specific.get(active_profile, []))
        unique: list[Path] = []
        for root_path in roots:
            if root_path.exists() and root_path not in unique:
                unique.append(root_path)
        return unique

    def fuzzy_match(query: str, text: str) -> bool:
        query = query.casefold().strip()
        text = text.casefold()
        if not query:
            return True
        if query in text:
            return True
        cursor = 0
        for char in query:
            cursor = text.find(char, cursor)
            if cursor < 0:
                return False
            cursor += 1
        return True

    def file_matches_query(path: Path, raw_query: str) -> bool:
        terms = [part.strip() for part in raw_query.casefold().split() if part.strip()]
        if not terms:
            return True
        haystack = f"{path.name} {path.suffix} {tag_for_path(path)}".casefold()
        try:
            stat = path.stat()
        except OSError:
            stat = None
        for term in terms:
            if term.startswith("type:"):
                kind = term.split(":", 1)[1]
                if kind in {"image", "photo"} and path.suffix.lower() not in IMAGE_SUFFIXES:
                    return False
                if kind in {"video", "movie"} and path.suffix.lower() not in VIDEO_SUFFIXES:
                    return False
                if kind in {"audio", "music"} and path.suffix.lower() not in AUDIO_SUFFIXES:
                    return False
                if kind in {"doc", "document", "pdf"} and path.suffix.lower() not in DOCUMENT_SUFFIXES | READER_SUFFIXES:
                    return False
                if kind in {"folder", "dir"} and not path.is_dir():
                    return False
                continue
            if term.startswith("tag:") and not fuzzy_match(term.split(":", 1)[1], tag_for_path(path)):
                return False
            if term.startswith("date:") and stat:
                value = term.split(":", 1)[1]
                age_days = (time.time() - stat.st_mtime) / 86400
                if value in {"today", "day"} and age_days > 1:
                    return False
                if value in {"week", "7d"} and age_days > 7:
                    return False
                if value in {"month", "30d"} and age_days > 31:
                    return False
                continue
            if term.startswith("size:") and stat:
                value = term.split(":", 1)[1]
                if value == "large" and stat.st_size < 50 * 1024 * 1024:
                    return False
                if value == "small" and stat.st_size > 1024 * 1024:
                    return False
                continue
            if not fuzzy_match(term, haystack):
                return False
        return True

    def ensure_index_db() -> sqlite3.Connection:
        GLOBAL_INDEX_DB.parent.mkdir(parents=True, exist_ok=True)
        conn = sqlite3.connect(GLOBAL_INDEX_DB)
        conn.execute(
            "create table if not exists files (path text primary key, name text, parent text, suffix text, kind text, mtime real, size integer)"
        )
        conn.execute("create index if not exists files_name_idx on files(name)")
        conn.execute("create index if not exists files_parent_idx on files(parent)")
        return conn

    def refresh_global_index(force: bool = False) -> int:
        try:
            if not force and GLOBAL_INDEX_DB.exists() and time.time() - GLOBAL_INDEX_DB.stat().st_mtime < 240:
                return 0
        except OSError:
            pass
        ignored = {".cache", ".local/share/Trash", ".git", "node_modules", "target", "__pycache__"}
        rows: list[tuple[str, str, str, str, str, float, int]] = []
        for root_path in profile_roots():
            try:
                iterator = root_path.rglob("*")
                for path in iterator:
                    if len(rows) >= INDEX_LIMIT:
                        break
                    if any(part in ignored for part in path.parts):
                        continue
                    try:
                        stat = path.stat()
                    except OSError:
                        continue
                    if path.is_dir() or path.suffix.lower() in PREVIEW_SUFFIXES or path.suffix:
                        rows.append(
                            (
                                str(path),
                                path.name,
                                path.parent.name,
                                path.suffix.lower(),
                                "folder" if path.is_dir() else "file",
                                stat.st_mtime,
                                stat.st_size if path.is_file() else 0,
                            )
                        )
            except OSError:
                continue
            if len(rows) >= INDEX_LIMIT:
                break
        with ensure_index_db() as conn:
            conn.execute("delete from files")
            conn.executemany("insert or replace into files values (?, ?, ?, ?, ?, ?, ?)", rows)
        write_json(GLOBAL_INDEX_CACHE, [row[0] for row in rows])
        return len(rows)

    def build_global_index() -> list[str]:
        try:
            refresh_global_index(False)
            with ensure_index_db() as conn:
                rows = conn.execute("select path from files order by mtime desc limit ?", (INDEX_LIMIT,)).fetchall()
            if rows:
                return [str(row[0]) for row in rows]
        except sqlite3.Error:
            pass
        data = load_json(GLOBAL_INDEX_CACHE, [])
        return [str(item) for item in data] if isinstance(data, list) else []

    def global_search(query: str) -> list[Path]:
        needle = query.strip().casefold()
        if not needle:
            return []
        try:
            refresh_global_index(False)
            like = f"%{needle}%"
            with ensure_index_db() as conn:
                rows = conn.execute(
                    "select path from files where lower(name) like ? or lower(parent) like ? or lower(suffix) like ? order by kind, name limit 180",
                    (like, like, like),
                ).fetchall()
            matches = [Path(str(row[0])) for row in rows if Path(str(row[0])).exists()]
            if matches:
                return matches
        except sqlite3.Error:
            pass
        matches: list[Path] = []
        for item in build_global_index():
            path = Path(item)
            haystack = f"{path.name} {path.parent.name} {path.suffix}"
            if fuzzy_match(query, haystack):
                matches.append(path)
            if len(matches) >= 120:
                break
        return matches

    def reindex_now():
        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, 2, "Refreshing search index")
            count = refresh_global_index(True)
            report(2, 2, "Search index ready")
            return count

        def done(count):
            if count == OPERATION_CANCELLED:
                finish_operation("Index refresh cancelled")
            else:
                finish_operation(f"Indexed {count} file item(s)")

        run_background("Refreshing search index", worker, done)

    def update_operation_queue(message: str = "") -> None:
        if message:
            operation_history.insert(0, message)
            del operation_history[4:]
        if operation_active or operation_history:
            operation_queue_label.set_text("  ·  ".join(operation_history[:3]) or operation_label.get_text())
            operation_queue.show()
        else:
            operation_queue.hide()

    def set_operation(message: str, active: bool = False):
        nonlocal operation_active, operation_cancel_requested, operation_pause_requested
        operation_active = active
        operation_cancel_requested = False if active else operation_cancel_requested
        operation_pause_requested = False
        operation_label.set_text(message)
        operation_label.set_visible(True)
        operation_progress.set_visible(active)
        operation_pause.set_visible(active)
        operation_pause.set_label(tr_text("Pause"))
        operation_cancel.set_visible(active)
        operation_progress.set_fraction(0.0)
        update_operation_queue(f"Running: {message}" if active else "")

    def finish_operation(message: str):
        nonlocal operation_cancel_requested, operation_pause_requested
        render()
        set_status(message)
        operation_cancel_requested = False
        operation_pause_requested = False
        operation_progress.set_visible(False)
        operation_pause.set_visible(False)
        operation_cancel.set_visible(False)
        set_operation(profile_title(active_profile, profile_ui), False)
        update_operation_queue(message)
        notify_system(tr_text("Seven Files"), message)

    def cancel_operation():
        nonlocal operation_cancel_requested
        operation_cancel_requested = True
        operation_label.set_text(tr_text("Cancelling..."))

    def toggle_pause_operation():
        nonlocal operation_pause_requested
        if not operation_active:
            return
        operation_pause_requested = not operation_pause_requested
        operation_pause.set_label(tr_text("Resume") if operation_pause_requested else tr_text("Pause"))
        operation_label.set_text(tr_text("Paused") if operation_pause_requested else tr_text("Resuming..."))

    operation_pause.connect("clicked", lambda *_: toggle_pause_operation())
    operation_cancel.connect("clicked", lambda *_: cancel_operation())

    def notify_system(title: str, body: str) -> None:
        if not body or os.environ.get("SEVENOS_FILES_NOTIFY", "1") == "0":
            return
        if not shutil.which("notify-send"):
            return
        subprocess.Popen(
            ["notify-send", "-a", "Seven Files", "-i", "system-file-manager", title, body],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

    def operation_progress_update(done_count: int, total_count: int, label: str | None = None) -> bool:
        if total_count > 0:
            operation_progress.set_fraction(max(0.0, min(1.0, done_count / total_count)))
        if label:
            operation_label.set_text(label)
        return False

    def run_background(label: str, worker, done):
        set_operation(label, True)

        def task():
            try:
                def reporter(done_count: int, total_count: int, progress_label: str | None = None) -> None:
                    GLib.idle_add(operation_progress_update, done_count, total_count, progress_label)

                def should_cancel() -> bool:
                    while operation_pause_requested and not operation_cancel_requested:
                        time.sleep(0.1)
                    return operation_cancel_requested

                result = worker(should_cancel, reporter)
                GLib.idle_add(lambda: (done(result), False)[1])
            except Exception as exc:
                GLib.idle_add(lambda: (finish_operation(f"Failed: {exc}"), False)[1])

        threading.Thread(target=task, daemon=True).start()

    def refresh_view_buttons():
        for button, mode in ((grid_btn, "grid"), (list_btn, "list"), (compact_btn, "compact")):
            ctx = button.get_style_context()
            if view_mode == mode:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")
        hidden_ctx = hidden_btn.get_style_context()
        if show_hidden:
            hidden_ctx.add_class("active")
        else:
            hidden_ctx.remove_class("active")

    def current_grid_columns() -> int:
        sidebar_cost = 120 if sidebar.get_visible() else 24
        preview_cost = 210 if preview.get_visible() else 0
        fallback_width = window.get_size()[0] - sidebar_cost - preview_cost
        width = max(320, scroller.get_allocated_width() or fallback_width)
        minimum = 2 if width < 430 else 3
        return max(minimum, min(7, int(width / 98)))

    def render_split() -> None:
        for child in split_flow.get_children():
            split_flow.remove(child)
        split_title.set_text(str(split_current))
        try:
            entries = sort_entries([path for path in split_current.iterdir() if show_hidden or not path.name.startswith(".")])
        except OSError:
            entries = []
        parent = split_current.parent if split_current.parent != split_current else split_current
        entries = [parent, *entries[:180]]
        for path in entries:
            child = Gtk.FlowBoxChild()
            child.path = path
            child.set_size_request(280, 40)
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            row.get_style_context().add_class("file-tile-box")
            icon = Gtk.Image.new_from_icon_name("go-up-symbolic" if path == parent and path != split_current else folder_icon(path), Gtk.IconSize.MENU)
            thumb = None if path == parent and path != split_current else tile_thumbnail(path, 24)
            if thumb:
                icon.set_from_pixbuf(thumb)
            else:
                icon.set_pixel_size(22)
            label = Gtk.Label(label=".." if path == parent and path != split_current else path.name)
            label.set_xalign(0)
            label.set_single_line_mode(True)
            label.set_ellipsize(Pango.EllipsizeMode.END)
            label.get_style_context().add_class("file-name")
            row.pack_start(icon, False, False, 0)
            row.pack_start(label, True, True, 0)
            child.add(row)
            split_flow.add(child)
        split_flow.show_all()

    def navigate_split(path: Path) -> None:
        nonlocal split_current
        if path.exists() and path.is_dir():
            split_current = path
            render_split()

    def open_path_in_split(path: Path) -> bool:
        nonlocal split_current, split_visible
        target = path if path.is_dir() else path.parent
        split_current = target
        if not split_visible:
            split_visible = True
            split_box.show()
            split_btn.get_style_context().add_class("active")
        render_split()
        return True

    def toggle_split_view(force: bool | None = None) -> bool:
        nonlocal split_visible, split_current
        split_visible = (not split_visible) if force is None else bool(force)
        if split_visible:
            split_current = current
            split_box.show()
            split_btn.get_style_context().add_class("active")
            render_split()
        else:
            split_box.hide()
            split_btn.get_style_context().remove_class("active")
        return True

    def schedule_hover_preview(widget, child, path: Path) -> bool:
        if hover_preview_state["id"]:
            GLib.source_remove(hover_preview_state["id"])
            hover_preview_state["id"] = 0
        child.get_style_context().add_class("hover-preview")

        def apply_preview() -> bool:
            hover_preview_state["id"] = 0
            if not flow.get_selected_children() and not rubberband_rect["active"]:
                update_preview(path)
            return False

        hover_preview_state["id"] = GLib.timeout_add(HOVER_PREVIEW_DELAY_MS, apply_preview)
        return False

    def cancel_hover_preview(_widget, child) -> bool:
        if hover_preview_state["id"]:
            GLib.source_remove(hover_preview_state["id"])
            hover_preview_state["id"] = 0
        child.get_style_context().remove_class("hover-preview")
        return False

    def schedule_folder_refresh(reason: str = "") -> None:
        if folder_monitor_state["render_id"]:
            GLib.source_remove(folder_monitor_state["render_id"])

        def apply_refresh() -> bool:
            folder_monitor_state["render_id"] = 0
            if reason and not operation_active:
                set_status(reason)
            render()
            return False

        folder_monitor_state["render_id"] = GLib.timeout_add(520, apply_refresh)

    def update_folder_monitor() -> None:
        watched = folder_monitor_state.get("path")
        if virtual_location or not current.exists() or not current.is_dir():
            monitor = folder_monitor_state.get("monitor")
            if monitor:
                try:
                    monitor.cancel()
                except Exception:
                    pass
            folder_monitor_state.update({"monitor": None, "path": None})
            return
        if watched == current and folder_monitor_state.get("monitor"):
            return
        monitor = folder_monitor_state.get("monitor")
        if monitor:
            try:
                monitor.cancel()
            except Exception:
                pass
        try:
            file_ref = Gio.File.new_for_path(str(current))
            monitor = file_ref.monitor_directory(Gio.FileMonitorFlags.NONE, None)
            monitor.connect("changed", lambda *_: schedule_folder_refresh(tr_text("Folder updated")))
            folder_monitor_state.update({"monitor": monitor, "path": current})
        except Exception:
            folder_monitor_state.update({"monitor": None, "path": current})

    def refresh_current() -> bool:
        render_location_rows(True)
        render()
        set_status(tr_text("Folder refreshed"))
        return True

    def render():
        focused_entry = window.get_focus() if isinstance(window.get_focus(), Gtk.Entry) else None
        focused_position = focused_entry.get_position() if focused_entry else -1
        selected_before = {child.path for child in flow.get_selected_children() if hasattr(child, "path")}
        try:
            scroll_before = scroller.get_vadjustment().get_value()
        except Exception:
            scroll_before = 0.0
        render_restore_state["selected"] = selected_before
        render_restore_state["scroll"] = scroll_before
        render_signature = f"{virtual_location}|{current}|{search_query}|{show_hidden}|{sort_mode}|{view_mode}"
        if render_limit_state.get("signature") != render_signature:
            render_limit_state["signature"] = render_signature
            render_limit_state["limit"] = RENDER_LIMIT
        directory_scan_truncated = False

        def local_directory_entries(path: Path) -> tuple[list[Path], bool]:
            entries: list[Path] = []
            truncated = False
            try:
                with os.scandir(path) as iterator:
                    for index, entry in enumerate(iterator):
                        if index >= SCAN_SOFT_LIMIT:
                            truncated = True
                            break
                        try:
                            entries.append(Path(entry.path))
                        except OSError:
                            continue
            except OSError:
                return [], False
            return entries, truncated

        sync_current_tab()
        update_folder_monitor()
        update_breadcrumbs()
        render_tabs()
        for child in flow.get_children():
            flow.remove(child)
        global_query = search_query.startswith("/")
        tag_query = search_query.startswith("#")
        if global_query:
            entries = global_search(search_query[1:].strip())
        elif tag_query:
            tag_name = search_query[1:].strip().casefold()
            tags = load_tags()
            entries = [Path(path) for path, tag in tags.items() if fuzzy_match(tag_name, tag)]
        else:
            try:
                if virtual_location == "recent":
                    entries = recent_paths()
                else:
                    entries, directory_scan_truncated = local_directory_entries(current)
            except OSError:
                entries = []
            if not show_hidden:
                entries = [path for path in entries if not path.name.startswith(".")]
            if search_query:
                entries = [path for path in entries if file_matches_query(path, search_query)]
        entries = sort_entries(entries)
        total_entries = len(entries)
        update_context_strip(total_entries, global_query, tag_query)
        if directory_scan_truncated:
            set_status(
                t(
                    "Très grand dossier : les {count} premiers éléments sont affichés pour garder Seven Files fluide.",
                    "Very large folder: showing the first {count} items to keep Seven Files responsive.",
                    count=SCAN_SOFT_LIMIT,
                )
            )
        current_render_limit = int(render_limit_state.get("limit", RENDER_LIMIT))
        limited_entries = entries[:current_render_limit]
        if view_mode == "grid":
            columns = current_grid_columns()
            flow.set_min_children_per_line(columns)
            flow.set_max_children_per_line(columns)
            flow.set_column_spacing(12)
            flow.set_row_spacing(18)
            flow.set_homogeneous(True)
        elif view_mode == "list":
            flow.set_min_children_per_line(1)
            flow.set_max_children_per_line(1)
            flow.set_column_spacing(0)
            flow.set_row_spacing(4)
            flow.set_homogeneous(False)
        else:
            flow.set_min_children_per_line(2)
            flow.set_max_children_per_line(2)
            flow.set_column_spacing(8)
            flow.set_row_spacing(4)
            flow.set_homogeneous(False)
        render_queue = list(limited_entries)

        def add_empty_state() -> None:
            # A single empty-state card must not keep the grid's multi-column
            # minimum, otherwise GTK asks Hyprland for a nearly full-screen
            # floating window when opening an empty drive.
            flow.set_min_children_per_line(1)
            flow.set_max_children_per_line(1)
            flow.set_column_spacing(0)
            flow.set_homogeneous(False)
            child = Gtk.FlowBoxChild()
            child.set_can_focus(False)
            child.path = current
            child.set_size_request(320, 190)
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            box.set_halign(Gtk.Align.CENTER)
            box.set_valign(Gtk.Align.CENTER)
            box.get_style_context().add_class("empty-state")
            icon = Gtk.Image.new_from_icon_name("edit-find-symbolic" if search_query else "folder-symbolic", Gtk.IconSize.DIALOG)
            icon.set_pixel_size(42)
            title = Gtk.Label(label=t("Aucun fichier correspondant", "No matching files") if search_query else t("Ce dossier est vide", "This folder is empty"))
            title.get_style_context().add_class("empty-title")
            hint_text = t("Essaie une autre recherche ou retire les filtres.", "Try another search or remove filters.") if search_query else t("Dépose des fichiers ici, colle des éléments ou crée un nouveau dossier.", "Drop files here, paste items, or create a new folder.")
            hint = Gtk.Label(label=hint_text)
            hint.set_line_wrap(True)
            hint.set_max_width_chars(30)
            hint.set_justify(Gtk.Justification.CENTER)
            hint.get_style_context().add_class("preview-hint")
            actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            actions.set_halign(Gtk.Align.CENTER)

            def empty_button(label: str, callback):
                button = Gtk.Button(label=label)
                button.get_style_context().add_class("selection-action")
                button.connect("clicked", lambda *_: callback())
                actions.pack_start(button, False, False, 0)

            box.pack_start(icon, False, False, 0)
            box.pack_start(title, False, False, 0)
            box.pack_start(hint, False, False, 0)
            if search_query:
                empty_button(tr_text("Clear Search"), clear_search)
                empty_button(tr_text("Global Search"), lambda: (search_entry.set_text(f"/{search_query.strip()}"), search_entry.grab_focus()))
            else:
                empty_button(tr_text("New Folder"), create_folder)
                empty_button(tr_text("New File"), create_file)
                empty_button(tr_text("Paste"), paste_items)
                empty_button(t("Connecter un serveur", "Connect Server"), connect_to_server)
            box.pack_start(actions, False, False, 8)
            child.add(box)
            flow.add(child)

        def add_load_more_state() -> None:
            remaining = max(0, total_entries - len(limited_entries))
            if remaining <= 0:
                return
            child = Gtk.FlowBoxChild()
            child.set_can_focus(False)
            child.set_size_request(82 if view_mode == "grid" else 420, 98 if view_mode == "grid" else 120)
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            box.set_halign(Gtk.Align.CENTER)
            box.set_valign(Gtk.Align.CENTER)
            box.get_style_context().add_class("empty-state")
            title = Gtk.Label(label=tr_text("{count} more item(s)", count=remaining))
            title.get_style_context().add_class("empty-title")
            hint = Gtk.Label(label=tr_text("Seven Files keeps large folders responsive by rendering them progressively."))
            hint.get_style_context().add_class("preview-hint")
            button = Gtk.Button(label=tr_text("Load More"))
            button.get_style_context().add_class("operation-cancel")

            def load_more() -> None:
                render_limit_state["limit"] = current_render_limit + RENDER_LIMIT
                render()

            button.connect("clicked", lambda *_: load_more())
            box.pack_start(title, False, False, 0)
            box.pack_start(hint, False, False, 0)
            box.pack_start(button, False, False, 0)
            child.add(box)
            flow.add(child)

        def add_entry(path: Path) -> None:
            child = Gtk.FlowBoxChild()
            child.set_can_focus(True)
            child.get_style_context().add_class("file-tile")
            if view_mode == "list":
                child.get_style_context().add_class("list-view")
                child.set_size_request(420, 44)
            elif view_mode == "compact":
                child.get_style_context().add_class("compact-view")
                child.set_size_request(210, 38)
            else:
                child.set_size_request(82, 98)
            child.path = path
            tile_event = Gtk.EventBox()
            tile_event.set_visible_window(False)
            tile_event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
            tile_event.file_child = child
            tile_event.file_path = path
            tile_event.spring_target = path if path.is_dir() else None
            orientation = Gtk.Orientation.VERTICAL if view_mode == "grid" else Gtk.Orientation.HORIZONTAL
            box = Gtk.Box(orientation=orientation, spacing=10)
            box.set_halign(Gtk.Align.FILL if view_mode != "grid" else Gtk.Align.CENTER)
            box.set_valign(Gtk.Align.CENTER)
            if view_mode == "list":
                box.set_size_request(420, 44)
            elif view_mode == "compact":
                box.set_size_request(210, 38)
            else:
                box.set_size_request(82, 98)
            box.get_style_context().add_class("file-tile-box")
            image = Gtk.Image.new_from_icon_name(folder_icon(path), Gtk.IconSize.DIALOG)
            image_size = 44 if view_mode == "grid" else 24
            thumb = tile_thumbnail(path, image_size)
            if thumb:
                image.set_from_pixbuf(thumb)
            else:
                image.set_pixel_size(image_size)
            label = Gtk.Label(label=path.name)
            label.set_xalign(0 if view_mode != "grid" else 0.5)
            label.set_width_chars(9 if view_mode == "grid" else 30)
            label.set_max_width_chars(9 if view_mode == "grid" else 30)
            label.set_line_wrap(False)
            label.set_single_line_mode(True)
            label.set_ellipsize(Pango.EllipsizeMode.END)
            label.set_justify(Gtk.Justification.CENTER if view_mode == "grid" else Gtk.Justification.LEFT)
            label.get_style_context().add_class("file-name")
            box.pack_start(image, False, False, 0)
            if view_mode == "grid":
                box.pack_start(label, False, False, 0)
                kind_chip = Gtk.Label(label=kind_label(path))
                kind_chip.get_style_context().add_class("file-kind-chip")
                if is_risky_file(path):
                    kind_chip.get_style_context().add_class("file-risk-chip")
                box.pack_start(kind_chip, False, False, 0)
                tag = tag_for_path(path)
                if tag:
                    tag_label = Gtk.Label(label=tag)
                    tag_label.get_style_context().add_class("tag-pill")
                    tag_label.get_style_context().add_class(f"tag-{tag.casefold()}")
                    box.pack_start(tag_label, False, False, 0)
            else:
                text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
                text_box.pack_start(label, False, False, 0)
                meta = Gtk.Label(label=file_row_meta(path))
                meta.set_xalign(0)
                meta.set_single_line_mode(True)
                meta.set_ellipsize(Pango.EllipsizeMode.END)
                meta.get_style_context().add_class("file-meta")
                if view_mode == "list":
                    text_box.pack_start(meta, False, False, 0)
                tag = tag_for_path(path)
                if tag:
                    tag_label = Gtk.Label(label=tag)
                    tag_label.set_xalign(0)
                    tag_label.get_style_context().add_class("tag-pill")
                    tag_label.get_style_context().add_class(f"tag-{tag.casefold()}")
                    text_box.pack_start(tag_label, False, False, 0)
                box.pack_start(text_box, True, True, 0)
            tile_event.add(box)
            setup_file_tile_dnd(tile_event, child, path)
            tile_event.connect("button-press-event", lambda _widget, event, tile=child, item=path: on_tile_button(event, tile, item))
            tile_event.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
            tile_event.connect("enter-notify-event", lambda widget, _event, tile=child, item=path: schedule_hover_preview(widget, tile, item))
            tile_event.connect("leave-notify-event", lambda widget, _event, tile=child: cancel_hover_preview(widget, tile))
            child.add(tile_event)
            flow.add(child)

        def restore_render_state() -> None:
            selected = render_restore_state.get("selected", set())
            if selected:
                for child in flow.get_children():
                    if getattr(child, "path", None) in selected:
                        flow.select_child(child)
            try:
                adjustment = scroller.get_vadjustment()
                target = float(render_restore_state.get("scroll", 0.0) or 0.0)
                max_value = max(adjustment.get_lower(), adjustment.get_upper() - adjustment.get_page_size())
                adjustment.set_value(min(max(adjustment.get_lower(), target), max_value))
            except Exception:
                pass

        def render_chunk() -> bool:
            if not render_queue and not limited_entries:
                add_empty_state()
                flow.show_all()
                restore_render_state()
                return False
            for _index in range(min(RENDER_CHUNK_SIZE, len(render_queue))):
                add_entry(render_queue.pop(0))
            if not render_queue:
                add_load_more_state()
            flow.show_all()
            keep_rendering = bool(render_queue)
            if not keep_rendering:
                restore_render_state()
            return keep_rendering

        render_chunk()
        selected_count = len(flow.get_selected_children())
        if not selected_count:
            update_selection_bar([])
        mode_label = theme_mode.title()
        location = "Recents" if virtual_location == "recent" else str(current)
        scope = "Global" if global_query else "Tags" if tag_query else "Local"
        width, _height = window.get_size()
        if selected_count:
            selected_text = t("{count} sélectionné", "{count} selected", count=selected_count)
            status_label.set_text(
                f"{selected_text} · {Path(location).name or location}" if width < 760 else f"{selected_text}  |  {location}"
            )
        else:
            count_text = t(
                "{visible}/{total} élément",
                "{visible}/{total} item(s)",
                visible=len(limited_entries),
                total=total_entries,
            )
            if width < 760:
                status_label.set_text(f"{count_text} · {scope} · {profile_title(active_profile, profile_ui)}")
            else:
                status_label.set_text(
                    f"{count_text}  |  {scope} · {mode_label} · {profile_title(active_profile, profile_ui)}  |  "
                    + t("Clic sélectionne · Double-clic ouvre", "Click selects · Double-click opens")
                )
        if not operation_active:
            operation_label.set_text(profile_title(active_profile, profile_ui))
        update_sidebar()
        refresh_view_buttons()
        if split_visible:
            render_split()
        if virtual_location == "recent":
            update_preview_multiple(entries)
        else:
            update_preview(current)
        if render_queue:
            GLib.idle_add(render_chunk)
        if focused_entry:
            focused_entry.grab_focus()
            focused_entry.set_position(focused_position)
    def file_row_meta(path: Path) -> str:
        try:
            stat = path.stat()
            modified = time.strftime("%b %d, %H:%M", time.localtime(stat.st_mtime))
            if path.is_dir():
                size = t("Dossier", "Folder")
            else:
                size = format_size(stat.st_size)
            kind = kind_label(path)
            return f"{kind}  |  {size}  |  {modified}"
        except OSError:
            return t("Indisponible", "Unavailable")

    def detail_row(label: str, value: str):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        card.get_style_context().add_class("inspector-card")
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("preview-heading")
        value_label = Gtk.Label(label=value)
        value_label.set_xalign(0)
        value_label.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        value_label.set_single_line_mode(True)
        value_label.set_max_width_chars(24)
        value_label.get_style_context().add_class("preview-value")
        card.pack_start(heading, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        preview_details.pack_start(card, False, False, 0)

    def preview_action(label: str, callback):
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("preview-action")
        button.connect("clicked", lambda *_: callback())
        button.connect("pressed", lambda widget: press_feedback(widget))
        button.connect("released", lambda widget: release_feedback(widget))
        preview_details.pack_start(button, False, False, 4)

    def preview_quick_actions(actions: list[tuple[str, object]]):
        if not actions:
            return
        grid = Gtk.FlowBox()
        grid.get_style_context().add_class("preview-action-grid")
        grid.set_selection_mode(Gtk.SelectionMode.NONE)
        grid.set_min_children_per_line(2)
        grid.set_max_children_per_line(2)
        grid.set_column_spacing(6)
        grid.set_row_spacing(6)
        grid.set_halign(Gtk.Align.FILL)
        for label, callback in actions:
            child = Gtk.FlowBoxChild()
            child.set_can_focus(False)
            button = Gtk.Button(label=label)
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("preview-mini-action")
            button.connect("clicked", lambda _button, action=callback: action())
            child.add(button)
            grid.add(child)
        preview_details.pack_start(grid, False, False, 0)

    def preview_context_actions(target: Path):
        if target.is_dir():
            preview_quick_actions(
                [
                    (t("Nouveau dossier", "New Folder"), create_folder),
                    (t("Coller", "Paste"), paste_items),
                    (t("Rechercher", "Search"), lambda: (search_entry.grab_focus(), search_entry.select_region(0, -1))),
                    (t("Terminal", "Terminal"), lambda target=target: open_terminal_here(target)),
                ]
            )
            return
        preview_quick_actions(
            [
                (t("Chemin", "Path"), lambda target=target: copy_path(target)),
                (t("Afficher", "Reveal"), lambda target=target: reveal_in_parent(target)),
                (t("Infos", "Info"), lambda target=target: properties_dialog(target)),
                (t("Tag", "Tag"), lambda target=target: tag_paths([target], "Focus")),
            ]
        )

    def preview_hint(text: str):
        label = Gtk.Label(label=text)
        label.set_xalign(0)
        label.set_line_wrap(True)
        label.set_max_width_chars(28)
        label.get_style_context().add_class("preview-hint")
        preview_details.pack_start(label, False, False, 0)

    def preview_decision(title: str, body: str, warn: bool = False):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        card.get_style_context().add_class("preview-decision")
        if warn:
            card.get_style_context().add_class("warn")
        title_label = Gtk.Label(label=title)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("preview-decision-title")
        body_label = Gtk.Label(label=body)
        body_label.set_xalign(0)
        body_label.set_line_wrap(True)
        body_label.set_max_width_chars(28)
        body_label.get_style_context().add_class("preview-decision-body")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(body_label, False, False, 0)
        preview_details.pack_start(card, False, False, 0)

    def preview_decision_for(target: Path):
        if target.is_dir():
            preview_decision(
                t("Espace prêt", "Space ready"),
                t("Ouvre, trie ou dépose des fichiers ici. Les actions restent non destructives tant que tu ne confirmes pas.", "Open, sort or drop files here. Actions stay non-destructive until you confirm."),
            )
        elif is_risky_file(target):
            if is_windows_app_file(target):
                plan = wincompat_plan(target)
                engine = str(plan.get("selected_engine") or "Bottles/Wine/Lutris")
                preview_decision(
                    t("App Windows détectée", "Windows app detected"),
                    t("SevenOS peut lancer ce fichier via {engine}. Vérifie sa source avant exécution.", "SevenOS can launch this file through {engine}. Verify its source before running it.", engine=engine),
                    True,
                )
            else:
                preview_decision(
                    t("À vérifier avant ouverture", "Review before opening"),
                    t("Ce fichier peut exécuter du code. Utilise l’ouverture sûre ou vérifie son empreinte.", "This file may execute code. Use Safe Open or verify its fingerprint."),
                    True,
                )
        elif target.suffix.lower() in READER_SUFFIXES:
            preview_decision(
                t("Lecture recommandée", "Reader recommended"),
                t("Seven Reader offre aperçu, lecture et inspection sans quitter SevenOS.", "Seven Reader gives preview, reading and inspection without leaving SevenOS."),
            )
        elif is_previewable(target):
            preview_decision(
                t("Aperçu disponible", "Preview available"),
                t("Espace ouvre Quick Look; double-clic ouvre l’action adaptée.", "Space opens Quick Look; double-click opens the adapted action."),
            )

    def read_text_preview(path: Path, limit: int = 6000) -> str:
        data = path.read_bytes()[:limit]
        return data.decode("utf-8", errors="replace")

    def read_docx_preview(path: Path, limit: int = 6000) -> str:
        with zipfile.ZipFile(path) as document:
            xml = document.read("word/document.xml")
        root = ET.fromstring(xml)
        namespace = "{http://schemas.openxmlformats.org/wordprocessingml/2006/main}"
        parts = [node.text or "" for node in root.iter(f"{namespace}t")]
        text = " ".join(part.strip() for part in parts if part.strip())
        return html.unescape(text[:limit])

    def thumbnail_cache_path(path: Path, prefix: str) -> Path:
        try:
            stat = path.stat()
            key = hashlib.sha256(f"{path.resolve()}:{stat.st_mtime_ns}:{stat.st_size}".encode("utf-8")).hexdigest()[:24]
        except OSError:
            key = hashlib.sha256(str(path).encode("utf-8")).hexdigest()[:24]
        THUMB_CACHE.mkdir(parents=True, exist_ok=True)
        return THUMB_CACHE / f"{prefix}-{key}.png"

    def video_thumbnail(path: Path) -> GdkPixbuf.Pixbuf | None:
        thumb = thumbnail_cache_path(path, "video")
        if thumb.exists():
            try:
                return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), 210, 150, True)
            except Exception:
                thumb.unlink(missing_ok=True)
        if shutil.which("ffmpegthumbnailer"):
            command = ["ffmpegthumbnailer", "-i", str(path), "-o", str(thumb), "-s", "420", "-q", "8"]
        elif shutil.which("ffmpeg"):
            command = [
                "ffmpeg", "-y", "-ss", "00:00:01", "-i", str(path),
                "-frames:v", "1", "-vf", "scale=420:-1", str(thumb),
            ]
        else:
            return None
        result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode != 0 or not thumb.exists():
            return None
        return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), 210, 150, True)

    def pdf_thumbnail(path: Path, render_width: int = 760, max_width: int = 210, max_height: int = 150) -> GdkPixbuf.Pixbuf | None:
        if not shutil.which("pdftoppm"):
            return None
        output_file = thumbnail_cache_path(path, f"pdf-{render_width}")
        if output_file.exists():
            try:
                return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(output_file), max_width, max_height, True)
            except Exception:
                output_file.unlink(missing_ok=True)
        output_prefix = output_file.with_suffix("")
        output_file = Path(f"{output_prefix}.png")
        result = subprocess.run(
            ["pdftoppm", "-f", "1", "-singlefile", "-png", "-scale-to", str(render_width), str(path), str(output_prefix)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode != 0 or not output_file.exists():
            return None
        return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(output_file), max_width, max_height, True)

    def image_thumbnail(path: Path, max_width: int = 210, max_height: int = 150) -> GdkPixbuf.Pixbuf | None:
        thumb = thumbnail_cache_path(path, f"image-{max_width}x{max_height}")
        if thumb.exists():
            try:
                return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), max_width, max_height, True)
            except Exception:
                thumb.unlink(missing_ok=True)
        try:
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), max_width, max_height, True)
            try:
                pixbuf.savev(str(thumb), "png", [], [])
            except Exception:
                pass
            return pixbuf
        except Exception:
            return None

    def tile_thumbnail(path: Path, size: int) -> GdkPixbuf.Pixbuf | None:
        def fit(pixbuf: GdkPixbuf.Pixbuf | None) -> GdkPixbuf.Pixbuf | None:
            if not pixbuf:
                return None
            width = pixbuf.get_width()
            height = pixbuf.get_height()
            if width <= size and height <= size:
                return pixbuf
            scale = min(size / max(1, width), size / max(1, height))
            return pixbuf.scale_simple(max(1, int(width * scale)), max(1, int(height * scale)), GdkPixbuf.InterpType.BILINEAR)

        if is_image(path):
            return image_thumbnail(path, size, size)
        if is_video(path):
            return fit(video_thumbnail(path))
        if path.is_file() and path.suffix.lower() == ".pdf":
            return pdf_thumbnail(path, 520, size, size)
        return None

    def update_preview(path: Path | None):
        for child in preview_details.get_children():
            preview_details.remove(child)
        target = path or current
        preview_decision_for(target)
        preview_context_actions(target)
        if is_image(target):
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(target), 210, 150, True)
                preview_icon.set_from_pixbuf(pixbuf)
            except Exception:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint(t("Espace prévisualise cette image. Double-clic ouvre Quick Look.", "Space previews this image. Double-click opens Seven Quick Look."))
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            preview_action(t("Ouvrir avec une app", "Open externally"), lambda target=target: open_externally(target))
        elif is_video(target):
            pixbuf = video_thumbnail(target)
            if pixbuf:
                preview_icon.set_from_pixbuf(pixbuf)
            else:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint(t("Espace ouvre l’aperçu vidéo. Le lecteur externe reste disponible.", "Space opens video preview. External player remains available from preview."))
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            preview_action(t("Ouvrir avec une app", "Open externally"), lambda target=target: open_externally(target))
        elif is_audio(target):
            preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
            preview_icon.set_pixel_size(88)
            preview_hint(t("Espace ouvre l’aperçu audio. Le lecteur externe reste disponible.", "Space opens audio preview. External player remains available from preview."))
            preview_action(t("Ouvrir avec une app", "Open externally"), lambda target=target: open_externally(target))
        elif target.is_file() and target.suffix.lower() == ".pdf":
            pixbuf = pdf_thumbnail(target)
            if pixbuf:
                preview_icon.set_from_pixbuf(pixbuf)
            else:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint(t("Ouvre ce document dans Seven Reader pour la lecture, le mode livre et l’inspection.", "Open this document in Seven Reader for book, double-page and inspect modes."))
            preview_action(t("Lire dans Seven Reader", "Read in Seven Reader"), lambda target=target: open_in_reader(target))
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
        else:
            preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
            preview_icon.set_pixel_size(88)
            if target.is_file() and target.suffix.lower() in READER_SUFFIXES:
                preview_hint(t("Ouvre ce document dans Seven Reader pour une lecture immersive.", "Open this document in Seven Reader for immersive reading."))
                preview_action(t("Lire dans Seven Reader", "Read in Seven Reader"), lambda target=target: open_in_reader(target))
                preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            elif target.is_file() and target.suffix.lower() in TEXT_SUFFIXES | DOCUMENT_SUFFIXES:
                preview_hint(t("Espace ouvre l’aperçu du document.", "Space opens document preview."))
                preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
                preview_action(t("Ouvrir avec une app", "Open externally"), lambda target=target: open_externally(target))
            elif target.is_dir():
                preview_action(t("Ouvrir", "Open"), lambda target=target: navigate(target))
                preview_action(t("Calculer la taille", "Calculate Size"), lambda target=target: calculate_size_for_path(target))
        preview_title.set_text(target.name or str(target))
        preview_subtitle.set_text(kind_label(target))
        try:
            stat = target.stat()
            detail_row(t("Emplacement", "Location"), str(target.parent if target != current else target))
            detail_row(t("Modifié", "Modified"), time.strftime("%b %d, %Y %H:%M", time.localtime(stat.st_mtime)))
            if target.is_file():
                detail_row(t("Taille", "Size"), format_size(stat.st_size))
            elif target.is_dir():
                try:
                    count = len(list(target.iterdir()))
                except OSError:
                    count = 0
                detail_row(t("Éléments", "Items"), f"{count}")
                usage = filesystem_usage(target)
                if usage:
                    detail_row(t("Disponible", "Available"), usage[0])
                    detail_row("Volume", usage[1])
            tag = tag_for_path(target)
            if tag:
                detail_row("Tag", tag)
            if target.is_file():
                if is_risky_file(target):
                    detail_row(t("Sécurité", "Security"), t("Vérifier avant ouverture", "Review before opening"))
                    if is_windows_app_file(target):
                        preview_action(t("Ouvrir avec Windows Apps", "Open with Windows Apps"), lambda target=target: open_windows_compat(target))
                        preview_action("Bottles", lambda target=target: open_windows_compat(target, "bottles"))
                        preview_action("Wine", lambda target=target: open_windows_compat(target, "wine"))
                        preview_action("Lutris", lambda target=target: open_windows_compat(target, "lutris"))
                    preview_action(t("Ouverture sûre", "Safe Open"), lambda target=target: safe_open_path(target))
                preview_action(t("Copier SHA256", "Copy SHA256"), hash_selected)
                preview_action(t("Demander à SevenAI", "Ask SevenAI"), sevenai_selected)
        except OSError:
            detail_row(t("État", "Status"), t("Indisponible", "Unavailable"))
        preview_details.show_all()

    def update_preview_multiple(paths: list[Path]):
        for child in preview_details.get_children():
            preview_details.remove(child)
        preview_icon.set_from_icon_name("edit-select-all", Gtk.IconSize.DIALOG)
        preview_icon.set_pixel_size(88)
        preview_title.set_text(t("{count} sélectionnés", "{count} selected", count=len(paths)))
        files = [path for path in paths if path.is_file()]
        folders = [path for path in paths if path.is_dir()]
        preview_subtitle.set_text(t("Sélection", "Selection"))
        total = 0
        for path in files:
            try:
                total += path.stat().st_size
            except OSError:
                pass
        detail_row(t("Fichiers", "Files"), str(len(files)))
        detail_row(t("Dossiers", "Folders"), str(len(folders)))
        detail_row(t("Taille totale", "Total size"), format_size(total))
        preview_quick_actions(
            [
                (t("Copier", "Copy"), copy_selected),
                (t("Compresser", "Compress"), compress_selected),
                ("AI", sevenai_selected),
                (t("Corbeille", "Trash"), trash_selected),
            ]
        )
        preview_hint(t("Utilise Copier, Compresser, Tags ou SevenAI sur les éléments sélectionnés.", "Use Copy, Compress, Tags or SevenAI actions on the selected items."))
        preview_details.show_all()

    def preview_text_view(text: str) -> Gtk.ScrolledWindow:
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        text_view = Gtk.TextView()
        text_view.set_editable(False)
        text_view.set_cursor_visible(False)
        text_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        text_view.get_style_context().add_class("quicklook-text")
        text_view.get_buffer().set_text(text)
        scroller.add(text_view)
        return scroller

    def preview_message(icon_name: str, title_text: str, body: str) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        box.set_margin_top(32)
        box.set_margin_bottom(32)
        box.set_margin_start(32)
        box.set_margin_end(32)
        icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        icon.set_pixel_size(96)
        label = Gtk.Label(label=title_text)
        label.get_style_context().add_class("preview-title")
        body_label = Gtk.Label(label=body)
        body_label.set_line_wrap(True)
        body_label.set_max_width_chars(54)
        body_label.set_justify(Gtk.Justification.CENTER)
        body_label.get_style_context().add_class("preview-value")
        box.pack_start(icon, False, False, 0)
        box.pack_start(label, False, False, 0)
        box.pack_start(body_label, False, False, 0)
        return box

    def inline_media_player(path: Path, video: bool):
        if Gst is None:
            return None
        playbin = Gst.ElementFactory.make("playbin", None)
        if playbin is None:
            return None
        media_widget = None
        if video:
            sink = Gst.ElementFactory.make("gtksink", None)
            if sink is None:
                sink = Gst.ElementFactory.make("gtkglsink", None)
            if sink is None:
                return None
            playbin.set_property("video-sink", sink)
            try:
                media_widget = sink.get_property("widget")
            except Exception:
                return None
        else:
            media_widget = preview_message("audio-x-generic", path.name, "Audio playback is inline. Use the controls below.")
        playbin.set_property("uri", file_uri(path))

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("media-inline")
        box.set_hexpand(True)
        box.set_vexpand(True)
        box.pack_start(media_widget, True, True, 0)

        controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        controls.set_margin_top(8)
        controls.set_margin_bottom(10)
        controls.set_margin_start(12)
        controls.set_margin_end(12)
        play_button = Gtk.Button(label=tr_text("Play"))
        play_button.get_style_context().add_class("media-control")
        stop_button = Gtk.Button(label=tr_text("Stop"))
        stop_button.get_style_context().add_class("media-control")
        seek = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
        seek.set_draw_value(False)
        seek.set_hexpand(True)
        position_label = Gtk.Label(label="00:00")
        controls.pack_start(play_button, False, False, 0)
        controls.pack_start(stop_button, False, False, 0)
        controls.pack_start(seek, True, True, 0)
        controls.pack_start(position_label, False, False, 0)
        box.pack_start(controls, False, False, 0)

        state = {"playing": False, "seeking": False, "updating": False, "timer": 0}

        def format_time(nanoseconds: int) -> str:
            seconds = max(0, int(nanoseconds / 1_000_000_000))
            return f"{seconds // 60:02d}:{seconds % 60:02d}"

        def toggle_play(*_args):
            state["playing"] = not state["playing"]
            playbin.set_state(Gst.State.PLAYING if state["playing"] else Gst.State.PAUSED)
            play_button.set_label(tr_text("Pause") if state["playing"] else tr_text("Play"))

        def stop_media(*_args):
            state["playing"] = False
            play_button.set_label(tr_text("Play"))
            playbin.set_state(Gst.State.NULL)
            seek.set_value(0)
            position_label.set_text("00:00")

        def update_position() -> bool:
            try:
                ok_pos, position = playbin.query_position(Gst.Format.TIME)
                ok_duration, duration = playbin.query_duration(Gst.Format.TIME)
            except Exception:
                return True
            if ok_pos and ok_duration and duration > 0 and not state["seeking"]:
                state["updating"] = True
                seek.set_value(min(100, max(0, position * 100 / duration)))
                state["updating"] = False
                position_label.set_text(format_time(position))
            return True

        def on_seek(_scale):
            if state["seeking"] or state["updating"]:
                return
            try:
                ok_duration, duration = playbin.query_duration(Gst.Format.TIME)
                if ok_duration and duration > 0:
                    target = int(duration * seek.get_value() / 100)
                    playbin.seek_simple(Gst.Format.TIME, Gst.SeekFlags.FLUSH | Gst.SeekFlags.KEY_UNIT, target)
            except Exception:
                pass

        play_button.connect("clicked", toggle_play)
        stop_button.connect("clicked", stop_media)
        seek.connect("button-press-event", lambda *_: state.update({"seeking": True}) or False)
        seek.connect("button-release-event", lambda *_: (state.update({"seeking": False}), on_seek(seek), False)[2])
        seek.connect("value-changed", on_seek)
        state["timer"] = GLib.timeout_add(350, update_position)

        def cleanup_media(*_args):
            if state["timer"]:
                GLib.source_remove(state["timer"])
                state["timer"] = 0
            playbin.set_state(Gst.State.NULL)

        return box, playbin, cleanup_media

    def open_quicklook_preview(path: Path):
        preview_window = Gtk.Window(title=path.name)
        preview_window.set_default_size(880, 620)
        preview_window.set_size_request(520, 360)
        preview_window.set_resizable(True)
        preview_window.set_position(Gtk.WindowPosition.CENTER)
        preview_window.set_wmclass("SevenQuickLook", "SevenQuickLook")
        preview_window.get_style_context().add_class("quicklook-window")

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        preview_window.add(outer)

        header = Gtk.HeaderBar(title=path.name)
        header.set_show_close_button(True)
        preview_window.set_titlebar(header)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        content.set_hexpand(True)
        content.set_vexpand(True)
        suffix = path.suffix.lower()

        if is_image(path):
            image_scroller = Gtk.ScrolledWindow()
            image_scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), 1280, 860, True)
                image = Gtk.Image.new_from_pixbuf(pixbuf)
            except Exception:
                image = Gtk.Image.new_from_icon_name("image-x-generic", Gtk.IconSize.DIALOG)
                image.set_pixel_size(128)
            image.set_margin_top(18)
            image.set_margin_bottom(18)
            image.set_margin_start(18)
            image.set_margin_end(18)
            image_scroller.add_with_viewport(image)
            content.pack_start(image_scroller, True, True, 0)
        elif suffix in TEXT_SUFFIXES:
            try:
                content.pack_start(preview_text_view(read_text_preview(path)), True, True, 0)
            except OSError as exc:
                content.pack_start(preview_message("text-x-generic", "Preview unavailable", str(exc)), True, True, 0)
        elif suffix == ".docx":
            try:
                content.pack_start(preview_text_view(read_docx_preview(path)), True, True, 0)
            except Exception as exc:
                content.pack_start(preview_message("x-office-document", "DOCX preview unavailable", str(exc)), True, True, 0)
        elif suffix == ".pdf":
            pixbuf = pdf_thumbnail(path, 1200, 760, 900)
            if pixbuf:
                image = Gtk.Image.new_from_pixbuf(pixbuf)
                image.set_halign(Gtk.Align.CENTER)
                image.set_valign(Gtk.Align.CENTER)
                content.pack_start(image, True, True, 0)
            else:
                content.pack_start(
                    preview_message(
                        "application-pdf",
                        "PDF document",
                        "Install poppler to render the first page inline, or open this file externally now.",
                    ),
                    True,
                    True,
                    0,
                )
        elif is_video(path):
            media = inline_media_player(path, video=True)
            if media:
                player, _playbin, cleanup = media
                content.pack_start(player, True, True, 0)
                preview_window.connect("destroy", cleanup)
            else:
                pixbuf = video_thumbnail(path)
                if pixbuf:
                    image = Gtk.Image.new_from_pixbuf(pixbuf)
                    image.set_halign(Gtk.Align.CENTER)
                    image.set_valign(Gtk.Align.CENTER)
                    content.pack_start(image, True, True, 0)
                else:
                    content.pack_start(
                        preview_message(
                            "video-x-generic",
                            "Video preview",
                            "Install GStreamer gtksink for inline playback, or use Open externally.",
                        ),
                        True,
                        True,
                        0,
                    )
        elif is_audio(path):
            media = inline_media_player(path, video=False)
            if media:
                player, _playbin, cleanup = media
                content.pack_start(player, True, True, 0)
                preview_window.connect("destroy", cleanup)
            else:
                content.pack_start(
                    preview_message(
                        "audio-x-generic",
                        "Audio file",
                        "Install GStreamer for inline playback, or use Open externally.",
                    ),
                    True,
                    True,
                    0,
                )
        else:
            content.pack_start(preview_message(folder_icon(path), "Preview", "No inline preview is available for this file type yet."), True, True, 0)

        outer.pack_start(content, True, True, 0)

        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        footer.get_style_context().add_class("quicklook-footer")
        footer.set_margin_top(8)
        footer.set_margin_bottom(10)
        footer.set_margin_start(14)
        footer.set_margin_end(14)
        open_button = Gtk.Button(label=tr_text("Open externally"))
        open_button.connect("clicked", lambda *_: open_externally(path))
        footer.pack_start(open_button, False, False, 0)
        if path.suffix.lower() in READER_SUFFIXES:
            reader_button = Gtk.Button(label=tr_text("Read in Seven Reader"))
            reader_button.connect("clicked", lambda *_: open_in_reader(path))
            footer.pack_start(reader_button, False, False, 0)
        if is_image(path):
            wallpaper_button = Gtk.Button(label=tr_text("Set as Wallpaper"))
            wallpaper_button.connect("clicked", lambda *_: set_wallpaper_from_file(path))
            footer.pack_end(wallpaper_button, False, False, 0)
        outer.pack_start(footer, False, False, 0)

        preview_window.show_all()

    def open_in_reader(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-reader").exists():
            command = [str(root / "bin/seven-reader"), "open", str(path)]
        elif shutil.which("seven-reader"):
            command = ["seven-reader", "open", str(path)]
        elif shutil.which("seven"):
            command = ["seven", "reader", str(path)]
        if command:
            log = Path("/tmp/sevenos-reader.log")
            with log.open("ab") as handle:
                subprocess.Popen(command, stdout=handle, stderr=handle, start_new_session=True)
            status_label.set_text(f"Opening {path.name} in Seven Reader")
        else:
            open_quicklook_preview(path)

    def wincompat_command(*args: str) -> list[str] | None:
        root = resolve_root()
        if root and (root / "bin/seven-wincompat").exists():
            return [str(root / "bin/seven-wincompat"), *args]
        if shutil.which("seven-wincompat"):
            return ["seven-wincompat", *args]
        return None

    def wincompat_plan(path: Path) -> dict:
        command = wincompat_command("plan", str(path), "--json")
        if not command:
            return {"state": "missing-helper", "available_engines": [], "selected_engine": "", "blocker": "seven-wincompat is missing"}
        try:
            result = subprocess.run(command, text=True, capture_output=True, check=False)
            if result.returncode == 0:
                return json.loads(result.stdout)
        except Exception:
            pass
        return {"state": "unknown", "available_engines": [], "selected_engine": "", "blocker": "Unable to resolve Windows compatibility plan"}

    def open_windows_compat(path: Path, engine: str = "auto", confirm: bool = True):
        plan = wincompat_plan(path)
        if plan.get("state") not in {"ready"}:
            blocker = plan.get("blocker") or t("Installe Bottles, Wine ou Lutris depuis SevenStore.", "Install Bottles, Wine or Lutris from SevenStore.")
            status_label.set_text(t("Compatibilité Windows indisponible: {blocker}", "Windows compatibility unavailable: {blocker}", blocker=blocker))
            set_status(str(blocker))
            notify_system(t("App Windows non lancée", "Windows app not launched"), str(blocker))
            update_preview(path)
            return
        selected = str(plan.get("selected_engine") or "auto")
        if confirm and not confirm_dialog(
            t("Ouvrir une app Windows", "Open Windows app"),
            t(
                "SevenOS va lancer {name} via {engine}. Les fichiers Windows exécutent du code: vérifie la source avant de continuer.",
                "SevenOS will launch {name} through {engine}. Windows files execute code: verify the source before continuing.",
                name=path.name,
                engine=selected,
            ),
            t("Ouvrir", "Open"),
        ):
            return
        command = wincompat_command("run", str(path), "--engine", engine)
        if not command:
            return
        log = Path("/tmp/sevenos-wincompat.log")
        with log.open("ab") as handle:
            subprocess.Popen(command, stdout=handle, stderr=handle, start_new_session=True)
        remember_recent(path)
        status_label.set_text(t("Lancement Windows via {engine}: {name}", "Windows launch via {engine}: {name}", engine=selected, name=path.name))
        set_status(t("Compatibilité Windows lancée", "Windows compatibility launched"))

    def open_file(path: Path):
        remember_recent(path)
        set_busy_cursor(tr_text("Opening {name}...", name=path.name), 620)
        if is_windows_app_file(path):
            open_windows_compat(path)
            return
        if is_risky_file(path) and active_profile in {"shield", "baobab"}:
            status_label.set_text("Risky file detected. Use Safe Open or context menu to continue.")
            update_preview(path)
            return
        if path.suffix.lower() in READER_SUFFIXES:
            open_in_reader(path)
            return
        if is_previewable(path):
            open_quicklook_preview(path)
        else:
            xdg_open(path)

    def safe_open_path(path: Path):
        remember_recent(path)
        if shutil.which("firejail"):
            subprocess.Popen(["firejail", "--quiet", "--private", "xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        elif shutil.which("bwrap"):
            subprocess.Popen(
                ["bwrap", "--ro-bind", "/", "/", "--dev", "/dev", "--proc", "/proc", "xdg-open", str(path)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        else:
            xdg_open(path)
        status_label.set_text(f"Safe Open requested for {path.name}")

    def hash_selected():
        target = selected_path()
        if not target or not target.is_file():
            status_label.set_text("Select a file to hash")
            return

        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, 2, "Hashing file")
            digest = file_hash(target)
            report(2, 2, "Hash ready")
            return digest

        def done(digest):
            if digest == OPERATION_CANCELLED:
                finish_operation("Hash cancelled")
                return
            copy_path_text = f"sha256  {digest}  {target}"
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(copy_path_text, -1)
            finish_operation("SHA256 copied to clipboard")

        run_background("Hashing file", worker, done)

    def open_externally(path: Path):
        if not is_image(path):
            xdg_open(path)
            return
        for command in ("loupe", "eog", "swayimg", "imv", "feh"):
            if shutil.which(command):
                subprocess.Popen([command, str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return
        xdg_open(path)

    def set_wallpaper_from_file(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-wallpaper").exists():
            command = [str(root / "bin/seven-wallpaper"), "set", str(path)]
        else:
            command = ["seven-wallpaper", "set", str(path)]
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def copy_path(path: Path):
        Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(str(path), -1)
        set_status(t("Chemin copié", "Path copied"))

    def copy_text(text: str):
        Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(text, -1)
        set_status(t("Texte copié", "Text copied"))

    def clipboard_file_payload(paths: list[Path], cut: bool = False) -> str:
        action = "cut" if cut else "copy"
        uris = [path.resolve().as_uri() for path in paths if path.exists()]
        return "\n".join([action, *uris]) + "\n"

    def clipboard_uri_list(paths: list[Path]) -> str:
        return "\n".join(path.resolve().as_uri() for path in paths if path.exists()) + "\n"

    def write_clipboard_cache(paths: list[Path], cut: bool = False):
        CLIPBOARD_CACHE.parent.mkdir(parents=True, exist_ok=True)
        CLIPBOARD_CACHE.write_text(
            json.dumps(
                {
                    "action": "cut" if cut else "copy",
                    "paths": [str(path.resolve()) for path in paths if path.exists()],
                    "time": time.time(),
                }
            ),
            encoding="utf-8",
        )

    def paths_from_uri_payload(payload: str) -> tuple[list[Path], bool]:
        lines = [line.strip() for line in payload.splitlines() if line.strip() and not line.startswith("#")]
        cut = False
        if lines and lines[0] in {"copy", "cut"}:
            cut = lines[0] == "cut"
            lines = lines[1:]
        paths: list[Path] = []
        for line in lines:
            if line.startswith("file://"):
                paths.append(Path(GLib.filename_from_uri(line)[0]))
            else:
                paths.append(Path(line))
        return [path for path in paths if path.exists()], cut

    def publish_file_clipboard(paths: list[Path], cut: bool = False):
        valid = [path for path in paths if path.exists()]
        if not valid:
            return
        uri_list = clipboard_uri_list(valid)
        write_clipboard_cache(valid, cut)
        if shutil.which("wl-copy") and os.environ.get("WAYLAND_DISPLAY"):
            subprocess.run(["wl-copy", "--type", "text/uri-list"], input=uri_list, text=True, check=False)
        elif shutil.which("xclip") and os.environ.get("DISPLAY"):
            subprocess.run(["xclip", "-selection", "clipboard", "-t", "text/uri-list"], input=uri_list, text=True, check=False)
        else:
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(uri_list, -1)

    def read_system_file_clipboard() -> tuple[list[Path], bool]:
        commands: list[list[str]] = []
        if shutil.which("wl-paste") and os.environ.get("WAYLAND_DISPLAY"):
            commands.extend([
                ["wl-paste", "--no-newline", "--type", "x-special/gnome-copied-files"],
                ["wl-paste", "--no-newline", "--type", "text/uri-list"],
            ])
        if shutil.which("xclip") and os.environ.get("DISPLAY"):
            commands.append(["xclip", "-selection", "clipboard", "-o", "-t", "x-special/gnome-copied-files"])
        for command in commands:
            result = subprocess.run(command, text=True, capture_output=True, check=False)
            if result.returncode == 0 and result.stdout.strip():
                paths, cut = paths_from_uri_payload(result.stdout)
                if paths:
                    return paths, cut
        if CLIPBOARD_CACHE.exists():
            try:
                data = json.loads(CLIPBOARD_CACHE.read_text(encoding="utf-8"))
                paths = [Path(path) for path in data.get("paths", [])]
                paths = [path for path in paths if path.exists()]
                if paths:
                    return paths, data.get("action") == "cut"
            except (OSError, json.JSONDecodeError):
                pass
        return [], False

    def selected_path() -> Path | None:
        selected = flow.get_selected_children()
        if not selected:
            return None
        return selected[0].path

    def selected_paths() -> list[Path]:
        return [child.path for child in flow.get_selected_children()]

    def focus_path_after_render(path: Path, message: str = "") -> None:
        def apply_focus() -> bool:
            for child in flow.get_children():
                if getattr(child, "path", None) == path:
                    flow.unselect_all()
                    flow.select_child(child)
                    child.grab_focus()
                    update_preview(path)
                    ensure_child_visible(child)
                    if message:
                        set_status(message)
                    return False
            if message:
                set_status(message)
            return False

        GLib.timeout_add(90, apply_focus)

    def decorate_dialog(dialog, title_text: str, subtitle: str = "", icon_name: str = "system-file-manager") -> Gtk.Box:
        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        surface = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        surface.get_style_context().add_class("files-dialog-surface")
        content.pack_start(surface, True, True, 0)
        hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        hero.get_style_context().add_class("files-dialog-hero")
        icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        icon.set_pixel_size(34)
        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title_label = Gtk.Label(label=title_text)
        title_label.set_xalign(0)
        title_label.get_style_context().add_class("files-dialog-title")
        subtitle_label = Gtk.Label(label=subtitle)
        subtitle_label.set_xalign(0)
        subtitle_label.set_line_wrap(True)
        subtitle_label.get_style_context().add_class("files-dialog-subtitle")
        text_box.pack_start(title_label, False, False, 0)
        if subtitle:
            text_box.pack_start(subtitle_label, False, False, 0)
        hero.pack_start(icon, False, False, 0)
        hero.pack_start(text_box, True, True, 0)
        surface.pack_start(hero, False, False, 0)
        return surface

    def copy_items(paths: list[Path], cut: bool = False):
        nonlocal file_clipboard, file_clipboard_cut
        file_clipboard = [path for path in paths if path.exists()]
        file_clipboard_cut = cut
        if file_clipboard:
            publish_file_clipboard(file_clipboard, cut)
            set_status(
                t(
                    "{action} {count} élément(s)",
                    "{action} {count} item(s)",
                    action=t("Coupé", "Cut") if cut else t("Copié", "Copied"),
                    count=len(file_clipboard),
                )
            )

    def copy_selected():
        paths = selected_paths()
        if paths:
            copy_items(paths)

    def cut_selected():
        paths = selected_paths()
        if paths:
            copy_items(paths, cut=True)

    def unique_destination(directory: Path, name: str) -> Path:
        destination = directory / name
        if not destination.exists():
            return destination
        stem = destination.stem
        suffix = destination.suffix
        for index in range(2, 1000):
            candidate = directory / f"{stem} copy {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{stem} copy{suffix}"

    def ask_conflict_policy(title_text: str, conflict_count: int) -> str:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button(t("Ignorer", "Skip"), 10)
        dialog.add_button(t("Remplacer", "Replace"), 20)
        dialog.add_button(t("Garder les deux", "Keep Both"), 30)
        dialog.set_default_response(30)
        content = decorate_dialog(
            dialog,
            t("Conflit de fichiers", "File Conflict"),
            t("{count} élément(s) existent déjà à destination.", "{count} item(s) already exist at the destination.", count=conflict_count),
            "dialog-warning-symbolic",
        )
        hint = Gtk.Label(label=t("Choisis comment Seven Files doit gérer ce conflit pour cette opération.", "Choose how Seven Files should handle name conflicts for this operation."))
        hint.set_xalign(0)
        hint.get_style_context().add_class("preview-hint")
        content.pack_start(hint, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        dialog.destroy()
        if response == 20:
            return "replace"
        if response == 10:
            return "skip"
        if response == 30:
            return "keep_both"
        return "cancel"

    def conflict_policy_for(sources: list[Path], destination_dir: Path) -> str:
        conflicts = [source for source in sources if (destination_dir / source.name).exists()]
        if not conflicts:
            return "direct"
        return ask_conflict_policy("File Conflict", len(conflicts))

    def destination_for_policy(source: Path, destination_dir: Path, policy: str) -> Path | None:
        destination = destination_dir / source.name
        if not destination.exists():
            return destination
        if policy == "skip":
            return None
        if policy == "replace":
            try:
                if destination.is_dir():
                    shutil.rmtree(destination)
                else:
                    destination.unlink()
                return destination
            except OSError:
                return None
        return unique_destination(destination_dir, source.name)

    def path_total_bytes(path: Path) -> int:
        try:
            if path.is_symlink() or path.is_file():
                return max(0, path.lstat().st_size)
            total = 0
            for root_dir, _dirs, files in os.walk(path):
                for filename in files:
                    try:
                        total += max(0, (Path(root_dir) / filename).lstat().st_size)
                    except OSError:
                        continue
            return total
        except OSError:
            return 0

    def operation_eta_label(action: str, done_bytes: int, total_bytes: int, started_at: float, item_name: str = "") -> str:
        elapsed = max(0.1, time.monotonic() - started_at)
        speed = done_bytes / elapsed
        remaining = max(0, total_bytes - done_bytes)
        eta = int(remaining / speed) if speed > 1 else 0
        minutes, seconds = divmod(eta, 60)
        percent = int((done_bytes / total_bytes) * 100) if total_bytes else 0
        suffix = f" · {item_name}" if item_name else ""
        return f"{action} {percent}% · {format_size(int(speed))}/s · {minutes:02d}:{seconds:02d} left{suffix}"

    def copy_file_streamed(source: Path, destination: Path, cancelled, progress) -> None:
        destination.parent.mkdir(parents=True, exist_ok=True)
        if source.is_symlink():
            if destination.exists() or destination.is_symlink():
                destination.unlink()
            os.symlink(os.readlink(source), destination)
            progress(max(1, source.lstat().st_size), source.name)
            return
        copied = 0
        try:
            with source.open("rb") as src, destination.open("wb") as dst:
                while True:
                    if cancelled():
                        raise InterruptedError
                    chunk = src.read(1024 * 1024)
                    if not chunk:
                        break
                    dst.write(chunk)
                    copied += len(chunk)
                    progress(len(chunk), source.name)
            shutil.copystat(source, destination, follow_symlinks=False)
        except InterruptedError:
            try:
                destination.unlink()
            except OSError:
                pass
            raise
        except Exception:
            try:
                if copied == 0 and destination.exists():
                    destination.unlink()
            except OSError:
                pass
            raise

    def copy_path_streamed(source: Path, destination: Path, cancelled, progress) -> None:
        if source.is_dir() and not source.is_symlink():
            destination.mkdir(parents=True, exist_ok=True)
            for root_dir, dirs, files in os.walk(source):
                if cancelled():
                    raise InterruptedError
                relative = Path(root_dir).relative_to(source)
                target_root = destination / relative
                target_root.mkdir(parents=True, exist_ok=True)
                for dirname in dirs:
                    (target_root / dirname).mkdir(exist_ok=True)
                for filename in files:
                    if cancelled():
                        raise InterruptedError
                    copy_file_streamed(Path(root_dir) / filename, target_root / filename, cancelled, progress)
            try:
                shutil.copystat(source, destination, follow_symlinks=False)
            except OSError:
                pass
            return
        copy_file_streamed(source, destination, cancelled, progress)

    def paste_items():
        nonlocal file_clipboard, file_clipboard_cut
        if not file_clipboard:
            file_clipboard, file_clipboard_cut = read_system_file_clipboard()
            if not file_clipboard:
                set_status(t("Rien à coller", "Nothing to paste"))
                return
        sources = list(file_clipboard)
        cut_mode = file_clipboard_cut
        destination_dir = current
        conflict_policy = conflict_policy_for(sources, destination_dir)
        if conflict_policy == "cancel":
            set_status(t("Collage annulé", "Paste cancelled"))
            return

        def worker(cancelled, report):
            pasted = 0
            total = len(sources)
            undo_created: list[str] = []
            undo_moves: list[tuple[str, str]] = []
            total_bytes = max(1, sum(path_total_bytes(source) for source in sources if source.exists()))
            done_bytes = 0
            started_at = time.monotonic()

            def progress(delta: int, item_name: str = "") -> None:
                nonlocal done_bytes
                done_bytes = min(total_bytes, done_bytes + max(0, delta))
                report(done_bytes, total_bytes, operation_eta_label("Pasting", done_bytes, total_bytes, started_at, item_name))

            for index, source in enumerate(sources, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                if not source.exists():
                    report(done_bytes, total_bytes, f"Skipping missing item {index}/{total}")
                    continue
                destination = destination_for_policy(source, destination_dir, conflict_policy)
                if destination is None:
                    progress(path_total_bytes(source), source.name)
                    continue
                try:
                    if cut_mode:
                        original = str(source)
                        shutil.move(str(source), str(destination))
                        undo_moves.append((original, str(destination)))
                        progress(path_total_bytes(destination), destination.name)
                    elif source.is_dir():
                        copy_path_streamed(source, destination, cancelled, progress)
                        undo_created.append(str(destination))
                    else:
                        copy_path_streamed(source, destination, cancelled, progress)
                        undo_created.append(str(destination))
                    pasted += 1
                    report(done_bytes, total_bytes, f"Pasted {index}/{total} · {format_size(done_bytes)}")
                except InterruptedError:
                    return OPERATION_CANCELLED
                except OSError:
                    progress(path_total_bytes(source), source.name)
                    report(done_bytes, total_bytes, f"Paste issue {index}/{total}")
                    continue
            return {"count": pasted, "created": undo_created, "moves": undo_moves}

        def done(result):
            nonlocal file_clipboard, file_clipboard_cut
            if result == OPERATION_CANCELLED:
                finish_operation("Paste cancelled")
                return
            pasted = int(result.get("count", 0)) if isinstance(result, dict) else int(result or 0)
            if cut_mode:
                file_clipboard = []
                file_clipboard_cut = False
                moves = result.get("moves", []) if isinstance(result, dict) else []
                if moves:
                    record_undo(f"Paste move {pasted} item(s)", "moved", moves)
            else:
                created = result.get("created", []) if isinstance(result, dict) else []
                if created:
                    record_undo(f"Paste copy {pasted} item(s)", "copied", created)
            finish_operation(f"Pasted {pasted} item(s)" if pasted else "Paste failed")

        run_background(f"Pasting {len(sources)} item(s)", worker, done)

    def ask_name(title_text: str, default_name: str) -> str | None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button("OK", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = decorate_dialog(dialog, title_text, t("Le nom est appliqué dans le dossier courant.", "The name is applied in the current folder."), "text-x-generic")
        entry = Gtk.Entry()
        entry.get_style_context().add_class("files-dialog-entry")
        entry.set_text(default_name)
        entry.set_activates_default(True)
        content.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not value:
            return None
        return Path(value).name

    def ask_text(title_text: str, default_value: str) -> str | None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button("OK", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = decorate_dialog(dialog, title_text, t("Saisis une valeur et valide avec Entrée.", "Enter a value and confirm with Enter."), "edit-find-symbolic")
        entry = Gtk.Entry()
        entry.get_style_context().add_class("files-dialog-entry")
        entry.set_text(default_value)
        entry.set_activates_default(True)
        content.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not value:
            return None
        return value

    def create_folder():
        name = ask_name(t("Nouveau dossier", "New Folder"), t("Dossier sans titre", "Untitled Folder"))
        if not name:
            return
        destination = unique_destination(current, name)
        try:
            destination.mkdir()
            record_undo(f"Create {destination.name}", "created", [str(destination)])
            render()
            focus_path_after_render(destination, t("Dossier créé: {name}", "Folder created: {name}", name=destination.name))
        except OSError as exc:
            set_status(t("Création du dossier impossible: {error}", "New folder failed: {error}", error=exc))

    def create_file():
        name = ask_name(t("Nouveau fichier", "New File"), "Untitled.txt")
        if not name:
            return
        destination = unique_destination(current, name)
        try:
            destination.touch(exist_ok=False)
            record_undo(f"Create {destination.name}", "created", [str(destination)])
            render()
            focus_path_after_render(destination, t("Fichier créé: {name}", "File created: {name}", name=destination.name))
        except OSError as exc:
            set_status(t("Création du fichier impossible: {error}", "New file failed: {error}", error=exc))

    def rename_path(path: Path):
        name = ask_name(t("Renommer", "Rename"), path.name)
        if not name or name == path.name:
            return
        destination = unique_destination(path.parent, name)
        try:
            path.rename(destination)
            record_undo(f"Rename {destination.name}", "renamed", [(str(path), str(destination))])
            render()
            focus_path_after_render(destination, t("Renommé: {name}", "Renamed: {name}", name=destination.name))
        except OSError as exc:
            set_status(t("Renommage impossible: {error}", "Rename failed: {error}", error=exc))

    def batch_rename_selected():
        paths = selected_paths()
        if len(paths) < 2:
            status_label.set_text("Select multiple items for batch rename")
            return
        pattern = ask_text("Batch Rename", "SevenOS-{n}-{name}")
        if not pattern:
            return
        renamed = 0
        undo_moves: list[tuple[str, str]] = []
        for index, path in enumerate(paths, start=1):
            target_name = pattern.replace("{n}", f"{index:02d}").replace("{name}", path.stem).replace("{ext}", path.suffix.lstrip("."))
            if path.is_file() and "{ext}" not in pattern:
                target_name = f"{target_name}{path.suffix}"
            destination = unique_destination(path.parent, Path(target_name).name)
            try:
                original = str(path)
                path.rename(destination)
                undo_moves.append((original, str(destination)))
                renamed += 1
            except OSError:
                continue
        if undo_moves:
            record_undo(f"Batch rename {renamed} item(s)", "renamed", undo_moves)
        render()
        status_label.set_text(f"Batch renamed {renamed} item(s)")

    def open_terminal_here(path: Path | None = None):
        target = path if path and path.is_dir() else current
        if shutil.which("seven-terminal"):
            subprocess.Popen(["seven-terminal", "profile"], cwd=target, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        for terminal in ("foot", "kitty", "alacritty", "gnome-terminal", "wezterm"):
            if shutil.which(terminal):
                command = [terminal]
                if terminal == "gnome-terminal":
                    command.extend(["--working-directory", str(target)])
                elif terminal == "wezterm":
                    command.extend(["start", "--cwd", str(target)])
                else:
                    command.extend(["--working-directory", str(target)])
                subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return
        status_label.set_text("No terminal found")

    def profile_action(path: Path):
        if active_profile == "forge":
            open_terminal_here(path if path.is_dir() else path.parent)
        elif active_profile == "studio" and is_image(path):
            open_externally(path)
        elif active_profile == "shield" and path.is_file():
            hash_selected()
        elif active_profile == "pulse":
            reveal_in_parent(path)
        else:
            update_preview(path)

    def duplicate_path(path: Path):
        destination = unique_destination(path.parent, f"{path.stem} copy{path.suffix}" if path.is_file() else f"{path.name} copy")
        try:
            if path.is_dir():
                shutil.copytree(path, destination)
            else:
                shutil.copy2(path, destination)
            record_undo(f"Duplicate {destination.name}", "duplicated", [str(destination)])
            render()
            focus_path_after_render(destination, t("Copie créée: {name}", "Copy created: {name}", name=destination.name))
        except OSError as exc:
            set_status(t("Duplication impossible: {error}", "Duplicate failed: {error}", error=exc))

    def trash_path(path: Path, render_after: bool = True) -> bool:
        if shutil.which("gio"):
            result = subprocess.run(["gio", "trash", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                if render_after:
                    render()
                    status_label.set_text(f"Moved {path.name} to Trash")
                return True
        TRASH_FILES_DIR.mkdir(parents=True, exist_ok=True)
        TRASH_INFO_DIR.mkdir(parents=True, exist_ok=True)
        try:
            destination = unique_destination(TRASH_FILES_DIR, path.name)
            original_uri = file_uri(path)
            deletion_date = time.strftime("%Y-%m-%dT%H:%M:%S", time.localtime())
            info_path = TRASH_INFO_DIR / f"{destination.name}.trashinfo"
            info_path.write_text(f"[Trash Info]\nPath={original_uri}\nDeletionDate={deletion_date}\n", encoding="utf-8")
            shutil.move(str(path), str(destination))
            if render_after:
                render()
                status_label.set_text(f"Moved {path.name} to Trash")
            return True
        except OSError as exc:
            if render_after:
                status_label.set_text(f"Trash failed: {exc}")
            return False

    def trash_original_path(path: Path) -> Path | None:
        info_path = TRASH_INFO_DIR / f"{path.name}.trashinfo"
        if not info_path.exists():
            return None
        parser = configparser.ConfigParser()
        try:
            parser.read(info_path, encoding="utf-8")
            raw = parser.get("Trash Info", "Path", fallback="")
        except Exception:
            return None
        if raw.startswith("file://"):
            return Path(urllib.parse.unquote(urllib.parse.urlparse(raw).path))
        return Path(raw).expanduser() if raw else None

    def restore_from_trash(path: Path):
        original = trash_original_path(path)
        if not original:
            status_label.set_text("Restore location is unknown")
            return
        destination = unique_destination(original.parent, original.name)
        try:
            destination.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(path), str(destination))
            info_path = TRASH_INFO_DIR / f"{path.name}.trashinfo"
            info_path.unlink(missing_ok=True)
            render()
            status_label.set_text(f"Restored {destination.name}")
        except OSError as exc:
            status_label.set_text(f"Restore failed: {exc}")

    def trash_selected():
        paths = selected_paths()
        if not paths:
            status_label.set_text("Select an item to move to Trash")
            return

        def worker(cancelled, report):
            moved = 0
            total = len(paths)
            for index, path in enumerate(paths, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                if trash_path(path, render_after=False):
                    moved += 1
                report(index, total, f"Trashed {index}/{total}")
            return moved

        def done(moved):
            if moved == OPERATION_CANCELLED:
                finish_operation("Trash cancelled")
            else:
                finish_operation(f"Moved {moved} item(s) to Trash")

        run_background(f"Trashing {len(paths)} item(s)", worker, done)

    def load_tags() -> dict[str, str]:
        if not TAG_CACHE.exists():
            return {}
        try:
            return json.loads(TAG_CACHE.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            return {}

    def save_tags(tags: dict[str, str]) -> None:
        TAG_CACHE.parent.mkdir(parents=True, exist_ok=True)
        TAG_CACHE.write_text(json.dumps(tags, indent=2, sort_keys=True), encoding="utf-8")

    def tag_paths(paths: list[Path], tag: str):
        if not paths:
            status_label.set_text("Select an item to tag")
            return
        tags = load_tags()
        for path in paths:
            tags[str(path.resolve())] = tag
        save_tags(tags)
        status_label.set_text(f"Tagged {len(paths)} item(s) as {tag}")
        update_preview_multiple(paths) if len(paths) > 1 else update_preview(paths[0])

    def tag_for_path(path: Path) -> str:
        return load_tags().get(str(path.resolve()), "")

    def show_ai_result(title: str, body: str):
        dialog = Gtk.Dialog(title=title, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(560, 420)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        content = decorate_dialog(dialog, title, t("Analyse locale de la sélection.", "Local analysis of the selection."), "seven-ai")
        text = Gtk.TextView()
        text.set_editable(False)
        text.set_cursor_visible(False)
        text.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        text.get_buffer().set_text(body)
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroller.add(text)
        content.pack_start(scroller, True, True, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()

    def sevenai_selected():
        paths = selected_paths()
        if not paths:
            status_label.set_text("Select an item before asking SevenAI")
            return
        root = resolve_root()
        seven = shutil.which("seven")
        seven_cmd = [seven] if seven else [str(root / "bin/seven")] if root and (root / "bin/seven").exists() else []
        if not seven_cmd:
            status_label.set_text("SevenAI command is not available")
            return
        summary = []
        for path in paths[:8]:
            kind = "folder" if path.is_dir() else path.suffix.lower().lstrip(".") or "file"
            summary.append(f"{path.name} ({kind}, {path})")
        prompt = (
            "Analyse cette sélection Seven Files et réponds en langage simple. "
            "Propose 3 actions utiles maximum: " + "; ".join(summary)
        )

        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, 2, "SevenAI is analyzing")
            result = subprocess.run([*seven_cmd, "ai", "provider", prompt], text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False, timeout=14)
            report(2, 2, "SevenAI analysis ready")
            return result.stdout.strip() or "SevenAI n'a pas retourné de suggestion."

        def done(output):
            if output == OPERATION_CANCELLED:
                finish_operation("SevenAI analysis cancelled")
                return
            finish_operation("SevenAI analysis ready")
            show_ai_result("SevenAI · File Insight", output)

        run_background("SevenAI is analyzing", worker, done)

    def calculate_size_for_path(path: Path | None = None) -> bool:
        target = path or selected_path() or current
        if not target.exists():
            set_status(tr_text("Cannot calculate size for missing item"))
            return True

        def worker(cancelled, report):
            total = 0
            count = 0
            if target.is_file() or target.is_symlink():
                return {"bytes": target.lstat().st_size, "count": 1}
            for root_dir, _dirs, files in os.walk(target):
                if cancelled():
                    return OPERATION_CANCELLED
                for filename in files:
                    if cancelled():
                        return OPERATION_CANCELLED
                    try:
                        total += max(0, (Path(root_dir) / filename).lstat().st_size)
                        count += 1
                    except OSError:
                        continue
                    if count % 180 == 0:
                        report(count, max(count + 1, count), tr_text("Calculating size · {count} file(s)", count=count))
            return {"bytes": total, "count": count}

        def done(result):
            if result == OPERATION_CANCELLED:
                finish_operation("Size calculation cancelled")
                return
            size = int(result.get("bytes", 0)) if isinstance(result, dict) else 0
            count = int(result.get("count", 0)) if isinstance(result, dict) else 0
            finish_operation(f"{target.name or target}: {format_size(size)} across {count} file(s)")

        run_background(f"Calculating size for {target.name or target}", worker, done)
        return True

    def go_to_path_dialog():
        show_location_entry()

    def archive_destination(path: Path, item_count: int = 1, archive_format: str = "zip", requested_name: str | None = None) -> Path:
        if item_count > 1 and path == current:
            base = "Archive"
            directory = current
        else:
            base = path.stem if path.is_file() else path.name
            directory = path.parent if path != current else current
        suffix = ARCHIVE_FORMATS.get(archive_format, ".zip")
        if requested_name:
            base = Path(requested_name).name
            for archive_suffix in sorted(ARCHIVE_FORMATS.values(), key=len, reverse=True):
                if base.endswith(archive_suffix):
                    base = base[: -len(archive_suffix)]
                    break
        candidate = directory / f"{base}{suffix}"
        if not candidate.exists():
            return candidate
        for index in range(2, 1000):
            candidate = directory / f"{base} {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{base} archive{suffix}"

    def archive_member_name(target: Path, item: Path) -> str:
        if target.is_dir():
            return str(item.relative_to(target.parent))
        return target.name

    def write_archive(destination: Path, targets: list[Path], archive_format: str):
        if archive_format == "zip":
            with zipfile.ZipFile(destination, "w", compression=zipfile.ZIP_DEFLATED) as archive:
                for target in targets:
                    if target.is_dir():
                        for item in target.rglob("*"):
                            if item == destination:
                                continue
                            archive.write(item, archive_member_name(target, item))
                    else:
                        archive.write(target, target.name)
            return
        mode = "w:gz" if archive_format == "tar.gz" else "w:xz"
        with tarfile.open(destination, mode) as archive:
            for target in targets:
                archive.add(target, arcname=target.name)

    def ask_archive_options(default_name: str) -> tuple[str, str] | None:
        dialog = Gtk.Dialog(title=tr_text("Compress"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(tr_text("Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button(tr_text("Compress"), Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = decorate_dialog(dialog, t("Compresser", "Compress"), t("Crée une archive dans le dossier courant.", "Create an archive in the current folder."), "package-x-generic")
        name_label = Gtk.Label(label=tr_text("Archive name"))
        name_label.set_xalign(0)
        entry = Gtk.Entry()
        entry.get_style_context().add_class("files-dialog-entry")
        entry.set_text(default_name)
        entry.set_activates_default(True)
        format_label = Gtk.Label(label=tr_text("Format"))
        format_label.set_xalign(0)
        combo = Gtk.ComboBoxText()
        for value in ARCHIVE_FORMATS:
            combo.append_text(value)
        combo.set_active(0)
        content.pack_start(name_label, False, False, 0)
        content.pack_start(entry, False, False, 0)
        content.pack_start(format_label, False, False, 0)
        content.pack_start(combo, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        name = entry.get_text().strip()
        archive_format = combo.get_active_text() or "zip"
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not name:
            return None
        return name, archive_format

    def compress_paths(paths: list[Path]):
        targets = [path for path in paths if path.exists()]
        if not targets:
            status_label.set_text("Select an item to compress")
            return
        base_path = targets[0] if len(targets) == 1 else current
        default_name = "Archive" if len(targets) > 1 else (base_path.stem if base_path.is_file() else base_path.name)
        options = ask_archive_options(default_name)
        if not options:
            status_label.set_text("Compression cancelled")
            return
        requested_name, archive_format = options
        destination = archive_destination(base_path, len(targets), archive_format, requested_name)
        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, max(1, len(targets)), f"Compressing {len(targets)} item(s)")
            write_archive(destination, targets, archive_format)
            report(max(1, len(targets)), max(1, len(targets)), "Compression complete")
            return destination.name

        def done(name):
            if name == OPERATION_CANCELLED:
                finish_operation("Compression cancelled")
                return
            finish_operation(f"Compressed {len(targets)} item(s) to {name}")

        run_background(f"Compressing {len(targets)} item(s)", worker, done)

    def compress_selected():
        paths = selected_paths()
        if paths:
            compress_paths(paths)
        else:
            status_label.set_text("Select an item to compress")

    def reveal_in_parent(path: Path):
        xdg_open(path.parent if path.is_file() else path)

    def human_mode(path: Path) -> str:
        try:
            return oct(path.stat().st_mode & 0o777)
        except OSError:
            return "Unknown"

    def human_owner(path: Path) -> str:
        try:
            stat = path.stat()
            user = pwd.getpwuid(stat.st_uid).pw_name
            group = grp.getgrgid(stat.st_gid).gr_name
            return f"{user}:{group}"
        except Exception:
            return "Unknown"

    def filesystem_usage(path: Path) -> tuple[str, str] | None:
        try:
            stat = os.statvfs(path)
            total = stat.f_blocks * stat.f_frsize
            available = stat.f_bavail * stat.f_frsize
            used = max(0, total - available)
            percent = int((used / total) * 100) if total else 0
            return f"{format_size(available)} available", f"{format_size(used)} used of {format_size(total)} ({percent}%)"
        except OSError:
            return None

    def set_permissions_dialog(path: Path) -> None:
        current_mode = human_mode(path)
        dialog = Gtk.Dialog(title=tr_text("Edit Permissions"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button(t("Appliquer", "Apply"), Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        box = decorate_dialog(dialog, t("Permissions", "Permissions"), t("Choisis un préréglage sûr ou ajuste la valeur avancée.", "Choose a safe preset or adjust the advanced value."), "dialog-password-symbolic")
        hint = Gtk.Label(label=tr_text("Choose a safe permission preset, or adjust the advanced value."))
        hint.set_xalign(0)
        hint.set_line_wrap(True)
        hint.get_style_context().add_class("preview-hint")
        box.pack_start(hint, False, False, 0)
        combo = Gtk.ComboBoxText()
        presets = [
            ("private", "Private - only me", "700" if path.is_dir() else "600"),
            ("standard", "Standard - me write, others read", "755" if path.is_dir() else "644"),
            ("shared", "Shared - group can write", "775" if path.is_dir() else "664"),
            ("advanced", "Advanced custom value", current_mode if current_mode != "Unknown" else ("755" if path.is_dir() else "644")),
        ]
        for preset_id, label, _mode in presets:
            combo.append(preset_id, tr_text(label))
        combo.set_active_id("standard")
        entry = Gtk.Entry()
        entry.get_style_context().add_class("files-dialog-entry")
        entry.set_text("755" if path.is_dir() else "644")
        entry.set_tooltip_text(tr_text("Advanced octal value, for example 755, 644 or 700"))

        def preset_changed(_combo) -> None:
            selected = combo.get_active_id()
            for preset_id, _label, mode in presets:
                if preset_id == selected:
                    entry.set_text(mode)
                    break

        combo.connect("changed", preset_changed)
        box.pack_start(combo, False, False, 0)
        box.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK:
            return
        cleaned = value.strip().lower().replace("0o", "")
        if not cleaned or any(char not in "01234567" for char in cleaned) or len(cleaned) > 4:
            set_status("Use permissions such as 755, 644 or 700")
            return
        try:
            os.chmod(path, int(cleaned, 8))
            set_status(f"Permissions updated: {path.name or path} -> {oct(path.stat().st_mode & 0o777)}")
            update_preview(path)
            schedule_folder_refresh()
        except PermissionError:
            set_status("Permission denied. Open as admin or use Terminal for protected files.")
        except OSError as exc:
            set_status(f"Permission update failed: {exc}")

    def copy_owner_command(path: Path) -> None:
        command = f"sudo chown {os.environ.get('USER', 'seven')}:{os.environ.get('USER', 'seven')} {shlex.quote(str(path))}"
        copy_text(command)
        status_label.set_text("Owner repair command copied")

    def clean_thumbnail_cache() -> None:
        def worker(cancelled, report):
            removed = 0
            files = [item for item in THUMB_CACHE.glob("*.png")] if THUMB_CACHE.exists() else []
            total = max(1, len(files))
            for index, item in enumerate(files, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                try:
                    item.unlink()
                    removed += 1
                except OSError:
                    pass
                report(index, total, f"Cleaning thumbnails {index}/{total}")
            return removed

        def done(removed):
            if removed == OPERATION_CANCELLED:
                finish_operation("Thumbnail cleanup cancelled")
            else:
                finish_operation(f"Cleaned {removed} thumbnail(s)")

        run_background("Cleaning thumbnail cache", worker, done)

    def reset_saved_session() -> bool:
        if not confirm_dialog(
            tr_text("Reset Seven Files Session"),
            tr_text("This clears saved tabs and window size. Your files are not modified."),
            tr_text("Reset"),
        ):
            return True
        try:
            SESSION_CACHE.unlink(missing_ok=True)
            set_status(tr_text("Seven Files session reset"))
        except OSError as exc:
            set_status(f"Session reset failed: {exc}")
        return True

    def show_files_guide() -> bool:
        dialog = Gtk.Dialog(title=tr_text("Seven Files Guide"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        dialog.set_default_size(520, 460)
        box = decorate_dialog(dialog, tr_text("Seven Files"), t("Repères essentiels pour naviguer vite et sans terminal.", "Essential hints for fast navigation without the terminal."), "system-file-manager")
        title = Gtk.Label(label=tr_text("Seven Files"))
        title.set_xalign(0)
        title.get_style_context().add_class("preview-title")
        box.pack_start(title, False, False, 0)
        guide_items = [
            (t("Mini OS", "Mini OS"), t("La section colorée permet d'ouvrir les dossiers Baobab, Forge, Shield, Studio, Atlas, Pulse ou SevenOS.", "Use the colored sidebar section to jump into Baobab, Forge, Shield, Studio, Atlas, Pulse or SevenOS folders.")),
            (t("Ressources", "Resources"), t("Téléchargements, Documents, Code, Musique, Images et Vidéos suivent le Mini OS actif par défaut. Les ressources partagées restent disponibles dans le menu système.", "Downloads, Documents, Code, Music, Pictures and Videos follow the active mini OS by default. Use shared resources from the system menu if you want one global library.")),
            (t("Actions", "Actions"), t("Ctrl+K recherche toutes les actions. Ctrl+G ouvre les favoris, récents et emplacements réseau.", "Press Ctrl+K to search every file action. Use Ctrl+G for favorites, recents and network places.")),
            (t("Fichiers", "Files"), t("Double-clic ouvre, Espace prévisualise, F2 renomme, Ctrl+Z annule les actions compatibles.", "Double-click opens, Space previews, F2 renames, Ctrl+Z undoes supported actions.")),
            (t("Volumes", "Volumes"), t("Les partitions Windows et disques amovibles apparaissent dans Emplacements. Clic droit pour monter, démonter ou éjecter.", "Windows partitions and removable drives appear in Locations. Right-click a volume to mount, unmount or eject.")),
            (t("Opérations", "Operations"), t("Copie, déplacement, compression et calcul de taille tournent en arrière-plan avec pause, annulation et progression.", "Copy, move, compress and size calculation run in the background with pause, cancel and progress.")),
            (t("Sécurité", "Safety"), t("Les fichiers risqués proposent une ouverture isolée. Permissions et propriétaire sont dans Informations.", "Risky files get Safe Open. Permissions and ownership helpers live in Properties.")),
        ]
        for heading_text, body_text in guide_items:
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            card.get_style_context().add_class("inspector-card")
            heading = Gtk.Label(label=heading_text)
            heading.set_xalign(0)
            heading.get_style_context().add_class("preview-heading")
            body = Gtk.Label(label=body_text)
            body.set_xalign(0)
            body.set_line_wrap(True)
            body.get_style_context().add_class("preview-value")
            card.pack_start(heading, False, False, 0)
            card.pack_start(body, False, False, 0)
            box.pack_start(card, False, False, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()
        return True

    def properties_dialog(path: Path):
        dialog = Gtk.Dialog(title=f"Properties · {path.name or path}", transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Fermer", "Close"), Gtk.ResponseType.CLOSE)
        dialog.set_default_size(420, 360)
        box = decorate_dialog(dialog, t("Informations", "Properties"), path.name or str(path), folder_icon(path))
        icon = Gtk.Image.new_from_icon_name(folder_icon(path), Gtk.IconSize.DIALOG)
        icon.set_pixel_size(56)
        title = Gtk.Label(label=path.name or str(path))
        title.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        title.get_style_context().add_class("preview-title")
        box.pack_start(icon, False, False, 0)
        box.pack_start(title, False, False, 0)
        try:
            stat = path.stat()
            rows = [
                (t("Type", "Kind"), t("Dossier", "Folder") if path.is_dir() else (path.suffix.upper().lstrip(".") or t("Fichier", "File"))),
                (t("Chemin", "Path"), str(path)),
                (t("Taille", "Size"), format_size(stat.st_size) if path.is_file() else file_row_meta(path)),
                (t("Modifié", "Modified"), time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(stat.st_mtime))),
                (t("Permissions", "Permissions"), human_mode(path)),
                (t("Propriétaire", "Owner"), human_owner(path)),
            ]
            usage = filesystem_usage(path if path.is_dir() else path.parent)
            if usage:
                rows.extend([(t("Disponible", "Available"), usage[0]), (t("Volume", "Volume"), usage[1])])
        except OSError as exc:
            rows = [(t("Erreur", "Error"), str(exc))]
        for key, value in rows:
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            card.get_style_context().add_class("inspector-card")
            k = Gtk.Label(label=key)
            k.set_xalign(0)
            k.get_style_context().add_class("preview-heading")
            v = Gtk.Label(label=value)
            v.set_xalign(0)
            v.set_selectable(True)
            v.set_line_wrap(True)
            v.get_style_context().add_class("preview-value")
            card.pack_start(k, False, False, 0)
            card.pack_start(v, False, False, 0)
            box.pack_start(card, False, False, 0)
        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        copy_button = Gtk.Button(label=t("Copier le chemin", "Copy Path"))
        copy_button.connect("clicked", lambda *_: copy_path(path))
        actions.pack_start(copy_button, False, False, 0)
        permissions_button = Gtk.Button(label=t("Modifier permissions", "Edit Permissions"))
        permissions_button.connect("clicked", lambda *_: set_permissions_dialog(path))
        actions.pack_start(permissions_button, False, False, 0)
        owner_button = Gtk.Button(label=t("Copier correction propriétaire", "Copy Owner Fix"))
        owner_button.connect("clicked", lambda *_: copy_owner_command(path))
        actions.pack_start(owner_button, False, False, 0)
        if path.is_dir():
            size_button = Gtk.Button(label=t("Calculer la taille", "Calculate Size"))
            size_button.connect("clicked", lambda *_: calculate_size_for_path(path))
            actions.pack_start(size_button, False, False, 0)
        if path.is_file():
            hash_button = Gtk.Button(label=t("Copier SHA256", "Copy SHA256"))
            hash_button.connect("clicked", lambda *_: hash_selected())
            actions.pack_start(hash_button, False, False, 0)
        box.pack_start(actions, False, False, 4)
        dialog.show_all()
        dialog.run()
        dialog.destroy()

    def add_menu_item(menu, label: str, callback):
        item = Gtk.MenuItem(label=label)
        item.connect("activate", lambda *_: callback())
        menu.append(item)

    def show_selection_actions_menu(button) -> bool:
        paths = selected_paths()
        target = paths[0] if paths else selected_path()
        single = len(paths) == 1 and target is not None
        multiple = len(paths) > 1
        menu = Gtk.Menu()
        if single:
            add_menu_item(menu, t("Aperçu", "Preview"), lambda: open_quicklook_preview(target) if target and is_previewable(target) else update_preview(target or current))
            if target and is_windows_app_file(target):
                add_menu_item(menu, t("Ouvrir via Windows", "Open with Windows compatibility"), lambda: open_windows_compat(target))
            if target and is_risky_file(target):
                add_menu_item(menu, t("Ouvrir isolé", "Safe Open"), lambda: safe_open_path(target))
            add_menu_item(menu, t("Informations", "Get Info"), lambda: properties_dialog(target or current))
            add_menu_item(menu, t("Copier le chemin", "Copy Path"), lambda: copy_path(target))
        elif multiple:
            add_menu_item(menu, t("Aperçu groupé", "Group Preview"), lambda: update_preview_multiple(paths))
            add_menu_item(menu, t("Copier les chemins", "Copy Paths"), lambda: copy_text("\n".join(str(path) for path in paths)))
        add_menu_item(menu, t("Déplacer", "Move"), lambda: copy_selected_to_split(True) if split_visible else cut_selected())
        add_menu_item(menu, t("Compresser", "Compress"), compress_selected)
        add_menu_item(menu, "SevenAI", sevenai_selected)
        menu.append(Gtk.SeparatorMenuItem())
        if single:
            add_menu_item(menu, t("Renommer", "Rename"), lambda: rename_path(target) if target else None)
            add_menu_item(menu, t("Dupliquer", "Duplicate"), lambda: duplicate_path(target) if target else None)
        add_menu_item(menu, t("Corbeille", "Trash"), trash_selected)
        menu.show_all()
        try:
            menu.popup_at_widget(button, Gdk.Gravity.SOUTH_WEST, Gdk.Gravity.NORTH_WEST, None)
        except Exception:
            menu.popup(None, None, None, None, 0, Gtk.get_current_event_time())
        return True

    def confirm_dialog(title_text: str, body: str, action: str = "Continue") -> bool:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(t("Annuler", "Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button(action, Gtk.ResponseType.OK)
        content = decorate_dialog(dialog, title_text, "", "dialog-question-symbolic")
        label = Gtk.Label(label=body)
        label.set_xalign(0)
        label.set_line_wrap(True)
        label.get_style_context().add_class("preview-hint")
        content.pack_start(label, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        dialog.destroy()
        return response == Gtk.ResponseType.OK

    def launch_with_app(path: Path, app) -> None:
        try:
            app.launch([Gio.File.new_for_path(str(path))], None)
            set_busy_cursor(tr_text("Opening {name}...", name=path.name), 520)
        except Exception as exc:
            set_status(f"Open With failed: {exc}")

    def add_open_with_submenu(menu: Gtk.Menu, path: Path) -> None:
        if not path.is_file():
            return
        try:
            content_type, _uncertain = Gio.content_type_guess(str(path), None)
            apps = Gio.AppInfo.get_all_for_type(content_type) if content_type else []
        except Exception:
            apps = []
        if not apps:
            return
        submenu = Gtk.Menu()
        seen: set[str] = set()
        for app in apps[:8]:
            name = app.get_display_name() or app.get_name() or ""
            app_id = app.get_id() or name
            if not name or app_id in seen:
                continue
            seen.add(app_id)
            item = Gtk.MenuItem(label=name)
            item.connect("activate", lambda _item, selected_app=app: launch_with_app(path, selected_app))
            submenu.append(item)
        if not seen:
            return
        parent = Gtk.MenuItem(label=t("Ouvrir avec", "Open With"))
        parent.set_submenu(submenu)
        menu.append(parent)

