    def setup_place_drop_target(widget, target: Path | str):
        uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 1)
        widget.drag_dest_set(Gtk.DestDefaults.ALL, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
        widget.connect("drag-motion", lambda row, context, _x, _y, time_value: on_drop_motion(row, context, time_value))
        widget.connect("drag-leave", lambda row, _context, _time: cancel_spring_open(row))
        widget.connect("drag-data-received", lambda row, context, _x, _y, data, _info, time_value, drop_target=target: on_sidebar_drop(row, context, data, time_value, drop_target))

    def add_place(label: str, icon: str, path: Path | str, container: Gtk.Box | None = None):
        target_container = container or sidebar
        row = Gtk.Button()
        row.set_relief(Gtk.ReliefStyle.NONE)
        row.get_style_context().add_class("sidebar-row")
        content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        content.pack_start(image, False, False, 0)
        content.pack_start(text, True, True, 0)
        row.add(content)
        row.connect("clicked", lambda *_: navigate_uri_or_path(path))
        row.connect("pressed", lambda widget: press_feedback(widget))
        row.connect("released", lambda widget: release_feedback(widget))
        row.place_path = path
        row.spring_target = path
        setup_place_drop_target(row, path)
        sidebar_buttons.append(row)
        target_container.pack_start(row, False, False, 0)
        return row

    def mounted_locations() -> list[tuple[str, str, Path | str]]:
        locations: list[tuple[str, str, Path | str]] = []
        try:
            monitor = Gio.VolumeMonitor.get()
            for mount in monitor.get_mounts():
                root_file = mount.get_root()
                path = root_file.get_path()
                uri = root_file.get_uri()
                label = mount.get_name() or path or uri
                target: Path | str = Path(path) if path else uri
                if target not in [item[2] for item in locations]:
                    locations.append((label, "drive-removable-media", target))
        except Exception:
            pass
        return locations

    def favorite_paths() -> list[Path]:
        items = load_json(FAVORITES_CACHE, [])
        paths: list[Path] = []
        if isinstance(items, list):
            for item in items:
                path = Path(str(item)).expanduser()
                if path.exists() and path.is_dir() and path not in paths:
                    paths.append(path)
        return paths[:16]

    def save_favorite_paths(paths: list[Path]) -> None:
        write_json(FAVORITES_CACHE, [str(path) for path in paths if path.exists() and path.is_dir()])

    def add_favorite_path(path: Path) -> None:
        target = path if path.is_dir() else path.parent
        paths = favorite_paths()
        if target not in paths:
            paths.append(target)
            save_favorite_paths(paths)
            render_favorite_rows()
            set_status(f"Added favorite: {target.name or target}")
        else:
            set_status(f"Favorite already exists: {target.name or target}")

    def remove_favorite_path(path: Path) -> None:
        target = path if path.is_dir() else path.parent
        paths = [item for item in favorite_paths() if item != target]
        save_favorite_paths(paths)
        render_favorite_rows()
        set_status(f"Removed favorite: {target.name or target}")

    def connect_to_server() -> None:
        uri = ask_text("Connect to Server", "smb://")
        if not uri:
            return
        if uri.startswith(("smb://", "sftp://", "ftp://", "dav://", "davs://")):
            subprocess.Popen(["gio", "open", uri] if shutil.which("gio") else ["xdg-open", uri], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            set_status(f"Opening network location {uri}")
        else:
            set_status("Use a network URI such as smb://server/share or sftp://host")

