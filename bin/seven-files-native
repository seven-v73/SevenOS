def theme_css(theme_mode: str, profile_ui: dict | None = None) -> str:
    shared_css = seven_theme.gtk_app_css("files", theme_mode) if seven_theme else ""
    if theme_mode == "light":
        return shared_css + """
        @define-color files_bg #F8FAFD;
        @define-color files_panel rgba(255,255,255,0.82);
        @define-color files_sidebar rgba(244,247,251,0.86);
        @define-color files_text #1C1F26;
        @define-color files_muted #6B7280;
        @define-color files_border rgba(0,0,0,0.08);
        @define-color files_hover rgba(47,123,255,0.10);
        @define-color files_selected rgba(47,123,255,0.18);
        @define-color files_accent #2F7BFF;
        """ + profile_css(theme_mode, profile_ui or {})
    return shared_css + """
    @define-color files_bg #09090B;
    @define-color files_panel rgba(18,19,26,0.78);
    @define-color files_sidebar rgba(17,17,27,0.84);
    @define-color files_text #EDEDED;
    @define-color files_muted #A6ADC8;
    @define-color files_border rgba(255,255,255,0.10);
    @define-color files_hover rgba(77,163,255,0.12);
    @define-color files_selected rgba(122,92,255,0.24);
    @define-color files_accent #89B4FA;
    """ + profile_css(theme_mode, profile_ui or {})


def folder_icon(path: Path) -> str:
    mapping = {
        "Desktop": "user-desktop",
        "Documents": "folder-documents",
        "Downloads": "folder-download",
        "Music": "folder-music",
        "Pictures": "folder-pictures",
        "Videos": "folder-videos",
        "Projects": "folder-development",
    }
    if path.is_dir():
        return mapping.get(path.name, "folder")
    suffix = path.suffix.lower()
    if suffix in IMAGE_SUFFIXES:
        return "image-x-generic"
    if suffix in VIDEO_SUFFIXES:
        return "video-x-generic"
    if suffix in AUDIO_SUFFIXES:
        return "audio-x-generic"
    if suffix in WINDOWS_APP_SUFFIXES:
        return "application-x-ms-dos-executable"
    if suffix in {".zip", ".tar", ".gz", ".xz", ".7z"}:
        return "package-x-generic"
    if suffix == ".pdf":
        return "application-pdf"
    if suffix in {".sh", ".py", ".rs", ".js", ".ts", ".html", ".css", ".json", ".md"}:
        return "text-x-script"
    return "text-x-generic"


def file_uri(path: Path) -> str:
    return path.resolve().as_uri()


def file_paths_from_uri_payload(payload: str) -> list[Path]:
    paths: list[Path] = []
    for line in payload.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if line in {"copy", "cut"}:
            continue
        if line.startswith("file://"):
            try:
                paths.append(Path(urllib.parse.unquote(urllib.parse.urlparse(line).path)))
            except Exception:
                continue
        else:
            paths.append(Path(line).expanduser())
    return [path for path in paths if path.exists()]


def is_risky_file(path: Path) -> bool:
    if not path.is_file():
        return False
    if path.suffix.lower() in {".sh", ".bash", ".zsh", ".fish", ".py", ".js", ".ts", ".jar", ".desktop"} | WINDOWS_APP_SUFFIXES:
        return True
    try:
        return bool(path.stat().st_mode & 0o111)
    except OSError:
        return False


def file_hash(path: Path, algorithm: str = "sha256", limit: int | None = None) -> str:
    digest = hashlib.new(algorithm)
    with path.open("rb") as handle:
        remaining = limit
        while True:
            if remaining is not None and remaining <= 0:
                break
            chunk = handle.read(1024 * 1024 if remaining is None else min(1024 * 1024, remaining))
            if not chunk:
                break
            digest.update(chunk)
            if remaining is not None:
                remaining -= len(chunk)
    return digest.hexdigest()


ARCHIVE_FORMATS = {
    "zip": ".zip",
    "tar.gz": ".tar.gz",
    "tar.xz": ".tar.xz",
}


def run_files(start_path: str) -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("GdkPixbuf", "2.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GdkPixbuf, Gio, GLib, Gtk, Pango
    try:
        gi.require_version("Gst", "1.0")
        from gi.repository import Gst

        Gst.init(None)
    except Exception:
        Gst = None
    GLib.set_prgname("SevenFilesNative")
    theme_mode = read_theme_mode()
    profile_ui = read_profile_ui()
    active_profile = read_active_profile()
    GLib.set_application_name(f"Seven Files · {profile_title(active_profile, profile_ui)}")
    try:
        Gdk.set_program_class("SevenFilesNative")
    except Exception:
        pass

    icon_theme = read_icon_theme(theme_mode)
    gtk_settings = Gtk.Settings.get_default()
    if gtk_settings:
        gtk_settings.set_property("gtk-icon-theme-name", icon_theme)

    prefs = load_json(PREFS_CACHE, {})
    grouped_resources = bool(prefs.get("grouped_resources", False))

    def mini_os_resource_root_for_start() -> Path:
        profile_key = (active_profile or "equinox").strip().lower() or "equinox"
        if grouped_resources or profile_key == "equinox":
            return Path.home()
        return Path.home() / ".local/share/sevenos/profile-containers" / profile_key / "home"

    virtual_location = ""
    start_raw = start_path.strip()
    explicit_start = start_raw not in {"", str(Path.home())}
    if start_raw.startswith("recent://"):
        current = Path.home()
        virtual_location = "recent"
    elif start_raw.startswith("trash://"):
        current = Path.home() / ".local/share/Trash/files"
        current.mkdir(parents=True, exist_ok=True)
    elif not start_raw:
        current = mini_os_resource_root_for_start()
    else:
        current = Path(start_path).expanduser()
    if not start_raw:
        try:
            current.mkdir(parents=True, exist_ok=True)
        except OSError:
            pass
    if not current.exists():
        current = Path.home()
    if current.is_file():
        current = current.parent

    history: list[Path] = []
    future: list[Path] = []
    tabs: list[dict[str, object]] = []
    active_tab_index = 0
    file_clipboard: list[Path] = []
    file_clipboard_cut = False
    view_mode = str(prefs.get("view_mode", "grid"))
    if view_mode not in {"grid", "list", "compact"}:
        view_mode = "grid"
    sort_mode = str(prefs.get("sort_mode", "name"))
    if sort_mode not in {"name", "modified", "size", "kind"}:
        sort_mode = "name"
    search_query = ""
    show_hidden = bool(prefs.get("show_hidden", False))
    sidebar_visible_pref = bool(prefs.get("sidebar_visible", True))
    # The sidebar is part of the file manager's core navigation contract:
    # disks, removable media and network locations must stay discoverable.
    # Older preferences could persist a hidden sidebar and make external
    # drives look "undetected", so restore the public default at launch.
    if prefs.get("sidebar_visible") is False:
        sidebar_visible_pref = True
    preview_visible_pref = bool(prefs.get("preview_visible", True))
    operation_active = False
    operation_cancel_requested = False
    operation_pause_requested = False
    selection_anchor: Path | None = None
    rubberband_origin: tuple[int, int] | None = None
    rubberband_rect = {"x": 0, "y": 0, "w": 0, "h": 0, "active": False}
    spring_open_state = {"id": 0, "target": None, "widget": None}
    hover_preview_state = {"id": 0}
    search_render_state = {"id": 0}
    folder_monitor_state = {"monitor": None, "path": None, "render_id": 0}
    render_restore_state = {"scroll": 0.0, "selected": set()}
    render_limit_state = {"limit": RENDER_LIMIT, "signature": ""}
    feedback_state = {"toast_id": 0, "flash_id": 0, "cursor_id": 0}
    split_current = Path.home()
    split_visible = False
    operation_history: list[str] = []
    undo_stack: list[dict[str, object]] = []

    css = theme_css(theme_mode, profile_ui) + seven_theme.surface_css("files", mode=theme_mode)
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    screen = Gdk.Screen.get_default()
    screen_width = screen.get_width() if screen else 1280
    screen_height = screen.get_height() if screen else 720
    workarea_width = screen_width
    workarea_height = screen_height
    try:
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() if display else None
        if monitor is None and display is not None:
            monitor = display.get_monitor_at_point(0, 0)
        if monitor is not None:
            workarea = monitor.get_workarea()
            workarea_width = max(MIN_WINDOW_SIZE[0], int(workarea.width))
            workarea_height = max(MIN_WINDOW_SIZE[1], int(workarea.height))
    except Exception:
        pass
    screen_compact = workarea_width < 920 or workarea_height < 620
    screen_tiny = workarea_width < 700 or workarea_height < 500
    runtime_sidebar_visible = sidebar_visible_pref and not screen_tiny
    runtime_preview_visible = preview_visible_pref and not screen_compact
    if screen_tiny and prefs.get("view_mode") is None:
        view_mode = "compact"

    def screen_window_size() -> tuple[int, int]:
        return (
            min(DEFAULT_WINDOW_SIZE[0], max(MIN_WINDOW_SIZE[0], min(workarea_width - 40, int(workarea_width * 0.70)))),
            min(DEFAULT_WINDOW_SIZE[1], max(MIN_WINDOW_SIZE[1], min(workarea_height - 56, int(workarea_height * 0.68)))),
        )

    def compact_window_size(width: int | None = None, height: int | None = None) -> tuple[int, int]:
        target_width, target_height = screen_window_size()
        requested_width = target_width if width is None else int(width)
        requested_height = target_height if height is None else int(height)
        max_width = min(DEFAULT_WINDOW_SIZE[0], max(MIN_WINDOW_SIZE[0], workarea_width - 40))
        max_height = min(DEFAULT_WINDOW_SIZE[1], max(MIN_WINDOW_SIZE[1], workarea_height - 56))
        return (
            min(max(MIN_WINDOW_SIZE[0], requested_width), max_width),
            min(max(MIN_WINDOW_SIZE[1], requested_height), max_height),
        )

    window = Gtk.Window(title=f"Seven Files · {profile_title(active_profile, profile_ui)}")
    window.set_default_size(*screen_window_size())
    window.set_size_request(*MIN_WINDOW_SIZE)
    window.set_resizable(True)
    window.set_decorated(False)
    window.set_wmclass("SevenFilesNative", "SevenFilesNative")
    window.get_style_context().add_class("seven-files")

    root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    root.get_style_context().add_class("files-root")
    window.add(root)

    sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar.get_style_context().add_class("files-sidebar")
    sidebar.set_size_request(132 if screen_compact else 150, -1)
    root.pack_start(sidebar, False, False, 0)

    traffic = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    traffic.get_style_context().add_class("traffic-row")
    sidebar.pack_start(traffic, False, False, 0)

    def draw_dot(widget, cr, fill: str, stroke: str, style: str):
        rgba = Gdk.RGBA()
        border = Gdk.RGBA()
        rgba.parse(fill)
        border.parse(stroke)
        alloc = widget.get_allocation()
        radius = min(alloc.width, alloc.height) / 2 - 1
        cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, rgba.alpha)
        cr.arc(alloc.width / 2, alloc.height / 2, radius, 0, 6.28318)
        cr.fill_preserve()
        cr.set_source_rgba(border.red, border.green, border.blue, 0.72)
        cr.set_line_width(1)
        cr.stroke()
        draw_dot_symbol(cr, style, alloc.width / 2, alloc.height / 2, radius)
        return False

    def draw_dot_symbol(cr, style: str, center_x: float, center_y: float, radius: float) -> None:
        cr.set_line_width(1.35)
        cr.set_line_cap(1)
        cr.set_source_rgba(0.20, 0.14, 0.10, 0.52)
        if style == "close":
            offset = radius * 0.38
            cr.move_to(center_x - offset, center_y - offset)
            cr.line_to(center_x + offset, center_y + offset)
            cr.move_to(center_x + offset, center_y - offset)
            cr.line_to(center_x - offset, center_y + offset)
        elif style == "min":
            offset = radius * 0.42
            cr.move_to(center_x - offset, center_y)
            cr.line_to(center_x + offset, center_y)
        elif style == "max":
            offset = radius * 0.36
            cr.move_to(center_x, center_y - offset)
            cr.line_to(center_x, center_y + offset)
            cr.move_to(center_x - offset, center_y)
            cr.line_to(center_x + offset, center_y)
        cr.stroke()

    def dot(fill: str, stroke: str, style: str, callback):
        event = Gtk.EventBox()
        event.set_visible_window(False)
        event.set_above_child(True)
        area = Gtk.DrawingArea()
        area.set_size_request(15, 15)
        area.get_style_context().add_class("traffic-dot")
        area.connect("draw", draw_dot, fill, stroke, style)
        event.add(area)
        event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
        event.connect("button-press-event", lambda widget, event_data: activate_dot(widget, event_data, callback))
        event.connect("button-release-event", lambda _widget, _event: release_feedback(event))
        return event

    def activate_dot(widget, event_data, callback) -> bool:
        if getattr(event_data, "button", 0) == 1:
            press_feedback(widget)
            callback()
            return True
        return False

    traffic.pack_start(dot("#ff5f57", "#d8463f", "close", lambda: window.close()), False, False, 0)
    traffic.pack_start(dot("#febc2e", "#d9a023", "min", lambda: minimize_window(window)), False, False, 0)
    traffic.pack_start(dot("#28c840", "#1fa334", "max", lambda: toggle_zoom_or_tile(window)), False, False, 0)

    def account_avatar_widget(label: str, size: int = 30) -> Gtk.Widget:
        path = profile_avatar_path()
        if path is not None:
            frame = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
            frame.set_halign(Gtk.Align.CENTER)
            frame.set_valign(Gtk.Align.CENTER)
            frame.get_style_context().add_class("files-user-avatar-frame")
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), size, size, True)
                image = Gtk.Image.new_from_pixbuf(pixbuf)
            except Exception:
                image = Gtk.Image.new_from_file(str(path))
            frame.pack_start(image, True, True, 0)
            return frame
        avatar = Gtk.Label(label=(label[:1] or "S").upper())
        avatar.set_halign(Gtk.Align.CENTER)
        avatar.set_valign(Gtk.Align.CENTER)
        avatar.get_style_context().add_class("files-user-avatar-initial")
        return avatar

    account_name = display_user_name()
    identity_card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
    identity_card.get_style_context().add_class("files-identity-card")
    identity_text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
    identity_title = Gtk.Label(label=account_name)
    identity_title.set_xalign(0)
    identity_title.set_single_line_mode(True)
    identity_title.set_ellipsize(Pango.EllipsizeMode.END)
    identity_title.set_width_chars(1)
    identity_title.set_max_width_chars(14)
    identity_title.get_style_context().add_class("files-identity-title")
    identity_card.set_tooltip_text(f"{profile_title(active_profile, profile_ui)} · {profile_role(active_profile)}")
    identity_text.pack_start(identity_title, False, False, 0)
    identity_card.pack_start(account_avatar_widget(account_name), False, False, 0)
    identity_card.pack_start(identity_text, True, True, 0)
    sidebar.pack_start(identity_card, False, False, 0)

    sidebar_scroller = Gtk.ScrolledWindow()
    sidebar_scroller.get_style_context().add_class("files-sidebar-scroll")
    sidebar_scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    sidebar_scroller.set_overlay_scrolling(True)
    sidebar_content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar_scroller.add(sidebar_content)
    sidebar.pack_start(sidebar_scroller, True, True, 0)

    sidebar_buttons = []

    def add_heading(label: str):
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("sidebar-heading")
        sidebar_content.pack_start(heading, False, False, 0)

    def setup_place_drop_target(widget, target: Path | str):
        uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 1)
        widget.drag_dest_set(Gtk.DestDefaults.ALL, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
        widget.connect("drag-motion", lambda row, context, _x, _y, time_value: on_drop_motion(row, context, time_value))
        widget.connect("drag-leave", lambda row, _context, _time: cancel_spring_open(row))
        widget.connect("drag-data-received", lambda row, context, _x, _y, data, _info, time_value, drop_target=target: on_sidebar_drop(row, context, data, time_value, drop_target))

    def add_place(
        label: str,
        icon: str,
        path: Path | str,
        container: Gtk.Box | None = None,
        tooltip: str = "",
        device: str = "",
        mounted_path: str = "",
        ejectable: bool = False,
        style_class: str = "",
        ensure_dir: bool = False,
    ):
        target_container = container or sidebar_content
        row = Gtk.Button()
        row.set_relief(Gtk.ReliefStyle.NONE)
        row.get_style_context().add_class("sidebar-row")
        if style_class:
            for css_class in style_class.split():
                row.get_style_context().add_class(css_class)
        if tooltip:
            row.set_tooltip_text(tooltip)
        content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        text.set_single_line_mode(True)
        text.set_ellipsize(Pango.EllipsizeMode.END)
        text.set_width_chars(1)
        text.set_max_width_chars(13 if screen_compact else 15)
        content.pack_start(image, False, False, 0)
        content.pack_start(text, True, True, 0)
        row.add(content)
        row.connect("clicked", lambda *_: ensure_and_navigate(path) if ensure_dir else navigate_uri_or_path(path))
        row.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        row.connect("button-press-event", lambda widget, event, target=path: show_place_menu(widget, event, target))
        row.connect("pressed", lambda widget: press_feedback(widget))
        row.connect("released", lambda widget: release_feedback(widget))
        row.place_path = path
        row.place_label = label
        row.place_device = device
        row.place_mount_path = mounted_path
        row.place_ejectable = ejectable
        row.spring_target = path
        if isinstance(path, Path) or str(path).startswith("file://"):
            setup_place_drop_target(row, path)
        sidebar_buttons.append(row)
        target_container.pack_start(row, False, False, 0)
        return row

    def mount_uri(device: str, label: str = "") -> str:
        return f"seven://mount?device={urllib.parse.quote(device)}&label={urllib.parse.quote(label)}"

    def ensure_and_navigate(target: Path | str) -> None:
        if isinstance(target, Path):
            try:
                target.mkdir(parents=True, exist_ok=True)
            except OSError as exc:
                set_status(f"Cannot create {target}: {exc}")
                return
            navigate(target)
            return
        navigate_uri_or_path(target)

    def lsblk_partitions() -> list[dict[str, object]]:
        if not shutil.which("lsblk"):
            return []
        try:
            result = subprocess.run(
                ["lsblk", "-J", "-o", "NAME,PATH,LABEL,FSTYPE,MOUNTPOINTS,TYPE,SIZE,MODEL,UUID,RM,TRAN"],
                text=True,
                capture_output=True,
                check=False,
                timeout=2.5,
            )
            payload = json.loads(result.stdout or "{}")
        except Exception:
            return []
        found: list[dict[str, object]] = []

        def walk(items: list[dict[str, object]], parent_removable: bool = False) -> None:
            for item in items:
                if not isinstance(item, dict):
                    continue
                removable = parent_removable or str(item.get("rm") or "").lower() in {"1", "true"} or str(item.get("tran") or "").lower() in {"usb", "mmc"}
                children = item.get("children")
                if isinstance(children, list):
                    walk(children, removable)
                path = str(item.get("path") or "")
                fstype = str(item.get("fstype") or "").lower()
                kind = str(item.get("type") or "")
                if not path or kind not in {"part", "crypt", "loop"} or not fstype:
                    continue
                item["_ejectable"] = removable or kind == "loop"
                found.append(item)

        walk(payload.get("blockdevices", []) if isinstance(payload.get("blockdevices"), list) else [])
        return found

    def mountpoints_for(partition: dict[str, object]) -> list[str]:
        raw = partition.get("mountpoints")
        if isinstance(raw, list):
            return [str(item) for item in raw if item]
        raw_single = partition.get("mountpoint")
        return [str(raw_single)] if raw_single else []

    def polkit_agent_running() -> bool:
        checks = (
            ["pgrep", "-u", os.environ.get("USER", ""), "-f", r"^/usr/lib/polkit-kde-authentication-agent-1($| )"],
            ["pgrep", "-u", os.environ.get("USER", ""), "-f", r"^/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1($| )"],
            ["pgrep", "-u", os.environ.get("USER", ""), "-x", "lxqt-policykit-agent"],
            ["pgrep", "-u", os.environ.get("USER", ""), "-x", "mate-polkit"],
        )
        for command in checks:
            result = subprocess.run(
                command,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
            )
            if result.returncode == 0:
                return True
        return False

    def start_polkit_agent() -> bool:
        if polkit_agent_running():
            return True
        candidates = (
            "/usr/lib/polkit-kde-authentication-agent-1",
            "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1",
            shutil.which("lxqt-policykit-agent") or "",
            shutil.which("mate-polkit") or "",
        )
        for candidate in candidates:
            if candidate and Path(candidate).exists():
                try:
                    subprocess.Popen(
                        [candidate],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        start_new_session=True,
                    )
                    time.sleep(0.45)
                    return polkit_agent_running()
                except OSError:
                    continue
        return False

    def volume_label(label: str, fstype: str, size: str, device: str) -> str:
        if label:
            return label
        if fstype in {"ntfs", "ntfs3"}:
            return f"Windows {size}".strip()
        if fstype in {"exfat", "vfat", "fat32"}:
            return f"External {size}".strip()
        return Path(device).name

    def size_to_gib(size: str) -> float:
        text = str(size or "").strip().upper().replace(",", ".")
        if not text:
            return 0.0
        number = ""
        unit = ""
        for char in text:
            if char.isdigit() or char == ".":
                number += char
            else:
                unit += char
        try:
            value = float(number)
        except ValueError:
            return 0.0
        unit = unit.strip()
        if unit.startswith("T"):
            return value * 1024
        if unit.startswith("G"):
            return value
        if unit.startswith("M"):
            return value / 1024
        if unit.startswith("K"):
            return value / (1024 * 1024)
        return value / (1024 * 1024 * 1024)

    def mounted_locations() -> list[tuple[str, str, Path | str, str, str, str, bool]]:
        locations: list[tuple[str, str, Path | str, str, str, str, bool]] = []
        seen: set[str] = set()
        partitions = lsblk_partitions()
        partition_by_device = {str(item.get("path") or ""): item for item in partitions}
        partition_by_mount: dict[str, str] = {}
        for partition in partitions:
            device = str(partition.get("path") or "")
            for mountpoint in mountpoints_for(partition):
                partition_by_mount[mountpoint] = device

        def add_location(
            label: str,
            icon: str,
            target: Path | str,
            tooltip: str = "",
            device: str = "",
            mounted_path: str = "",
            ejectable: bool = False,
        ) -> None:
            key = str(target)
            if key in seen:
                return
            seen.add(key)
            locations.append((label, icon, target, tooltip, device, mounted_path, ejectable))

        try:
            monitor = Gio.VolumeMonitor.get()
            for mount in monitor.get_mounts():
                root_file = mount.get_root()
                path = root_file.get_path()
                uri = root_file.get_uri()
                label = mount.get_name() or path or uri
                target: Path | str = Path(path) if path else uri
                device = partition_by_mount.get(path or "", "")
                info = partition_by_device.get(device, {})
                add_location(label, "drive-removable-media", target, uri, device, path or "", bool(info.get("_ejectable")))
            for volume in monitor.get_volumes():
                mount = volume.get_mount()
                if mount:
                    continue
                label = volume.get_name() or "Volume"
                device = ""
                try:
                    device = volume.get_identifier("unix-device") or ""
                except Exception:
                    device = ""
                if device:
                    info = partition_by_device.get(device, {})
                    fstype = str(info.get("fstype") or "").lower()
                    size = str(info.get("size") or "")
                    if fstype in {"ntfs", "ntfs3", "exfat", "vfat", "fat32"} and size_to_gib(size) < 1:
                        continue
                    add_location(label, "drive-harddisk", mount_uri(device, label), tr_text("Not mounted. Click to mount and open."), device, "", bool(info.get("_ejectable")))
        except Exception:
            pass

        for partition in partitions:
            device = str(partition.get("path") or "")
            if not device:
                continue
            fstype = str(partition.get("fstype") or "").lower()
            label = str(partition.get("label") or "")
            size = str(partition.get("size") or "")
            ejectable = bool(partition.get("_ejectable"))
            mounts = mountpoints_for(partition)
            if any(path in {"/", "/home", "/boot", "/efi"} or path.startswith("/boot/") for path in mounts):
                continue
            title = volume_label(label, fstype, size, device)
            icon = "drive-harddisk"
            if fstype in {"ntfs", "ntfs3"}:
                if not mounts and size_to_gib(size) < 1:
                    continue
                icon = "drive-removable-media" if ejectable else "drive-harddisk"
                if not ejectable and not title.lower().startswith("windows"):
                    title = f"Windows · {title}"
            elif fstype in {"exfat", "vfat", "fat32"}:
                if not mounts and size_to_gib(size) < 1:
                    continue
                icon = "drive-removable-media"
            if mounts:
                add_location(title, icon, Path(mounts[0]), f"{fstype.upper()} · {device}", device, mounts[0], ejectable)
            elif fstype in {"ntfs", "ntfs3", "exfat", "vfat", "fat32", "ext4", "btrfs", "xfs"}:
                add_location(title, icon, mount_uri(device, title), f"{fstype.upper()} · {device} · {tr_text('Click to mount')}", device, "", ejectable)
        return locations

    def favorite_paths() -> list[Path]:
        items = load_json(FAVORITES_CACHE, [])
        paths: list[Path] = []
        if isinstance(items, list):
            for item in items:
                path = Path(str(item)).expanduser()
                if path.exists() and path.is_dir() and path not in paths:
                    paths.append(path)
        return paths[:16]

    def save_favorite_paths(paths: list[Path]) -> None:
        write_json(FAVORITES_CACHE, [str(path) for path in paths if path.exists() and path.is_dir()])

    def add_favorite_path(path: Path) -> None:
        target = path if path.is_dir() else path.parent
        paths = favorite_paths()
        if target not in paths:
            paths.append(target)
            save_favorite_paths(paths)
            render_favorite_rows()
            set_status(f"Added favorite: {target.name or target}")
        else:
            set_status(f"Favorite already exists: {target.name or target}")

    def remove_favorite_path(path: Path) -> None:
        target = path if path.is_dir() else path.parent
        paths = [item for item in favorite_paths() if item != target]
        save_favorite_paths(paths)
        render_favorite_rows()
        set_status(f"Removed favorite: {target.name or target}")

    def network_places() -> list[str]:
        items = load_json(NETWORK_CACHE, [])
        places: list[str] = []
        if isinstance(items, list):
            for item in items:
                uri = str(item).strip()
                if uri.startswith(("smb://", "sftp://", "ftp://", "dav://", "davs://")) and uri not in places:
                    places.append(uri)
        return places[:12]

    def save_network_places(places: list[str]) -> None:
        write_json(NETWORK_CACHE, [place for place in places if place.startswith(("smb://", "sftp://", "ftp://", "dav://", "davs://"))])

    def remember_network_place(uri: str) -> None:
        places = network_places()
        if uri in places:
            places.remove(uri)
        places.insert(0, uri)
        save_network_places(places[:12])
        render_location_rows()

    def forget_network_place(uri: str) -> None:
        save_network_places([place for place in network_places() if place != uri])
        render_location_rows()
        set_status(f"Forgot network location {uri}")

    def network_label(uri: str) -> str:
        parsed = urllib.parse.urlparse(uri)
        host = parsed.netloc or uri
        path = parsed.path.strip("/")
        if path:
            return f"{host}/{path.split('/')[0]}"
        return host

    def connect_to_server() -> None:
        uri = ask_text("Connect to Server", "smb://")
        if not uri:
            return
        if uri.startswith(("smb://", "sftp://", "ftp://", "dav://", "davs://")):
            remember_network_place(uri)
            subprocess.Popen(["gio", "open", uri] if shutil.which("gio") else ["xdg-open", uri], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            set_status(f"Opening network location {uri}")
        else:
            set_status("Use a network URI such as smb://server/share or sftp://host")

