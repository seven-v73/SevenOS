        add_menu_item(menu, t("Demander à SevenAI", "Ask SevenAI"), sevenai_selected)
        if path.is_file():
            add_menu_item(menu, t("Copier SHA256", "Copy SHA256"), hash_selected)
        for tag, tag_fr in (("Blue", "Bleu"), ("Violet", "Violet"), ("Green", "Vert"), ("Orange", "Orange"), ("Focus", "Focus")):
            add_menu_item(menu, f"Tag: {tag_fr if language_code() == 'fr' else tag}", lambda tag_name=tag: tag_paths(active_paths, tag_name))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, t("Afficher dans le dossier", "Reveal in Folder"), lambda: reveal_in_parent(path))
        add_menu_item(menu, t("Copier le chemin", "Copy Path"), lambda: copy_path(path))
