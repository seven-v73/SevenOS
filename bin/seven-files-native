    status_label.set_single_line_mode(True)
    status_label.get_style_context().add_class("files-status-label")
    statusbar.pack_start(status_label, True, True, 0)
    operation_label = Gtk.Label(label=f"{profile_title(active_profile, profile_ui)}")
    operation_label.get_style_context().add_class("operation-pill")
    statusbar.pack_end(operation_label, False, False, 0)
    main.pack_start(statusbar, False, False, 0)

    preview = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
    preview.get_style_context().add_class("files-preview")
    preview.set_size_request(254, -1)
    root.pack_start(preview, False, False, 0)

    preview_icon = Gtk.Image.new_from_icon_name("folder", Gtk.IconSize.DIALOG)
    preview_icon.set_pixel_size(88)
    preview_icon.set_halign(Gtk.Align.CENTER)
    preview_icon.get_style_context().add_class("preview-icon")
    preview.pack_start(preview_icon, False, False, 0)

    preview_title = Gtk.Label(label="Seven Files")
    preview_title.set_ellipsize(Pango.EllipsizeMode.END)
    preview_title.set_single_line_mode(True)
    preview_title.set_max_width_chars(20)
    preview_title.set_justify(Gtk.Justification.CENTER)
    preview_title.set_halign(Gtk.Align.CENTER)
    preview_title.get_style_context().add_class("preview-title")
    preview.pack_start(preview_title, False, False, 0)

    preview_subtitle = Gtk.Label(label=tr_text("SevenOS Files workspace"))
    preview_subtitle.set_halign(Gtk.Align.CENTER)
    preview_subtitle.get_style_context().add_class("preview-subtitle")
    preview.pack_start(preview_subtitle, False, False, 0)

    preview_details = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    preview.pack_start(preview_details, False, False, 0)

    def update_sidebar():
        for row in sidebar_buttons:
            ctx = row.get_style_context()
            place_path = getattr(row, "place_path", None)
            if (virtual_location == "recent" and place_path == RECENTS_SENTINEL) or place_path == current:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")

    def path_label(path: Path) -> str:
        if virtual_location == "recent":
            return "Recents"
        if path == Path.home():
            return "Home"
        if path == Path(path.anchor):
            return "SevenOS"
        return path.name or str(path)

    def update_breadcrumbs():
        for child in breadcrumb_box.get_children():
            breadcrumb_box.remove(child)
        if virtual_location == "recent":
            button = Gtk.Button(label=tr_text("Recents"))
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("breadcrumb-button")
            breadcrumb_box.pack_start(button, False, False, 0)
            breadcrumb_box.show_all()
            return
        parts: list[Path] = []
        cursor = current
        while True:
            parts.append(cursor)
            if cursor.parent == cursor:
                break
            cursor = cursor.parent
        parts.reverse()
        if len(parts) > 5:
            parts = [parts[0], *parts[-4:]]
        for index, part in enumerate(parts):
            button = Gtk.Button(label=path_label(part))
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("breadcrumb-button")
            button.connect("clicked", lambda _button, target=part: navigate(target))
            breadcrumb_box.pack_start(button, False, False, 0)
            if index < len(parts) - 1:
                sep = Gtk.Label(label="›")
                sep.get_style_context().add_class("files-status-label")
                breadcrumb_box.pack_start(sep, False, False, 0)
        breadcrumb_box.show_all()

    def sort_entries(entries: list[Path]) -> list[Path]:
        mode = sort_mode

        def safe_stat(path: Path):
            try:
                return path.stat()
            except OSError:
                return None

        if mode == "modified":
            return sorted(entries, key=lambda p: (not p.is_dir(), -(safe_stat(p).st_mtime if safe_stat(p) else 0), p.name.casefold()))
        if mode == "size":
            return sorted(entries, key=lambda p: (not p.is_dir(), -(safe_stat(p).st_size if safe_stat(p) and p.is_file() else 0), p.name.casefold()))
        if mode == "kind":
            return sorted(entries, key=lambda p: (not p.is_dir(), p.suffix.casefold(), p.name.casefold()))
        return sorted(entries, key=lambda p: (not p.is_dir(), p.name.casefold()))

    def save_preferences():
        write_json(PREFS_CACHE, {"view_mode": view_mode, "sort_mode": sort_mode, "show_hidden": show_hidden})

    def recent_paths() -> list[Path]:
        data = load_json(RECENTS_CACHE, [])
        paths = []
        for item in data:
            path = Path(str(item))
            if path.exists() and path not in paths:
                paths.append(path)
        return paths[:80]

    def remember_recent(path: Path):
        if not path.exists():
            return
        paths = [str(path.resolve())]
        paths.extend(str(item.resolve()) for item in recent_paths() if item.resolve() != path.resolve())
        write_json(RECENTS_CACHE, paths[:80])

    def profile_roots() -> list[Path]:
        roots = [Path.home(), Path.home() / "Documents", Path.home() / "Downloads", Path.home() / "Projects"]
        profile_specific = {
            "baobab": [Path.home() / "Baobab", Path.home() / "Documents/Culture"],
            "forge": [Path.home() / "Projects", Path.home() / "Code"],
            "shield": [Path.home() / "Shield", Path.home() / "Security"],
            "studio": [Path.home() / "Pictures", Path.home() / "Videos", Path.home() / "Studio"],
            "horizon": [Path.home() / "Deployments", Path.home() / "Cloud"],
            "pulse": [Path.home() / "Games", Path.home() / "Videos"],
            "windows": [Path.home() / "Downloads/windows", Path.home() / ".local/share/sevenos/windows"],
        }
        roots.extend(profile_specific.get(active_profile, []))
        unique: list[Path] = []
        for root_path in roots:
            if root_path.exists() and root_path not in unique:
                unique.append(root_path)
        return unique

    def fuzzy_match(query: str, text: str) -> bool:
        query = query.casefold().strip()
        text = text.casefold()
        if not query:
            return True
        if query in text:
            return True
        cursor = 0
        for char in query:
            cursor = text.find(char, cursor)
            if cursor < 0:
                return False
            cursor += 1
        return True

    def build_global_index() -> list[str]:
        try:
            if GLOBAL_INDEX_CACHE.exists() and time.time() - GLOBAL_INDEX_CACHE.stat().st_mtime < 180:
                data = json.loads(GLOBAL_INDEX_CACHE.read_text(encoding="utf-8"))
                if isinstance(data, list):
                    return [str(item) for item in data]
        except (OSError, json.JSONDecodeError):
            pass
        indexed: list[str] = []
        ignored = {".cache", ".local/share/Trash", ".git", "node_modules", "target", "__pycache__"}
        for root_path in profile_roots():
            for path in root_path.rglob("*"):
                if len(indexed) >= 900:
                    break
                rel = str(path.relative_to(Path.home())) if str(path).startswith(str(Path.home())) else str(path)
                if any(part in ignored for part in path.parts):
                    continue
                if path.exists() and (path.is_dir() or path.suffix.lower() in PREVIEW_SUFFIXES or path.suffix):
                    indexed.append(str(path))
            if len(indexed) >= 900:
                break
        write_json(GLOBAL_INDEX_CACHE, indexed)
        return indexed

    def global_search(query: str) -> list[Path]:
        matches: list[Path] = []
        for item in build_global_index():
            path = Path(item)
            haystack = f"{path.name} {path.parent.name} {path.suffix}"
            if fuzzy_match(query, haystack):
                matches.append(path)
            if len(matches) >= 120:
                break
        return matches

    def set_operation(message: str, active: bool = False):
        nonlocal operation_active
        operation_active = active
        operation_label.set_text(message)
        operation_label.set_visible(True)

    def finish_operation(message: str):
        render()
        status_label.set_text(message)
        set_operation(profile_title(active_profile, profile_ui), False)

    def run_background(label: str, worker, done):
        set_operation(label, True)

        def task():
            try:
                result = worker()
                GLib.idle_add(lambda: (done(result), False)[1])
            except Exception as exc:
                GLib.idle_add(lambda: (finish_operation(f"Failed: {exc}"), False)[1])

        threading.Thread(target=task, daemon=True).start()

    def refresh_view_buttons():
        for button, mode in ((grid_btn, "grid"), (list_btn, "list"), (compact_btn, "compact")):
            ctx = button.get_style_context()
            if view_mode == mode:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")
        hidden_ctx = hidden_btn.get_style_context()
        if show_hidden:
            hidden_ctx.add_class("active")
        else:
            hidden_ctx.remove_class("active")

    def render():
        previous_size = window.get_size()
        update_breadcrumbs()
        for child in flow.get_children():
            flow.remove(child)
        global_query = search_query.startswith("/")
        tag_query = search_query.startswith("#")
        if global_query:
            entries = global_search(search_query[1:].strip())
        elif tag_query:
            tag_name = search_query[1:].strip().casefold()
            tags = load_tags()
            entries = [Path(path) for path, tag in tags.items() if fuzzy_match(tag_name, tag)]
        else:
            try:
                entries = recent_paths() if virtual_location == "recent" else list(current.iterdir())
            except OSError:
                entries = []
            if not show_hidden:
                entries = [path for path in entries if not path.name.startswith(".")]
            if search_query:
                query = search_query.casefold()
                entries = [path for path in entries if fuzzy_match(query, f"{path.name} {path.suffix} {tag_for_path(path)}")]
        entries = sort_entries(entries)
        if view_mode == "grid":
            flow.set_min_children_per_line(4)
            flow.set_max_children_per_line(4)
            flow.set_column_spacing(22)
            flow.set_row_spacing(30)
            flow.set_homogeneous(True)
        elif view_mode == "list":
            flow.set_min_children_per_line(1)
            flow.set_max_children_per_line(1)
            flow.set_column_spacing(0)
            flow.set_row_spacing(4)
            flow.set_homogeneous(False)
        else:
            flow.set_min_children_per_line(2)
            flow.set_max_children_per_line(2)
            flow.set_column_spacing(8)
            flow.set_row_spacing(4)
            flow.set_homogeneous(False)
        for path in entries:
            child = Gtk.FlowBoxChild()
            child.set_can_focus(True)
            child.get_style_context().add_class("file-tile")
            if view_mode == "list":
                child.get_style_context().add_class("list-view")
                child.set_size_request(560, 48)
            elif view_mode == "compact":
                child.get_style_context().add_class("compact-view")
                child.set_size_request(250, 40)
            else:
                child.set_size_request(120, 124)
            child.path = path
            tile_event = Gtk.EventBox()
            tile_event.set_visible_window(False)
            tile_event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
            orientation = Gtk.Orientation.VERTICAL if view_mode == "grid" else Gtk.Orientation.HORIZONTAL
            box = Gtk.Box(orientation=orientation, spacing=10)
            box.set_halign(Gtk.Align.FILL if view_mode != "grid" else Gtk.Align.CENTER)
            box.set_valign(Gtk.Align.CENTER)
            if view_mode == "list":
                box.set_size_request(560, 48)
            elif view_mode == "compact":
                box.set_size_request(250, 40)
            else:
                box.set_size_request(120, 124)
            box.get_style_context().add_class("file-tile-box")
            image = Gtk.Image.new_from_icon_name(folder_icon(path), Gtk.IconSize.DIALOG)
            image.set_pixel_size(68 if view_mode == "grid" else 26)
            label = Gtk.Label(label=path.name)
            label.set_xalign(0 if view_mode != "grid" else 0.5)
            label.set_width_chars(13 if view_mode == "grid" else 34)
            label.set_max_width_chars(13 if view_mode == "grid" else 34)
            label.set_line_wrap(False)
            label.set_single_line_mode(True)
            label.set_ellipsize(Pango.EllipsizeMode.END)
            label.set_justify(Gtk.Justification.CENTER if view_mode == "grid" else Gtk.Justification.LEFT)
            label.get_style_context().add_class("file-name")
            box.pack_start(image, False, False, 0)
            if view_mode == "grid":
                box.pack_start(label, False, False, 0)
                tag = tag_for_path(path)
                if tag:
                    tag_label = Gtk.Label(label=tag)
                    tag_label.get_style_context().add_class("tag-pill")
                    tag_label.get_style_context().add_class(f"tag-{tag.casefold()}")
                    box.pack_start(tag_label, False, False, 0)
            else:
                text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
                text_box.pack_start(label, False, False, 0)
                meta = Gtk.Label(label=file_row_meta(path))
                meta.set_xalign(0)
                meta.set_single_line_mode(True)
                meta.set_ellipsize(Pango.EllipsizeMode.END)
                meta.get_style_context().add_class("file-meta")
                if view_mode == "list":
                    text_box.pack_start(meta, False, False, 0)
                tag = tag_for_path(path)
                if tag:
                    tag_label = Gtk.Label(label=tag)
                    tag_label.set_xalign(0)
                    tag_label.get_style_context().add_class("tag-pill")
                    tag_label.get_style_context().add_class(f"tag-{tag.casefold()}")
                    text_box.pack_start(tag_label, False, False, 0)
                box.pack_start(text_box, True, True, 0)
            tile_event.add(box)
            tile_event.connect("button-press-event", lambda _widget, event, tile=child, item=path: on_tile_button(event, tile, item))
            child.add(tile_event)
            flow.add(child)
        selected_count = len(flow.get_selected_children())
        mode_label = theme_mode.title()
        location = "Recents" if virtual_location == "recent" else str(current)
        scope = "Global" if global_query else "Tags" if tag_query else "Local"
        status_label.set_text(
            f"{len(entries)} item(s)  |  {scope} · {mode_label} · {profile_title(active_profile, profile_ui)}  |  Click selects · Double-click opens"
            if not selected_count
            else f"{selected_count} selected  |  {location}"
        )
        if not operation_active:
            operation_label.set_text(profile_title(active_profile, profile_ui))
        update_sidebar()
        refresh_view_buttons()
        if virtual_location == "recent":
            update_preview_multiple(entries)
        else:
            update_preview(current)
        flow.show_all()
        flow.grab_focus()
        if previous_size != (1, 1):
            GLib.idle_add(lambda: restore_window_size(previous_size))

    def restore_window_size(size: tuple[int, int]) -> bool:
        width, height = size
        if width > 0 and height > 0:
            window.resize(width, height)
        return False

    def file_row_meta(path: Path) -> str:
        try:
            stat = path.stat()
            modified = time.strftime("%b %d, %H:%M", time.localtime(stat.st_mtime))
            if path.is_dir():
                try:
                    size = f"{len(list(path.iterdir()))} items"
                except OSError:
                    size = "Folder"
            else:
                size = format_size(stat.st_size)
            kind = "Folder" if path.is_dir() else (path.suffix.upper().lstrip(".") or "File")
            return f"{kind}  |  {size}  |  {modified}"
        except OSError:
            return "Unavailable"

    def detail_row(label: str, value: str):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        card.get_style_context().add_class("inspector-card")
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("preview-heading")
        value_label = Gtk.Label(label=value)
        value_label.set_xalign(0)
        value_label.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        value_label.set_single_line_mode(True)
        value_label.set_max_width_chars(24)
        value_label.get_style_context().add_class("preview-value")
        card.pack_start(heading, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        preview_details.pack_start(card, False, False, 0)

    def preview_action(label: str, callback):
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("preview-action")
        button.connect("clicked", lambda *_: callback())
        preview_details.pack_start(button, False, False, 4)

    def preview_hint(text: str):
        label = Gtk.Label(label=text)
        label.set_xalign(0)
        label.set_line_wrap(True)
        label.set_max_width_chars(28)
        label.get_style_context().add_class("preview-hint")
        preview_details.pack_start(label, False, False, 0)

    def read_text_preview(path: Path, limit: int = 6000) -> str:
        data = path.read_bytes()[:limit]
        return data.decode("utf-8", errors="replace")

    def read_docx_preview(path: Path, limit: int = 6000) -> str:
        with zipfile.ZipFile(path) as document:
            xml = document.read("word/document.xml")
        root = ET.fromstring(xml)
        namespace = "{http://schemas.openxmlformats.org/wordprocessingml/2006/main}"
        parts = [node.text or "" for node in root.iter(f"{namespace}t")]
        text = " ".join(part.strip() for part in parts if part.strip())
        return html.unescape(text[:limit])

    def video_thumbnail(path: Path) -> GdkPixbuf.Pixbuf | None:
        thumb = Path("/tmp") / f"seven-files-thumb-{os.getpid()}-{abs(hash(path))}.png"
        if shutil.which("ffmpegthumbnailer"):
            command = ["ffmpegthumbnailer", "-i", str(path), "-o", str(thumb), "-s", "420", "-q", "8"]
        elif shutil.which("ffmpeg"):
            command = [
                "ffmpeg", "-y", "-ss", "00:00:01", "-i", str(path),
                "-frames:v", "1", "-vf", "scale=420:-1", str(thumb),
            ]
        else:
            return None
        result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode != 0 or not thumb.exists():
            return None
        try:
            return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), 210, 150, True)
        finally:
            thumb.unlink(missing_ok=True)

    def pdf_thumbnail(path: Path, render_width: int = 760, max_width: int = 210, max_height: int = 150) -> GdkPixbuf.Pixbuf | None:
        if not shutil.which("pdftoppm"):
            return None
        output_prefix = Path("/tmp") / f"seven-files-pdf-{os.getpid()}-{abs(hash(path))}"
        output_file = Path(f"{output_prefix}.png")
        result = subprocess.run(
            ["pdftoppm", "-f", "1", "-singlefile", "-png", "-scale-to", str(render_width), str(path), str(output_prefix)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode != 0 or not output_file.exists():
            return None
        try:
            return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(output_file), max_width, max_height, True)
        finally:
            output_file.unlink(missing_ok=True)

    def update_preview(path: Path | None):
        for child in preview_details.get_children():
            preview_details.remove(child)
        target = path or current
        if is_image(target):
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(target), 210, 150, True)
                preview_icon.set_from_pixbuf(pixbuf)
            except Exception:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint("Space previews this image. Double-click opens Seven Quick Look.")
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            preview_action("Open externally", lambda target=target: open_externally(target))
        elif is_video(target):
            pixbuf = video_thumbnail(target)
            if pixbuf:
                preview_icon.set_from_pixbuf(pixbuf)
            else:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint("Space opens video preview. External player remains available from preview.")
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            preview_action("Open externally", lambda target=target: open_externally(target))
        elif is_audio(target):
            preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
            preview_icon.set_pixel_size(88)
            preview_hint("Space opens audio preview. External player remains available from preview.")
            preview_action("Open externally", lambda target=target: open_externally(target))
        elif target.is_file() and target.suffix.lower() == ".pdf":
            pixbuf = pdf_thumbnail(target)
            if pixbuf:
                preview_icon.set_from_pixbuf(pixbuf)
            else:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint("Open this document in Seven Reader for book, double-page and inspect modes.")
            preview_action("Read in Seven Reader", lambda target=target: open_in_reader(target))
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
        else:
            preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
            preview_icon.set_pixel_size(88)
            if target.is_file() and target.suffix.lower() in READER_SUFFIXES:
                preview_hint("Open this document in Seven Reader for immersive reading.")
                preview_action("Read in Seven Reader", lambda target=target: open_in_reader(target))
                preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            elif target.is_file() and target.suffix.lower() in TEXT_SUFFIXES | DOCUMENT_SUFFIXES:
                preview_hint("Space opens document preview.")
                preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
                preview_action("Open externally", lambda target=target: open_externally(target))
            elif target.is_dir():
                preview_action("Open", lambda target=target: navigate(target))
        preview_title.set_text(target.name or str(target))
        preview_subtitle.set_text("Folder" if target.is_dir() else (target.suffix.upper().lstrip(".") or "File"))
        try:
            stat = target.stat()
            detail_row("Location", str(target.parent if target != current else target))
            detail_row("Modified", time.strftime("%b %d, %Y %H:%M", time.localtime(stat.st_mtime)))
            if target.is_file():
                detail_row("Size", format_size(stat.st_size))
            elif target.is_dir():
                try:
                    count = len(list(target.iterdir()))
                except OSError:
                    count = 0
                detail_row("Items", f"{count}")
            tag = tag_for_path(target)
            if tag:
                detail_row("Tag", tag)
            if target.is_file():
                preview_action("Ask SevenAI", sevenai_selected)
        except OSError:
            detail_row("Status", "Unavailable")
        preview_details.show_all()

    def update_preview_multiple(paths: list[Path]):
        for child in preview_details.get_children():
            preview_details.remove(child)
        preview_icon.set_from_icon_name("edit-select-all", Gtk.IconSize.DIALOG)
        preview_icon.set_pixel_size(88)
        preview_title.set_text(f"{len(paths)} selected")
        files = [path for path in paths if path.is_file()]
        folders = [path for path in paths if path.is_dir()]
        preview_subtitle.set_text("Selection")
        total = 0
        for path in files:
            try:
                total += path.stat().st_size
            except OSError:
                pass
        detail_row("Files", str(len(files)))
        detail_row("Folders", str(len(folders)))
        detail_row("Total size", format_size(total))
        preview_hint("Use Copy, Compress, Tags or SevenAI actions on the selected items.")
        preview_details.show_all()

    def preview_text_view(text: str) -> Gtk.ScrolledWindow:
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        text_view = Gtk.TextView()
        text_view.set_editable(False)
        text_view.set_cursor_visible(False)
        text_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        text_view.get_style_context().add_class("quicklook-text")
        text_view.get_buffer().set_text(text)
        scroller.add(text_view)
        return scroller

    def preview_message(icon_name: str, title_text: str, body: str) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        box.set_margin_top(32)
        box.set_margin_bottom(32)
        box.set_margin_start(32)
        box.set_margin_end(32)
        icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        icon.set_pixel_size(96)
        label = Gtk.Label(label=title_text)
        label.get_style_context().add_class("preview-title")
        body_label = Gtk.Label(label=body)
        body_label.set_line_wrap(True)
        body_label.set_max_width_chars(54)
        body_label.set_justify(Gtk.Justification.CENTER)
        body_label.get_style_context().add_class("preview-value")
        box.pack_start(icon, False, False, 0)
        box.pack_start(label, False, False, 0)
        box.pack_start(body_label, False, False, 0)
        return box

    def open_quicklook_preview(path: Path):
        preview_window = Gtk.Window(title=path.name)
        preview_window.set_default_size(880, 620)
        preview_window.set_size_request(520, 360)
        preview_window.set_resizable(True)
        preview_window.set_position(Gtk.WindowPosition.CENTER)
        preview_window.set_wmclass("SevenQuickLook", "SevenQuickLook")
        preview_window.get_style_context().add_class("quicklook-window")

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        preview_window.add(outer)

        header = Gtk.HeaderBar(title=path.name)
        header.set_show_close_button(True)
        preview_window.set_titlebar(header)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        content.set_hexpand(True)
        content.set_vexpand(True)
        suffix = path.suffix.lower()

        if is_image(path):
            image_scroller = Gtk.ScrolledWindow()
            image_scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), 1280, 860, True)
                image = Gtk.Image.new_from_pixbuf(pixbuf)
            except Exception:
                image = Gtk.Image.new_from_icon_name("image-x-generic", Gtk.IconSize.DIALOG)
                image.set_pixel_size(128)
            image.set_margin_top(18)
            image.set_margin_bottom(18)
            image.set_margin_start(18)
            image.set_margin_end(18)
            image_scroller.add_with_viewport(image)
            content.pack_start(image_scroller, True, True, 0)
        elif suffix in TEXT_SUFFIXES:
            try:
                content.pack_start(preview_text_view(read_text_preview(path)), True, True, 0)
            except OSError as exc:
                content.pack_start(preview_message("text-x-generic", "Preview unavailable", str(exc)), True, True, 0)
        elif suffix == ".docx":
            try:
                content.pack_start(preview_text_view(read_docx_preview(path)), True, True, 0)
            except Exception as exc:
                content.pack_start(preview_message("x-office-document", "DOCX preview unavailable", str(exc)), True, True, 0)
        elif suffix == ".pdf":
            pixbuf = pdf_thumbnail(path, 1200, 760, 900)
            if pixbuf:
                image = Gtk.Image.new_from_pixbuf(pixbuf)
                image.set_halign(Gtk.Align.CENTER)
                image.set_valign(Gtk.Align.CENTER)
                content.pack_start(image, True, True, 0)
            else:
                content.pack_start(
                    preview_message(
                        "application-pdf",
                        "PDF document",
                        "Install poppler to render the first page inline, or open this file externally now.",
                    ),
                    True,
                    True,
                    0,
                )
        elif is_video(path):
            pixbuf = video_thumbnail(path)
            if pixbuf:
                large = None
                thumb = Path("/tmp") / f"seven-files-video-large-{os.getpid()}-{abs(hash(path))}.png"
                if shutil.which("ffmpeg"):
                    result = subprocess.run(
                        [
                            "ffmpeg", "-y", "-ss", "00:00:01", "-i", str(path),
                            "-frames:v", "1", "-vf", "scale=960:-1", str(thumb),
                        ],
                        stdout=subprocess.DEVNULL,
                        stderr=subprocess.DEVNULL,
                        check=False,
                    )
                    if result.returncode == 0 and thumb.exists():
                        try:
                            large = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), 760, 520, True)
                        finally:
                            thumb.unlink(missing_ok=True)
                image = Gtk.Image.new_from_pixbuf(large or pixbuf)
                image.set_halign(Gtk.Align.CENTER)
                image.set_valign(Gtk.Align.CENTER)
                content.pack_start(image, True, True, 0)
            else:
                content.pack_start(
                    preview_message(
                        "video-x-generic",
                        "Video preview",
                        "Install ffmpegthumbnailer for live thumbnails. Use Open externally to play this file.",
                    ),
                    True,
                    True,
                    0,
                )
        elif is_audio(path):
            content.pack_start(
                preview_message(
                    "audio-x-generic",
                    "Audio file",
                    "Seven Files can identify this audio file. Use Open externally to play it with your preferred player.",
                ),
                True,
                True,
                0,
            )
        else:
            content.pack_start(preview_message(folder_icon(path), "Preview", "No inline preview is available for this file type yet."), True, True, 0)

        outer.pack_start(content, True, True, 0)

        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        footer.get_style_context().add_class("quicklook-footer")
        footer.set_margin_top(8)
        footer.set_margin_bottom(10)
        footer.set_margin_start(14)
        footer.set_margin_end(14)
        open_button = Gtk.Button(label=tr_text("Open externally"))
        open_button.connect("clicked", lambda *_: open_externally(path))
        footer.pack_start(open_button, False, False, 0)
        if path.suffix.lower() in READER_SUFFIXES:
            reader_button = Gtk.Button(label=tr_text("Read in Seven Reader"))
            reader_button.connect("clicked", lambda *_: open_in_reader(path))
            footer.pack_start(reader_button, False, False, 0)
        if is_image(path):
            wallpaper_button = Gtk.Button(label=tr_text("Set as Wallpaper"))
            wallpaper_button.connect("clicked", lambda *_: set_wallpaper_from_file(path))
            footer.pack_end(wallpaper_button, False, False, 0)
        outer.pack_start(footer, False, False, 0)

        preview_window.show_all()

    def open_in_reader(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-reader").exists():
            command = [str(root / "bin/seven-reader"), "open", str(path)]
        elif shutil.which("seven-reader"):
            command = ["seven-reader", "open", str(path)]
        elif shutil.which("seven"):
            command = ["seven", "reader", str(path)]
        if command:
            log = Path("/tmp/sevenos-reader.log")
            with log.open("ab") as handle:
                subprocess.Popen(command, stdout=handle, stderr=handle, start_new_session=True)
            status_label.set_text(f"Opening {path.name} in Seven Reader")
        else:
            open_quicklook_preview(path)

    def open_file(path: Path):
        remember_recent(path)
        if path.suffix.lower() in READER_SUFFIXES:
            open_in_reader(path)
            return
        if is_previewable(path):
            open_quicklook_preview(path)
        else:
            xdg_open(path)

    def open_externally(path: Path):
        if not is_image(path):
            xdg_open(path)
            return
        for command in ("loupe", "eog", "swayimg", "imv", "feh"):
            if shutil.which(command):
                subprocess.Popen([command, str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return
        xdg_open(path)

    def set_wallpaper_from_file(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-wallpaper").exists():
            command = [str(root / "bin/seven-wallpaper"), "set", str(path)]
        else:
            command = ["seven-wallpaper", "set", str(path)]
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def copy_path(path: Path):
        Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(str(path), -1)

    def clipboard_file_payload(paths: list[Path], cut: bool = False) -> str:
        action = "cut" if cut else "copy"
        uris = [path.resolve().as_uri() for path in paths if path.exists()]
        return "\n".join([action, *uris]) + "\n"

    def clipboard_uri_list(paths: list[Path]) -> str:
        return "\n".join(path.resolve().as_uri() for path in paths if path.exists()) + "\n"

    def write_clipboard_cache(paths: list[Path], cut: bool = False):
        CLIPBOARD_CACHE.parent.mkdir(parents=True, exist_ok=True)
        CLIPBOARD_CACHE.write_text(
            json.dumps(
                {
                    "action": "cut" if cut else "copy",
                    "paths": [str(path.resolve()) for path in paths if path.exists()],
                    "time": time.time(),
                }
            ),
            encoding="utf-8",
        )

    def paths_from_uri_payload(payload: str) -> tuple[list[Path], bool]:
        lines = [line.strip() for line in payload.splitlines() if line.strip() and not line.startswith("#")]
        cut = False
        if lines and lines[0] in {"copy", "cut"}:
            cut = lines[0] == "cut"
            lines = lines[1:]
        paths: list[Path] = []
        for line in lines:
            if line.startswith("file://"):
                paths.append(Path(GLib.filename_from_uri(line)[0]))
            else:
                paths.append(Path(line))
        return [path for path in paths if path.exists()], cut

    def publish_file_clipboard(paths: list[Path], cut: bool = False):
        valid = [path for path in paths if path.exists()]
        if not valid:
            return
        uri_list = clipboard_uri_list(valid)
        write_clipboard_cache(valid, cut)
        if shutil.which("wl-copy") and os.environ.get("WAYLAND_DISPLAY"):
            subprocess.run(["wl-copy", "--type", "text/uri-list"], input=uri_list, text=True, check=False)
        elif shutil.which("xclip") and os.environ.get("DISPLAY"):
            subprocess.run(["xclip", "-selection", "clipboard", "-t", "text/uri-list"], input=uri_list, text=True, check=False)
        else:
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(uri_list, -1)

    def read_system_file_clipboard() -> tuple[list[Path], bool]:
        commands: list[list[str]] = []
        if shutil.which("wl-paste") and os.environ.get("WAYLAND_DISPLAY"):
            commands.extend([
                ["wl-paste", "--no-newline", "--type", "x-special/gnome-copied-files"],
                ["wl-paste", "--no-newline", "--type", "text/uri-list"],
            ])
        if shutil.which("xclip") and os.environ.get("DISPLAY"):
            commands.append(["xclip", "-selection", "clipboard", "-o", "-t", "x-special/gnome-copied-files"])
        for command in commands:
            result = subprocess.run(command, text=True, capture_output=True, check=False)
            if result.returncode == 0 and result.stdout.strip():
                paths, cut = paths_from_uri_payload(result.stdout)
                if paths:
                    return paths, cut
        if CLIPBOARD_CACHE.exists():
            try:
                data = json.loads(CLIPBOARD_CACHE.read_text(encoding="utf-8"))
                paths = [Path(path) for path in data.get("paths", [])]
                paths = [path for path in paths if path.exists()]
                if paths:
                    return paths, data.get("action") == "cut"
            except (OSError, json.JSONDecodeError):
                pass
        return [], False

    def selected_path() -> Path | None:
        selected = flow.get_selected_children()
        if not selected:
            return None
        return selected[0].path

    def selected_paths() -> list[Path]:
        return [child.path for child in flow.get_selected_children()]

    def copy_items(paths: list[Path], cut: bool = False):
        nonlocal file_clipboard, file_clipboard_cut
        file_clipboard = [path for path in paths if path.exists()]
        file_clipboard_cut = cut
        if file_clipboard:
            publish_file_clipboard(file_clipboard, cut)
            status_label.set_text(f"{'Cut' if cut else 'Copied'} {len(file_clipboard)} file item(s)")

    def copy_selected():
        paths = selected_paths()
        if paths:
            copy_items(paths)

    def cut_selected():
        paths = selected_paths()
        if paths:
            copy_items(paths, cut=True)

    def unique_destination(directory: Path, name: str) -> Path:
        destination = directory / name
        if not destination.exists():
            return destination
        stem = destination.stem
        suffix = destination.suffix
        for index in range(2, 1000):
            candidate = directory / f"{stem} copy {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{stem} copy{suffix}"

    def paste_items():
        nonlocal file_clipboard, file_clipboard_cut
        if not file_clipboard:
            file_clipboard, file_clipboard_cut = read_system_file_clipboard()
            if not file_clipboard:
                status_label.set_text("Nothing to paste")
                return
        sources = list(file_clipboard)
        cut_mode = file_clipboard_cut
        destination_dir = current

        def worker():
            pasted = 0
            for source in sources:
                if not source.exists():
                    continue
                destination = unique_destination(destination_dir, source.name)
                try:
                    if cut_mode:
                        shutil.move(str(source), str(destination))
                    elif source.is_dir():
                        shutil.copytree(source, destination)
                    else:
                        shutil.copy2(source, destination)
                    pasted += 1
                except OSError:
                    continue
            return pasted

        def done(pasted):
            nonlocal file_clipboard, file_clipboard_cut
            if cut_mode:
                file_clipboard = []
                file_clipboard_cut = False
            finish_operation(f"Pasted {pasted} item(s)" if pasted else "Paste failed")

        run_background(f"Pasting {len(sources)} item(s)", worker, done)

    def ask_name(title_text: str, default_name: str) -> str | None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("OK", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        entry = Gtk.Entry()
        entry.set_text(default_name)
        entry.set_activates_default(True)
        content.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not value:
            return None
        return Path(value).name

    def ask_text(title_text: str, default_value: str) -> str | None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("OK", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        entry = Gtk.Entry()
        entry.set_text(default_value)
        entry.set_activates_default(True)
        content.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not value:
            return None
        return value

    def create_folder():
        name = ask_name("New Folder", "Untitled Folder")
        if not name:
            return
        destination = unique_destination(current, name)
        try:
            destination.mkdir()
            render()
            status_label.set_text(f"Created {destination.name}")
        except OSError as exc:
            status_label.set_text(f"New folder failed: {exc}")

    def rename_path(path: Path):
        name = ask_name("Rename", path.name)
        if not name or name == path.name:
            return
        destination = unique_destination(path.parent, name)
        try:
            path.rename(destination)
            render()
            status_label.set_text(f"Renamed to {destination.name}")
        except OSError as exc:
            status_label.set_text(f"Rename failed: {exc}")

    def duplicate_path(path: Path):
        destination = unique_destination(path.parent, f"{path.stem} copy{path.suffix}" if path.is_file() else f"{path.name} copy")
        try:
            if path.is_dir():
                shutil.copytree(path, destination)
            else:
                shutil.copy2(path, destination)
            render()
            status_label.set_text(f"Duplicated {path.name}")
        except OSError as exc:
            status_label.set_text(f"Duplicate failed: {exc}")

    def trash_path(path: Path):
        if shutil.which("gio"):
            result = subprocess.run(["gio", "trash", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                render()
                status_label.set_text(f"Moved {path.name} to Trash")
                return
        trash_dir = Path.home() / ".local/share/Trash/files"
        trash_dir.mkdir(parents=True, exist_ok=True)
        try:
            shutil.move(str(path), str(unique_destination(trash_dir, path.name)))
            render()
            status_label.set_text(f"Moved {path.name} to Trash")
        except OSError as exc:
            status_label.set_text(f"Trash failed: {exc}")

    def trash_selected():
        paths = selected_paths()
        if not paths:
            status_label.set_text("Select an item to move to Trash")
            return
        for path in paths:
            trash_path(path)
        render()
        status_label.set_text(f"Moved {len(paths)} item(s) to Trash")

    def load_tags() -> dict[str, str]:
        if not TAG_CACHE.exists():
            return {}
        try:
            return json.loads(TAG_CACHE.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            return {}

    def save_tags(tags: dict[str, str]) -> None:
        TAG_CACHE.parent.mkdir(parents=True, exist_ok=True)
        TAG_CACHE.write_text(json.dumps(tags, indent=2, sort_keys=True), encoding="utf-8")

    def tag_paths(paths: list[Path], tag: str):
        if not paths:
            status_label.set_text("Select an item to tag")
            return
        tags = load_tags()
        for path in paths:
            tags[str(path.resolve())] = tag
        save_tags(tags)
        status_label.set_text(f"Tagged {len(paths)} item(s) as {tag}")
        update_preview_multiple(paths) if len(paths) > 1 else update_preview(paths[0])

    def tag_for_path(path: Path) -> str:
        return load_tags().get(str(path.resolve()), "")

    def show_ai_result(title: str, body: str):
        dialog = Gtk.Dialog(title=title, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(560, 420)
        dialog.add_button("Close", Gtk.ResponseType.CLOSE)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        text = Gtk.TextView()
        text.set_editable(False)
        text.set_cursor_visible(False)
        text.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        text.get_buffer().set_text(body)
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroller.add(text)
        content.pack_start(scroller, True, True, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()

    def sevenai_selected():
        paths = selected_paths()
        if not paths:
            status_label.set_text("Select an item before asking SevenAI")
            return
        root = resolve_root()
        seven = shutil.which("seven")
        seven_cmd = [seven] if seven else [str(root / "bin/seven")] if root and (root / "bin/seven").exists() else []
        if not seven_cmd:
            status_label.set_text("SevenAI command is not available")
            return
        summary = []
        for path in paths[:8]:
            kind = "folder" if path.is_dir() else path.suffix.lower().lstrip(".") or "file"
            summary.append(f"{path.name} ({kind}, {path})")
        prompt = (
            "Analyse cette sélection Seven Files et réponds en langage simple. "
            "Propose 3 actions utiles maximum: " + "; ".join(summary)
        )

        def worker():
            result = subprocess.run([*seven_cmd, "ai", "provider", prompt], text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False, timeout=14)
            return result.stdout.strip() or "SevenAI n'a pas retourné de suggestion."

        def done(output):
            finish_operation("SevenAI analysis ready")
            show_ai_result("SevenAI · File Insight", output)

        run_background("SevenAI is analyzing", worker, done)

    def go_to_path_dialog():
        name = ask_text("Go to Folder", str(current))
        if not name:
            return
        target = Path(name).expanduser()
        if target.exists() and target.is_dir():
            navigate(target)
        else:
            status_label.set_text(f"Folder not found: {target}")

    def archive_destination(path: Path, item_count: int = 1, archive_format: str = "zip", requested_name: str | None = None) -> Path:
        if item_count > 1 and path == current:
            base = "Archive"
            directory = current
        else:
            base = path.stem if path.is_file() else path.name
            directory = path.parent if path != current else current
        suffix = ARCHIVE_FORMATS.get(archive_format, ".zip")
        if requested_name:
            base = Path(requested_name).name
            for archive_suffix in sorted(ARCHIVE_FORMATS.values(), key=len, reverse=True):
                if base.endswith(archive_suffix):
                    base = base[: -len(archive_suffix)]
                    break
        candidate = directory / f"{base}{suffix}"
        if not candidate.exists():
            return candidate
        for index in range(2, 1000):
            candidate = directory / f"{base} {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{base} archive{suffix}"

    def archive_member_name(target: Path, item: Path) -> str:
        if target.is_dir():
            return str(item.relative_to(target.parent))
        return target.name

    def write_archive(destination: Path, targets: list[Path], archive_format: str):
        if archive_format == "zip":
            with zipfile.ZipFile(destination, "w", compression=zipfile.ZIP_DEFLATED) as archive:
                for target in targets:
                    if target.is_dir():
                        for item in target.rglob("*"):
                            if item == destination:
                                continue
                            archive.write(item, archive_member_name(target, item))
                    else:
                        archive.write(target, target.name)
            return
        mode = "w:gz" if archive_format == "tar.gz" else "w:xz"
        with tarfile.open(destination, mode) as archive:
            for target in targets:
                archive.add(target, arcname=target.name)

    def ask_archive_options(default_name: str) -> tuple[str, str] | None:
        dialog = Gtk.Dialog(title=tr_text("Compress"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(tr_text("Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button(tr_text("Compress"), Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        name_label = Gtk.Label(label=tr_text("Archive name"))
        name_label.set_xalign(0)
        entry = Gtk.Entry()
        entry.set_text(default_name)
        entry.set_activates_default(True)
        format_label = Gtk.Label(label=tr_text("Format"))
        format_label.set_xalign(0)
        combo = Gtk.ComboBoxText()
        for value in ARCHIVE_FORMATS:
            combo.append_text(value)
        combo.set_active(0)
        content.pack_start(name_label, False, False, 0)
        content.pack_start(entry, False, False, 0)
        content.pack_start(format_label, False, False, 0)
        content.pack_start(combo, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        name = entry.get_text().strip()
        archive_format = combo.get_active_text() or "zip"
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not name:
            return None
        return name, archive_format

    def compress_paths(paths: list[Path]):
        targets = [path for path in paths if path.exists()]
        if not targets:
            status_label.set_text("Select an item to compress")
            return
        base_path = targets[0] if len(targets) == 1 else current
        default_name = "Archive" if len(targets) > 1 else (base_path.stem if base_path.is_file() else base_path.name)
        options = ask_archive_options(default_name)
        if not options:
            status_label.set_text("Compression cancelled")
            return
        requested_name, archive_format = options
        destination = archive_destination(base_path, len(targets), archive_format, requested_name)
        def worker():
            write_archive(destination, targets, archive_format)
            return destination.name

        def done(name):
            finish_operation(f"Compressed {len(targets)} item(s) to {name}")

        run_background(f"Compressing {len(targets)} item(s)", worker, done)

    def compress_selected():
        paths = selected_paths()
        if paths:
            compress_paths(paths)
        else:
            status_label.set_text("Select an item to compress")

    def reveal_in_parent(path: Path):
        xdg_open(path.parent if path.is_file() else path)

    def add_menu_item(menu, label: str, callback):
        item = Gtk.MenuItem(label=label)
        item.connect("activate", lambda *_: callback())
        menu.append(item)

    def show_context_menu(path: Path, event):
        active_paths = selected_paths()
        if path not in active_paths:
            active_paths = [path]
        menu = Gtk.Menu()
        add_menu_item(menu, "Open", lambda: navigate(path) if path.is_dir() else open_file(path))
        if path.is_file() and path.suffix.lower() in READER_SUFFIXES:
            add_menu_item(menu, "Read in Seven Reader", lambda: open_in_reader(path))
        if path.is_file() and is_previewable(path):
            add_menu_item(menu, "Quick Look", lambda: open_quicklook_preview(path))
        add_menu_item(menu, "Copy", lambda: copy_items(active_paths))
        add_menu_item(menu, "Cut", lambda: copy_items(active_paths, cut=True))
        add_menu_item(menu, "Paste Item", paste_items)
        add_menu_item(menu, "Duplicate", lambda: duplicate_path(path))
        add_menu_item(menu, "Rename", lambda: rename_path(path))
        add_menu_item(menu, "Compress", lambda: compress_paths(active_paths))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Ask SevenAI", sevenai_selected)
        for tag in ("Blue", "Violet", "Green", "Orange", "Focus"):
            add_menu_item(menu, f"Tag: {tag}", lambda tag_name=tag: tag_paths(active_paths, tag_name))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Reveal in Folder", lambda: reveal_in_parent(path))
        add_menu_item(menu, "Copy Path", lambda: copy_path(path))
        add_menu_item(menu, "Move to Trash", lambda: trash_selected())
        if is_image(path):
            menu.append(Gtk.SeparatorMenuItem())
            add_menu_item(menu, "Set as Wallpaper", lambda: set_wallpaper_from_file(path))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Properties", lambda: update_preview(path))
        menu.show_all()
        try:
            menu.popup_at_pointer(event)
        except AttributeError:
            menu.popup(None, None, None, None, event.button, event.time)

    def on_tile_button(event, child, path: Path) -> bool:
        if getattr(event, "button", 0) == 3:
            flow.select_child(child)
            update_preview(path)
            show_context_menu(path, event)
            return True
        if getattr(event, "button", 0) == 1:
            if getattr(event, "type", None) == Gdk.EventType._2BUTTON_PRESS:
                flow.unselect_all()
                flow.select_child(child)
                update_preview(path)
                open_selected(path)
            elif event.state & (Gdk.ModifierType.CONTROL_MASK | Gdk.ModifierType.SHIFT_MASK):
                if child in flow.get_selected_children():
                    flow.unselect_child(child)
                else:
                    flow.select_child(child)
                selected = flow.get_selected_children()
                if len(selected) > 1:
                    update_preview_multiple([item.path for item in selected])
                elif selected:
                    update_preview(selected[0].path)
                else:
                    update_preview(current)
            else:
                flow.unselect_all()
                flow.select_child(child)
                update_preview(path)
            return True
        return False

    def open_selected(path: Path | None = None):
        target = path or selected_path()
        if not target:
            return
        if target.is_dir():
            navigate(target)
        else:
            open_file(target)

    def navigate(path: Path):
        nonlocal current, virtual_location
        if path == RECENTS_SENTINEL:
            if virtual_location != "recent":
                history.append(current)
                future.clear()
            virtual_location = "recent"
            render()
            return
        if not path.exists() or not path.is_dir():
            return
        if path != current or virtual_location:
            history.append(current)
            future.clear()
            current = path
            virtual_location = ""
            remember_recent(path)
        render()

    def go_back():
        nonlocal current, virtual_location
        if history:
            future.append(current)
            current = history.pop()
            virtual_location = ""
            render()

    def go_forward():
        nonlocal current, virtual_location
        if future:
            history.append(current)
            current = future.pop()
            virtual_location = ""
            render()

    def set_search_query(entry):
        nonlocal search_query
        search_query = entry.get_text().strip()
        render()

    def cycle_sort_mode():
        nonlocal sort_mode
        try:
            index = sort_order.index(sort_mode)
        except ValueError:
            index = 0
        sort_mode = sort_order[(index + 1) % len(sort_order)]
        sort_button.set_label(sort_labels.get(sort_mode, "A-Z"))
        save_preferences()
        render()

    def activate(_flow, child):
        if child is None:
            return
        open_selected(child.path)

    def selection_changed(flow_box):
        selected = flow_box.get_selected_children()
        location = "Recents" if virtual_location == "recent" else str(current)
        if len(selected) > 1:
            update_preview_multiple([child.path for child in selected])
            status_label.set_text(f"{len(selected)} selected  |  {location}")
        elif selected:
            update_preview(selected[0].path)
        else:
            update_preview_multiple(recent_paths()) if virtual_location == "recent" else update_preview(current)

    def on_key(_window, event):
        if event.keyval == Gdk.KEY_Escape:
            window.close()
            return True
        if event.keyval == Gdk.KEY_BackSpace:
            go_back()
            return True
        if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            open_selected()
            return True
        if event.keyval == Gdk.KEY_Delete:
            trash_selected()
            return True
        if event.keyval == Gdk.KEY_F2:
            target = selected_path()
            if target:
                rename_path(target)
            return True
        if event.keyval == Gdk.KEY_space:
            target = selected_path()
            if target and target.suffix.lower() in READER_SUFFIXES:
                open_in_reader(target)
                return True
            if target and is_previewable(target):
                open_quicklook_preview(target)
                return True
        if event.keyval in (Gdk.KEY_Left, Gdk.KEY_Right, Gdk.KEY_Up, Gdk.KEY_Down):
            move_keyboard_selection(event.keyval)
            return True
        if event.state & Gdk.ModifierType.CONTROL_MASK:
            if event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
                copy_selected()
                return True
            if event.keyval in (Gdk.KEY_x, Gdk.KEY_X):
                cut_selected()
                return True
            if event.keyval in (Gdk.KEY_v, Gdk.KEY_V):
                paste_items()
                return True
            if event.keyval in (Gdk.KEY_a, Gdk.KEY_A):
                flow.select_all()
                return True
            if event.keyval in (Gdk.KEY_f, Gdk.KEY_F):
                search_entry.grab_focus()
                return True
            if event.keyval in (Gdk.KEY_h, Gdk.KEY_H):
                toggle_hidden()
                return True
            if event.keyval in (Gdk.KEY_l, Gdk.KEY_L):
                go_to_path_dialog()
                return True
            if event.keyval in (Gdk.KEY_i, Gdk.KEY_I):
                preview.set_visible(not preview.get_visible())
                return True
        if event.state & Gdk.ModifierType.MOD1_MASK and event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
            compress_selected()
            return True
        return False

    def adapt_layout(_window, event):
        width = getattr(event, "width", 1040)
        if width < 860:
            sidebar.set_visible(False)
            preview.set_visible(False)
            search_entry.set_size_request(92, -1)
            sort_button.set_size_request(52, -1)
        elif width < 1040:
            sidebar.set_visible(True)
            preview.set_visible(False)
            search_entry.set_size_request(104, -1)
            sort_button.set_size_request(54, -1)
        else:
            sidebar.set_visible(True)
            search_entry.set_size_request(112, -1)
            sort_button.set_size_request(58, -1)
        return False

    def move_keyboard_selection(keyval: int):
        children = flow.get_children()
        if not children:
            return
        selected = flow.get_selected_children()
        if selected and selected[0] in children:
            index = children.index(selected[0])
        else:
            index = 0
        columns = 1 if view_mode == "list" else 2 if view_mode == "compact" else max(1, min(4, len(children)))
        if keyval == Gdk.KEY_Left:
            index = max(0, index - 1)
        elif keyval == Gdk.KEY_Right:
            index = min(len(children) - 1, index + 1)
        elif keyval == Gdk.KEY_Up:
            index = max(0, index - columns)
        elif keyval == Gdk.KEY_Down:
            index = min(len(children) - 1, index + columns)
        child = children[index]
        flow.select_child(child)
        child.grab_focus()
        update_preview(child.path)

    search_entry.connect("search-changed", set_search_query)
    sort_button.connect("clicked", lambda *_: cycle_sort_mode())
    flow.connect("child-activated", activate)
    flow.connect("selected-children-changed", selection_changed)
    flow.connect("key-press-event", on_key)
    window.connect("key-press-event", on_key)
    window.connect("configure-event", adapt_layout)
    window.connect("destroy", Gtk.main_quit)
    render()
    window.show_all()
    window.resize(1040, 660)
    Gtk.main()
    return 0


def toggle_zoom_or_tile(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        result = subprocess.run(["hyprctl", "dispatch", "togglefloating", "active"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            return
    if window.is_maximized():
        window.unmaximize()
        window.resize(1120, 700)
    else:
        window.maximize()


def minimize_window(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        for command in (
            ["hyprctl", "dispatch", "movetoworkspacesilent", "special:seven"],
            ["hyprctl", "dispatch", "movetoworkspace", "special:seven"],
        ):
            result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                return
    window.iconify()


def format_size(size: int) -> str:
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{size} B"


def begin_move(window, event) -> bool:
    if getattr(event, "button", 0) == 1:
        window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
        return True
    return False


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("path", nargs="?", default=str(Path.home()))
    args = parser.parse_args()
    if args.probe:
        return probe()
    return run_files(args.path)


if __name__ == "__main__":
    raise SystemExit(main())
