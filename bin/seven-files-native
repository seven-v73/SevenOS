    def mini_os_resource_root(profile: str | None = None) -> Path:
        profile_key = (profile or active_profile or "equinox").strip().lower()
        if grouped_resources or profile_key == "equinox":
            return Path.home()
        return Path.home() / ".local/share/sevenos/profile-containers" / profile_key / "home"

