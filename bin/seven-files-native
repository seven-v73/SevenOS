#!/usr/bin/env python3
"""SevenOS Finder-like native file surface."""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("GdkPixbuf", "2.0")
        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def xdg_open(path: Path) -> None:
    subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


IMAGE_SUFFIXES = {".png", ".jpg", ".jpeg", ".webp", ".gif", ".svg", ".bmp", ".tiff", ".tif"}


def is_image(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in IMAGE_SUFFIXES


def resolve_root() -> Path | None:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin").is_dir():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin").is_dir():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin").is_dir():
            return candidate
    return None


def folder_icon(path: Path) -> str:
    mapping = {
        "Desktop": "user-desktop",
        "Documents": "folder-documents",
        "Downloads": "folder-download",
        "Music": "folder-music",
        "Pictures": "folder-pictures",
        "Videos": "folder-videos",
        "Projects": "folder-development",
    }
    if path.is_dir():
        return mapping.get(path.name, "folder")
    suffix = path.suffix.lower()
    if suffix in IMAGE_SUFFIXES:
        return "image-x-generic"
    if suffix in {".mp4", ".mkv", ".mov", ".webm"}:
        return "video-x-generic"
    if suffix in {".mp3", ".wav", ".flac", ".ogg"}:
        return "audio-x-generic"
    if suffix in {".zip", ".tar", ".gz", ".xz", ".7z"}:
        return "package-x-generic"
    if suffix in {".pdf"}:
        return "application-pdf"
    if suffix in {".sh", ".py", ".rs", ".js", ".ts", ".html", ".css", ".json", ".md"}:
        return "text-x-script"
    return "text-x-generic"


def run_files(start_path: str) -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("GdkPixbuf", "2.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GdkPixbuf, GLib, Gtk, Pango
    GLib.set_prgname("SevenFilesNative")
    GLib.set_application_name("Seven Files")
    try:
        Gdk.set_program_class("SevenFilesNative")
    except Exception:
        pass

    current = Path(start_path).expanduser()
    if not current.exists():
        current = Path.home()
    if current.is_file():
        current = current.parent

    history: list[Path] = []
    future: list[Path] = []
    file_clipboard: list[Path] = []
    file_clipboard_cut = False

    css = """
    window.seven-files {
      background: #fbfcfd;
      border-radius: 18px;
      color: #20242a;
    }
    .files-root {
      background: #fbfcfd;
    }
    .files-sidebar {
      min-width: 204px;
      padding: 16px 13px;
      background: rgba(244, 246, 248, 0.97);
      border-right: 1px solid rgba(134, 145, 156, 0.20);
    }
    .traffic-row {
      padding: 0 0 20px 0;
    }
    .traffic-dot {
      min-width: 15px;
      min-height: 15px;
      margin-right: 9px;
    }
    .sidebar-heading {
      color: #8a8f96;
      font: 500 11px "DM Sans", "Inter", sans-serif;
      margin: 14px 0 5px 8px;
    }
    .sidebar-row {
      min-height: 37px;
      padding: 0 11px;
      border-radius: 12px;
      color: #20242a;
      font: 500 13px "DM Sans", "Inter", sans-serif;
    }
    .sidebar-row:hover,
    .sidebar-row.active {
      background: rgba(35, 118, 220, 0.10);
    }
    .files-main {
      min-width: 650px;
      background: #ffffff;
    }
    .files-preview {
      min-width: 254px;
      padding: 22px 18px;
      background: rgba(249, 250, 251, 0.98);
      border-left: 1px solid rgba(134, 145, 156, 0.16);
    }
    .preview-icon {
      margin: 8px 0 12px 0;
    }
    .preview-title {
      color: #20242a;
      font: 500 17px "DM Sans", "Inter", sans-serif;
    }
    .preview-subtitle {
      color: #7b828a;
      font: 500 12px "DM Sans", "Inter", sans-serif;
      margin-bottom: 18px;
    }
    .preview-heading {
      color: #8a8f96;
      font: 500 11px "DM Sans", "Inter", sans-serif;
      margin-top: 12px;
    }
    .preview-value {
      color: #30363d;
      font: 500 12px "DM Sans", "Inter", sans-serif;
    }
    .files-toolbar {
      min-height: 64px;
      padding: 0 20px 0 14px;
      background: rgba(255, 255, 255, 0.98);
      border-bottom: 1px solid rgba(134, 145, 156, 0.16);
    }
    .toolbar-button {
      min-width: 38px;
      min-height: 38px;
      border-radius: 999px;
      background: rgba(247, 248, 250, 0.98);
      color: #30363d;
      border: 0;
      padding: 0;
    }
    .toolbar-button:hover {
      background: rgba(226, 230, 235, 0.96);
    }
    .files-title {
      color: #30363d;
      font: 500 18px "DM Sans", "Inter", sans-serif;
    }
    .files-grid {
      padding: 34px 36px;
      background: #ffffff;
    }
    .file-tile {
      min-width: 120px;
      min-height: 124px;
      padding: 10px 6px;
      border-radius: 16px;
      color: #20242a;
    }
    .file-tile:hover,
    .file-tile:selected {
      background: rgba(35, 118, 220, 0.10);
    }
    .file-name {
      color: #20242a;
      font: 500 12px "DM Sans", "Inter", sans-serif;
    }
    .files-statusbar {
      min-height: 32px;
      padding: 0 18px;
      background: rgba(255, 255, 255, 0.98);
      border-top: 1px solid rgba(134, 145, 156, 0.14);
    }
    .files-status-label {
      color: #7b828a;
      font: 500 11px "DM Sans", "Inter", sans-serif;
    }
    .file-tile-box {
      min-width: 120px;
      min-height: 124px;
    }
    menu {
      border-radius: 12px;
      padding: 6px;
      background: #ffffff;
      border: 1px solid rgba(134, 145, 156, 0.22);
    }
    menuitem {
      min-height: 30px;
      border-radius: 8px;
      padding: 0 10px;
      color: #20242a;
      font: 500 12px "DM Sans", "Inter", sans-serif;
    }
    menuitem:hover {
      background: rgba(35, 118, 220, 0.10);
    }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title="Seven Files")
    window.set_default_size(1080, 680)
    window.set_size_request(980, 600)
    window.set_resizable(True)
    window.set_decorated(False)
    window.set_wmclass("SevenFilesNative", "SevenFilesNative")
    window.get_style_context().add_class("seven-files")

    root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    root.get_style_context().add_class("files-root")
    window.add(root)

    sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar.get_style_context().add_class("files-sidebar")
    sidebar.set_size_request(204, -1)
    root.pack_start(sidebar, False, False, 0)

    traffic = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    traffic.get_style_context().add_class("traffic-row")
    sidebar.pack_start(traffic, False, False, 0)

    def draw_dot(widget, cr, fill: str, stroke: str, style: str):
        rgba = Gdk.RGBA()
        border = Gdk.RGBA()
        rgba.parse(fill)
        border.parse(stroke)
        alloc = widget.get_allocation()
        radius = min(alloc.width, alloc.height) / 2 - 1
        cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, rgba.alpha)
        cr.arc(alloc.width / 2, alloc.height / 2, radius, 0, 6.28318)
        cr.fill_preserve()
        cr.set_source_rgba(border.red, border.green, border.blue, 0.72)
        cr.set_line_width(1)
        cr.stroke()
        draw_dot_symbol(cr, style, alloc.width / 2, alloc.height / 2, radius)
        return False

    def draw_dot_symbol(cr, style: str, center_x: float, center_y: float, radius: float) -> None:
        cr.set_line_width(1.35)
        cr.set_line_cap(1)
        cr.set_source_rgba(0.20, 0.14, 0.10, 0.52)
        if style == "close":
            offset = radius * 0.38
            cr.move_to(center_x - offset, center_y - offset)
            cr.line_to(center_x + offset, center_y + offset)
            cr.move_to(center_x + offset, center_y - offset)
            cr.line_to(center_x - offset, center_y + offset)
        elif style == "min":
            offset = radius * 0.42
            cr.move_to(center_x - offset, center_y)
            cr.line_to(center_x + offset, center_y)
        elif style == "max":
            offset = radius * 0.36
            cr.move_to(center_x, center_y - offset)
            cr.line_to(center_x, center_y + offset)
            cr.move_to(center_x - offset, center_y)
            cr.line_to(center_x + offset, center_y)
        cr.stroke()

    def dot(fill: str, stroke: str, style: str, callback):
        event = Gtk.EventBox()
        event.set_visible_window(False)
        event.set_above_child(True)
        area = Gtk.DrawingArea()
        area.set_size_request(15, 15)
        area.get_style_context().add_class("traffic-dot")
        area.connect("draw", draw_dot, fill, stroke, style)
        event.add(area)
        event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
        event.connect("button-press-event", lambda _widget, event_data: activate_dot(event_data, callback))
        return event

    def activate_dot(event_data, callback) -> bool:
        if getattr(event_data, "button", 0) == 1:
            callback()
            return True
        return False

    traffic.pack_start(dot("#ff5f57", "#d8463f", "close", lambda: window.close()), False, False, 0)
    traffic.pack_start(dot("#febc2e", "#d9a023", "min", lambda: minimize_window(window)), False, False, 0)
    traffic.pack_start(dot("#28c840", "#1fa334", "max", lambda: toggle_zoom_or_tile(window)), False, False, 0)

    sidebar_buttons = []

    def add_heading(label: str):
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("sidebar-heading")
        sidebar.pack_start(heading, False, False, 0)

    def add_place(label: str, icon: str, path: Path):
        row = Gtk.Button()
        row.set_relief(Gtk.ReliefStyle.NONE)
        row.get_style_context().add_class("sidebar-row")
        content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        content.pack_start(image, False, False, 0)
        content.pack_start(text, True, True, 0)
        row.add(content)
        row.connect("clicked", lambda *_: navigate(path))
        row.place_path = path
        sidebar_buttons.append(row)
        sidebar.pack_start(row, False, False, 0)

    add_place("Recents", "document-open-recent", Path.home())
    add_heading("Favorites")
    add_place("Applications", "applications-system", Path("/usr/share/applications"))
    add_place("Downloads", "folder-download", Path.home() / "Downloads")
    add_place("Desktop", "user-desktop", Path.home() / "Desktop")
    add_place("Documents", "folder-documents", Path.home() / "Documents")
    add_place("Pictures", "folder-pictures", Path.home() / "Pictures")
    add_place("Projects", "folder-development", Path.home() / "Projects")
    add_heading("Locations")
    add_place(Path.home().name, "user-home", Path.home())
    add_place("SevenOS", "drive-harddisk", Path("/"))

    main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    main.get_style_context().add_class("files-main")
    main.set_size_request(650, -1)
    root.pack_start(main, True, True, 0)

    toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    toolbar.get_style_context().add_class("files-toolbar")
    main.pack_start(toolbar, False, False, 0)
    toolbar.connect("button-press-event", lambda _widget, event: begin_move(window, event))

    def toolbar_button(icon: str, callback):
        button = Gtk.Button()
        button.set_relief(Gtk.ReliefStyle.NONE)
        button.get_style_context().add_class("toolbar-button")
        button.add(Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.BUTTON))
        button.connect("clicked", callback)
        return button

    back_btn = toolbar_button("go-previous-symbolic", lambda *_: go_back())
    forward_btn = toolbar_button("go-next-symbolic", lambda *_: go_forward())
    toolbar.pack_start(back_btn, False, False, 0)
    toolbar.pack_start(forward_btn, False, False, 0)

    title = Gtk.Label()
    title.set_xalign(0)
    title.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
    title.set_single_line_mode(True)
    title.get_style_context().add_class("files-title")
    toolbar.pack_start(title, True, True, 10)

    copy_btn = toolbar_button("edit-copy-symbolic", lambda *_: copy_selected())
    paste_btn = toolbar_button("edit-paste-symbolic", lambda *_: paste_items())
    for button in (copy_btn, paste_btn):
        toolbar.pack_start(button, False, False, 0)

    for icon in ("view-grid-symbolic", "view-list-symbolic", "view-column-symbolic"):
        toolbar.pack_start(toolbar_button(icon, lambda *_: None), False, False, 0)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    main.pack_start(scroller, True, True, 0)

    flow = Gtk.FlowBox()
    flow.get_style_context().add_class("files-grid")
    flow.set_halign(Gtk.Align.FILL)
    flow.set_valign(Gtk.Align.START)
    flow.set_selection_mode(Gtk.SelectionMode.SINGLE)
    flow.set_activate_on_single_click(False)
    flow.set_min_children_per_line(4)
    flow.set_max_children_per_line(4)
    flow.set_column_spacing(22)
    flow.set_row_spacing(30)
    flow.set_homogeneous(True)
    scroller.add(flow)

    statusbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    statusbar.get_style_context().add_class("files-statusbar")
    status_label = Gtk.Label()
    status_label.set_xalign(0)
    status_label.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
    status_label.set_single_line_mode(True)
    status_label.get_style_context().add_class("files-status-label")
    statusbar.pack_start(status_label, True, True, 0)
    main.pack_start(statusbar, False, False, 0)

    preview = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
    preview.get_style_context().add_class("files-preview")
    preview.set_size_request(254, -1)
    root.pack_start(preview, False, False, 0)

    preview_icon = Gtk.Image.new_from_icon_name("folder", Gtk.IconSize.DIALOG)
    preview_icon.set_pixel_size(88)
    preview_icon.set_halign(Gtk.Align.CENTER)
    preview_icon.get_style_context().add_class("preview-icon")
    preview.pack_start(preview_icon, False, False, 0)

    preview_title = Gtk.Label(label="Seven Files")
    preview_title.set_ellipsize(Pango.EllipsizeMode.END)
    preview_title.set_single_line_mode(True)
    preview_title.set_max_width_chars(20)
    preview_title.set_justify(Gtk.Justification.CENTER)
    preview_title.set_halign(Gtk.Align.CENTER)
    preview_title.get_style_context().add_class("preview-title")
    preview.pack_start(preview_title, False, False, 0)

    preview_subtitle = Gtk.Label(label="Finder-like workspace")
    preview_subtitle.set_halign(Gtk.Align.CENTER)
    preview_subtitle.get_style_context().add_class("preview-subtitle")
    preview.pack_start(preview_subtitle, False, False, 0)

    preview_details = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    preview.pack_start(preview_details, False, False, 0)

    def update_sidebar():
        for row in sidebar_buttons:
            ctx = row.get_style_context()
            if getattr(row, "place_path", None) == current:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")

    def render():
        previous_size = window.get_size()
        title.set_text(current.name or str(current))
        for child in flow.get_children():
            flow.remove(child)
        try:
            entries = sorted(current.iterdir(), key=lambda p: (not p.is_dir(), p.name.casefold()))
        except OSError:
            entries = []
        for path in entries:
            child = Gtk.FlowBoxChild()
            child.get_style_context().add_class("file-tile")
            child.set_size_request(120, 124)
            child.path = path
            tile_event = Gtk.EventBox()
            tile_event.set_visible_window(False)
            tile_event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
            box.set_halign(Gtk.Align.CENTER)
            box.set_size_request(120, 124)
            box.get_style_context().add_class("file-tile-box")
            image = Gtk.Image.new_from_icon_name(folder_icon(path), Gtk.IconSize.DIALOG)
            image.set_pixel_size(68)
            label = Gtk.Label(label=path.name)
            label.set_width_chars(13)
            label.set_max_width_chars(13)
            label.set_line_wrap(False)
            label.set_single_line_mode(True)
            label.set_ellipsize(Pango.EllipsizeMode.END)
            label.set_justify(Gtk.Justification.CENTER)
            label.get_style_context().add_class("file-name")
            box.pack_start(image, False, False, 0)
            box.pack_start(label, False, False, 0)
            tile_event.add(box)
            tile_event.connect("button-press-event", lambda _widget, event, tile=child, item=path: on_tile_button(event, tile, item))
            child.add(tile_event)
            flow.add(child)
        status_label.set_text(f"{len(entries)} items  |  {current}")
        update_sidebar()
        update_preview(current)
        flow.show_all()
        if previous_size != (1, 1):
            GLib.idle_add(lambda: restore_window_size(previous_size))

    def restore_window_size(size: tuple[int, int]) -> bool:
        width, height = size
        if width > 0 and height > 0:
            window.resize(width, height)
        return False

    def detail_row(label: str, value: str):
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("preview-heading")
        value_label = Gtk.Label(label=value)
        value_label.set_xalign(0)
        value_label.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        value_label.set_single_line_mode(True)
        value_label.set_max_width_chars(24)
        value_label.get_style_context().add_class("preview-value")
        preview_details.pack_start(heading, False, False, 0)
        preview_details.pack_start(value_label, False, False, 0)

    def update_preview(path: Path | None):
        for child in preview_details.get_children():
            preview_details.remove(child)
        target = path or current
        preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
        preview_icon.set_pixel_size(88)
        preview_title.set_text(target.name or str(target))
        preview_subtitle.set_text("Folder" if target.is_dir() else (target.suffix.upper().lstrip(".") or "File"))
        try:
            stat = target.stat()
            detail_row("Location", str(target.parent if target != current else target))
            detail_row("Modified", time.strftime("%b %d, %Y %H:%M", time.localtime(stat.st_mtime)))
            if target.is_file():
                detail_row("Size", format_size(stat.st_size))
            elif target.is_dir():
                try:
                    count = len(list(target.iterdir()))
                except OSError:
                    count = 0
                detail_row("Items", f"{count}")
        except OSError:
            detail_row("Status", "Unavailable")
        preview_details.show_all()

    def open_image_preview(path: Path):
        preview_window = Gtk.Window(title=path.name)
        preview_window.set_default_size(880, 620)
        preview_window.set_size_request(520, 360)
        preview_window.set_resizable(True)
        preview_window.set_position(Gtk.WindowPosition.CENTER)
        preview_window.set_wmclass("SevenImagePreview", "SevenImagePreview")

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        preview_window.add(outer)

        header = Gtk.HeaderBar(title=path.name)
        header.set_show_close_button(True)
        preview_window.set_titlebar(header)

        image_scroller = Gtk.ScrolledWindow()
        image_scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        image_scroller.set_hexpand(True)
        image_scroller.set_vexpand(True)

        try:
            pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), 1160, 760, True)
            image = Gtk.Image.new_from_pixbuf(pixbuf)
        except Exception:
            image = Gtk.Image.new_from_icon_name("image-x-generic", Gtk.IconSize.DIALOG)
            image.set_pixel_size(128)
        image.set_margin_top(24)
        image.set_margin_bottom(24)
        image.set_margin_start(24)
        image.set_margin_end(24)
        image_scroller.add_with_viewport(image)
        outer.pack_start(image_scroller, True, True, 0)

        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        footer.set_margin_top(8)
        footer.set_margin_bottom(10)
        footer.set_margin_start(14)
        footer.set_margin_end(14)
        open_button = Gtk.Button(label="Open externally")
        wallpaper_button = Gtk.Button(label="Set as Wallpaper")
        open_button.connect("clicked", lambda *_: open_image_externally(path))
        wallpaper_button.connect("clicked", lambda *_: set_wallpaper_from_file(path))
        footer.pack_start(open_button, False, False, 0)
        footer.pack_end(wallpaper_button, False, False, 0)
        outer.pack_start(footer, False, False, 0)

        preview_window.show_all()

    def open_file(path: Path):
        if is_image(path):
            open_image_preview(path)
        else:
            xdg_open(path)

    def open_image_externally(path: Path):
        for command in ("loupe", "eog", "swayimg", "imv", "feh"):
            if shutil.which(command):
                subprocess.Popen([command, str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return
        open_image_preview(path)

    def set_wallpaper_from_file(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-wallpaper").exists():
            command = [str(root / "bin/seven-wallpaper"), "set", str(path)]
        else:
            command = ["seven-wallpaper", "set", str(path)]
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def copy_path(path: Path):
        Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(str(path), -1)

    def selected_path() -> Path | None:
        selected = flow.get_selected_children()
        if not selected:
            return None
        return selected[0].path

    def copy_items(paths: list[Path], cut: bool = False):
        nonlocal file_clipboard, file_clipboard_cut
        file_clipboard = [path for path in paths if path.exists()]
        file_clipboard_cut = cut
        if file_clipboard:
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text("\n".join(str(path) for path in file_clipboard), -1)
            status_label.set_text(f"{'Cut' if cut else 'Copied'} {len(file_clipboard)} item(s)")

    def copy_selected():
        path = selected_path()
        if path:
            copy_items([path])

    def cut_selected():
        path = selected_path()
        if path:
            copy_items([path], cut=True)

    def unique_destination(directory: Path, name: str) -> Path:
        destination = directory / name
        if not destination.exists():
            return destination
        stem = destination.stem
        suffix = destination.suffix
        for index in range(2, 1000):
            candidate = directory / f"{stem} copy {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{stem} copy{suffix}"

    def paste_items():
        nonlocal file_clipboard, file_clipboard_cut
        if not file_clipboard:
            status_label.set_text("Nothing to paste")
            return
        pasted = 0
        for source in list(file_clipboard):
            if not source.exists():
                continue
            destination = unique_destination(current, source.name)
            try:
                if file_clipboard_cut:
                    shutil.move(str(source), str(destination))
                elif source.is_dir():
                    shutil.copytree(source, destination)
                else:
                    shutil.copy2(source, destination)
                pasted += 1
            except OSError:
                continue
        if file_clipboard_cut:
            file_clipboard = []
            file_clipboard_cut = False
        render()
        status_label.set_text(f"Pasted {pasted} item(s)" if pasted else "Paste failed")

    def reveal_in_parent(path: Path):
        xdg_open(path.parent if path.is_file() else path)

    def add_menu_item(menu, label: str, callback):
        item = Gtk.MenuItem(label=label)
        item.connect("activate", lambda *_: callback())
        menu.append(item)

    def show_context_menu(path: Path, event):
        menu = Gtk.Menu()
        add_menu_item(menu, "Open", lambda: navigate(path) if path.is_dir() else open_file(path))
        add_menu_item(menu, "Copy", lambda: copy_items([path]))
        add_menu_item(menu, "Cut", lambda: copy_items([path], cut=True))
        add_menu_item(menu, "Paste Item", paste_items)
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Reveal in Folder", lambda: reveal_in_parent(path))
        add_menu_item(menu, "Copy Path", lambda: copy_path(path))
        if is_image(path):
            menu.append(Gtk.SeparatorMenuItem())
            add_menu_item(menu, "Set as Wallpaper", lambda: set_wallpaper_from_file(path))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Properties", lambda: update_preview(path))
        menu.show_all()
        try:
            menu.popup_at_pointer(event)
        except AttributeError:
            menu.popup(None, None, None, None, event.button, event.time)

    def on_tile_button(event, child, path: Path) -> bool:
        if getattr(event, "button", 0) == 3:
            flow.select_child(child)
            update_preview(path)
            show_context_menu(path, event)
            return True
        if getattr(event, "button", 0) == 1:
            flow.select_child(child)
            update_preview(path)
            if getattr(event, "type", None) == Gdk.EventType._2BUTTON_PRESS:
                open_selected(path)
            return True
        return False

    def open_selected(path: Path | None = None):
        target = path or selected_path()
        if not target:
            return
        if target.is_dir():
            navigate(target)
        else:
            open_file(target)

    def navigate(path: Path):
        nonlocal current
        if not path.exists() or not path.is_dir():
            return
        if path != current:
            history.append(current)
            future.clear()
            current = path
        render()

    def go_back():
        nonlocal current
        if history:
            future.append(current)
            current = history.pop()
            render()

    def go_forward():
        nonlocal current
        if future:
            history.append(current)
            current = future.pop()
            render()

    def activate(_flow, child):
        if child is None:
            return
        open_selected(child.path)

    def selection_changed(flow_box):
        selected = flow_box.get_selected_children()
        if selected:
            update_preview(selected[0].path)
        else:
            update_preview(current)

    def on_key(_window, event):
        if event.keyval == Gdk.KEY_Escape:
            window.close()
            return True
        if event.keyval == Gdk.KEY_BackSpace:
            go_back()
            return True
        if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            open_selected()
            return True
        if event.state & Gdk.ModifierType.CONTROL_MASK:
            if event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
                copy_selected()
                return True
            if event.keyval in (Gdk.KEY_x, Gdk.KEY_X):
                cut_selected()
                return True
            if event.keyval in (Gdk.KEY_v, Gdk.KEY_V):
                paste_items()
                return True
        return False

    flow.connect("child-activated", activate)
    flow.connect("selected-children-changed", selection_changed)
    window.connect("key-press-event", on_key)
    window.connect("destroy", Gtk.main_quit)
    render()
    window.show_all()
    window.resize(1080, 680)
    Gtk.main()
    return 0


def toggle_zoom_or_tile(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        result = subprocess.run(["hyprctl", "dispatch", "togglefloating", "active"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            return
    if window.is_maximized():
        window.unmaximize()
        window.resize(1120, 700)
    else:
        window.maximize()


def minimize_window(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        for command in (
            ["hyprctl", "dispatch", "movetoworkspacesilent", "special:seven"],
            ["hyprctl", "dispatch", "movetoworkspace", "special:seven"],
        ):
            result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                return
    window.iconify()


def format_size(size: int) -> str:
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{size} B"


def begin_move(window, event) -> bool:
    if getattr(event, "button", 0) == 1:
        window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
        return True
    return False


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("path", nargs="?", default=str(Path.home()))
    args = parser.parse_args()
    if args.probe:
        return probe()
    return run_files(args.path)


if __name__ == "__main__":
    raise SystemExit(main())
