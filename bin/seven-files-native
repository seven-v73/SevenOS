def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("GdkPixbuf", "2.0")
        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def xdg_open(path: Path) -> None:
    subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


IMAGE_SUFFIXES = {".png", ".jpg", ".jpeg", ".webp", ".gif", ".svg", ".bmp", ".tiff", ".tif"}
VIDEO_SUFFIXES = {".mp4", ".mkv", ".mov", ".webm", ".avi", ".m4v"}
AUDIO_SUFFIXES = {".mp3", ".wav", ".flac", ".ogg", ".m4a", ".aac", ".opus"}
TEXT_SUFFIXES = {
    ".txt", ".md", ".log", ".csv", ".json", ".yaml", ".yml", ".toml", ".ini",
    ".conf", ".sh", ".py", ".rs", ".js", ".ts", ".html", ".css", ".xml",
}
DOCUMENT_SUFFIXES = {".pdf", ".docx", ".odt", ".rtf"}
READER_SUFFIXES = {".pdf", ".epub", ".md", ".markdown", ".txt", ".cbz"}
PREVIEW_SUFFIXES = IMAGE_SUFFIXES | VIDEO_SUFFIXES | AUDIO_SUFFIXES | TEXT_SUFFIXES | DOCUMENT_SUFFIXES | READER_SUFFIXES
CLIPBOARD_CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos" / "files-clipboard.json"
TAG_CACHE = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/files-tags.json"
PREFS_CACHE = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/files-prefs.json"
RECENTS_CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos/files-recents.json"
GLOBAL_INDEX_CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos/files-index.json"
PROFILE_UI_FILE = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/profile-ui.json"
RECENTS_SENTINEL = Path("__sevenos_recent__")


def is_image(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in IMAGE_SUFFIXES


def is_video(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in VIDEO_SUFFIXES


def is_audio(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in AUDIO_SUFFIXES


def is_previewable(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in PREVIEW_SUFFIXES


def resolve_root() -> Path | None:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin").is_dir():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin").is_dir():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin").is_dir():
            return candidate
    return None


ROOT_DIR = resolve_root()
if ROOT_DIR:
    sys.path.insert(0, str(ROOT_DIR / "scripts"))
try:
    from seven_i18n import tr_text  # noqa: E402
    import seven_theme  # noqa: E402
except Exception:  # pragma: no cover - fallback for standalone probes
    def tr_text(text: str, **values: object) -> str:
        return text.format(**values) if values else text
    seven_theme = None


def read_theme_mode() -> str:
    config = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/theme.conf"
    if os.environ.get("SEVENOS_THEME_MODE") in {"dark", "light"}:
        return os.environ["SEVENOS_THEME_MODE"]
    if config.exists():
        for line in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            if line.startswith("SEVENOS_THEME_MODE="):
                value = line.split("=", 1)[1].strip().strip("'\"")
                if value in {"dark", "light"}:
                    return value
    return "dark"


def read_icon_theme(theme_mode: str) -> str:
    settings = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "gtk-3.0/settings.ini"
    if settings.exists():
        for line in settings.read_text(encoding="utf-8", errors="ignore").splitlines():
            if line.startswith("gtk-icon-theme-name="):
                value = line.split("=", 1)[1].strip()
                if value:
                    return value
    return "Papirus" if theme_mode == "light" else "Papirus-Dark"


def read_active_profile() -> str:
    try:
        profile_ui = json.loads(PROFILE_UI_FILE.read_text(encoding="utf-8"))
        if isinstance(profile_ui, dict) and profile_ui.get("profile"):
            return str(profile_ui["profile"]).strip().lower() or "equinox"
    except (OSError, json.JSONDecodeError):
        pass
    config = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/profile.env"
    if os.environ.get("SEVENOS_PROFILE"):
        return os.environ["SEVENOS_PROFILE"].strip().lower()
    if config.exists():
        for line in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            if line.startswith("SEVENOS_PROFILE="):
                return line.split("=", 1)[1].strip().strip("'\"").lower() or "equinox"
    return "equinox"


def profile_label(profile: str) -> str:
    return {
        "equinox": "Equinox",
        "baobab": "Baobab",
        "forge": "Forge",
        "shield": "Shield",
        "studio": "Studio",
        "horizon": "Horizon",
        "pulse": "Pulse",
        "windows": "Windows",
    }.get(profile, profile.title() or "Equinox")


def load_json(path: Path, fallback):
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        pass
    return fallback


def write_json(path: Path, payload) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")


def read_profile_ui() -> dict:
    data = load_json(PROFILE_UI_FILE, {})
    return data if isinstance(data, dict) else {}


def profile_title(profile: str, profile_ui: dict) -> str:
    return str(profile_ui.get("title") or profile_label(profile))


def profile_css(theme_mode: str, profile_ui: dict) -> str:
    accent = profile_ui.get("accent") or "#89B4FA"
    secondary = profile_ui.get("secondary") or "#8B7CFF"
    return f"""
    @define-color files_accent {accent};
    .files-root {{
      background:
        radial-gradient(circle at top left, alpha({accent}, {'0.14' if theme_mode == 'light' else '0.18'}), transparent 38%),
        radial-gradient(circle at top right, alpha({secondary}, {'0.10' if theme_mode == 'light' else '0.13'}), transparent 34%),
        linear-gradient(145deg, alpha(@files_panel, 0.98), alpha(@files_bg, 0.94));
    }}
    .files-search {{
      border-color: alpha({accent}, 0.22);
    }}
    .operation-pill {{
      border-color: alpha({accent}, 0.26);
      color: {accent};
    }}
    """


def theme_css(theme_mode: str, profile_ui: dict | None = None) -> str:
    shared_css = seven_theme.gtk_app_css("files", theme_mode) if seven_theme else ""
    if theme_mode == "light":
        return shared_css + """
        @define-color files_bg #F8FAFD;
        @define-color files_panel rgba(255,255,255,0.82);
        @define-color files_sidebar rgba(244,247,251,0.86);
        @define-color files_text #1C1F26;
        @define-color files_muted #6B7280;
        @define-color files_border rgba(0,0,0,0.08);
        @define-color files_hover rgba(47,123,255,0.10);
        @define-color files_selected rgba(47,123,255,0.18);
        @define-color files_accent #2F7BFF;
        """ + profile_css(theme_mode, profile_ui or {})
    return shared_css + """
    @define-color files_bg #09090B;
    @define-color files_panel rgba(18,19,26,0.78);
    @define-color files_sidebar rgba(17,17,27,0.84);
    @define-color files_text #EDEDED;
    @define-color files_muted #A6ADC8;
    @define-color files_border rgba(255,255,255,0.10);
    @define-color files_hover rgba(77,163,255,0.12);
    @define-color files_selected rgba(122,92,255,0.24);
    @define-color files_accent #89B4FA;
    """ + profile_css(theme_mode, profile_ui or {})


def folder_icon(path: Path) -> str:
    mapping = {
        "Desktop": "user-desktop",
        "Documents": "folder-documents",
        "Downloads": "folder-download",
        "Music": "folder-music",
        "Pictures": "folder-pictures",
        "Videos": "folder-videos",
        "Projects": "folder-development",
    }
    if path.is_dir():
        return mapping.get(path.name, "folder")
    suffix = path.suffix.lower()
    if suffix in IMAGE_SUFFIXES:
        return "image-x-generic"
    if suffix in VIDEO_SUFFIXES:
        return "video-x-generic"
    if suffix in AUDIO_SUFFIXES:
        return "audio-x-generic"
    if suffix in {".zip", ".tar", ".gz", ".xz", ".7z"}:
        return "package-x-generic"
    if suffix == ".pdf":
        return "application-pdf"
    if suffix in {".sh", ".py", ".rs", ".js", ".ts", ".html", ".css", ".json", ".md"}:
        return "text-x-script"
    return "text-x-generic"


ARCHIVE_FORMATS = {
    "zip": ".zip",
    "tar.gz": ".tar.gz",
    "tar.xz": ".tar.xz",
}


def run_files(start_path: str) -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("GdkPixbuf", "2.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GdkPixbuf, GLib, Gtk, Pango
    GLib.set_prgname("SevenFilesNative")
    theme_mode = read_theme_mode()
    profile_ui = read_profile_ui()
    active_profile = read_active_profile()
    GLib.set_application_name(f"Seven Files · {profile_title(active_profile, profile_ui)}")
    try:
        Gdk.set_program_class("SevenFilesNative")
    except Exception:
        pass

    icon_theme = read_icon_theme(theme_mode)
    gtk_settings = Gtk.Settings.get_default()
    if gtk_settings:
        gtk_settings.set_property("gtk-icon-theme-name", icon_theme)

    prefs = load_json(PREFS_CACHE, {})
    virtual_location = ""
    start_raw = start_path.strip()
    if start_raw.startswith("recent://"):
        current = Path.home()
        virtual_location = "recent"
    elif start_raw.startswith("trash://"):
        current = Path.home() / ".local/share/Trash/files"
        current.mkdir(parents=True, exist_ok=True)
    else:
        current = Path(start_path).expanduser()
    if not current.exists():
        current = Path.home()
    if current.is_file():
        current = current.parent

    history: list[Path] = []
    future: list[Path] = []
    file_clipboard: list[Path] = []
    file_clipboard_cut = False
    view_mode = str(prefs.get("view_mode", "grid"))
    if view_mode not in {"grid", "list", "compact"}:
        view_mode = "grid"
    sort_mode = str(prefs.get("sort_mode", "name"))
    if sort_mode not in {"name", "modified", "size", "kind"}:
        sort_mode = "name"
    search_query = ""
    show_hidden = bool(prefs.get("show_hidden", False))
    operation_active = False

    css = theme_css(theme_mode, profile_ui) + seven_theme.surface_css("files", mode=theme_mode)
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title=f"Seven Files · {profile_title(active_profile, profile_ui)}")
    window.set_default_size(1040, 660)
    window.set_size_request(760, 520)
    window.set_resizable(True)
    window.set_decorated(False)
    window.set_wmclass("SevenFilesNative", "SevenFilesNative")
    window.get_style_context().add_class("seven-files")

    root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    root.get_style_context().add_class("files-root")
    window.add(root)

    sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    sidebar.get_style_context().add_class("files-sidebar")
    sidebar.set_size_request(204, -1)
    root.pack_start(sidebar, False, False, 0)

    traffic = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    traffic.get_style_context().add_class("traffic-row")
    sidebar.pack_start(traffic, False, False, 0)

    def draw_dot(widget, cr, fill: str, stroke: str, style: str):
        rgba = Gdk.RGBA()
        border = Gdk.RGBA()
        rgba.parse(fill)
        border.parse(stroke)
        alloc = widget.get_allocation()
        radius = min(alloc.width, alloc.height) / 2 - 1
        cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, rgba.alpha)
        cr.arc(alloc.width / 2, alloc.height / 2, radius, 0, 6.28318)
        cr.fill_preserve()
        cr.set_source_rgba(border.red, border.green, border.blue, 0.72)
        cr.set_line_width(1)
        cr.stroke()
        draw_dot_symbol(cr, style, alloc.width / 2, alloc.height / 2, radius)
        return False

    def draw_dot_symbol(cr, style: str, center_x: float, center_y: float, radius: float) -> None:
        cr.set_line_width(1.35)
        cr.set_line_cap(1)
        cr.set_source_rgba(0.20, 0.14, 0.10, 0.52)
        if style == "close":
            offset = radius * 0.38
            cr.move_to(center_x - offset, center_y - offset)
            cr.line_to(center_x + offset, center_y + offset)
            cr.move_to(center_x + offset, center_y - offset)
            cr.line_to(center_x - offset, center_y + offset)
        elif style == "min":
            offset = radius * 0.42
            cr.move_to(center_x - offset, center_y)
            cr.line_to(center_x + offset, center_y)
        elif style == "max":
            offset = radius * 0.36
            cr.move_to(center_x, center_y - offset)
            cr.line_to(center_x, center_y + offset)
            cr.move_to(center_x - offset, center_y)
            cr.line_to(center_x + offset, center_y)
        cr.stroke()

    def dot(fill: str, stroke: str, style: str, callback):
        event = Gtk.EventBox()
        event.set_visible_window(False)
        event.set_above_child(True)
        area = Gtk.DrawingArea()
        area.set_size_request(15, 15)
        area.get_style_context().add_class("traffic-dot")
        area.connect("draw", draw_dot, fill, stroke, style)
        event.add(area)
        event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
        event.connect("button-press-event", lambda _widget, event_data: activate_dot(event_data, callback))
        return event

    def activate_dot(event_data, callback) -> bool:
        if getattr(event_data, "button", 0) == 1:
            callback()
            return True
        return False

    traffic.pack_start(dot("#ff5f57", "#d8463f", "close", lambda: window.close()), False, False, 0)
    traffic.pack_start(dot("#febc2e", "#d9a023", "min", lambda: minimize_window(window)), False, False, 0)
    traffic.pack_start(dot("#28c840", "#1fa334", "max", lambda: toggle_zoom_or_tile(window)), False, False, 0)

    sidebar_buttons = []

    def add_heading(label: str):
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("sidebar-heading")
        sidebar.pack_start(heading, False, False, 0)

    def add_place(label: str, icon: str, path: Path):
        row = Gtk.Button()
        row.set_relief(Gtk.ReliefStyle.NONE)
        row.get_style_context().add_class("sidebar-row")
        content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        image = Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.MENU)
        text = Gtk.Label(label=label)
        text.set_xalign(0)
        content.pack_start(image, False, False, 0)
        content.pack_start(text, True, True, 0)
        row.add(content)
        row.connect("clicked", lambda *_: navigate(path))
        row.place_path = path
        sidebar_buttons.append(row)
        sidebar.pack_start(row, False, False, 0)

    add_place("Recents", "document-open-recent", RECENTS_SENTINEL)
    add_heading("Favorites")
    add_place("Applications", "applications-system", Path("/usr/share/applications"))
    add_place("Downloads", "folder-download", Path.home() / "Downloads")
    add_place("Desktop", "user-desktop", Path.home() / "Desktop")
    add_place("Documents", "folder-documents", Path.home() / "Documents")
    add_place("Pictures", "folder-pictures", Path.home() / "Pictures")
    add_place("Projects", "folder-development", Path.home() / "Projects")
    add_heading("Locations")
    add_place(Path.home().name, "user-home", Path.home())
    add_place("SevenOS", "drive-harddisk", Path("/"))

    main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    main.get_style_context().add_class("files-main")
    main.set_size_request(650, -1)
    root.pack_start(main, True, True, 0)

    toolbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    toolbar.get_style_context().add_class("files-toolbar")
    main.pack_start(toolbar, False, False, 0)
    toolbar.connect("button-press-event", lambda _widget, event: begin_move(window, event))

    nav_group = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
    nav_group.get_style_context().add_class("toolbar-group")
    actions_group = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
    actions_group.get_style_context().add_class("toolbar-group")
    view_group = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
    view_group.get_style_context().add_class("toolbar-group")

    def toolbar_button(icon: str, callback):
        button = Gtk.Button()
        button.set_relief(Gtk.ReliefStyle.NONE)
        button.get_style_context().add_class("toolbar-button")
        button.add(Gtk.Image.new_from_icon_name(icon, Gtk.IconSize.BUTTON))
        button.connect("clicked", callback)
        return button

    back_btn = toolbar_button("go-previous-symbolic", lambda *_: go_back())
    forward_btn = toolbar_button("go-next-symbolic", lambda *_: go_forward())
    nav_group.pack_start(back_btn, False, False, 0)
    nav_group.pack_start(forward_btn, False, False, 0)
    toolbar.pack_start(nav_group, False, False, 0)

    breadcrumb_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
    breadcrumb_box.set_hexpand(True)
    toolbar.pack_start(breadcrumb_box, True, True, 10)

    search_entry = Gtk.SearchEntry()
    search_entry.set_placeholder_text(tr_text("Search"))
    search_entry.get_style_context().add_class("files-search")
    search_entry.set_tooltip_text(tr_text("Search current folder. Prefix with / for global search or # for tags."))
    search_entry.set_width_chars(8)
    search_entry.set_max_width_chars(12)
    search_entry.set_size_request(112, -1)
    toolbar.pack_start(search_entry, False, False, 0)

    sort_labels = {"name": "A-Z", "modified": tr_text("Date"), "size": tr_text("Size"), "kind": tr_text("Type")}
    sort_order = ["name", "modified", "size", "kind"]
    sort_button = Gtk.Button(label=sort_labels.get(sort_mode, "A-Z"))
    sort_button.set_relief(Gtk.ReliefStyle.NONE)
    sort_button.get_style_context().add_class("files-sort")
    sort_button.set_tooltip_text(tr_text("Sort files: A-Z, Date, Size, Type"))
    sort_button.set_size_request(58, -1)
    toolbar.pack_start(sort_button, False, False, 0)

    copy_btn = toolbar_button("edit-copy-symbolic", lambda *_: copy_selected())
    paste_btn = toolbar_button("edit-paste-symbolic", lambda *_: paste_items())
    compress_btn = toolbar_button("package-x-generic-symbolic", lambda *_: compress_selected())
    ai_btn = toolbar_button("seven-ai", lambda *_: sevenai_selected())
    new_folder_btn = toolbar_button("folder-new-symbolic", lambda *_: create_folder())
    compress_btn.set_tooltip_text(tr_text("Compress selected item"))
    ai_btn.set_tooltip_text(tr_text("Ask SevenAI about selection"))
    new_folder_btn.set_tooltip_text(tr_text("New folder"))
    for button in (new_folder_btn, copy_btn, paste_btn, compress_btn, ai_btn):
        actions_group.pack_start(button, False, False, 0)
    toolbar.pack_start(actions_group, False, False, 0)

    def set_view_mode(mode: str):
        nonlocal view_mode
        view_mode = mode
        save_preferences()
        render()

    def toggle_hidden():
        nonlocal show_hidden
        show_hidden = not show_hidden
        save_preferences()
        render()

    grid_btn = toolbar_button("view-grid-symbolic", lambda *_: set_view_mode("grid"))
    list_btn = toolbar_button("view-list-symbolic", lambda *_: set_view_mode("list"))
    compact_btn = toolbar_button("view-column-symbolic", lambda *_: set_view_mode("compact"))
    grid_btn.set_tooltip_text(tr_text("Grid view"))
    list_btn.set_tooltip_text(tr_text("List view"))
    compact_btn.set_tooltip_text(tr_text("Compact view"))
    for button in (grid_btn, list_btn, compact_btn):
        view_group.pack_start(button, False, False, 0)

    hidden_btn = toolbar_button("view-visible-symbolic", lambda *_: toggle_hidden())
    hidden_btn.set_tooltip_text(tr_text("Show hidden files"))
    view_group.pack_start(hidden_btn, False, False, 0)
    toolbar.pack_start(view_group, False, False, 0)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    main.pack_start(scroller, True, True, 0)

    flow = Gtk.FlowBox()
    flow.set_can_focus(True)
    flow.get_style_context().add_class("files-grid")
    flow.set_halign(Gtk.Align.FILL)
    flow.set_valign(Gtk.Align.START)
    flow.set_selection_mode(Gtk.SelectionMode.MULTIPLE)
    flow.set_activate_on_single_click(False)
    flow.set_min_children_per_line(4)
    flow.set_max_children_per_line(4)
    flow.set_column_spacing(22)
    flow.set_row_spacing(30)
    flow.set_homogeneous(True)
    scroller.add(flow)

    statusbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
    statusbar.get_style_context().add_class("files-statusbar")
