    grouped_resources = bool(prefs.get("grouped_resources", False))

    def mini_os_resource_root_for_start() -> Path:
        profile_key = (active_profile or "equinox").strip().lower() or "equinox"
        if grouped_resources or profile_key == "equinox":
            return Path.home()
        return Path.home() / ".local/share/sevenos/profile-containers" / profile_key / "home"

    virtual_location = ""
    start_raw = start_path.strip()
    explicit_start = start_raw not in {"", str(Path.home())}
    if start_raw.startswith("recent://"):
        current = Path.home()
        virtual_location = "recent"
    elif start_raw.startswith("trash://"):
        current = Path.home() / ".local/share/Trash/files"
        current.mkdir(parents=True, exist_ok=True)
    elif not start_raw:
        current = mini_os_resource_root_for_start()
    else:
        current = Path(start_path).expanduser()
    if not start_raw:
        try:
            current.mkdir(parents=True, exist_ok=True)
        except OSError:
            pass
    if not current.exists():
        current = Path.home()
    if current.is_file():
        current = current.parent

    history: list[Path] = []
    future: list[Path] = []
    tabs: list[dict[str, object]] = []
    active_tab_index = 0
    file_clipboard: list[Path] = []
    file_clipboard_cut = False
    view_mode = str(prefs.get("view_mode", "grid"))
