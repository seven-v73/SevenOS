    preview_icon.get_style_context().add_class("preview-icon")
    preview.pack_start(preview_icon, False, False, 0)

    preview_title = Gtk.Label(label="Seven Files")
    preview_title.set_ellipsize(Pango.EllipsizeMode.END)
    preview_title.set_single_line_mode(True)
    preview_title.set_max_width_chars(20)
    preview_title.set_justify(Gtk.Justification.CENTER)
    preview_title.set_halign(Gtk.Align.CENTER)
    preview_title.get_style_context().add_class("preview-title")
    preview.pack_start(preview_title, False, False, 0)

    preview_subtitle = Gtk.Label(label=tr_text("SevenOS Files workspace"))
    preview_subtitle.set_halign(Gtk.Align.CENTER)
    preview_subtitle.get_style_context().add_class("preview-subtitle")
    preview.pack_start(preview_subtitle, False, False, 0)

    preview_details = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    preview.pack_start(preview_details, False, False, 0)

    def update_sidebar():
        for row in sidebar_buttons:
            ctx = row.get_style_context()
            place_path = getattr(row, "place_path", None)
            if (virtual_location == "recent" and place_path == RECENTS_SENTINEL) or place_path == current:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")

    def tab_title(path: Path, virtual: str = "") -> str:
        if virtual == "recent":
            return "Recents"
        return "Home" if path == Path.home() else (path.name or "SevenOS")

    def sync_current_tab() -> None:
        if not tabs:
            return
        tabs[active_tab_index] = {
            "path": current,
            "virtual": virtual_location,
            "history": list(history),
            "future": list(future),
        }

    def show_tab_menu(button, index: int, event) -> bool:
        menu = Gtk.Menu()
        tab = tabs[index]
        path = tab.get("path", Path.home())
        actions = [
            ("Open Tab", lambda: switch_tab(index)),
            ("Duplicate Tab", lambda: new_tab(path, str(tab.get("virtual", "")))),
            ("Close Tab", lambda: close_tab(index)),
        ]
        if isinstance(path, Path):
            actions.append(("Add Tab Folder to Favorites", lambda: add_favorite_path(path)))
        for label, callback in actions:
            item = Gtk.MenuItem(label=label)
            item.connect("activate", lambda _item, action=callback: action())
            menu.append(item)
        menu.show_all()
        try:
            menu.popup_at_pointer(event)
        except AttributeError:
            menu.popup(None, None, None, None, getattr(event, "button", 0), getattr(event, "time", Gtk.get_current_event_time()))
        return True

    def render_tabs() -> None:
        for child in tabbar.get_children():
            tabbar.remove(child)
        for index, tab in enumerate(tabs):
            label = tab_title(tab.get("path", Path.home()), str(tab.get("virtual", "")))
            button = Gtk.Button(label=label)
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("files-tab")
            if index == active_tab_index:
                button.get_style_context().add_class("active")
            button.connect("clicked", lambda _button, tab_index=index: switch_tab(tab_index))
            button.connect(
                "button-press-event",
                lambda widget, event, tab_index=index: close_tab(tab_index)
                if getattr(event, "button", 0) == 2
                else show_tab_menu(widget, tab_index, event)
                if getattr(event, "button", 0) == 3
                else False,
            )
            tabbar.pack_start(button, False, False, 0)
        add_button = Gtk.Button(label="+")
        add_button.set_relief(Gtk.ReliefStyle.NONE)
        add_button.get_style_context().add_class("files-tab")
        add_button.set_tooltip_text(tr_text("New tab"))
        add_button.connect("clicked", lambda *_: new_tab(current))
        tabbar.pack_start(add_button, False, False, 0)
        tabbar.show_all()

    def switch_tab(index: int) -> bool:
        nonlocal current, virtual_location, history, future, active_tab_index
        if index < 0 or index >= len(tabs) or index == active_tab_index:
            return False
        sync_current_tab()
        active_tab_index = index
        tab = tabs[index]
        current = tab.get("path", Path.home())
        virtual_location = str(tab.get("virtual", ""))
        history = list(tab.get("history", []))
        future = list(tab.get("future", []))
        clear_search()
        render()
        return True

    def new_tab(path: Path | None = None, virtual: str = "") -> bool:
        nonlocal current, virtual_location, history, future, active_tab_index
        sync_current_tab()
        tabs.append({"path": path or Path.home(), "virtual": virtual, "history": [], "future": []})
        active_tab_index = len(tabs) - 1
        current = path or Path.home()
        virtual_location = virtual
        history = []
        future = []
        clear_search()
        render()
        return True

    def close_tab(index: int | None = None) -> bool:
        nonlocal current, virtual_location, history, future, active_tab_index
        if len(tabs) <= 1:
            window.close()
            return True
        target = active_tab_index if index is None else index
        if target < 0 or target >= len(tabs):
            return False
        tabs.pop(target)
        if target < active_tab_index:
            active_tab_index -= 1
        active_tab_index = min(active_tab_index, len(tabs) - 1)
        tab = tabs[active_tab_index]
        current = tab.get("path", Path.home())
        virtual_location = str(tab.get("virtual", ""))
        history = list(tab.get("history", []))
        future = list(tab.get("future", []))
        render()
        return True

    def show_history_menu(button, items: list[Path], reverse: bool = True) -> bool:
        menu = Gtk.Menu()
        source = list(reversed(items)) if reverse else list(items)
        for path in source[:12]:
            item = Gtk.MenuItem(label=tab_title(path))
            item.connect("activate", lambda _item, target=path: navigate(target))
            menu.append(item)
        if not source:
            item = Gtk.MenuItem(label=tr_text("No history"))
            item.set_sensitive(False)
            menu.append(item)
        menu.show_all()
        try:
            menu.popup_at_widget(button, Gdk.Gravity.SOUTH_WEST, Gdk.Gravity.NORTH_WEST, None)
        except Exception:
            menu.popup(None, None, None, None, 0, Gtk.get_current_event_time())
        return True

    back_btn.connect("button-press-event", lambda button, event: show_history_menu(button, history) if getattr(event, "button", 0) == 3 else False)
    forward_btn.connect("button-press-event", lambda button, event: show_history_menu(button, future, reverse=False) if getattr(event, "button", 0) == 3 else False)

    def press_feedback(widget) -> bool:
        widget.get_style_context().add_class("pressed")
        return False

    def release_feedback(widget) -> bool:
        widget.get_style_context().remove_class("pressed")
        return False

    def flash_status() -> bool:
        statusbar.get_style_context().add_class("status-flash")

        def clear_flash() -> bool:
            statusbar.get_style_context().remove_class("status-flash")
            return False

        GLib.timeout_add(STATUS_FLASH_MS, clear_flash)
        return False

    def set_status(message: str) -> None:
        status_label.set_text(message)
        flash_status()

    def flash_tile(child) -> None:
        child.get_style_context().add_class("pressed")

        def clear_pressed() -> bool:
            child.get_style_context().remove_class("pressed")
            return False

        GLib.timeout_add(CLICK_FEEDBACK_MS, clear_pressed)

    def path_label(path: Path) -> str:
        if virtual_location == "recent":
            return "Recents"
        if path == Path.home():
            return "Home"
        if path == Path(path.anchor):
            return "SevenOS"
        return path.name or str(path)

    def update_breadcrumbs():
        for child in breadcrumb_box.get_children():
            breadcrumb_box.remove(child)
        breadcrumb_box.set_visible(not location_entry.get_visible())
        def show_breadcrumb_menu(button, event, target: Path) -> bool:
            menu = Gtk.Menu()
            for label, callback in (
                ("Open", lambda: navigate(target)),
                ("Open in New Tab", lambda: new_tab(target)),
                ("Open in Split", lambda: open_path_in_split(target)),
                ("Add to Favorites", lambda: add_favorite_path(target)),
                ("Copy Path", lambda: copy_path(target)),
            ):
                item = Gtk.MenuItem(label=label)
                item.connect("activate", lambda _item, action=callback: action())
                menu.append(item)
            menu.show_all()
            try:
                menu.popup_at_pointer(event)
            except AttributeError:
                menu.popup(None, None, None, None, getattr(event, "button", 0), getattr(event, "time", Gtk.get_current_event_time()))
            return True

        if virtual_location == "recent":
            button = Gtk.Button(label=tr_text("Recents"))
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("breadcrumb-button")
            button.set_size_request(-1, 24)
            button.connect("pressed", lambda widget: press_feedback(widget))
            button.connect("released", lambda widget: release_feedback(widget))
            breadcrumb_box.pack_start(button, False, False, 0)
            breadcrumb_box.show_all()
            return
        home = Path.home()
        try:
            relative_to_home = current.relative_to(home)
            parts = [Path(current.anchor), home]
            cursor = home
            for segment in relative_to_home.parts:
                cursor = cursor / segment
                if cursor != home:
                    parts.append(cursor)
        except ValueError:
            parts = []
            cursor = current
            while True:
                if cursor != home.parent:
                    parts.append(cursor)
                if cursor.parent == cursor:
                    break
                cursor = cursor.parent
            parts.reverse()
        if len(parts) > 5:
            parts = [parts[0], *parts[-4:]]
        for index, part in enumerate(parts):
            button = Gtk.Button(label=path_label(part))
            button.set_relief(Gtk.ReliefStyle.NONE)
            button.get_style_context().add_class("breadcrumb-button")
            button.set_size_request(-1, 22)
            button.connect("clicked", lambda _button, target=part: navigate(target))
            button.connect(
                "button-press-event",
                lambda widget, event, target=part: show_breadcrumb_menu(widget, event, target)
                if getattr(event, "button", 0) == 3
                else False,
            )
            button.connect("pressed", lambda widget: press_feedback(widget))
            button.connect("released", lambda widget: release_feedback(widget))
            breadcrumb_box.pack_start(button, False, False, 0)
            if index < len(parts) - 1:
                sep = Gtk.Label(label="›")
                sep.get_style_context().add_class("files-status-label")
                breadcrumb_box.pack_start(sep, False, False, 0)
        breadcrumb_box.show_all()

    def show_location_entry() -> bool:
        location_entry.set_text(str(current))
        breadcrumb_box.set_visible(False)
        location_entry.show()
        location_entry.grab_focus()
        location_entry.select_region(0, -1)
        for button in breadcrumb_box.get_children():
            button.get_style_context().add_class("path-editing")
        return True

    def hide_location_entry() -> bool:
        location_entry.hide()
        breadcrumb_box.set_visible(True)
        for button in breadcrumb_box.get_children():
            button.get_style_context().remove_class("path-editing")
        return True

    def commit_location_entry() -> bool:
        raw = location_entry.get_text().strip()
        hide_location_entry()
        if not raw:
            return True
        target = Path(raw).expanduser()
        if target.exists() and target.is_dir():
            navigate(target)
        else:
            set_status(f"Folder not found: {target}")
        return True

    def sort_entries(entries: list[Path]) -> list[Path]:
        mode = sort_mode

        def safe_stat(path: Path):
            try:
                return path.stat()
            except OSError:
                return None

        if mode == "modified":
            return sorted(entries, key=lambda p: (not p.is_dir(), -(safe_stat(p).st_mtime if safe_stat(p) else 0), p.name.casefold()))
        if mode == "size":
            return sorted(entries, key=lambda p: (not p.is_dir(), -(safe_stat(p).st_size if safe_stat(p) and p.is_file() else 0), p.name.casefold()))
        if mode == "kind":
            return sorted(entries, key=lambda p: (not p.is_dir(), p.suffix.casefold(), p.name.casefold()))
        return sorted(entries, key=lambda p: (not p.is_dir(), p.name.casefold()))

    def save_preferences():
        write_json(PREFS_CACHE, {"view_mode": view_mode, "sort_mode": sort_mode, "show_hidden": show_hidden})

    def recent_paths() -> list[Path]:
        data = load_json(RECENTS_CACHE, [])
        paths = []
        for item in data:
            path = Path(str(item))
            if path.exists() and path not in paths:
                paths.append(path)
        return paths[:80]

    def remember_recent(path: Path):
        if not path.exists():
            return
        paths = [str(path.resolve())]
        paths.extend(str(item.resolve()) for item in recent_paths() if item.resolve() != path.resolve())
        write_json(RECENTS_CACHE, paths[:80])

    def profile_roots() -> list[Path]:
        roots = [Path.home(), Path.home() / "Documents", Path.home() / "Downloads", Path.home() / "Projects"]
        profile_specific = {
            "baobab": [Path.home() / "Baobab", Path.home() / "Documents/Culture"],
            "forge": [Path.home() / "Projects", Path.home() / "Code", Path.home() / "Deployments", Path.home() / "Cloud"],
            "shield": [Path.home() / "Shield", Path.home() / "Security"],
            "studio": [Path.home() / "Pictures", Path.home() / "Videos", Path.home() / "Studio"],
            "pulse": [Path.home() / "Games", Path.home() / "Videos"],
            "windows": [Path.home() / "Downloads/windows", Path.home() / ".local/share/sevenos/windows"],
        }
        roots.extend(profile_specific.get(active_profile, []))
        unique: list[Path] = []
        for root_path in roots:
            if root_path.exists() and root_path not in unique:
                unique.append(root_path)
        return unique

    def fuzzy_match(query: str, text: str) -> bool:
        query = query.casefold().strip()
        text = text.casefold()
        if not query:
            return True
        if query in text:
            return True
        cursor = 0
        for char in query:
            cursor = text.find(char, cursor)
            if cursor < 0:
                return False
            cursor += 1
        return True

    def file_matches_query(path: Path, raw_query: str) -> bool:
        terms = [part.strip() for part in raw_query.casefold().split() if part.strip()]
        if not terms:
            return True
        haystack = f"{path.name} {path.suffix} {tag_for_path(path)}".casefold()
        try:
            stat = path.stat()
        except OSError:
            stat = None
        for term in terms:
            if term.startswith("type:"):
                kind = term.split(":", 1)[1]
                if kind in {"image", "photo"} and path.suffix.lower() not in IMAGE_SUFFIXES:
                    return False
                if kind in {"video", "movie"} and path.suffix.lower() not in VIDEO_SUFFIXES:
                    return False
                if kind in {"audio", "music"} and path.suffix.lower() not in AUDIO_SUFFIXES:
                    return False
                if kind in {"doc", "document", "pdf"} and path.suffix.lower() not in DOCUMENT_SUFFIXES | READER_SUFFIXES:
                    return False
                if kind in {"folder", "dir"} and not path.is_dir():
                    return False
                continue
            if term.startswith("tag:") and not fuzzy_match(term.split(":", 1)[1], tag_for_path(path)):
                return False
            if term.startswith("date:") and stat:
                value = term.split(":", 1)[1]
                age_days = (time.time() - stat.st_mtime) / 86400
                if value in {"today", "day"} and age_days > 1:
                    return False
                if value in {"week", "7d"} and age_days > 7:
                    return False
                if value in {"month", "30d"} and age_days > 31:
                    return False
                continue
            if term.startswith("size:") and stat:
                value = term.split(":", 1)[1]
                if value == "large" and stat.st_size < 50 * 1024 * 1024:
                    return False
                if value == "small" and stat.st_size > 1024 * 1024:
                    return False
                continue
            if not fuzzy_match(term, haystack):
                return False
        return True

    def ensure_index_db() -> sqlite3.Connection:
        GLOBAL_INDEX_DB.parent.mkdir(parents=True, exist_ok=True)
        conn = sqlite3.connect(GLOBAL_INDEX_DB)
        conn.execute(
            "create table if not exists files (path text primary key, name text, parent text, suffix text, kind text, mtime real, size integer)"
        )
        conn.execute("create index if not exists files_name_idx on files(name)")
        conn.execute("create index if not exists files_parent_idx on files(parent)")
        return conn

    def refresh_global_index(force: bool = False) -> int:
        try:
            if not force and GLOBAL_INDEX_DB.exists() and time.time() - GLOBAL_INDEX_DB.stat().st_mtime < 240:
                return 0
        except OSError:
            pass
        ignored = {".cache", ".local/share/Trash", ".git", "node_modules", "target", "__pycache__"}
        rows: list[tuple[str, str, str, str, str, float, int]] = []
        for root_path in profile_roots():
            try:
                iterator = root_path.rglob("*")
                for path in iterator:
                    if len(rows) >= INDEX_LIMIT:
                        break
                    if any(part in ignored for part in path.parts):
                        continue
                    try:
                        stat = path.stat()
                    except OSError:
                        continue
                    if path.is_dir() or path.suffix.lower() in PREVIEW_SUFFIXES or path.suffix:
                        rows.append(
                            (
                                str(path),
                                path.name,
                                path.parent.name,
                                path.suffix.lower(),
                                "folder" if path.is_dir() else "file",
                                stat.st_mtime,
                                stat.st_size if path.is_file() else 0,
                            )
                        )
            except OSError:
                continue
            if len(rows) >= INDEX_LIMIT:
                break
        with ensure_index_db() as conn:
            conn.execute("delete from files")
            conn.executemany("insert or replace into files values (?, ?, ?, ?, ?, ?, ?)", rows)
        write_json(GLOBAL_INDEX_CACHE, [row[0] for row in rows])
        return len(rows)

    def build_global_index() -> list[str]:
        try:
            refresh_global_index(False)
            with ensure_index_db() as conn:
                rows = conn.execute("select path from files order by mtime desc limit ?", (INDEX_LIMIT,)).fetchall()
            if rows:
                return [str(row[0]) for row in rows]
        except sqlite3.Error:
            pass
        data = load_json(GLOBAL_INDEX_CACHE, [])
        return [str(item) for item in data] if isinstance(data, list) else []

    def global_search(query: str) -> list[Path]:
        needle = query.strip().casefold()
        if not needle:
            return []
        try:
            refresh_global_index(False)
            like = f"%{needle}%"
            with ensure_index_db() as conn:
                rows = conn.execute(
                    "select path from files where lower(name) like ? or lower(parent) like ? or lower(suffix) like ? order by kind, name limit 180",
                    (like, like, like),
                ).fetchall()
            matches = [Path(str(row[0])) for row in rows if Path(str(row[0])).exists()]
            if matches:
                return matches
        except sqlite3.Error:
            pass
        matches: list[Path] = []
        for item in build_global_index():
            path = Path(item)
            haystack = f"{path.name} {path.parent.name} {path.suffix}"
            if fuzzy_match(query, haystack):
                matches.append(path)
            if len(matches) >= 120:
                break
        return matches

    def reindex_now():
        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, 2, "Refreshing search index")
            count = refresh_global_index(True)
            report(2, 2, "Search index ready")
            return count

        def done(count):
            if count == OPERATION_CANCELLED:
                finish_operation("Index refresh cancelled")
            else:
                finish_operation(f"Indexed {count} file item(s)")

        run_background("Refreshing search index", worker, done)

    def update_operation_queue(message: str = "") -> None:
        if message:
            operation_history.insert(0, message)
            del operation_history[4:]
        if operation_active or operation_history:
            operation_queue_label.set_text("  ·  ".join(operation_history[:3]) or operation_label.get_text())
            operation_queue.show()
        else:
            operation_queue.hide()

    def set_operation(message: str, active: bool = False):
        nonlocal operation_active, operation_cancel_requested
        operation_active = active
        operation_cancel_requested = False if active else operation_cancel_requested
        operation_label.set_text(message)
        operation_label.set_visible(True)
        operation_progress.set_visible(active)
        operation_cancel.set_visible(active)
        operation_progress.set_fraction(0.0)
        update_operation_queue(f"Running: {message}" if active else "")

    def finish_operation(message: str):
        nonlocal operation_cancel_requested
        render()
        set_status(message)
        operation_cancel_requested = False
        operation_progress.set_visible(False)
        operation_cancel.set_visible(False)
        set_operation(profile_title(active_profile, profile_ui), False)
        update_operation_queue(message)

    def cancel_operation():
        nonlocal operation_cancel_requested
        operation_cancel_requested = True
        operation_label.set_text(tr_text("Cancelling..."))

    operation_cancel.connect("clicked", lambda *_: cancel_operation())

    def operation_progress_update(done_count: int, total_count: int, label: str | None = None) -> bool:
        if total_count > 0:
            operation_progress.set_fraction(max(0.0, min(1.0, done_count / total_count)))
        if label:
            operation_label.set_text(label)
        return False

    def run_background(label: str, worker, done):
        set_operation(label, True)

        def task():
            try:
                def reporter(done_count: int, total_count: int, progress_label: str | None = None) -> None:
                    GLib.idle_add(operation_progress_update, done_count, total_count, progress_label)

                result = worker(lambda: operation_cancel_requested, reporter)
                GLib.idle_add(lambda: (done(result), False)[1])
            except Exception as exc:
                GLib.idle_add(lambda: (finish_operation(f"Failed: {exc}"), False)[1])

        threading.Thread(target=task, daemon=True).start()

    def refresh_view_buttons():
        for button, mode in ((grid_btn, "grid"), (list_btn, "list"), (compact_btn, "compact")):
            ctx = button.get_style_context()
            if view_mode == mode:
                ctx.add_class("active")
            else:
                ctx.remove_class("active")
        hidden_ctx = hidden_btn.get_style_context()
        if show_hidden:
            hidden_ctx.add_class("active")
        else:
            hidden_ctx.remove_class("active")

    def current_grid_columns() -> int:
        width = max(640, scroller.get_allocated_width() or window.get_size()[0] - 492)
        return max(3, min(7, int(width / 154)))

    def render_split() -> None:
        for child in split_flow.get_children():
            split_flow.remove(child)
        split_title.set_text(str(split_current))
        try:
            entries = sort_entries([path for path in split_current.iterdir() if show_hidden or not path.name.startswith(".")])
        except OSError:
            entries = []
        parent = split_current.parent if split_current.parent != split_current else split_current
        entries = [parent, *entries[:180]]
        for path in entries:
            child = Gtk.FlowBoxChild()
            child.path = path
            child.set_size_request(280, 40)
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            row.get_style_context().add_class("file-tile-box")
            icon = Gtk.Image.new_from_icon_name("go-up-symbolic" if path == parent and path != split_current else folder_icon(path), Gtk.IconSize.MENU)
            icon.set_pixel_size(22)
            label = Gtk.Label(label=".." if path == parent and path != split_current else path.name)
            label.set_xalign(0)
            label.set_single_line_mode(True)
            label.set_ellipsize(Pango.EllipsizeMode.END)
            label.get_style_context().add_class("file-name")
            row.pack_start(icon, False, False, 0)
            row.pack_start(label, True, True, 0)
            child.add(row)
            split_flow.add(child)
        split_flow.show_all()

    def navigate_split(path: Path) -> None:
        nonlocal split_current
        if path.exists() and path.is_dir():
            split_current = path
            render_split()

    def open_path_in_split(path: Path) -> bool:
        nonlocal split_current, split_visible
        target = path if path.is_dir() else path.parent
        split_current = target
        if not split_visible:
            split_visible = True
            split_box.show()
            split_btn.get_style_context().add_class("active")
        render_split()
        return True

    def toggle_split_view(force: bool | None = None) -> bool:
        nonlocal split_visible, split_current
        split_visible = (not split_visible) if force is None else bool(force)
        if split_visible:
            split_current = current
            split_box.show()
            split_btn.get_style_context().add_class("active")
            render_split()
        else:
            split_box.hide()
            split_btn.get_style_context().remove_class("active")
        return True

    def schedule_hover_preview(widget, child, path: Path) -> bool:
        if hover_preview_state["id"]:
            GLib.source_remove(hover_preview_state["id"])
            hover_preview_state["id"] = 0
        child.get_style_context().add_class("hover-preview")

        def apply_preview() -> bool:
            hover_preview_state["id"] = 0
            if not flow.get_selected_children() and not rubberband_rect["active"]:
                update_preview(path)
            return False

        hover_preview_state["id"] = GLib.timeout_add(HOVER_PREVIEW_DELAY_MS, apply_preview)
        return False

    def cancel_hover_preview(_widget, child) -> bool:
        if hover_preview_state["id"]:
            GLib.source_remove(hover_preview_state["id"])
            hover_preview_state["id"] = 0
        child.get_style_context().remove_class("hover-preview")
        return False

    def render():
        previous_size = window.get_size()
        focused_entry = window.get_focus() if isinstance(window.get_focus(), Gtk.Entry) else None
        focused_position = focused_entry.get_position() if focused_entry else -1
        sync_current_tab()
        update_breadcrumbs()
        render_tabs()
        for child in flow.get_children():
            flow.remove(child)
        global_query = search_query.startswith("/")
        tag_query = search_query.startswith("#")
        if global_query:
            entries = global_search(search_query[1:].strip())
        elif tag_query:
            tag_name = search_query[1:].strip().casefold()
            tags = load_tags()
            entries = [Path(path) for path, tag in tags.items() if fuzzy_match(tag_name, tag)]
        else:
            try:
                entries = recent_paths() if virtual_location == "recent" else list(current.iterdir())
            except OSError:
                entries = []
            if not show_hidden:
                entries = [path for path in entries if not path.name.startswith(".")]
            if search_query:
                entries = [path for path in entries if file_matches_query(path, search_query)]
        entries = sort_entries(entries)
        total_entries = len(entries)
        limited_entries = entries[:RENDER_LIMIT]
        if view_mode == "grid":
            columns = current_grid_columns()
            flow.set_min_children_per_line(columns)
            flow.set_max_children_per_line(columns)
            flow.set_column_spacing(22)
            flow.set_row_spacing(30)
            flow.set_homogeneous(True)
        elif view_mode == "list":
            flow.set_min_children_per_line(1)
            flow.set_max_children_per_line(1)
            flow.set_column_spacing(0)
            flow.set_row_spacing(4)
            flow.set_homogeneous(False)
        else:
            flow.set_min_children_per_line(2)
            flow.set_max_children_per_line(2)
            flow.set_column_spacing(8)
            flow.set_row_spacing(4)
            flow.set_homogeneous(False)
        render_queue = list(limited_entries)

        def add_empty_state() -> None:
            child = Gtk.FlowBoxChild()
            child.set_selectable(False)
            child.set_can_focus(False)
            child.path = current
            child.set_size_request(420, 190)
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            box.set_halign(Gtk.Align.CENTER)
            box.set_valign(Gtk.Align.CENTER)
            box.get_style_context().add_class("empty-state")
            icon = Gtk.Image.new_from_icon_name("edit-find-symbolic" if search_query else "folder-symbolic", Gtk.IconSize.DIALOG)
            icon.set_pixel_size(42)
            title = Gtk.Label(label="No matching files" if search_query else "This folder is empty")
            title.get_style_context().add_class("empty-title")
            hint_text = "Try another search or remove filters." if search_query else "Drop files here, paste items, or create a new folder."
            hint = Gtk.Label(label=hint_text)
            hint.get_style_context().add_class("preview-hint")
            box.pack_start(icon, False, False, 0)
            box.pack_start(title, False, False, 0)
            box.pack_start(hint, False, False, 0)
            child.add(box)
            flow.add(child)

        def add_entry(path: Path) -> None:
            child = Gtk.FlowBoxChild()
            child.set_can_focus(True)
            child.get_style_context().add_class("file-tile")
            if view_mode == "list":
                child.get_style_context().add_class("list-view")
                child.set_size_request(560, 48)
            elif view_mode == "compact":
                child.get_style_context().add_class("compact-view")
                child.set_size_request(250, 40)
            else:
                child.set_size_request(120, 124)
            child.path = path
            tile_event = Gtk.EventBox()
            tile_event.set_visible_window(False)
            tile_event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
            tile_event.file_child = child
            tile_event.file_path = path
            tile_event.spring_target = path if path.is_dir() else None
            orientation = Gtk.Orientation.VERTICAL if view_mode == "grid" else Gtk.Orientation.HORIZONTAL
            box = Gtk.Box(orientation=orientation, spacing=10)
            box.set_halign(Gtk.Align.FILL if view_mode != "grid" else Gtk.Align.CENTER)
            box.set_valign(Gtk.Align.CENTER)
            if view_mode == "list":
                box.set_size_request(560, 48)
            elif view_mode == "compact":
                box.set_size_request(250, 40)
            else:
                box.set_size_request(120, 124)
            box.get_style_context().add_class("file-tile-box")
            image = Gtk.Image.new_from_icon_name(folder_icon(path), Gtk.IconSize.DIALOG)
            image.set_pixel_size(68 if view_mode == "grid" else 26)
            label = Gtk.Label(label=path.name)
            label.set_xalign(0 if view_mode != "grid" else 0.5)
            label.set_width_chars(13 if view_mode == "grid" else 34)
            label.set_max_width_chars(13 if view_mode == "grid" else 34)
            label.set_line_wrap(False)
            label.set_single_line_mode(True)
            label.set_ellipsize(Pango.EllipsizeMode.END)
            label.set_justify(Gtk.Justification.CENTER if view_mode == "grid" else Gtk.Justification.LEFT)
            label.get_style_context().add_class("file-name")
            box.pack_start(image, False, False, 0)
            if view_mode == "grid":
                box.pack_start(label, False, False, 0)
                tag = tag_for_path(path)
                if tag:
                    tag_label = Gtk.Label(label=tag)
                    tag_label.get_style_context().add_class("tag-pill")
                    tag_label.get_style_context().add_class(f"tag-{tag.casefold()}")
                    box.pack_start(tag_label, False, False, 0)
            else:
                text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
                text_box.pack_start(label, False, False, 0)
                meta = Gtk.Label(label=file_row_meta(path))
                meta.set_xalign(0)
                meta.set_single_line_mode(True)
                meta.set_ellipsize(Pango.EllipsizeMode.END)
                meta.get_style_context().add_class("file-meta")
                if view_mode == "list":
                    text_box.pack_start(meta, False, False, 0)
                tag = tag_for_path(path)
                if tag:
                    tag_label = Gtk.Label(label=tag)
                    tag_label.set_xalign(0)
                    tag_label.get_style_context().add_class("tag-pill")
                    tag_label.get_style_context().add_class(f"tag-{tag.casefold()}")
                    text_box.pack_start(tag_label, False, False, 0)
                box.pack_start(text_box, True, True, 0)
            tile_event.add(box)
            setup_file_tile_dnd(tile_event, child, path)
            tile_event.connect("button-press-event", lambda _widget, event, tile=child, item=path: on_tile_button(event, tile, item))
            tile_event.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK)
            tile_event.connect("enter-notify-event", lambda widget, _event, tile=child, item=path: schedule_hover_preview(widget, tile, item))
            tile_event.connect("leave-notify-event", lambda widget, _event, tile=child: cancel_hover_preview(widget, tile))
            child.add(tile_event)
            flow.add(child)

        def render_chunk() -> bool:
            if not render_queue and not limited_entries:
                add_empty_state()
                flow.show_all()
                return False
            for _index in range(min(RENDER_CHUNK_SIZE, len(render_queue))):
                add_entry(render_queue.pop(0))
            flow.show_all()
            return bool(render_queue)

        render_chunk()
        selected_count = len(flow.get_selected_children())
        mode_label = theme_mode.title()
        location = "Recents" if virtual_location == "recent" else str(current)
        scope = "Global" if global_query else "Tags" if tag_query else "Local"
        status_label.set_text(
            f"{len(limited_entries)} of {total_entries} item(s)  |  {scope} · {mode_label} · {profile_title(active_profile, profile_ui)}  |  Click selects · Double-click opens"
            if not selected_count
            else f"{selected_count} selected  |  {location}"
        )
        if not operation_active:
            operation_label.set_text(profile_title(active_profile, profile_ui))
        update_sidebar()
        refresh_view_buttons()
        if split_visible:
            render_split()
        if virtual_location == "recent":
            update_preview_multiple(entries)
        else:
            update_preview(current)
        if render_queue:
            GLib.idle_add(render_chunk)
        if focused_entry:
            focused_entry.grab_focus()
            focused_entry.set_position(focused_position)
        else:
            flow.grab_focus()
        if previous_size != (1, 1):
            GLib.idle_add(lambda: restore_window_size(previous_size))

    def restore_window_size(size: tuple[int, int]) -> bool:
        width, height = size
        if width > 0 and height > 0:
            window.resize(width, height)
        return False

    def file_row_meta(path: Path) -> str:
        try:
            stat = path.stat()
            modified = time.strftime("%b %d, %H:%M", time.localtime(stat.st_mtime))
            if path.is_dir():
                try:
                    size = f"{len(list(path.iterdir()))} items"
                except OSError:
                    size = "Folder"
            else:
                size = format_size(stat.st_size)
            kind = "Folder" if path.is_dir() else (path.suffix.upper().lstrip(".") or "File")
            return f"{kind}  |  {size}  |  {modified}"
        except OSError:
            return "Unavailable"

    def detail_row(label: str, value: str):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        card.get_style_context().add_class("inspector-card")
        heading = Gtk.Label(label=label)
        heading.set_xalign(0)
        heading.get_style_context().add_class("preview-heading")
        value_label = Gtk.Label(label=value)
        value_label.set_xalign(0)
        value_label.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        value_label.set_single_line_mode(True)
        value_label.set_max_width_chars(24)
        value_label.get_style_context().add_class("preview-value")
        card.pack_start(heading, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        preview_details.pack_start(card, False, False, 0)

    def preview_action(label: str, callback):
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("preview-action")
        button.connect("clicked", lambda *_: callback())
        button.connect("pressed", lambda widget: press_feedback(widget))
        button.connect("released", lambda widget: release_feedback(widget))
        preview_details.pack_start(button, False, False, 4)

    def preview_hint(text: str):
        label = Gtk.Label(label=text)
        label.set_xalign(0)
        label.set_line_wrap(True)
        label.set_max_width_chars(28)
        label.get_style_context().add_class("preview-hint")
        preview_details.pack_start(label, False, False, 0)

    def read_text_preview(path: Path, limit: int = 6000) -> str:
        data = path.read_bytes()[:limit]
        return data.decode("utf-8", errors="replace")

    def read_docx_preview(path: Path, limit: int = 6000) -> str:
        with zipfile.ZipFile(path) as document:
            xml = document.read("word/document.xml")
        root = ET.fromstring(xml)
        namespace = "{http://schemas.openxmlformats.org/wordprocessingml/2006/main}"
        parts = [node.text or "" for node in root.iter(f"{namespace}t")]
        text = " ".join(part.strip() for part in parts if part.strip())
        return html.unescape(text[:limit])

    def thumbnail_cache_path(path: Path, prefix: str) -> Path:
        try:
            stat = path.stat()
            key = hashlib.sha256(f"{path.resolve()}:{stat.st_mtime_ns}:{stat.st_size}".encode("utf-8")).hexdigest()[:24]
        except OSError:
            key = hashlib.sha256(str(path).encode("utf-8")).hexdigest()[:24]
        THUMB_CACHE.mkdir(parents=True, exist_ok=True)
        return THUMB_CACHE / f"{prefix}-{key}.png"

    def video_thumbnail(path: Path) -> GdkPixbuf.Pixbuf | None:
        thumb = thumbnail_cache_path(path, "video")
        if thumb.exists():
            try:
                return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), 210, 150, True)
            except Exception:
                thumb.unlink(missing_ok=True)
        if shutil.which("ffmpegthumbnailer"):
            command = ["ffmpegthumbnailer", "-i", str(path), "-o", str(thumb), "-s", "420", "-q", "8"]
        elif shutil.which("ffmpeg"):
            command = [
                "ffmpeg", "-y", "-ss", "00:00:01", "-i", str(path),
                "-frames:v", "1", "-vf", "scale=420:-1", str(thumb),
            ]
        else:
            return None
        result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode != 0 or not thumb.exists():
            return None
        return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(thumb), 210, 150, True)

    def pdf_thumbnail(path: Path, render_width: int = 760, max_width: int = 210, max_height: int = 150) -> GdkPixbuf.Pixbuf | None:
        if not shutil.which("pdftoppm"):
            return None
        output_file = thumbnail_cache_path(path, f"pdf-{render_width}")
        if output_file.exists():
            try:
                return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(output_file), max_width, max_height, True)
            except Exception:
                output_file.unlink(missing_ok=True)
        output_prefix = output_file.with_suffix("")
        output_file = Path(f"{output_prefix}.png")
        result = subprocess.run(
            ["pdftoppm", "-f", "1", "-singlefile", "-png", "-scale-to", str(render_width), str(path), str(output_prefix)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode != 0 or not output_file.exists():
            return None
        return GdkPixbuf.Pixbuf.new_from_file_at_scale(str(output_file), max_width, max_height, True)

    def update_preview(path: Path | None):
        for child in preview_details.get_children():
            preview_details.remove(child)
        target = path or current
        if is_image(target):
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(target), 210, 150, True)
                preview_icon.set_from_pixbuf(pixbuf)
            except Exception:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint("Space previews this image. Double-click opens Seven Quick Look.")
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            preview_action("Open externally", lambda target=target: open_externally(target))
        elif is_video(target):
            pixbuf = video_thumbnail(target)
            if pixbuf:
                preview_icon.set_from_pixbuf(pixbuf)
            else:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint("Space opens video preview. External player remains available from preview.")
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            preview_action("Open externally", lambda target=target: open_externally(target))
        elif is_audio(target):
            preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
            preview_icon.set_pixel_size(88)
            preview_hint("Space opens audio preview. External player remains available from preview.")
            preview_action("Open externally", lambda target=target: open_externally(target))
        elif target.is_file() and target.suffix.lower() == ".pdf":
            pixbuf = pdf_thumbnail(target)
            if pixbuf:
                preview_icon.set_from_pixbuf(pixbuf)
            else:
                preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
                preview_icon.set_pixel_size(88)
            preview_hint("Open this document in Seven Reader for book, double-page and inspect modes.")
            preview_action("Read in Seven Reader", lambda target=target: open_in_reader(target))
            preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
        else:
            preview_icon.set_from_icon_name(folder_icon(target), Gtk.IconSize.DIALOG)
            preview_icon.set_pixel_size(88)
            if target.is_file() and target.suffix.lower() in READER_SUFFIXES:
                preview_hint("Open this document in Seven Reader for immersive reading.")
                preview_action("Read in Seven Reader", lambda target=target: open_in_reader(target))
                preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
            elif target.is_file() and target.suffix.lower() in TEXT_SUFFIXES | DOCUMENT_SUFFIXES:
                preview_hint("Space opens document preview.")
                preview_action("Quick Look", lambda target=target: open_quicklook_preview(target))
                preview_action("Open externally", lambda target=target: open_externally(target))
            elif target.is_dir():
                preview_action("Open", lambda target=target: navigate(target))
        preview_title.set_text(target.name or str(target))
        preview_subtitle.set_text("Folder" if target.is_dir() else (target.suffix.upper().lstrip(".") or "File"))
        try:
            stat = target.stat()
            detail_row("Location", str(target.parent if target != current else target))
            detail_row("Modified", time.strftime("%b %d, %Y %H:%M", time.localtime(stat.st_mtime)))
            if target.is_file():
                detail_row("Size", format_size(stat.st_size))
            elif target.is_dir():
                try:
                    count = len(list(target.iterdir()))
                except OSError:
                    count = 0
                detail_row("Items", f"{count}")
            tag = tag_for_path(target)
            if tag:
                detail_row("Tag", tag)
            if target.is_file():
                if is_risky_file(target):
                    detail_row("Security", "Review before opening")
                    preview_action("Safe Open", lambda target=target: safe_open_path(target))
                preview_action("Copy SHA256", hash_selected)
                preview_action("Ask SevenAI", sevenai_selected)
        except OSError:
            detail_row("Status", "Unavailable")
        preview_details.show_all()

    def update_preview_multiple(paths: list[Path]):
        for child in preview_details.get_children():
            preview_details.remove(child)
        preview_icon.set_from_icon_name("edit-select-all", Gtk.IconSize.DIALOG)
        preview_icon.set_pixel_size(88)
        preview_title.set_text(f"{len(paths)} selected")
        files = [path for path in paths if path.is_file()]
        folders = [path for path in paths if path.is_dir()]
        preview_subtitle.set_text("Selection")
        total = 0
        for path in files:
            try:
                total += path.stat().st_size
            except OSError:
                pass
        detail_row("Files", str(len(files)))
        detail_row("Folders", str(len(folders)))
        detail_row("Total size", format_size(total))
        preview_hint("Use Copy, Compress, Tags or SevenAI actions on the selected items.")
        preview_details.show_all()

    def preview_text_view(text: str) -> Gtk.ScrolledWindow:
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        text_view = Gtk.TextView()
        text_view.set_editable(False)
        text_view.set_cursor_visible(False)
        text_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        text_view.get_style_context().add_class("quicklook-text")
        text_view.get_buffer().set_text(text)
        scroller.add(text_view)
        return scroller

    def preview_message(icon_name: str, title_text: str, body: str) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        box.set_margin_top(32)
        box.set_margin_bottom(32)
        box.set_margin_start(32)
        box.set_margin_end(32)
        icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        icon.set_pixel_size(96)
        label = Gtk.Label(label=title_text)
        label.get_style_context().add_class("preview-title")
        body_label = Gtk.Label(label=body)
        body_label.set_line_wrap(True)
        body_label.set_max_width_chars(54)
        body_label.set_justify(Gtk.Justification.CENTER)
        body_label.get_style_context().add_class("preview-value")
        box.pack_start(icon, False, False, 0)
        box.pack_start(label, False, False, 0)
        box.pack_start(body_label, False, False, 0)
        return box

    def inline_media_player(path: Path, video: bool):
        if Gst is None:
            return None
        playbin = Gst.ElementFactory.make("playbin", None)
        if playbin is None:
            return None
        media_widget = None
        if video:
            sink = Gst.ElementFactory.make("gtksink", None)
            if sink is None:
                sink = Gst.ElementFactory.make("gtkglsink", None)
            if sink is None:
                return None
            playbin.set_property("video-sink", sink)
            try:
                media_widget = sink.get_property("widget")
            except Exception:
                return None
        else:
            media_widget = preview_message("audio-x-generic", path.name, "Audio playback is inline. Use the controls below.")
        playbin.set_property("uri", file_uri(path))

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("media-inline")
        box.set_hexpand(True)
        box.set_vexpand(True)
        box.pack_start(media_widget, True, True, 0)

        controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        controls.set_margin_top(8)
        controls.set_margin_bottom(10)
        controls.set_margin_start(12)
        controls.set_margin_end(12)
        play_button = Gtk.Button(label=tr_text("Play"))
        play_button.get_style_context().add_class("media-control")
        stop_button = Gtk.Button(label=tr_text("Stop"))
        stop_button.get_style_context().add_class("media-control")
        seek = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
        seek.set_draw_value(False)
        seek.set_hexpand(True)
        position_label = Gtk.Label(label="00:00")
        controls.pack_start(play_button, False, False, 0)
        controls.pack_start(stop_button, False, False, 0)
        controls.pack_start(seek, True, True, 0)
        controls.pack_start(position_label, False, False, 0)
        box.pack_start(controls, False, False, 0)

        state = {"playing": False, "seeking": False, "updating": False, "timer": 0}

        def format_time(nanoseconds: int) -> str:
            seconds = max(0, int(nanoseconds / 1_000_000_000))
            return f"{seconds // 60:02d}:{seconds % 60:02d}"

        def toggle_play(*_args):
            state["playing"] = not state["playing"]
            playbin.set_state(Gst.State.PLAYING if state["playing"] else Gst.State.PAUSED)
            play_button.set_label(tr_text("Pause") if state["playing"] else tr_text("Play"))

        def stop_media(*_args):
            state["playing"] = False
            play_button.set_label(tr_text("Play"))
            playbin.set_state(Gst.State.NULL)
            seek.set_value(0)
            position_label.set_text("00:00")

        def update_position() -> bool:
            try:
                ok_pos, position = playbin.query_position(Gst.Format.TIME)
                ok_duration, duration = playbin.query_duration(Gst.Format.TIME)
            except Exception:
                return True
            if ok_pos and ok_duration and duration > 0 and not state["seeking"]:
                state["updating"] = True
                seek.set_value(min(100, max(0, position * 100 / duration)))
                state["updating"] = False
                position_label.set_text(format_time(position))
            return True

        def on_seek(_scale):
            if state["seeking"] or state["updating"]:
                return
            try:
                ok_duration, duration = playbin.query_duration(Gst.Format.TIME)
                if ok_duration and duration > 0:
                    target = int(duration * seek.get_value() / 100)
                    playbin.seek_simple(Gst.Format.TIME, Gst.SeekFlags.FLUSH | Gst.SeekFlags.KEY_UNIT, target)
            except Exception:
                pass

        play_button.connect("clicked", toggle_play)
        stop_button.connect("clicked", stop_media)
        seek.connect("button-press-event", lambda *_: state.update({"seeking": True}) or False)
        seek.connect("button-release-event", lambda *_: (state.update({"seeking": False}), on_seek(seek), False)[2])
        seek.connect("value-changed", on_seek)
        state["timer"] = GLib.timeout_add(350, update_position)

        def cleanup_media(*_args):
            if state["timer"]:
                GLib.source_remove(state["timer"])
                state["timer"] = 0
            playbin.set_state(Gst.State.NULL)

        return box, playbin, cleanup_media

    def open_quicklook_preview(path: Path):
        preview_window = Gtk.Window(title=path.name)
        preview_window.set_default_size(880, 620)
        preview_window.set_size_request(520, 360)
        preview_window.set_resizable(True)
        preview_window.set_position(Gtk.WindowPosition.CENTER)
        preview_window.set_wmclass("SevenQuickLook", "SevenQuickLook")
        preview_window.get_style_context().add_class("quicklook-window")

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        preview_window.add(outer)

        header = Gtk.HeaderBar(title=path.name)
        header.set_show_close_button(True)
        preview_window.set_titlebar(header)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        content.set_hexpand(True)
        content.set_vexpand(True)
        suffix = path.suffix.lower()

        if is_image(path):
            image_scroller = Gtk.ScrolledWindow()
            image_scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), 1280, 860, True)
                image = Gtk.Image.new_from_pixbuf(pixbuf)
            except Exception:
                image = Gtk.Image.new_from_icon_name("image-x-generic", Gtk.IconSize.DIALOG)
                image.set_pixel_size(128)
            image.set_margin_top(18)
            image.set_margin_bottom(18)
            image.set_margin_start(18)
            image.set_margin_end(18)
            image_scroller.add_with_viewport(image)
            content.pack_start(image_scroller, True, True, 0)
        elif suffix in TEXT_SUFFIXES:
            try:
                content.pack_start(preview_text_view(read_text_preview(path)), True, True, 0)
            except OSError as exc:
                content.pack_start(preview_message("text-x-generic", "Preview unavailable", str(exc)), True, True, 0)
        elif suffix == ".docx":
            try:
                content.pack_start(preview_text_view(read_docx_preview(path)), True, True, 0)
            except Exception as exc:
                content.pack_start(preview_message("x-office-document", "DOCX preview unavailable", str(exc)), True, True, 0)
        elif suffix == ".pdf":
            pixbuf = pdf_thumbnail(path, 1200, 760, 900)
            if pixbuf:
                image = Gtk.Image.new_from_pixbuf(pixbuf)
                image.set_halign(Gtk.Align.CENTER)
                image.set_valign(Gtk.Align.CENTER)
                content.pack_start(image, True, True, 0)
            else:
                content.pack_start(
                    preview_message(
                        "application-pdf",
                        "PDF document",
                        "Install poppler to render the first page inline, or open this file externally now.",
                    ),
                    True,
                    True,
                    0,
                )
        elif is_video(path):
            media = inline_media_player(path, video=True)
            if media:
                player, _playbin, cleanup = media
                content.pack_start(player, True, True, 0)
                preview_window.connect("destroy", cleanup)
            else:
                pixbuf = video_thumbnail(path)
                if pixbuf:
                    image = Gtk.Image.new_from_pixbuf(pixbuf)
                    image.set_halign(Gtk.Align.CENTER)
                    image.set_valign(Gtk.Align.CENTER)
                    content.pack_start(image, True, True, 0)
                else:
                    content.pack_start(
                        preview_message(
                            "video-x-generic",
                            "Video preview",
                            "Install GStreamer gtksink for inline playback, or use Open externally.",
                        ),
                        True,
                        True,
                        0,
                    )
        elif is_audio(path):
            media = inline_media_player(path, video=False)
            if media:
                player, _playbin, cleanup = media
                content.pack_start(player, True, True, 0)
                preview_window.connect("destroy", cleanup)
            else:
                content.pack_start(
                    preview_message(
                        "audio-x-generic",
                        "Audio file",
                        "Install GStreamer for inline playback, or use Open externally.",
                    ),
                    True,
                    True,
                    0,
                )
        else:
            content.pack_start(preview_message(folder_icon(path), "Preview", "No inline preview is available for this file type yet."), True, True, 0)

        outer.pack_start(content, True, True, 0)

        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        footer.get_style_context().add_class("quicklook-footer")
        footer.set_margin_top(8)
        footer.set_margin_bottom(10)
        footer.set_margin_start(14)
        footer.set_margin_end(14)
        open_button = Gtk.Button(label=tr_text("Open externally"))
        open_button.connect("clicked", lambda *_: open_externally(path))
        footer.pack_start(open_button, False, False, 0)
        if path.suffix.lower() in READER_SUFFIXES:
            reader_button = Gtk.Button(label=tr_text("Read in Seven Reader"))
            reader_button.connect("clicked", lambda *_: open_in_reader(path))
            footer.pack_start(reader_button, False, False, 0)
        if is_image(path):
            wallpaper_button = Gtk.Button(label=tr_text("Set as Wallpaper"))
            wallpaper_button.connect("clicked", lambda *_: set_wallpaper_from_file(path))
            footer.pack_end(wallpaper_button, False, False, 0)
        outer.pack_start(footer, False, False, 0)

        preview_window.show_all()

    def open_in_reader(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-reader").exists():
            command = [str(root / "bin/seven-reader"), "open", str(path)]
        elif shutil.which("seven-reader"):
            command = ["seven-reader", "open", str(path)]
        elif shutil.which("seven"):
            command = ["seven", "reader", str(path)]
        if command:
            log = Path("/tmp/sevenos-reader.log")
            with log.open("ab") as handle:
                subprocess.Popen(command, stdout=handle, stderr=handle, start_new_session=True)
            status_label.set_text(f"Opening {path.name} in Seven Reader")
        else:
            open_quicklook_preview(path)

    def open_file(path: Path):
        remember_recent(path)
        if is_risky_file(path) and active_profile in {"shield", "baobab"}:
            status_label.set_text("Risky file detected. Use Safe Open or context menu to continue.")
            update_preview(path)
            return
        if path.suffix.lower() in READER_SUFFIXES:
            open_in_reader(path)
            return
        if is_previewable(path):
            open_quicklook_preview(path)
        else:
            xdg_open(path)

    def safe_open_path(path: Path):
        remember_recent(path)
        if shutil.which("firejail"):
            subprocess.Popen(["firejail", "--quiet", "--private", "xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        elif shutil.which("bwrap"):
            subprocess.Popen(
                ["bwrap", "--ro-bind", "/", "/", "--dev", "/dev", "--proc", "/proc", "xdg-open", str(path)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        else:
            xdg_open(path)
        status_label.set_text(f"Safe Open requested for {path.name}")

    def hash_selected():
        target = selected_path()
        if not target or not target.is_file():
            status_label.set_text("Select a file to hash")
            return

        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, 2, "Hashing file")
            digest = file_hash(target)
            report(2, 2, "Hash ready")
            return digest

        def done(digest):
            if digest == OPERATION_CANCELLED:
                finish_operation("Hash cancelled")
                return
            copy_path_text = f"sha256  {digest}  {target}"
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(copy_path_text, -1)
            finish_operation("SHA256 copied to clipboard")

        run_background("Hashing file", worker, done)

    def open_externally(path: Path):
        if not is_image(path):
            xdg_open(path)
            return
        for command in ("loupe", "eog", "swayimg", "imv", "feh"):
            if shutil.which(command):
                subprocess.Popen([command, str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return
        xdg_open(path)

    def set_wallpaper_from_file(path: Path):
        root = resolve_root()
        command: list[str] | None = None
        if root and (root / "bin/seven-wallpaper").exists():
            command = [str(root / "bin/seven-wallpaper"), "set", str(path)]
        else:
            command = ["seven-wallpaper", "set", str(path)]
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def copy_path(path: Path):
        Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(str(path), -1)

    def clipboard_file_payload(paths: list[Path], cut: bool = False) -> str:
        action = "cut" if cut else "copy"
        uris = [path.resolve().as_uri() for path in paths if path.exists()]
        return "\n".join([action, *uris]) + "\n"

    def clipboard_uri_list(paths: list[Path]) -> str:
        return "\n".join(path.resolve().as_uri() for path in paths if path.exists()) + "\n"

    def write_clipboard_cache(paths: list[Path], cut: bool = False):
        CLIPBOARD_CACHE.parent.mkdir(parents=True, exist_ok=True)
        CLIPBOARD_CACHE.write_text(
            json.dumps(
                {
                    "action": "cut" if cut else "copy",
                    "paths": [str(path.resolve()) for path in paths if path.exists()],
                    "time": time.time(),
                }
            ),
            encoding="utf-8",
        )

    def paths_from_uri_payload(payload: str) -> tuple[list[Path], bool]:
        lines = [line.strip() for line in payload.splitlines() if line.strip() and not line.startswith("#")]
        cut = False
        if lines and lines[0] in {"copy", "cut"}:
            cut = lines[0] == "cut"
            lines = lines[1:]
        paths: list[Path] = []
        for line in lines:
            if line.startswith("file://"):
                paths.append(Path(GLib.filename_from_uri(line)[0]))
            else:
                paths.append(Path(line))
        return [path for path in paths if path.exists()], cut

    def publish_file_clipboard(paths: list[Path], cut: bool = False):
        valid = [path for path in paths if path.exists()]
        if not valid:
            return
        uri_list = clipboard_uri_list(valid)
        write_clipboard_cache(valid, cut)
        if shutil.which("wl-copy") and os.environ.get("WAYLAND_DISPLAY"):
            subprocess.run(["wl-copy", "--type", "text/uri-list"], input=uri_list, text=True, check=False)
        elif shutil.which("xclip") and os.environ.get("DISPLAY"):
            subprocess.run(["xclip", "-selection", "clipboard", "-t", "text/uri-list"], input=uri_list, text=True, check=False)
        else:
            Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(uri_list, -1)

    def read_system_file_clipboard() -> tuple[list[Path], bool]:
        commands: list[list[str]] = []
        if shutil.which("wl-paste") and os.environ.get("WAYLAND_DISPLAY"):
            commands.extend([
                ["wl-paste", "--no-newline", "--type", "x-special/gnome-copied-files"],
                ["wl-paste", "--no-newline", "--type", "text/uri-list"],
            ])
        if shutil.which("xclip") and os.environ.get("DISPLAY"):
            commands.append(["xclip", "-selection", "clipboard", "-o", "-t", "x-special/gnome-copied-files"])
        for command in commands:
            result = subprocess.run(command, text=True, capture_output=True, check=False)
            if result.returncode == 0 and result.stdout.strip():
                paths, cut = paths_from_uri_payload(result.stdout)
                if paths:
                    return paths, cut
        if CLIPBOARD_CACHE.exists():
            try:
                data = json.loads(CLIPBOARD_CACHE.read_text(encoding="utf-8"))
                paths = [Path(path) for path in data.get("paths", [])]
                paths = [path for path in paths if path.exists()]
                if paths:
                    return paths, data.get("action") == "cut"
            except (OSError, json.JSONDecodeError):
                pass
        return [], False

    def selected_path() -> Path | None:
        selected = flow.get_selected_children()
        if not selected:
            return None
        return selected[0].path

    def selected_paths() -> list[Path]:
        return [child.path for child in flow.get_selected_children()]

    def copy_items(paths: list[Path], cut: bool = False):
        nonlocal file_clipboard, file_clipboard_cut
        file_clipboard = [path for path in paths if path.exists()]
        file_clipboard_cut = cut
        if file_clipboard:
            publish_file_clipboard(file_clipboard, cut)
            status_label.set_text(f"{'Cut' if cut else 'Copied'} {len(file_clipboard)} file item(s)")

    def copy_selected():
        paths = selected_paths()
        if paths:
            copy_items(paths)

    def cut_selected():
        paths = selected_paths()
        if paths:
            copy_items(paths, cut=True)

    def unique_destination(directory: Path, name: str) -> Path:
        destination = directory / name
        if not destination.exists():
            return destination
        stem = destination.stem
        suffix = destination.suffix
        for index in range(2, 1000):
            candidate = directory / f"{stem} copy {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{stem} copy{suffix}"

    def ask_conflict_policy(title_text: str, conflict_count: int) -> str:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("Skip", 10)
        dialog.add_button("Replace", 20)
        dialog.add_button("Keep Both", 30)
        dialog.set_default_response(30)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(16)
        content.set_margin_end(16)
        label = Gtk.Label(label=f"{conflict_count} item(s) already exist at the destination.")
        label.set_xalign(0)
        hint = Gtk.Label(label="Choose how Seven Files should handle name conflicts for this operation.")
        hint.set_xalign(0)
        hint.get_style_context().add_class("preview-hint")
        content.pack_start(label, False, False, 0)
        content.pack_start(hint, False, False, 6)
        dialog.show_all()
        response = dialog.run()
        dialog.destroy()
        if response == 20:
            return "replace"
        if response == 10:
            return "skip"
        if response == 30:
            return "keep_both"
        return "cancel"

    def conflict_policy_for(sources: list[Path], destination_dir: Path) -> str:
        conflicts = [source for source in sources if (destination_dir / source.name).exists()]
        if not conflicts:
            return "direct"
        return ask_conflict_policy("File Conflict", len(conflicts))

    def destination_for_policy(source: Path, destination_dir: Path, policy: str) -> Path | None:
        destination = destination_dir / source.name
        if not destination.exists():
            return destination
        if policy == "skip":
            return None
        if policy == "replace":
            try:
                if destination.is_dir():
                    shutil.rmtree(destination)
                else:
                    destination.unlink()
                return destination
            except OSError:
                return None
        return unique_destination(destination_dir, source.name)

    def paste_items():
        nonlocal file_clipboard, file_clipboard_cut
        if not file_clipboard:
            file_clipboard, file_clipboard_cut = read_system_file_clipboard()
            if not file_clipboard:
                status_label.set_text("Nothing to paste")
                return
        sources = list(file_clipboard)
        cut_mode = file_clipboard_cut
        destination_dir = current
        conflict_policy = conflict_policy_for(sources, destination_dir)
        if conflict_policy == "cancel":
            set_status("Paste cancelled")
            return

        def worker(cancelled, report):
            pasted = 0
            total = len(sources)
            for index, source in enumerate(sources, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                if not source.exists():
                    report(index, total, f"Skipping missing item {index}/{total}")
                    continue
                destination = destination_for_policy(source, destination_dir, conflict_policy)
                if destination is None:
                    report(index, total, f"Skipped conflict {index}/{total}")
                    continue
                try:
                    if cut_mode:
                        shutil.move(str(source), str(destination))
                    elif source.is_dir():
                        shutil.copytree(source, destination)
                    else:
                        shutil.copy2(source, destination)
                    pasted += 1
                    report(index, total, f"Pasted {index}/{total}")
                except OSError:
                    report(index, total, f"Paste issue {index}/{total}")
                    continue
            return pasted

        def done(pasted):
            nonlocal file_clipboard, file_clipboard_cut
            if pasted == OPERATION_CANCELLED:
                finish_operation("Paste cancelled")
                return
            if cut_mode:
                file_clipboard = []
                file_clipboard_cut = False
            finish_operation(f"Pasted {pasted} item(s)" if pasted else "Paste failed")

        run_background(f"Pasting {len(sources)} item(s)", worker, done)

    def ask_name(title_text: str, default_name: str) -> str | None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("OK", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        entry = Gtk.Entry()
        entry.set_text(default_name)
        entry.set_activates_default(True)
        content.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not value:
            return None
        return Path(value).name

    def ask_text(title_text: str, default_value: str) -> str | None:
        dialog = Gtk.Dialog(title=title_text, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("OK", Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        entry = Gtk.Entry()
        entry.set_text(default_value)
        entry.set_activates_default(True)
        content.pack_start(entry, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        value = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not value:
            return None
        return value

    def create_folder():
        name = ask_name("New Folder", "Untitled Folder")
        if not name:
            return
        destination = unique_destination(current, name)
        try:
            destination.mkdir()
            render()
            status_label.set_text(f"Created {destination.name}")
        except OSError as exc:
            status_label.set_text(f"New folder failed: {exc}")

    def create_file():
        name = ask_name("New File", "Untitled.txt")
        if not name:
            return
        destination = unique_destination(current, name)
        try:
            destination.touch(exist_ok=False)
            render()
            set_status(f"Created {destination.name}")
        except OSError as exc:
            set_status(f"New file failed: {exc}")

    def rename_path(path: Path):
        name = ask_name("Rename", path.name)
        if not name or name == path.name:
            return
        destination = unique_destination(path.parent, name)
        try:
            path.rename(destination)
            render()
            status_label.set_text(f"Renamed to {destination.name}")
        except OSError as exc:
            status_label.set_text(f"Rename failed: {exc}")

    def batch_rename_selected():
        paths = selected_paths()
        if len(paths) < 2:
            status_label.set_text("Select multiple items for batch rename")
            return
        pattern = ask_text("Batch Rename", "SevenOS-{n}-{name}")
        if not pattern:
            return
        renamed = 0
        for index, path in enumerate(paths, start=1):
            target_name = pattern.replace("{n}", f"{index:02d}").replace("{name}", path.stem).replace("{ext}", path.suffix.lstrip("."))
            if path.is_file() and "{ext}" not in pattern:
                target_name = f"{target_name}{path.suffix}"
            destination = unique_destination(path.parent, Path(target_name).name)
            try:
                path.rename(destination)
                renamed += 1
            except OSError:
                continue
        render()
        status_label.set_text(f"Batch renamed {renamed} item(s)")

    def open_terminal_here(path: Path | None = None):
        target = path if path and path.is_dir() else current
        for terminal in ("foot", "kitty", "alacritty", "gnome-terminal", "wezterm"):
            if shutil.which(terminal):
                command = [terminal]
                if terminal == "gnome-terminal":
                    command.extend(["--working-directory", str(target)])
                elif terminal == "wezterm":
                    command.extend(["start", "--cwd", str(target)])
                else:
                    command.extend(["--working-directory", str(target)])
                subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return
        status_label.set_text("No terminal found")

    def profile_action(path: Path):
        if active_profile == "forge":
            open_terminal_here(path if path.is_dir() else path.parent)
        elif active_profile == "studio" and is_image(path):
            open_externally(path)
        elif active_profile == "shield" and path.is_file():
            hash_selected()
        elif active_profile == "windows" and path.suffix.lower() == ".exe":
            xdg_open(path)
        elif active_profile == "pulse":
            reveal_in_parent(path)
        else:
            update_preview(path)

    def duplicate_path(path: Path):
        destination = unique_destination(path.parent, f"{path.stem} copy{path.suffix}" if path.is_file() else f"{path.name} copy")
        try:
            if path.is_dir():
                shutil.copytree(path, destination)
            else:
                shutil.copy2(path, destination)
            render()
            status_label.set_text(f"Duplicated {path.name}")
        except OSError as exc:
            status_label.set_text(f"Duplicate failed: {exc}")

    def trash_path(path: Path, render_after: bool = True) -> bool:
        if shutil.which("gio"):
            result = subprocess.run(["gio", "trash", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                if render_after:
                    render()
                    status_label.set_text(f"Moved {path.name} to Trash")
                return True
        TRASH_FILES_DIR.mkdir(parents=True, exist_ok=True)
        TRASH_INFO_DIR.mkdir(parents=True, exist_ok=True)
        try:
            destination = unique_destination(TRASH_FILES_DIR, path.name)
            original_uri = file_uri(path)
            deletion_date = time.strftime("%Y-%m-%dT%H:%M:%S", time.localtime())
            info_path = TRASH_INFO_DIR / f"{destination.name}.trashinfo"
            info_path.write_text(f"[Trash Info]\nPath={original_uri}\nDeletionDate={deletion_date}\n", encoding="utf-8")
            shutil.move(str(path), str(destination))
            if render_after:
                render()
                status_label.set_text(f"Moved {path.name} to Trash")
            return True
        except OSError as exc:
            if render_after:
                status_label.set_text(f"Trash failed: {exc}")
            return False

    def trash_original_path(path: Path) -> Path | None:
        info_path = TRASH_INFO_DIR / f"{path.name}.trashinfo"
        if not info_path.exists():
            return None
        parser = configparser.ConfigParser()
        try:
            parser.read(info_path, encoding="utf-8")
            raw = parser.get("Trash Info", "Path", fallback="")
        except Exception:
            return None
        if raw.startswith("file://"):
            return Path(urllib.parse.unquote(urllib.parse.urlparse(raw).path))
        return Path(raw).expanduser() if raw else None

    def restore_from_trash(path: Path):
        original = trash_original_path(path)
        if not original:
            status_label.set_text("Restore location is unknown")
            return
        destination = unique_destination(original.parent, original.name)
        try:
            destination.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(path), str(destination))
            info_path = TRASH_INFO_DIR / f"{path.name}.trashinfo"
            info_path.unlink(missing_ok=True)
            render()
            status_label.set_text(f"Restored {destination.name}")
        except OSError as exc:
            status_label.set_text(f"Restore failed: {exc}")

    def trash_selected():
        paths = selected_paths()
        if not paths:
            status_label.set_text("Select an item to move to Trash")
            return

        def worker(cancelled, report):
            moved = 0
            total = len(paths)
            for index, path in enumerate(paths, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                if trash_path(path, render_after=False):
                    moved += 1
                report(index, total, f"Trashed {index}/{total}")
            return moved

        def done(moved):
            if moved == OPERATION_CANCELLED:
                finish_operation("Trash cancelled")
            else:
                finish_operation(f"Moved {moved} item(s) to Trash")

        run_background(f"Trashing {len(paths)} item(s)", worker, done)

    def load_tags() -> dict[str, str]:
        if not TAG_CACHE.exists():
            return {}
        try:
            return json.loads(TAG_CACHE.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            return {}

    def save_tags(tags: dict[str, str]) -> None:
        TAG_CACHE.parent.mkdir(parents=True, exist_ok=True)
        TAG_CACHE.write_text(json.dumps(tags, indent=2, sort_keys=True), encoding="utf-8")

    def tag_paths(paths: list[Path], tag: str):
        if not paths:
            status_label.set_text("Select an item to tag")
            return
        tags = load_tags()
        for path in paths:
            tags[str(path.resolve())] = tag
        save_tags(tags)
        status_label.set_text(f"Tagged {len(paths)} item(s) as {tag}")
        update_preview_multiple(paths) if len(paths) > 1 else update_preview(paths[0])

    def tag_for_path(path: Path) -> str:
        return load_tags().get(str(path.resolve()), "")

    def show_ai_result(title: str, body: str):
        dialog = Gtk.Dialog(title=title, transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.set_default_size(560, 420)
        dialog.add_button("Close", Gtk.ResponseType.CLOSE)
        content = dialog.get_content_area()
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        text = Gtk.TextView()
        text.set_editable(False)
        text.set_cursor_visible(False)
        text.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        text.get_buffer().set_text(body)
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroller.add(text)
        content.pack_start(scroller, True, True, 0)
        dialog.show_all()
        dialog.run()
        dialog.destroy()

    def sevenai_selected():
        paths = selected_paths()
        if not paths:
            status_label.set_text("Select an item before asking SevenAI")
            return
        root = resolve_root()
        seven = shutil.which("seven")
        seven_cmd = [seven] if seven else [str(root / "bin/seven")] if root and (root / "bin/seven").exists() else []
        if not seven_cmd:
            status_label.set_text("SevenAI command is not available")
            return
        summary = []
        for path in paths[:8]:
            kind = "folder" if path.is_dir() else path.suffix.lower().lstrip(".") or "file"
            summary.append(f"{path.name} ({kind}, {path})")
        prompt = (
            "Analyse cette sélection Seven Files et réponds en langage simple. "
            "Propose 3 actions utiles maximum: " + "; ".join(summary)
        )

        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, 2, "SevenAI is analyzing")
            result = subprocess.run([*seven_cmd, "ai", "provider", prompt], text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False, timeout=14)
            report(2, 2, "SevenAI analysis ready")
            return result.stdout.strip() or "SevenAI n'a pas retourné de suggestion."

        def done(output):
            if output == OPERATION_CANCELLED:
                finish_operation("SevenAI analysis cancelled")
                return
            finish_operation("SevenAI analysis ready")
            show_ai_result("SevenAI · File Insight", output)

        run_background("SevenAI is analyzing", worker, done)

    def go_to_path_dialog():
        show_location_entry()

    def archive_destination(path: Path, item_count: int = 1, archive_format: str = "zip", requested_name: str | None = None) -> Path:
        if item_count > 1 and path == current:
            base = "Archive"
            directory = current
        else:
            base = path.stem if path.is_file() else path.name
            directory = path.parent if path != current else current
        suffix = ARCHIVE_FORMATS.get(archive_format, ".zip")
        if requested_name:
            base = Path(requested_name).name
            for archive_suffix in sorted(ARCHIVE_FORMATS.values(), key=len, reverse=True):
                if base.endswith(archive_suffix):
                    base = base[: -len(archive_suffix)]
                    break
        candidate = directory / f"{base}{suffix}"
        if not candidate.exists():
            return candidate
        for index in range(2, 1000):
            candidate = directory / f"{base} {index}{suffix}"
            if not candidate.exists():
                return candidate
        return directory / f"{base} archive{suffix}"

    def archive_member_name(target: Path, item: Path) -> str:
        if target.is_dir():
            return str(item.relative_to(target.parent))
        return target.name

    def write_archive(destination: Path, targets: list[Path], archive_format: str):
        if archive_format == "zip":
            with zipfile.ZipFile(destination, "w", compression=zipfile.ZIP_DEFLATED) as archive:
                for target in targets:
                    if target.is_dir():
                        for item in target.rglob("*"):
                            if item == destination:
                                continue
                            archive.write(item, archive_member_name(target, item))
                    else:
                        archive.write(target, target.name)
            return
        mode = "w:gz" if archive_format == "tar.gz" else "w:xz"
        with tarfile.open(destination, mode) as archive:
            for target in targets:
                archive.add(target, arcname=target.name)

    def ask_archive_options(default_name: str) -> tuple[str, str] | None:
        dialog = Gtk.Dialog(title=tr_text("Compress"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button(tr_text("Cancel"), Gtk.ResponseType.CANCEL)
        dialog.add_button(tr_text("Compress"), Gtk.ResponseType.OK)
        dialog.set_default_response(Gtk.ResponseType.OK)
        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(14)
        content.set_margin_bottom(14)
        content.set_margin_start(14)
        content.set_margin_end(14)
        name_label = Gtk.Label(label=tr_text("Archive name"))
        name_label.set_xalign(0)
        entry = Gtk.Entry()
        entry.set_text(default_name)
        entry.set_activates_default(True)
        format_label = Gtk.Label(label=tr_text("Format"))
        format_label.set_xalign(0)
        combo = Gtk.ComboBoxText()
        for value in ARCHIVE_FORMATS:
            combo.append_text(value)
        combo.set_active(0)
        content.pack_start(name_label, False, False, 0)
        content.pack_start(entry, False, False, 0)
        content.pack_start(format_label, False, False, 0)
        content.pack_start(combo, False, False, 0)
        dialog.show_all()
        response = dialog.run()
        name = entry.get_text().strip()
        archive_format = combo.get_active_text() or "zip"
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not name:
            return None
        return name, archive_format

    def compress_paths(paths: list[Path]):
        targets = [path for path in paths if path.exists()]
        if not targets:
            status_label.set_text("Select an item to compress")
            return
        base_path = targets[0] if len(targets) == 1 else current
        default_name = "Archive" if len(targets) > 1 else (base_path.stem if base_path.is_file() else base_path.name)
        options = ask_archive_options(default_name)
        if not options:
            status_label.set_text("Compression cancelled")
            return
        requested_name, archive_format = options
        destination = archive_destination(base_path, len(targets), archive_format, requested_name)
        def worker(cancelled, report):
            if cancelled():
                return OPERATION_CANCELLED
            report(1, max(1, len(targets)), f"Compressing {len(targets)} item(s)")
            write_archive(destination, targets, archive_format)
            report(max(1, len(targets)), max(1, len(targets)), "Compression complete")
            return destination.name

        def done(name):
            if name == OPERATION_CANCELLED:
                finish_operation("Compression cancelled")
                return
            finish_operation(f"Compressed {len(targets)} item(s) to {name}")

        run_background(f"Compressing {len(targets)} item(s)", worker, done)

    def compress_selected():
        paths = selected_paths()
        if paths:
            compress_paths(paths)
        else:
            status_label.set_text("Select an item to compress")

    def reveal_in_parent(path: Path):
        xdg_open(path.parent if path.is_file() else path)

    def human_mode(path: Path) -> str:
        try:
            return oct(path.stat().st_mode & 0o777)
        except OSError:
            return "Unknown"

    def properties_dialog(path: Path):
        dialog = Gtk.Dialog(title=f"Properties · {path.name or path}", transient_for=window, flags=Gtk.DialogFlags.MODAL)
        dialog.add_button("Close", Gtk.ResponseType.CLOSE)
        dialog.set_default_size(420, 360)
        content = dialog.get_content_area()
        content.set_margin_top(16)
        content.set_margin_bottom(16)
        content.set_margin_start(16)
        content.set_margin_end(16)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        content.pack_start(box, True, True, 0)
        icon = Gtk.Image.new_from_icon_name(folder_icon(path), Gtk.IconSize.DIALOG)
        icon.set_pixel_size(56)
        title = Gtk.Label(label=path.name or str(path))
        title.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        title.get_style_context().add_class("preview-title")
        box.pack_start(icon, False, False, 0)
        box.pack_start(title, False, False, 0)
        try:
            stat = path.stat()
            rows = [
                ("Kind", "Folder" if path.is_dir() else (path.suffix.upper().lstrip(".") or "File")),
                ("Path", str(path)),
                ("Size", human_size(stat.st_size) if path.is_file() else file_row_meta(path)),
                ("Modified", time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(stat.st_mtime))),
                ("Permissions", human_mode(path)),
            ]
        except OSError as exc:
            rows = [("Error", str(exc))]
        for key, value in rows:
            card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            card.get_style_context().add_class("inspector-card")
            k = Gtk.Label(label=key)
            k.set_xalign(0)
            k.get_style_context().add_class("preview-heading")
            v = Gtk.Label(label=value)
            v.set_xalign(0)
            v.set_selectable(True)
            v.set_line_wrap(True)
            v.get_style_context().add_class("preview-value")
            card.pack_start(k, False, False, 0)
            card.pack_start(v, False, False, 0)
            box.pack_start(card, False, False, 0)
        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        copy_button = Gtk.Button(label="Copy Path")
        copy_button.connect("clicked", lambda *_: copy_path(path))
        actions.pack_start(copy_button, False, False, 0)
        if path.is_file():
            hash_button = Gtk.Button(label="Copy SHA256")
            hash_button.connect("clicked", lambda *_: hash_selected())
            actions.pack_start(hash_button, False, False, 0)
        box.pack_start(actions, False, False, 4)
        dialog.show_all()
        dialog.run()
        dialog.destroy()

    def add_menu_item(menu, label: str, callback):
        item = Gtk.MenuItem(label=label)
        item.connect("activate", lambda *_: callback())
        menu.append(item)

    def show_context_menu(path: Path, event):
        active_paths = selected_paths()
        if path not in active_paths:
            active_paths = [path]
        menu = Gtk.Menu()
        add_menu_item(menu, "Open", lambda: navigate(path) if path.is_dir() else open_file(path))
        if path.is_dir():
            add_menu_item(menu, "Open in New Tab", lambda: new_tab(path))
            add_menu_item(menu, "Open in Split", lambda: open_path_in_split(path))
        if str(path).startswith(str(TRASH_FILES_DIR)):
            add_menu_item(menu, "Restore from Trash", lambda: restore_from_trash(path))
        if path.is_file() and path.suffix.lower() in READER_SUFFIXES:
            add_menu_item(menu, "Read in Seven Reader", lambda: open_in_reader(path))
        if path.is_file() and is_previewable(path):
            add_menu_item(menu, "Quick Look", lambda: open_quicklook_preview(path))
        if path.is_file() and is_risky_file(path):
            add_menu_item(menu, "Safe Open", lambda: safe_open_path(path))
        add_menu_item(menu, "Copy", lambda: copy_items(active_paths))
        add_menu_item(menu, "Cut", lambda: copy_items(active_paths, cut=True))
        add_menu_item(menu, "Paste Item", paste_items)
        add_menu_item(menu, "New File", create_file)
        add_menu_item(menu, "Duplicate", lambda: duplicate_path(path))
        add_menu_item(menu, "Rename", lambda: rename_path(path))
        if len(active_paths) > 1:
            add_menu_item(menu, "Batch Rename", batch_rename_selected)
        add_menu_item(menu, "Compress", lambda: compress_paths(active_paths))
        if split_visible:
            add_menu_item(menu, "Copy to Split", lambda: copy_selected_to_split(False))
            add_menu_item(menu, "Move to Split", lambda: copy_selected_to_split(True))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, f"{profile_label(active_profile)} Action", lambda: profile_action(path))
        add_menu_item(menu, "Ask SevenAI", sevenai_selected)
        if path.is_file():
            add_menu_item(menu, "Copy SHA256", hash_selected)
        for tag in ("Blue", "Violet", "Green", "Orange", "Focus"):
            add_menu_item(menu, f"Tag: {tag}", lambda tag_name=tag: tag_paths(active_paths, tag_name))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Reveal in Folder", lambda: reveal_in_parent(path))
        add_menu_item(menu, "Copy Path", lambda: copy_path(path))
        add_menu_item(menu, "Add to Favorites", lambda: add_favorite_path(path))
        if (path if path.is_dir() else path.parent) in favorite_paths():
            add_menu_item(menu, "Remove from Favorites", lambda: remove_favorite_path(path))
        add_menu_item(menu, "Move to Trash", lambda: trash_selected())
        if is_image(path):
            menu.append(Gtk.SeparatorMenuItem())
            add_menu_item(menu, "Set as Wallpaper", lambda: set_wallpaper_from_file(path))
        menu.append(Gtk.SeparatorMenuItem())
        add_menu_item(menu, "Properties", lambda: properties_dialog(path))
        menu.show_all()
        try:
            menu.popup_at_pointer(event)
        except AttributeError:
            menu.popup(None, None, None, None, event.button, event.time)

    def setup_file_tile_dnd(widget, child, path: Path):
        uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 1)
        widget.drag_source_set(Gdk.ModifierType.BUTTON1_MASK, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
        widget.connect("drag-data-get", lambda _widget, _context, data, _info, _time: on_file_drag_data_get(data))
        if path.is_dir():
            widget.drag_dest_set(Gtk.DestDefaults.ALL, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
            widget.connect("drag-motion", lambda target_widget, context, _x, _y, time_value: on_drop_motion(target_widget, context, time_value))
            widget.connect("drag-leave", lambda target_widget, _context, _time: cancel_spring_open(target_widget))
            widget.connect("drag-data-received", lambda target_widget, context, _x, _y, data, _info, time_value, target=path: on_file_drop(target_widget, context, data, time_value, target))

    def setup_current_drop_target(widget):
        uri_target = Gtk.TargetEntry.new(URI_LIST_TARGET, 0, 1)
        widget.drag_dest_set(Gtk.DestDefaults.ALL, [uri_target], Gdk.DragAction.COPY | Gdk.DragAction.MOVE)
        widget.connect("drag-motion", lambda target_widget, context, _x, _y, time_value: on_drop_motion(target_widget, context, time_value))
        widget.connect("drag-leave", lambda target_widget, _context, _time: cancel_spring_open(target_widget))
        widget.connect("drag-data-received", lambda target_widget, context, _x, _y, data, _info, time_value: on_file_drop(target_widget, context, data, time_value, current))

    def on_file_drag_data_get(data) -> None:
        paths = selected_paths()
        if not paths:
            target = selected_path()
            paths = [target] if target else []
        data.set_uris([file_uri(path) for path in paths if path.exists()])

    def on_drop_motion(widget, context, time_value: int) -> bool:
        try:
            context.drag_status(Gdk.DragAction.MOVE, time_value)
        except Exception:
            pass
        try:
            widget.get_style_context().add_class("drop-target")
        except Exception:
            pass
        try:
            widget.file_child.get_style_context().add_class("drop-target")
        except Exception:
            pass
        schedule_spring_open(widget)
        return True

    def cancel_spring_open(widget=None) -> None:
        if spring_open_state["id"]:
            GLib.source_remove(spring_open_state["id"])
            spring_open_state["id"] = 0
        target_widget = widget or spring_open_state.get("widget")
        for css_class in ("spring-armed", "drop-target"):
            try:
                target_widget.get_style_context().remove_class(css_class)
            except Exception:
                pass
            try:
                target_widget.file_child.get_style_context().remove_class(css_class)
            except Exception:
                pass
        spring_open_state["target"] = None
        spring_open_state["widget"] = None

    def schedule_spring_open(widget) -> None:
        target = getattr(widget, "spring_target", None)
        if not isinstance(target, Path) or not target.exists() or not target.is_dir() or target == current:
            return
        if spring_open_state["target"] == target and spring_open_state["id"]:
            return
        cancel_spring_open()
        spring_open_state["target"] = target
        spring_open_state["widget"] = widget
        try:
            widget.get_style_context().add_class("spring-armed")
        except Exception:
            pass
        try:
            widget.file_child.get_style_context().add_class("spring-armed")
        except Exception:
            pass

        def spring_open() -> bool:
            spring_open_state["id"] = 0
            if target.exists() and target.is_dir():
                navigate(target)
                status_label.set_text(f"Spring opened {target.name}")
            cancel_spring_open(widget)
            return False

        spring_open_state["id"] = GLib.timeout_add(SPRING_OPEN_DELAY_MS, spring_open)

    def move_or_copy_paths(paths: list[Path], destination_dir: Path, move: bool, label: str):
        sources = [path for path in paths if path.exists() and path.parent != destination_dir]
        if not sources:
            status_label.set_text("Nothing to move")
            return
        conflict_policy = conflict_policy_for(sources, destination_dir)
        if conflict_policy == "cancel":
            set_status(f"{label} cancelled")
            return

        def worker(cancelled, report):
            completed = 0
            total = len(sources)
            for index, source in enumerate(sources, start=1):
                if cancelled():
                    return OPERATION_CANCELLED
                destination = destination_for_policy(source, destination_dir, conflict_policy)
                if destination is None:
                    report(index, total, f"Skipped conflict {index}/{total}")
                    continue
                try:
                    if move:
                        shutil.move(str(source), str(destination))
                    elif source.is_dir():
                        shutil.copytree(source, destination)
                    else:
                        shutil.copy2(source, destination)
                    completed += 1
                    report(index, total, f"{label} {index}/{total}")
                except OSError:
                    report(index, total, f"{label} issue {index}/{total}")
            return completed

        def done(completed):
            if completed == OPERATION_CANCELLED:
                finish_operation(f"{label} cancelled")
            else:
                finish_operation(f"{label} {completed} item(s)")
            if split_visible:
                render_split()

        run_background(f"{label} {len(sources)} item(s)", worker, done)

    def copy_selected_to_split(move: bool = False) -> bool:
        paths = selected_paths()
        if not paths:
            set_status("Select item(s) to send to split view")
            return True
        move_or_copy_paths(paths, split_current, move=move, label="Moved" if move else "Copied")
        return True

    def on_file_drop(widget, context, data, time_value: int, destination: Path) -> None:
        cancel_spring_open(widget)
        try:
            widget.file_child.get_style_context().remove_class("drop-target")
        except Exception:
            pass
        paths = [path for path in file_paths_from_uri_payload("\n".join(data.get_uris())) if path.exists()]
        try:
            move = context.get_selected_action() == Gdk.DragAction.MOVE
        except Exception:
            move = True
        if destination.exists() and destination.is_dir():
            move_or_copy_paths(paths, destination, move=True if move else False, label="Moved" if move else "Copied")
            context.finish(bool(paths), False, time_value)
        else:
            context.finish(False, False, time_value)

    def on_sidebar_drop(widget, context, data, time_value: int, target: Path | str) -> None:
        cancel_spring_open(widget)
        widget.get_style_context().remove_class("drop-target")
        paths = [path for path in file_paths_from_uri_payload("\n".join(data.get_uris())) if path.exists()]
        destination = target if isinstance(target, Path) else Path(urllib.parse.urlparse(str(target)).path)
        if destination.exists() and destination.is_dir():
            move_or_copy_paths(paths, destination, move=True, label="Moved")
            context.finish(bool(paths), False, time_value)
        else:
            context.finish(False, False, time_value)

    def on_tile_button(event, child, path: Path) -> bool:
        nonlocal selection_anchor
        if getattr(event, "button", 0) == 3:
            flash_tile(child)
            flow.select_child(child)
            selection_anchor = path
            update_preview(path)
            show_context_menu(path, event)
            return True
        if getattr(event, "button", 0) == 1:
            flash_tile(child)
            range_extend_mask = Gdk.ModifierType.CONTROL_MASK | Gdk.ModifierType.SHIFT_MASK
            range_extend = (event.state & range_extend_mask) == range_extend_mask or bool(event.state & Gdk.ModifierType.SHIFT_MASK)
            if getattr(event, "type", None) == Gdk.EventType._2BUTTON_PRESS:
                flow.unselect_all()
                flow.select_child(child)
                update_preview(path)
                open_selected(path)
            elif range_extend:
                children = flow.get_children()
                anchor_child = next((item for item in children if getattr(item, "path", None) == selection_anchor), None)
                if anchor_child and anchor_child in children and child in children:
                    start = children.index(anchor_child)
                    end = children.index(child)
                    flow.unselect_all()
                    for item in children[min(start, end): max(start, end) + 1]:
                        flow.select_child(item)
                    update_preview_multiple([item.path for item in flow.get_selected_children()])
                else:
                    flow.select_child(child)
                    update_preview(path)
                selection_anchor = selection_anchor or path
            elif event.state & Gdk.ModifierType.CONTROL_MASK:
                if child in flow.get_selected_children():
                    flow.unselect_child(child)
                else:
                    flow.select_child(child)
                selected = flow.get_selected_children()
                if len(selected) > 1:
                    update_preview_multiple([item.path for item in selected])
                elif selected:
                    update_preview(selected[0].path)
                else:
                    update_preview(current)
                selection_anchor = path
            else:
                flow.unselect_all()
                flow.select_child(child)
                selection_anchor = path
                update_preview(path)
            return True
        return False

    def open_selected(path: Path | None = None):
        target = path or selected_path()
        if not target:
            return
        if target.is_dir():
            navigate(target)
        else:
            open_file(target)

    def navigate_uri_or_path(target: Path | str):
        if isinstance(target, Path):
            navigate(target)
            return
        uri = str(target)
        if uri.startswith("file://"):
            navigate(Path(urllib.parse.unquote(urllib.parse.urlparse(uri).path)))
        elif uri.startswith(("smb://", "sftp://", "ftp://", "dav://")):
            subprocess.Popen(["gio", "open", uri] if shutil.which("gio") else ["xdg-open", uri], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            status_label.set_text(f"Opening network location {uri}")
        elif uri == "seven://connect-server":
            connect_to_server()
        else:
            navigate(Path(uri).expanduser())

    def navigate(path: Path):
        nonlocal current, virtual_location
        if path == RECENTS_SENTINEL:
            if virtual_location != "recent":
                history.append(current)
                future.clear()
            virtual_location = "recent"
            render()
            return
        if not path.exists() or not path.is_dir():
            return
        if path != current or virtual_location:
            history.append(current)
            future.clear()
            current = path
            virtual_location = ""
            remember_recent(path)
        render()

    def go_back():
        nonlocal current, virtual_location
        if history:
            future.append(current)
            current = history.pop()
            virtual_location = ""
            render()

    def go_forward():
        nonlocal current, virtual_location
        if future:
            history.append(current)
            current = future.pop()
            virtual_location = ""
            render()

    def set_search_query(entry):
        nonlocal search_query
        search_query = entry.get_text().strip()
        entry.set_icon_sensitive(Gtk.EntryIconPosition.SECONDARY, bool(search_query))
        if search_render_state["id"]:
            GLib.source_remove(search_render_state["id"])

        def apply_search() -> bool:
            search_render_state["id"] = 0
            render()
            return False

        search_render_state["id"] = GLib.timeout_add(120, apply_search)

    def clear_search() -> bool:
        search_entry.set_text("")
        search_entry.grab_focus()
        search_entry.set_position(0)
        return True

    def entry_has_focus() -> bool:
        focus = window.get_focus()
        return isinstance(focus, Gtk.Entry)

    def cycle_sort_mode():
        nonlocal sort_mode
        try:
            index = sort_order.index(sort_mode)
        except ValueError:
            index = 0
        sort_mode = sort_order[(index + 1) % len(sort_order)]
        sort_button.set_label(sort_labels.get(sort_mode, "A-Z"))
        save_preferences()
        render()

    def activate(_flow, child):
        if child is None:
            return
        open_selected(child.path)

    def selection_changed(flow_box):
        selected = flow_box.get_selected_children()
        location = "Recents" if virtual_location == "recent" else str(current)
        if len(selected) > 1:
            update_preview_multiple([child.path for child in selected])
            status_label.set_text(f"{len(selected)} selected  |  {location}")
        elif selected:
            update_preview(selected[0].path)
        else:
            update_preview_multiple(recent_paths()) if virtual_location == "recent" else update_preview(current)

    def on_key(_window, event):
        if entry_has_focus():
            if event.state & Gdk.ModifierType.CONTROL_MASK:
                if event.keyval in (Gdk.KEY_f, Gdk.KEY_F):
                    search_entry.grab_focus()
                    search_entry.select_region(0, -1)
                    return True
                if event.keyval in (Gdk.KEY_l, Gdk.KEY_L):
                    show_location_entry()
                    return True
                return False
            if event.keyval == Gdk.KEY_Escape:
                if window.get_focus() == search_entry:
                    clear_search()
                    flow.grab_focus()
                    return True
                if window.get_focus() == location_entry:
                    hide_location_entry()
                    return True
            return False
        if event.keyval == Gdk.KEY_Escape:
            window.close()
            return True
        if event.keyval == Gdk.KEY_BackSpace:
            go_back()
            return True
        if event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            open_selected()
            return True
        if event.keyval == Gdk.KEY_Delete:
            trash_selected()
            return True
        if event.keyval == Gdk.KEY_F2:
            target = selected_path()
            if target:
                rename_path(target)
            return True
        if event.keyval == Gdk.KEY_space:
            target = selected_path()
            if target and target.suffix.lower() in READER_SUFFIXES:
                open_in_reader(target)
                return True
            if target and is_previewable(target):
                open_quicklook_preview(target)
                return True
        if event.keyval in (Gdk.KEY_Left, Gdk.KEY_Right, Gdk.KEY_Up, Gdk.KEY_Down):
            move_keyboard_selection(event.keyval)
            return True
        if event.state & Gdk.ModifierType.CONTROL_MASK:
            if event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
                copy_selected()
                return True
            if event.keyval in (Gdk.KEY_x, Gdk.KEY_X):
                cut_selected()
                return True
            if event.keyval in (Gdk.KEY_v, Gdk.KEY_V):
                paste_items()
                return True
            if event.keyval in (Gdk.KEY_t, Gdk.KEY_T):
                new_tab(current)
                return True
            if event.keyval in (Gdk.KEY_w, Gdk.KEY_W):
                close_tab()
                return True
            if event.keyval in (Gdk.KEY_a, Gdk.KEY_A):
                flow.select_all()
                return True
            if event.keyval in (Gdk.KEY_f, Gdk.KEY_F):
                search_entry.grab_focus()
                search_entry.select_region(0, -1)
                return True
            if event.keyval in (Gdk.KEY_h, Gdk.KEY_H):
                toggle_hidden()
                return True
            if event.keyval in (Gdk.KEY_n, Gdk.KEY_N):
                create_file()
                return True
            if event.keyval in (Gdk.KEY_l, Gdk.KEY_L):
                show_location_entry()
                return True
            if event.keyval in (Gdk.KEY_i, Gdk.KEY_I):
                preview.set_visible(not preview.get_visible())
                return True
            if event.keyval in (Gdk.KEY_d, Gdk.KEY_D):
                toggle_split_view()
                return True
        if event.state & Gdk.ModifierType.MOD1_MASK and event.keyval in (Gdk.KEY_c, Gdk.KEY_C):
            compress_selected()
            return True
        return False

    def adapt_layout(_window, event):
        width = getattr(event, "width", 1040)
        if width < 860:
            sidebar.set_visible(False)
            preview.set_visible(False)
            search_entry.set_size_request(64, 22)
            location_entry.set_size_request(168, 24)
            sort_button.set_size_request(34, 24)
        elif width < 1040:
            sidebar.set_visible(True)
            preview.set_visible(False)
            search_entry.set_size_request(70, 22)
            location_entry.set_size_request(190, 24)
            sort_button.set_size_request(36, 24)
        else:
            sidebar.set_visible(True)
            search_entry.set_size_request(76, 22)
            location_entry.set_size_request(220, 24)
            sort_button.set_size_request(38, 24)
        return False

    def move_keyboard_selection(keyval: int):
        children = flow.get_children()
        if not children:
            return
        selected = flow.get_selected_children()
        if selected and selected[0] in children:
            index = children.index(selected[0])
        else:
            index = 0
        columns = 1 if view_mode == "list" else 2 if view_mode == "compact" else max(1, min(current_grid_columns(), len(children)))
        if keyval == Gdk.KEY_Left:
            index = max(0, index - 1)
        elif keyval == Gdk.KEY_Right:
            index = min(len(children) - 1, index + 1)
        elif keyval == Gdk.KEY_Up:
            index = max(0, index - columns)
        elif keyval == Gdk.KEY_Down:
            index = min(len(children) - 1, index + columns)
        child = children[index]
        flow.select_child(child)
        child.grab_focus()
        update_preview(child.path)

    def rects_intersect(a: tuple[int, int, int, int], b: tuple[int, int, int, int]) -> bool:
        ax, ay, aw, ah = a
        bx, by, bw, bh = b
        return ax < bx + bw and ax + aw > bx and ay < by + bh and ay + ah > by

    def update_rubberband_widget() -> None:
        x = rubberband_rect["x"]
        y = rubberband_rect["y"]
        w = max(1, rubberband_rect["w"])
        h = max(1, rubberband_rect["h"])
        rubberband.set_margin_start(x)
        rubberband.set_margin_top(y)
        rubberband.set_size_request(w, h)
        rubberband.set_visible(bool(rubberband_rect["active"]))
        rubberband.queue_draw()

    def select_children_in_rect() -> None:
        area = (rubberband_rect["x"], rubberband_rect["y"], rubberband_rect["w"], rubberband_rect["h"])
        flow.unselect_all()
        selected = []
        for child in flow.get_children():
            alloc = child.get_allocation()
            child_rect = (alloc.x, alloc.y, alloc.width, alloc.height)
            if rects_intersect(area, child_rect):
                flow.select_child(child)
                selected.append(child.path)
        if len(selected) > 1:
            update_preview_multiple(selected)
        elif selected:
            update_preview(selected[0])
        else:
            update_preview(current)

    def on_flow_button_press(_flow, event) -> bool:
        nonlocal rubberband_origin
        if getattr(event, "button", 0) != 1:
            return False
        try:
            if flow.get_child_at_pos(int(event.x), int(event.y)) is not None:
                return False
        except Exception:
            pass
        rubberband_origin = (int(event.x), int(event.y))
        rubberband_rect.update({"x": int(event.x), "y": int(event.y), "w": 1, "h": 1, "active": True})
        update_rubberband_widget()
        flow.grab_focus()
        return True

    def on_flow_motion(_flow, event) -> bool:
        if rubberband_origin is None:
            return False
        origin_x, origin_y = rubberband_origin
        x = int(min(origin_x, event.x))
        y = int(min(origin_y, event.y))
        w = int(abs(event.x - origin_x))
        h = int(abs(event.y - origin_y))
        rubberband_rect.update({"x": x, "y": y, "w": w, "h": h, "active": True})
        update_rubberband_widget()
        select_children_in_rect()
        return True

    def on_flow_button_release(_flow, event) -> bool:
        nonlocal rubberband_origin
        if rubberband_origin is None or getattr(event, "button", 0) != 1:
            return False
        select_children_in_rect()
        rubberband_origin = None
        rubberband_rect["active"] = False
        update_rubberband_widget()
        return True

    search_entry.connect("changed", set_search_query)
    search_entry.connect(
        "icon-release",
        lambda _entry, position, _event: clear_search() if position == Gtk.EntryIconPosition.SECONDARY else False,
    )
    search_entry.connect(
        "key-press-event",
        lambda _entry, event: clear_search() if event.keyval == Gdk.KEY_Escape else False,
    )
    location_entry.connect("activate", lambda *_: commit_location_entry())
    location_entry.connect("focus-out-event", lambda *_: hide_location_entry())
    location_entry.connect(
        "key-press-event",
        lambda _entry, event: hide_location_entry() if event.keyval == Gdk.KEY_Escape else False,
    )
    sort_button.connect("clicked", lambda *_: cycle_sort_mode())
    sort_button.connect("pressed", lambda widget: press_feedback(widget))
    sort_button.connect("released", lambda widget: release_feedback(widget))
    setup_current_drop_target(flow)
    flow.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK | Gdk.EventMask.POINTER_MOTION_MASK)
    flow.connect("button-press-event", on_flow_button_press)
    flow.connect("motion-notify-event", on_flow_motion)
    flow.connect("button-release-event", on_flow_button_release)
    flow.connect("child-activated", activate)
    flow.connect("selected-children-changed", selection_changed)
    flow.connect("key-press-event", on_key)
    split_flow.connect("child-activated", lambda _flow, child: navigate_split(child.path) if child and child.path.is_dir() else None)
    window.connect("key-press-event", on_key)
    window.connect("configure-event", adapt_layout)
    window.connect("destroy", Gtk.main_quit)
    tabs.append({"path": current, "virtual": virtual_location, "history": [], "future": []})
    render()
    window.show_all()
    window.resize(1120, 700)
    Gtk.main()
    return 0


def toggle_zoom_or_tile(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        result = subprocess.run(["hyprctl", "dispatch", "togglefloating", "active"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            return
    if window.is_maximized():
        window.unmaximize()
        window.resize(1120, 700)
    else:
        window.maximize()


def minimize_window(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        for command in (
            ["hyprctl", "dispatch", "movetoworkspacesilent", "special:seven"],
            ["hyprctl", "dispatch", "movetoworkspace", "special:seven"],
        ):
            result = subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                return
    window.iconify()


def format_size(size: int) -> str:
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{size} B"


def begin_move(window, event) -> bool:
    if getattr(event, "button", 0) == 1:
        window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
        return True
    return False


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("path", nargs="?", default=str(Path.home()))
    args = parser.parse_args()
    if args.probe:
        return probe()
    return run_files(args.path)


if __name__ == "__main__":
    raise SystemExit(main())
