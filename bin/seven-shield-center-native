#!/usr/bin/env python3
"""Compact SevenOS Shield center for Waybar."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
import seven_theme  # noqa: E402
from seven_i18n import tr_text  # noqa: E402


def run_json(command: list[str], fallback):
    try:
        out = subprocess.check_output(command, cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
        return json.loads(out)
    except Exception:
        return fallback


def run_detached(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def run_terminal(command: str, title: str = "SevenOS Shield") -> None:
    escaped = command.replace("'", "'\"'\"'")
    wrapped = f"{escaped}; printf '\\nPress Enter to close...'; read -r"
    if shutil_which("seven-terminal"):
        subprocess.Popen(
            ["seven-terminal", "cyber", "--", "bash", "-lc", wrapped],
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return
    run_detached(command)


def shutil_which(name: str) -> str | None:
    for folder in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(folder) / name
        if candidate.exists() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def probe() -> int:
    ensure_gi_python()
    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenShieldCenterNative")
    GLib.set_application_name("SevenOS Shield")
    try:
        Gdk.set_program_class("SevenShieldCenterNative")
    except Exception:
        pass

    css = seven_theme.gtk_app_css("shield-center") + """
    * { font-family: "SF Pro Display", "SF UI Display", "San Francisco", system-ui, sans-serif; }
    window.shield-center-window { background: transparent; }
    .shield-root {
      padding: 18px;
      border-radius: 28px;
      background:
        radial-gradient(ellipse at 14% 0%, alpha(@seven_success, 0.15), transparent 42%),
        radial-gradient(ellipse at 86% 0%, alpha(@seven_wallpaper_secondary, 0.10), transparent 40%),
        @seven_panel;
      border: 1px solid @seven_border;
    }
    .title { color: @seven_text; font-size: 21px; font-weight: 500; }
    .subtitle { color: @seven_muted; font-size: 12px; }
    .metric {
      min-height: 76px;
      padding: 12px;
      border-radius: 18px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .metric.good { border-color: alpha(@seven_success, 0.30); background: alpha(@seven_success, 0.10); }
    .metric.warn { border-color: alpha(@seven_warning, 0.30); background: alpha(@seven_warning, 0.08); }
    .metric.bad { border-color: alpha(@seven_danger, 0.30); background: alpha(@seven_danger, 0.08); }
    .metric-value { color: @seven_text; font-family: "JetBrainsMono Nerd Font", "SF Mono", monospace; font-size: 22px; font-weight: 500; }
    .metric-label { color: @seven_muted; font-size: 11px; }
    .plan-card {
      min-height: 58px;
      padding: 10px 12px;
      border-radius: 18px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .plan-title { color: @seven_text; font-size: 13px; font-weight: 500; }
    .plan-note { color: @seven_muted; font-size: 11px; }
    .section-title { color: @seven_text; font-size: 13px; font-weight: 500; margin-top: 4px; }
    .row-title { color: @seven_text; font-size: 12px; font-weight: 500; }
    .row-note { color: @seven_muted; font-size: 11px; }
    .action-strip {
      padding: 12px;
      border-radius: 22px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .icon-action {
      min-width: 44px;
      min-height: 44px;
      padding: 0;
      border-radius: 999px;
      color: @seven_text;
      background: alpha(@seven_success, 0.09);
      border: 1px solid alpha(@seven_success, 0.18);
    }
    .icon-action:hover { background: alpha(@seven_success, 0.18); }
    .pill {
      padding: 4px 10px;
      border-radius: 999px;
      color: @seven_text;
      background: alpha(@seven_success, 0.10);
      border: 1px solid alpha(@seven_success, 0.16);
      font-size: 11px;
    }
    """
    if seven_theme.current_theme_mode() == "light":
        css += """
        .shield-root {
          background:
            linear-gradient(145deg, rgba(247,255,252,0.94), rgba(235,250,246,0.84)),
            rgba(255,255,255,0.84);
          border-color: rgba(0,122,92,0.18);
          box-shadow: 0 24px 72px rgba(20,80,70,0.14);
        }
        .title, .metric-value, .plan-title, .section-title, .row-title { color: rgba(20,43,38,0.96); }
        .subtitle, .metric-label, .plan-note, .row-note { color: rgba(20,43,38,0.60); }
        .metric, .plan-card, .action-strip {
          background: rgba(255,255,255,0.68);
          border-color: rgba(0,122,92,0.12);
        }
        .icon-action, .pill {
          color: rgba(20,43,38,0.92);
          background: rgba(0,167,122,0.10);
          border-color: rgba(0,122,92,0.16);
        }
        .icon-action:hover { background: rgba(0,167,122,0.16); }
        """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    dashboard = run_json([str(ROOT / "security/shield-control.sh"), "dashboard", "--json"], {"posture": {"percent": 0, "label": "unknown"}, "plan": {"next": []}})
    posture_payload = dashboard.get("posture", {})
    persona = dashboard.get("persona", {}).get("active", {})
    scope = dashboard.get("scope", {})
    network = dashboard.get("network", {})
    evidence = dashboard.get("evidence", {})
    tool_doctor = dashboard.get("tool_doctor", {})
    wrappers = dashboard.get("wrappers", {}).get("wrappers", [])
    bundles = dashboard.get("bundles", {}).get("bundles", [])
    toolchain = dashboard.get("toolchain", {}).get("sources", [])
    percent = int(posture_payload.get("percent", 0) or 0)
    posture = posture_payload.get("label", "unknown")
    wrapper_ok = sum(1 for item in wrappers if item.get("state") == "OK")
    bundle_ok = sum(1 for item in bundles if item.get("state") == "OK")

    window = Gtk.Window(title="SevenOS Shield")
    window.set_wmclass("SevenShieldCenterNative", "SevenShieldCenterNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(760, 680)
    window.get_style_context().add_class("shield-center-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.get_style_context().add_class("shield-root")
    window.add(root)

    title = Gtk.Label(label="Shield", xalign=0)
    title.get_style_context().add_class("title")
    root.pack_start(title, False, False, 0)
    subtitle = Gtk.Label(label=f"{posture.title()} posture · {persona.get('title', 'Safe Audit')} · {scope.get('state', 'DRAFT')}", xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    root.pack_start(subtitle, False, False, 0)

    metrics = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_start(metrics, False, False, 0)
    metrics.pack_start(metric(Gtk, f"{percent}%", "Trust", css_state(percent)), True, True, 0)
    metrics.pack_start(metric(Gtk, f"{tool_doctor.get('overall', 0)}%", "Tools", css_state(int(tool_doctor.get("overall", 0) or 0))), True, True, 0)
    metrics.pack_start(metric(Gtk, f"{scope.get('target_count', 0)}", "Targets", "warn" if not scope.get("active") else "good"), True, True, 0)
    metrics.pack_start(metric(Gtk, f"{wrapper_ok}/{len(wrappers)}", "Wrappers", "good" if wrappers and wrapper_ok == len(wrappers) else "warn"), True, True, 0)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    scroller.set_min_content_height(420)
    root.pack_start(scroller, True, True, 0)

    content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
    scroller.add(content)

    content.pack_start(section_label(Gtk, "Operational State"), False, False, 0)
    state_grid = Gtk.Grid()
    state_grid.set_column_spacing(10)
    state_grid.set_row_spacing(10)
    content.pack_start(state_grid, False, False, 0)
    state_grid.attach(detail_card(Gtk, "Persona", persona.get("title", "Safe Audit"), "seven shield personas"), 0, 0, 1, 1)
    state_grid.attach(detail_card(Gtk, "Scope", f"{scope.get('state', 'DRAFT')} · {scope.get('target_count', 0)} target(s)", "seven shield scope"), 1, 0, 1, 1)
    state_grid.attach(detail_card(Gtk, "Network", network.get("persona", {}).get("policy", "normal-guarded"), "seven shield network"), 0, 1, 1, 1)
    state_grid.attach(detail_card(Gtk, "Evidence", f"{evidence.get('items', 0)} item(s)", "seven shield evidence"), 1, 1, 1, 1)

    content.pack_start(section_label(Gtk, "Tool Doctor"), False, False, 0)
    for domain in (tool_doctor.get("domains") or [])[:5]:
        content.pack_start(row_card(Gtk, domain.get("title", "Domain"), f"{domain.get('percent', 0)}% · {domain.get('state', 'UNKNOWN')}", "seven shield tool-doctor"), False, False, 0)

    content.pack_start(section_label(Gtk, "Shield Bundles"), False, False, 0)
    for bundle in bundles[:5]:
        note = f"{bundle.get('percent', 0)}% · persona {bundle.get('persona', '-')}"
        content.pack_start(row_card(Gtk, bundle.get("title", bundle.get("key", "Bundle")), note, bundle.get("commands", {}).get("install", f"seven shield bundles status {bundle.get('key', '')}")), False, False, 0)

    content.pack_start(section_label(Gtk, "Shield Toolchain Sources"), False, False, 0)
    for source in toolchain:
        content.pack_start(row_card(Gtk, source.get("title", source.get("key", "Source")), f"{source.get('state', 'MISS')} · {source.get('role', '')}", source.get("install", "seven shield toolchain")), False, False, 0)

    next_actions = (dashboard.get("plan", {}).get("next") or [])[:3]
    if next_actions:
        content.pack_start(section_label(Gtk, "Next Actions"), False, False, 0)
        for item in next_actions:
            content.pack_start(plan_card(Gtk, item), False, False, 0)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    actions.set_halign(Gtk.Align.CENTER)
    actions.get_style_context().add_class("action-strip")
    root.pack_end(actions, False, False, 0)
    for glyph, tooltip, command in [
        ("󰒃", "Dashboard", "seven shield dashboard"),
        ("󰄬", "Doctor", "seven shield tool-doctor"),
        ("󱗼", "Bundles", "seven shield bundles"),
        ("󰉋", "Workspace", "seven shield open"),
        ("󰾅", "Performance", "seven shield performance apply"),
    ]:
        button = Gtk.Button()
        button.get_style_context().add_class("icon-action")
        button.set_tooltip_text(tooltip)
        button.add(Gtk.Label(label=glyph))
        button.connect("clicked", lambda _button, cmd=command: run_terminal(cmd))
        actions.pack_start(button, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def css_state(percent: int) -> str:
    if percent >= 70:
        return "good"
    if percent >= 35:
        return "warn"
    return "bad"


def metric(Gtk, value: str, label: str, state: str):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    box.get_style_context().add_class("metric")
    box.get_style_context().add_class(state)
    value_label = Gtk.Label(label=value)
    value_label.get_style_context().add_class("metric-value")
    label_label = Gtk.Label(label=label)
    label_label.get_style_context().add_class("metric-label")
    box.pack_start(value_label, False, False, 0)
    box.pack_start(label_label, False, False, 0)
    return box


def section_label(Gtk, text: str):
    label = Gtk.Label(label=text, xalign=0)
    label.get_style_context().add_class("section-title")
    return label


def detail_card(Gtk, title: str, note: str, command: str):
    button = Gtk.Button()
    button.get_style_context().add_class("plan-card")
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    title_label = Gtk.Label(label=title, xalign=0)
    title_label.get_style_context().add_class("row-title")
    note_label = Gtk.Label(label=note, xalign=0)
    note_label.get_style_context().add_class("row-note")
    box.pack_start(title_label, False, False, 0)
    box.pack_start(note_label, False, False, 0)
    button.add(box)
    button.connect("clicked", lambda _button, cmd=command: run_terminal(cmd))
    return button


def row_card(Gtk, title: str, note: str, command: str):
    button = Gtk.Button()
    button.get_style_context().add_class("plan-card")
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
    title_label = Gtk.Label(label=title, xalign=0)
    title_label.get_style_context().add_class("row-title")
    note_label = Gtk.Label(label=note, xalign=0)
    note_label.get_style_context().add_class("row-note")
    text.pack_start(title_label, False, False, 0)
    text.pack_start(note_label, False, False, 0)
    row.pack_start(text, True, True, 0)
    pill = Gtk.Label(label=tr_text("Ouvrir", "Open"))
    pill.get_style_context().add_class("pill")
    row.pack_end(pill, False, False, 0)
    button.add(row)
    button.connect("clicked", lambda _button, cmd=command: run_terminal(cmd))
    return button


def plan_card(Gtk, item: dict):
    button = Gtk.Button()
    button.get_style_context().add_class("plan-card")
    button.set_tooltip_text(item.get("command", "seven shield dashboard"))
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
    title = Gtk.Label(label=item.get("title", "Shield action"), xalign=0)
    title.get_style_context().add_class("plan-title")
    note = Gtk.Label(label=f"{item.get('severity', 'next')} · {item.get('phase', 'trust')}", xalign=0)
    note.get_style_context().add_class("plan-note")
    box.pack_start(title, False, False, 0)
    box.pack_start(note, False, False, 0)
    button.add(box)
    button.connect("clicked", lambda _button, cmd=item.get("command", "seven shield dashboard"): run_terminal(cmd))
    return button


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    return run()


if __name__ == "__main__":
    raise SystemExit(main())
