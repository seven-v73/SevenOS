#!/usr/bin/env python3
"""Seven Notes: local-first native notes surface and widget backend."""

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
import uuid
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "bin").is_dir():
        return Path(env_root).resolve()
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin").is_dir():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin").is_dir():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None

CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
DATA_DIR = Path(os.environ.get("XDG_DATA_HOME", str(Path.home() / ".local/share"))) / "sevenos" / "notes"
NOTES_FILE = DATA_DIR / "notes.json"
PREFS_FILE = CONFIG_DIR / "notes.json"


def lang_is_fr() -> bool:
    raw = " ".join(
        value
        for value in (
            os.environ.get("SEVENOS_LANGUAGE"),
            os.environ.get("LANGUAGE"),
            os.environ.get("LC_ALL"),
            os.environ.get("LANG"),
        )
        if value
    ).lower()
    return raw.startswith("fr")


def tr(fr: str, en: str) -> str:
    return fr if lang_is_fr() else en


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if system_python.exists() and Path(sys.executable).resolve() != system_python:
            result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                os.environ["SEVENOS_GI_PYTHON"] = "1"
                os.execv(str(system_python), [str(system_python), *sys.argv])


def now() -> int:
    return int(time.time())


def load_notes() -> list[dict]:
    if not NOTES_FILE.exists():
        return []
    try:
        data = json.loads(NOTES_FILE.read_text(encoding="utf-8"))
        notes = data.get("notes") if isinstance(data, dict) else data
        if isinstance(notes, list):
            return [item for item in notes if isinstance(item, dict)]
    except Exception:
        pass
    return []


def save_notes(notes: list[dict]) -> None:
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    payload = {"schema": "sevenos.notes.v1", "updated": now(), "notes": notes}
    tmp = NOTES_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    tmp.replace(NOTES_FILE)


def load_prefs() -> dict:
    prefs = {"accent": "equinox", "density": "comfortable", "sort": "updated", "widget_mode": "recent"}
    try:
        if PREFS_FILE.exists():
            data = json.loads(PREFS_FILE.read_text(encoding="utf-8"))
            if isinstance(data, dict):
                prefs.update({key: data[key] for key in prefs if key in data})
    except Exception:
        pass
    return prefs


def save_prefs(prefs: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    PREFS_FILE.write_text(json.dumps({"schema": "sevenos.notes.preferences.v1", **prefs}, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def note_title(body: str) -> str:
    for line in body.splitlines():
        line = line.strip()
        if line:
            return line[:72]
    return tr("Nouvelle note", "New note")


def add_note(text: str, title: str | None = None, color: str = "equinox", pinned: bool = False) -> dict:
    text = text.strip()
    item = {
        "id": uuid.uuid4().hex[:12],
        "title": (title or note_title(text)).strip()[:90],
        "body": text,
        "color": color,
        "pinned": bool(pinned),
        "created": now(),
        "updated": now(),
    }
    notes = load_notes()
    notes.insert(0, item)
    save_notes(notes)
    return item


def status_payload() -> dict:
    notes = load_notes()
    recent = sorted(notes, key=lambda item: (bool(item.get("pinned")), int(item.get("updated") or 0)), reverse=True)[:8]
    return {
        "schema": "sevenos.notes.status.v1",
        "state": "ready",
        "count": len(notes),
        "storage": str(NOTES_FILE),
        "preferences": load_prefs(),
        "recent": recent,
        "commands": {
            "open": "seven-notes",
            "quick": "seven-notes quick",
            "add": "seven-notes add \"text\"",
            "widget": "seven widgets add notes && seven widgets open",
        },
    }


def print_json(data) -> int:
    print(json.dumps(data, ensure_ascii=False, indent=2))
    return 0


CSS = """
window.seven-notes-window {
  color: @seven_text;
}
.notes-shell {
  padding: 14px;
  border-radius: 24px;
  background: alpha(@seven_panel, 0.985);
  border: 1px solid alpha(@seven_border, 0.96);
}
.notes-sidebar {
  padding: 10px;
  border-radius: 20px;
  background: alpha(@seven_panel_2, 0.78);
  border: 1px solid alpha(@seven_border, 0.84);
}
.notes-title {
  font-size: 22px;
  font-weight: 600;
  color: @seven_text;
}
.notes-note {
  color: @seven_muted;
  font-size: 12px;
}
.note-row {
  padding: 10px;
  border-radius: 14px;
  background: transparent;
  border: 1px solid transparent;
}
.note-row:hover,
.note-row.active {
  background: alpha(@seven_hover, 0.72);
  border-color: alpha(@seven_accent, 0.30);
}
.note-row-title {
  color: @seven_text;
  font-weight: 600;
