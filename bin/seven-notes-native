  color: @seven_text;
  background: transparent;
}
button {
  border-radius: 999px;
  padding: 8px 13px;
  color: @seven_text;
  background: alpha(@seven_panel_2, 0.96);
  border: 1px solid alpha(@seven_border, 0.92);
}
button.suggested-action {
  background: alpha(@seven_accent, 0.28);
  border-color: alpha(@seven_accent, 0.56);
}
button:hover {
  background: @seven_hover;
}
"""


class NotesWindow:
    def __init__(self, quick: bool = False):
        ensure_gi_python()
        import gi

        gi.require_version("Gtk", "3.0")
        gi.require_version("Gdk", "3.0")
        from gi.repository import Gdk, GLib, Gtk, Pango

        self.GLib = GLib
        self.Gtk = Gtk
        self.Pango = Pango
        self.notes = load_notes()
        self.prefs = load_prefs()
        self.selected_id = self.notes[0]["id"] if self.notes else None
        self.save_source = 0

        mode = seven_theme.current_theme_mode() if seven_theme else os.environ.get("SEVENOS_THEME_MODE", "dark")
        css = (seven_theme.gtk_app_css("notes", mode) if seven_theme else "") + CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(css.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.window = Gtk.Window(title="Seven Notes")
        self.window.set_wmclass("SevenNotesNative", "SevenNotesNative")
        self.window.get_style_context().add_class("seven-notes-window")
        self.window.set_position(Gtk.WindowPosition.CENTER)
        self.window.set_default_size(480 if quick else 820, 360 if quick else 560)
        self.window.set_decorated(True)
        self.window.connect("destroy", Gtk.main_quit)

        self.root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        self.root.get_style_context().add_class("notes-shell")
        self.window.add(self.root)
        self.sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self.sidebar.set_size_request(250, -1)
        self.sidebar.get_style_context().add_class("notes-sidebar")
        self.editor = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.editor.get_style_context().add_class("editor-card")
        if not quick:
            self.root.pack_start(self.sidebar, False, False, 0)
        self.root.pack_start(self.editor, True, True, 0)
        self.render()

    def selected_note(self) -> dict | None:
        for item in self.notes:
            if item.get("id") == self.selected_id:
                return item
        return self.notes[0] if self.notes else None

    def render(self) -> None:
        for child in list(self.sidebar.get_children()):
            self.sidebar.remove(child)
        for child in list(self.editor.get_children()):
            self.editor.remove(child)
        self.render_sidebar()
        self.render_editor()
        self.window.show_all()

    def label(self, text: str, css_class: str, wrap: bool = False):
        label = self.Gtk.Label(label=text, xalign=0)
        label.get_style_context().add_class(css_class)
        label.set_ellipsize(self.Pango.EllipsizeMode.END)
        label.set_line_wrap(wrap)
        return label

    def render_sidebar(self) -> None:
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=2)
        header.pack_start(self.label("Seven Notes", "notes-title"), False, False, 0)
        header.pack_start(self.label(tr("Notes locales, rapides et proches du bureau.", "Local, fast notes close to the desktop."), "notes-note", True), False, False, 0)
        self.sidebar.pack_start(header, False, False, 0)
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text(tr("Rechercher", "Search"))
        search.connect("search-changed", lambda entry: self.filter_notes(entry.get_text()))
        self.sidebar.pack_start(search, False, False, 0)
        self.list_box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=6)
        self.sidebar.pack_start(self.list_box, True, True, 0)
        self.populate_list("")
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
        new_button = self.Gtk.Button(label=tr("Nouvelle", "New"))
        new_button.get_style_context().add_class("suggested-action")
        new_button.connect("clicked", lambda *_: self.new_note())
        widget_button = self.Gtk.Button(label=tr("Widget", "Widget"))
        widget_button.connect("clicked", lambda *_: self.enable_widget())
        actions.pack_start(new_button, True, True, 0)
        actions.pack_start(widget_button, True, True, 0)
        self.sidebar.pack_end(actions, False, False, 0)

    def filter_notes(self, query: str) -> None:
        self.populate_list(query)
        self.window.show_all()

    def populate_list(self, query: str) -> None:
        for child in list(self.list_box.get_children()):
            self.list_box.remove(child)
        query = query.lower().strip()
        rows = sorted(self.notes, key=lambda item: (bool(item.get("pinned")), int(item.get("updated") or 0)), reverse=True)
        for item in rows:
            text = f"{item.get('title', '')}\n{item.get('body', '')}".lower()
            if query and query not in text:
                continue
            row = self.Gtk.Button()
            row.get_style_context().add_class("note-row")
            if item.get("id") == self.selected_id:
                row.get_style_context().add_class("active")
            content = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=2)
            title = ("★ " if item.get("pinned") else "") + str(item.get("title") or tr("Sans titre", "Untitled"))
            content.pack_start(self.label(title, "note-row-title"), False, False, 0)
            preview = str(item.get("body") or "").replace("\n", " ").strip()[:90]
            content.pack_start(self.label(preview or tr("Note vide", "Empty note"), "note-row-note"), False, False, 0)
            row.add(content)
            row.connect("clicked", lambda _button, note_id=item.get("id"): self.select_note(str(note_id)))
            self.list_box.pack_start(row, False, False, 0)

    def render_editor(self) -> None:
        note = self.selected_note()
        if note is None:
            note = add_note("", tr("Nouvelle note", "New note"))
            self.notes = load_notes()
            self.selected_id = note["id"]
        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
        self.title_entry = self.Gtk.Entry()
        self.title_entry.set_text(str(note.get("title") or ""))
        self.title_entry.set_placeholder_text(tr("Titre", "Title"))
        self.title_entry.connect("changed", lambda *_: self.queue_save())
        top.pack_start(self.title_entry, True, True, 0)
        pin = self.Gtk.ToggleButton(label="★")
        pin.set_active(bool(note.get("pinned")))
        pin.set_tooltip_text(tr("Épingler", "Pin"))
        pin.connect("toggled", lambda *_: self.queue_save())
        self.pin_button = pin
        delete = self.Gtk.Button(label=tr("Supprimer", "Delete"))
        delete.connect("clicked", lambda *_: self.delete_current())
        top.pack_start(pin, False, False, 0)
        top.pack_start(delete, False, False, 0)
        self.editor.pack_start(top, False, False, 0)

        toolbar = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
        for color, label in (("equinox", "EQ"), ("baobab", "BA"), ("forge", "FO"), ("shield", "SH"), ("studio", "ST"), ("atlas", "AT"), ("pulse", "PU")):
            button = self.Gtk.Button(label=label)
            button.connect("clicked", lambda _b, c=color: self.set_color(c))
            toolbar.pack_start(button, False, False, 0)
        quick = self.Gtk.Button(label=tr("Sur l’accueil", "On Home"))
        quick.connect("clicked", lambda *_: self.enable_widget())
        toolbar.pack_start(quick, False, False, 0)
        self.editor.pack_start(toolbar, False, False, 0)

        scroller = self.Gtk.ScrolledWindow()
        scroller.set_policy(self.Gtk.PolicyType.AUTOMATIC, self.Gtk.PolicyType.AUTOMATIC)
        self.text = self.Gtk.TextView()
        self.text.set_wrap_mode(self.Gtk.WrapMode.WORD_CHAR)
        self.text.get_buffer().set_text(str(note.get("body") or ""))
        self.text.get_buffer().connect("changed", lambda *_: self.queue_save())
        scroller.add(self.text)
        self.editor.pack_start(scroller, True, True, 0)
        self.status = self.label(tr("Sauvegarde automatique locale.", "Local autosave."), "notes-note")
        self.editor.pack_start(self.status, False, False, 0)

    def select_note(self, note_id: str) -> None:
        self.flush_save()
        self.selected_id = note_id
        self.render()

    def new_note(self) -> None:
        self.flush_save()
        item = add_note("", tr("Nouvelle note", "New note"), color=str(self.prefs.get("accent") or "equinox"))
        self.notes = load_notes()
        self.selected_id = item["id"]
        self.render()

    def current_body(self) -> str:
        buffer = self.text.get_buffer()
        start, end = buffer.get_bounds()
        return buffer.get_text(start, end, True)

    def queue_save(self) -> None:
        if self.save_source:
            self.GLib.source_remove(self.save_source)
        self.save_source = self.GLib.timeout_add(450, self.flush_save)

    def flush_save(self):
        self.save_source = 0
        note = self.selected_note()
        if note is None or not hasattr(self, "text"):
            return False
        body = self.current_body()
        title = self.title_entry.get_text().strip() or note_title(body)
        for item in self.notes:
            if item.get("id") == note.get("id"):
                item["title"] = title
                item["body"] = body
                item["pinned"] = bool(self.pin_button.get_active())
                item.setdefault("created", now())
                item["updated"] = now()
                break
        save_notes(self.notes)
        self.status.set_text(tr("Sauvegardé à {time}", "Saved at {time}").format(time=time.strftime("%H:%M")))
        return False

    def set_color(self, color: str) -> None:
        note = self.selected_note()
        if note:
            note["color"] = color
            self.prefs["accent"] = color
            save_prefs(self.prefs)
            self.queue_save()

    def delete_current(self) -> None:
        note = self.selected_note()
        if note is None:
            return
        self.notes = [item for item in self.notes if item.get("id") != note.get("id")]
        save_notes(self.notes)
        self.selected_id = self.notes[0]["id"] if self.notes else None
        self.render()

    def enable_widget(self) -> None:
        subprocess.Popen([str(ROOT / "bin/seven-widgets-native"), "add", "notes"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.Popen([str(ROOT / "bin/seven-widgets-native"), "open"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        self.status.set_text(tr("Widget Notes ajouté à l’accueil.", "Notes widget added to Home."))

    def run(self) -> int:
        self.window.show_all()
        self.Gtk.main()
        return 0


def main() -> int:
    if "--probe" in sys.argv:
        ensure_gi_python()
        print("OK")
        return 0
    if "--json" in sys.argv or (len(sys.argv) > 1 and sys.argv[1] in {"json", "status"}):
        return print_json(status_payload())
    if len(sys.argv) > 1 and sys.argv[1] == "doctor":
        return print_json({"schema": "sevenos.notes.doctor.v1", "state": "ready", "notes": len(load_notes()), "storage": str(NOTES_FILE), "widget": "notes"})
    if len(sys.argv) > 1 and sys.argv[1] == "add":
        text = " ".join(sys.argv[2:]).strip()
        if not text:
            text = sys.stdin.read().strip()
        return print_json(add_note(text or tr("Note rapide", "Quick note")))
    quick = len(sys.argv) > 1 and sys.argv[1] in {"quick", "widget"}
    return NotesWindow(quick=quick).run()


if __name__ == "__main__":
    raise SystemExit(main())
