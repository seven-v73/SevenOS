  local selected="$1"
  case "$selected" in
    "Bluetooth Panel") run_detached seven-waybar-center-native bluetooth ;;
    "Toggle Bluetooth") run_detached seven-bluetooth toggle ;;
    "Scan Devices") run_detached seven-bluetooth scan ;;
    "Device Manager") run_detached seven-bluetooth manager ;;
    "Settings") run_detached seven-settings network ;;
    *) return 0 ;;
  esac
}

run_audio_action() {
  local selected="$1"
  case "$selected" in
    "Volume Mixer") command_or_terminal "SevenOS Audio" pavucontrol "wpctl status" ;;
    "Mute Toggle") run_detached wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
    "Volume Up") run_detached wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ;;
    "Volume Down") run_detached wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ;;
    "Settings") run_detached seven-settings sound ;;
    *) return 0 ;;
  esac
}

run_media_action() {
  local selected="$1"
  case "$selected" in
    "Lecture / pause") run_detached playerctl -p playerctld play-pause ;;
    "Suivant") run_detached playerctl -p playerctld next ;;
    "Précédent") run_detached playerctl -p playerctld previous ;;
    "Stop") run_detached playerctl -p playerctld stop ;;
    "Audio") run_detached seven-quick-settings audio ;;
    *) return 0 ;;
  esac
}

