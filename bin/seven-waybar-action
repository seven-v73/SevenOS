#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/install.sh" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/../install.sh" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/SevenOS" "$HOME/Code/OS/SevenOS"; do
    if [[ -x "$candidate/install.sh" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-waybar-action: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
export SEVENOS_ROOT="$ROOT_DIR"
TARGET_WINDOW_ADDRESS="${SEVENOS_TARGET_WINDOW_ADDRESS:-}"

notify() {
  local title="$1"
  local message="$2"
  if command -v notify-send >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    notify-send "$title" "$message" || true
  else
    printf '%s: %s\n' "$title" "$message"
  fi
}

dry_run() {
  [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]
}

dry_line() {
  printf 'DRY-RUN > %s\n' "$*"
}

run_detached() {
  if dry_run; then
    dry_line "Launch > $*"
    return 0
  fi
  setsid -f "$@" >/tmp/sevenos-waybar-action.log 2>&1 || notify "SevenOS Shell Bar" "Action failed: $*"
}

run_terminal() {
  local title="$1"
  local command="$2"
  local wrapped
  wrapped="$command; printf '\nPress Enter to close...'; read -r"

  if dry_run; then
    dry_line "$title > $command"
    return 0
  fi

  if command -v seven-terminal >/dev/null 2>&1; then
    run_detached seven-terminal focus -- bash -lc "$wrapped"
  elif command -v kitty >/dev/null 2>&1; then
    run_detached kitty --title "$title" bash -lc "$wrapped"
  elif command -v foot >/dev/null 2>&1; then
    run_detached foot -e bash -lc "$wrapped"
  elif command -v alacritty >/dev/null 2>&1; then
    run_detached alacritty -e bash -lc "$wrapped"
  else
    bash -lc "$command"
  fi
}

open_rofi_menu() {
  local prompt="$1"
  shift
  local theme="${SEVENOS_ROFI_THEME:-$HOME/.config/rofi/sevenos.rasi}"
  local message="${SEVENOS_ROFI_MESSAGE:-}"
  if [[ ! -s "$theme" && -s "$ROOT_DIR/hyprland/rofi/$(basename "$theme")" ]]; then
    theme="$ROOT_DIR/hyprland/rofi/$(basename "$theme")"
  fi

  if dry_run; then
    dry_line "$prompt > Open panel"
    printf '%s\n' "$@"
    return 0
  fi

  if ! command -v rofi >/dev/null 2>&1; then
    notify "SevenOS Shell Bar" "SevenOS fallback menu is not installed."
    return 1
  fi

  if [[ -n "$message" ]]; then
    printf '%s\n' "$@" | rofi -dmenu -i -matching fuzzy -p "$prompt" -mesg "$message" -theme "$theme"
  else
    printf '%s\n' "$@" | rofi -dmenu -i -matching fuzzy -p "$prompt" -theme "$theme"
  fi
}

clean_selection() {
  local selected="$1"
  selected="${selected#*  }"
  selected="${selected%%    *}"
  printf '%s\n' "$selected"
}

command_or_terminal() {
  local title="$1"
  local preferred="$2"
  local fallback="$3"

  if command -v "$preferred" >/dev/null 2>&1; then
    run_detached "$preferred"
  else
    run_terminal "$title" "$fallback"
  fi
}

native_panel() {
  local name="$1"
  shift || true
  local local_path="$ROOT_DIR/bin/$name"
  if [[ -x "$local_path" ]] && "$local_path" --probe >/dev/null 2>&1; then
    run_detached "$local_path" "$@"
    return 0
  fi
  if command -v "$name" >/dev/null 2>&1 && "$name" --probe >/dev/null 2>&1; then
    run_detached "$name" "$@"
    return 0
  fi
  return 1
}

native_app_menu_panel() {
  local area="$1"
  local runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
  local request_dir="$runtime_dir/sevenos"
  local request_file="$request_dir/app-menu-request.json"
  local status_file="$request_dir/app-menu-status.json"
  mkdir -p "$request_dir"
  printf '{"area":"%s","time":%s}\n' "$area" "$(date +%s%3N 2>/dev/null || date +%s)" > "$request_file"

  # Keep app menus deterministic: the Waybar click opens a fresh painted panel.
  # Persistent reuse was elegant, but stale GTK surfaces could stay visible while
  # their child content stopped repainting on some Hyprland setups.
  pgrep -u "$USER" -f '(^|/| )seven-app-menu-native( |$)' | while read -r stale_pid; do
    [[ -n "$stale_pid" ]] && kill "$stale_pid" >/dev/null 2>&1 || true
  done
  rm -f "$status_file"
  # UX contract: native_panel seven-app-menu-native file
  native_panel seven-app-menu-native "$area"
}

run_wifi() {
  local helper="$ROOT_DIR/bin/seven-wifi"
  if [[ -x "$helper" ]]; then
    run_detached "$helper" "$@"
  elif command -v seven-wifi >/dev/null 2>&1; then
    run_detached seven-wifi "$@"
  else
    notify "SevenOS Network" "seven-wifi is not installed. Run ./install.sh cli."
  fi
}

run_system_action() {
  local selected="$1"
  case "$selected" in
    "Settings") run_detached seven-settings system ;;
    "Monitor") run_terminal "SevenOS Monitor" "if command -v btop >/dev/null 2>&1; then btop; else top; fi" ;;
    "Updates") run_detached seven-settings system ;;
    "Repair UI") run_detached seven-waybar repair ;;
    *) return 0 ;;
  esac
}

run_sevenos_action() {
  local selected="$1"
  case "$selected" in
    "Éteindre"|"Eteindre") run_detached seven-power poweroff ;;
    "Redémarrer"|"Redemarrer") run_detached seven-power reboot ;;
    "Mise à jour") run_detached seven-settings updates ;;
    *) return 0 ;;
  esac
}

run_profile_action() {
  local selected="$1"
  case "$selected" in
    "Profile Center"|"Centre des espaces") run_detached seven-profile-center-native ;;
    "Workspace"|"Fichiers") run_detached seven-files profile ;;
    "Settings"|"Réglages") run_detached seven-settings profiles ;;
    "Activate Equinox"|"Utiliser Equinox") run_detached seven profile activate equinox ;;
    "Activate Baobab"|"Utiliser Baobab") run_detached seven profile activate baobab ;;
    "Activate Forge"|"Utiliser Forge") run_terminal "SevenOS Forge" "seven profile activate forge" ;;
    "Activate Shield"|"Utiliser Shield") run_terminal "SevenOS Shield" "seven profile activate shield" ;;
    "Activate Studio"|"Utiliser Studio") run_detached seven profile activate studio ;;
    "Activate Windows Bridge"|"Utiliser Windows") run_detached seven profile activate windows ;;
    "Activate Pulse"|"Utiliser Pulse") run_detached seven profile activate pulse ;;
    *) return 0 ;;
  esac
}

run_mini_context_action() {
  local selected="$1"
  case "$selected" in
    "Daily Overview") run_detached seven-overview windows ;;
    "Daily Files") open_path_with_files "$HOME" ;;
    "Daily Settings") run_detached seven-settings ;;
    "Daily Help") run_detached seven-help-native ;;
    "Daily Doctor") run_terminal "SevenOS Doctor" "seven doctor check 2>/dev/null || seven status" ;;
    "Forge Terminal") run_detached seven-terminal forge ;;
    "Forge Logs") run_terminal "SevenOS Forge Logs" "git status --short; printf '\n'; git log --oneline -10" ;;
    "Forge Build") run_terminal "SevenOS Forge Build" "if [[ -x ./build.sh ]]; then ./build.sh; elif [[ -f package.json ]]; then npm run build; elif [[ -f Makefile ]]; then make; else git status --short; fi" ;;
    "Shield Center") run_detached seven-shield-center-native ;;
    "Shield Audit") run_terminal "SevenOS Shield Audit" "seven shield status 2>/dev/null || seven doctor check security" ;;
    "Shield Sandbox") run_terminal "SevenOS Shield Sandbox" "seven shield lab --preset web" ;;
    "Studio Open") run_detached seven-files profile studio ;;
    "Studio Pictures") run_detached seven profile open-folder studio Pictures ;;
    "Studio Videos") run_detached seven profile open-folder studio Videos ;;
    "Studio Media") open_path_with_files "$HOME/Pictures" ;;
    "Studio Exports") open_path_with_files "$HOME/Videos" ;;
    "Studio Recorder") run_detached seven-recorder-native ;;
    "Windows Guide"|"Windows Bridge") run_detached seven-windows-assistant guide ;;
    "Windows Apps") run_detached seven-windows-assistant apps ;;
    "Windows Folders") run_detached seven-files profile windows ;;
    "Windows Repair") run_detached seven-windows-assistant repair ;;
    "Windows Status") run_detached seven-windows-assistant status ;;
    "Pulse Open") run_detached seven-files profile pulse ;;
    "Pulse Games") run_detached seven-hub games ;;
    "Pulse Captures") run_detached seven profile open-folder pulse Videos ;;
    "Pulse Recorder") run_detached seven-recorder-native ;;
    "Pulse Performance") run_detached seven-mini-os-center pulse ;;
    "Baobab Open") run_detached seven-baobab-native ;;
    "Baobab Collections") run_detached seven-files profile baobab ;;
    "Baobab Reader") run_detached seven-reader ;;
    "Baobab Culture") run_detached seven-baobab-native ;;
    "Mini OS Center") run_detached seven-mini-os-center ;;
    *) return 0 ;;
  esac
}

