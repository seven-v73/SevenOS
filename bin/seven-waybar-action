#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/install.sh" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/../install.sh" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/SevenOS" "$HOME/Code/OS/SevenOS"; do
    if [[ -x "$candidate/install.sh" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-waybar-action: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
export SEVENOS_ROOT="$ROOT_DIR"

notify() {
  local title="$1"
  local message="$2"
  if command -v notify-send >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    notify-send "$title" "$message" || true
  else
    printf '%s: %s\n' "$title" "$message"
  fi
}

dry_run() {
  [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]
}

dry_line() {
  printf 'DRY-RUN > %s\n' "$*"
}

run_detached() {
  if dry_run; then
    dry_line "Launch > $*"
    return 0
  fi
  setsid -f "$@" >/tmp/sevenos-waybar-action.log 2>&1 || notify "SevenOS Waybar" "Action failed: $*"
}

run_terminal() {
  local title="$1"
  local command="$2"
  local wrapped
  wrapped="$command; printf '\nPress Enter to close...'; read -r"

  if dry_run; then
    dry_line "$title > $command"
    return 0
  fi

  if command -v kitty >/dev/null 2>&1; then
    run_detached kitty --title "$title" bash -lc "$wrapped"
  elif command -v foot >/dev/null 2>&1; then
    run_detached foot -e bash -lc "$wrapped"
  elif command -v alacritty >/dev/null 2>&1; then
    run_detached alacritty -e bash -lc "$wrapped"
  else
    bash -lc "$command"
  fi
}

open_rofi_menu() {
  local prompt="$1"
  shift

  if dry_run; then
    dry_line "$prompt > Open panel"
    printf '%s\n' "$@"
    return 0
  fi

  if ! command -v rofi >/dev/null 2>&1; then
    notify "SevenOS Waybar" "Rofi is not installed."
    return 1
  fi

  printf '%s\n' "$@" | rofi -dmenu -p "$prompt" -theme "$HOME/.config/rofi/sevenos.rasi"
}

clean_selection() {
  local selected="$1"
  selected="${selected#*  }"
  selected="${selected%%    *}"
  printf '%s\n' "$selected"
}

command_or_terminal() {
  local title="$1"
  local preferred="$2"
  local fallback="$3"

  if command -v "$preferred" >/dev/null 2>&1; then
    run_detached "$preferred"
  else
    run_terminal "$title" "$fallback"
  fi
}

native_panel() {
  local name="$1"
  shift || true
  local local_path="$ROOT_DIR/bin/$name"
  if [[ -x "$local_path" ]] && "$local_path" --probe >/dev/null 2>&1; then
    run_detached "$local_path" "$@"
    return 0
  fi
  if command -v "$name" >/dev/null 2>&1 && "$name" --probe >/dev/null 2>&1; then
    run_detached "$name" "$@"
    return 0
  fi
  return 1
}

run_wifi() {
  local helper="$ROOT_DIR/bin/seven-wifi"
  if [[ -x "$helper" ]]; then
    run_detached "$helper" "$@"
  elif command -v seven-wifi >/dev/null 2>&1; then
    run_detached seven-wifi "$@"
  else
    notify "SevenOS Network" "seven-wifi is not installed. Run ./install.sh cli."
  fi
}

run_system_action() {
  local selected="$1"
  case "$selected" in
    "Settings") run_detached seven-settings system ;;
    "Monitor") run_terminal "SevenOS Monitor" "if command -v btop >/dev/null 2>&1; then btop; else top; fi" ;;
    "Updates") run_detached seven-settings system ;;
    "Repair UI") run_detached seven-waybar repair ;;
    *) return 0 ;;
  esac
}

run_profile_action() {
  local selected="$1"
  case "$selected" in
    "Profile Center") run_detached seven-profile-center-native ;;
    "Workspace") run_detached seven-files profile ;;
    "Settings") run_detached seven-settings profiles ;;
    "Activate Forge") run_terminal "SevenOS Forge" "seven profile activate forge" ;;
    "Activate Shield") run_terminal "SevenOS Shield" "seven profile activate shield" ;;
    "Activate Studio") run_terminal "SevenOS Studio" "seven profile activate studio" ;;
    *) return 0 ;;
  esac
}

run_security_action() {
  local selected="$1"
  case "$selected" in
    "Shield Center") run_detached seven-shield-center-native ;;
    "Enable Shield") run_terminal "SevenOS Shield" "seven shield enable" ;;
    "Cyber Lab") run_terminal "SevenOS Cyber Lab" "seven shield lab --preset web" ;;
    "Settings") run_detached seven-settings security ;;
    *) return 0 ;;
  esac
}

run_network_action() {
  local selected="$1"
  case "$selected" in
    "Wi-Fi Panel") run_wifi menu ;;
    "Disconnect Wi-Fi") run_wifi disconnect ;;
    "Toggle Wi-Fi") run_wifi toggle ;;
    "Settings") run_detached seven-settings network ;;
    *) return 0 ;;
  esac
}

run_audio_action() {
  local selected="$1"
  case "$selected" in
    "Volume Mixer") command_or_terminal "SevenOS Audio" pavucontrol "wpctl status" ;;
    "Mute Toggle") run_detached wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;
    "Volume Up") run_detached wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ;;
    "Volume Down") run_detached wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ;;
    "Settings") run_detached seven-settings sound ;;
    *) return 0 ;;
  esac
}

run_battery_action() {
  local selected="$1"
  case "$selected" in
    "Power Menu") run_detached seven-power ;;
    "Sleep") run_detached seven-power suspend ;;
    "Lock Session") run_detached seven-power lock ;;
    "Settings") run_detached seven-settings power ;;
    *) return 0 ;;
  esac
}

run_clock_action() {
  local selected="$1"
  case "$selected" in
    "Calendar") command_or_terminal "SevenOS Calendar" gnome-calendar "cal -3; printf '\n'; timedatectl" ;;
    "Clock") run_detached seven-spotlight time ;;
    "World Time") run_detached seven-spotlight "world time" ;;
    "Settings") run_detached seven-settings system ;;
    *) return 0 ;;
  esac
}

show_menu() {
  local area="$1"
  local prompt runner
  local -a options
  local selected

  if ! dry_run; then
    case "$area" in
      profile) native_panel seven-profile-center-native && return 0 ;;
      security) native_panel seven-shield-center-native && return 0 ;;
      network) native_panel seven-waybar-center-native network && return 0 ;;
      audio) native_panel seven-waybar-center-native audio && return 0 ;;
      battery) native_panel seven-waybar-center-native power && return 0 ;;
      system) native_panel seven-waybar-center-native system && return 0 ;;
      clock) native_panel seven-waybar-center-native time && return 0 ;;
    esac
  fi

  case "$area" in
    system)
      prompt="System"
      runner="run_system_action"
      options=("󰒓  Settings" "󰍛  Monitor" "󰚰  Updates" "󰜉  Repair UI")
      ;;
    profile)
      prompt="Profiles"
      runner="run_profile_action"
      options=("󰐃  Profile Center" "󰉋  Workspace" "󰒓  Settings" "󰌢  Activate Forge" "󰒃  Activate Shield" "󰏗  Activate Studio")
      ;;
    security)
      prompt="Security"
      runner="run_security_action"
      options=("󰒃  Shield Center" "󰞀  Enable Shield" "󰛵  Cyber Lab" "󰒓  Settings")
      ;;
    network)
      prompt="Network"
      runner="run_network_action"
      options=("󰤨  Wi-Fi Panel" "󰖩  Toggle Wi-Fi" "󰤭  Disconnect Wi-Fi" "󰒓  Settings")
      ;;
    audio)
      prompt="Audio"
      runner="run_audio_action"
      options=("󰕾  Volume Mixer" "󰖁  Mute Toggle" "󰝝  Volume Up" "󰝞  Volume Down" "󰒓  Settings")
      ;;
    battery)
      prompt="Power"
      runner="run_battery_action"
      options=("󰐥  Power Menu" "󰒲  Sleep" "󰍁  Lock Session" "󰒓  Settings")
      ;;
    clock)
      prompt="Time"
      runner="run_clock_action"
      options=("󰃭  Calendar" "󰥔  Clock" "󰀗  World Time" "󰒓  Settings")
      ;;
    network-connect)
      run_wifi connect
      return 0
      ;;
    network-disconnect)
      run_wifi disconnect
      return 0
      ;;
    network-settings)
      run_wifi settings
      return 0
      ;;
    network-status)
      run_terminal "SevenOS Network" "seven-wifi status 2>/dev/null || nmcli device status"
      return 0
      ;;
    *)
      printf 'seven-waybar-action: unknown area: %s\n' "$area" >&2
      exit 1
      ;;
  esac

  if dry_run; then
    open_rofi_menu "$prompt" "${options[@]}"
    return 0
  fi

  selected="$(open_rofi_menu "$prompt" "${options[@]}")"
  selected="$(clean_selection "$selected")"
  "$runner" "$selected"
}

show_menu "${1:-system}"
