  local selected="$1"
  case "$selected" in
    "Power Menu") run_detached seven-power ;;
    "Sleep") run_detached seven-power suspend ;;
    "Lock Session") run_detached seven-power lock ;;
    "Settings") run_detached seven-settings power ;;
    *) return 0 ;;
  esac
}

run_clock_action() {
  local selected="$1"
  case "$selected" in
    "Calendar") command_or_terminal "SevenOS Calendar" gnome-calendar "cal -3; printf '\n'; timedatectl" ;;
    "Clock") run_detached seven-spotlight time ;;
    "World Time") run_detached seven-spotlight "world time" ;;
    "Settings") run_detached seven-settings system ;;
    *) return 0 ;;
  esac
}

active_window_field() {
  local field="$1"
  if ! command -v hyprctl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    return 0
  fi
  hyprctl activewindow -j 2>/dev/null | jq -r ".$field // empty" 2>/dev/null || true
}

capture_target_window() {
  if [[ -z "$TARGET_WINDOW_ADDRESS" ]]; then
    TARGET_WINDOW_ADDRESS="$(active_window_field address)"
  fi
}

focus_target_window() {
  capture_target_window
  if [[ -n "$TARGET_WINDOW_ADDRESS" ]] && command -v hyprctl >/dev/null 2>&1; then
    hyprctl dispatch focuswindow "address:$TARGET_WINDOW_ADDRESS" >/dev/null 2>&1 || true
    sleep 0.06
  fi
}

current_profile_key() {
  local manager="$ROOT_DIR/profiles/profile-manager.sh"
  if [[ -x "$manager" ]] && command -v jq >/dev/null 2>&1; then
    "$manager" current --json 2>/dev/null | jq -r '.key // "equinox"' 2>/dev/null || printf 'equinox\n'
  else
    printf '%s\n' "${SEVENOS_PROFILE:-equinox}"
  fi
}

app_menu_mode() {
  local app_class profile
  app_class="$(active_window_field class)"
  [[ -n "$app_class" ]] || app_class="$(active_window_field initialClass)"
  app_class="${app_class,,}"
  profile="$(current_profile_key)"
  profile="${profile,,}"

  if [[ "$app_class" =~ (code|codium|jetbrains|terminal|kitty) ]]; then
    printf 'developer\n'
  elif [[ "$app_class" =~ (firefox|chrom|brave|browser) ]]; then
    printf 'browser\n'
  elif [[ "$app_class" =~ (nautilus|seven-files|file) ]]; then
    printf 'files\n'
  elif [[ "$profile" == "studio" || "$profile" == "shield" || "$profile" == "windows" || "$profile" == "forge" || "$profile" == "pulse" || "$profile" == "baobab" ]]; then
    printf '%s\n' "$profile"
  else
    printf 'default\n'
  fi
}

app_menu_key() {
  local app_class
  app_class="$(active_window_field class)"
  [[ -n "$app_class" ]] || app_class="$(active_window_field initialClass)"
  app_class="${app_class,,}"
  if [[ "$app_class" == *google-chrome* ]]; then
    printf 'chrome\n'
  elif [[ "$app_class" == *chromium* ]]; then
    printf 'chromium\n'
  elif [[ "$app_class" == *firefox* || "$app_class" == *librewolf* ]]; then
    printf 'firefox\n'
  elif [[ "$app_class" == "code" || "$app_class" == *visual-studio-code* ]]; then
    printf 'vscode\n'
  else
    printf 'generic\n'
  fi
}

app_service_key() {
  local key title
  key="$(app_menu_key)"
  title="$(active_window_field title)"
  title="${title,,}"
  [[ "$key" =~ ^(chrome|chromium|firefox|brave)$ ]] || { printf '\n'; return 0; }
  if [[ "$title" == *youtube* ]]; then
    printf 'youtube\n'
  elif [[ "$title" == *gmail* || ( "$title" == *inbox* && "$title" == *mail* ) ]]; then
    printf 'gmail\n'
  elif [[ "$title" == *"google docs"* || "$title" == *"docs.google"* ]]; then
    printf 'google-docs\n'
  elif [[ "$title" == *"google sheets"* || "$title" == *"sheets.google"* ]]; then
    printf 'google-sheets\n'
  elif [[ "$title" == *"google drive"* || "$title" == *"drive.google"* ]]; then
    printf 'google-drive\n'
  elif [[ "$title" == *github* ]]; then
    printf 'github\n'
  elif [[ "$title" == *figma* ]]; then
    printf 'figma\n'
  elif [[ "$title" == *notion* ]]; then
    printf 'notion\n'
  elif [[ "$title" == *spotify* ]]; then
    printf 'spotify-web\n'
  elif [[ "$title" == *netflix* || "$title" == *"prime video"* || "$title" == *"disney+"* ]]; then
    printf 'streaming\n'
  else
    printf '\n'
  fi
}

copy_active_window_title() {
  local title
  title="$(active_window_field title)"
  if [[ -z "$title" ]]; then
    notify "SevenOS Menu" "No active window title to copy."
    return 0
  fi
  if dry_run; then
    dry_line "Copy window title > $title"
    return 0
  fi
  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$title" | wl-copy
    notify "SevenOS Menu" "Window title copied."
  else
    notify "SevenOS Menu" "wl-copy is not installed."
  fi
}

open_path_with_files() {
  local path="$1"
  if [[ -x "$ROOT_DIR/bin/seven-files" ]]; then
    run_detached "$ROOT_DIR/bin/seven-files" "$path"
  elif command -v seven-files >/dev/null 2>&1; then
    run_detached seven-files "$path"
  else
    run_detached xdg-open "$path"
  fi
}

send_menu_key() {
  local key="$1"
  if dry_run; then
    dry_line "Active app menu > Alt+$key"
    return 0
  fi
  if command -v wtype >/dev/null 2>&1; then
    wtype -M alt -k "$key" -m alt
    return 0
  fi
  if command -v ydotool >/dev/null 2>&1; then
    ydotool key "56:1" "${key}:1" "${key}:0" "56:0" >/dev/null 2>&1 || true
    return 0
  fi
  notify "SevenOS Menu" "Install wtype for native app-menu clicks."
}

send_shortcut() {
  local spec="$1"
  local key modifiers modifier
  IFS='+' read -r -a parts <<<"$spec"
  key="${parts[-1]}"
  modifiers=("${parts[@]:0:${#parts[@]}-1}")
  if dry_run; then
    dry_line "Active app > ${spec}"
    return 0
  fi
  if ! command -v wtype >/dev/null 2>&1; then
    notify "SevenOS Menu" "Install wtype to control the active app from the menu bar."
    return 0
  fi
  focus_target_window
  local -a args=()
  for modifier in "${modifiers[@]}"; do
    [[ -n "$modifier" ]] || continue
    args+=("-M" "${modifier,,}")
  done
  args+=("-k" "${key,,}")
  for ((idx=${#modifiers[@]}-1; idx>=0; idx--)); do
    modifier="${modifiers[$idx]}"
    [[ -n "$modifier" ]] || continue
    args+=("-m" "${modifier,,}")
  done
  wtype "${args[@]}"
}

send_function_key() {
  local key="$1"
  if dry_run; then
    dry_line "Active app > $key"
    return 0
  fi
  if ! command -v wtype >/dev/null 2>&1; then
    notify "SevenOS Menu" "Install wtype to control the active app from the menu bar."
    return 0
  fi
  focus_target_window
  wtype -k "$key"
}

run_active_app_command() {
  local selected="$1"
  case "$selected" in
    "Nouvel onglet"|"New tab") send_shortcut "ctrl+t" ;;
    "Nouvelle fenêtre"|"New window") send_shortcut "ctrl+n" ;;
    "Nouvelle fenêtre privée"|"Fenêtre privée"|"Private window") send_shortcut "ctrl+shift+n" ;;
    "Ouvrir"|"Open") send_shortcut "ctrl+o" ;;
    "Enregistrer"|"Save") send_shortcut "ctrl+s" ;;
    "Imprimer"|"Print") send_shortcut "ctrl+p" ;;
    "Fermer"|"Close") send_shortcut "ctrl+w" ;;
    "Quitter"|"Quit") send_shortcut "ctrl+q" ;;
    "Annuler"|"Undo") send_shortcut "ctrl+z" ;;
    "Rétablir"|"Redo") send_shortcut "ctrl+shift+z" ;;
    "Couper"|"Cut") send_shortcut "ctrl+x" ;;
    "Copier"|"Copy"|"Copier titre"|"Copy title") send_shortcut "ctrl+c" ;;
    "Coller"|"Paste") send_shortcut "ctrl+v" ;;
    "Tout sélectionner"|"Select all") send_shortcut "ctrl+a" ;;
    "Rechercher"|"Search"|"Rechercher mail"|"Search mail") send_shortcut "ctrl+f" ;;
    "Préférences"|"Preferences") send_shortcut "ctrl+comma" ;;
    "Recharger"|"Reload") send_shortcut "ctrl+r" ;;
    "Zoom avant"|"Zoom in") send_shortcut "ctrl+plus" ;;
    "Zoom arrière"|"Zoom out") send_shortcut "ctrl+minus" ;;
    "Taille réelle"|"Actual size") send_shortcut "ctrl+0" ;;
    "Plein écran"|"Full screen") send_function_key "F11" ;;
    "Outils développeur"|"Developer tools") send_shortcut "ctrl+shift+i" ;;
    "Historique"|"History") send_shortcut "ctrl+h" ;;
    "Téléchargements"|"Downloads") send_shortcut "ctrl+j" ;;
    "Barre d'adresse"|"Address bar") send_shortcut "ctrl+l" ;;
    "Rouvrir l'onglet fermé"|"Reopen closed tab") send_shortcut "ctrl+shift+t" ;;
    "Onglet suivant"|"Next tab") send_shortcut "ctrl+Tab" ;;
    "Onglet précédent"|"Previous tab") send_shortcut "ctrl+shift+Tab" ;;
    "Fermer l'onglet"|"Close tab") send_shortcut "ctrl+w" ;;
    "Favoris"|"Marque-pages"|"Favorites"|"Bookmarks") send_shortcut "ctrl+shift+o" ;;
    "Ajouter"|"Ajouter cette page"|"Bookmark this page") send_shortcut "ctrl+d" ;;
    "Lecture / pause"|"Play / pause") send_shortcut "space" ;;
    "Vidéo suivante"|"Next video") send_shortcut "shift+n" ;;
    "Vidéo précédente"|"Previous video") send_shortcut "shift+p" ;;
    "Mode cinéma"|"Theater mode") send_shortcut "t" ;;
    "Sous-titres"|"Subtitles") send_shortcut "c" ;;
    "J'aime"|"Like") send_shortcut "shift+=" ;;
    "Nouveau message"|"New message") send_shortcut "c" ;;
    "Archiver"|"Archive") send_shortcut "e" ;;
    "Spam") send_shortcut "shift+1" ;;
    "Lien"|"Link") send_shortcut "ctrl+k" ;;
    "Palette commandes"|"Command palette") send_shortcut "ctrl+shift+p" ;;
    "Palette terminal"|"Terminal palette") run_detached seven-terminal menu ;;
    "Nouveau terminal"|"New terminal") send_shortcut "ctrl+shift+grave" ;;
    "Terminal doctor") run_terminal "Seven Terminal Doctor" "seven-terminal doctor 2>/dev/null || seven doctor check terminal" ;;
    "Projet Forge"|"Open Forge project") run_detached seven-terminal forge ;;
    "Seven Files Home") open_path_with_files "$HOME" ;;
    "Seven Files profil"|"Seven Files profile") run_detached seven-files profile ;;
    "Exports Studio"|"Studio exports") open_path_with_files "$HOME/Videos" ;;
    "Shield Center") run_detached seven-shield-center-native ;;
    "Sandbox Shield"|"Shield sandbox") run_terminal "SevenOS Shield Sandbox" "seven shield lab --preset web" ;;
    "Windows Assistant") run_detached seven-windows-assistant guide ;;
    "Windows Apps") run_detached seven-windows-assistant apps ;;
    "Jeux Pulse"|"Pulse games") run_detached seven-hub games ;;
    "Collections Baobab"|"Baobab collections") open_path_with_files "$HOME/Documents" ;;
    "Contrôles fenêtre"|"Window controls") run_detached seven-window controls ;;
    "Centrer"|"Center") run_detached hyprctl dispatch centerwindow ;;
    "Flottante"|"Floating") run_detached seven-window toggle-float ;;
    "Split gauche"|"Split left") run_detached seven-window split-left ;;
    "Split droite"|"Split right") run_detached seven-window split-right ;;
    "Aide app active"|"Active app help") send_function_key "F1" ;;
    "Aide SevenOS"|"SevenOS help") run_detached seven-help-native ;;
    *) return 0 ;;
  esac
}

show_active_app_menu() {
  local area="$1"
  local mode prompt runner selected
  local title
  local -a options
  capture_target_window
  title="$(active_window_field title)"
  mode="$(app_menu_mode)"
  runner="run_active_app_command"
  export SEVENOS_ROFI_THEME="$HOME/.config/rofi/app-menu.rasi"
  export SEVENOS_ROFI_MESSAGE="${title:-Application active}"
  case "$area" in
    file)
      if [[ "$(app_menu_key)" =~ ^(chrome|chromium)$ ]]; then
        prompt="Onglets"
        options=("󰝒  Nouvel onglet    Ctrl+T" "󰈔  Nouvelle fenêtre    Ctrl+N" "󰈹  Fenêtre privée    Ctrl+Shift+N" "󰑖  Rouvrir l'onglet fermé    Ctrl+Shift+T" "󰓩  Onglet suivant    Ctrl+Tab" "󰓪  Onglet précédent    Ctrl+Shift+Tab" "󰅖  Fermer l'onglet    Ctrl+W")
      else
        prompt="Fichier"
        options=("󰝒  Nouvel onglet    Ctrl+T" "󰈔  Nouvelle fenêtre    Ctrl+N" "󰈹  Nouvelle fenêtre privée    Ctrl+Shift+N" "󰉋  Ouvrir    Ctrl+O" "󰆓  Enregistrer    Ctrl+S" "󰐪  Imprimer    Ctrl+P" "󰅖  Fermer    Ctrl+W")
      fi
      ;;
    edit)
      prompt="Édition"
      options=("󰕌  Annuler    Ctrl+Z" "󰑎  Rétablir    Ctrl+Shift+Z" "󰅚  Couper    Ctrl+X" "󰆏  Copier    Ctrl+C" "󰆒  Coller    Ctrl+V" "󰒆  Tout sélectionner    Ctrl+A" "󰍉  Rechercher    Ctrl+F")
      ;;
    view)
      prompt="Affichage"
      options=("󰑓  Recharger    Ctrl+R" "󰍉  Zoom avant    Ctrl++" "󰍉  Zoom arrière    Ctrl+-" "󰾆  Taille réelle    Ctrl+0" "󰊓  Plein écran    F11")
      [[ "$mode" == "developer" || "$mode" == "browser" ]] && options+=("󰙨  Outils développeur    Ctrl+Shift+I")
      ;;
    extra)
      case "$mode" in
        browser)
          prompt="Historique"
          options=("󰋚  Historique    Ctrl+H" "󰉍  Téléchargements    Ctrl+J" "󰀂  Barre d'adresse    Ctrl+L")
          ;;
        developer)
          prompt="Terminal"
          options=("󰆍  Palette terminal" "󰒓  Terminal doctor" "󰌢  Projet Forge")
          ;;
        forge)
          prompt="Forge"
          options=("󰌢  Projet Forge" "󰆍  Palette terminal")
          ;;
        files)
          prompt="Aller"
          options=("󰉋  Seven Files Home" "󰉋  Seven Files profil")
          ;;
        studio)
          prompt="Export"
          options=("󰈙  Exports Studio")
          ;;
        shield)
          prompt="Sandbox"
          options=("󰒃  Shield Center" "󰛵  Sandbox Shield")
          ;;
        windows)
          prompt="Windows"
          options=("󰖳  Windows Assistant" "󰿭  Windows Apps")
          ;;
        pulse)
          prompt="Jeux"
          options=("󰓅  Jeux Pulse")
          ;;
        baobab)
          prompt="Collections"
          options=("󰔱  Collections Baobab")
          ;;
        *)
          prompt="Actions"
          options=("󰍉  Rechercher" "󰊓  Plein écran")
          ;;
      esac
      ;;
    tools)
      case "$mode" in
        browser)
          prompt="Favoris"
          options=("󰃀  Favoris" "󰆤  Ajouter cette page    Ctrl+D" "󰈙  Importer")
          ;;
        developer|forge)
          prompt="Terminal"
          options=("󰆍  Nouveau terminal" "󰒓  Terminal doctor" "󰌢  Projet Forge")
          ;;
        files)
          prompt="Actions"
          options=("󰉋  Seven Files Home" "󰉋  Seven Files profil" "󰈙  Exporter sélection")
          ;;
        media)
          prompt="Audio"
          options=("󰕾  Volume" "󰝟  Muet" "󰊓  Plein écran")
          ;;
        shield)
          prompt="Audit"
          options=("󰒃  Shield Center" "󰛵  Audit rapide")
          ;;
        windows)
          prompt="Apps"
          options=("󰿭  Windows Apps" "󰖳  Windows Assistant")
          ;;
        *)
          prompt="Actions"
          options=("󰍉  Rechercher" "󰊓  Plein écran")
          ;;
      esac
      ;;
    window)
      prompt="Fenêtre"
      options=("󰖲  Contrôles fenêtre" "󰉌  Centrer" "󰹑  Flottante" "󰤼  Split gauche" "󰤽  Split droite" "󰅖  Fermer    Ctrl+W")
      ;;
    help)
      prompt="Aide"
      options=("󰋖  Aide app active" "󰋖  Aide SevenOS")
      ;;
    *)
      show_menu app-menu
      return 0
      ;;
  esac
  if dry_run; then
    open_rofi_menu "$prompt" "${options[@]}"
    return 0
  fi
  selected="$(open_rofi_menu "$prompt" "${options[@]}")"
  selected="$(clean_selection "$selected")"
  "$runner" "$selected"
}

run_direct_app_menu() {
  local area="$1"
  local mode
  mode="$(app_menu_mode)"
  case "$area" in
    file)
      case "$(app_menu_key)" in
        chrome|chromium) send_shortcut ctrl+t ;;
        *) send_menu_key f ;;
      esac
      ;;
    edit) send_menu_key e ;;
    view)
      case "$mode" in
        developer) send_menu_key s ;;
        shield) run_detached seven-shield-center-native ;;
        windows) run_detached seven-windows-assistant guide ;;
        *) send_menu_key v ;;
      esac
      ;;
    extra)
      case "$mode" in
        browser) run_detached xdg-open "chrome://history" ;;
        developer|forge) run_detached seven-terminal menu ;;
        files) run_detached seven-files profile ;;
        studio) open_path_with_files "$HOME/Videos" ;;
        shield) run_terminal "SevenOS Shield Sandbox" "seven shield lab --preset web" ;;
        windows) run_detached seven-windows-assistant apps ;;
        pulse) run_detached seven-hub games ;;
        baobab) open_path_with_files "$HOME/Documents" ;;
        *) send_menu_key g ;;
      esac
      ;;
    tools)
      case "$mode" in
        browser) send_shortcut ctrl+d ;;
        developer|forge) run_detached seven-terminal menu ;;
        files) run_detached seven-files profile ;;
        shield) run_detached seven-shield-center-native ;;
        windows) run_detached seven-windows-assistant apps ;;
        *) send_menu_key t ;;
      esac
      ;;
    window) run_detached seven-window controls ;;
    help) send_menu_key h ;;
    *) show_menu app-menu ;;
  esac
}

run_app_menu_action() {
  local selected="$1"
  case "$selected" in
    "Fichier · Nouveau terminal") run_detached seven-terminal focus ;;
    "Fichier · Ouvrir Seven Files") open_path_with_files "$HOME" ;;
    "Fichier · Dossier personnel") open_path_with_files "$HOME" ;;
    "Fichier · Téléchargements") open_path_with_files "$HOME/Downloads" ;;
    "Édition · Copier titre fenêtre") copy_active_window_title ;;
    "Édition · Presse-papiers") run_detached seven-clipboard ;;
    "Affichage · Vue fenêtres") run_detached seven-overview windows ;;
    "Fenêtre · Contrôles") run_detached seven-window controls ;;
    "Fenêtre · Centrer") run_detached hyprctl dispatch centerwindow ;;
    "Fenêtre · Flottante") run_detached seven-window toggle-float ;;
    "Fenêtre · Plein écran") run_detached seven-window fullscreen ;;
    "Fenêtre · Split gauche") run_detached seven-window split-left ;;
    "Fenêtre · Split droite") run_detached seven-window split-right ;;
    "Fenêtre · Fermer") run_detached hyprctl dispatch killactive ;;
    "Terminal · Palette") run_detached seven-terminal menu ;;
    "Terminal · Doctor") run_terminal "Seven Terminal Doctor" "seven-terminal doctor 2>/dev/null || seven doctor check terminal" ;;
    "Forge · Projet Git") run_detached seven-terminal forge ;;
    "Forge · Logs") run_terminal "SevenOS Forge Logs" "git status --short; printf '\n'; git log --oneline -10" ;;
    "Navigateur · Nouvelle fenêtre") run_detached xdg-open about:blank ;;
    "Navigateur · Téléchargements") open_path_with_files "$HOME/Downloads" ;;
    "Seven Files · Home") open_path_with_files "$HOME" ;;
    "Seven Files · Profil actif") run_detached seven-files profile ;;
    "Studio · Médias") open_path_with_files "$HOME/Pictures" ;;
    "Studio · Exports") open_path_with_files "$HOME/Videos" ;;
    "Shield · Centre") run_detached seven-shield-center-native ;;
    "Shield · Audit rapide") run_terminal "SevenOS Shield Audit" "seven shield status 2>/dev/null || seven doctor check security" ;;
    "Windows · Assistant") run_detached seven-windows-assistant guide ;;
    "Windows · Apps") run_detached seven-windows-assistant apps ;;
    "Pulse · Captures") open_path_with_files "$HOME/Videos" ;;
    "Pulse · Jeux") run_detached seven-hub games ;;
    "Baobab · Collections") open_path_with_files "$HOME/Documents" ;;
    "Aide · SevenOS") run_detached seven-help-native ;;
    *) return 0 ;;
  esac
}

show_menu() {
  local area="${1:-system}"
  shift || true
  local prompt runner
  local -a options
  local selected

  if ! dry_run; then
    case "$area" in
      app-file) native_app_menu_panel file && return 0 ;;
      app-edit) native_app_menu_panel edit && return 0 ;;
      app-view) native_app_menu_panel view && return 0 ;;
      app-extra) native_app_menu_panel extra && return 0 ;;
      app-tools) native_app_menu_panel tools && return 0 ;;
      app-window) native_app_menu_panel window && return 0 ;;
      app-help) native_app_menu_panel help && return 0 ;;
      sevenos-menu) native_panel seven-system-menu-native && return 0 ;;
      app-menu-window) native_panel seven-window-controls-native && return 0 ;;
      profile) native_panel seven-profile-center-native && return 0 ;;
      security) native_panel seven-shield-center-native && return 0 ;;
      network) native_panel seven-waybar-center-native network && return 0 ;;
      bluetooth) native_panel seven-waybar-center-native bluetooth && return 0 ;;
      audio) native_panel seven-waybar-center-native audio && return 0 ;;
      media-menu) native_panel seven-media-menu-native && return 0 ;;
      mini-context) native_panel seven-mini-context-menu-native && return 0 ;;
      battery) native_panel seven-waybar-center-native power && return 0 ;;
      system) native_panel seven-waybar-center-native system && return 0 ;;
      clock) native_panel seven-waybar-center-native time && return 0 ;;
    esac
  fi

  case "$area" in
    app-command)
      run_active_app_command "$*"
      return 0
      ;;
    mini-command)
      run_mini_context_action "$*"
      return 0
      ;;
    sevenos-menu)
      prompt="SevenOS"
      runner="run_sevenos_action"
      options=("⏻  Éteindre" "↻  Redémarrer" "⇣  Mise à jour")
      ;;
    app-file)
      show_active_app_menu file
      return 0
      ;;
    app-edit)
      show_active_app_menu edit
      return 0
      ;;
    app-view)
      show_active_app_menu view
      return 0
      ;;
    app-extra)
      show_active_app_menu extra
      return 0
      ;;
    app-tools)
      show_active_app_menu tools
      return 0
      ;;
    app-window)
      show_active_app_menu window
      return 0
      ;;
    app-help)
      show_active_app_menu help
      return 0
      ;;
    system)
      prompt="System"
      runner="run_system_action"
      options=("󰒓  Settings" "󰍛  Monitor" "󰚰  Updates" "󰜉  Repair UI")
      ;;
    profile)
      prompt="Espaces SevenOS"
      runner="run_profile_action"
      options=("󰐃  Centre des espaces" "󰉋  Fichiers" "󰒓  Réglages" "󰘦  Utiliser Equinox" "󰔱  Utiliser Baobab" "󰏗  Utiliser Studio" "󰖳  Utiliser Windows" "󰓅  Utiliser Pulse" "󰌢  Utiliser Forge" "󰒃  Utiliser Shield")
      ;;
    mini-context)
      prompt="Mini OS"
      runner="run_mini_context_action"
      case "$(current_profile_key)" in
        forge) options=("󰆍  Forge Terminal" "󰑭  Forge Logs" "󰒓  Forge Build" "󰐃  Mini OS Center") ;;
        shield) options=("󰒃  Shield Center" "󰛵  Shield Audit" "󰞀  Shield Sandbox" "󰐃  Mini OS Center") ;;
        studio) options=("󰏗  Studio Open" "󰋩  Studio Pictures" "󰕧  Studio Videos" "󰻂  Studio Recorder") ;;
        windows) options=("󰖳  Windows Guide" "󰿭  Windows Apps" "󰉋  Windows Folders" "󰁨  Windows Repair") ;;
        pulse) options=("󰓅  Pulse Open" "󰊴  Pulse Games" "󰹑  Pulse Captures" "󰻂  Pulse Recorder") ;;
        baobab) options=("󰔱  Baobab Open" "󰉋  Baobab Collections" "󰈙  Baobab Reader" "󰐅  Baobab Culture") ;;
        equinox|*) options=("󰕰  Daily Overview" "󰉋  Daily Files" "󰒓  Daily Settings" "󰞋  Daily Help") ;;
      esac
      ;;
    security)
      prompt="Security"
      runner="run_security_action"
      options=("󰒃  Shield Center" "󰞀  Enable Shield" "󰛵  Cyber Lab" "󰒓  Settings")
      ;;
    network)
      prompt="Network"
      runner="run_network_action"
      options=("󰤨  Wi-Fi Panel" "󰖩  Toggle Wi-Fi" "󰤭  Disconnect Wi-Fi" "󰒓  Settings")
      ;;
    bluetooth)
      prompt="Bluetooth"
      runner="run_bluetooth_action"
      options=("󰂯  Bluetooth Panel" "󰖩  Toggle Bluetooth" "󰐢  Scan Devices" "󰂱  Device Manager" "󰒓  Settings")
      ;;
    audio)
      prompt="Audio"
      runner="run_audio_action"
      options=("󰕾  Volume Mixer" "󰖁  Mute Toggle" "󰝝  Volume Up" "󰝞  Volume Down" "󰒓  Settings")
      ;;
    media-menu)
      prompt="Média"
      runner="run_media_action"
      options=("󰐊  Lecture / pause" "󰒭  Suivant" "󰒮  Précédent" "󰓛  Stop" "󰕾  Audio")
      ;;
    battery)
      prompt="Power"
      runner="run_battery_action"
      options=("󰐥  Power Menu" "󰒲  Sleep" "󰍁  Lock Session" "󰒓  Settings")
      ;;
    clock)
      prompt="Time"
      runner="run_clock_action"
      options=("󰃭  Calendar" "󰥔  Clock" "󰀗  World Time" "󰒓  Settings")
      ;;
    app-menu)
      prompt="SevenOS Menu"
      runner="run_app_menu_action"
      options=(
        "󰆍  Fichier · Nouveau terminal"
        "󰉋  Fichier · Ouvrir Seven Files"
        "󰅇  Édition · Copier titre fenêtre"
        "󰅌  Édition · Presse-papiers"
        "󰕰  Affichage · Vue fenêtres"
        "󰖲  Fenêtre · Contrôles"
        "󰉌  Fenêtre · Centrer"
        "󰹑  Fenêtre · Flottante"
        "󰊓  Fenêtre · Plein écran"
        "󰤼  Fenêtre · Split gauche"
        "󰤽  Fenêtre · Split droite"
        "󰅖  Fenêtre · Fermer"
      )
      case "$(app_menu_mode)" in
        developer)
          options+=("󰆍  Terminal · Palette" "󰒓  Terminal · Doctor" "󰌢  Forge · Projet Git" "󰑭  Forge · Logs")
          ;;
        forge)
          options+=("󰌢  Forge · Projet Git" "󰑭  Forge · Logs" "󰆍  Terminal · Palette")
          ;;
        browser)
          options+=("󰈹  Navigateur · Nouvelle fenêtre" "󰉍  Navigateur · Téléchargements")
          ;;
        files)
          options+=("󰉋  Seven Files · Home" "󰉋  Seven Files · Profil actif" "󰉍  Fichier · Téléchargements")
          ;;
        studio)
          options+=("󰏗  Studio · Médias" "󰈙  Studio · Exports")
          ;;
        shield)
          options+=("󰒃  Shield · Centre" "󰛵  Shield · Audit rapide")
          ;;
        windows)
          options+=("󰖳  Windows · Assistant" "󰿭  Windows · Apps")
          ;;
        pulse)
          options+=("󰓅  Pulse · Jeux" "󰹑  Pulse · Captures")
          ;;
        baobab)
          options+=("󰔱  Baobab · Collections")
          ;;
      esac
      options+=("󰋖  Aide · SevenOS")
      ;;
    app-menu-window)
      prompt="Window"
      runner="run_app_menu_action"
      options=("󰖲  Fenêtre · Contrôles" "󰉌  Fenêtre · Centrer" "󰹑  Fenêtre · Flottante" "󰊓  Fenêtre · Plein écran" "󰤼  Fenêtre · Split gauche" "󰤽  Fenêtre · Split droite" "󰅖  Fenêtre · Fermer")
      ;;
    network-connect)
      run_wifi connect
      return 0
      ;;
    network-disconnect)
      run_wifi disconnect
      return 0
      ;;
    network-settings)
      run_wifi settings
      return 0
      ;;
    network-status)
      run_terminal "SevenOS Network" "seven-wifi status 2>/dev/null || nmcli device status"
      return 0
      ;;
    *)
      printf 'seven-waybar-action: unknown area: %s\n' "$area" >&2
      exit 1
      ;;
  esac

  if dry_run; then
    open_rofi_menu "$prompt" "${options[@]}"
    return 0
  fi

  selected="$(open_rofi_menu "$prompt" "${options[@]}")"
  selected="$(clean_selection "$selected")"
  "$runner" "$selected"
}

show_menu "$@"
