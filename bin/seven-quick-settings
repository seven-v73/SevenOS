#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT/hyprland/rofi" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/../hyprland/rofi" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -d "$candidate/hyprland/rofi" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root)"
THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/quick-settings.rasi"

dry_line() {
  printf 'DRY-RUN > Quick Settings > %s\n' "$*"
}

clean_selection() {
  local selected="$1"
  selected="${selected#*  }"
  selected="${selected%%    *}"
  printf '%s\n' "$selected"
}

run_detached() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    dry_line "Launch > $*"
    return 0
  fi
  setsid -f "$@" >/tmp/sevenos-quick-settings.log 2>&1 || true
}

run_terminal() {
  local title="$1"
  local command="$2"
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    dry_line "$title > $command"
    return 0
  fi

  if command -v kitty >/dev/null 2>&1; then
    run_detached kitty --title "$title" bash -lc "$command; printf '\nPress Enter to close...'; read -r"
  else
    bash -lc "$command"
  fi
}

menu() {
  cat <<'EOF'
󰒓  Control Center
󰀻  Apps Overview
󰖲  Window Overview
󰤨  Network Settings
󰕾  Audio Mixer
󰸉  Wallpaper Refresh
󰉋  Profile Workspace
󰁯  Migration Plan
󰍛  System Monitor
󰐥  Power Menu
EOF
}

if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
  dry_line "Open panel"
  menu
  exit 0
fi

if [[ "${SEVENOS_PANEL_FALLBACK:-0}" != "1" ]] &&
   command -v seven-shell-panel >/dev/null 2>&1 &&
   seven-shell-panel status >/dev/null 2>&1; then
  seven-shell-panel quick
  exit $?
fi

if ! command -v rofi >/dev/null 2>&1; then
  printf 'seven-quick-settings: rofi is required\n' >&2
  exit 1
fi

selected="$(menu | rofi -dmenu -i -p "SevenOS" -mesg "Quick Settings" -theme "$THEME" 2>/dev/null || true)"
selected="$(clean_selection "$selected")"

case "$selected" in
  "Control Center"*) run_detached seven hub ;;
  "Apps Overview"*) run_detached seven-overview apps ;;
  "Window Overview"*) run_detached seven-overview windows ;;
  "Network Settings"*)
    if command -v nm-connection-editor >/dev/null 2>&1; then
      run_detached nm-connection-editor
    else
      run_terminal "SevenOS Network" "nmtui"
    fi
    ;;
  "Audio Mixer"*)
    if command -v pavucontrol >/dev/null 2>&1; then
      run_detached pavucontrol
    else
      run_terminal "SevenOS Audio" "wpctl status"
    fi
    ;;
  "Wallpaper Refresh"*) run_terminal "SevenOS Wallpaper" "seven-wallpaper refresh" ;;
  "Profile Workspace"*) run_detached seven-files profile ;;
  "Migration Plan"*) run_terminal "SevenOS Migration" "seven migrate plan" ;;
  "System Monitor"*)
    if command -v btop >/dev/null 2>&1; then
      run_detached kitty --title "SevenOS Monitor" btop
    else
      run_terminal "SevenOS Monitor" "top"
    fi
    ;;
  "Power Menu"*) run_detached seven-power ;;
  "") exit 0 ;;
esac
