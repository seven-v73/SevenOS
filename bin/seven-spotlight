#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/scripts/actions.sh" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/../scripts/actions.sh" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -x "$candidate/scripts/actions.sh" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-spotlight: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
export SEVENOS_ROOT="$ROOT_DIR"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
THEME="$CONFIG_HOME/rofi/spotlight.rasi"

notify() {
  local title="$1"
  local message="$2"
  if command -v notify-send >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    notify-send "$title" "$message" || true
  else
    printf '%s: %s\n' "$title" "$message"
  fi
}

dry_run() {
  [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]
}

url_encode() {
  python - "$1" <<'PY'
import sys
from urllib.parse import quote_plus
print(quote_plus(sys.argv[1]))
PY
}

open_url() {
  local url="$1"
  if dry_run; then
    printf 'DRY-RUN > Spotlight > Open URL > %s\n' "$url"
    return 0
  fi
  if command -v xdg-open >/dev/null 2>&1; then
    setsid -f xdg-open "$url" >/tmp/sevenos-spotlight.log 2>&1 || notify "SevenOS Spotlight" "Could not open URL."
  else
    notify "SevenOS Spotlight" "xdg-open is not installed."
    return 1
  fi
}

open_path() {
  local path="$1"
  if dry_run; then
    printf 'DRY-RUN > Spotlight > Open path > %s\n' "$path"
    return 0
  fi
  if command -v xdg-open >/dev/null 2>&1; then
    setsid -f xdg-open "$path" >/tmp/sevenos-spotlight.log 2>&1 || notify "SevenOS Spotlight" "Could not open path."
  else
    notify "SevenOS Spotlight" "xdg-open is not installed."
    return 1
  fi
}

desktop_catalog() {
  python - <<'PY'
import os
from pathlib import Path

def truthy(value):
    return str(value).strip().lower() in {"1", "true", "yes"}

def fallback_icon(categories):
    cats = {item for item in categories.split(";") if item}
    if "Development" in cats:
        return "applications-development"
    if "Graphics" in cats or "AudioVideo" in cats:
        return "applications-graphics"
    if "Network" in cats:
        return "applications-internet"
    if "System" in cats or "Settings" in cats:
        return "preferences-system"
    if "Utility" in cats:
        return "applications-utilities"
    if "Game" in cats:
        return "applications-games"
    if "Office" in cats:
        return "applications-office"
    return "application-x-executable"

def read_desktop(path):
    data = {}
    in_entry = False
    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None
    for raw in content.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            in_entry = line == "[Desktop Entry]"
            continue
        if not in_entry or "=" not in line:
            continue
        key, value = line.split("=", 1)
        data.setdefault(key.strip(), value.strip())
    if data.get("Type", "Application") != "Application":
        return None
    if truthy(data.get("Hidden", "false")):
        return None
    if truthy(data.get("NoDisplay", "false")) and os.environ.get("SEVENOS_APPS_SHOW_HIDDEN") != "1":
        return None
    name = data.get("Name") or data.get("Name[en_US]") or path.stem
    exec_value = data.get("Exec", "")
    if not exec_value:
        return None
    comment = data.get("Comment", "")
    categories = data.get("Categories", "")
    icon = data.get("Icon") or fallback_icon(categories)
    return name, path.name, str(path), comment, icon

data_dirs = [
    Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share")),
    Path.home() / ".local/share/flatpak/exports/share",
    Path("/var/lib/flatpak/exports/share"),
]
for raw in os.environ.get("XDG_DATA_DIRS", "/usr/local/share:/usr/share").split(":"):
    if raw:
        data_dirs.append(Path(raw))

seen = set()
apps = []
for base in data_dirs:
    app_dir = base / "applications"
    if not app_dir.is_dir():
        continue
    for path in app_dir.glob("*.desktop"):
        resolved = str(path)
        if resolved in seen:
            continue
        seen.add(resolved)
        item = read_desktop(path)
        if item:
            apps.append(item)

for name, desktop_id, path, comment, icon in sorted(apps, key=lambda item: item[0].casefold()):
    print("\t".join(value.replace("\t", " ") for value in ("app", f"󰀻  App · {name}", desktop_id, path, comment, icon)))
PY
}

action_catalog() {
  ACTION_JSON="$("$ROOT_DIR/scripts/actions.sh" --json)" python - <<'PY'
import json
import os
import sys

icons = {
    "Desktop": ("󰇄", "preferences-desktop"),
    "System": ("󰒓", "preferences-system"),
    "Profiles": ("󰀻", "avatar-default"),
    "Security": ("󰒃", "security-high"),
    "Windows": ("󰖳", "computer"),
    "Server": ("󰒋", "network-server"),
    "Installer": ("󰏗", "system-software-install"),
    "Apps": ("󰀻", "applications-other"),
    "Ecosystem": ("󰌢", "applications-science"),
}

try:
    payload = json.loads(os.environ.get("ACTION_JSON", "{}"))
except Exception:
    payload = {"actions": []}

for item in payload.get("actions", []):
    action_id = item.get("id", "")
    title = item.get("title", action_id)
    category = item.get("category", "System")
    command = item.get("command", "")
    description = item.get("description", "")
    glyph, icon = icons.get(category, ("󰐊", "system-run"))
    label = f"{glyph}  {category} · {title}"
    print("\t".join(value.replace("\t", " ") for value in ("action", label, action_id, command, description, icon)))
PY
}

