#!/usr/bin/env bash
set -Eeuo pipefail

usage() {
  cat <<'EOF'
Seven Files

Usage:
  seven-files [open|menu|profile|read|reader|wallpaper|windows|doctor|home|downloads|documents|code|projects|pictures|videos|music|trash|recent] [path]
  seven-files resources [status|mini|shared|toggle]

Seven Files opens the preferred graphical file manager with SevenOS fallbacks.
Use "seven-files reader" to open Seven Reader, or "seven-files reader DOCUMENT" to open a document.
Use "seven-files wallpaper IMAGE" to set a Hyprland/SevenOS wallpaper from a file manager action.
Use "seven-files windows FILE" to launch .exe/.msi files through Bottles, Wine or Lutris.
Use "seven-files doctor --json" to check native runtime, window rules and storage helpers.
EOF
}

FILES_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/sevenos"
FILES_DOCTOR_CACHE="$FILES_CACHE_DIR/files-doctor.json"
FILES_DOCTOR_CACHE_TTL="${SEVENOS_FILES_DOCTOR_CACHE_TTL:-300}"
FILES_DOCTOR_REFRESH="${SEVENOS_FILES_DOCTOR_REFRESH:-0}"

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/bin/seven" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/seven" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/SevenOS" "$HOME/Code/OS/SevenOS"; do
    if [[ -x "$candidate/bin/seven" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

is_dry_run() {
  [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]
}

normalize_target() {
  local target="$1"
  if [[ "$target" == file://* ]]; then
    python - "$target" <<'PY'
from urllib.parse import unquote, urlparse
import sys

parsed = urlparse(sys.argv[1])
print(unquote(parsed.path or sys.argv[1].removeprefix("file://")))
PY
  else
    printf '%s\n' "$target"
  fi
}

active_profile() {
  local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos"
  local profile="${SEVENOS_ACTIVE_PROFILE:-}"

  if [[ -z "$profile" && -f "$config_dir/profile.env" ]]; then
    profile="$(awk -F= '/^SEVENOS_ACTIVE_PROFILE=/{gsub(/["'\'']/, "", $2); print $2; exit}' "$config_dir/profile.env")"
  fi
  if [[ -z "$profile" && -f "$config_dir/runtime.json" ]]; then
    profile="$(python - "$config_dir/runtime.json" <<'PY'
import json, sys
try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
    profile = data.get("active_profile") or data.get("profile") or ""
    if isinstance(profile, dict):
        profile = profile.get("key") or profile.get("id") or ""
    print(str(profile))
except Exception:
    print("")
PY
)"
  fi

  profile="${profile:-equinox}"
  profile="${profile//[^a-zA-Z0-9_-]/}"
  printf '%s\n' "${profile:-equinox}"
}

files_prefs_path() {
  printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/files-prefs.json"
}

grouped_resources_enabled() {
  local prefs
  prefs="$(files_prefs_path)"
  [[ -f "$prefs" ]] || return 1
  python - "$prefs" <<'PY'
import json, sys
try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
    raise SystemExit(0 if data.get("grouped_resources") is True else 1)
except SystemExit:
    raise
except Exception:
    raise SystemExit(1)
PY
}

set_grouped_resources() {
  local value="$1"
  local prefs
  prefs="$(files_prefs_path)"
  mkdir -p "$(dirname -- "$prefs")"
  python - "$prefs" "$value" <<'PY'
import json, sys
from pathlib import Path

path = Path(sys.argv[1])
value = sys.argv[2].lower() == "true"
try:
    data = json.loads(path.read_text(encoding="utf-8")) if path.exists() else {}
    if not isinstance(data, dict):
        data = {}
except Exception:
    data = {}
data["grouped_resources"] = value
path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

resource_root() {
  local profile
  profile="$(active_profile)"
  if [[ "$profile" == "equinox" ]] || grouped_resources_enabled; then
    printf '%s\n' "$HOME"
  else
    printf '%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}/sevenos/profile-containers/$profile/home"
  fi
}

resource_path() {
  local key="${1:-home}"
  local root
  root="$(resource_root)"
  case "$key" in
    home) printf '%s\n' "$root" ;;
    downloads|download|telechargements|tÃĐlÃĐchargements) printf '%s\n' "$root/Downloads" ;;
    documents|docs) printf '%s\n' "$root/Documents" ;;
    code|projects|project|projets) printf '%s\n' "$root/Code" ;;
    pictures|images|photos) printf '%s\n' "$root/Pictures" ;;
    videos|video|vidÃĐos) printf '%s\n' "$root/Videos" ;;
    music|musique|audio) printf '%s\n' "$root/Music" ;;
    *) printf '%s\n' "$root" ;;
  esac
}

open_path() {
  local target="$1"
  local manager native
  target="$(normalize_target "$target")"
  native="$(resolve_root || true)/bin/seven-files-native"

  if is_dry_run; then
    printf 'open files %q with native Seven Files surface\n' "$target"
    return 0
  fi

  if [[ -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
    setsid -f "$native" "$target" >/tmp/sevenos-files.log 2>&1
    return 0
  fi

  configure_nautilus_preferences

  if command -v nautilus >/dev/null 2>&1; then
    setsid -f nautilus --new-window "$target" >/tmp/sevenos-files.log 2>&1
    return 0
  fi

  for manager in nautilus nemo thunar dolphin pcmanfm; do
    if command -v "$manager" >/dev/null 2>&1; then
      setsid -f "$manager" "$target" >/tmp/sevenos-files.log 2>&1
      return 0
    fi
  done

  if command -v xdg-open >/dev/null 2>&1; then
    setsid -f xdg-open "$target" >/tmp/sevenos-files.log 2>&1
    return 0
  fi

  printf 'seven-files: no graphical file manager found\n' >&2
  printf 'Install the SevenOS base layer or run: sudo pacman -S --needed nautilus gvfs file-roller\n' >&2
  return 1
}

configure_nautilus_preferences() {
  command -v gsettings >/dev/null 2>&1 || return 0

  gsettings set org.gnome.nautilus.preferences default-folder-viewer 'icon-view' >/dev/null 2>&1 || true
  gsettings set org.gnome.nautilus.icon-view default-zoom-level 'large' >/dev/null 2>&1 || true
  gsettings set org.gnome.nautilus.list-view default-zoom-level 'standard' >/dev/null 2>&1 || true
  gsettings set org.gnome.nautilus.preferences show-create-link true >/dev/null 2>&1 || true
  gsettings set org.gnome.nautilus.preferences show-delete-permanently true >/dev/null 2>&1 || true
  gsettings set org.gtk.Settings.FileChooser sort-directories-first true >/dev/null 2>&1 || true
  gsettings set org.gnome.desktop.interface gtk-decoration-layout 'close,minimize,maximize:' >/dev/null 2>&1 || true
}

ensure_dirs() {
  local dir
  local root
  is_dry_run && return 0

  root="$(resource_root)"
  for dir in "$root" "$root/Desktop" "$root/Documents" "$root/Downloads" "$root/Pictures" "$root/Videos" "$root/Music" "$root/Code" "$root/Templates" "$root/Public"; do
    [[ -d "$dir" ]] || mkdir -p "$dir"
  done
  mkdir -p "$root/.config"
  cat >"$root/.config/user-dirs.dirs" <<'EOF'
XDG_DESKTOP_DIR="$HOME/Desktop"
XDG_DOWNLOAD_DIR="$HOME/Downloads"
XDG_TEMPLATES_DIR="$HOME/Templates"
XDG_PUBLICSHARE_DIR="$HOME/Public"
XDG_DOCUMENTS_DIR="$HOME/Documents"
XDG_MUSIC_DIR="$HOME/Music"
XDG_PICTURES_DIR="$HOME/Pictures"
XDG_VIDEOS_DIR="$HOME/Videos"
EOF
}

menu() {
  local choice
  local options

  options=$(
    cat <<EOF
ó°  Home
ó°ē  Code
ó°  Downloads
ó°  Documents
ó°  Pictures
ó°§  Videos
ó°  Music
ó°  Shared Home
ó°  Recent
ó°Đš  Trash
ó°  Root
ó°  SevenOS Repo
EOF
  )

  if is_dry_run; then
    printf 'rofi places menu\n'
    return 0
  fi

  if command -v rofi >/dev/null 2>&1; then
    choice="$(printf '%s\n' "$options" | rofi -dmenu -p "Seven Files" -theme "${XDG_CONFIG_HOME:-$HOME/.config}/rofi/sevenos.rasi")"
  else
    printf '%s\n' "$options"
    printf 'Choice: '
    IFS= read -r choice
  fi

  choice="${choice#*  }"
  choice="${choice%%    *}"

  case "$choice" in
    Home) open_path "$(resource_path home)" ;;
    Code|Projects) open_path "$(resource_path code)" ;;
    Downloads) open_path "$(resource_path downloads)" ;;
    Documents) open_path "$(resource_path documents)" ;;
    Pictures) open_path "$(resource_path pictures)" ;;
    Videos) open_path "$(resource_path videos)" ;;
    Music) open_path "$(resource_path music)" ;;
    "Shared Home") open_path "$HOME" ;;
    Recent) open_path "recent:///" ;;
    Trash) open_path "trash:///" ;;
    Root) open_path "/" ;;
    "SevenOS Repo")
      if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT" ]]; then
        open_path "$SEVENOS_ROOT"
      else
        open_path "$HOME"
      fi
      ;;
    "") ;;
    *) open_path "$choice" ;;
  esac
}

resources_command() {
  local action="${1:-status}"
  local profile root mode
  profile="$(active_profile)"
  root="$(resource_root)"
  mode="mini-os"
  grouped_resources_enabled && mode="shared"

  case "$action" in
    status|"")
      printf 'Seven Files resources: %s\n' "$mode"
      printf 'Active mini OS: %s\n' "$profile"
      printf 'Root: %s\n' "$root"
      ;;
    mini|mini-os|isolated|profile)
      set_grouped_resources false
      ensure_dirs
      printf 'Seven Files resources now follow the active mini OS.\n'
      ;;
    shared|global|grouped)
      set_grouped_resources true
      ensure_dirs
      printf 'Seven Files resources now use shared user folders.\n'
      ;;
    toggle)
      if grouped_resources_enabled; then
        set_grouped_resources false
        printf 'Seven Files resources now follow the active mini OS.\n'
      else
        set_grouped_resources true
        printf 'Seven Files resources now use shared user folders.\n'
      fi
      ensure_dirs
      ;;
    *)
      printf 'seven-files: unknown resources action: %s\n' "$action" >&2
      return 1
      ;;
  esac
}

open_profile_workspace() {
  local root
  root="$(resolve_root || true)"

  if [[ -n "$root" ]]; then
    SEVENOS_ROOT="$root" "$root/bin/seven" profile open "${1:-}" || return $?
  else
    open_path "$HOME"
  fi
}

set_wallpaper() {
  local image="${1:-}"
  local root

  if [[ -z "$image" ]]; then
    printf 'seven-files: missing wallpaper image path\n' >&2
    return 1
  fi

  if is_dry_run; then
    printf 'set SevenOS wallpaper %q\n' "$image"
    return 0
  fi

  root="$(resolve_root || true)"
  if [[ -n "$root" && -x "$root/bin/seven-wallpaper" ]]; then
    SEVENOS_ROOT="$root" "$root/bin/seven-wallpaper" set "$image"
  elif command -v seven-wallpaper >/dev/null 2>&1; then
    seven-wallpaper set "$image"
  else
    printf 'seven-files: seven-wallpaper command not found\n' >&2
    return 1
  fi
}

read_document() {
  local document="${1:-}"
  local root reader

  root="$(resolve_root || true)"
  reader="$root/bin/seven-reader"

  if is_dry_run; then
    if [[ -n "$document" ]]; then
      printf 'open %q with Seven Reader immersive surface\n' "$document"
    else
      printf 'open Seven Reader immersive library\n'
    fi
    return 0
  fi

  if [[ -n "$document" ]]; then
    document="$(normalize_target "$document")"
  fi

  if [[ -n "$root" && -x "$reader" ]]; then
    if [[ -n "$document" ]]; then
      setsid -f "$reader" open "$document" >/tmp/sevenos-reader.log 2>&1
    else
      setsid -f "$reader" library >/tmp/sevenos-reader.log 2>&1
    fi
    return 0
  fi

  if command -v seven-reader >/dev/null 2>&1; then
    if [[ -n "$document" ]]; then
      setsid -f seven-reader open "$document" >/tmp/sevenos-reader.log 2>&1
    else
      setsid -f seven-reader library >/tmp/sevenos-reader.log 2>&1
    fi
    return 0
  fi

  printf 'seven-files: seven-reader command not found\n' >&2
  return 1
}

run_windows_file() {
  local file="${1:-}"
  local root helper
  if [[ -z "$file" ]]; then
    printf 'seven-files: missing Windows app file\n' >&2
    return 1
  fi
  file="$(normalize_target "$file")"
  root="$(resolve_root || true)"
  helper="$root/bin/seven-wincompat"
  if is_dry_run; then
    if [[ -n "$root" && -x "$helper" ]]; then
      SEVENOS_DRY_RUN=1 "$helper" run "$file" --dry-run
    else
      printf 'run Windows app file %q through SevenOS compatibility layer\n' "$file"
    fi
    return 0
  fi
  if [[ -n "$root" && -x "$helper" ]]; then
    "$helper" run "$file"
  elif command -v seven-wincompat >/dev/null 2>&1; then
    seven-wincompat run "$file"
  else
    printf 'seven-files: seven-wincompat command not found\n' >&2
    return 1
  fi
}

doctor_command() {
  local format=""
  local deep="0"
  local arg
  for arg in "$@"; do
    case "$arg" in
      --json) format="--json" ;;
      --deep) deep="1" ;;
      --refresh|--no-cache) FILES_DOCTOR_REFRESH=1 ;;
    esac
  done
  if [[ "$format" == "--json" && "$deep" != "1" && "$FILES_DOCTOR_REFRESH" != "1" ]] &&
     [[ -s "$FILES_DOCTOR_CACHE" ]] &&
     python -m json.tool "$FILES_DOCTOR_CACHE" >/dev/null 2>&1; then
    local now mtime
    now="$(date +%s)"
    mtime="$(stat -c %Y "$FILES_DOCTOR_CACHE" 2>/dev/null || printf 0)"
    if (( now - mtime < FILES_DOCTOR_CACHE_TTL )); then
      cat "$FILES_DOCTOR_CACHE"
      return 0
    fi
  fi
  local root native prefs hypr_user hypr_repo wrapper
  root="$(resolve_root || true)"
  native="$root/bin/seven-files-native"
  prefs="$(files_prefs_path)"
  hypr_user="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/conf/sevenos-lua-generated.conf"
  hypr_repo="$root/hyprland/conf/sevenos-lua-generated.conf"
  wrapper="${BASH_SOURCE[0]}"

  local payload rc
  set +e
  payload="$(python - "$format" "$deep" "$root" "$native" "$prefs" "$hypr_user" "$hypr_repo" "$wrapper" <<'PY'
import json, os, subprocess, sys
from pathlib import Path

fmt, deep, root, native, prefs, hypr_user, hypr_repo, wrapper = sys.argv[1:9]

def cmd_ok(command):
    return subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0

checks = []
native_path = Path(native)
wrapper_text = Path(wrapper).read_text(encoding="utf-8", errors="ignore") if Path(wrapper).exists() else ""
hypr_text = ""
for item in (hypr_user, hypr_repo):
    path = Path(item)
    if path.exists():
        hypr_text += "\n" + path.read_text(encoding="utf-8", errors="ignore")

checks.append({"key": "root", "ok": bool(root) and Path(root).exists(), "detail": root or "missing"})
checks.append({"key": "native", "ok": native_path.exists() and os.access(native_path, os.X_OK), "detail": str(native_path)})
checks.append({"key": "native-probe", "ok": native_path.exists() and cmd_ok([str(native_path), "--probe"]), "detail": "seven-files-native --probe"})
checks.append({"key": "window-rule", "ok": "SevenFilesNative" in hypr_text and "size 700 500" in hypr_text and "center" in hypr_text, "detail": "Hyprland floating centered rule"})
settle_name = "settle_native_" + "window"
checks.append({
    "key": "no-delayed-wrapper-center",
    "ok": f"{settle_name}() {{" not in wrapper_text and f"\n    {settle_name}" not in wrapper_text,
    "detail": "wrapper does not move window after launch",
})
checks.append({"key": "udisks", "ok": cmd_ok(["sh", "-lc", "command -v udisksctl >/dev/null 2>&1"]), "detail": "external disk mount helper"})
helper_path = Path(root) / "bin" / "seven-disk-mount" if root else Path("/missing/seven-disk-mount")
checks.append({
    "key": "admin-disk-mount",
    "ok": helper_path.exists() and os.access(helper_path, os.X_OK) and cmd_ok(["sh", "-lc", "command -v pkexec >/dev/null 2>&1"]),
    "detail": "administrator mount helper for internal Windows/data disks",
})
checks.append({
    "key": "polkit-agent",
    "ok": cmd_ok(["sh", "-lc", "pgrep -u \"$USER\" -f '^/usr/lib/polkit-kde-authentication-agent-1($| )|^/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1($| )|lxqt-policykit-agent|mate-polkit' >/dev/null 2>&1"]),
    "detail": "graphical administrator prompts are available",
})
checks.append({
    "key": "settings-update-auth",
    "ok": (Path(root) / "bin" / "seven-update-admin").exists() and (Path(root) / "bin" / "seven-askpass").exists() and cmd_ok(["sh", "-lc", "command -v zenity >/dev/null 2>&1 || command -v kdialog >/dev/null 2>&1 || command -v yad >/dev/null 2>&1"]),
    "detail": "Settings can request update authorization graphically",
})
checks.append({"key": "gvfs", "ok": cmd_ok(["sh", "-lc", "command -v gio >/dev/null 2>&1"]), "detail": "GIO/GVFS file operations"})
native_text = native_path.read_text(encoding="utf-8", errors="ignore") if native_path.exists() else ""
checks.append({
    "key": "deferred-drive-scan",
    "ok": "schedule_drive_scan" in native_text and "render_location_rows(False)" in native_text,
    "detail": "drive scan is deferred after the first paint",
})
checks.append({
    "key": "stable-selection-bar",
    "ok": "No selection" in native_text and "selection_bar.set_size_request(-1, 38)" in native_text,
    "detail": "selection controls keep a stable bottom band",
})
checks.append({
    "key": "large-folder-soft-limit",
    "ok": "SCAN_SOFT_LIMIT" in native_text and "os.scandir" in native_text,
    "detail": "large folders use a bounded first scan",
})
checks.append({
    "key": "drive-error-feedback",
    "ok": "drive_error_state" in native_text and "show_drive_error_details" in native_text,
    "detail": "drive failures keep visible details in the drive panel",
})

prefs_state = "missing"
try:
    data = json.loads(Path(prefs).read_text(encoding="utf-8"))
    prefs_state = "sidebar visible" if data.get("sidebar_visible", True) is not False else "sidebar hidden"
    checks.append({"key": "sidebar-default", "ok": data.get("sidebar_visible", True) is not False, "detail": prefs_state})
except Exception:
    checks.append({"key": "sidebar-default", "ok": True, "detail": prefs_state})

if deep == "1":
    geometry = "not-running"
    geometry_ok = True
    try:
        result = subprocess.run(["hyprctl", "-j", "clients"], text=True, capture_output=True, check=False, timeout=2)
        clients = json.loads(result.stdout or "[]") if result.returncode == 0 else []
        matches = [item for item in clients if item.get("class") == "SevenFilesNative" or "Seven Files" in str(item.get("title", ""))]
        if matches:
            item = matches[-1]
            size = item.get("size") or []
            at = item.get("at") or []
            floating = bool(item.get("floating"))
            geometry = f"at={at} size={size} floating={floating}"
            geometry_ok = floating and len(size) == 2 and int(size[0]) >= 500 and int(size[1]) >= 430
    except Exception as exc:
        geometry = f"unknown: {exc}"
        geometry_ok = True
    checks.append({"key": "live-geometry", "ok": geometry_ok, "detail": geometry})

ok = all(item["ok"] for item in checks)
payload = {"schema": "sevenos.files.doctor.v1", "ready": ok, "state": "ready" if ok else "needs-attention", "deep": deep == "1", "checks": checks}
if fmt == "--json":
    print(json.dumps(payload, ensure_ascii=False, indent=2))
else:
    print(f"Seven Files: {payload['state']}")
    for item in checks:
        print(f"[{'OK' if item['ok'] else 'MISS'}] {item['key']}: {item['detail']}")
raise SystemExit(0 if ok else 1)
PY
)"
  rc=$?
  set -e
  if [[ "$format" == "--json" && "$deep" != "1" && "$rc" -eq 0 ]]; then
    mkdir -p "$FILES_CACHE_DIR"
    local tmp
    tmp="$(mktemp "${FILES_DOCTOR_CACHE}.XXXXXX")"
    printf '%s\n' "$payload" >"$tmp"
    if python -m json.tool "$tmp" >/dev/null 2>&1; then
      mv -f "$tmp" "$FILES_DOCTOR_CACHE"
    else
      rm -f "$tmp"
    fi
  fi
  printf '%s\n' "$payload"
  return "$rc"
}

ensure_dirs

action="${1:-open}"
target="${2:-}"

case "$action" in
  open)
    open_path "${target:-$(resource_path home)}"
    ;;
  menu|places)
    menu
    ;;
  profile|workspace)
    open_profile_workspace "$target"
    ;;
  wallpaper|set-wallpaper)
    set_wallpaper "$target"
    ;;
  windows|win|exe|msi)
    run_windows_file "$target"
    ;;
  doctor|check)
    doctor_command "${@:2}"
    ;;
  read|reader|book)
    read_document "$target"
    ;;
  home)
    open_path "$(resource_path home)"
    ;;
  downloads)
    open_path "$(resource_path downloads)"
    ;;
  documents)
    open_path "$(resource_path documents)"
    ;;
  code)
    open_path "$(resource_path code)"
    ;;
  projects)
    open_path "$(resource_path code)"
    ;;
  pictures)
    open_path "$(resource_path pictures)"
    ;;
  videos)
    open_path "$(resource_path videos)"
    ;;
  music)
    open_path "$(resource_path music)"
    ;;
  resources|resource-mode)
    resources_command "$target"
    ;;
  recent)
    open_path "recent:///"
    ;;
  trash)
    open_path "trash:///"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    open_path "$action"
    ;;
esac
