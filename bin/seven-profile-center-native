    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenProfileCenterNative")
    GLib.set_application_name(tr_text("Espaces SevenOS"))
    try:
        Gdk.set_program_class("SevenProfileCenterNative")
    except Exception:
        pass

    css = seven_theme.gtk_app_css("profile-center") + """
    * { font-family: "SF Pro Display", "SF UI Display", "San Francisco", system-ui, sans-serif; }
    window.profile-center-window { background: transparent; }
