#!/usr/bin/env python3
"""Compact SevenOS profile center for Waybar."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()


def run_json(*args: str):
    try:
        out = subprocess.check_output([str(ROOT / "bin/seven"), *args], cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
        return json.loads(out)
    except Exception:
        return []


def run_detached(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def probe() -> int:
    ensure_gi_python()
    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def state_class(state: str) -> str:
    return {"OK": "good", "PART": "warn", "MISS": "bad"}.get(state, "warn")


def run() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenProfileCenterNative")
    GLib.set_application_name("SevenOS Profiles")
    try:
        Gdk.set_program_class("SevenProfileCenterNative")
    except Exception:
        pass

    css = """
    * { font-family: "SF Pro Display", "SF UI Display", "San Francisco", system-ui, sans-serif; }
    window.profile-center-window { background: transparent; }
    .profile-root {
      padding: 16px;
      border-radius: 30px;
      background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(230,244,249,0.66)), rgba(255,255,255,0.58);
      border: 1px solid rgba(255,255,255,0.84);
    }
    .title { color: rgba(16,27,34,0.98); font-size: 18px; font-weight: 500; }
    .subtitle { color: rgba(42,58,68,0.62); font-size: 11px; }
    .tile {
      min-height: 96px;
      padding: 12px;
      border-radius: 22px;
      background: rgba(255,255,255,0.52);
      border: 1px solid rgba(255,255,255,0.72);
      color: rgba(20,34,44,0.96);
    }
    .tile:hover { background: rgba(255,255,255,0.80); border-color: rgba(91,127,166,0.30); }
    .tile.good { border-color: rgba(90,173,114,0.30); background: rgba(90,173,114,0.08); }
    .tile.warn { border-color: rgba(111,157,188,0.34); background: rgba(111,157,188,0.08); }
    .tile.bad { border-color: rgba(196,103,58,0.28); background: rgba(196,103,58,0.08); }
    .glyph { font-size: 24px; }
    .tile-title { font-size: 13px; font-weight: 500; }
    .tile-note { color: rgba(44,60,70,0.66); font-size: 11px; }
    .action-strip {
      padding: 12px;
      border-radius: 22px;
      background: rgba(255,255,255,0.46);
      border: 1px solid rgba(255,255,255,0.68);
    }
    .icon-action {
      min-width: 44px;
      min-height: 44px;
      padding: 0;
      border-radius: 999px;
      background: rgba(255,255,255,0.58);
      border: 1px solid rgba(255,255,255,0.76);
    }
    .icon-action:hover { background: rgba(255,255,255,0.84); }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    profiles = run_json("profile", "status", "--json")
    active = next((item for item in profiles if item.get("active")), None)

    window = Gtk.Window(title="SevenOS Profiles")
    window.set_wmclass("SevenProfileCenterNative", "SevenProfileCenterNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(520, 430)
    window.get_style_context().add_class("profile-center-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.get_style_context().add_class("profile-root")
    window.add(root)

    title = Gtk.Label(label="Profiles", xalign=0)
    title.get_style_context().add_class("title")
    root.pack_start(title, False, False, 0)
    subtitle = Gtk.Label(label=f"Active: {active.get('title', 'None') if active else 'None'}", xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    root.pack_start(subtitle, False, False, 0)

    grid = Gtk.Grid()
    grid.set_column_spacing(10)
    grid.set_row_spacing(10)
    root.pack_start(grid, True, True, 0)

    for index, profile in enumerate(profiles[:6]):
        title_text = profile.get("title", profile.get("key", "Profile"))
        state = profile.get("state", "MISS")
        installed = profile.get("installed", 0)
        total = profile.get("total", 0)
        command = f"seven profile activate {profile['key']}" if state == "OK" else f"seven profile install {profile['key']}"
        if profile.get("active"):
            command = f"seven profile open {profile['key']}"
        button = profile_tile(Gtk, title_text[:1].upper(), title_text, "active" if profile.get("active") else f"{installed}/{total}", command, state_class(state))
        grid.attach(button, index % 3, index // 3, 1, 1)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    actions.set_halign(Gtk.Align.CENTER)
    actions.get_style_context().add_class("action-strip")
    root.pack_end(actions, False, False, 0)
    for glyph, tooltip, command in [
        ("󰉋", "Open workspace", "seven-files profile"),
        ("󰞋", "Profile guide", "seven profile guide"),
        ("󰀻", "Profile apps", "seven profile apps"),
        ("󰒓", "Open Hub", "seven-hub-native open"),
    ]:
        button = Gtk.Button()
        button.get_style_context().add_class("icon-action")
        button.set_tooltip_text(tooltip)
        button.add(Gtk.Label(label=glyph))
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        actions.pack_start(button, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def profile_tile(Gtk, glyph: str, title: str, note: str, command: str, css_class: str):
    button = Gtk.Button()
    button.get_style_context().add_class("tile")
    button.get_style_context().add_class(css_class)
    button.set_tooltip_text(command)
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    icon = Gtk.Label(label=glyph)
    icon.get_style_context().add_class("glyph")
    label = Gtk.Label(label=title)
    label.get_style_context().add_class("tile-title")
    meta = Gtk.Label(label=note)
    meta.get_style_context().add_class("tile-note")
    box.pack_start(icon, False, False, 0)
    box.pack_start(label, False, False, 0)
    box.pack_start(meta, False, False, 0)
    button.add(box)
    button.connect("clicked", lambda _button: run_detached(command))
    return button


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    return run()


if __name__ == "__main__":
    raise SystemExit(main())
