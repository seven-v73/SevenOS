        .node-glyph { color: rgba(28,31,38,0.84); }
        .prism-wordmark {
          color: rgba(28,31,38,0.90);
          background: rgba(47,123,255,0.08);
          border-color: rgba(47,123,255,0.16);
        }
        """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    profiles = run_json("profile", "status", "--json")
    runtime = run_json("runtime", "status", "--json")
    isolation = run_json("profile", "isolation", "status", "--json")
    migration = run_json("profile", "migrate-aliases", "--json")
    catalog = load_catalog()
    theme_profiles = load_profile_themes()
    active = next((item for item in profiles if item.get("active")), None)

    window = Gtk.Window(title=t("Espaces SevenOS", "SevenOS Spaces"))
    window.set_wmclass("SevenProfileCenterNative", "SevenProfileCenterNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(940, 650)
    window.get_style_context().add_class("profile-center-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.get_style_context().add_class("profile-root")
    window.add(root)

    topbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    topbar.get_style_context().add_class("topbar")
    root.pack_start(topbar, False, False, 0)

    title = Gtk.Label(label=t("Espaces SevenOS", "SevenOS Spaces"), xalign=0)
    title.get_style_context().add_class("title")
    topbar.pack_start(title, True, True, 0)
    controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    topbar.pack_end(controls, False, False, 0)
    count_pill = Gtk.Label(label=t("{count} espaces", "{count} spaces").format(count=str(len(profiles))))
    count_pill.get_style_context().add_class("pill")
    controls.pack_start(count_pill, False, False, 0)
    settings_button = Gtk.Button(label=t("Réglages", "Settings"))
    settings_button.get_style_context().add_class("window-action")
    settings_button.connect("clicked", lambda _button: run_detached("seven-settings profiles"))
    controls.pack_start(settings_button, False, False, 0)
    close_button = Gtk.Button(label=t("Fermer", "Close"))
    close_button.get_style_context().add_class("window-action")
    close_button.connect("clicked", lambda _button: Gtk.main_quit())
    controls.pack_start(close_button, False, False, 0)

    active_key = str(active.get("key", "")) if active else ""
    active_label = localized_profile_title(active_key, str(active.get("title") or "")) if active else t("Aucun", "None")
    subtitle_text = t("Espace actif : {profile}", "Active space: {profile}").format(profile=active_label)
    if active_key in PUBLIC_PROFILE_NOTES:
        subtitle_text += f" · {PUBLIC_PROFILE_NOTES[active_key]}"
    subtitle = Gtk.Label(label=subtitle_text, xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    root.pack_start(subtitle, False, False, 0)

    if isinstance(migration, dict) and int(migration.get("pending") or 0) > 0:
        root.pack_start(alias_migration_panel(Gtk, migration), False, False, 0)

    root.pack_start(
        prism_panel(
            Gtk,
            GLib,
            Gdk,
            profiles if isinstance(profiles, list) else [],
            catalog if isinstance(catalog, dict) else {},
            theme_profiles,
            active_key,
        ),
        True,
        True,
        0,
    )

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    actions.set_halign(Gtk.Align.CENTER)
    actions.get_style_context().add_class("action-strip")
    root.pack_end(actions, False, False, 0)
    for glyph, tooltip, command in [
        ("󰉋", t("Ouvrir les fichiers", "Open files"), "seven-files profile"),
        ("󰡱", t("Ouvrir l'espace actif", "Open active space"), f"seven profile center {active.get('key', '')}" if active else "seven profile center"),
        ("󰀻", t("Voir les applications", "View applications"), "seven profile apps"),
        ("󰁨", t("Réparer cet espace", "Repair this space"), "seven-settings profiles"),
        ("󰞋", t("Aide SevenOS", "SevenOS Help"), "seven-help-native mini-os"),
        ("󰒓", t("Ouvrir le Hub", "Open Hub"), "seven-hub-native open"),
    ]:
        button = Gtk.Button()
        button.get_style_context().add_class("icon-action")
        button.set_tooltip_text(tooltip)
        button.add(Gtk.Label(label=glyph))
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        actions.pack_start(button, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def composition_panel(Gtk, runtime: dict, isolation: dict):
    panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
    panel.get_style_context().add_class("section")

    primary = runtime.get("primary_profile", {})
    composite = runtime.get("composite_runtime", {})
    resource = runtime.get("resource_plan", {})
    doctor = runtime.get("doctor", {})
    injected = composite.get("injected_profiles") or []
    active_count = isolation.get("active_package_count", 0)
    inactive_count = isolation.get("inactive_package_count", 0)

    title = Gtk.Label(label=t("Préparation de l’espace", "Space preparation"), xalign=0)
    title.get_style_context().add_class("section-title")
    panel.pack_start(title, False, False, 0)

    summary = Gtk.Label(
        label=t(
            "Espace principal : {primary} · outils ajoutés : {injected} · éléments prêts : {active} / {inactive} en attente",
            "Primary space: {primary} · added tools: {injected} · ready items: {active} / {inactive} waiting",
        ).format(
            primary=localized_profile_title(str(primary.get("key") or composite.get("primary") or ""), str(primary.get("title") or composite.get("primary") or "unknown")),
            injected=", ".join(injected) if injected else t("aucun", "none"),
            active=active_count,
            inactive=inactive_count,
        ),
        xalign=0,
    )
    summary.get_style_context().add_class("section-note")
    panel.pack_start(summary, False, False, 0)

    details = Gtk.Label(
        label=t(
            "Performance : {cpu} · mémoire : {ram} · éléments isolés : {services} · reprise : {snapshot}",
            "Performance: {cpu} · memory: {ram} · isolated items: {services} · resume: {snapshot}",
        ).format(
            cpu=resource.get("cpu", {}).get("strategy", "unknown"),
            ram=resource.get("ram", {}).get("strategy", "unknown"),
            services=resource.get("isolation", {}).get("services", "unknown"),
            snapshot=t("prête", "ready") if any(item.get("name") == "criu" and item.get("state") == "OK" for item in doctor.get("checks", [])) else t("prévue", "planned"),
        ),
        xalign=0,
    )
    details.get_style_context().add_class("danger-note")
    panel.pack_start(details, False, False, 0)
    return panel


def public_profile_panel(Gtk, key: str):
    panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    panel.get_style_context().add_class("section")

    title = Gtk.Label(label=t("Ce que cet espace prépare", "What this space prepares"), xalign=0)
    title.get_style_context().add_class("section-title")
    panel.pack_start(title, False, False, 0)

    grid = Gtk.Grid()
    grid.set_column_spacing(8)
    grid.set_row_spacing(8)
    panel.pack_start(grid, False, False, 0)
    for index, (name, value) in enumerate(PUBLIC_PROFILE_DETAILS.get(key, [])):
        grid.attach(layer_card(Gtk, name, value), index % 4, index // 4, 1, 1)
    return panel


def color_tuple(hex_color: str, alpha: float = 1.0) -> tuple[float, float, float, float]:
    text = str(hex_color or "").strip().lstrip("#")
    if len(text) != 6:
        return (0.54, 0.49, 1.0, alpha)
    try:
        return (int(text[0:2], 16) / 255, int(text[2:4], 16) / 255, int(text[4:6], 16) / 255, alpha)
    except Exception:
        return (0.54, 0.49, 1.0, alpha)


def prism_panel(Gtk, GLib, Gdk, profiles: list[dict], catalog: dict, theme_profiles: dict, active_key: str):
    profile_by_key = {str(item.get("key", "")): item for item in profiles if isinstance(item, dict)}
    naming = catalog.get("profile_naming", {}) if isinstance(catalog.get("profile_naming"), dict) else {}
    profile_defs = catalog.get("profiles", {}) if isinstance(catalog.get("profiles"), dict) else {}
    order = ["equinox", "baobab", "forge", "shield", "pulse", "windows", "studio"]
    outer_order = ["baobab", "forge", "shield", "pulse", "windows", "studio"]
    positions = {
        "equinox": (242, 172, 176, 68),
        "baobab": (257, 20, 146, 64),
        "forge": (476, 96, 146, 64),
        "shield": (476, 260, 146, 64),
        "pulse": (257, 330, 146, 66),
        "windows": (38, 260, 146, 64),
        "studio": (38, 96, 146, 64),
    }
    centers = {key: (x + w / 2, y + h / 2) for key, (x, y, w, h) in positions.items()}
    pulse = {"value": 0.0}

    panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
    panel.set_can_focus(True)
    panel.add_events(Gdk.EventMask.KEY_PRESS_MASK)
    panel.get_style_context().add_class("prism-panel")

    header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    header_title = Gtk.Label(label=t("Seven Prism · Mini OS", "Seven Prism · Mini OS"), xalign=0)
    header_title.get_style_context().add_class("prism-title")
    header_note = Gtk.Label(
        label=t(
            "Equinox est le centre. Les six sommets spécialisés gardent leur rôle et se relient à lui explicitement.",
            "Equinox is the center. The six specialized vertices keep their role and link to it explicitly.",
        ),
        xalign=0,
    )
    header_note.set_line_wrap(True)
    header_note.get_style_context().add_class("prism-note")
    header_copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    header_copy.set_hexpand(True)
    header_copy.pack_start(header_title, False, False, 0)
    header_copy.pack_start(header_note, False, False, 0)
    header.pack_start(header_copy, True, True, 0)
    active_badge = Gtk.Label(label=t("Equinox Core", "Equinox Core"))
    active_badge.get_style_context().add_class("pill")
    header.pack_end(active_badge, False, False, 0)
    wordmark = Gtk.Label(label="SevenOS Prism")
    wordmark.get_style_context().add_class("prism-wordmark")
    header.pack_end(wordmark, False, False, 0)
    panel.pack_start(header, False, False, 0)

    content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    panel.pack_start(content, True, True, 0)

    stage = Gtk.Overlay()
    stage.set_size_request(660, 414)
    stage.get_style_context().add_class("prism-stage")
    drawing = Gtk.DrawingArea()
    drawing.set_size_request(660, 414)
    fixed = Gtk.Fixed()
    fixed.set_size_request(660, 414)

    inspector = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    inspector.set_size_request(210, -1)
    inspector.get_style_context().add_class("prism-inspector")
    inspector_title = Gtk.Label(xalign=0)
    inspector_title.get_style_context().add_class("inspector-title")
    inspector_note = Gtk.Label(xalign=0)
    inspector_note.set_line_wrap(True)
    inspector_note.set_max_width_chars(28)
    inspector_note.get_style_context().add_class("inspector-note")
    inspector_role = Gtk.Label(xalign=0)
    inspector_role.set_line_wrap(True)
    inspector_role.set_max_width_chars(28)
    inspector_role.get_style_context().add_class("danger-note")
    inspector_actions = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    inspector_actions.get_style_context().add_class("inspector-actions")
    action_open = Gtk.Button()
    action_open.get_style_context().add_class("inspector-action")
    action_open.get_style_context().add_class("primary")
    action_activate = Gtk.Button()
    action_activate.get_style_context().add_class("inspector-action")
    action_files = Gtk.Button()
    action_files.get_style_context().add_class("inspector-action")
    inspector_actions.pack_start(action_open, False, False, 0)
    inspector_actions.pack_start(action_activate, False, False, 0)
    inspector_actions.pack_start(action_files, False, False, 0)
    inspector.pack_start(inspector_title, False, False, 0)
    inspector.pack_start(inspector_note, False, False, 0)
    inspector.pack_start(inspector_role, False, False, 0)
    inspector.pack_end(inspector_actions, False, False, 0)
    selected_key = {"value": active_key if active_key in positions else "equinox"}
    node_by_key = {}

    def profile_title(key: str) -> str:
        profile = profile_by_key.get(key, {})
        theme = theme_profiles.get(key, {}) if isinstance(theme_profiles.get(key), dict) else {}
        fallback = str(profile.get("title") or theme.get("label") or naming.get(key) or key.title())
        return localized_profile_title(key, fallback)

    def profile_icon(key: str) -> str:
        profile = profile_by_key.get(key, {})
        theme = theme_profiles.get(key, {}) if isinstance(theme_profiles.get(key), dict) else {}
        return str(profile.get("waybar_icon") or theme.get("icon") or profile_title(key)[:1].upper())

    def profile_note(key: str) -> str:
        profile = profile_by_key.get(key, {})
        if key == active_key:
            return t("actif maintenant", "active now")
        if key in PUBLIC_PROFILE_NOTES:
            return PUBLIC_PROFILE_NOTES[key]
        state = str(profile.get("state") or "MISS")
        installed = profile.get("installed", 0)
        total = profile.get("total", 0)
        return f"{state} · {installed}/{total}"

    def center_command(key: str) -> str:
        if key == "equinox":
            return "seven-settings profiles"
        definition = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
        surfaces = definition.get("profile_surfaces", {}) if isinstance(definition.get("profile_surfaces"), dict) else {}
        return str(surfaces.get("center") or definition.get("center_command") or f"seven-mini-os-center {key}")

    def run_selected(kind: str) -> None:
        key = selected_key["value"]
        if kind == "open":
            run_detached(center_command(key))
        elif kind == "activate":
            action_activate.set_sensitive(False)
            action_activate.set_label(t("Préparation…", "Preparing…"))
            active_badge.set_text(t("Passage en cours", "Switching"))
            wordmark.set_text(t("SevenOS prépare {profile}", "SevenOS is preparing {profile}").format(profile=profile_title(key)))
            node = node_by_key.get(key)
            if node is not None:
                node.get_style_context().add_class("switching")
            drawing.queue_draw()
            run_detached(f"seven profile activate {key}")
            GLib.timeout_add(1450, lambda: (Gtk.main_quit(), False)[1])
        elif kind == "files":
            run_detached(f"seven-files profile {key}")

    def describe(key: str) -> None:
        selected_key["value"] = key
        profile = profile_by_key.get(key, {})
        theme = theme_profiles.get(key, {}) if isinstance(theme_profiles.get(key), dict) else {}
        definition = profile_defs.get(key, {}) if isinstance(profile_defs.get(key), dict) else {}
        inspector_title.set_text(profile_title(key))
        fallback_note = str(theme.get("ui_mood") or definition.get("purpose") or "")
        inspector_note.set_text(localized_profile_mood(key, fallback_note) or PUBLIC_PROFILE_NOTES.get(key) or profile_note(key))
        relation = (
            t("Sommet central : host/admin, réglages et arbitrage des ressources.", "Central vertex: host/admin, settings and resource arbitration.")
            if key == "equinox"
            else t("Relié à Equinox par activation explicite, sans charger silencieusement les autres piles.", "Linked to Equinox through explicit activation, without silently loading other stacks.")
        )
        inspector_role.set_text(relation)
        action_open.set_label(t("Ouvrir le centre", "Open center") if key != "equinox" else t("Ouvrir les réglages", "Open settings"))
        action_activate.set_label(t("Actif", "Active") if key == active_key else t("Activer ce sommet", "Activate vertex"))
        action_activate.set_sensitive(key != active_key)
        action_files.set_label(t("Voir les fichiers", "View files"))
        active_badge.set_text(t("Actif", "Active") if key == active_key else profile_note(key))
        wordmark.set_text(profile_title(key))
        for node_key, node in node_by_key.items():
            context = node.get_style_context()
            if node_key == key:
                context.add_class("selected")
            else:
                context.remove_class("selected")
        drawing.queue_draw()

    action_open.connect("clicked", lambda _button: run_selected("open"))
    action_activate.connect("clicked", lambda _button: run_selected("activate"))
    action_files.connect("clicked", lambda _button: run_selected("files"))

    key_targets = {
        Gdk.KEY_1: "equinox",
        Gdk.KEY_2: "baobab",
        Gdk.KEY_3: "forge",
        Gdk.KEY_4: "shield",
        Gdk.KEY_5: "pulse",
        Gdk.KEY_6: "windows",
        Gdk.KEY_7: "studio",
    }

    def handle_key(_widget, event) -> bool:
        if event.keyval in key_targets:
            describe(key_targets[event.keyval])
            return True
        if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter}:
            run_selected("open")
            return True
        if event.keyval in {Gdk.KEY_a, Gdk.KEY_A}:
            if selected_key["value"] != active_key:
                run_selected("activate")
            return True
        if event.keyval in {Gdk.KEY_f, Gdk.KEY_F}:
            run_selected("files")
            return True
        return False

    panel.connect("key-press-event", handle_key)

    def draw_prism(_area, cr) -> bool:
        phase = pulse["value"]
        equinox_center = centers["equinox"]

        outer_points = [centers[key] for key in outer_order]
        inner_points = [
            (
                equinox_center[0] + (point[0] - equinox_center[0]) * 0.42,
                equinox_center[1] + (point[1] - equinox_center[1]) * 0.42,
            )
            for point in outer_points
        ]

        for radius, alpha, width in ((168, 0.030, 18), (122, 0.042, 10)):
            cr.set_source_rgba(0.30, 0.62, 1.0, alpha + 0.010 * math.sin(phase))
            cr.set_line_width(width)
            cr.arc(equinox_center[0], equinox_center[1], radius, 0, math.pi * 2)
            cr.stroke()

        for index, key in enumerate(outer_order):
            a = outer_points[index]
            b = outer_points[(index + 1) % len(outer_points)]
            fill = color_tuple((theme_profiles.get(key, {}) or {}).get("accent"), 0.060 + 0.018 * math.sin(phase + index))
            cr.set_source_rgba(*fill)
            cr.move_to(*equinox_center)
            cr.line_to(*a)
            cr.line_to(*b)
            cr.close_path()
            cr.fill()

        cr.set_source_rgba(0.05, 0.06, 0.10, 0.10)
        cr.move_to(*inner_points[0])
        for point in inner_points[1:]:
            cr.line_to(*point)
        cr.close_path()
        cr.fill()

        cr.set_line_width(1.4)
        for index, key in enumerate(outer_order):
            a = outer_points[index]
            b = outer_points[(index + 1) % len(outer_points)]
            edge = color_tuple((theme_profiles.get(key, {}) or {}).get("accent"), 0.22)
            cr.set_source_rgba(*edge)
            cr.move_to(*a)
            cr.line_to(*b)
            cr.stroke()

        cr.set_line_width(1.0)
        for index in range(len(inner_points)):
            a = inner_points[index]
            b = inner_points[(index + 1) % len(inner_points)]
            cr.set_source_rgba(0.88, 0.93, 1.0, 0.16)
            cr.move_to(*a)
            cr.line_to(*b)
            cr.stroke()

        for index, key in enumerate(outer_order):
            point = outer_points[index]
            color = color_tuple((theme_profiles.get(key, {}) or {}).get("accent"), 0.30)
            highlighted = key == selected_key.get("value")
            cr.set_line_width(2.8 if highlighted else 1.5)
            cr.set_source_rgba(*color)
            cr.move_to(*equinox_center)
            cr.line_to(*point)
            cr.stroke()

            inner = inner_points[index]
            cr.set_line_width(2.4 if highlighted else (2.2 if key == active_key else 1.1))
            cr.set_source_rgba(0.93, 0.96, 1.0, 0.34 if highlighted else (0.26 if key == active_key else 0.12))
            cr.move_to(*inner)
            cr.line_to(*point)
            cr.stroke()

            cr.arc(point[0], point[1], 5.2 if highlighted else (4.4 if key == active_key else 3.2), 0, math.pi * 2)
            cr.set_source_rgba(*color_tuple((theme_profiles.get(key, {}) or {}).get("accent"), 0.72 if highlighted else (0.64 if key == active_key else 0.44)))
            cr.fill()

        cr.set_line_width(2.0)
        cr.set_source_rgba(0.30, 0.64, 1.0, 0.28)
        cr.move_to(*outer_points[0])
        for point in outer_points[1:]:
            cr.line_to(*point)
        cr.close_path()
        cr.stroke()

        highlight_key = selected_key.get("value") or active_key
        active_center = centers.get(highlight_key, centers["equinox"])
        radius = 46 + math.sin(phase) * 5
        color = color_tuple((theme_profiles.get(highlight_key, {}) or {}).get("accent"), 0.18)
        cr.arc(active_center[0], active_center[1], radius, 0, math.pi * 2)
        cr.set_source_rgba(*color)
        cr.fill()

        mark_radius = 44
        mark_points = [
            (
                equinox_center[0] + math.cos(-math.pi / 2 + index * math.pi / 3) * mark_radius,
                equinox_center[1] + math.sin(-math.pi / 2 + index * math.pi / 3) * mark_radius,
            )
            for index in range(6)
        ]
        cr.set_source_rgba(0.03, 0.04, 0.07, 0.16)
        cr.move_to(*mark_points[0])
        for point in mark_points[1:]:
            cr.line_to(*point)
        cr.close_path()
        cr.fill()
        cr.set_line_width(1.4)
        for index, point in enumerate(mark_points):
            cr.set_source_rgba(0.30, 0.64, 1.0, 0.32 if index % 2 == 0 else 0.22)
            cr.move_to(*equinox_center)
            cr.line_to(*point)
            cr.stroke()
        cr.set_source_rgba(0.48, 0.36, 1.0, 0.30)
        cr.move_to(*mark_points[0])
        for point in mark_points[1:]:
            cr.line_to(*point)
        cr.close_path()
        cr.stroke()

        cr.set_line_width(1.6)
        cr.set_source_rgba(0.80, 0.88, 1.0, 0.34)
        cr.arc(equinox_center[0], equinox_center[1], 62 + math.sin(phase * 0.8) * 4, 0, math.pi * 2)
        cr.stroke()
        return False

    drawing.connect("draw", draw_prism)
    stage.add(drawing)
    stage.add_overlay(fixed)

    for key in order:
        if key not in positions:
            continue
        x, y, width, height = positions[key]
        node = prism_node(Gtk, profile_icon(key), profile_title(key), profile_note(key), key, key == active_key)
        node.set_size_request(width, height)
        node_by_key[key] = node
        node.connect("clicked", lambda _button, selected=key: describe(selected))
        node.connect("enter-notify-event", lambda _button, _event, selected=key: (describe(selected), False)[1])
        fixed.put(node, x, y)

    describe(active_key if active_key in positions else "equinox")
    content.pack_start(stage, True, True, 0)
    content.pack_start(inspector, False, False, 0)

    def tick() -> bool:
        pulse["value"] = (pulse["value"] + 0.12) % (math.pi * 2)
        drawing.queue_draw()
        return True

    GLib.timeout_add(48, tick)
    GLib.idle_add(lambda: (panel.grab_focus(), False)[1])
    return panel


def prism_node(Gtk, glyph: str, title: str, note: str, key: str, active: bool):
    button = Gtk.Button()
    button.get_style_context().add_class("prism-node")
    button.get_style_context().add_class(key)
    if active:
        button.get_style_context().add_class("active")
    box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    box.set_valign(Gtk.Align.CENTER)
    icon = Gtk.Label(label=glyph)
    icon.get_style_context().add_class("node-glyph")
    text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    text.set_hexpand(True)
    label = Gtk.Label(label=title)
    label.set_xalign(0)
    label.set_max_width_chars(16)
    label.set_line_wrap(True)
    label.get_style_context().add_class("node-title")
    meta = Gtk.Label(label=note)
    meta.set_xalign(0)
    meta.set_max_width_chars(20)
    meta.set_line_wrap(True)
    meta.get_style_context().add_class("node-note")
    text.pack_start(label, False, False, 0)
    text.pack_start(meta, False, False, 0)
    box.pack_start(icon, False, False, 0)
    box.pack_start(text, True, True, 0)
    button.add(box)
    return button


def alias_migration_panel(Gtk, migration: dict):
    count = int(migration.get("pending") or 0)
    panel = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    panel.get_style_context().add_class("alias-card")

    text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
    text_box.set_hexpand(True)
    title = Gtk.Label(label=t("Anciens noms à nettoyer", "Old names to clean up"), xalign=0)
    title.get_style_context().add_class("alias-title")
    note = Gtk.Label(
        label=t(
            "{count} ancien(s) repère(s) peuvent encore créer de la confusion. SevenOS peut les nettoyer.",
            "{count} old marker(s) may still create confusion. SevenOS can clean them up.",
        ).format(count=str(count)),
        xalign=0,
    )
    note.set_line_wrap(True)
    note.get_style_context().add_class("alias-note")
    text_box.pack_start(title, False, False, 0)
    text_box.pack_start(note, False, False, 0)
    panel.pack_start(text_box, True, True, 0)

    button = Gtk.Button(label=t("Nettoyer", "Clean up"))
    button.get_style_context().add_class("alias-button")
    button.connect("clicked", lambda _button: run_detached("seven profile migrate-aliases --apply"))
    panel.pack_end(button, False, False, 0)
    return panel


def layer_card(Gtk, name: str, value: str):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    box.set_hexpand(True)
    box.get_style_context().add_class("layer-card")
    title = Gtk.Label(label=name, xalign=0)
    title.get_style_context().add_class("layer-name")
    text = Gtk.Label(label=value, xalign=0)
    text.set_line_wrap(True)
    text.set_max_width_chars(28)
    text.get_style_context().add_class("layer-value")
    box.pack_start(title, False, False, 0)
    box.pack_start(text, False, False, 0)
    return box


def profile_tile(Gtk, glyph: str, title: str, note: str, command: str, css_class: str, key: str, active: bool):
    button = Gtk.Button()
    button.set_hexpand(True)
    button.get_style_context().add_class("tile")
    button.get_style_context().add_class(css_class)
    if key:
        button.get_style_context().add_class(key)
    if active:
        button.get_style_context().add_class("active")
    button.set_tooltip_text(command)
    box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    box.set_valign(Gtk.Align.CENTER)
    icon = Gtk.Label(label=glyph)
    icon.get_style_context().add_class("glyph")
    icon.set_valign(Gtk.Align.CENTER)
    text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    text_box.set_hexpand(True)
    label = Gtk.Label(label=title)
    label.set_xalign(0)
    label.get_style_context().add_class("tile-title")
    meta = Gtk.Label(label=note)
    meta.set_xalign(0)
    meta.get_style_context().add_class("tile-note")
    text_box.pack_start(label, False, False, 0)
    text_box.pack_start(meta, False, False, 0)
    state_label = Gtk.Label(label=t("Actif", "Active") if active else t("Activer", "Activate"))
    state_label.get_style_context().add_class("pill")
    box.pack_start(icon, False, False, 0)
    box.pack_start(text_box, True, True, 0)
    box.pack_end(state_label, False, False, 0)
    button.add(box)
    button.connect("clicked", lambda _button: run_detached(command))
    return button


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    return run()


if __name__ == "__main__":
    raise SystemExit(main())
