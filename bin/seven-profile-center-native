def localized_profile_title(key: str, fallback: str | None = None) -> str:
    values = LOCALIZED_PROFILE_TEXT.get(key, {})
    return str(values.get("title") or fallback or key.title())


def localized_profile_note(key: str, fallback: str | None = None) -> str:
    values = LOCALIZED_PROFILE_TEXT.get(key, {})
    return str(values.get("note") or fallback or "")


def localized_profile_mood(key: str, fallback: str | None = None) -> str:
    values = LOCALIZED_PROFILE_TEXT.get(key, {})
    return str(values.get("mood") or fallback or localized_profile_note(key))


