      padding: 6px 11px;
      border-radius: 999px;
      color: @seven_text;
      background: alpha(@seven_text, 0.065);
      border: 1px solid @seven_border;
      font-size: 11px;
      font-weight: 500;
    }
    .window-action {
      min-height: 30px;
      padding: 5px 10px;
      border-radius: 9px;
      color: @seven_text;
      background: transparent;
      border: 1px solid transparent;
      font-size: 11px;
      font-weight: 500;
    }
    .window-action:hover {
      color: @seven_text;
      background: @seven_hover;
      border-color: alpha(@seven_accent, 0.24);
    }
    .section {
      padding: 11px;
      border-radius: 15px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .section-title { color: @seven_text; font-size: 12px; font-weight: 500; }
    .section-note { color: @seven_muted; font-size: 11px; }
    .alias-card {
      padding: 10px 12px;
      border-radius: 20px;
      background:
        linear-gradient(135deg, rgba(249,226,175,0.16), rgba(255,255,255,0.045)),
        rgba(255,255,255,0.045);
      border: 1px solid rgba(249,226,175,0.24);
    }
    .alias-title { color: rgba(255,244,199,0.96); font-size: 12px; font-weight: 500; }
    .alias-note { color: rgba(245,247,250,0.66); font-size: 11px; }
    .alias-button {
      min-height: 34px;
      padding: 6px 12px;
      border-radius: 999px;
      color: rgba(22,24,31,0.96);
      background: rgba(249,226,175,0.92);
      border: 1px solid rgba(255,255,255,0.20);
      font-size: 11px;
      font-weight: 500;
    }
    .layer-card {
      padding: 9px 10px;
      border-radius: 12px;
      background: rgba(255,255,255,0.040);
      border: 1px solid rgba(255,255,255,0.075);
    }
    .layer-name { color: rgba(245,247,250,0.90); font-size: 11px; font-weight: 500; }
    .layer-value { color: rgba(245,247,250,0.58); font-size: 10px; }
    .tile {
      min-height: 56px;
      padding: 10px 12px;
      border-radius: 14px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.060), rgba(255,255,255,0.032)),
        rgba(255,255,255,0.032);
      border: 1px solid rgba(255,255,255,0.095);
      color: rgba(245,247,250,0.96);
    }
    .tile:hover {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.090), rgba(255,255,255,0.045)),
        rgba(255,255,255,0.048);
      border-color: rgba(156,203,255,0.30);
    }
    .tile.good { border-color: rgba(166,227,161,0.24); }
    .tile.warn { border-color: rgba(249,226,175,0.30); }
    .tile.bad { border-color: rgba(243,139,168,0.28); }
    .tile.active {
      background:
        linear-gradient(90deg, rgba(137,180,250,0.18), rgba(255,255,255,0.040)),
        rgba(255,255,255,0.050);
      border-color: rgba(137,180,250,0.45);
    }
    .tile.equinox { border-color: rgba(139,124,255,0.28); }
    .tile.baobab { border-color: rgba(166,227,161,0.28); }
    .tile.forge { border-color: rgba(249,226,175,0.34); }
    .tile.shield { border-color: rgba(0,255,179,0.30); }
    .tile.studio { border-color: rgba(203,166,247,0.28); }
    .tile.windows { border-color: rgba(137,220,235,0.28); }
    .tile.pulse { border-color: rgba(0,212,255,0.30); }
    .glyph { font-size: 20px; min-width: 34px; color: rgba(245,247,250,0.90); }
    .tile-title { font-size: 12px; font-weight: 500; }
    .tile-note { color: rgba(245,247,250,0.62); font-size: 11px; }
    .action-strip {
      padding: 8px;
      border-radius: 14px;
      background: rgba(255,255,255,0.038);
      border: 1px solid rgba(255,255,255,0.085);
    }
    .danger-note { color: rgba(249,226,175,0.82); font-size: 10px; }
    .icon-action {
      min-width: 36px;
      min-height: 36px;
      padding: 0;
      border-radius: 10px;
      color: rgba(245,247,250,0.94);
      background: rgba(255,255,255,0.052);
      border: 1px solid rgba(255,255,255,0.09);
    }
    .icon-action:hover { background: rgba(255,255,255,0.14); }
    """
    if seven_theme.current_theme_mode() == "light":
        css += """
        .profile-root {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.92), rgba(245,247,252,0.78)),
            rgba(255,255,255,0.84);
          border-color: rgba(28,31,38,0.10);
          box-shadow: 0 24px 72px rgba(43,63,100,0.16);
        }
        .title, .section-title, .tile, .layer-name, .tile-title { color: rgba(28,31,38,0.96); }
        .subtitle, .section-note, .layer-value, .tile-note, .alias-note { color: rgba(28,31,38,0.58); }
        .pill, .window-action, .icon-action {
          color: rgba(28,31,38,0.86);
          background: rgba(255,255,255,0.66);
          border-color: rgba(28,31,38,0.08);
        }
        .window-action:hover, .icon-action:hover {
          color: rgba(28,31,38,0.96);
          background: rgba(47,123,255,0.10);
          border-color: rgba(47,123,255,0.18);
        }
        .section, .layer-card, .tile, .action-strip {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.78), rgba(255,255,255,0.52)),
            rgba(255,255,255,0.50);
          border-color: rgba(28,31,38,0.08);
        }
        .tile:hover, .tile.active {
          background: rgba(47,123,255,0.11);
          border-color: rgba(47,123,255,0.24);
        }
        .alias-card {
          background: rgba(255,246,220,0.72);
          border-color: rgba(176,120,0,0.18);
        }
        .alias-title, .danger-note { color: rgba(123,82,0,0.86); }
        .glyph { color: rgba(28,31,38,0.82); }
        """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    profiles = run_json("profile", "status", "--json")
    runtime = run_json("runtime", "status", "--json")
    isolation = run_json("profile", "isolation", "status", "--json")
    migration = run_json("profile", "migrate-aliases", "--json")
    catalog = load_catalog()
    active = next((item for item in profiles if item.get("active")), None)

    window = Gtk.Window(title=tr_text("Espaces SevenOS"))
    window.set_wmclass("SevenProfileCenterNative", "SevenProfileCenterNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(860, 640)
    window.get_style_context().add_class("profile-center-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.get_style_context().add_class("profile-root")
    window.add(root)

    topbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    topbar.get_style_context().add_class("topbar")
    root.pack_start(topbar, False, False, 0)

    title = Gtk.Label(label=tr_text("Espaces SevenOS"), xalign=0)
    title.get_style_context().add_class("title")
    topbar.pack_start(title, True, True, 0)
    controls = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    topbar.pack_end(controls, False, False, 0)
    count_pill = Gtk.Label(label=tr_text("{count} espaces", count=str(len(profiles))))
    count_pill.get_style_context().add_class("pill")
    controls.pack_start(count_pill, False, False, 0)
    settings_button = Gtk.Button(label=tr_text("Réglages"))
    settings_button.get_style_context().add_class("window-action")
    settings_button.connect("clicked", lambda _button: run_detached("seven-settings profiles"))
    controls.pack_start(settings_button, False, False, 0)
    close_button = Gtk.Button(label=tr_text("Fermer"))
    close_button.get_style_context().add_class("window-action")
    close_button.connect("clicked", lambda _button: Gtk.main_quit())
    controls.pack_start(close_button, False, False, 0)

    active_label = active.get("title", tr_text("None")) if active else tr_text("None")
    active_key = str(active.get("key", "")) if active else ""
    subtitle_text = tr_text("Espace actif: {profile}", profile=active_label)
    if active_key in PUBLIC_PROFILE_NOTES:
        subtitle_text += f" · {PUBLIC_PROFILE_NOTES[active_key]}"
    subtitle = Gtk.Label(label=subtitle_text, xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    root.pack_start(subtitle, False, False, 0)

    if isinstance(migration, dict) and int(migration.get("pending") or 0) > 0:
        root.pack_start(alias_migration_panel(Gtk, migration), False, False, 0)

    if active_key in PUBLIC_PROFILE_DETAILS:
        root.pack_start(public_profile_panel(Gtk, active_key), False, False, 0)
    else:
        composition = composition_panel(Gtk, runtime if isinstance(runtime, dict) else {}, isolation if isinstance(isolation, dict) else {})
        root.pack_start(composition, False, False, 0)

    if active and active_key not in PUBLIC_PROFILE_DETAILS:
        active_catalog = (catalog.get("profiles", {}) or {}).get(active.get("key", ""), {})
        layers = active_catalog.get("layers", {})
        layers_box = Gtk.Grid()
        layers_box.set_column_spacing(8)
        layers_box.set_row_spacing(8)
        layers_box.get_style_context().add_class("section")
        for index, (name, values) in enumerate([
            (t("Noyau", "Core"), layers.get("kernel")),
            (t("Préparation", "Preparation"), layers.get("runtime")),
            (t("Interface", "Interface"), layers.get("experience")),
            (t("IA", "AI"), layers.get("intelligence")),
        ]):
            layers_box.attach(layer_card(Gtk, name, compact_list(values)), index % 4, index // 4, 1, 1)
        root.pack_start(layers_box, False, False, 0)

    grid = Gtk.Grid()
    grid.set_column_spacing(10)
    grid.set_row_spacing(10)
    root.pack_start(grid, True, True, 0)

    for index, profile in enumerate(profiles):
        title_text = profile.get("title", profile.get("key", tr_text("Espace")))
        state = profile.get("state", "MISS")
        installed = profile.get("installed", 0)
        total = profile.get("total", 0)
        key = profile.get("key", "")
        command = f"seven profile activate {key}"
        role = profile.get("role") or key
        if key in PUBLIC_PROFILE_NOTES:
            note = tr_text("en cours") if profile.get("active") else PUBLIC_PROFILE_NOTES[key]
        else:
            note = tr_text("en cours · prêt") if profile.get("active") else f"{role} · {state} · {installed}/{total}"
        glyph = profile.get("waybar_icon") or title_text[:1].upper()
        button = profile_tile(Gtk, glyph, title_text, note, command, state_class(state), key, bool(profile.get("active")))
        grid.attach(button, 0, index, 1, 1)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    actions.set_halign(Gtk.Align.CENTER)
    actions.get_style_context().add_class("action-strip")
    root.pack_end(actions, False, False, 0)
    for glyph, tooltip, command in [
        ("󰉋", tr_text("Ouvrir les fichiers"), "seven-files profile"),
        ("󰡱", tr_text("Ouvrir l'espace actif"), f"seven profile center {active.get('key', '')}" if active else "seven profile center"),
        ("󰀻", tr_text("Voir les applications"), "seven profile apps"),
        ("󰁨", tr_text("Réparer cet espace"), "seven-settings profiles"),
        ("󰞋", tr_text("Aide SevenOS"), "seven-help-native mini-os"),
        ("󰒓", tr_text("Ouvrir le Hub"), "seven-hub-native open"),
    ]:
        button = Gtk.Button()
        button.get_style_context().add_class("icon-action")
        button.set_tooltip_text(tooltip)
        button.add(Gtk.Label(label=glyph))
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        actions.pack_start(button, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def composition_panel(Gtk, runtime: dict, isolation: dict):
    panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
    panel.get_style_context().add_class("section")

    primary = runtime.get("primary_profile", {})
    composite = runtime.get("composite_runtime", {})
    resource = runtime.get("resource_plan", {})
    doctor = runtime.get("doctor", {})
    injected = composite.get("injected_profiles") or []
    active_count = isolation.get("active_package_count", 0)
    inactive_count = isolation.get("inactive_package_count", 0)

    title = Gtk.Label(label=tr_text("Préparation de l’espace"), xalign=0)
    title.get_style_context().add_class("section-title")
    panel.pack_start(title, False, False, 0)

    summary = Gtk.Label(
        label=tr_text(
            "Espace principal: {primary} · outils ajoutés: {injected} · éléments prêts: {active} / {inactive} en attente",
            primary=primary.get("title") or composite.get("primary") or "unknown",
            injected=", ".join(injected) if injected else tr_text("aucun"),
            active=active_count,
            inactive=inactive_count,
        ),
        xalign=0,
    )
    summary.get_style_context().add_class("section-note")
    panel.pack_start(summary, False, False, 0)

    details = Gtk.Label(
        label=tr_text(
            "Performance: {cpu} · mémoire: {ram} · éléments isolés: {services} · reprise: {snapshot}",
            cpu=resource.get("cpu", {}).get("strategy", "unknown"),
            ram=resource.get("ram", {}).get("strategy", "unknown"),
            services=resource.get("isolation", {}).get("services", "unknown"),
            snapshot=tr_text("prête") if any(item.get("name") == "criu" and item.get("state") == "OK" for item in doctor.get("checks", [])) else tr_text("prévue"),
        ),
        xalign=0,
    )
    details.get_style_context().add_class("danger-note")
    panel.pack_start(details, False, False, 0)
    return panel


def public_profile_panel(Gtk, key: str):
    panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    panel.get_style_context().add_class("section")

    title = Gtk.Label(label=tr_text("Ce que cet espace prépare"), xalign=0)
    title.get_style_context().add_class("section-title")
    panel.pack_start(title, False, False, 0)

    grid = Gtk.Grid()
    grid.set_column_spacing(8)
    grid.set_row_spacing(8)
    panel.pack_start(grid, False, False, 0)
    for index, (name, value) in enumerate(PUBLIC_PROFILE_DETAILS.get(key, [])):
        grid.attach(layer_card(Gtk, name, value), index % 4, index // 4, 1, 1)
    return panel


def alias_migration_panel(Gtk, migration: dict):
    count = int(migration.get("pending") or 0)
    panel = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    panel.get_style_context().add_class("alias-card")

    text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
    text_box.set_hexpand(True)
    title = Gtk.Label(label=tr_text("Anciens noms à nettoyer"), xalign=0)
    title.get_style_context().add_class("alias-title")
    note = Gtk.Label(
        label=tr_text(
            "{count} ancien(s) repère(s) peuvent encore créer de la confusion. SevenOS peut les nettoyer.",
            count=str(count),
        ),
        xalign=0,
    )
    note.set_line_wrap(True)
    note.get_style_context().add_class("alias-note")
    text_box.pack_start(title, False, False, 0)
    text_box.pack_start(note, False, False, 0)
    panel.pack_start(text_box, True, True, 0)

    button = Gtk.Button(label=tr_text("Nettoyer"))
    button.get_style_context().add_class("alias-button")
    button.connect("clicked", lambda _button: run_detached("seven profile migrate-aliases --apply"))
    panel.pack_end(button, False, False, 0)
    return panel


def layer_card(Gtk, name: str, value: str):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
    box.set_hexpand(True)
    box.get_style_context().add_class("layer-card")
    title = Gtk.Label(label=name, xalign=0)
    title.get_style_context().add_class("layer-name")
    text = Gtk.Label(label=value, xalign=0)
    text.set_line_wrap(True)
    text.set_max_width_chars(28)
    text.get_style_context().add_class("layer-value")
    box.pack_start(title, False, False, 0)
    box.pack_start(text, False, False, 0)
    return box


def profile_tile(Gtk, glyph: str, title: str, note: str, command: str, css_class: str, key: str, active: bool):
    button = Gtk.Button()
    button.set_hexpand(True)
    button.get_style_context().add_class("tile")
    button.get_style_context().add_class(css_class)
    if key:
        button.get_style_context().add_class(key)
    if active:
        button.get_style_context().add_class("active")
    button.set_tooltip_text(command)
    box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    box.set_valign(Gtk.Align.CENTER)
    icon = Gtk.Label(label=glyph)
    icon.get_style_context().add_class("glyph")
    icon.set_valign(Gtk.Align.CENTER)
    text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    text_box.set_hexpand(True)
    label = Gtk.Label(label=title)
    label.set_xalign(0)
    label.get_style_context().add_class("tile-title")
    meta = Gtk.Label(label=note)
    meta.set_xalign(0)
    meta.get_style_context().add_class("tile-note")
    text_box.pack_start(label, False, False, 0)
    text_box.pack_start(meta, False, False, 0)
    state_label = Gtk.Label(label=tr_text("Actif") if active else tr_text("Activer"))
    state_label.get_style_context().add_class("pill")
    box.pack_start(icon, False, False, 0)
    box.pack_start(text_box, True, True, 0)
    box.pack_end(state_label, False, False, 0)
    button.add(box)
    button.connect("clicked", lambda _button: run_detached(command))
    return button


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    return run()


if __name__ == "__main__":
    raise SystemExit(main())
