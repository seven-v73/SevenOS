#!/usr/bin/env python3
import json
import os
import shlex
import shutil
import subprocess
import sys
import time
from pathlib import Path

import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GLib, Pango


ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None


def lang_is_fr() -> bool:
    language = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG", "")
    return language.lower().startswith("fr")


def tr(fr: str, en: str) -> str:
    return fr if lang_is_fr() else en


def shlex_quote(value: str) -> str:
    return shlex.quote(value)


def load_doctor():
    result = subprocess.run(
        [str(ROOT / "bin" / "seven"), "doctor", "check", "--json"],
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        return {
            "decision": "error",
            "summary": {"issues": 1},
            "issues": [
                {
                    "title": tr("Seven Doctor a échoué", "Seven Doctor failed"),
                    "detail": result.stderr.strip() or tr("Impossible de lire les diagnostics système.", "Unable to read system diagnostics."),
                    "command": "seven doctor check",
                    "severity": "high",
                }
            ],
            "checks": [],
        }
    return json.loads(result.stdout)


def run_text(command: list[str], timeout: float = 2.0) -> str:
    try:
        result = subprocess.run(command, text=True, capture_output=True, check=False, timeout=timeout)
        return result.stdout.strip()
    except Exception:
        return ""


def read_cpu_total() -> tuple[int, int]:
    try:
        fields = Path("/proc/stat").read_text(encoding="utf-8").splitlines()[0].split()[1:]
        values = [int(item) for item in fields]
    except Exception:
        return (0, 0)
    idle = values[3] + (values[4] if len(values) > 4 else 0)
    total = sum(values)
    return idle, total


def cpu_percent() -> int:
    idle_a, total_a = read_cpu_total()
    time.sleep(0.08)
    idle_b, total_b = read_cpu_total()
    total_delta = max(total_b - total_a, 1)
    idle_delta = max(idle_b - idle_a, 0)
    return max(0, min(100, round(100 * (1 - idle_delta / total_delta))))


def memory_percent() -> tuple[int, str]:
    values: dict[str, int] = {}
    try:
        for line in Path("/proc/meminfo").read_text(encoding="utf-8").splitlines():
            key, raw = line.split(":", 1)
            values[key] = int(raw.strip().split()[0])
    except Exception:
        return 0, "0 / 0 GiB"
    total = values.get("MemTotal", 0)
    available = values.get("MemAvailable", 0)
    used = max(total - available, 0)
    percent = round(used / total * 100) if total else 0
    detail = f"{used / 1024 / 1024:.1f} / {total / 1024 / 1024:.1f} GiB"
    return percent, detail


def disk_percent(path: str = str(Path.home())) -> tuple[int, str]:
    try:
        usage = shutil.disk_usage(path)
    except OSError:
        return 0, "0 / 0 GiB"
    percent = round(usage.used / usage.total * 100) if usage.total else 0
    detail = f"{usage.used / 1024**3:.0f} / {usage.total / 1024**3:.0f} GiB"
    return percent, detail


def process_rows(limit: int = 22) -> list[dict[str, object]]:
    output = run_text(["ps", "-eo", "pid=,comm=,pcpu=,pmem=,stat=,args=", "--sort=-pcpu"], timeout=2.5)
    rows = []
    current_pid = os.getpid()
    for line in output.splitlines():
        parts = line.strip().split(None, 5)
        if len(parts) < 6:
            continue
        try:
            pid = int(parts[0])
            cpu = float(parts[2])
            mem = float(parts[3])
        except ValueError:
            continue
        if pid == current_pid:
            continue
        rows.append({
            "pid": pid,
            "name": parts[1],
            "cpu": cpu,
            "memory": mem,
            "state": parts[4],
            "command": parts[5],
        })
        if len(rows) >= limit:
            break
    return rows


def service_rows(limit: int = 26) -> list[dict[str, str]]:
    rows: list[dict[str, str]] = []
    failed = run_text(["systemctl", "--failed", "--plain", "--no-legend"], timeout=2.5)
    for line in failed.splitlines():
        parts = line.split(None, 4)
        if not parts:
            continue
        rows.append({"unit": parts[0], "state": "failed", "scope": "system", "detail": parts[4] if len(parts) > 4 else ""})
    user_failed = run_text(["systemctl", "--user", "--failed", "--plain", "--no-legend"], timeout=2.5)
    for line in user_failed.splitlines():
        parts = line.split(None, 4)
        if not parts:
            continue
        rows.append({"unit": parts[0], "state": "failed", "scope": "user", "detail": parts[4] if len(parts) > 4 else ""})
    active = run_text(["systemctl", "list-units", "--type=service", "--state=running", "--plain", "--no-legend"], timeout=2.5)
    for line in active.splitlines():
        parts = line.split(None, 4)
        if not parts:
            continue
        rows.append({"unit": parts[0], "state": "running", "scope": "system", "detail": parts[4] if len(parts) > 4 else ""})
        if len(rows) >= limit:
            break
    return rows[:limit]


def task_snapshot(doctor: dict) -> dict[str, object]:
    mem, mem_detail = memory_percent()
    disk, disk_detail = disk_percent()
    processes = process_rows()
    services = service_rows()
    failed_services = [item for item in services if item.get("state") == "failed"]
    return {
        "schema": "sevenos.doctor-task-manager.v1",
        "resources": {
            "cpu": {"percent": cpu_percent(), "detail": run_text(["uptime", "-p"], timeout=1.0) or tr("Charge système", "System load")},
            "memory": {"percent": mem, "detail": mem_detail},
            "disk": {"percent": disk, "detail": disk_detail},
            "processes": {"count": len(run_text(["ps", "-e", "-o", "pid="], timeout=1.5).splitlines()), "shown": len(processes)},
        },
        "processes": processes,
        "top_processes": processes[:5],
        "services": services,
        "alerts": {
            "issues": len(doctor.get("issues") or []),
            "failed_services": len(failed_services),
        },
    }


