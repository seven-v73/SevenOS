def current_css() -> str:
    mode = seven_theme.current_theme_mode() if seven_theme else os.environ.get("SEVENOS_THEME_MODE", "dark")
    base = seven_theme.gtk_app_css("doctor", mode) if seven_theme else ""
    return base + CSS_COMMON


class DoctorWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="Seven Doctor")
        self.get_style_context().add_class("seven-window")
        self.set_default_size(980, 680)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_name("seven-doctor")

        provider = Gtk.CssProvider()
        provider.load_from_data(current_css().encode())
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        self.data = load_doctor()
        self.task = task_snapshot(self.data)
        self.filter_text = ""
        self.sort_mode = "cpu"
        self.auto_refresh_id = 0
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        outer.get_style_context().add_class("shell")
        self.add(outer)

        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title = Gtk.Label(label=tr("Seven Doctor", "Seven Doctor"), xalign=0)
        title.get_style_context().add_class("title")
        summary = self.data.get("summary", {})
        subtitle = Gtk.Label(
            label=f"{self.data.get('decision', 'unknown')} · {summary.get('issues', 0)} issue(s) · {summary.get('checks', 0)} checks",
            xalign=0,
        )
        subtitle.get_style_context().add_class("subtitle")
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(subtitle, False, False, 0)
        header.pack_start(title_box, True, True, 0)

        monitor = Gtk.Button(label=tr("Moniteur", "Monitor"))
        monitor.connect("clicked", lambda *_: self.terminal("btop || htop || top"))
        header.pack_end(monitor, False, False, 0)
        refresh = Gtk.Button(label=tr("Actualiser", "Refresh"))
        refresh.connect("clicked", lambda *_: self.reload())
        header.pack_end(refresh, False, False, 0)
        outer.pack_start(header, False, False, 0)

        tools = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        tools.get_style_context().add_class("toolbar")
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
        self.stack.set_transition_duration(180)
        self.switcher = Gtk.StackSwitcher()
        self.switcher.set_stack(self.stack)
        self.switcher.get_style_context().add_class("switcher")
        tools.pack_start(self.switcher, False, False, 0)
        self.search = Gtk.SearchEntry()
        self.search.set_placeholder_text(tr("Filtrer apps, PID, services...", "Filter apps, PID, services..."))
        self.search.get_style_context().add_class("search")
        self.search.connect("search-changed", self.on_search_changed)
        tools.pack_start(self.search, True, True, 0)
        self.sort_combo = Gtk.ComboBoxText()
        self.sort_combo.append("cpu", tr("CPU", "CPU"))
        self.sort_combo.append("memory", tr("RAM", "RAM"))
        self.sort_combo.append("name", tr("Nom", "Name"))
        self.sort_combo.set_active_id(self.sort_mode)
        self.sort_combo.connect("changed", self.on_sort_changed)
        tools.pack_start(self.sort_combo, False, False, 0)
        auto_label = Gtk.Label(label=tr("Auto-refresh", "Auto-refresh"))
        auto_label.get_style_context().add_class("subtitle")
        tools.pack_start(auto_label, False, False, 0)
        self.auto_switch = Gtk.Switch()
        self.auto_switch.connect("notify::active", self.on_auto_refresh)
        tools.pack_start(self.auto_switch, False, False, 0)
        outer.pack_start(tools, False, False, 0)

        outer.pack_start(self.stack, True, True, 0)
        self.render()

    def reload(self):
        self.data = load_doctor()
        self.task = task_snapshot(self.data)
        self.rerender()

    def rerender(self):
        active = self.stack.get_visible_child_name() or "overview"
        for child in list(self.stack.get_children()):
            self.stack.remove(child)
        self.render()
        if self.stack.get_child_by_name(active):
            self.stack.set_visible_child_name(active)
        self.show_all()

    def on_search_changed(self, entry):
        self.filter_text = entry.get_text().strip().lower()
        self.rerender()

    def on_sort_changed(self, combo):
        self.sort_mode = combo.get_active_id() or "cpu"
        self.rerender()

    def on_auto_refresh(self, switch, *_):
        if switch.get_active():
            if not self.auto_refresh_id:
                self.auto_refresh_id = GLib.timeout_add_seconds(4, self.auto_refresh_tick)
        elif self.auto_refresh_id:
            GLib.source_remove(self.auto_refresh_id)
            self.auto_refresh_id = 0

    def auto_refresh_tick(self):
        if not getattr(self, "auto_switch", None) or not self.auto_switch.get_active():
            self.auto_refresh_id = 0
            return False
        self.reload()
        return True

    def on_destroy(self, *_):
        if self.auto_refresh_id:
            GLib.source_remove(self.auto_refresh_id)
            self.auto_refresh_id = 0
        Gtk.main_quit()

    def match_filter(self, *values):
        if not self.filter_text:
            return True
        haystack = " ".join(str(value) for value in values).lower()
        return self.filter_text in haystack

    def render(self):
        self.stack.add_titled(self.overview_page(), "overview", tr("Vue", "Overview"))
        self.stack.add_titled(self.process_page(), "apps", tr("Apps", "Apps"))
        self.stack.add_titled(self.services_page(), "services", tr("Services", "Services"))
        self.stack.add_titled(self.checks_page(), "checks", tr("Checks", "Checks"))

    def page_scroller(self, child):
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.add(child)
        return scroller

    def overview_page(self):
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
        resources = self.task.get("resources", {})
        page.pack_start(self.hero_card(), False, False, 0)
        grid = Gtk.Grid(column_spacing=12, row_spacing=12)
        grid.set_column_homogeneous(True)
        cards = [
            ("CPU", resources.get("cpu", {}).get("percent", 0), resources.get("cpu", {}).get("detail", "")),
            (tr("Mémoire", "Memory"), resources.get("memory", {}).get("percent", 0), resources.get("memory", {}).get("detail", "")),
            (tr("Disque", "Disk"), resources.get("disk", {}).get("percent", 0), resources.get("disk", {}).get("detail", "")),
            (tr("Processus", "Processes"), resources.get("processes", {}).get("count", 0), tr("en cours", "running")),
        ]
        for index, (title, value, detail) in enumerate(cards):
            grid.attach(self.metric_card(title, value, detail, percent=isinstance(value, int) and title != tr("Processus", "Processes")), index % 2, index // 2, 1, 1)
        page.pack_start(grid, False, False, 0)

        alerts = self.task.get("alerts", {})
        status = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        status.pack_start(self.status_card(
            tr("Santé SevenOS", "SevenOS Health"),
            f"{self.data.get('decision', 'unknown')} · {alerts.get('issues', 0)} issue(s)",
            "seven doctor check --json",
            "good" if not alerts.get("issues") else "warn",
        ), True, True, 0)
        status.pack_start(self.status_card(
            tr("Services", "Services"),
            f"{alerts.get('failed_services', 0)} " + tr("service(s) en erreur", "failed service(s)"),
            "systemctl --failed",
            "good" if not alerts.get("failed_services") else "danger",
        ), True, True, 0)
        page.pack_start(status, False, False, 0)
        page.pack_start(self.quick_actions(), False, False, 0)
        page.pack_start(self.section_label(tr("Processus les plus actifs", "Most active processes")), False, False, 0)
        for item in self.task.get("top_processes", []):
            page.pack_start(self.process_row(item, compact=True), False, False, 0)
        return self.page_scroller(page)

    def process_page(self):
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        page.pack_start(self.section_label(tr("Applications et processus en cours", "Running applications and processes")), False, False, 0)
        visible = []
        for item in self.sorted_processes():
            if not self.match_filter(item.get("name"), item.get("pid"), item.get("command")):
                continue
            visible.append(item)
            page.pack_start(self.process_row(item), False, False, 0)
        if not visible:
            page.pack_start(self.empty_state(tr("Aucun processus ne correspond au filtre.", "No process matches the current filter.")), False, False, 0)
        return self.page_scroller(page)

    def services_page(self):
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        page.pack_start(self.section_label(tr("Services système", "System services")), False, False, 0)
        visible = []
        for item in self.task.get("services", []):
            if not self.match_filter(item.get("unit"), item.get("state"), item.get("detail"), item.get("scope")):
                continue
            visible.append(item)
            page.pack_start(self.service_row(item), False, False, 0)
        if not visible:
            page.pack_start(self.empty_state(tr("Aucun service ne correspond au filtre.", "No service matches the current filter.")), False, False, 0)
        return self.page_scroller(page)

    def checks_page(self):
        page = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        issues = self.data.get("issues") or []
        items = issues if issues else [
            {
                    "title": tr("Le système semble prêt", "System looks ready"),
                    "detail": tr("Aucun problème dur détecté par Seven Doctor.", "No hard issue detected by Seven Doctor."),
                "command": "seven daily",
                "severity": "low",
            }
        ]
        visible = []
        for item in items:
            if not self.match_filter(item.get("title"), item.get("detail"), item.get("command"), item.get("severity")):
                continue
            visible.append(item)
            page.pack_start(self.card(item), False, False, 0)
        if not visible:
            page.pack_start(self.empty_state(tr("Aucun check ne correspond au filtre.", "No check matches the current filter.")), False, False, 0)
        return self.page_scroller(page)

    def section_label(self, text):
        label = Gtk.Label(label=text, xalign=0)
        label.get_style_context().add_class("section-title")
        return label

    def sorted_processes(self):
        rows = list(self.task.get("processes", []))
        if self.sort_mode == "memory":
            return sorted(rows, key=lambda item: float(item.get("memory") or 0), reverse=True)
        if self.sort_mode == "name":
            return sorted(rows, key=lambda item: str(item.get("name") or "").lower())
        return sorted(rows, key=lambda item: float(item.get("cpu") or 0), reverse=True)

    def hero_card(self):
        alerts = self.task.get("alerts", {})
        issues = int(alerts.get("issues") or 0)
        failed = int(alerts.get("failed_services") or 0)
        good = issues == 0 and failed == 0
        title = tr("Système stable", "System stable") if good else tr("Attention requise", "Attention needed")
        detail = (
            tr("Seven Doctor surveille les ressources, les applications et les services sans action cachée.",
               "Seven Doctor watches resources, applications and services without hidden actions.")
            if good else
            tr("Consulte les services et checks signalés avant d’appliquer une réparation.",
               "Review flagged services and checks before applying a repair.")
        )
        item = {"title": title, "detail": detail, "command": "seven ai operate 'diagnose system' --json", "severity": "low" if good else "high"}
        return self.card(item)

    def quick_actions(self):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        box.get_style_context().add_class("card")
        actions = [
            (tr("Diagnostic IA", "AI Diagnose"), "seven ai operate 'diagnose system' --json"),
            (tr("Rapport support", "Support report"), "seven support bundle"),
            (tr("Réparation guidée", "Guided repair"), "seven repair doctor"),
            (tr("Qualité publique", "Public quality"), "seven public-experience doctor --json"),
        ]
        for label, command in actions:
            button = Gtk.Button(label=label)
            button.connect("clicked", lambda _, cmd=command: self.terminal(cmd))
            box.pack_start(button, True, True, 0)
        return box

    def empty_state(self, text):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        box.get_style_context().add_class("card")
        label = Gtk.Label(label=text, xalign=0.5)
        label.get_style_context().add_class("subtitle")
        box.pack_start(label, False, False, 0)
        return box

    def metric_card(self, title, value, detail, *, percent=True):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("card")
        if percent:
            numeric = int(value)
            if numeric >= 90:
                box.get_style_context().add_class("danger")
            elif numeric >= 75:
                box.get_style_context().add_class("warn")
        label = Gtk.Label(label=str(title), xalign=0)
        label.get_style_context().add_class("subtitle")
        value_label = Gtk.Label(label=f"{value}%" if percent else str(value), xalign=0)
        value_label.get_style_context().add_class("metric-value")
        detail_label = Gtk.Label(label=str(detail), xalign=0)
        detail_label.get_style_context().add_class("subtitle")
        box.pack_start(label, False, False, 0)
        box.pack_start(value_label, False, False, 0)
        if percent:
            progress = Gtk.ProgressBar()
            progress.set_fraction(max(0, min(100, int(value))) / 100)
            box.pack_start(progress, False, False, 0)
        box.pack_start(detail_label, False, False, 0)
        return box

    def status_card(self, title, detail, command, level):
        item = {"title": title, "detail": detail, "command": command, "severity": "low" if level == "good" else "high" if level == "danger" else "medium"}
        return self.card(item)

    def terminal(self, command):
        subprocess.Popen([str(ROOT / "bin" / "seven-terminal"), "--", "sh", "-lc", command])

    def process_row(self, item, compact=False):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("row-card")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title = Gtk.Label(label=f"{item.get('name')}  ·  PID {item.get('pid')}", xalign=0)
        title.get_style_context().add_class("label-title")
        detail = Gtk.Label(label=str(item.get("command", ""))[:160], xalign=0)
        detail.set_ellipsize(Pango.EllipsizeMode.END)
        detail.get_style_context().add_class("subtitle")
        labels.pack_start(title, False, False, 0)
        labels.pack_start(detail, False, False, 0)
        box.pack_start(labels, True, True, 0)
        meter = Gtk.ProgressBar()
        meter.get_style_context().add_class("mini-meter")
        meter.set_fraction(max(0.0, min(100.0, float(item.get("cpu") or 0))) / 100.0)
        box.pack_start(meter, False, False, 0)
        metrics = Gtk.Label(label=f"CPU {item.get('cpu'):.1f}% · RAM {item.get('memory'):.1f}%", xalign=1)
        metrics.get_style_context().add_class("pill")
        if float(item.get("cpu") or 0) >= 50 or float(item.get("memory") or 0) >= 20:
            metrics.get_style_context().add_class("danger-pill")
        box.pack_start(metrics, False, False, 0)
        if compact:
            return box
        details = Gtk.Button(label=tr("Détails", "Details"))
        details.connect("clicked", lambda *_: self.terminal(f"ps -p {int(item.get('pid'))} -o pid,ppid,user,stat,pcpu,pmem,etime,args; printf '\\n'; read -r -p 'Entrée pour fermer...' _"))
        box.pack_start(details, False, False, 0)
        stop = Gtk.Button(label=tr("Arrêter", "Stop"))
        stop.connect("clicked", lambda *_: self.terminal(f"printf 'Arrêter PID {int(item.get('pid'))} ? [y/N] '; read ans; [ \"$ans\" = y ] && kill {int(item.get('pid'))}; sleep 1"))
        box.pack_start(stop, False, False, 0)
        return box

    def service_row(self, item):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.get_style_context().add_class("row-card")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title = Gtk.Label(label=f"{item.get('unit')} · {item.get('state')} · {item.get('scope')}", xalign=0)
        title.get_style_context().add_class("label-title")
        detail = Gtk.Label(label=item.get("detail", ""), xalign=0)
        detail.set_ellipsize(Pango.EllipsizeMode.END)
        detail.get_style_context().add_class("subtitle")
        labels.pack_start(title, False, False, 0)
        labels.pack_start(detail, False, False, 0)
        box.pack_start(labels, True, True, 0)
        state = Gtk.Label(label=str(item.get("state", "")), xalign=1)
        state.get_style_context().add_class("pill")
        if item.get("state") == "failed":
            state.get_style_context().add_class("danger-pill")
        box.pack_start(state, False, False, 0)
        unit = str(item.get("unit"))
        scope = "--user " if item.get("scope") == "user" else ""
        logs = Gtk.Button(label=tr("Logs", "Logs"))
        logs.connect("clicked", lambda *_: self.terminal(f"journalctl {scope}-u {shlex_quote(unit)} -n 120 --no-pager; printf '\\n'; read -r -p 'Entrée pour fermer...' _"))
        box.pack_start(logs, False, False, 0)
        restart = Gtk.Button(label=tr("Relancer", "Restart"))
        restart.connect("clicked", lambda *_: self.terminal(f"printf 'Relancer {unit} ? [y/N] '; read ans; [ \"$ans\" = y ] && systemctl {scope}restart {shlex_quote(unit)}; sleep 1"))
        box.pack_start(restart, False, False, 0)
        return box

    def card(self, item):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("card")
        sev = item.get("severity", "medium")
        box.get_style_context().add_class("danger" if sev == "critical" else "warn" if sev in {"high", "medium"} else "good")

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title = Gtk.Label(label=item.get("title", tr("Point à vérifier", "Issue")), xalign=0)
        title.get_style_context().add_class("label-title")
        detail = Gtk.Label(label=item.get("detail", ""), xalign=0)
        detail.set_line_wrap(True)
        detail.get_style_context().add_class("label-detail")
        labels.pack_start(title, False, False, 0)
        labels.pack_start(detail, False, False, 0)
        row.pack_start(labels, True, True, 0)

        command = item.get("command", "seven doctor check")
        btn = Gtk.Button(label=tr("Ouvrir", "Open"))
        btn.connect("clicked", lambda *_: subprocess.Popen([str(ROOT / "bin" / "seven-terminal"), "--", "sh", "-lc", command]))
        row.pack_end(btn, False, False, 0)
        box.pack_start(row, False, False, 0)

        cmd = Gtk.Label(label=command, xalign=0)
        cmd.get_style_context().add_class("subtitle")
        box.pack_start(cmd, False, False, 0)
        return box


if __name__ == "__main__":
    if "--probe" in sys.argv:
        print("OK")
        raise SystemExit(0)
    if "--json" in sys.argv:
        doctor = load_doctor()
        print(json.dumps({"schema": "sevenos.doctor-native.v1", "doctor": doctor, "task_manager": task_snapshot(doctor)}, ensure_ascii=False, indent=2))
        raise SystemExit(0)
    win = DoctorWindow()
    win.connect("destroy", win.on_destroy)
    win.show_all()
    Gtk.main()
