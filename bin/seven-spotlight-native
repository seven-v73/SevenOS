#!/usr/bin/env python3
"""SevenOS native Spotlight surface."""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import subprocess
import sys
import threading
import time
import unicodedata
from dataclasses import dataclass
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven-spotlight").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven-spotlight").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven-spotlight").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos"
RUNTIME_DIR = Path(os.environ.get("XDG_RUNTIME_DIR", f"/tmp/sevenos-{os.getuid()}")) / "sevenos"
THEME_CONF = CONFIG_DIR / "theme.conf"
PROFILE_UI_FILE = CONFIG_DIR / "profile-ui.json"
CACHE_FILE = CACHE_DIR / "spotlight.json"
LOCK_FILE = RUNTIME_DIR / "spotlight.lock"
CACHE_TTL_SECONDS = 45
LOCK_HANDLE = None


@dataclass
class Item:
    kind: str
    label: str
    key: str
    command: str
    detail: str
    icon: str

    @property
    def clean_title(self) -> str:
        if " · " in self.label:
            return self.label.split(" · ", 1)[1].strip()
        return self.label.strip()

    @property
    def category(self) -> str:
        if " · " in self.label:
            return self.label.split(" · ", 1)[0].strip()
        return self.kind.title()

    @property
    def search_text(self) -> str:
        return normalize(" ".join((self.label, self.key, self.command, self.detail, self.kind)))


CATEGORIES = [
    ("all", "seven-spotlight", "All"),
    ("apps", "view-grid-symbolic", "Applications"),
    ("files", "system-file-manager", "Files"),
    ("settings", "seven-settings", "Settings"),
    ("system", "system-run", "Actions"),
    ("web", "web-browser", "Web"),
    ("clipboard", "edit-paste", "Clipboard"),
    ("atlas", "folder-documents", "Atlas"),
    ("history", "document-open-recent", "History"),
]


def normalize(value: str) -> str:
    normalized = unicodedata.normalize("NFKD", value or "")
    return "".join(char for char in normalized if not unicodedata.combining(char)).casefold()


def read_json(path: Path, default):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return default


def read_profile_ui() -> dict:
    data = read_json(PROFILE_UI_FILE, {})
    if not isinstance(data, dict):
        return {}
    return data


def profile_items(profile_ui: dict) -> list[Item]:
    if not profile_ui:
        return []
    key = str(profile_ui.get("profile") or "equinox")
    title = str(profile_ui.get("title") or key.title())
    home = profile_ui.get("home_screen") if isinstance(profile_ui.get("home_screen"), dict) else {}
    items = [
        Item("profile", f"{title} · Home", f"profile.home.{key}", str(profile_ui.get("center_command") or f"seven profile center {key}"), str(home.get("focus") or profile_ui.get("purpose") or "Open the active mini OS home."), "preferences-system-symbolic"),
        Item("profile", f"{title} · Workspace", f"profile.workspace.{key}", str(profile_ui.get("workspace_command") or f"seven profile open {key}"), str(home.get("library") or "Open the mini OS workspace."), "folder-symbolic"),
        Item("profile", f"{title} · Runtime", f"profile.runtime.{key}", str(profile_ui.get("runtime_command") or f"seven runtime plan {key}"), "Show layers, resources, services and composition for this mini OS.", "utilities-system-monitor-symbolic"),
    ]
    for action in home.get("actions", []) if isinstance(home.get("actions"), list) else []:
        if not isinstance(action, dict):
            continue
        label = str(action.get("label") or "").strip()
        command = str(action.get("command") or "").strip()
        if label and command:
            items.append(Item("profile", f"{title} · {label}", f"profile.action.{key}.{normalize(label)}", command, str(action.get("description") or "Mini OS action"), "system-run-symbolic"))
    return items


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")


def current_theme_mode() -> str:
    env_mode = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    if env_mode in {"dark", "light"}:
        return env_mode
    try:
        for raw in THEME_CONF.read_text(encoding="utf-8", errors="replace").splitlines():
            if "=" not in raw or raw.strip().startswith("#"):
                continue
            key, value = [part.strip().lower() for part in raw.split("=", 1)]
            if key in {"mode", "theme_mode", "sevenos_theme_mode"} and value in {"dark", "light"}:
                return value
    except OSError:
        pass
    return "dark"


def icon_theme_name(mode: str) -> str:
    settings = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "gtk-3.0/settings.ini"
    try:
        for raw in settings.read_text(encoding="utf-8", errors="replace").splitlines():
            if raw.strip().startswith("gtk-icon-theme-name="):
                value = raw.split("=", 1)[1].strip()
                if value:
                    return value
    except OSError:
        pass
    return "Papirus-Dark" if mode == "dark" else "Papirus"


def rows_to_items(rows) -> list[Item]:
    return [Item(*row[:6]) for row in rows if isinstance(row, list) and len(row) >= 6]


def read_cached_catalog(*, max_age: float | None = CACHE_TTL_SECONDS) -> list[Item]:
    cached = read_json(CACHE_FILE, {})
    now = time.time()
    if (
        cached.get("schema") == "sevenos.spotlight.v1"
        and isinstance(cached.get("items"), list)
        and (max_age is None or now - float(cached.get("created_at", 0)) <= max_age)
    ):
        return rows_to_items(cached["items"])
    return []


def load_catalog(*, force: bool = False) -> list[Item]:
    if not force:
        cached_items = read_cached_catalog()
        if cached_items:
            return cached_items
    result = subprocess.run(
        [str(ROOT / "bin/seven-spotlight"), "catalog"],
        text=True,
        capture_output=True,
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_SPOTLIGHT_NATIVE": "0"},
        check=False,
    )
    items: list[Item] = []
    for raw in result.stdout.splitlines():
        parts = raw.split("\t")
        if len(parts) >= 6:
            items.append(Item(*parts[:6]))
    write_json(CACHE_FILE, {"schema": "sevenos.spotlight.v1", "created_at": time.time(), "items": [[item.kind, item.label, item.key, item.command, item.detail, item.icon] for item in items]})
    return items


def fuzzy_score(query: str, item: Item) -> int:
    if not query:
        return 0
    haystack = item.search_text
    title = normalize(item.clean_title)
    if title == query:
        score = 140
    elif title.startswith(query):
        score = 118
    elif query in haystack:
        score = 82
    else:
        score = 0
        position = 0
        for char in query:
            found = haystack.find(char, position)
            if found == -1:
                return -1
            score += 4 if found == position else 2
            position = found + 1
    if item.kind == "app":
        score += 18
    if item.kind in {"setting", "action", "intent"}:
        score += 14
    if item.kind in {"history", "clipboard", "window"}:
        score += 8
    return score


def filter_items(items: list[Item], query: str, mode: str) -> list[Item]:
    if mode != "all":
        items = [item for item in items if mode_matches(item, mode)]
    if not query.strip():
        return items[:9] if mode != "all" else []
    terms = [normalize(term) for term in query.split() if term.strip()]
    ranked: list[tuple[int, int, Item]] = []
    for item in items:
        if not all(term in item.search_text or fuzzy_score(term, item) >= 0 for term in terms):
            continue
        score = fuzzy_score(normalize(query), item)
        if score >= 0:
            ranked.append((-score, len(item.clean_title), item))
    return [item for _, __, item in sorted(ranked, key=lambda row: (row[0], row[1]))[:9]]


def mode_matches(item: Item, mode: str) -> bool:
    return {
        "apps": item.kind == "app",
        "files": item.kind == "file",
        "settings": item.kind == "setting",
        "system": item.kind in {"action", "intent", "mode", "profile"},
        "web": item.kind in {"calc", "convert", "define", "web", "mail", "contacts", "calendar", "quick", "bookmark"},
        "clipboard": item.kind == "clipboard",
        "windows": item.kind == "window",
        "history": item.kind == "history",
    }.get(mode, True)


def dispatch_item(item: Item) -> None:
    if item.kind == "profile":
        subprocess.Popen(
            ["bash", "-lc", item.command],
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return
    subprocess.Popen(
        [str(ROOT / "bin/seven-spotlight"), "dispatch", item.kind, item.key, item.command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_SPOTLIGHT_NATIVE": "0"},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def dispatch_query(query: str) -> None:
    if not query.strip():
        return
    subprocess.Popen(
        [str(ROOT / "bin/seven-spotlight"), "query", query],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_SPOTLIGHT_NATIVE": "0"},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def shutil_which(command: str) -> str | None:
    for folder in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(folder) / command
        if candidate.exists() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def close_existing_spotlight() -> bool:
    if not shutil_which("hyprctl"):
        return False
    try:
        result = subprocess.run(
            ["hyprctl", "clients", "-j"],
            capture_output=True,
            text=True,
            check=False,
        )
        clients = json.loads(result.stdout or "[]")
    except (OSError, json.JSONDecodeError):
        return False
    for client in clients:
        if client.get("class") != "SevenSpotlightNative":
            continue
        address = str(client.get("address", "")).strip()
        if not address:
            continue
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{address}"], check=False)
        return True
    return False


def acquire_spotlight_lock() -> bool:
    global LOCK_HANDLE
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    LOCK_HANDLE = LOCK_FILE.open("w", encoding="utf-8")
    try:
        fcntl.flock(LOCK_HANDLE.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        return False
    LOCK_HANDLE.seek(0)
    LOCK_HANDLE.truncate()
    LOCK_HANDLE.write(f"{os.getpid()}\n")
    LOCK_HANDLE.flush()
    return True


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def profile_css(profile: dict, mode: str) -> str:
    accent = profile.get("accent") or "#8B7CFF"
    secondary = profile.get("secondary") or "#6EA8FF"
    glow = "0.18" if mode == "light" else "0.30"
    surface = "0.10" if mode == "light" else "0.16"
    return f"""
    .spotlight-root {{
      border-color: alpha({accent}, 0.28);
      box-shadow:
        0 24px 72px rgba(0,0,0,{'0.16' if mode == 'light' else '0.42'}),
        0 0 42px alpha({accent}, {glow});
    }}
    .spotlight-search {{
      border-color: alpha({accent}, 0.24);
      background:
        radial-gradient(ellipse at 10% -20%, alpha({accent}, {surface}), transparent 58%),
        alpha(#FFFFFF, {'0.82' if mode == 'light' else '0.10'});
    }}
    .category-button.active,
    .result-row.selected,
    .result-row:hover {{
      border-color: alpha({accent}, 0.34);
      background: alpha({accent}, {'0.15' if mode == 'light' else '0.18'});
    }}
    .ai-card {{
      border-color: alpha({secondary}, 0.24);
      background: alpha({secondary}, {'0.10' if mode == 'light' else '0.14'});
    }}
    """


