def run(mode: str, *, field_mode: bool = False) -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenSpotlightNative")
    GLib.set_application_name("SevenOS Spotlight")
    try:
        Gdk.set_program_class("SevenSpotlightNative")
    except Exception:
        pass

    theme_mode = current_theme_mode()
    Gtk.Settings.get_default().set_property("gtk-icon-theme-name", icon_theme_name(theme_mode))
    profile_ui = read_profile_ui()
    css = spotlight_css(theme_mode, profile_ui)
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    current_mode = mode if mode in {key for key, _, _ in CATEGORIES} else "all"
    result_rows: list[Gtk.Widget] = []
    current_matches: list[Item] = []
    selected_index = 0

    profile_title = profile_ui.get("title") or "SevenOS"
    items = profile_items(profile_ui) + read_cached_catalog(max_age=None)
    window = Gtk.Window(title=f"{profile_title} Spotlight")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_wmclass("SevenSpotlightNative", "SevenSpotlightNative")
    window.get_style_context().add_class("spotlight-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    root.get_style_context().add_class("spotlight-root")
    if field_mode:
        root.get_style_context().add_class("field-mode")
    window.add(root)

    entry = Gtk.Entry()
    # Keep "Search SevenOS" in source as the design-check baseline while the
    # runtime label adapts to the active mini OS through profile-ui.json.
    entry.set_placeholder_text(f"Search {profile_title}" if not field_mode else "Search apps, files, actions...")
    entry.set_icon_from_icon_name(Gtk.EntryIconPosition.PRIMARY, "system-search")
    entry.get_style_context().add_class("spotlight-search")
    root.pack_start(entry, False, False, 0)

    category_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    category_row.set_halign(Gtk.Align.CENTER)
    category_row.get_style_context().add_class("category-row")
    root.pack_start(category_row, False, False, 0)

    result_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    result_box.get_style_context().add_class("result-list")
    root.pack_start(result_box, False, False, 0)

    home = profile_ui.get("home_screen") if isinstance(profile_ui.get("home_screen"), dict) else {}
    persona = home.get("ai_persona") or "SevenAI"
    ai_card = Gtk.Label(label=f"{profile_title} · {persona} analyse les requêtes libres et demande confirmation avant les actions système.")
    ai_card.set_xalign(0)
    ai_card.get_style_context().add_class("ai-card")
    root.pack_start(ai_card, False, False, 0)

    category_buttons: dict[str, Gtk.Button] = {}

    def refresh_results() -> None:
        nonlocal result_rows, current_matches, selected_index
        for child in list(result_box.get_children()):
            result_box.remove(child)
        result_rows = []
        query = entry.get_text()
        current_matches = filter_items(items, query, current_mode)
        matches = current_matches
        selected_index = 0
        result_box.set_visible(bool(matches))
        ai_card.set_visible(bool(query.strip()) and not matches)
        for item in matches:
            row = make_result_row(item)
            result_box.pack_start(row, False, False, 0)
            result_rows.append(row)
        update_selection()
        result_box.show_all()

    def update_selection() -> None:
        for index, row in enumerate(result_rows):
            style = row.get_child().get_style_context()
            if index == selected_index:
                style.add_class("selected")
            else:
                style.remove_class("selected")

    def set_mode(new_mode: str) -> None:
        nonlocal current_mode
        current_mode = new_mode
        for key, button in category_buttons.items():
            if key == new_mode:
                button.get_style_context().add_class("active")
            else:
                button.get_style_context().remove_class("active")
        refresh_results()

    def make_category_button(key: str, icon_name: str, label: str) -> Gtk.Button:
        button = Gtk.Button()
        button.set_tooltip_text(label)
        button.get_style_context().add_class("category-button")
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        content.set_halign(Gtk.Align.CENTER)
        icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        icon.set_pixel_size(24)
        content.pack_start(icon, False, False, 0)
        text = Gtk.Label(label=label)
        text.get_style_context().add_class("category-label")
        content.pack_start(text, False, False, 0)
        button.add(content)
        button.connect("clicked", lambda _button: set_mode(key))
        category_buttons[key] = button
        return button

    def make_result_row(item: Item) -> Gtk.EventBox:
        event = Gtk.EventBox()
        event.set_visible_window(False)
        event.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        event.connect("button-press-event", lambda _widget, event_data, row_item=item: activate_result(row_item) if getattr(event_data, "button", 0) == 1 else False)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        row.get_style_context().add_class("result-row")
        icon = Gtk.Image.new_from_icon_name(item.icon, Gtk.IconSize.DIALOG)
        icon.set_pixel_size(30)
        row.pack_start(icon, False, False, 0)

        text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title = Gtk.Label(label=item.clean_title)
        title.set_xalign(0)
        title.get_style_context().add_class("result-title")
        meta_text = item.detail if item.detail else item.category
        meta = Gtk.Label(label=meta_text[:88])
        meta.set_xalign(0)
        meta.get_style_context().add_class("result-meta")
        text.pack_start(title, False, False, 0)
        text.pack_start(meta, False, False, 0)
        row.pack_start(text, True, True, 0)
        event.add(row)
        return event

    def activate_result(item: Item) -> bool:
        dispatch_item(item)
        window.destroy()
        return True

    def activate_current() -> None:
        query = entry.get_text().strip()
        if current_matches:
            dispatch_item(current_matches[selected_index])
        else:
            dispatch_query(query)
        window.destroy()

    def refresh_catalog_async() -> None:
        def worker() -> None:
            fresh_items = load_catalog(force=True)

            def apply_items() -> bool:
                nonlocal items
                items = profile_items(profile_ui) + fresh_items
                refresh_results()
                return False

            GLib.idle_add(apply_items)

        threading.Thread(target=worker, name="sevenos-spotlight-catalog", daemon=True).start()

    def on_key(_widget, event) -> bool:
        nonlocal selected_index
        if event.keyval == Gdk.KEY_Escape:
            window.destroy()
            return True
        if event.keyval in {Gdk.KEY_Down, Gdk.KEY_Tab} and result_rows:
            selected_index = min(selected_index + 1, len(result_rows) - 1)
            update_selection()
            return True
        if event.keyval == Gdk.KEY_Up and result_rows:
            selected_index = max(selected_index - 1, 0)
            update_selection()
            return True
        if Gdk.KEY_1 <= event.keyval <= Gdk.KEY_8 and event.state & Gdk.ModifierType.CONTROL_MASK:
            index = event.keyval - Gdk.KEY_1
            if index < len(CATEGORIES):
                set_mode(CATEGORIES[index][0])
                return True
        if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter}:
            activate_current()
            return True
        return False

    for category in CATEGORIES:
        category_row.pack_start(make_category_button(*category), False, False, 0)

    if field_mode:
        category_row.set_no_show_all(True)
        category_row.hide()

    entry.connect("changed", lambda _entry: refresh_results())
    window.connect("key-press-event", on_key)
    window.connect("destroy", Gtk.main_quit)
    window.set_default_size(560 if field_mode else 684, 0)
    window.show_all()
    set_mode(current_mode)
    refresh_catalog_async()
    entry.grab_focus()
    Gtk.main()
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--mode", default="all")
    parser.add_argument("--field", action="store_true")
    parser.add_argument("--probe", action="store_true")
    args = parser.parse_args()
    if args.probe:
        return probe()
    if not acquire_spotlight_lock():
        close_existing_spotlight()
        return 0
    if close_existing_spotlight():
        return 0
    return run(args.mode, field_mode=args.field)


if __name__ == "__main__":
    raise SystemExit(main())
