#!/usr/bin/env python3
"""Native SevenOS release review surface."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "scripts/release.sh").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent.parent / "scripts/release.sh").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "scripts/release.sh").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()


def language_code() -> str:
    language = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG", "en_US.UTF-8")
    config = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos/language.conf"
    if not os.environ.get("SEVENOS_LANGUAGE") and config.exists():
        for raw in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = raw.partition("=")
            if key.strip() in {"SEVENOS_LANGUAGE", "LANG"}:
                language = value.strip().strip("'\"")
                break
    return "fr" if language.lower().startswith("fr") else "en"


LANG = language_code()


def tr(fr: str, en: str) -> str:
    return fr if LANG == "fr" else en


def release_json(action: str) -> dict[str, object]:
    try:
        result = subprocess.run(
            [str(ROOT / "scripts/release.sh"), action, "--json"],
            cwd=str(ROOT),
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
            text=True,
            capture_output=True,
            timeout=25,
            check=False,
        )
        return json.loads(result.stdout or "{}") if result.stdout.strip() else {}
    except Exception:
        return {}


def run_detached(*command: str) -> None:
    subprocess.Popen(command, cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)


def open_terminal(command: str) -> None:
    wrapped = f"cd {json.dumps(str(ROOT))}; {command}; printf '\\nPress Enter to close...'; read -r"
    if (ROOT / "bin/seven-terminal").exists():
        run_detached(str(ROOT / "bin/seven-terminal"), "--", "bash", "-lc", wrapped)
    else:
        run_detached("bash", "-lc", wrapped)


def probe() -> int:
    review = release_json("review")
    print(json.dumps({"schema": "sevenos.release-review-native.v1", "root": str(ROOT), "state": review.get("state", "unknown"), "dirty_count": review.get("dirty_count", 0)}, ensure_ascii=False))
    return 0


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    if not (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        print(json.dumps(release_json("review"), ensure_ascii=False))
        return 0

    ensure_gi_python()
    import gi

    gi.require_version("Gtk", "3.0")
    gi.require_version("Gdk", "3.0")
    from gi.repository import Gdk, Gtk  # noqa: E402

    review = release_json("review")
    counts = review.get("counts") if isinstance(review.get("counts"), dict) else {}
    groups = review.get("groups") if isinstance(review.get("groups"), list) else []

    css = b"""
    .release-window { background: transparent; color: #f6f8fb; }
    .release-root {
      padding: 18px;
      border-radius: 28px;
      background: linear-gradient(145deg, rgba(255,255,255,0.15), rgba(255,255,255,0.052)), rgba(14,17,28,0.90);
      border: 1px solid rgba(255,255,255,0.17);
    }
    .title { font-size: 24px; font-weight: 600; color: #ffffff; }
    .subtitle { font-size: 12px; color: rgba(246,248,251,0.66); }
    .pill, .group-card {
      padding: 10px 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.070);
      border: 1px solid rgba(255,255,255,0.11);
    }
    .pill-title { font-size: 10px; color: rgba(246,248,251,0.54); }
    .pill-value { font-size: 16px; font-weight: 600; color: #ffffff; }
    .group-title { font-size: 14px; font-weight: 600; color: #ffffff; }
    .group-note, .path-row { font-size: 11px; color: rgba(246,248,251,0.66); }
    .present { border-color: rgba(126,206,255,0.34); background: rgba(77,163,255,0.10); }
    .quiet { opacity: 0.72; }
    button {
      min-height: 36px;
      padding: 0 14px;
      border-radius: 14px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.15);
      color: #ffffff;
    }
    button.primary { background: linear-gradient(135deg, #4da3ff, #7a5cff); }
    """

    provider = Gtk.CssProvider()
    provider.load_from_data(css)
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title="SevenOS Release Review")
    window.set_wmclass("SevenReleaseReviewNative", "SevenReleaseReviewNative")
    window.set_decorated(False)
    window.set_default_size(760, 620)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.get_style_context().add_class("release-window")
    visual = window.get_screen().get_rgba_visual()
    if visual:
        window.set_visual(visual)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.set_margin_top(12)
    root.set_margin_bottom(12)
    root.set_margin_start(12)
    root.set_margin_end(12)
    root.get_style_context().add_class("release-root")
    window.add(root)

    header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    title = Gtk.Label(label=tr("Revue release SevenOS", "SevenOS Release Review"), xalign=0)
    title.get_style_context().add_class("title")
    subtitle = Gtk.Label(label=f"{review.get('root', ROOT)} · {review.get('branch', 'main')} · {review.get('commit', '')}", xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    title_box.pack_start(title, False, False, 0)
    title_box.pack_start(subtitle, False, False, 0)
    header.pack_start(title_box, True, True, 0)
    close = Gtk.Button(label="×")
    close.connect("clicked", lambda *_: Gtk.main_quit())
    header.pack_end(close, False, False, 0)
    root.pack_start(header, False, False, 0)

    metrics = Gtk.Grid()
    metrics.set_column_spacing(8)
    metrics.set_column_homogeneous(True)
    metric_items = [
        (tr("État", "State"), str(review.get("state", "unknown"))),
        (tr("Modifiés", "Modified"), str(counts.get("modified", 0))),
        (tr("Non suivis", "Untracked"), str(counts.get("untracked", 0))),
        (tr("Total", "Total"), str(review.get("dirty_count", 0))),
    ]
    for index, (label, value) in enumerate(metric_items):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        box.get_style_context().add_class("pill")
        small = Gtk.Label(label=label, xalign=0)
        small.get_style_context().add_class("pill-title")
        strong = Gtk.Label(label=value, xalign=0)
        strong.get_style_context().add_class("pill-value")
        box.pack_start(small, False, False, 0)
        box.pack_start(strong, False, False, 0)
        metrics.attach(box, index, 0, 1, 1)
    root.pack_start(metrics, False, False, 0)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    body = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=9)
    scroller.add(body)
    root.pack_start(scroller, True, True, 0)

    for group in groups:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.get_style_context().add_class("group-card")
        card.get_style_context().add_class("present" if group.get("state") == "PRESENT" else "quiet")
        heading = Gtk.Label(label=str(group.get("title", "")), xalign=0)
        heading.get_style_context().add_class("group-title")
        note = Gtk.Label(label=str(group.get("reason", "")), xalign=0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("group-note")
        card.pack_start(heading, False, False, 0)
        card.pack_start(note, False, False, 0)
        for path in list(group.get("sample_paths") or [])[:8]:
            row = Gtk.Label(label=f"• {path}", xalign=0)
            row.set_ellipsize(3)
            row.get_style_context().add_class("path-row")
            card.pack_start(row, False, False, 0)
        body.pack_start(card, False, False, 0)

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    actions.set_halign(Gtk.Align.END)
    freeze = Gtk.Button(label=tr("Écrire le manifeste", "Write Manifest"))
    freeze.get_style_context().add_class("primary")
    freeze.connect("clicked", lambda *_: open_terminal("seven release freeze --json | python -m json.tool"))
    quality = Gtk.Button(label=tr("Gate qualité", "Quality Gate"))
    quality.connect("clicked", lambda *_: open_terminal("seven quality doctor"))
    identity = Gtk.Button(label=tr("Identité", "Identity"))
    identity.connect("clicked", lambda *_: run_detached(str(ROOT / "bin/seven"), "identity", "open"))
    status = Gtk.Button(label="git status")
    status.connect("clicked", lambda *_: open_terminal("git status --short"))
    actions.pack_start(status, False, False, 0)
    actions.pack_start(identity, False, False, 0)
    actions.pack_start(quality, False, False, 0)
    actions.pack_start(freeze, False, False, 0)
    root.pack_end(actions, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
