def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def truthy(value: str) -> bool:
    return str(value).strip().lower() in {"1", "true", "yes"}


def normalize(value: str) -> str:
    normalized = unicodedata.normalize("NFKD", value or "")
    return "".join(char for char in normalized if not unicodedata.combining(char)).casefold()


def read_json(path: Path, default):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return default


def read_profile_ui() -> dict:
    data = read_json(PROFILE_UI_FILE, {})
    return data if isinstance(data, dict) else {}


def default_filter_for_profile(profile: dict) -> str:
    home = profile.get("home_screen") if isinstance(profile.get("home_screen"), dict) else {}
    if home.get("launchpad_filter"):
        return str(home["launchpad_filter"])
    key = profile.get("profile", "equinox")
    return {
        "forge": "dev",
        "studio": "creative",
        "atlas": "atlas",
        "pulse": "games",
        "baobab": "office",
        "shield": "network",
    }.get(key, "all")


def mini_os_section_label(key: str, fallback: str, profile: dict) -> str:
    profile_key = str(profile.get("profile", active_profile_key()) or "equinox")
    return PROFILE_SECTION_LABELS.get(profile_key, {}).get(key, fallback)


def mini_os_worlds(profile: dict) -> list[dict]:
    active = str(profile.get("profile", active_profile_key()) or "equinox")
    order = [active, *[key for key in WORLD_ORDER if key != active]]
    worlds = []
    for key in order:
        world = dict(MINI_OS_WORLDS[key])
        world["key"] = key
        world["active"] = key == active
        worlds.append(world)
    return worlds


def world_app_count(apps: list[dict], world: dict) -> int:
    categories = set(world.get("categories", []))
    return sum(1 for app in apps if app.get("category", "all") in categories or (world.get("filter") == "all" and app.get("sevenos_core")))


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True), encoding="utf-8")


def current_theme_mode() -> str:
    env_mode = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    if env_mode in {"dark", "light"}:
        return env_mode
    try:
        for raw in THEME_CONF.read_text(encoding="utf-8", errors="replace").splitlines():
            if "=" not in raw or raw.strip().startswith("#"):
                continue
            key, value = [part.strip().lower() for part in raw.split("=", 1)]
            if key in {"mode", "theme_mode", "sevenos_theme_mode"} and value in {"dark", "light"}:
                return value
    except OSError:
        pass
    return "dark"


def icon_theme_name(mode: str) -> str:
    settings = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "gtk-3.0/settings.ini"
    try:
        for raw in settings.read_text(encoding="utf-8", errors="replace").splitlines():
            if raw.strip().startswith("gtk-icon-theme-name="):
                value = raw.split("=", 1)[1].strip()
                if value:
                    return value
    except OSError:
        pass
    return "Papirus-Dark" if mode == "dark" else "Papirus"


def prefs() -> dict:
    data = read_json(PREFS_FILE, {})
    return {
        "favorites": list(dict.fromkeys(data.get("favorites", []))),
        "hidden": set(data.get("hidden", [])),
    }


def save_prefs(favorites: list[str], hidden: set[str]) -> None:
    write_json(PREFS_FILE, {"favorites": favorites, "hidden": sorted(hidden)})


def recents() -> dict:
    data = read_json(RECENTS_FILE, {})
    if isinstance(data, dict):
        return {str(key): float(value) for key, value in data.items() if str(key)}
    return {}


def record_recent(app: dict) -> None:
    data = recents()
    data[app["desktop_id"]] = time.time()
    keep = dict(sorted(data.items(), key=lambda item: item[1], reverse=True)[:40])
    write_json(RECENTS_FILE, keep)


def active_profile_key() -> str:
    profile = os.environ.get("SEVENOS_ACTIVE_PROFILE", "equinox").strip().strip("'\"") or "equinox"
    profile_env = CONFIG_DIR / "profile.env"
    if profile_env.exists():
        for raw in profile_env.read_text(encoding="utf-8", errors="replace").splitlines():
            if raw.startswith("SEVENOS_ACTIVE_PROFILE="):
                profile = raw.split("=", 1)[1].strip().strip("'\"") or profile
                break
    return profile


def app_dirs() -> list[Path]:
    data_home = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share"))
    profile = active_profile_key()
    data_dirs = [
        data_home / "sevenos/profiles" / profile,
        data_home,
        Path.home() / ".local/share/flatpak/exports/share",
        Path("/var/lib/flatpak/exports/share"),
    ]
    for raw in os.environ.get("XDG_DATA_DIRS", "/usr/local/share:/usr/share").split(":"):
        if raw:
            data_dirs.append(Path(raw))
    return data_dirs


def cache_signature() -> dict:
    paths: list[Path] = []
    for base in app_dirs():
        app_dir = base / "applications"
        if app_dir.is_dir():
            paths.extend(app_dir.glob("*.desktop"))
    newest = 0
    for path in paths:
        try:
            newest = max(newest, int(path.stat().st_mtime))
        except OSError:
            continue
    for path in CORE_DESKTOP_FILES:
        try:
            newest = max(newest, int(path.stat().st_mtime))
        except OSError:
            continue
    return {"profile": active_profile_key(), "count": len(paths), "core_count": len(CORE_DESKTOP_FILES), "newest": newest}


def category_for(data: dict) -> str:
    if truthy(str(data.get("sevenos_core", "false"))):
        return "sevenos"
    categories = {item for item in data.get("categories", "").split(";") if item}
    joined = normalize(" ".join((data.get("name", ""), data.get("desktop_id", ""), data.get("path", ""))))
    if {"Wine", "Bottles"} & categories or "wine" in joined or "bottles" in joined:
        return "atlas"
    if "Development" in categories:
        return "dev"
    if "Graphics" in categories:
        return "creative"
    if "AudioVideo" in categories or "Audio" in categories or "Video" in categories:
        return "media"
    if "Network" in categories:
        return "network"
    if "Game" in categories:
        return "games"
    if "Office" in categories:
        return "office"
    if {"System", "Settings", "Utility"} & categories:
        return "system"
    return "all"


def fallback_icon(categories: str) -> str:
    cats = {item for item in categories.split(";") if item}
    if "SevenOS" in cats:
        return "seven-hub"
    if "Culture" in cats or "Education" in cats or "Maps" in cats:
        return "seven-baobab"
    if "Development" in cats:
        return "applications-development"
    if "Graphics" in cats:
        return "applications-graphics"
    if "AudioVideo" in cats or "Audio" in cats or "Video" in cats:
        return "applications-multimedia"
    if "Network" in cats:
        return "applications-internet"
    if "System" in cats or "Settings" in cats:
        return "preferences-system"
    if "Utility" in cats:
        return "applications-utilities"
    if "Game" in cats:
        return "applications-games"
    if "Office" in cats:
        return "applications-office"
    return "applications-utilities"


def icon_candidates(app: dict) -> list[str]:
    raw_icon = str(app.get("icon", "")).strip()
    categories = str(app.get("categories", ""))
    desktop_id = normalize(str(app.get("desktop_id", "")))
    name = normalize(str(app.get("name", "")))
    candidates: list[str] = []
    if raw_icon:
        candidates.append(raw_icon)
    if "baobab" in desktop_id or "baobab" in name or "Culture" in categories:
        candidates.append("seven-baobab")
    candidates.append(fallback_icon(categories))
    if app.get("sevenos_core") or desktop_id.startswith("seven-") or "SevenOS" in categories:
        candidates.append("seven-hub")
    candidates.extend(["applications-utilities", "application-x-executable"])
    return list(dict.fromkeys(item for item in candidates if item))


def read_desktop(path: Path):
    data = {}
    in_entry = False
    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None

    for raw in content.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            in_entry = line == "[Desktop Entry]"
            continue
        if not in_entry or "=" not in line:
            continue
        key, value = line.split("=", 1)
        data.setdefault(key.strip(), value.strip())

    if data.get("Type", "Application") != "Application":
        return None
    if truthy(data.get("Hidden", "false")):
        return None
    if truthy(data.get("NoDisplay", "false")) and os.environ.get("SEVENOS_APPS_SHOW_HIDDEN") != "1":
        return None
    if not data.get("Exec"):
        return None

    entry = {
        "name": data.get("Name") or data.get("Name[en_US]") or path.stem,
        "desktop_id": path.name,
        "path": str(path),
        "comment": data.get("Comment", ""),
        "categories": data.get("Categories", ""),
        "icon": data.get("Icon") or fallback_icon(data.get("Categories", "")),
        "exec": data.get("Exec", ""),
    }
    entry["sevenos_core"] = path in CORE_DESKTOP_FILES or "SevenOS" in {item for item in entry["categories"].split(";") if item}
    entry["category"] = category_for(entry)
    entry["search"] = normalize(" ".join((entry["name"], entry["comment"], entry["categories"], entry["desktop_id"])))
    return entry


def core_app_entry(raw: dict, source_path: Path | None = None) -> dict:
    entry = {
        "name": raw["name"],
        "desktop_id": raw["desktop_id"],
        "path": str(source_path or ROOT_DIR / "seven-hub" / raw["desktop_id"]),
        "comment": raw.get("comment", ""),
        "categories": "SevenOS;System;Utility;",
        "icon": raw.get("icon", "application-x-executable"),
        "exec": raw.get("exec", ""),
        "sevenos_core": True,
        "category": "sevenos",
    }
    entry["search"] = normalize(" ".join((entry["name"], entry["comment"], entry["categories"], entry["desktop_id"], "sevenos core mini os base")))
    return entry


def core_apps() -> list[dict]:
    entries: list[dict] = []
    seen: set[str] = set()
    for path in CORE_DESKTOP_FILES:
        entry = read_desktop(path)
        if not entry:
            continue
        entry["sevenos_core"] = True
        entry["category"] = "sevenos"
        entry["search"] = normalize(" ".join((entry["name"], entry["comment"], entry["categories"], entry["desktop_id"], "sevenos core mini os base")))
        entries.append(entry)
        seen.add(entry["desktop_id"])
    for raw in CORE_APP_FALLBACKS:
        if raw["desktop_id"] not in seen:
            entries.append(core_app_entry(raw))
    return entries


def canonical_app_key(app: dict) -> str:
    name = normalize(app.get("name", "")).strip()
    desktop_id = normalize(Path(str(app.get("desktop_id", ""))).stem)
    return name or desktop_id


def app_priority(app: dict) -> tuple[int, str]:
    path = str(app.get("path", ""))
    score = 0
    if app.get("sevenos_core"):
        score += 1000
    if "/sevenos/profiles/" in path:
        score += 160
    if path.startswith(str(Path.home() / ".local/share")):
        score += 90
    if "/flatpak/exports/share/" in path:
        score += 70
    if path.startswith("/usr/local/share"):
        score += 50
    if path.startswith("/usr/share"):
        score += 20
    if app.get("exec"):
        score += 10
    return score, normalize(app.get("desktop_id", ""))


def dedupe_apps(apps: list[dict]) -> list[dict]:
    by_desktop_id: dict[str, dict] = {}
    for app in apps:
        desktop_id = str(app.get("desktop_id", ""))
        existing = by_desktop_id.get(desktop_id)
        if existing is None or app_priority(app) > app_priority(existing):
            by_desktop_id[desktop_id] = app

    by_name: dict[str, dict] = {}
    for app in by_desktop_id.values():
        key = canonical_app_key(app)
        existing = by_name.get(key)
        if existing is None or app_priority(app) > app_priority(existing):
            by_name[key] = app

    return sorted(by_name.values(), key=lambda app: (0 if app.get("sevenos_core") else 1, app["name"].casefold()))


def duplicate_groups(apps: list[dict]) -> list[dict]:
    groups: dict[str, list[dict]] = {}
    seen: set[tuple[str, str, str]] = set()
    for app in apps:
        signature = (
            canonical_app_key(app),
            str(app.get("desktop_id", "")),
            str(app.get("path", "")),
        )
        if signature in seen:
            continue
        seen.add(signature)
        groups.setdefault(canonical_app_key(app), []).append(app)
    duplicates = []
    for key, items in groups.items():
        if len(items) < 2:
            continue
        duplicates.append(
            {
                "key": key,
                "name": items[0].get("name", key),
                "count": len(items),
                "desktop_ids": sorted(str(item.get("desktop_id", "")) for item in items),
            }
        )
    return sorted(duplicates, key=lambda item: (-item["count"], item["name"].casefold()))


def read_cached_apps() -> list[dict]:
    cached = read_json(CACHE_FILE, {})
    if cached.get("signature") != cache_signature():
        return []
    if cached.get("schema") not in {CATALOG_SCHEMA, "sevenos.apps.v1"}:
        return []
    apps = cached.get("apps")
    return apps if isinstance(apps, list) else []


def write_apps_cache(apps: list[dict], raw_count: int, duplicates: list[dict]) -> None:
    write_json(
        CACHE_FILE,
        {
            "schema": CATALOG_SCHEMA,
            "signature": cache_signature(),
            "generated_at": time.time(),
            "raw_count": raw_count,
            "count": len(apps),
            "duplicates": duplicates,
            "apps": apps,
        },
    )


def scan_apps() -> list[dict]:
    seen = set()
    apps = []
    core_ids = {item["desktop_id"] for item in core_apps()}
    for base in app_dirs():
        app_dir = base / "applications"
        if not app_dir.is_dir():
            continue
        for path in app_dir.glob("*.desktop"):
            if str(path) in seen:
                continue
            seen.add(str(path))
            entry = read_desktop(path)
            if entry:
                if entry["desktop_id"] in core_ids:
                    entry["sevenos_core"] = True
                    entry["category"] = "sevenos"
                apps.append(entry)
    for app in core_apps():
        apps.append(app)
    return dedupe_apps(apps)


def scan_apps_with_report() -> tuple[list[dict], int, list[dict]]:
    seen = set()
    raw_apps = []
    core_ids = {item["desktop_id"] for item in core_apps()}
    for base in app_dirs():
        app_dir = base / "applications"
        if not app_dir.is_dir():
            continue
        for path in app_dir.glob("*.desktop"):
            if str(path) in seen:
                continue
            seen.add(str(path))
            entry = read_desktop(path)
            if entry:
                if entry["desktop_id"] in core_ids:
                    entry["sevenos_core"] = True
                    entry["category"] = "sevenos"
                raw_apps.append(entry)
    raw_apps.extend(core_apps())
    duplicates = duplicate_groups(raw_apps)
    return dedupe_apps(raw_apps), len(raw_apps), duplicates


def load_apps(force: bool = False) -> list[dict]:
    if not force:
        cached_apps = read_cached_apps()
        if cached_apps:
            return cached_apps
    apps, raw_count, duplicates = scan_apps_with_report()
    write_apps_cache(apps, raw_count, duplicates)
    return apps


def category_counts(apps: list[dict]) -> dict[str, int]:
    counts = {key: 0 for key, _label, _icon in CATEGORIES}
    for app in apps:
        counts["all"] += 1
        category = app.get("category", "all")
        if category in counts and category != "all":
            counts[category] += 1
    return counts


def launchpad_doctor_payload(refresh: bool = False) -> dict:
    start = time.perf_counter()
    apps = load_apps(force=refresh)
    elapsed_ms = round((time.perf_counter() - start) * 1000, 2)
    cached = read_json(CACHE_FILE, {})
    duplicates = cached.get("duplicates", []) if isinstance(cached, dict) else []
    state = "ready" if apps else "needs-apps"
    return {
        "schema": "sevenos.launchpad.doctor.v1",
        "state": state,
        "profile": active_profile_key(),
        "profile_sections": PROFILE_SECTION_LABELS.get(active_profile_key(), {}),
        "mini_os_worlds": [
            {
                "key": world["key"],
                "title": world["title"],
                "filter": world["filter"],
                "categories": world["categories"],
                "apps": world_app_count(apps, world),
                "active": world["active"],
            }
            for world in mini_os_worlds(read_profile_ui())
        ],
        "cache": {
            "path": str(CACHE_FILE),
            "exists": CACHE_FILE.exists(),
            "schema": cached.get("schema") if isinstance(cached, dict) else None,
            "signature_valid": bool(read_cached_apps()),
            "raw_count": int(cached.get("raw_count", len(apps))) if isinstance(cached, dict) else len(apps),
            "count": len(apps),
        },
        "catalog": {
            "apps": len(apps),
            "sevenos_core": sum(1 for app in apps if app.get("sevenos_core")),
            "categories": category_counts(apps),
            "duplicates_grouped": len(duplicates) if isinstance(duplicates, list) else 0,
            "duplicate_samples": duplicates[:12] if isinstance(duplicates, list) else [],
        },
        "performance": {
            "load_ms": elapsed_ms,
            "progressive_loading": True,
            "background_refresh": True,
        },
        "commands": [
            "seven launchpad open",
            "seven launchpad refresh",
            "seven launchpad doctor --json",
            "seven launchpad catalog",
        ],
    }


def print_launchpad_doctor(json_mode: bool = False, refresh: bool = False) -> int:
    payload = launchpad_doctor_payload(refresh=refresh)
    if json_mode:
        print(json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True))
        return 0 if payload["state"] == "ready" else 1
    print("SevenOS Launchpad Doctor")
    print("========================")
    print(f"State: {payload['state']}")
    print(f"Profile: {payload['profile']}")
    print(f"Apps: {payload['catalog']['apps']} ({payload['catalog']['sevenos_core']} SevenOS)")
    print(f"Cache: {payload['cache']['path']}")
    print(f"Load: {payload['performance']['load_ms']} ms")
    print(f"Duplicates grouped: {payload['catalog']['duplicates_grouped']}")
    return 0 if payload["state"] == "ready" else 1


def shutil_which(command: str) -> str | None:
    for folder in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(folder) / command
        if candidate.exists() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def run_detached(command: list[str]) -> None:
    try:
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=launch_environment())
    except OSError:
        pass


def hyprctl_dispatch(*args: str) -> bool:
    if not shutil_which("hyprctl"):
        return False
    try:
        result = subprocess.run(
            ["hyprctl", "dispatch", *args],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
            timeout=1.5,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    return result.returncode == 0


def enter_modal_submap() -> None:
    global MODAL_SUBMAP_ACTIVE
    if hyprctl_dispatch("submap", "sevenos-launchpad"):
        MODAL_SUBMAP_ACTIVE = True


def leave_modal_submap() -> None:
    global MODAL_SUBMAP_ACTIVE
    if not MODAL_SUBMAP_ACTIVE:
        return
    hyprctl_dispatch("submap", "reset")
    MODAL_SUBMAP_ACTIVE = False


def log_launch(message: str) -> None:
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a", encoding="utf-8") as handle:
            handle.write(f"{time.strftime('%Y-%m-%d %H:%M:%S')} {message}\n")
    except OSError:
        pass


def launch_environment() -> dict:
    env = os.environ.copy()
    user_bin = str(Path.home() / ".local/bin")
    repo_bin = str(ROOT_DIR / "bin")
    path_parts = [user_bin, repo_bin]
    for part in env.get("PATH", "").split(os.pathsep):
        if part and part not in path_parts:
            path_parts.append(part)
    env["PATH"] = os.pathsep.join(path_parts)
    env.setdefault("SEVENOS_ROOT", str(ROOT_DIR))
    return env


def parse_desktop_exec(exec_line: str) -> list[str]:
    try:
        parts = shlex.split(exec_line)
    except ValueError:
        return []

    command = []
    for part in parts:
        if part in {"%f", "%F", "%u", "%U", "%i", "%c", "%k", "%d", "%D", "%n", "%N", "%v", "%m"}:
            continue
        command.append(part.replace("%%", "%"))
    return command


def launch_desktop_exec(app: dict) -> bool:
    command = parse_desktop_exec(app.get("exec", ""))
    if not command:
        return False
    shell_experience("launch", app.get("name") or app.get("desktop_id") or "Application", app.get("desktop_id", ""))
    helper = ROOT_DIR / "bin" / "seven-profile-launch"
    if helper.exists():
        try:
            result = subprocess.run(
                [str(helper), app.get("desktop_id", ""), app.get("path", ""), "--", *command],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                env=launch_environment(),
                check=False,
                timeout=1.5,
            )
            if result.returncode == 0:
                log_launch(f"profile launch ok: {' '.join(command)}")
                record_recent(app)
                return True
            log_launch(f"profile launch blocked: {' '.join(command)} rc={result.returncode}")
            return True
        except (OSError, subprocess.TimeoutExpired) as exc:
            log_launch(f"profile launch failed: {' '.join(command)} :: {exc}")
    try:
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=launch_environment())
        log_launch(f"launch exec ok: {' '.join(command)}")
        record_recent(app)
        return True
    except OSError as exc:
        log_launch(f"launch exec failed: {' '.join(command)} :: {exc}")
        return False


def close_existing_launchpad() -> bool:
    if not shutil_which("hyprctl"):
        return False
    try:
        result = subprocess.run(
            ["hyprctl", "clients", "-j"],
            capture_output=True,
            text=True,
            check=False,
        )
        clients = json.loads(result.stdout or "[]")
    except (OSError, json.JSONDecodeError):
        return False

    launchpad_classes = {"SevenLaunchpadNative", "seven-launchpad-native"}
    for client in clients:
        client_class = str(client.get("class", ""))
        client_title = str(client.get("title", ""))
        if client_class not in launchpad_classes and client_title != "SevenOS Launchpad":
            continue
        address = str(client.get("address", "")).strip()
        if not address:
            continue
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{address}"], check=False)
        return True
    return False


def acquire_launchpad_lock() -> bool:
    global LOCK_HANDLE
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    LOCK_HANDLE = LOCK_FILE.open("w", encoding="utf-8")
    try:
        fcntl.flock(LOCK_HANDLE.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        return False
    LOCK_HANDLE.seek(0)
    LOCK_HANDLE.truncate()
    LOCK_HANDLE.write(f"{os.getpid()}\n")
    LOCK_HANDLE.flush()
    return True


def launch_app(app) -> None:
    if launch_desktop_exec(app):
        return

    desktop_id = app["desktop_id"]
    desktop_path = app["path"]
    commands = [
        ["gtk-launch", desktop_id.removesuffix(".desktop")],
        ["gtk-launch", desktop_id],
        ["gio", "launch", desktop_path],
        ["dex", desktop_path],
    ]
    for command in commands:
        if not shutil_which(command[0]):
            continue
        try:
            shell_experience("launch", app.get("name") or desktop_id, desktop_id)
            subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=launch_environment())
            log_launch(f"launch fallback ok: {' '.join(command)}")
            record_recent(app)
            return
        except OSError as exc:
            log_launch(f"launch fallback failed: {' '.join(command)} :: {exc}")
            continue
    log_launch(f"launch failed: {app.get('desktop_id', app.get('name', 'unknown'))}")


def shell_experience(kind: str, label: str, detail: str = "") -> None:
    helper = ROOT_DIR / "scripts/shell-experience.sh"
    if not helper.exists():
        return
    try:
        subprocess.Popen([str(helper), kind, label, detail], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        return


def fuzzy_score(query: str, app: dict, favorites: list[str], recent_map: dict) -> int:
    if not query:
        score = 10
    else:
        haystack = app.get("search") or normalize(" ".join((app["name"], app["comment"], app["categories"])))
        name = normalize(app["name"])
        if name == query:
            score = 120
        elif name.startswith(query):
            score = 100
        elif query in haystack:
            score = 70
        else:
            position = 0
            score = 0
            for char in query:
                found = haystack.find(char, position)
                if found == -1:
                    return -1
                score += 3
                position = found + 1
    if app["desktop_id"] in favorites:
        score += 28
    if app["desktop_id"] in recent_map:
        score += 16
    return score


def profile_css(profile: dict, mode: str) -> str:
    accent = profile.get("accent") or "#8B7CFF"
    secondary = profile.get("secondary") or "#6EA8FF"
    return f"""
    .launchpad-topbar {{
      border-color: alpha({accent}, 0.26);
      box-shadow:
        0 22px 60px rgba(0,0,0,{'0.14' if mode == 'light' else '0.34'}),
        0 0 34px alpha({accent}, {'0.18' if mode == 'light' else '0.20'});
    }}
    .launchpad-filter:checked {{
      background: linear-gradient(135deg, {accent}, {secondary});
      box-shadow: 0 8px 24px alpha({accent}, {'0.22' if mode == 'light' else '0.28'});
    }}
    .launchpad-search {{
      border-color: alpha({accent}, 0.22);
    }}
    .launchpad-suggestion {{
      border-color: alpha({secondary}, 0.22);
      background: alpha({secondary}, {'0.12' if mode == 'light' else '0.13'});
    }}
    """


