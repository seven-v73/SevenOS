#!/usr/bin/env python3
"""SevenOS native Launchpad surface with context, cache and large app icons."""

from __future__ import annotations

import argparse
import fcntl
import json
import os
import subprocess
import sys
import time
import unicodedata
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "scripts"))
from seven_i18n import tr_text  # noqa: E402


CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "sevenos"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos"
RUNTIME_DIR = Path(os.environ.get("XDG_RUNTIME_DIR", f"/tmp/sevenos-{os.getuid()}")) / "sevenos"
THEME_CONF = CONFIG_DIR / "theme.conf"
PREFS_FILE = CONFIG_DIR / "launchpad.json"
RECENTS_FILE = STATE_DIR / "launchpad-recents.json"
CACHE_FILE = CACHE_DIR / "apps.json"
LOCK_FILE = RUNTIME_DIR / "launchpad.lock"
LOCK_HANDLE = None

CATEGORIES = [
    ("all", "All", "view-app-grid-symbolic"),
    ("favorites", "Favorites", "emblem-favorite-symbolic"),
    ("recent", "Recent", "document-open-recent-symbolic"),
    ("dev", "Dev", "applications-development-symbolic"),
    ("creative", "Creative", "applications-graphics-symbolic"),
    ("system", "System", "preferences-system-symbolic"),
    ("network", "Network", "applications-internet-symbolic"),
    ("media", "Media", "applications-multimedia-symbolic"),
    ("office", "Office", "x-office-document-symbolic"),
    ("games", "Games", "applications-games-symbolic"),
    ("windows", "Windows", "computer-symbolic"),
]


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def truthy(value: str) -> bool:
    return str(value).strip().lower() in {"1", "true", "yes"}


def normalize(value: str) -> str:
    normalized = unicodedata.normalize("NFKD", value or "")
    return "".join(char for char in normalized if not unicodedata.combining(char)).casefold()


def read_json(path: Path, default):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return default


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True), encoding="utf-8")


def current_theme_mode() -> str:
    env_mode = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    if env_mode in {"dark", "light"}:
        return env_mode
    try:
        for raw in THEME_CONF.read_text(encoding="utf-8", errors="replace").splitlines():
            if "=" not in raw or raw.strip().startswith("#"):
                continue
            key, value = [part.strip().lower() for part in raw.split("=", 1)]
            if key in {"mode", "theme_mode", "sevenos_theme_mode"} and value in {"dark", "light"}:
                return value
    except OSError:
        pass
    return "dark"


def icon_theme_name(mode: str) -> str:
    settings = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "gtk-3.0/settings.ini"
    try:
        for raw in settings.read_text(encoding="utf-8", errors="replace").splitlines():
            if raw.strip().startswith("gtk-icon-theme-name="):
                value = raw.split("=", 1)[1].strip()
                if value:
                    return value
    except OSError:
        pass
    return "Papirus-Dark" if mode == "dark" else "Papirus"


def prefs() -> dict:
    data = read_json(PREFS_FILE, {})
    return {
        "favorites": list(dict.fromkeys(data.get("favorites", []))),
        "hidden": set(data.get("hidden", [])),
    }


def save_prefs(favorites: list[str], hidden: set[str]) -> None:
    write_json(PREFS_FILE, {"favorites": favorites, "hidden": sorted(hidden)})


def recents() -> dict:
    data = read_json(RECENTS_FILE, {})
    if isinstance(data, dict):
        return {str(key): float(value) for key, value in data.items() if str(key)}
    return {}


def record_recent(app: dict) -> None:
    data = recents()
    data[app["desktop_id"]] = time.time()
    keep = dict(sorted(data.items(), key=lambda item: item[1], reverse=True)[:40])
    write_json(RECENTS_FILE, keep)


def app_dirs() -> list[Path]:
    data_dirs = [
        Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share")),
        Path.home() / ".local/share/flatpak/exports/share",
        Path("/var/lib/flatpak/exports/share"),
    ]
    for raw in os.environ.get("XDG_DATA_DIRS", "/usr/local/share:/usr/share").split(":"):
        if raw:
            data_dirs.append(Path(raw))
    return data_dirs


def cache_signature() -> dict:
    paths: list[Path] = []
    for base in app_dirs():
        app_dir = base / "applications"
        if app_dir.is_dir():
            paths.extend(app_dir.glob("*.desktop"))
    newest = 0
    for path in paths:
        try:
            newest = max(newest, int(path.stat().st_mtime))
        except OSError:
            continue
    return {"count": len(paths), "newest": newest}


def category_for(data: dict) -> str:
    categories = {item for item in data.get("categories", "").split(";") if item}
    joined = normalize(" ".join((data.get("name", ""), data.get("desktop_id", ""), data.get("path", ""))))
    if {"Wine", "Bottles"} & categories or "wine" in joined or "bottles" in joined:
        return "windows"
    if "Development" in categories:
        return "dev"
    if "Graphics" in categories:
        return "creative"
    if "AudioVideo" in categories or "Audio" in categories or "Video" in categories:
        return "media"
    if "Network" in categories:
        return "network"
    if "Game" in categories:
        return "games"
    if "Office" in categories:
        return "office"
    if {"System", "Settings", "Utility"} & categories:
        return "system"
    return "all"


def fallback_icon(categories: str) -> str:
    cats = {item for item in categories.split(";") if item}
    if "Development" in cats:
        return "applications-development"
    if "Graphics" in cats:
        return "applications-graphics"
    if "AudioVideo" in cats or "Audio" in cats or "Video" in cats:
        return "applications-multimedia"
    if "Network" in cats:
        return "applications-internet"
    if "System" in cats or "Settings" in cats:
        return "preferences-system"
    if "Utility" in cats:
        return "applications-utilities"
    if "Game" in cats:
        return "applications-games"
    if "Office" in cats:
        return "applications-office"
    return "application-x-executable"


def read_desktop(path: Path):
    data = {}
    in_entry = False
    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None

    for raw in content.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("[") and line.endswith("]"):
            in_entry = line == "[Desktop Entry]"
            continue
        if not in_entry or "=" not in line:
            continue
        key, value = line.split("=", 1)
        data.setdefault(key.strip(), value.strip())

    if data.get("Type", "Application") != "Application":
        return None
    if truthy(data.get("Hidden", "false")):
        return None
    if truthy(data.get("NoDisplay", "false")) and os.environ.get("SEVENOS_APPS_SHOW_HIDDEN") != "1":
        return None
    if not data.get("Exec"):
        return None

    entry = {
        "name": data.get("Name") or data.get("Name[en_US]") or path.stem,
        "desktop_id": path.name,
        "path": str(path),
        "comment": data.get("Comment", ""),
        "categories": data.get("Categories", ""),
        "icon": data.get("Icon") or fallback_icon(data.get("Categories", "")),
    }
    entry["category"] = category_for(entry)
    entry["search"] = normalize(" ".join((entry["name"], entry["comment"], entry["categories"], entry["desktop_id"])))
    return entry


def scan_apps() -> list[dict]:
    seen = set()
    apps = []
    for base in app_dirs():
        app_dir = base / "applications"
        if not app_dir.is_dir():
            continue
        for path in app_dir.glob("*.desktop"):
            if str(path) in seen:
                continue
            seen.add(str(path))
            entry = read_desktop(path)
            if entry:
                apps.append(entry)
    return sorted(apps, key=lambda app: app["name"].casefold())


def load_apps() -> list[dict]:
    signature = cache_signature()
    cached = read_json(CACHE_FILE, {})
    if cached.get("signature") == signature and isinstance(cached.get("apps"), list):
        return cached["apps"]
    apps = scan_apps()
    write_json(CACHE_FILE, {"schema": "sevenos.apps.v1", "signature": signature, "apps": apps})
    return apps


def shutil_which(command: str) -> str | None:
    for folder in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(folder) / command
        if candidate.exists() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def run_detached(command: list[str]) -> None:
    try:
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError:
        pass


def close_existing_launchpad() -> bool:
    if not shutil_which("hyprctl"):
        return False
    try:
        result = subprocess.run(
            ["hyprctl", "clients", "-j"],
            capture_output=True,
            text=True,
            check=False,
        )
        clients = json.loads(result.stdout or "[]")
    except (OSError, json.JSONDecodeError):
        return False

    for client in clients:
        if client.get("class") != "SevenLaunchpadNative":
            continue
        address = str(client.get("address", "")).strip()
        if not address:
            continue
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{address}"], check=False)
        return True
    return False


def acquire_launchpad_lock() -> bool:
    global LOCK_HANDLE
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    LOCK_HANDLE = LOCK_FILE.open("w", encoding="utf-8")
    try:
        fcntl.flock(LOCK_HANDLE.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        return False
    LOCK_HANDLE.seek(0)
    LOCK_HANDLE.truncate()
    LOCK_HANDLE.write(f"{os.getpid()}\n")
    LOCK_HANDLE.flush()
    return True


def launch_app(app) -> None:
    desktop_id = app["desktop_id"]
    desktop_path = app["path"]
    commands = [
        ["gtk-launch", desktop_id.removesuffix(".desktop")],
        ["gtk-launch", desktop_id],
        ["gio", "launch", desktop_path],
        ["dex", desktop_path],
    ]
    for command in commands:
        if not shutil_which(command[0]):
            continue
        try:
            subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            record_recent(app)
            return
        except OSError:
            continue


def fuzzy_score(query: str, app: dict, favorites: list[str], recent_map: dict) -> int:
    if not query:
        score = 10
    else:
        haystack = app.get("search") or normalize(" ".join((app["name"], app["comment"], app["categories"])))
        name = normalize(app["name"])
        if name == query:
            score = 120
        elif name.startswith(query):
            score = 100
        elif query in haystack:
            score = 70
        else:
            position = 0
            score = 0
            for char in query:
                found = haystack.find(char, position)
                if found == -1:
                    return -1
                score += 3
                position = found + 1
    if app["desktop_id"] in favorites:
        score += 28
    if app["desktop_id"] in recent_map:
        score += 16
    return score


