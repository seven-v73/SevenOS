def run_launchpad() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GdkPixbuf, GLib, Gtk, Pango

    enter_modal_submap()
    atexit.register(leave_modal_submap)

    mode = current_theme_mode()
    profile_ui = read_profile_ui()
    Gtk.Settings.get_default().set_property("gtk-icon-theme-name", icon_theme_name(mode))

    app_prefs = prefs()
    favorites = app_prefs["favorites"]
    hidden = app_prefs["hidden"]
    recent_map = recents()
    cached_apps = read_cached_apps()
    apps = [app for app in cached_apps if app["desktop_id"] not in hidden or app.get("sevenos_core")]
    active_filter = {"id": default_filter_for_profile(profile_ui)}
    if active_filter["id"] not in {item[0] for item in CATEGORIES}:
        active_filter["id"] = "all"
    visible_apps = list(apps)
    filter_guard = {"active": False}
    render_source = {"id": 0}

    provider = Gtk.CssProvider()
    provider.load_from_data(launchpad_css(mode, profile_ui).encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title="SevenOS Launchpad")
    window.set_decorated(False)
    window.set_default_size(1320, 780)
    window.set_size_request(1, 1)
    window.set_resizable(False)
    window.set_accept_focus(True)
    window.set_focus_on_map(True)
    window.set_modal(True)
    window.set_keep_above(True)
    window.set_skip_taskbar_hint(True)
    window.set_skip_pager_hint(True)
    window.set_type_hint(Gdk.WindowTypeHint.DIALOG)
    window.stick()
    window.fullscreen()
    window.set_wmclass("SevenLaunchpadNative", "SevenLaunchpadNative")
    window.get_style_context().add_class("seven-launchpad")

    stage = Gtk.Fixed()
    stage.set_hexpand(True)
    stage.set_vexpand(True)
    stage.set_halign(Gtk.Align.FILL)
    stage.set_valign(Gtk.Align.FILL)
    stage.get_style_context().add_class("launchpad-stage")
    window.add(stage)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=22)
    root.set_halign(Gtk.Align.CENTER)
    root.set_valign(Gtk.Align.CENTER)
    root.get_style_context().add_class("launchpad-root")
    stage.put(root, 0, 0)

    topbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
    topbar.set_halign(Gtk.Align.CENTER)
    topbar.get_style_context().add_class("launchpad-topbar")
    root.pack_start(topbar, False, False, 0)

    brand_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
    brand_box.set_margin_start(8)
    profile_title = profile_ui.get("title") or "SevenOS"
    brand = Gtk.Label(label=profile_title)
    brand.set_xalign(0)
    brand.get_style_context().add_class("launchpad-brand")
    home = profile_ui.get("home_screen") if isinstance(profile_ui.get("home_screen"), dict) else {}
    subtitle_text = home.get("focus") or profile_ui.get("role", "")
    subtitle = Gtk.Label(label=tr_text("Apps") + f" · {subtitle_text}".rstrip(" · "))
    subtitle.set_xalign(0)
    subtitle.set_max_width_chars(72)
    subtitle.set_ellipsize(Pango.EllipsizeMode.END)
    subtitle.get_style_context().add_class("launchpad-subtitle")
    brand_box.pack_start(brand, False, False, 0)
    brand_box.pack_start(subtitle, False, False, 0)
    topbar.pack_start(brand_box, False, False, 0)

    search = Gtk.SearchEntry()
    search.set_placeholder_text(tr_text("Search"))
    search.get_style_context().add_class("launchpad-search")
    topbar.pack_start(search, False, False, 0)

    center_command = str(profile_ui.get("center_command") or "seven-profile-center-native")
    center_label = str((home.get("title") if isinstance(home, dict) else "") or "Mini OS")
    ai_button = Gtk.Button(label=center_label)
    ai_button.get_style_context().add_class("launchpad-suggestion")
    ai_button.set_tooltip_text("Open the active mini OS home")
    ai_button.connect("clicked", lambda _button: run_detached(["bash", "-lc", center_command]))
    topbar.pack_start(ai_button, False, False, 0)

    worlds = mini_os_worlds(profile_ui)
    world_count_labels: dict[str, Gtk.Label] = {}
    world_buttons: dict[str, Gtk.Button] = {}

    worlds_scroll = Gtk.ScrolledWindow()
    worlds_scroll.get_style_context().add_class("launchpad-worlds-scroll")
    worlds_scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.NEVER)
    worlds_scroll.set_min_content_height(88)
    root.pack_start(worlds_scroll, False, False, 0)

    world_flow = Gtk.FlowBox()
    world_flow.get_style_context().add_class("launchpad-worlds")
    world_flow.set_halign(Gtk.Align.CENTER)
    world_flow.set_selection_mode(Gtk.SelectionMode.NONE)
    world_flow.set_min_children_per_line(3)
    world_flow.set_max_children_per_line(7)
    world_flow.set_column_spacing(10)
    world_flow.set_row_spacing(8)
    worlds_scroll.add(world_flow)

    def open_world(world: dict) -> None:
        if world["key"] == str(profile_ui.get("profile", active_profile_key())):
            set_filter(str(world.get("filter", "all")))
            return
        run_detached(["bash", "-lc", str(world.get("command", ""))])
        window.close()

    def refresh_world_cards() -> None:
        for world in worlds:
            key = world["key"]
            label = world_count_labels.get(key)
            if label:
                label.set_text(f"{world_app_count(apps, world)} apps")
            button = world_buttons.get(key)
            if not button:
                continue
            context = button.get_style_context()
            if world.get("active") or active_filter["id"] == world.get("filter"):
                context.add_class("launchpad-world-active")
            else:
                context.remove_class("launchpad-world-active")

    for world in worlds:
        child = Gtk.FlowBoxChild()
        button = Gtk.Button()
        button.get_style_context().add_class("launchpad-world-card")
        button.set_relief(Gtk.ReliefStyle.NONE)
        button.set_tooltip_text(world["phrase"])
        button.connect("clicked", lambda _button, selected=world: open_world(selected))

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title = Gtk.Label(label=world["title"])
        title.set_xalign(0)
        title.get_style_context().add_class("launchpad-world-title")
        phrase = Gtk.Label(label=world["phrase"])
        phrase.set_xalign(0)
        phrase.set_max_width_chars(22)
        phrase.set_ellipsize(Pango.EllipsizeMode.END)
        phrase.get_style_context().add_class("launchpad-world-phrase")
        count = Gtk.Label(label=f"{world_app_count(apps, world)} apps")
        count.set_xalign(0)
        count.get_style_context().add_class("launchpad-world-count")
        box.pack_start(title, False, False, 0)
        box.pack_start(phrase, False, False, 0)
        box.pack_start(count, False, False, 0)
        button.add(box)
        child.add(button)
        world_flow.add(child)
        world_buttons[world["key"]] = button
        world_count_labels[world["key"]] = count

    filters = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    filters.set_halign(Gtk.Align.CENTER)
    root.pack_start(filters, False, False, 0)

    filter_buttons: dict[str, Gtk.ToggleButton] = {}
    for key, label, _icon in CATEGORIES:
        button = Gtk.ToggleButton(label=tr_text(mini_os_section_label(key, label, profile_ui)))
        button.get_style_context().add_class("launchpad-filter")
        button.set_active(key == active_filter["id"])
        filters.pack_start(button, False, False, 0)
        filter_buttons[key] = button

    scroller = Gtk.ScrolledWindow()
    scroller.get_style_context().add_class("launchpad-scroll")
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    root.pack_start(scroller, True, True, 0)

    flow = Gtk.FlowBox()
    flow.set_halign(Gtk.Align.CENTER)
    flow.set_valign(Gtk.Align.START)
    flow.set_selection_mode(Gtk.SelectionMode.SINGLE)
    flow.set_min_children_per_line(4)
    flow.set_max_children_per_line(8)
    flow.set_column_spacing(34)
    flow.set_row_spacing(28)
    scroller.add(flow)

    empty = Gtk.Label(label=tr_text("No results"))
    empty.get_style_context().add_class("launchpad-empty")
    empty.set_halign(Gtk.Align.CENTER)
    empty.hide()
    root.pack_start(empty, False, False, 0)

    def clamp(value: int, low: int, high: int) -> int:
        return max(low, min(high, value))

    def active_monitor_geometry():
        screen = Gdk.Screen.get_default()
        monitor = screen.get_primary_monitor()
        if window.get_window():
            monitor = screen.get_monitor_at_window(window.get_window())
        if monitor < 0:
            monitor = 0
        return screen.get_monitor_geometry(monitor)

    def apply_responsive_layout(width: int | None = None, height: int | None = None) -> bool:
        if not width or not height:
            geometry = active_monitor_geometry()
            width = geometry.width
            height = geometry.height

        available_width = max(320, width - 32)
        available_height = max(360, height - 32)
        panel_width = clamp(int(width * 0.88), min(620, available_width), min(1360, available_width))
        panel_height = clamp(int(height * 0.84), min(520, available_height), min(860, available_height))
        stage.set_size_request(width, height)
        root.set_size_request(panel_width, panel_height)
        stage.move(root, max(0, (width - panel_width) // 2), max(0, (height - panel_height) // 2))

        if panel_width >= 1260:
            columns = 8
        elif panel_width >= 1120:
            columns = 7
        elif panel_width >= 960:
            columns = 6
        elif panel_width >= 780:
            columns = 5
        elif panel_width >= 700:
            columns = 4
        else:
            columns = 3

        flow.set_min_children_per_line(min(4, columns))
        flow.set_max_children_per_line(columns)
        world_flow.set_max_children_per_line(min(7, max(3, columns)))
        search.set_size_request(220 if panel_width < 700 else 240 if panel_width < 900 else 320, -1)
        subtitle.set_max_width_chars(40 if panel_width < 900 else 72)
        return False

    def category_label(app: dict) -> str:
        value = app.get("category", "all")
        for key, label, _icon in CATEGORIES:
            if key == value:
                return tr_text(mini_os_section_label(key, label, profile_ui))
        return tr_text("App")

    def show_app_info(app: dict) -> None:
        dialog = Gtk.MessageDialog(
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
            message_type=Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.CLOSE,
            text=app["name"],
        )
        details = "\n".join(
            part
            for part in [
                app.get("comment", ""),
                f"{tr_text('Category')}: {category_label(app)}",
                app.get("desktop_id", ""),
            ]
            if part
        )
        dialog.format_secondary_text(details)
        dialog.run()
        dialog.destroy()

    def toggle_favorite(app: dict) -> None:
        desktop_id = app["desktop_id"]
        if desktop_id in favorites:
            favorites.remove(desktop_id)
        else:
            favorites.insert(0, desktop_id)
        save_prefs(favorites, hidden)
        update_filter(search)

    def hide_app(app: dict) -> None:
        if app.get("sevenos_core"):
            return
        hidden.add(app["desktop_id"])
        save_prefs(favorites, hidden)
        update_filter(search)

    def menu_for_app(app: dict, event) -> bool:
        menu = Gtk.Menu()
        entries = [
            (tr_text("Open"), lambda _item: (launch_app(app), window.close())),
            (
                tr_text("Remove from Favorites") if app["desktop_id"] in favorites else tr_text("Add to Favorites"),
                lambda _item: toggle_favorite(app),
            ),
            (tr_text("Show in Seven Files"), lambda _item: run_detached(["seven-files", str(Path(app["path"]).parent)])),
            (tr_text("Info"), lambda _item: show_app_info(app)),
        ]
        if not app.get("sevenos_core"):
            entries.append((tr_text("Hide from Launchpad"), lambda _item: hide_app(app)))
        for label, callback in entries:
            item = Gtk.MenuItem(label=label)
            item.connect("activate", callback)
            menu.append(item)
        menu.show_all()
        menu.popup_at_pointer(event)
        return True

    def app_icon_image(app: dict):
        icon_theme = Gtk.IconTheme.get_default()

        def file_image(path: Path):
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file_at_scale(str(path), 76, 76, True)
                return Gtk.Image.new_from_pixbuf(pixbuf)
            except Exception:
                image = Gtk.Image.new_from_file(str(path))
                image.set_pixel_size(76)
                return image

        for candidate in icon_candidates(app):
            candidate_path = Path(candidate).expanduser()
            if candidate_path.is_absolute() and candidate_path.exists():
                return file_image(candidate_path)
            local_path = LOCAL_ICON_FILES.get(candidate)
            if local_path and local_path.exists():
                return file_image(local_path)
            if icon_theme.has_icon(candidate):
                image = Gtk.Image.new_from_icon_name(candidate, Gtk.IconSize.DIALOG)
                image.set_pixel_size(76)
                return image
        image = Gtk.Image.new_from_icon_name("applications-utilities", Gtk.IconSize.DIALOG)
        image.set_pixel_size(76)
        return image

    def make_child(app):
        child = Gtk.FlowBoxChild()
        child.get_style_context().add_class("launchpad-tile")
        child.get_style_context().add_class(f"launchpad-category-{app.get('category', 'all')}")
        child.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        child.app = app

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)

        image = app_icon_image(app)
        image.set_halign(Gtk.Align.CENTER)
        box.pack_start(image, False, False, 0)

        label = Gtk.Label(label=app["name"])
        label.set_max_width_chars(15)
        label.set_line_wrap(True)
        label.set_lines(2)
        label.set_justify(Gtk.Justification.CENTER)
        label.set_halign(Gtk.Align.CENTER)
        label.get_style_context().add_class("launchpad-label")
        box.pack_start(label, False, False, 0)

        meta = Gtk.Label(label=category_label(app))
        meta.set_halign(Gtk.Align.CENTER)
        meta.get_style_context().add_class("launchpad-meta")
        box.pack_start(meta, False, False, 0)

        child.add(box)

        def on_tile_click(_child, event) -> bool:
            if event.button == 3:
                return menu_for_app(app, event)
            if event.button == 1:
                launch_app(app)
                window.close()
                return True
            return False

        child.connect("button-press-event", on_tile_click)
        return child

    def render():
        render_source["id"] = 0
        for child in flow.get_children():
            flow.remove(child)
        for app in visible_apps:
            flow.add(make_child(app))
        empty.set_visible(not visible_apps)
        flow.show_all()
        return False

    def schedule_render():
        if render_source["id"]:
            GLib.source_remove(render_source["id"])
        render_source["id"] = GLib.idle_add(render)

    def update_filter(entry):
        nonlocal visible_apps
        query = normalize(entry.get_text().strip())
        selected = active_filter["id"]
        ranked = []
        for app in apps:
            desktop_id = app["desktop_id"]
            category = app.get("category", "all")
            if selected == "favorites" and desktop_id not in favorites:
                continue
            if selected == "recent" and desktop_id not in recent_map:
                continue
            keep_core = bool(app.get("sevenos_core")) and selected not in {"favorites", "recent"}
            if selected not in {"all", "favorites", "recent"} and category != selected and not keep_core:
                continue
            score = fuzzy_score(query, app, favorites, recent_map)
            if keep_core and selected != "sevenos":
                score += 12
            if score >= 0:
                ranked.append((score, recent_map.get(desktop_id, 0), app["name"].casefold(), app))
        ranked.sort(key=lambda item: (-item[0], -item[1], item[2]))
        visible_apps = [item[3] for item in ranked]
        refresh_world_cards()
        schedule_render()

    def refresh_apps_async() -> None:
        def worker() -> None:
            refreshed = load_apps(force=True)

            def apply_refresh():
                nonlocal apps, recent_map
                recent_map = recents()
                apps = [app for app in refreshed if app["desktop_id"] not in hidden or app.get("sevenos_core")]
                update_filter(search)
                return False

            GLib.idle_add(apply_refresh)

        threading.Thread(target=worker, name="seven-launchpad-refresh", daemon=True).start()

    def set_filter(key: str) -> None:
        if key not in filter_buttons:
            key = "all"
        active_filter["id"] = key
        filter_guard["active"] = True
        try:
            for other_key, other_button in filter_buttons.items():
                other_button.set_active(other_key == key)
        finally:
            filter_guard["active"] = False
        update_filter(search)

    for key, button in filter_buttons.items():
        def on_filter_toggled(toggle_button, filter_key=key):
            if filter_guard["active"]:
                return
            if toggle_button.get_active():
                set_filter(filter_key)
                return
            if active_filter["id"] == filter_key:
                filter_guard["active"] = True
                try:
                    toggle_button.set_active(True)
                finally:
                    filter_guard["active"] = False

        button.connect("toggled", on_filter_toggled)

    def activate(_flow, child):
        if child is not None:
            launch_app(child.app)
            window.close()

    def on_key(_window, event):
        keyval = event.keyval
        state = event.state & Gtk.accelerator_get_default_mod_mask()
        if keyval == Gdk.KEY_Escape:
            if search.get_text():
                search.set_text("")
            else:
                window.close()
            return True
        if state & Gdk.ModifierType.CONTROL_MASK and keyval in {Gdk.KEY_f, Gdk.KEY_F}:
            search.grab_focus()
            return True
        if keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter}:
            selected = flow.get_selected_children()
            if selected:
                activate(flow, selected[0])
                return True
        if Gdk.KEY_1 <= keyval <= Gdk.KEY_9:
            index = keyval - Gdk.KEY_1
            if index < len(CATEGORIES):
                set_filter(CATEGORIES[index][0])
                return True
        return False

    search.connect("search-changed", update_filter)
    flow.connect("child-activated", activate)
    window.connect("key-press-event", on_key)

    def on_configure(_window, event):
        apply_responsive_layout(event.width, event.height)
        return False

    window.connect("configure-event", on_configure)

    def on_destroy(_window):
        leave_modal_submap()
        Gtk.main_quit()

    window.connect("destroy", on_destroy)
    update_filter(search)
    apply_responsive_layout()
    window.show_all()
    GLib.idle_add(apply_responsive_layout)
    refresh_apps_async()

    def focus_launchpad():
        window.fullscreen()
        window.present()
        search.grab_focus()
        return False

    GLib.idle_add(focus_launchpad)
    Gtk.main()
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("--doctor", action="store_true")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--refresh", action="store_true")
    parser.add_argument("--catalog-json", action="store_true")
    args = parser.parse_args()
    if args.probe:
        return probe()
    if args.catalog_json:
        apps = load_apps(force=args.refresh)
        print(json.dumps({"schema": CATALOG_SCHEMA, "count": len(apps), "apps": apps}, ensure_ascii=False, indent=2, sort_keys=True))
        return 0
    if args.doctor or args.json:
        return print_launchpad_doctor(json_mode=args.json, refresh=args.refresh)
    if args.refresh:
        apps = load_apps(force=True)
        print(f"Launchpad cache refreshed: {len(apps)} apps")
        return 0
    if not acquire_launchpad_lock():
        close_existing_launchpad()
        return 0
    if close_existing_launchpad():
        return 0
    return run_launchpad()


if __name__ == "__main__":
    raise SystemExit(main())
