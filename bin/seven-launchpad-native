def run_launchpad() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, Gtk

    mode = current_theme_mode()
    Gtk.Settings.get_default().set_property("gtk-icon-theme-name", icon_theme_name(mode))

    app_prefs = prefs()
    favorites = app_prefs["favorites"]
    hidden = app_prefs["hidden"]
    recent_map = recents()
    apps = [app for app in load_apps() if app["desktop_id"] not in hidden]
    active_filter = {"id": "all"}
    visible_apps = list(apps)

    provider = Gtk.CssProvider()
    provider.load_from_data(launchpad_css(mode).encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window()
    window.set_decorated(False)
    window.fullscreen()
    window.set_wmclass("SevenLaunchpadNative", "SevenLaunchpadNative")
    window.get_style_context().add_class("seven-launchpad")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=22)
    root.get_style_context().add_class("launchpad-root")
    window.add(root)

    topbar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
    topbar.set_halign(Gtk.Align.CENTER)
    topbar.get_style_context().add_class("launchpad-topbar")
    root.pack_start(topbar, False, False, 0)

    brand_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
    brand_box.set_margin_start(8)
    brand = Gtk.Label(label="SevenOS")
    brand.set_xalign(0)
    brand.get_style_context().add_class("launchpad-brand")
    subtitle = Gtk.Label(label=tr_text("Apps"))
    subtitle.set_xalign(0)
    subtitle.get_style_context().add_class("launchpad-subtitle")
    brand_box.pack_start(brand, False, False, 0)
    brand_box.pack_start(subtitle, False, False, 0)
    topbar.pack_start(brand_box, False, False, 0)

    search = Gtk.SearchEntry()
    search.set_placeholder_text(tr_text("Search"))
    search.get_style_context().add_class("launchpad-search")
    topbar.pack_start(search, False, False, 0)

    ai_button = Gtk.Button(label="SevenAI")
    ai_button.get_style_context().add_class("launchpad-suggestion")
    ai_button.connect("clicked", lambda _button: run_detached(["seven", "ai", "focus"]))
    topbar.pack_start(ai_button, False, False, 0)

    filters = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    filters.set_halign(Gtk.Align.CENTER)
    root.pack_start(filters, False, False, 0)

    filter_buttons: dict[str, Gtk.ToggleButton] = {}
    for key, label, _icon in CATEGORIES:
        button = Gtk.ToggleButton(label=tr_text(label))
        button.get_style_context().add_class("launchpad-filter")
        button.set_active(key == "all")
        filters.pack_start(button, False, False, 0)
        filter_buttons[key] = button

    scroller = Gtk.ScrolledWindow()
    scroller.get_style_context().add_class("launchpad-scroll")
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    root.pack_start(scroller, True, True, 0)

    flow = Gtk.FlowBox()
    flow.set_halign(Gtk.Align.CENTER)
    flow.set_valign(Gtk.Align.START)
    flow.set_selection_mode(Gtk.SelectionMode.SINGLE)
    flow.set_min_children_per_line(5)
    flow.set_max_children_per_line(8)
    screen_width = Gdk.Screen.get_default().get_width()
    if screen_width < 1320:
        flow.set_max_children_per_line(6)
    flow.set_column_spacing(34)
    flow.set_row_spacing(28)
    scroller.add(flow)

    empty = Gtk.Label(label=tr_text("No results"))
    empty.get_style_context().add_class("launchpad-empty")
    empty.set_halign(Gtk.Align.CENTER)
    empty.hide()
    root.pack_start(empty, False, False, 0)

    def category_label(app: dict) -> str:
        value = app.get("category", "all")
        for key, label, _icon in CATEGORIES:
            if key == value:
                return tr_text(label)
        return tr_text("App")

    def show_app_info(app: dict) -> None:
        dialog = Gtk.MessageDialog(
            transient_for=window,
            flags=Gtk.DialogFlags.MODAL,
            message_type=Gtk.MessageType.INFO,
            buttons=Gtk.ButtonsType.CLOSE,
            text=app["name"],
        )
        details = "\n".join(
            part
            for part in [
                app.get("comment", ""),
                f"{tr_text('Category')}: {category_label(app)}",
                app.get("desktop_id", ""),
            ]
            if part
        )
        dialog.format_secondary_text(details)
        dialog.run()
        dialog.destroy()

    def toggle_favorite(app: dict) -> None:
        desktop_id = app["desktop_id"]
        if desktop_id in favorites:
            favorites.remove(desktop_id)
        else:
            favorites.insert(0, desktop_id)
        save_prefs(favorites, hidden)
        update_filter(search)

    def hide_app(app: dict) -> None:
        hidden.add(app["desktop_id"])
        save_prefs(favorites, hidden)
        update_filter(search)

    def menu_for_app(app: dict, event) -> bool:
        menu = Gtk.Menu()
        entries = [
            (tr_text("Open"), lambda _item: (launch_app(app), window.close())),
            (
                tr_text("Remove from Favorites") if app["desktop_id"] in favorites else tr_text("Add to Favorites"),
                lambda _item: toggle_favorite(app),
            ),
            (tr_text("Show in Seven Files"), lambda _item: run_detached(["seven-files", str(Path(app["path"]).parent)])),
            (tr_text("Info"), lambda _item: show_app_info(app)),
            (tr_text("Hide from Launchpad"), lambda _item: hide_app(app)),
        ]
        for label, callback in entries:
            item = Gtk.MenuItem(label=label)
            item.connect("activate", callback)
            menu.append(item)
        menu.show_all()
        menu.popup_at_pointer(event)
        return True

    def make_child(app):
        child = Gtk.FlowBoxChild()
        child.get_style_context().add_class("launchpad-tile")
        child.get_style_context().add_class(f"launchpad-category-{app.get('category', 'all')}")
        child.add_events(Gdk.EventMask.BUTTON_PRESS_MASK)
        child.app = app

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)

        image = Gtk.Image.new_from_icon_name(app["icon"], Gtk.IconSize.DIALOG)
        image.set_pixel_size(76)
        image.set_halign(Gtk.Align.CENTER)
        box.pack_start(image, False, False, 0)

        label = Gtk.Label(label=app["name"])
        label.set_max_width_chars(15)
        label.set_line_wrap(True)
        label.set_lines(2)
        label.set_justify(Gtk.Justification.CENTER)
        label.set_halign(Gtk.Align.CENTER)
        label.get_style_context().add_class("launchpad-label")
        box.pack_start(label, False, False, 0)

        meta = Gtk.Label(label=category_label(app))
        meta.set_halign(Gtk.Align.CENTER)
        meta.get_style_context().add_class("launchpad-meta")
        box.pack_start(meta, False, False, 0)

        child.add(box)
        child.connect("button-press-event", lambda _child, event: menu_for_app(app, event) if event.button == 3 else False)
        return child

    def render():
        for child in flow.get_children():
            flow.remove(child)
        for app in visible_apps:
            flow.add(make_child(app))
        empty.set_visible(not visible_apps)
        flow.show_all()

    def update_filter(entry):
        nonlocal visible_apps
        query = normalize(entry.get_text().strip())
        selected = active_filter["id"]
        ranked = []
        for app in apps:
            desktop_id = app["desktop_id"]
            category = app.get("category", "all")
            if selected == "favorites" and desktop_id not in favorites:
                continue
            if selected == "recent" and desktop_id not in recent_map:
                continue
            if selected not in {"all", "favorites", "recent"} and category != selected:
                continue
            score = fuzzy_score(query, app, favorites, recent_map)
            if score >= 0:
                ranked.append((score, recent_map.get(desktop_id, 0), app["name"].casefold(), app))
        ranked.sort(key=lambda item: (-item[0], -item[1], item[2]))
        visible_apps = [item[3] for item in ranked]
        render()

    def set_filter(key: str) -> None:
        active_filter["id"] = key
        for other_key, other_button in filter_buttons.items():
            other_button.set_active(other_key == key)
        update_filter(search)

    for key, button in filter_buttons.items():
        button.connect("clicked", lambda _button, filter_key=key: set_filter(filter_key))

    def activate(_flow, child):
        if child is not None:
            launch_app(child.app)
            window.close()

    def on_key(_window, event):
        keyval = event.keyval
        state = event.state & Gtk.accelerator_get_default_mod_mask()
        if keyval == Gdk.KEY_Escape:
            if search.get_text():
                search.set_text("")
            else:
                window.close()
            return True
        if state & Gdk.ModifierType.CONTROL_MASK and keyval in {Gdk.KEY_f, Gdk.KEY_F}:
            search.grab_focus()
            return True
        if keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter}:
            selected = flow.get_selected_children()
            if selected:
                activate(flow, selected[0])
                return True
        if Gdk.KEY_1 <= keyval <= Gdk.KEY_9:
            index = keyval - Gdk.KEY_1
            if index < len(CATEGORIES):
                set_filter(CATEGORIES[index][0])
                return True
        return False

    search.connect("search-changed", update_filter)
    flow.connect("child-activated", activate)
    window.connect("key-press-event", on_key)
    window.connect("destroy", Gtk.main_quit)
    update_filter(search)
    window.show_all()
    search.grab_focus()
    Gtk.main()
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    args = parser.parse_args()
    if args.probe:
        return probe()
    if not acquire_launchpad_lock():
        close_existing_launchpad()
        return 0
    if close_existing_launchpad():
        return 0
    return run_launchpad()


if __name__ == "__main__":
    raise SystemExit(main())
