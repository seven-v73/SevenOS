#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="${SEVENOS_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
VM_NAME="${SEVENOS_WINDOWS_VM:-sevenos-windows}"
ACTION="${1:-status}"
shift || true
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos"
VM_PLAN="$CONFIG_DIR/windows-vm-plan.json"
PROVISIONER="$ROOT_DIR/vm/windows-provisioner.sh"
WINDOWS_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/sevenos/vm/windows"
WINDOWS_DISK_PATH="$WINDOWS_DATA_DIR/${VM_NAME}.qcow2"
VIRTIO_ISO="$WINDOWS_DATA_DIR/virtio-win.iso"

language_code() {
  local language="${SEVENOS_LANGUAGE:-${LANG:-en_US.UTF-8}}"
  local config="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.conf"
  if [[ -z "${SEVENOS_LANGUAGE:-}" && -f "$config" ]]; then
    language="$(awk -F= '/^(SEVENOS_LANGUAGE|LANG)=/{gsub(/["'\'']/, "", $2); print $2; exit}' "$config")"
  fi
  [[ "$language" == fr* ]] && printf 'fr' || printf 'en'
}

LANG_CODE="$(language_code)"

msg() {
  local key="$1"
  case "$LANG_CODE:$key" in
    fr:windows_plan) printf 'Plan Windows SevenOS' ;;
    fr:mode) printf 'Mode' ;;
    fr:ready) printf 'prêt' ;;
    fr:open_actions) printf 'Actions ouvertes' ;;
    fr:critical) printf 'critique(s)' ;;
    fr:high) printf 'haute(s)' ;;
    fr:medium) printf 'moyenne(s)' ;;
    fr:severity) printf 'Gravité' ;;
    fr:phase) printf 'Phase' ;;
    fr:command) printf 'Commande' ;;
    *) case "$key" in
      windows_plan) printf 'SevenOS Windows Plan' ;;
      mode) printf 'Mode' ;;
      ready) printf 'ready' ;;
      open_actions) printf 'Open actions' ;;
      critical) printf 'critical' ;;
      high) printf 'high' ;;
      medium) printf 'medium' ;;
      severity) printf 'Severity' ;;
      phase) printf 'Phase' ;;
      command) printf 'Command' ;;
      *) printf '%s' "$key" ;;
    esac ;;
  esac
}

dry_run() {
  [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]
}

dry_line() {
  printf 'DRY-RUN > Windows Mode > %s\n' "$*"
}

run_setup_step() {
  local title="$1"
  shift
  printf '\n[Windows SevenOS] %s\n' "$title"
  if dry_run; then
    printf 'DRY-RUN > '
    printf '%q ' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

run_setup_shell_step() {
  local title="$1"
  local command="$2"
  printf '\n[Windows SevenOS] %s\n' "$title"
  if dry_run; then
    printf 'DRY-RUN > %s\n' "$command"
    return 0
  fi
  bash -lc "$command"
}

command_state() {
  command -v "$1" >/dev/null 2>&1 && printf 'OK' || printf 'MISS'
}

with_timeout() {
  if command -v timeout >/dev/null 2>&1; then
    timeout --kill-after=1s "${SEVENOS_WINDOWS_STATUS_TIMEOUT:-3s}" "$@"
  else
    "$@"
  fi
}

virsh_system() {
  with_timeout virsh -c qemu:///system "$@"
}

package_state() {
  pacman -Q "$1" >/dev/null 2>&1 && printf 'OK' || printf 'MISS'
}

service_state() {
  systemctl is-active --quiet "$1" 2>/dev/null && printf 'OK' || printf 'MISS'
}

flatpak_app_state() {
  command -v flatpak >/dev/null 2>&1 && flatpak info "$1" >/dev/null 2>&1 && printf 'OK' || printf 'MISS'
}

kvm_state() {
  [[ -r /dev/kvm ]] && printf 'OK' || printf 'MISS'
}

virt_cpu_state() {
  grep -Eiq '(vmx|svm)' /proc/cpuinfo 2>/dev/null && printf 'OK' || printf 'MISS'
}

libvirt_group_state() {
  id -nG 2>/dev/null | tr ' ' '\n' | grep -qx libvirt && printf 'OK' || printf 'MISS'
}

network_state() {
  command -v virsh >/dev/null 2>&1 &&
    virsh_system net-info default >/dev/null 2>&1 &&
    printf 'OK' || printf 'MISS'
}

vm_state() {
  if ! command -v virsh >/dev/null 2>&1; then
    printf 'MISS'
    return 0
  fi

  if ! virsh_system dominfo "$VM_NAME" >/dev/null 2>&1; then
    printf 'MISS'
    return 0
  fi

  local state
  state="$(virsh_system domstate "$VM_NAME" 2>/dev/null || true)"
  case "$state" in
    running) printf 'RUN' ;;
    *) printf 'OK' ;;
  esac
}

vm_disk_bus() {
  if ! command -v virsh >/dev/null 2>&1; then
    printf 'MISS'
    return 0
  fi
  if ! virsh_system dominfo "$VM_NAME" >/dev/null 2>&1; then
    printf 'MISS'
    return 0
  fi

  local xml
  xml="$(virsh_system dumpxml "$VM_NAME" 2>/dev/null || true)"
  WINDOWS_VM_XML="$xml" /usr/bin/python3 - <<'PY'
import os
import sys
import xml.etree.ElementTree as ET

try:
    root = ET.fromstring(os.environ.get("WINDOWS_VM_XML", ""))
except Exception:
    print("UNKNOWN")
    raise SystemExit(0)

for disk in root.findall("./devices/disk"):
    if disk.get("device") != "disk":
        continue
    target = disk.find("target")
    if target is not None:
        print(target.get("bus", "UNKNOWN"))
        raise SystemExit(0)
print("MISS")
PY
}

vm_network_models() {
  if ! command -v virsh >/dev/null 2>&1; then
    printf 'MISS'
    return 0
  fi
  if ! virsh_system dominfo "$VM_NAME" >/dev/null 2>&1; then
    printf 'MISS'
    return 0
  fi

  local xml
  xml="$(virsh_system dumpxml "$VM_NAME" 2>/dev/null || true)"
  WINDOWS_VM_XML="$xml" /usr/bin/python3 - <<'PY'
import os
import xml.etree.ElementTree as ET

try:
    root = ET.fromstring(os.environ.get("WINDOWS_VM_XML", ""))
except Exception:
    print("UNKNOWN")
    raise SystemExit(0)

models = []
for iface in root.findall("./devices/interface"):
    model = iface.find("model")
    if model is not None and model.get("type"):
        models.append(model.get("type"))
print(",".join(models) if models else "MISS")
PY
}

vm_plan_state() {
  [[ -s "$VM_PLAN" ]] && printf 'OK' || printf 'MISS'
}

write_vm_plan() {
  mkdir -p "$CONFIG_DIR"
  python - "$VM_NAME" "$VM_PLAN" <<'PY'
import json
import os
import sys
from pathlib import Path

vm_name, path = sys.argv[1:]
payload = {
    "schema": "sevenos.windows-vm-plan.v1",
    "vm_name": vm_name,
    "state": "waiting-for-official-media",
    "required_inputs": ["official_windows_iso_or_quickget"],
    "optional_inputs": ["virtio_iso", "autounattend_template"],
    "provision_command": "seven windows provision --yes",
    "recommended_command": f"seven windows create --iso /path/to/windows.iso --virtio-iso ~/.local/share/sevenos/vm/windows/virtio-win.iso --disk-path ~/.local/share/sevenos/vm/windows/{vm_name}.qcow2 --os win11 --name {vm_name}",
    "reason": "SevenOS cannot redistribute Windows. It must build the VM locally from official/user-authorized media.",
}
Path(path).write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")
print(path)
PY
}

status_json() {
  local provision_json
  local bridge_json
  provision_json="$(with_timeout "$PROVISIONER" status --json 2>/dev/null || printf '{}')"
  bridge_json="$(with_timeout "$ROOT_DIR/vm/windows-mode.sh" bridge-status --json 2>/dev/null || printf '{}')"
  SEVENOS_WINDOWS_PROVISION_JSON="$provision_json" \
  SEVENOS_WINDOWS_BRIDGE_JSON="$bridge_json" \
  python - "$VM_NAME" \
    "$(virt_cpu_state)" \
    "$(kvm_state)" \
    "$(command_state wine)" \
    "$(command_state lutris)" \
    "$(command_state flatpak)" \
    "$(flatpak_app_state com.usebottles.bottles)" \
    "$(command_state qemu-system-x86_64)" \
    "$(command_state virt-manager)" \
    "$(command_state virt-install)" \
    "$(command_state virsh)" \
    "$(service_state libvirtd.service)" \
    "$(libvirt_group_state)" \
    "$(network_state)" \
    "$(vm_state)" \
    "$(vm_disk_bus)" \
    "$(vm_network_models)" \
    "$(vm_plan_state)" <<'PY'
import json
import os
import sys

keys = [
    "vm_name",
    "cpu_virtualization",
    "kvm_device",
    "wine",
    "lutris",
    "flatpak",
    "bottles_flatpak",
    "qemu",
    "virt_manager",
    "virt_install",
    "virsh",
    "libvirtd",
    "libvirt_group",
    "default_network",
    "windows_vm",
    "windows_vm_disk_bus",
    "windows_vm_network_models",
    "windows_vm_plan",
]
payload = dict(zip(keys, sys.argv[1:]))
payload["schema"] = "sevenos.windows.v1"
try:
    payload["provisioning"] = json.loads(os.environ.get("SEVENOS_WINDOWS_PROVISION_JSON", "{}") or "{}")
except Exception:
    payload["provisioning"] = {"schema": "sevenos.windows-provision.v1", "state": "unavailable"}
try:
    payload["bridge_runtime"] = json.loads(os.environ.get("SEVENOS_WINDOWS_BRIDGE_JSON", "{}") or "{}")
except Exception:
    payload["bridge_runtime"] = {"schema": "sevenos.windows-bridge-runtime.v1", "state": "unavailable"}
payload["vm_ready"] = all(
    payload[key] in {"OK", "RUN"}
    for key in ("cpu_virtualization", "kvm_device", "qemu", "virt_manager", "virsh", "libvirtd", "default_network")
)
payload["app_ready"] = payload["wine"] == "OK" and (payload["bottles_flatpak"] == "OK" or payload["lutris"] == "OK")
payload["ready"] = payload["vm_ready"] and payload["app_ready"]
payload["mode"] = "complete" if payload["ready"] else "vm-ready" if payload["vm_ready"] else "setup-needed"
payload["recommendations"] = []
if payload["wine"] != "OK" or payload["lutris"] != "OK":
    payload["recommendations"].append({"command": "seven profile install windows", "reason": "Install Wine/Lutris compatibility tooling"})
if payload["bottles_flatpak"] != "OK":
    payload["recommendations"].append({"command": "seven flatpak install", "reason": "Install Bottles through Flatpak for accessible Windows apps"})
if not payload["vm_ready"]:
    payload["recommendations"].append({"command": "seven vm check", "reason": "Finish Windows preparation"})
if payload["windows_vm"] == "MISS":
    provisioning = payload.get("provisioning", {})
    artifacts = provisioning.get("artifacts", {})
    recommended_next = provisioning.get("recommended_next", "seven windows provision --yes")
    if provisioning.get("ready_to_create_vm") and artifacts.get("virtio_iso") == "OK":
        payload["recommendations"].append({"command": recommended_next, "reason": "Create the full Windows space from the official installer"})
    elif recommended_next != "seven windows provision --yes":
        payload["recommendations"].append({"command": recommended_next, "reason": "Finish the missing Windows preparation step"})
    else:
        payload["recommendations"].append({"command": "seven windows provision --yes", "reason": "Prepare the official Windows installer and local Windows space"})
elif payload.get("windows_vm_disk_bus") == "virtio":
    payload["recommendations"].append({
        "command": "seven windows installer-help",
        "reason": "The Windows installer cannot see its disk yet. SevenOS can guide the storage step.",
    })
if payload["windows_vm"] in {"OK", "RUN"} and "e1000e" not in payload.get("windows_vm_network_models", "").split(","):
    payload["recommendations"].append({
        "command": "seven windows fix-network",
        "reason": "Windows may not have internet yet. SevenOS can add a compatible network path.",
    })
print(json.dumps(payload, indent=2))
PY
}

plan_json() {
  WINDOWS_STATUS="$(status_json)" python - <<'PY'
import json
import os

status = json.loads(os.environ["WINDOWS_STATUS"])

metadata = {
    "wine": {
        "title": "Install Wine compatibility",
        "severity": "high",
        "impact": "packages",
        "phase": "apps",
        "command": "seven profile install windows",
        "reason": "Wine is the base layer for lightweight Windows applications.",
    },
    "lutris": {
        "title": "Install Lutris app/game manager",
        "severity": "medium",
        "impact": "packages",
        "phase": "apps",
        "command": "seven profile install windows",
        "reason": "Lutris gives SevenOS a friendlier Windows app and game workflow.",
    },
    "bottles_flatpak": {
        "title": "Install Bottles",
        "severity": "high",
        "impact": "packages",
        "phase": "apps",
        "command": "seven flatpak install",
        "reason": "Bottles is the accessible non-terminal surface for Windows apps.",
    },
    "cpu_virtualization": {
        "title": "Activer Windows complet",
        "severity": "critical",
        "impact": "manual",
        "phase": "windows",
        "command": "seven vm check",
        "reason": "La machine doit autoriser Windows complet dans ses réglages de démarrage.",
    },
    "kvm_device": {
        "title": "Autoriser Windows complet",
        "severity": "critical",
        "impact": "changes",
        "phase": "windows",
        "command": "seven vm check",
        "reason": "SevenOS needs hardware acceleration for full Windows.",
    },
    "qemu": {
        "title": "Installer Windows complet",
        "severity": "critical",
        "impact": "packages",
        "phase": "windows",
        "command": "seven profile install windows",
        "reason": "SevenOS doit installer le moteur local qui lance Windows complet.",
    },
    "virt_manager": {
        "title": "Installer la gestion graphique",
        "severity": "high",
        "impact": "packages",
        "phase": "windows",
        "command": "seven profile install windows",
        "reason": "SevenOS ajoute une interface visuelle pour ouvrir, arrêter et réparer Windows.",
    },
    "virt_install": {
        "title": "Installer l’assistant Windows",
        "severity": "high",
        "impact": "packages",
        "phase": "windows",
        "command": "seven profile install windows",
        "reason": "SevenOS ajoute l’assistant qui prépare Windows sans commandes manuelles.",
    },
    "virsh": {
        "title": "Installer les outils Windows",
        "severity": "high",
        "impact": "packages",
        "phase": "windows",
        "command": "seven profile install windows",
        "reason": "SevenOS controls the full Windows space through the system Windows service.",
    },
    "libvirtd": {
        "title": "Démarrer Windows",
        "severity": "critical",
        "impact": "changes",
        "phase": "windows",
        "command": "seven improve compatibility",
        "reason": "Le service local Windows doit être actif pour ouvrir Windows complet.",
    },
    "libvirt_group": {
        "title": "Autoriser ton compte",
        "severity": "medium",
        "impact": "changes",
        "phase": "access",
        "command": "seven improve compatibility",
        "reason": "Ton compte doit pouvoir ouvrir Windows sans demander des commandes avancées.",
    },
    "default_network": {
        "title": "Préparer internet Windows",
        "severity": "high",
        "impact": "changes",
        "phase": "network",
        "command": "seven windows network",
        "reason": "Full Windows needs an internet path prepared by SevenOS.",
    },
    "windows_vm": {
        "title": "Create full Windows",
        "severity": "medium",
        "impact": "manual",
        "phase": "install",
        "command": "seven windows provision --yes",
        "reason": "SevenOS a besoin du fichier d’installation officiel pour créer Windows complet.",
    },
}

rank = {"critical": 0, "high": 1, "medium": 2, "low": 3}
checks = [
    "cpu_virtualization",
    "kvm_device",
    "wine",
    "lutris",
    "bottles_flatpak",
    "qemu",
    "virt_manager",
    "virt_install",
    "virsh",
    "libvirtd",
    "libvirt_group",
    "default_network",
    "windows_vm",
]
actions = []
for key in checks:
    state = status.get(key, "MISS")
    if state in {"OK", "RUN"}:
        continue
    item = metadata[key]
    actions.append({
        "key": key,
        "state": state,
        "title": item["title"],
        "severity": item["severity"],
        "impact": item["impact"],
        "phase": item["phase"],
        "reason": item["reason"],
        "command": item["command"],
    })

actions.sort(key=lambda item: (rank.get(item["severity"], 9), item["phase"], item["key"]))

print(json.dumps({
    "schema": "sevenos.windows-plan.v1",
    "writer": "seven-daemon",
    "mode": status.get("mode", "setup-needed"),
    "ready": bool(status.get("ready")),
    "summary": {
        "total": len(actions),
        "critical": sum(1 for item in actions if item["severity"] == "critical"),
        "high": sum(1 for item in actions if item["severity"] == "high"),
        "medium": sum(1 for item in actions if item["severity"] == "medium"),
    },
    "next": actions,
}, indent=2))
PY
}

plan_human() {
  WINDOWS_PLAN="$(plan_json)" \
  SEVENOS_WINDOWS_PLAN_TITLE="$(msg windows_plan)" \
  SEVENOS_LABEL_MODE="$(msg mode)" \
  SEVENOS_LABEL_READY="$(msg ready)" \
  SEVENOS_LABEL_OPEN_ACTIONS="$(msg open_actions)" \
  SEVENOS_LABEL_CRITICAL="$(msg critical)" \
  SEVENOS_LABEL_HIGH="$(msg high)" \
  SEVENOS_LABEL_MEDIUM="$(msg medium)" \
  SEVENOS_LABEL_SEVERITY="$(msg severity)" \
  SEVENOS_LABEL_PHASE="$(msg phase)" \
  SEVENOS_LABEL_COMMAND="$(msg command)" \
  SEVENOS_LANG_CODE="$LANG_CODE" \
  python - <<'PY'
import json
import os

data = json.loads(os.environ["WINDOWS_PLAN"])
summary = data.get("summary", {})

print(os.environ.get("SEVENOS_WINDOWS_PLAN_TITLE", "SevenOS Windows Plan"))
print("====================")
print(f"{os.environ.get('SEVENOS_LABEL_MODE', 'Mode')}: {data.get('mode', 'setup-needed')} · {os.environ.get('SEVENOS_LABEL_READY', 'ready')}: {str(data.get('ready', False)).lower()}")
print(
    f"{os.environ.get('SEVENOS_LABEL_OPEN_ACTIONS', 'Open actions')}: {summary.get('total', 0)} "
    f"({summary.get('critical', 0)} {os.environ.get('SEVENOS_LABEL_CRITICAL', 'critical')}, {summary.get('high', 0)} {os.environ.get('SEVENOS_LABEL_HIGH', 'high')}, {summary.get('medium', 0)} {os.environ.get('SEVENOS_LABEL_MEDIUM', 'medium')})"
)
print()
print(f"{os.environ.get('SEVENOS_LABEL_SEVERITY', 'Severity'):<9} {os.environ.get('SEVENOS_LABEL_PHASE', 'Phase'):<9} {os.environ.get('SEVENOS_LABEL_COMMAND', 'Command')}")
print(f"{'--------':<9} {'-----':<9} {'-------'}")
for item in data.get("next", []):
    reason = item.get('reason','')
    if os.environ.get("SEVENOS_LANG_CODE") == "fr":
        reason = {
            "SevenOS needs official Windows media, VirtIO drivers and a local qcow2 plan before launching full Windows Desktop Mode.": "SevenOS a besoin d’un fichier d’installation Windows officiel avant de lancer Windows complet.",
            "Prepare the official Windows installer and local Windows space": "Préparer le fichier Windows officiel et l’espace Windows local.",
            "Install Wine/Lutris compatibility tooling": "Installer les outils de compatibilité Wine/Lutris.",
            "Install Bottles through Flatpak for accessible Windows apps": "Installer Bottles via Flatpak pour des apps Windows accessibles.",
            "Complete KVM/libvirt readiness": "Finaliser la préparation Windows.",
            "Finish Windows preparation": "Finaliser la préparation Windows.",
            "Create the guided Windows VM": "Créer l’espace Windows guidé.",
            "Create the full Windows space from the official installer": "Créer Windows complet depuis l’installateur officiel.",
            "Finish the missing Windows preparation step": "Terminer l’étape Windows manquante.",
            "The Windows installer cannot see its disk yet. SevenOS can guide the storage step.": "L’installation Windows ne voit pas encore son disque. SevenOS peut guider cette étape.",
            "Windows may not have internet yet. SevenOS can add a compatible network path.": "Windows peut manquer d’internet. SevenOS peut préparer un accès compatible.",
            "Wine is the base layer for lightweight Windows applications.": "Wine est la couche de base pour les applications Windows légères.",
            "Lutris gives SevenOS a friendlier Windows app and game workflow.": "Lutris rend le flux des apps et jeux Windows plus accessible dans SevenOS.",
            "Bottles is the accessible non-terminal surface for Windows apps.": "Bottles fournit une surface graphique accessible pour les apps Windows.",
            "KVM needs VT-x or AMD-V enabled in firmware.": "La virtualisation doit être activée dans les réglages de la machine.",
            "SevenOS needs /dev/kvm for performant Windows VM mode.": "SevenOS a besoin de l’accélération matérielle pour Windows complet.",
            "SevenOS needs hardware acceleration for full Windows.": "SevenOS a besoin de l’accélération matérielle pour Windows complet.",
            "QEMU is required for full Windows Desktop Mode.": "Le moteur Windows complet doit être installé.",
            "Virt Manager is the graphical VM control surface for non-terminal users.": "Le gestionnaire graphique Windows doit être installé.",
            "SevenOS must install the local engine that starts full Windows.": "SevenOS doit installer le moteur local qui lance Windows complet.",
            "SevenOS adds a visual interface to open, stop and repair Windows.": "SevenOS ajoute une interface visuelle pour ouvrir, arrêter et réparer Windows.",
            "SevenOS adds the assistant that prepares Windows without manual commands.": "SevenOS ajoute l’assistant qui prépare Windows sans commandes manuelles.",
            "SevenOS controls the full Windows space through the system Windows service.": "SevenOS pilote Windows complet à travers son service local.",
            "The local Windows service must be active to open full Windows.": "Le service local Windows doit être actif pour ouvrir Windows complet.",
            "Your account must be able to open Windows without advanced commands.": "Ton compte doit pouvoir ouvrir Windows sans commandes avancées.",
            "Full Windows needs an internet path prepared by SevenOS.": "Windows complet a besoin d’un accès internet préparé par SevenOS.",
            "SevenOS needs the official installer file to create full Windows.": "SevenOS a besoin du fichier d’installation officiel pour créer Windows complet.",
        }.get(reason, reason)
    print(f"{item.get('severity',''):<9} {item.get('phase',''):<9} {item.get('command','')}")
    print(f"{'':<9} {'':<9} {reason}")
PY
}

daemon_json() {
  local action="$1"
  if [[ -x "$ROOT_DIR/bin/seven-daemon" ]]; then
    exec "$ROOT_DIR/bin/seven-daemon" "$action" --json
  fi
}

status_human() {
  local bridge_json
  printf 'SevenOS Windows\n\n'
  printf '  %-20s %s\n' "Accélération" "$(virt_cpu_state)"
  printf '  %-20s %s\n' "Accès Windows" "$(kvm_state)"
  printf '  %-20s %s\n' "Wine" "$(command_state wine)"
  printf '  %-20s %s\n' "Lutris" "$(command_state lutris)"
  printf '  %-20s %s\n' "Bottles" "$(flatpak_app_state com.usebottles.bottles)"
  printf '  %-20s %s\n' "Windows complet" "$(command_state qemu-system-x86_64)"
  printf '  %-20s %s\n' "Gestion graphique" "$(command_state virt-manager)"
  printf '  %-20s %s\n' "Création guidée" "$(command_state virt-install)"
  printf '  %-20s %s\n' "Service Windows" "$(service_state libvirtd.service)"
  printf '  %-20s %s\n' "Droits utilisateur" "$(libvirt_group_state)"
  printf '  %-20s %s\n' "Internet Windows" "$(network_state)"
  printf '  %-20s %s\n' "Windows prêt" "$(vm_state)"
  local disk_bus
  disk_bus="$(vm_disk_bus)"
  if [[ "$disk_bus" != "MISS" ]]; then
    printf '  %-20s %s\n' "Disque Windows" "$disk_bus"
  fi
  local network_models
  network_models="$(vm_network_models)"
  if [[ "$network_models" != "MISS" ]]; then
    printf '  %-20s %s\n' "Réseau Windows" "$network_models"
  fi
  if [[ "$network_models" != *"e1000e"* && "$network_models" != "MISS" ]]; then
    printf '\n'
    if [[ "$LANG_CODE" == "fr" ]]; then
      printf 'Note: Windows peut manquer d’internet. Lance la réparation réseau Windows.\n'
    else
      printf 'Note: Windows may not have internet yet. Run Windows network repair.\n'
    fi
  fi
  if [[ "$disk_bus" == "virtio" ]]; then
    printf '\n'
    if [[ "$LANG_CODE" == "fr" ]]; then
      printf 'Note: l’installation Windows peut ne pas voir le disque. Ouvre l’aide d’installation Windows.\n'
    else
      printf 'Note: Windows setup may not see the disk yet. Open Windows install help.\n'
    fi
  fi
  bridge_json="$("$ROOT_DIR/vm/windows-mode.sh" bridge-status --json 2>/dev/null || printf '{}')"
  WINDOWS_BRIDGE_JSON="$bridge_json" python - <<'PY'
import json
import os

try:
    data = json.loads(os.environ.get("WINDOWS_BRIDGE_JSON", "{}") or "{}")
except Exception:
    data = {}

if data:
    print()
    print("État Windows:")
    print(f"  espace actif         {data.get('active_profile', 'unknown')}")
    print(f"  état attendu         {data.get('desired_state', 'unknown')}")
    print(f"  Windows              {data.get('vm_state', 'unknown')}")
    print(f"  fenêtre              {data.get('console', 'unknown')}")
    print(f"  synchronisé          {str(data.get('synchronized', False)).lower()}")
    if data.get("recommended_action") and data.get("recommended_action") != "none":
        print(f"  action proposée      {data.get('recommended_action')}")
PY
  printf '\n'
  printf 'Actions utiles:\n'
  printf '  seven windows setup          Préparer Windows pas à pas\n'
  printf '  seven windows setup --iso /path/windows.iso\n'
  printf '  seven windows guide          Voir le guide Windows\n'
  printf '  seven windows catalog        Voir les possibilités Windows\n'
  printf '  seven windows resolve APP    Choisir la meilleure façon d’ouvrir une app\n'
  printf '  seven windows prepare APP    Préparer une app Windows\n'
  printf '  seven windows diagnose APP   Comprendre un échec d’installation\n'
  printf '  seven windows run APP        Lancer une app Windows\n'
  printf '  seven windows enter          Ouvrir Windows complet\n'
  printf '  seven windows leave          Fermer Windows proprement\n'
  printf '  seven windows sync           Ranger l’état Windows\n'
  printf '  seven windows apps           Ouvrir les apps Windows\n'
  printf '  seven windows vm             Ouvrir la gestion Windows complète\n'
  printf '  seven windows sources        Comprendre les sources Windows officielles\n'
  printf '  seven windows provision      Préparer les fichiers Windows\n'
  printf '  seven windows boot-installer Redémarrer sur l’installation Windows\n'
  printf '  seven windows fix-network    Réparer internet dans Windows\n'
  printf '  seven windows installer-help Aider si le disque Windows est invisible\n'
  printf '  seven windows create --iso /path/windows.iso --virtio-iso /path/virtio.iso\n'
}

installer_help_action() {
  if [[ "$LANG_CODE" == "fr" ]]; then
    cat <<'EOF'
SevenOS Windows Installer - aucun disque visible

Pourquoi cela arrive :
  Windows peut parfois ne pas voir le disque pendant la première installation.
  SevenOS peut le rendre visible avec le fichier d’aide Windows fourni.

Solution rapide :
  1. Dans l'écran du choix de disque, clique sur "Charger un pilote".
  2. Clique sur "Parcourir".
  3. Ouvre le disque de pilotes Windows.
  4. Va dans : viostor > w11 > amd64
  5. Sélectionne le pilote de stockage proposé.
  6. Reviens à la liste : le disque SevenOS doit apparaître.

Solution SevenOS recommandée pour une nouvelle installation simple :
  SevenOS prépare maintenant les nouvelles installations pour que Windows voie
  le disque directement dans la plupart des cas.

  Si tu veux recommencer proprement cette installation :
    virsh -c qemu:///system destroy sevenos-windows
    virsh -c qemu:///system undefine sevenos-windows --nvram
    rm -f ~/.local/share/sevenos/vm/windows/sevenos-windows.qcow2
    seven windows create --iso ~/.cache/sevenos/vm/windows/quickget/windows-11/windows-11.iso --virtio-iso ~/.local/share/sevenos/vm/windows/virtio-win.iso --disk-path ~/.local/share/sevenos/vm/windows/sevenos-windows.qcow2

Note :
  Les options avancées restent disponibles dans l’aide, mais l’assistant SevenOS
  choisit le chemin le plus simple pour une première installation.
EOF
  else
    cat <<'EOF'
SevenOS Windows Installer - no disk visible

Why this happens:
  Windows may not see the disk during the first install. SevenOS can make it
  visible with the included Windows helper files.

Quick fix:
  1. On the disk selection screen, click "Load driver".
  2. Click "Browse".
  3. Open the Windows driver disk.
  4. Go to: viostor > w11 > amd64
  5. Select the proposed storage driver.
  6. Return to the list: the SevenOS disk should appear.

Recommended SevenOS path for a simple new install:
  SevenOS now prepares new installs so Windows sees the disk directly in most
  cases.

  To restart this install cleanly:
    virsh -c qemu:///system destroy sevenos-windows
    virsh -c qemu:///system undefine sevenos-windows --nvram
    rm -f ~/.local/share/sevenos/vm/windows/sevenos-windows.qcow2
    seven windows create --iso ~/.cache/sevenos/vm/windows/quickget/windows-11/windows-11.iso --virtio-iso ~/.local/share/sevenos/vm/windows/virtio-win.iso --disk-path ~/.local/share/sevenos/vm/windows/sevenos-windows.qcow2

Note:
  Advanced options remain available in Help, but the SevenOS assistant chooses
  the simplest path for first-time setup.
EOF
  fi
}

guide_action() {
  cat <<'EOF'
Guide Windows SevenOS

Chemin simple pour la première installation
   seven windows setup
   seven windows setup --iso /path/to/windows.iso

SevenOS prépare les apps Windows, les dossiers partagés, internet Windows et
Windows complet lorsque tu fournis un fichier d’installation officiel.

1. Préparer l’espace Windows
   seven profile install windows

2. Essayer les apps Windows simples
   seven windows catalog
   seven windows resolve photoshop
   seven windows prepare office
   seven run photoshop
   seven windows run /path/to/setup.exe
   seven windows diagnose /path/to/setup.exe

3. Vérifier Windows complet seulement si une app en a besoin
   seven windows status
   seven vm network

4. Pour les apps Windows légères
   seven windows apps

5. Pour Windows complet
   seven windows sources
  seven windows provision --yes
  seven windows create --iso /path/windows.iso --virtio-iso /path/virtio.iso --os win11
  seven windows vm
  seven windows installer-help

SevenOS garde deux chemins séparés:
- Apps Windows légères avec Wine, Bottles, Proton ou Lutris.
- Windows complet pour les apps lourdes ou très sensibles.
- SevenOS ne fournit pas Windows lui-même. Il prépare ton installation à partir
  d’un média Windows officiel ou autorisé par toi.

For Microsoft Office:
- Use `seven windows prepare office` once; SevenOS remembers when the prefix is ready.
- If Microsoft 365 shows error 0-2031 or a Click-to-Run crash, run
  `seven windows diagnose OfficeSetup.exe`.
- Bottles ou Windows complet est recommandé si l’installateur Microsoft 365
  échoue avec Wine seul.
EOF
}

setup_next_action() {
  local status
  status="$(status_json)"
  WINDOWS_STATUS="$status" python - <<'PY'
import json, os

status = json.loads(os.environ.get("WINDOWS_STATUS", "{}") or "{}")
provision = status.get("provisioning", {}) if isinstance(status, dict) else {}
artifacts = provision.get("artifacts", {}) if isinstance(provision, dict) else {}
print(json.dumps({
    "vm_state": status.get("windows_vm", "MISS"),
    "ready_to_create_vm": bool(provision.get("ready_to_create_vm")),
    "recommended_next": provision.get("recommended_next", "seven windows provision --yes"),
    "windows_iso_path": artifacts.get("windows_iso_path") or provision.get("windows_iso_path"),
    "virtio_iso": artifacts.get("virtio_iso"),
}, indent=2))
PY
}

setup_action() {
  local iso=""
  local open_after=1
  local json=0
  local assume_yes=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --iso)
        iso="${2:-}"
        shift 2
        ;;
      --yes|-y)
        assume_yes=1
        shift
        ;;
      --open)
        open_after=1
        shift
        ;;
      --no-open)
        open_after=0
        shift
        ;;
      --json)
        json=1
        shift
        ;;
      --dry-run)
        export SEVENOS_DRY_RUN=1
        shift
        ;;
      -h|--help)
        cat <<'EOF'
Première préparation Windows SevenOS

Usage:
  seven windows setup
  seven windows setup --iso /path/to/windows.iso
  seven windows setup --yes --no-open

What it does:
  - prépare les applications Windows;
  - prépare internet pour Windows;
  - prépare le disque Windows local;
  - prépare les fichiers d’aide Windows quand c’est possible;
  - crée Windows complet quand un fichier Windows officiel est disponible;
  - ouvre Windows seulement quand c’est utile, sauf avec --no-open.
EOF
        return 0
        ;;
      *)
        if [[ -z "$iso" && "$1" == *.iso ]]; then
          iso="$1"
          shift
        else
          printf 'seven windows setup: unknown option: %s\n' "$1" >&2
          return 1
        fi
        ;;
    esac
  done

  local yes_args=()
  [[ "$assume_yes" == "1" ]] && yes_args=(--yes)

  if [[ "$json" == "1" ]]; then
    setup_next_action
    return 0
  fi

  printf 'Première préparation Windows SevenOS\n'
  printf '====================================\n'
  printf 'SevenOS prépare Windows localement, mais tu fournis le média officiel Microsoft.\n'

  if [[ -n "$iso" ]] && ! dry_run && [[ ! -f "$iso" ]]; then
    printf '\nFichier Windows introuvable: %s\n' "$iso" >&2
    printf 'Télécharge le fichier Windows officiel depuis Microsoft, puis lance:\n'
    printf '  seven windows setup --iso /path/to/windows.iso\n'
    return 1
  fi

  run_setup_step "Préparer les apps Windows" "$ROOT_DIR/install.sh" windows "${yes_args[@]}"
  run_setup_step "Préparer internet et les autorisations Windows" "$ROOT_DIR/bin/seven-windows-assistant" repair
  run_setup_step "Préparer le disque et les fichiers Windows" "$PROVISIONER" provision "${yes_args[@]}"

  if [[ -n "$iso" ]]; then
    run_setup_step "Préparer les fichiers d’aide Windows" "$PROVISIONER" virtio "${yes_args[@]}"
    run_setup_step "Créer Windows complet" "$ROOT_DIR/vm/windows-vm.sh" \
      --iso "$iso" \
      --virtio-iso "$VIRTIO_ISO" \
      --disk-path "$WINDOWS_DISK_PATH" \
      --os win11 \
      --name "$VM_NAME"
  else
    local next_json recommended ready vm_state
    next_json="$(setup_next_action)"
    ready="$(NEXT_JSON="$next_json" python - <<'PY'
import json, os
print("1" if json.loads(os.environ["NEXT_JSON"]).get("ready_to_create_vm") else "0")
PY
)"
    vm_state="$(NEXT_JSON="$next_json" python - <<'PY'
import json, os
print(json.loads(os.environ["NEXT_JSON"]).get("vm_state", "MISS"))
PY
)"
    recommended="$(NEXT_JSON="$next_json" python - <<'PY'
import json, os
print(json.loads(os.environ["NEXT_JSON"]).get("recommended_next", "seven windows provision --yes"))
PY
)"
    if [[ "$vm_state" == "MISS" && "$ready" == "1" && "$recommended" == seven\ windows\ create* ]]; then
      run_setup_shell_step "Créer Windows complet depuis le média officiel préparé" "$recommended"
    elif [[ "$vm_state" == "MISS" ]]; then
      printf '\nWindows est préparé, mais le fichier d’installation Windows manque encore.\n'
      printf 'Prochaine étape simple:\n'
      printf '  1. Télécharge un ISO Windows 10/11 depuis Microsoft.\n'
      printf '  2. Lance: seven windows setup --iso /path/to/windows.iso\n'
      printf '\nSevenOS peut aussi ouvrir l’aide des sources:\n'
      printf '  seven windows sources\n'
      open_after=0
    fi
  fi

  if [[ "$open_after" == "1" ]]; then
    case "$(vm_state)" in
      OK|RUN)
        run_setup_step "Ouvrir Windows" "$ROOT_DIR/vm/windows-mode.sh" enter
        ;;
      *)
        printf '\nLa préparation Windows est enregistrée. Lance ceci quand le média est prêt:\n'
        printf '  seven windows setup --iso /path/to/windows.iso\n'
        ;;
    esac
  fi

  printf '\nÉtat Windows:\n'
  status_human
}

run_detached() {
  local label="$1"
  shift
  if dry_run; then
    dry_line "$label"
    printf '%q ' "$@"
    printf '\n'
    return 0
  fi
  nohup "$@" >/dev/null 2>&1 &
}

open_bottles() {
  if dry_run; then
    dry_line "Open Windows app manager"
    printf 'flatpak run com.usebottles.bottles\n'
    return 0
  fi
  if command -v flatpak >/dev/null 2>&1 && flatpak info com.usebottles.bottles >/dev/null 2>&1; then
    run_detached "Open Windows app manager" flatpak run com.usebottles.bottles
  elif command -v bottles >/dev/null 2>&1; then
    run_detached "Open Windows app manager" bottles
  else
    printf 'Bottles is not installed yet.\n\n'
    guide_action
    return 1
  fi
}

repair_action() {
  local status
  status="$(status_json)"
  WINDOWS_STATUS="$status" python - <<'PY'
import json
import os

status = json.loads(os.environ["WINDOWS_STATUS"])
provision = status.get("provisioning", {}) if isinstance(status, dict) else {}
recommended = provision.get("recommended_next") or "seven windows provision --yes"
print("Réparation Windows SevenOS")
print("==========================")
print(f"Service Windows: {status.get('libvirtd', 'MISS')}")
print(f"Internet Windows: {status.get('default_network', 'MISS')}")
print(f"Windows complet: {status.get('windows_vm', 'MISS')}")
print(f"Installation prête: {str(provision.get('ready_to_create_vm', False)).lower()}")
print("")
print("Actions prévues:")
actions = 0
if status.get("libvirtd") != "OK":
    print("- démarrer le service Windows")
    actions += 1
if status.get("default_network") != "OK":
    print("- préparer internet pour Windows")
    actions += 1
if status.get("windows_vm") == "MISS" and provision.get("ready_to_create_vm"):
    print(f"- créer Windows complet: {recommended}")
    actions += 1
elif status.get("windows_vm") == "MISS":
    print("- préparer le fichier d’installation Windows")
    actions += 1
if actions == 0:
    print("- aucune: Windows est déjà prêt")
PY

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    printf '\nDRY-RUN commands:\n'
    WINDOWS_STATUS="$status" python - <<'PY'
import json, os
status=json.loads(os.environ["WINDOWS_STATUS"])
if status.get("libvirtd") != "OK":
    print("  sudo systemctl enable --now libvirtd.service")
if status.get("default_network") != "OK":
    print("  seven windows network")
PY
    WINDOWS_STATUS="$status" python - <<'PY'
import json, os
status=json.loads(os.environ["WINDOWS_STATUS"])
cmd=(status.get("provisioning") or {}).get("recommended_next")
if status.get("windows_vm") == "MISS" and cmd:
    print(f"  {cmd}")
PY
    return 0
  fi

  if [[ "$(service_state libvirtd.service)" != "OK" ]]; then
    if sudo -n true >/dev/null 2>&1; then
      sudo systemctl enable --now libvirtd.service || true
    else
      printf '\nAutorisation administrateur nécessaire pour démarrer le service Windows.\n'
    fi
  fi

  if [[ "$(network_state)" != "OK" ]]; then
    if sudo -n true >/dev/null 2>&1; then
      "$ROOT_DIR/vm/network.sh" || true
    else
      printf 'Autorisation administrateur nécessaire pour préparer internet Windows.\n'
    fi
  fi

  WINDOWS_STATUS="$status" python - <<'PY'
import json
import os

status = json.loads(os.environ["WINDOWS_STATUS"])
provision = status.get("provisioning", {}) if isinstance(status, dict) else {}
if status.get("windows_vm") == "MISS" and provision.get("ready_to_create_vm"):
    print("\nWindows complet est prêt à être créé. Lance:")
    print("  " + provision.get("recommended_next", "seven windows create --iso /path/windows.iso --virtio-iso /path/virtio.iso"))
PY
}

open_virt_manager() {
  if dry_run; then
    dry_line "Open Virt Manager"
    printf 'virt-manager --connect qemu:///system\n'
    return 0
  fi
  if command -v virt-manager >/dev/null 2>&1; then
    if virsh -c qemu:///system dominfo "$VM_NAME" >/dev/null 2>&1; then
      "$ROOT_DIR/vm/windows-mode.sh" console --name "$VM_NAME"
    else
      run_detached "Open Virt Manager" virt-manager --connect qemu:///system
    fi
  else
    printf 'Virt Manager is not installed yet.\n\n'
    guide_action
    return 1
  fi
}

open_best_surface() {
  if [[ -x "$ROOT_DIR/bin/seven-windows-native" ]]; then
    if dry_run; then
      dry_line "Open Windows SevenOS"
      printf 'seven-windows-native\n'
      return 0
    fi
    run_detached "Open Windows SevenOS" "$ROOT_DIR/bin/seven-windows-native"
    return 0
  fi
  if [[ "$(flatpak_app_state com.usebottles.bottles)" == "OK" ]]; then
    open_bottles
  elif [[ "$(command_state virt-manager)" == "OK" ]]; then
    open_virt_manager
  else
    guide_action
    return 1
  fi
}

case "$ACTION" in
  status)
    if [[ "${1:-}" == "--json" ]]; then
      status_json
    else
      status_human
    fi
    ;;
  plan)
    if [[ "${1:-}" == "--json" ]]; then
      plan_json
    else
      plan_human
    fi
    ;;
  guide|help)
    guide_action
    ;;
  setup|first-run|onboarding|install)
    setup_action "$@"
    ;;
  panel|gui|native|assistant)
    open_best_surface
    ;;
  installer-help|disk-help)
    installer_help_action
    ;;
  open)
    open_best_surface
    ;;
  enter)
    "$ROOT_DIR/vm/windows-mode.sh" enter "$@"
    ;;
  leave|exit)
    "$ROOT_DIR/vm/windows-mode.sh" leave "$@"
    ;;
  sync|reconcile)
    "$ROOT_DIR/vm/windows-mode.sh" sync "$@"
    ;;
  bridge-status|runtime-status|sync-status)
    "$ROOT_DIR/vm/windows-mode.sh" bridge-status "$@"
    ;;
  apps|bottles)
    open_bottles
    ;;
  catalog)
    "$ROOT_DIR/vm/windows-app-runner.sh" catalog "$@"
    ;;
  resolve)
    "$ROOT_DIR/vm/windows-app-runner.sh" resolve "$@"
    ;;
  prepare)
    "$ROOT_DIR/vm/windows-app-runner.sh" prepare "$@"
    ;;
  diagnose|doctor)
    "$ROOT_DIR/vm/windows-app-runner.sh" diagnose "$@"
    ;;
  run)
    "$ROOT_DIR/vm/windows-app-runner.sh" run "$@"
    ;;
  vm|virt-manager)
    open_virt_manager
    ;;
  provision)
    "$PROVISIONER" provision "$@"
    ;;
  sources)
    "$PROVISIONER" sources "$@"
    ;;
  virtio)
    "$PROVISIONER" virtio "$@"
    ;;
  autounattend)
    "$PROVISIONER" autounattend "$@"
    ;;
  create)
    if [[ "$#" -eq 0 || " $* " != *" --iso "* ]]; then
      plan_path="$(write_vm_plan)"
      cat <<'EOF'
Windows complet a besoin d’un fichier d’installation Windows officiel avant de démarrer.

Chemin recommandé:
  seven windows provision --yes

Chemin manuel:
  seven windows create --iso /path/to/windows.iso --virtio-iso ~/.local/share/sevenos/vm/windows/virtio-win.iso --disk-path ~/.local/share/sevenos/vm/windows/sevenos-windows.qcow2 --os win11

Pourquoi ces fichiers d’aide?
  Ils aident Windows à voir le disque et internet pendant l’installation.

Pourquoi SevenOS ne fournit pas Windows directement?
  Windows n’est pas redistribué par SevenOS. SevenOS prépare ton installation à partir d’un média officiel ou autorisé par toi.

Ouvre le guide à tout moment avec:
  seven windows guide
EOF
      printf '\nSevenOS a enregistré un plan guidé Windows:\n  %s\n' "$plan_path"
      exit 0
    fi
    "$ROOT_DIR/vm/windows-vm.sh" "$@"
    ;;
  repair|fix|doctor-vm)
    repair_action "$@"
    ;;
  start|console|stop|fix-network|network-fix)
    "$ROOT_DIR/vm/windows-mode.sh" "$ACTION" "$@"
    ;;
  boot-installer|installer-boot)
    "$ROOT_DIR/vm/windows-mode.sh" boot-installer "$@"
    ;;
  network)
    "$ROOT_DIR/vm/network.sh" "$@"
    ;;
  check)
    "$ROOT_DIR/vm/check.sh" "$@"
    ;;
  --json)
    status_json
    ;;
  -h|--help)
    guide_action
    ;;
  *)
    printf 'seven-windows-assistant: unknown action: %s\n\n' "$ACTION" >&2
    guide_action >&2
    exit 1
    ;;
esac
