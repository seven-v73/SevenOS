#!/usr/bin/env bash
set -Eeuo pipefail

ACTION="${1:-status}"

json_status() {
  cat <<'JSON'
{
  "schema": "sevenos.retired-windows-vm.v1",
  "state": "retired",
  "ready": false,
  "app_ready": false,
  "vm_ready": false,
  "mode": "retired",
  "replacement": "atlas",
  "message": "Windows VM is retired from the SevenOS mini OS model. Use Atlas Explorer as the seventh native mini OS."
}
JSON
}

case "$ACTION" in
  status|plan|bridge-status|catalog|resolve|prepare|diagnose|run|apps|guide|setup|repair|network|sources|provision|create|vm|start|enter|leave|sync|console|boot-installer|fix-network|installer-help|open)
    if [[ " $* " == *" --json "* || "$ACTION" == "status" || "$ACTION" == "plan" || "$ACTION" == "bridge-status" || "$ACTION" == "catalog" || "$ACTION" == "resolve" ]]; then
      json_status
      exit 0
    fi
    ;;
esac

cat <<'EOF'
SevenOS Windows VM has been retired.

SevenOS now keeps seven native mini OS identities:
Equinox, Baobab, Forge, Shield, Studio, Atlas and Pulse.

Use Atlas Explorer instead:
  seven atlas open
  seven atlas status
  seven atlas install --yes
  seven profile activate atlas

Light compatibility apps can still be installed as normal apps when needed, but
Windows VM is no longer a SevenOS mini OS or public workflow.
EOF
