#!/usr/bin/env python3
"""SevenDecor overlay controls for non-native application windows."""

from __future__ import annotations

import argparse
import cairo
import json
import math
import os
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
CONTROL_STATE = CONFIG_DIR / "window-controls.json"
PRISM_ITEMS = CONFIG_DIR / "window-prism-items.json"
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None


def language_code() -> str:
    language = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG", "en_US.UTF-8")
    config = CONFIG_DIR / "language.conf"
    if not os.environ.get("SEVENOS_LANGUAGE") and config.exists():
        try:
            for raw in config.read_text(encoding="utf-8", errors="ignore").splitlines():
                key, _, value = raw.partition("=")
                if key.strip() in {"SEVENOS_LANGUAGE", "LANG"}:
                    language = value.strip().strip("'\"")
                    break
        except Exception:
            pass
    return "fr" if language.lower().startswith("fr") else "en"


def tr(fr: str, en: str) -> str:
    return fr if language_code() == "fr" else en


def subprocess_run(command: list[str]) -> int:
    return subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode


def seven_window_command(*args: str) -> list[str]:
    local = ROOT / "bin/seven-window"
    if local.exists():
        return [str(local), *args]
    user = Path.home() / ".local/bin/seven-window"
    if user.exists():
        return [str(user), *args]
    return ["seven-window", *args]


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        if subprocess_run([str(system_python), "-c", "import gi"]) == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    if probe_ok():
        print("OK")
        return 0
    print("MISS: GTK/GDK unavailable", file=sys.stderr)
    return 1


def probe_ok() -> bool:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        return False
    return True


def active_window() -> dict:
    try:
        data = subprocess.check_output(["hyprctl", "-j", "activewindow"], text=True, stderr=subprocess.DEVNULL)
        return json.loads(data)
    except Exception:
        return {}


def hypr_clients() -> list[dict]:
    try:
        data = subprocess.check_output(["hyprctl", "-j", "clients"], text=True, stderr=subprocess.DEVNULL)
        clients = json.loads(data)
        return clients if isinstance(clients, list) else []
    except Exception:
        return []


def hypr_monitors() -> list[dict]:
    try:
        data = subprocess.check_output(["hyprctl", "-j", "monitors"], text=True, stderr=subprocess.DEVNULL)
        monitors = json.loads(data)
        return monitors if isinstance(monitors, list) else []
    except Exception:
        return []


def is_controls_window(item: dict) -> bool:
    klass = str(item.get("class") or item.get("initialClass") or "")
    title = str(item.get("title") or item.get("initialTitle") or "")
    return klass == "SevenWindowControlsNative" or title in {
        "Seven Window Controls",
        "Seven Window Layout",
        "Seven Window Advanced",
        "Seven Window Traffic Lights",
    }


def target_window() -> dict:
    active = active_window()
    if active and not is_controls_window(active):
        return active
    clients = [item for item in hypr_clients() if isinstance(item, dict) and not is_controls_window(item)]
    clients.sort(key=lambda item: int(item.get("focusHistoryID") or 9999))
    return clients[0] if clients else {}


def window_by_address(address: str) -> dict:
    if not address:
        return {}
    wanted = address.lower()
    for item in hypr_clients():
        if isinstance(item, dict) and str(item.get("address") or "").lower() == wanted and not is_controls_window(item):
            return item
    return {}


def controls_window() -> dict:
    for item in hypr_clients():
        if isinstance(item, dict) and str(item.get("title") or "") == "Seven Window Traffic Lights":
            return item
    return {}


def focus_target(address: str) -> None:
    if address:
        subprocess_run(["hyprctl", "dispatch", "focuswindow", f"address:{address}"])


def run_action(action: str, address: str) -> None:
    if action.startswith("workspace:"):
        focus_target(address)
        workspace = action.split(":", 1)[1]
        subprocess_run(["hyprctl", "dispatch", "movetoworkspacesilent", workspace])
        return
    focus_target(address)
    command_map = {
        "close": ["hyprctl", "dispatch", "killactive"],
        "float": seven_window_command("toggle-float"),
        "maximize": seven_window_command("smart-maximize"),
        "fullscreen": seven_window_command("fullscreen"),
        "split-left": seven_window_command("split-left"),
        "split-right": seven_window_command("split-right"),
        "mosaic": seven_window_command("mosaic"),
        "scratchpad": ["hyprctl", "dispatch", "movetoworkspacesilent", "special:seven"],
        "pin": ["hyprctl", "dispatch", "pin"],
        "focus-mode": seven_window_command("mode", "focus"),
        "menu": seven_window_command("layout-menu"),
    }
    command = command_map.get(action)
    if command:
        subprocess_run(command)


def target_summary(target: dict) -> str:
    title = (target.get("title") or "").strip()
    klass = (target.get("class") or "").strip()
    if title and klass:
        return f"{klass} · {title}"
    return title or klass or tr("Fenêtre active", "Active window")


def target_short_name(target: dict) -> str:
    klass = (target.get("class") or target.get("initialClass") or "").strip()
    title = (target.get("title") or "").strip()
    text = klass or title or tr("Fenêtre", "Window")
    if len(text) > 22:
        return text[:19].rstrip() + "..."
    return text


def target_workspace_key(target: dict) -> str:
    workspace = target.get("workspace") if isinstance(target.get("workspace"), dict) else {}
    return str(workspace.get("id") or workspace.get("name") or "")


def target_cycle_candidates(target: dict) -> list[dict]:
    key = target_workspace_key(target)
    candidates = []
    for item in hypr_clients():
        if not isinstance(item, dict) or is_controls_window(item):
            continue
        if key and target_workspace_key(item) != key:
            continue
        candidates.append(item)
    candidates.sort(key=lambda item: int(item.get("focusHistoryID") or 9999))
    return candidates


def cycle_target_from(target: dict, direction: int) -> dict:
    candidates = target_cycle_candidates(target or target_window())
    if not candidates:
        return target or {}
    current_address = str((target or {}).get("address") or "").lower()
    index = 0
    for candidate_index, item in enumerate(candidates):
        if str(item.get("address") or "").lower() == current_address:
            index = candidate_index
            break
    next_index = (index + (1 if direction >= 0 else -1)) % len(candidates)
    return candidates[next_index]


def monitor_for_window(target: dict) -> dict:
    monitors = hypr_monitors()
    if not monitors:
        return {"x": 0, "y": 0, "width": 1920, "height": 1080}
    monitor_id = target.get("monitor")
    for monitor in monitors:
        if monitor.get("id") == monitor_id:
            return monitor
    return monitors[0]


def clamp(value: int, low: int, high: int) -> int:
    return max(low, min(value, high))


def load_control_state() -> dict:
    try:
        return json.loads(CONTROL_STATE.read_text(encoding="utf-8"))
    except Exception:
        return {"placement": "adaptive"}


def save_control_state(data: dict) -> None:
    try:
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        CONTROL_STATE.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
    except Exception:
        pass


def hidden_classes() -> list[str]:
    state = load_control_state()
    classes = state.get("hidden_classes")
    if not isinstance(classes, list):
        return []
    return [str(item).lower() for item in classes if str(item).strip()]


def hide_class_for_target(target: dict) -> None:
    klass = str(target.get("class") or target.get("initialClass") or "").strip()
    if not klass:
        return
    state = load_control_state()
    classes = state.get("hidden_classes")
    if not isinstance(classes, list):
        classes = []
    lowered = {str(item).lower() for item in classes}
    if klass.lower() not in lowered:
        classes.append(klass)
    state["hidden_classes"] = classes
    state.setdefault("schema", "sevenos.window-controls.state.v1")
    save_control_state(state)


def clear_hidden_classes() -> None:
    state = load_control_state()
    state["hidden_classes"] = []
    state.setdefault("schema", "sevenos.window-controls.state.v1")
    save_control_state(state)


def target_is_hidden(target: dict) -> bool:
    klass = str(target.get("class") or target.get("initialClass") or "").lower()
    return bool(klass and klass in hidden_classes())


def locked_address() -> str:
    state = load_control_state()
    return str(state.get("locked_address") or "")


def locked_target() -> dict:
    return window_by_address(locked_address())


def lock_target(target: dict) -> None:
    address = str(target.get("address") or "")
    if not address:
        return
    state = load_control_state()
    state["schema"] = "sevenos.window-controls.state.v1"
    state["locked_address"] = address
    state["locked_class"] = target.get("class") or target.get("initialClass") or ""
    state["locked_title"] = target.get("title") or ""
    save_control_state(state)


def unlock_target() -> None:
    state = load_control_state()
    for key in ("locked_address", "locked_class", "locked_title"):
        state.pop(key, None)
    state["schema"] = "sevenos.window-controls.state.v1"
    save_control_state(state)


def effective_target() -> dict:
    locked = locked_target()
    if locked:
        return locked
    return target_window()


def save_manual_position() -> None:
    controls = controls_window()
    at = controls.get("at") if isinstance(controls.get("at"), list) else []
    if len(at) < 2:
        return
    state = load_control_state()
    state.update({
        "schema": "sevenos.window-controls.state.v1",
        "placement": "manual",
        "x": int(at[0]),
        "y": int(at[1]),
    })
    save_control_state(state)


def reset_adaptive_position() -> None:
    state = load_control_state()
    state.update({
        "schema": "sevenos.window-controls.state.v1",
        "placement": "adaptive",
    })
    save_control_state(state)


def desired_controls_position(target: dict, controls: dict) -> tuple[int, int]:
    monitor = monitor_for_window(target)
    monitor_x = int(monitor.get("x") or 0)
    monitor_y = int(monitor.get("y") or 0)
    monitor_w = int(monitor.get("width") or 1920)
    monitor_h = int(monitor.get("height") or 1080)
    controls_size = controls.get("size") if isinstance(controls.get("size"), list) else [100, 32]
    controls_w = int(controls_size[0] if len(controls_size) > 0 else 100)
    controls_h = int(controls_size[1] if len(controls_size) > 1 else 32)
    state = load_control_state()
    if state.get("placement") == "manual":
        x = clamp(int(state.get("x") or monitor_x + 12), monitor_x + 8, monitor_x + monitor_w - controls_w - 8)
        y = clamp(int(state.get("y") or monitor_y + 42), monitor_y + 32, monitor_y + monitor_h - controls_h - 8)
        return x, y
    at = target.get("at") if isinstance(target.get("at"), list) else [monitor_x, monitor_y]
    target_x = int(at[0] if len(at) > 0 else monitor_x)
    target_y = int(at[1] if len(at) > 1 else monitor_y)
    x = target_x + int(os.environ.get("SEVENOS_WINDOW_CONTROLS_OFFSET_X", "12"))
    y = target_y + int(os.environ.get("SEVENOS_WINDOW_CONTROLS_OFFSET_Y", "10"))
    min_y = monitor_y + int(os.environ.get("SEVENOS_WINDOW_CONTROLS_MIN_Y", "42"))
    x = clamp(x, monitor_x + 12, monitor_x + monitor_w - controls_w - 12)
    y = clamp(y, min_y, monitor_y + monitor_h - controls_h - 12)
    return x, y


def move_controls_to_target(target: dict) -> None:
    controls = controls_window()
    address = controls.get("address") or ""
    if not address or not target:
        return
    x, y = desired_controls_position(target, controls)
    current_at = controls.get("at") if isinstance(controls.get("at"), list) else []
    if len(current_at) >= 2 and abs(int(current_at[0]) - x) < 2 and abs(int(current_at[1]) - y) < 2:
        return
    subprocess_run(["hyprctl", "dispatch", "movewindowpixel", "exact", str(x), str(y) + f",address:{address}"])


def resize_controls(width: int, height: int) -> None:
    controls = controls_window()
    address = controls.get("address") or ""
    if address:
        subprocess_run(["hyprctl", "dispatch", "resizewindowpixel", "exact", str(width), str(height) + f",address:{address}"])


def move_controls_absolute(x: int, y: int) -> None:
    controls = controls_window()
    address = controls.get("address") or ""
    if address:
        subprocess_run(["hyprctl", "dispatch", "movewindowpixel", "exact", str(int(x)), str(int(y)) + f",address:{address}"])


