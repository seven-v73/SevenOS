    mode = seven_theme.current_theme_mode() if seven_theme else os.environ.get("SEVENOS_THEME_MODE", "dark")
    base = seven_theme.gtk_app_css("window-controls", mode) if seven_theme else ""
    css = """
    window.seven-decor-overlay {
