#!/usr/bin/env python3
"""SevenDecor overlay controls for non-native application windows."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None


def subprocess_run(command: list[str]) -> int:
    return subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        if subprocess_run([str(system_python), "-c", "import gi"]) == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def probe() -> int:
    if probe_ok():
        print("OK")
        return 0
    print("MISS: GTK/GDK unavailable", file=sys.stderr)
    return 1


def probe_ok() -> bool:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        return False
    return True


def active_window() -> dict:
    try:
        data = subprocess.check_output(["hyprctl", "-j", "activewindow"], text=True, stderr=subprocess.DEVNULL)
        return json.loads(data)
    except Exception:
        return {}


def focus_target(address: str) -> None:
    if address:
        subprocess_run(["hyprctl", "dispatch", "focuswindow", f"address:{address}"])


def run_action(action: str, address: str) -> None:
    focus_target(address)
    command_map = {
        "close": ["hyprctl", "dispatch", "killactive"],
        "float": ["seven-window", "toggle-float"],
        "maximize": ["seven-window", "smart-maximize"],
        "fullscreen": ["seven-window", "fullscreen"],
        "split-left": ["seven-window", "split-left"],
        "split-right": ["seven-window", "split-right"],
        "mosaic": ["seven-window", "mosaic"],
        "menu": ["seven-window", "layout-menu"],
    }
    command = command_map.get(action)
    if command:
        subprocess_run(command)


def target_summary(target: dict) -> str:
    title = (target.get("title") or "").strip()
    klass = (target.get("class") or "").strip()
    if title and klass:
        return f"{klass} · {title}"
    return title or klass or "Active window"


def load_css() -> None:
    from gi.repository import Gdk, Gtk

    mode = seven_theme.current_theme_mode() if seven_theme else os.environ.get("SEVENOS_THEME_MODE", "dark")
    base = seven_theme.gtk_app_css("window-controls", mode) if seven_theme else ""
    css = """
    window.seven-decor-overlay {
      background: @seven_panel;
      border: 1px solid @seven_border;
      border-radius: 18px;
    }
    .overlay-root {
      padding: 10px 12px;
      background: @seven_panel;
      border-radius: 18px;
    }
    .overlay-title {
      color: @seven_text;
      font: 600 11px "SF Pro Text", "Inter", system-ui, sans-serif;
    }
    .overlay-subtitle {
      color: @seven_muted;
      font: 500 10px "SF Pro Text", "Inter", system-ui, sans-serif;
    }
    .traffic {
      min-width: 15px;
      min-height: 15px;
      border-radius: 999px;
      padding: 0;
      margin: 0 8px 0 0;
      border: 1px solid rgba(0,0,0,0.20);
      background-image: none;
    }
    .traffic.close { background: @seven_traffic_close; }
    .traffic.float { background: @seven_traffic_minimize; }
    .traffic.max { background: @seven_traffic_maximize; }
    .pill-action {
      min-height: 25px;
      padding: 0 10px;
      border-radius: 999px;
      color: @seven_text;
      background: alpha(@seven_text, 0.07);
      border: 1px solid @seven_border;
      font: 600 10px "SF Pro Text", "Inter", system-ui, sans-serif;
    }
    .pill-action:hover {
      background: @seven_hover;
      border-color: alpha(@seven_accent, 0.34);
    }
    .menu-card {
      padding: 14px;
      background: @seven_panel;
      border-radius: 20px;
    }
    .menu-button {
      min-height: 34px;
      padding: 0 13px;
      border-radius: 12px;
      color: @seven_text;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
      font: 600 11px "SF Pro Text", "Inter", system-ui, sans-serif;
    }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data((base + css).encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)


def traffic_button(style: str, label: str, callback=None):
    from gi.repository import Gtk

    button = Gtk.Button()
    button.set_tooltip_text(label)
    button.get_style_context().add_class("traffic")
    button.get_style_context().add_class(style)
    if callback is not None:
        button.connect("clicked", lambda *_: callback())
    return button


def pill(label: str, callback):
    from gi.repository import Gtk

    button = Gtk.Button(label=label)
    button.get_style_context().add_class("pill-action")
    button.connect("clicked", lambda *_: callback())
    return button


def close_after(window, callback):
    callback()
    window.close()


def show_controls(menu: bool = False) -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    GLib.set_prgname("SevenWindowControlsNative")
    GLib.set_application_name("Seven Window Controls")
    try:
        Gdk.set_program_class("SevenWindowControlsNative")
    except Exception:
        pass

    target = active_window()
    address = target.get("address") or ""
    summary = target_summary(target)
    load_css()

    window = Gtk.Window(title="Seven Window Controls")
    window.set_wmclass("SevenWindowControlsNative", "SevenWindowControlsNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_skip_taskbar_hint(True)
    window.set_skip_pager_hint(True)
    window.get_style_context().add_class("seven-decor-overlay")
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: window.close() if Gdk.keyval_name(event.keyval) == "Escape" else False)

    if menu:
      root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
      root.get_style_context().add_class("menu-card")
      window.add(root)
      title = Gtk.Label(label="Seven Window Layout")
      title.set_xalign(0)
      title.get_style_context().add_class("overlay-title")
      root.pack_start(title, False, False, 0)
      subtitle = Gtk.Label(label=summary)
      subtitle.set_xalign(0)
      subtitle.set_ellipsize(3)
      subtitle.get_style_context().add_class("overlay-subtitle")
      root.pack_start(subtitle, False, False, 0)
      grid = Gtk.Grid(column_spacing=8, row_spacing=8)
      root.pack_start(grid, False, False, 4)
      items = [
          ("Smart Max", "maximize"), ("Fullscreen", "fullscreen"),
          ("Split Left", "split-left"), ("Split Right", "split-right"),
          ("Float / Tile", "float"), ("Mosaic", "mosaic"),
      ]
      for index, (label, action) in enumerate(items):
          button = Gtk.Button(label=label)
          button.get_style_context().add_class("menu-button")
          button.connect("clicked", lambda _b, act=action: close_after(window, lambda: run_action(act, address)))
          grid.attach(button, index % 2, index // 2, 1, 1)
      window.set_default_size(330, 250)
    else:
      root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
      root.get_style_context().add_class("overlay-root")
      window.add(root)
      root.pack_start(traffic_button("close", "Close active window", lambda: close_after(window, lambda: run_action("close", address))), False, False, 0)
      root.pack_start(traffic_button("float", "Toggle floating / tiling", lambda: close_after(window, lambda: run_action("float", address))), False, False, 0)
      max_button = traffic_button("max", "Smart maximize / double-click fullscreen")
      max_button.connect("button-press-event", lambda _b, event: close_after(window, lambda: run_action("fullscreen" if event.type == Gdk.EventType._2BUTTON_PRESS else "maximize", address)) or True)
      max_button.connect("button-release-event", lambda *_: True)
      root.pack_start(max_button, False, False, 0)
      title_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
      title = Gtk.Label(label="SevenDecor")
      title.set_xalign(0)
      title.get_style_context().add_class("overlay-title")
      subtitle = Gtk.Label(label=summary)
      subtitle.set_xalign(0)
      subtitle.set_ellipsize(3)
      subtitle.get_style_context().add_class("overlay-subtitle")
      title_box.pack_start(title, False, False, 0)
      title_box.pack_start(subtitle, False, False, 0)
      root.pack_start(title_box, True, True, 5)
      root.pack_start(pill("Layout", lambda: close_after(window, lambda: run_action("menu", address))), False, False, 0)
      window.set_default_size(420, 54)

    window.show_all()
    Gtk.main()
    return 0


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("--menu", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()
    if args.probe:
        return probe()
    if args.json:
        print(json.dumps({"schema": "sevenos.window-controls.v1", "native": probe_ok()}))
        return 0
    return show_controls(menu=args.menu)


if __name__ == "__main__":
    raise SystemExit(main())
