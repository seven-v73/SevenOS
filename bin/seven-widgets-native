def lang_is_fr() -> bool:
    language = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG", "")
    return language.lower().startswith("fr")


def tr(fr: str, en: str) -> str:
    return fr if lang_is_fr() else en


def catalog_keys() -> set[str]:
    return {item["key"] for item in CATALOG}


def widget_icon(key: str) -> str:
    return WIDGET_ICONS.get(key, "•")


def widget_title(key: str) -> str:
    for item in CATALOG:
        if item["key"] == key:
            return item["title"] if lang_is_fr() else item["title_en"]
    return key


def widget_category(key: str) -> str:
    for item in CATALOG:
        if item["key"] == key:
            return str(item.get("category") or "sevenos")
    return "sevenos"


def widget_category_title(key: str) -> str:
    for category, fr, en in WIDGET_CATEGORIES:
        if category == key:
            return fr if lang_is_fr() else en
    return key.title()


def widget_search_text(item: dict) -> str:
    fields = [
        str(item.get("key") or ""),
        str(item.get("title") or ""),
        str(item.get("title_en") or ""),
        str(item.get("note") or ""),
        str(item.get("note_en") or ""),
        widget_category_title(str(item.get("category") or "")),
    ]
    return " ".join(fields).casefold()


def preset_widgets(name: str) -> list[str]:
    key = name.strip().lower()
    if key == "active":
        key = current_profile()
    wanted = PRESETS.get(key, PRESETS["equinox"])
    return [item for item in wanted if item in catalog_keys()]


def layout_key(value: str | None) -> str:
    key = str(value or "calm-grid").strip().lower()
    return key if key in LAYOUTS else "calm-grid"


def layout_title(key: str) -> str:
    item = LAYOUTS.get(layout_key(key), LAYOUTS["calm-grid"])
    return item["title"] if lang_is_fr() else item["title_en"]


def run(command: list[str], timeout: float = 1.5) -> str:
    try:
        return subprocess.run(command, text=True, capture_output=True, check=False, timeout=timeout).stdout.strip()
    except Exception:
        return ""


def config() -> dict:
    if CONFIG_FILE.exists():
        try:
            data = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
            if isinstance(data, dict):
                if data.get("schema") != "sevenos.widgets.config.v2":
                    data["schema"] = "sevenos.widgets.config.v2"
                    data["desktop_right_click"] = False
                data.setdefault("enabled", DEFAULT_WIDGETS)
                data.setdefault("visible", False)
                data.setdefault("desktop_right_click", False)
                data.setdefault("home_workspace", HOME_WORKSPACE)
                data.setdefault("layout", "calm-grid")
                data.setdefault("last_preset", "")
                data.setdefault("last_action", {})
                save_config(data)
                return data
        except json.JSONDecodeError:
            pass
    return {
        "schema": "sevenos.widgets.config.v2",
        "enabled": DEFAULT_WIDGETS,
        "visible": False,
        "desktop_right_click": False,
        "home_workspace": HOME_WORKSPACE,
        "layout": "calm-grid",
        "last_action": {},
    }


def save_config(data: dict) -> None:
    try:
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        CONFIG_FILE.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    except OSError:
        # Some probes run from restricted contexts. Keep the UI readable and let
        # explicit write commands report through their returned state.
        return


def backup_config(data: dict | None = None) -> None:
    payload = dict(data or config())
    payload["backup_created"] = int(time.time())
    try:
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        BACKUP_FILE.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    except OSError:
        return


def restore_previous_config() -> dict:
    if BACKUP_FILE.exists():
        try:
            data = json.loads(BACKUP_FILE.read_text(encoding="utf-8"))
            if isinstance(data, dict):
                data.pop("backup_created", None)
                data["schema"] = "sevenos.widgets.config.v2"
                mark_action(data, "Configuration widgets précédente restaurée.", "Previous widget configuration restored.")
                save_config(data)
                return data
        except Exception:
            pass
    return config()


def mark_action(data: dict, fr: str, en: str) -> dict:
    data["last_action"] = {"fr": fr, "en": en, "time": int(time.time())}
    return data


def last_action_text(data: dict) -> str:
    action = data.get("last_action")
    if not isinstance(action, dict):
        return ""
    text = str(action.get("fr" if lang_is_fr() else "en") or "")
    try:
        age = int(time.time()) - int(action.get("time") or 0)
    except Exception:
        age = 999999
    return text if text and age < 900 else ""


def current_profile() -> str:
    text = run([str(ROOT / "profiles/profile-manager.sh"), "current", "--json"], timeout=1.0)
    try:
        return str(json.loads(text or "{}").get("key") or "equinox")
    except json.JSONDecodeError:
        return os.environ.get("SEVENOS_PROFILE", "equinox")


def cpu_percent() -> int:
    def read() -> tuple[int, int]:
        try:
            fields = Path("/proc/stat").read_text(encoding="utf-8").splitlines()[0].split()[1:]
            values = [int(item) for item in fields]
        except Exception:
            return 0, 0
        idle = values[3] + (values[4] if len(values) > 4 else 0)
        return idle, sum(values)

    idle_a, total_a = read()
    time.sleep(0.05)
    idle_b, total_b = read()
    total_delta = max(total_b - total_a, 1)
    return max(0, min(100, round(100 * (1 - max(idle_b - idle_a, 0) / total_delta))))


def memory_percent() -> int:
    values: dict[str, int] = {}
    try:
        for line in Path("/proc/meminfo").read_text(encoding="utf-8").splitlines():
            key, raw = line.split(":", 1)
            values[key] = int(raw.strip().split()[0])
    except Exception:
        return 0
    total = values.get("MemTotal", 0)
    available = values.get("MemAvailable", 0)
    return round((total - available) / total * 100) if total else 0


def disk_percent() -> int:
    try:
        usage = shutil.disk_usage(str(Path.home()))
    except OSError:
        return 0
    return round(usage.used / usage.total * 100) if usage.total else 0


def disk_summary() -> dict:
    try:
        usage = shutil.disk_usage(str(Path.home()))
    except OSError:
        return {"percent": 0, "free": "?", "used": "?"}
    gib = 1024 ** 3
    return {
        "percent": round(usage.used / usage.total * 100) if usage.total else 0,
        "free": f"{usage.free / gib:.0f} GiB",
        "used": f"{usage.used / gib:.0f} GiB",
    }


def battery_summary() -> dict:
    power_supply = Path("/sys/class/power_supply")
    batteries = sorted(power_supply.glob("BAT*")) if power_supply.exists() else []
    if not batteries:
        profile = run(["powerprofilesctl", "get"], timeout=0.7) if shutil.which("powerprofilesctl") else ""
        return {"present": False, "percent": None, "status": tr("Secteur", "AC power"), "profile": profile or "balanced"}
    battery = batteries[0]
    capacity = (battery / "capacity").read_text(encoding="utf-8", errors="ignore").strip() if (battery / "capacity").exists() else ""
    status = (battery / "status").read_text(encoding="utf-8", errors="ignore").strip() if (battery / "status").exists() else ""
    try:
        percent = max(0, min(100, int(capacity)))
    except Exception:
        percent = None
    profile = run(["powerprofilesctl", "get"], timeout=0.7) if shutil.which("powerprofilesctl") else ""
    return {"present": True, "percent": percent, "status": status or "unknown", "profile": profile or "balanced"}


def media_summary() -> dict:
    if not shutil.which("playerctl"):
        return {"state": "missing", "title": tr("Playerctl absent", "playerctl missing"), "artist": "", "player": ""}
    status = run(["playerctl", "status"], timeout=0.6)
    title = run(["playerctl", "metadata", "title"], timeout=0.6)
    artist = run(["playerctl", "metadata", "artist"], timeout=0.6)
    player = run(["playerctl", "-l"], timeout=0.6).splitlines()
    return {
        "state": status or tr("Aucune lecture", "No playback"),
        "title": title or tr("Rien en lecture", "Nothing playing"),
        "artist": artist,
        "player": player[0] if player else "",
    }


def month_summary() -> dict:
    now = time.localtime()
    _, days = calendar.monthrange(now.tm_year, now.tm_mon)
    return {
        "day": now.tm_mday,
        "days": days,
        "weekday": time.strftime("%A", now),
        "month": time.strftime("%B", now),
        "week": time.strftime("%V", now),
        "fraction": now.tm_mday / max(days, 1),
    }


def weather_summary(data: dict | None = None) -> dict:
    prefs = data or config()
    weather = prefs.get("weather") if isinstance(prefs.get("weather"), dict) else {}
    enabled = bool(weather.get("enabled", False))
    location = str(weather.get("location") or "")
    summary = str(weather.get("summary") or "")
    return {
        "enabled": enabled,
        "location": location or tr("Non configuré", "Not configured"),
        "summary": summary or tr("Ajoute une ville dans les réglages widgets.", "Add a city in widget settings."),
    }


def doctor_state() -> dict:
    text = run([str(ROOT / "bin/seven"), "doctor", "check", "--json"], timeout=6.0)
    try:
        return json.loads(text or "{}")
    except json.JSONDecodeError:
        return {}


def network_state() -> str:
    text = run(["nmcli", "-t", "-f", "STATE", "general"], timeout=1.0)
    return text or "unknown"


def seven_notes() -> list[dict]:
    if SEVEN_NOTES_FILE.exists():
        try:
            data = json.loads(SEVEN_NOTES_FILE.read_text(encoding="utf-8"))
            notes = data.get("notes") if isinstance(data, dict) else data
            if isinstance(notes, list):
                return [item for item in notes if isinstance(item, dict)]
        except Exception:
            pass
    if NOTE_FILE.exists():
        text = NOTE_FILE.read_text(encoding="utf-8", errors="ignore").strip()
        if text:
            return [{"id": "legacy", "title": tr("Mémo rapide", "Quick memo"), "body": text, "updated": int(NOTE_FILE.stat().st_mtime)}]
    return []


def add_widget_note(text: str) -> None:
    text = text.strip()
    if not text:
        return
    subprocess.run([str(ROOT / "bin/seven-notes"), "add", text], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def current_workspace() -> str:
    text = run(["hyprctl", "activeworkspace", "-j"], timeout=0.5)
    try:
        data = json.loads(text or "{}")
    except json.JSONDecodeError:
        return "unknown"
    return str(data.get("id") or data.get("name") or "unknown")


def switch_home_workspace() -> None:
    target = str(config().get("home_workspace") or HOME_WORKSPACE)
    if shutil.which("hyprctl"):
        subprocess.run(["hyprctl", "dispatch", "workspace", target], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def active_window_present() -> bool:
    text = run(["hyprctl", "activewindow", "-j"], timeout=0.5)
    try:
        data = json.loads(text or "{}")
    except json.JSONDecodeError:
        return False
    return bool(data.get("class") or data.get("title") or data.get("address"))


def widget_payload() -> dict:
    data = config()
    doctor = doctor_state()
    summary = doctor.get("summary") if isinstance(doctor.get("summary"), dict) else {}
    disk = disk_summary()
    return {
        "schema": "sevenos.widgets.status.v1",
        "config": data,
        "catalog": CATALOG,
        "profile": current_profile(),
        "runtime": {
            "cpu": cpu_percent(),
            "memory": memory_percent(),
            "disk": disk["percent"],
            "disk_summary": disk,
            "battery": battery_summary(),
            "media": media_summary(),
            "calendar": month_summary(),
            "weather": weather_summary(data),
            "network": network_state(),
            "doctor": {"decision": doctor.get("decision", "unknown"), "issues": summary.get("issues", 0)},
            "workspace": current_workspace(),
            "updated": int(time.time()),
        },
    }


