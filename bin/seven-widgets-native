    def notes_widget_card(self, payload: dict):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("widget")
        notes = sorted(seven_notes(), key=lambda item: (bool(item.get("pinned")), int(item.get("updated") or 0)), reverse=True)
        title_label = Gtk.Label(label=f"{widget_icon('notes')}  {tr('Notes', 'Notes')}", xalign=0)
        title_label.get_style_context().add_class("subtitle")
        value_label = Gtk.Label(label=notes[0].get("title", tr("Rien à noter", "Nothing yet")) if notes else tr("Rien à noter", "Nothing yet"), xalign=0)
        value_label.get_style_context().add_class("value")
        value_label.set_line_wrap(True)
        card.pack_start(title_label, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        for item in notes[:3]:
            body = str(item.get("body") or "").replace("\n", " ").strip()
            chip = Gtk.Label(label=(body or str(item.get("title") or ""))[:52], xalign=0)
            chip.get_style_context().add_class("note-chip")
            card.pack_start(chip, False, False, 0)
        entry = Gtk.Entry()
        entry.set_placeholder_text(tr("Note rapide…", "Quick note…"))
        save = Gtk.Button(label=tr("Ajouter", "Add"))
        save.get_style_context().add_class("compact")

        def submit(*_args):
            text = entry.get_text().strip()
            if text:
                add_widget_note(text)
                entry.set_text("")
                self.render()

        entry.connect("activate", submit)
        save.connect("clicked", submit)
        card.pack_start(entry, False, False, 0)
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        open_button = Gtk.Button(label=tr("Ouvrir", "Open"))
        open_button.get_style_context().add_class("compact")
        open_button.connect("clicked", lambda *_a: subprocess.Popen(["seven-notes"]))
        row.pack_start(save, True, True, 0)
        row.pack_start(open_button, True, True, 0)
        card.pack_start(row, False, False, 0)
        return card

    def tasks_widget_card(self, payload: dict):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("widget")
        notes = sorted(seven_notes(), key=lambda item: int(item.get("updated") or 0), reverse=True)
        tasks = []
        for item in notes:
            text = " ".join([str(item.get("title") or ""), str(item.get("body") or "")]).strip()
            if text.lower().startswith(("todo", "à faire", "a faire", "- [ ]")) or "#task" in text.lower():
                tasks.append(text.replace("#task", "").strip())
        title_label = Gtk.Label(label=f"{widget_icon('tasks')}  {tr('Tâches', 'Tasks')}", xalign=0)
        title_label.get_style_context().add_class("subtitle")
        value_label = Gtk.Label(label=str(len(tasks)) if tasks else tr("Prêt", "Ready"), xalign=0)
        value_label.get_style_context().add_class("value")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        for task in tasks[:3]:
            chip = Gtk.Label(label=task[:54], xalign=0)
            chip.get_style_context().add_class("note-chip")
            card.pack_start(chip, False, False, 0)
        entry = Gtk.Entry()
        entry.set_placeholder_text(tr("Nouvelle tâche…", "New task…"))
        save = Gtk.Button(label=tr("Ajouter", "Add"))
        save.get_style_context().add_class("compact")

        def submit(*_args):
            text = entry.get_text().strip()
            if text:
                add_widget_note(f"#task {text}")
                entry.set_text("")
                self.render()

        entry.connect("activate", submit)
        save.connect("clicked", submit)
        card.pack_start(entry, False, False, 0)
        card.pack_start(save, False, False, 0)
        return card


def set_widget(key: str, enabled: bool) -> dict:
    data = config()
    current = [item for item in data.get("enabled", []) if item in catalog_keys()]
    previous = list(current)
    if enabled and key not in current:
        current.append(key)
    if not enabled:
        current = [item for item in current if item != key]
    if current != previous:
        backup_config(data)
    data["enabled"] = current
    if current != previous:
        verb = ("Widget ajouté", "Widget added") if enabled else ("Widget retiré", "Widget removed")
        mark_action(data, f"{verb[0]} : {widget_title(key)}.", f"{verb[1]}: {widget_title(key)}.")
    save_config(data)
    return data


def move_widget(key: str, direction: str) -> dict:
    data = config()
    current = [item for item in data.get("enabled", []) if item in catalog_keys()]
    if key not in current:
        return data
    index = current.index(key)
    target = index - 1 if direction == "up" else index + 1
    if target < 0 or target >= len(current):
        return data
    backup_config(data)
    current[index], current[target] = current[target], current[index]
    data["enabled"] = current
    data["last_preset"] = "custom"
    mark_action(data, f"{widget_title(key)} déplacé.", f"{widget_title(key)} moved.")
    save_config(data)
    return data


def apply_preset(name: str) -> dict:
    data = config()
    backup_config(data)
    preset_name = name.strip().lower() or "equinox"
    if preset_name == "active":
        preset_name = current_profile()
    data["enabled"] = preset_widgets(preset_name)
    data["last_preset"] = preset_name
    data["layout"] = "calm-grid"
    mark_action(data, f"Preset {preset_name.title()} appliqué.", f"{preset_name.title()} preset applied.")
    save_config(data)
    return data


def merge_preset(name: str) -> dict:
    data = config()
    backup_config(data)
    preset_name = name.strip().lower() or "equinox"
    if preset_name == "active":
        preset_name = current_profile()
    current = [item for item in data.get("enabled", []) if item in catalog_keys()]
    for item in preset_widgets(preset_name):
        if item not in current:
            current.append(item)
    data["enabled"] = current
    data["last_preset"] = f"{preset_name}-merged"
    mark_action(data, f"Recommandations {preset_name.title()} ajoutées.", f"{preset_name.title()} recommendations added.")
    save_config(data)
    return data


def set_layout(name: str) -> dict:
    data = config()
    if layout_key(str(data.get("layout"))) != layout_key(name):
        backup_config(data)
    data["layout"] = layout_key(name)
    mark_action(data, f"Disposition {layout_title(name)} activée.", f"{layout_title(name)} layout enabled.")
    save_config(data)
    return data


def reset_widgets() -> dict:
    data = config()
    backup_config(data)
    data["enabled"] = list(DEFAULT_WIDGETS)
    data["last_preset"] = "default"
    mark_action(data, "Widgets réinitialisés.", "Widgets reset.")
    save_config(data)
    return data


def set_right_click(enabled: bool) -> dict:
    data = config()
    data["desktop_right_click"] = bool(enabled)
    mark_action(data, "Menu clic droit mis à jour.", "Right-click menu updated.")
    save_config(data)
    return data


def set_home_workspace(workspace: str) -> dict:
    data = config()
    data["home_workspace"] = str(workspace or HOME_WORKSPACE)
    mark_action(data, f"Workspace d’accueil réglé sur {data['home_workspace']}.", f"Home workspace set to {data['home_workspace']}.")
    save_config(data)
    return data


def set_weather_location(location: str) -> dict:
    data = config()
    location = location.strip()
    data["weather"] = {
        "enabled": bool(location),
        "location": location,
        "summary": tr("Météo locale configurée.", "Local weather configured.") if location else "",
    }
    if location:
        current = [item for item in data.get("enabled", []) if item in catalog_keys()]
        if "weather" not in current:
            current.append("weather")
        data["enabled"] = current
    mark_action(data, "Météo locale mise à jour.", "Local weather updated.")
    save_config(data)
    return data


def launch_native(mode: str) -> None:
    subprocess.Popen([str(ROOT / "bin/seven-widgets-native"), mode])


def show_widgets() -> None:
    data = config()
    data["visible"] = True
    save_config(data)
    close_desktop_widgets()
    switch_home_workspace()
    subprocess.Popen([str(ROOT / "bin/seven-widgets-native"), "desktop"])


def close_desktop_widgets() -> None:
    subprocess.run(["pkill", "-f", "[s]even-widgets-native desktop"], check=False)
    if shutil.which("hyprctl"):
        subprocess.run(["hyprctl", "dispatch", "closewindow", "title:^(Seven Widgets Desktop)$"], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def hide_widgets() -> None:
    data = config()
    data["visible"] = False
    save_config(data)
    close_desktop_widgets()


def toggle_widgets() -> None:
    if bool(config().get("visible", False)):
        hide_widgets()
    else:
        show_widgets()


def doctor() -> dict:
    data = config()
    keys = catalog_keys()
    invalid = [item for item in data.get("enabled", []) if item not in keys]
    return {
        "schema": "sevenos.widgets.doctor.v1",
        "state": "ready" if not invalid else "needs-attention",
        "score": 100 if not invalid else 82,
        "config": str(CONFIG_FILE),
        "backup": str(BACKUP_FILE),
        "backup_available": BACKUP_FILE.exists(),
        "catalog": len(CATALOG),
        "categories": [category for category, _fr, _en in WIDGET_CATEGORIES],
        "presets": sorted(PRESETS.keys()),
        "layouts": sorted(LAYOUTS.keys()),
        "layout": layout_key(str(data.get("layout"))),
        "last_preset": data.get("last_preset", ""),
        "enabled": data.get("enabled", []),
        "invalid": invalid,
        "commands": {
            "menu": "seven widgets menu",
            "add": "seven widgets add clock",
            "move": "seven widgets move notes up",
            "settings": "seven widgets settings",
            "open": "seven widgets open",
            "hide": "seven widgets hide",
            "toggle": "seven widgets toggle",
            "home": "seven widgets home 1",
            "preset": "seven widgets preset active",
            "merge": "seven widgets merge active",
            "restore": "seven widgets restore",
            "layout": "seven widgets layout calm-grid",
            "reset": "seven widgets reset",
        },
    }


def main() -> int:
    action = sys.argv[1] if len(sys.argv) > 1 else "menu"
    if "--probe" in sys.argv:
        print("OK")
        return 0
    if action in {"json", "status"} or "--json" in sys.argv and action not in {"doctor", "catalog"}:
        print(json.dumps(widget_payload(), ensure_ascii=False, indent=2))
        return 0
    if action == "catalog":
        print(json.dumps({"schema": "sevenos.widgets.catalog.v1", "catalog": CATALOG, "presets": PRESETS, "layouts": LAYOUTS}, ensure_ascii=False, indent=2))
        return 0
    if action == "doctor":
        print(json.dumps(doctor(), ensure_ascii=False, indent=2))
        return 0
    if action == "add" and len(sys.argv) > 2:
        print(json.dumps(set_widget(sys.argv[2], True), ensure_ascii=False, indent=2))
        return 0
    if action == "move" and len(sys.argv) > 3:
        print(json.dumps(move_widget(sys.argv[2], sys.argv[3]), ensure_ascii=False, indent=2))
        return 0
    if action in {"remove", "rm"} and len(sys.argv) > 2:
        print(json.dumps(set_widget(sys.argv[2], False), ensure_ascii=False, indent=2))
        return 0
    if action == "home" and len(sys.argv) > 2:
        print(json.dumps(set_home_workspace(sys.argv[2]), ensure_ascii=False, indent=2))
        return 0
    if action == "weather" and len(sys.argv) > 2:
        print(json.dumps(set_weather_location(" ".join(sys.argv[2:])), ensure_ascii=False, indent=2))
        return 0
    if action == "preset" and len(sys.argv) > 2:
        print(json.dumps(apply_preset(sys.argv[2]), ensure_ascii=False, indent=2))
        return 0
    if action in {"merge", "complete", "recommend"} and len(sys.argv) > 2:
        print(json.dumps(merge_preset(sys.argv[2]), ensure_ascii=False, indent=2))
        return 0
    if action in {"restore", "undo"}:
        print(json.dumps(restore_previous_config(), ensure_ascii=False, indent=2))
        return 0
    if action == "layout" and len(sys.argv) > 2:
        print(json.dumps(set_layout(sys.argv[2]), ensure_ascii=False, indent=2))
        return 0
    if action == "reset":
        print(json.dumps(reset_widgets(), ensure_ascii=False, indent=2))
        return 0
    if action == "right-click" and len(sys.argv) > 2:
        print(json.dumps(set_right_click(sys.argv[2].lower() in {"1", "on", "true", "yes", "enable", "enabled"}), ensure_ascii=False, indent=2))
        return 0
    if action in {"open", "show"}:
        show_widgets()
        return 0
    if action == "hide":
        hide_widgets()
        return 0
    if action == "toggle":
        toggle_widgets()
        return 0
    if action in {"desktop-menu", "right-click"}:
        if not config().get("desktop_right_click", True) or active_window_present():
            return 0
    mode = "settings" if action in {"settings", "config"} else "desktop" if action == "desktop" else "menu"
    win = WidgetsWindow(mode)
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
