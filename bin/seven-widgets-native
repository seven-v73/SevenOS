            button.connect("clicked", lambda _b, layout=key: (set_layout(layout), self.render()))
            layout_grid.attach(button, index, 0, 1, 1)
        layout_note = Gtk.Label(
            label=tr(
                "Calme pour l’usage quotidien, Compacte pour voir plus, Focus pour un accueil vertical.",
                "Calm for daily use, Compact for more cards, Focus for a vertical home.",
            ),
            xalign=0,
        )
        layout_note.get_style_context().add_class("subtitle")
        layout_grid.attach(layout_note, 0, 1, 3, 1)
        self.root.pack_start(layout_grid, False, False, 0)

        self.section_label(tr("Comportement", "Behavior"))
        menu_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        menu_row.get_style_context().add_class("widget-row")
        menu_labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        menu_labels.pack_start(Gtk.Label(label=tr("Menu au clic droit", "Right-click menu"), xalign=0), False, False, 0)
        menu_note = Gtk.Label(
            label=tr(
                "Ouvre Ajouter un widget depuis le bureau, avec garde-fou si une app est active.",
                "Open Add widget from the desktop, guarded when an app is active.",
            ),
            xalign=0,
        )
        menu_note.get_style_context().add_class("subtitle")
        menu_labels.pack_start(menu_note, False, False, 0)
        menu_row.pack_start(menu_labels, True, True, 0)
        menu_switch = Gtk.Switch()
        menu_switch.set_active(bool(state.get("desktop_right_click", False)))
        menu_switch.connect("notify::active", lambda sw, _p: set_right_click(sw.get_active()))
        menu_row.pack_start(menu_switch, False, False, 0)
        self.root.pack_start(menu_row, False, False, 0)
        home_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        home_row.get_style_context().add_class("widget-row")
        home_labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        home_labels.pack_start(Gtk.Label(label=tr("Workspace d’accueil", "Home workspace"), xalign=0), False, False, 0)
        home_note = Gtk.Label(
            label=tr(
                "Les widgets s’ouvrent uniquement sur cet espace. 1 est recommandé.",
                "Widgets open only on this workspace. 1 is recommended.",
            ),
            xalign=0,
        )
        home_note.get_style_context().add_class("subtitle")
        home_labels.pack_start(home_note, False, False, 0)
        home_row.pack_start(home_labels, True, True, 0)
        home_combo = Gtk.ComboBoxText()
        for number in range(1, 8):
            home_combo.append(str(number), str(number))
        home_combo.set_active_id(str(state.get("home_workspace") or HOME_WORKSPACE))
        home_combo.connect("changed", lambda combo: set_home_workspace(combo.get_active_id() or HOME_WORKSPACE))
        home_row.pack_start(home_combo, False, False, 0)
        self.root.pack_start(home_row, False, False, 0)
        weather_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        weather_row.get_style_context().add_class("widget-row")
        weather_labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        weather_labels.pack_start(Gtk.Label(label=tr("Météo locale", "Local weather"), xalign=0), False, False, 0)
        weather_note = Gtk.Label(
            label=tr(
                "Carte opt-in : SevenOS n’appelle aucun service météo sans ville configurée.",
                "Opt-in card: SevenOS does not call weather services without a configured city.",
            ),
            xalign=0,
        )
        weather_note.get_style_context().add_class("subtitle")
        weather_labels.pack_start(weather_note, False, False, 0)
        weather_entry = Gtk.Entry()
        weather_entry.set_placeholder_text(tr("Ville ou zone", "City or area"))
        weather_entry.set_text(str((state.get("weather") or {}).get("location") or ""))
        weather_save = Gtk.Button(label=tr("Enregistrer", "Save"))
        weather_save.connect("clicked", lambda *_: set_weather_location(weather_entry.get_text()))
        weather_row.pack_start(weather_labels, True, True, 0)
        weather_row.pack_start(weather_entry, False, False, 0)
        weather_row.pack_start(weather_save, False, False, 0)
        self.root.pack_start(weather_row, False, False, 0)

        ordered_enabled = [key for key in state.get("enabled", []) if key in catalog_keys()]
        self.section_label(tr("Ordre de l’accueil", "Home order"))
        if ordered_enabled:
            for index, key in enumerate(ordered_enabled):
                row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
                row.get_style_context().add_class("widget-row")
                order_label = Gtk.Label(label=str(index + 1), xalign=0.5)
                order_label.get_style_context().add_class("order-index")
                icon = Gtk.Label(label=widget_icon(key), xalign=0.5)
                icon.get_style_context().add_class("widget-icon")
                labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
                labels.pack_start(Gtk.Label(label=widget_title(key), xalign=0), False, False, 0)
                note = Gtk.Label(
                    label=tr("Position sur l’écran d’accueil.", "Position on the home screen."),
                    xalign=0,
                )
                note.get_style_context().add_class("subtitle")
                labels.pack_start(note, False, False, 0)
                up = Gtk.Button(label="↑")
                up.get_style_context().add_class("compact")
                down = Gtk.Button(label="↓")
                down.get_style_context().add_class("compact")
                remove = Gtk.Button(label=tr("Retirer", "Remove"))
                remove.get_style_context().add_class("compact")
                up.set_sensitive(index > 0)
                down.set_sensitive(index < len(ordered_enabled) - 1)
                up.set_tooltip_text(tr("Monter ce widget", "Move this widget up"))
                down.set_tooltip_text(tr("Descendre ce widget", "Move this widget down"))
                remove.set_tooltip_text(tr("Retirer ce widget de l’accueil", "Remove this widget from Home"))
                up.connect("clicked", lambda _b, selected=key: (move_widget(selected, "up"), self.render()))
                down.connect("clicked", lambda _b, selected=key: (move_widget(selected, "down"), self.render()))
                remove.connect("clicked", lambda _b, selected=key: (set_widget(selected, False), self.render()))
                row.pack_start(order_label, False, False, 0)
                row.pack_start(icon, False, False, 0)
                row.pack_start(labels, True, True, 0)
                row.pack_start(up, False, False, 0)
                row.pack_start(down, False, False, 0)
                row.pack_start(remove, False, False, 0)
                self.root.pack_start(row, False, False, 0)
        else:
            row = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
            row.get_style_context().add_class("widget-row")
            row.pack_start(Gtk.Label(label=tr("Aucun widget actif", "No active widgets"), xalign=0), False, False, 0)
            note = Gtk.Label(
                label=tr("Applique un preset ou active des widgets ci-dessous.", "Apply a preset or enable widgets below."),
                xalign=0,
            )
            note.get_style_context().add_class("subtitle")
            row.pack_start(note, False, False, 0)
            self.root.pack_start(row, False, False, 0)

        self.section_label(tr("Widgets disponibles", "Available widgets"))
        search_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        search_row.get_style_context().add_class("search-row")
        search_icon = Gtk.Label(label="⌕", xalign=0.5)
        search_icon.get_style_context().add_class("micro")
        search = Gtk.SearchEntry()
        search.set_placeholder_text(tr("Rechercher un widget, une catégorie ou un usage…", "Search a widget, category or use…"))
        search.set_text(self.settings_query)
        search_row.pack_start(search_icon, False, False, 0)
        search_row.pack_start(search, True, True, 0)
        self.root.pack_start(search_row, False, False, 0)

        visible_groups: list[tuple[Gtk.Box, Gtk.Label, list[tuple[Gtk.Box, dict]]]] = []
        for category, _fr, _en in WIDGET_CATEGORIES:
            items = [item for item in CATALOG if item.get("category") == category]
            if not items:
                continue
            active_count = sum(1 for item in items if item["key"] in enabled)
            category_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            title = Gtk.Label(label=widget_category_title(category).upper(), xalign=0)
            title.get_style_context().add_class("category-title")
            count = Gtk.Label(label=f"{active_count}/{len(items)}", xalign=0.5)
            count.get_style_context().add_class("category-count")
            category_row.pack_start(title, True, True, 0)
            category_row.pack_start(count, False, False, 0)
            self.root.pack_start(category_row, False, False, 0)
            group_rows: list[tuple[Gtk.Box, dict]] = []
            for item in items:
                row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                row.get_style_context().add_class("widget-row")
                icon = Gtk.Label(label=widget_icon(item["key"]), xalign=0.5)
                icon.get_style_context().add_class("widget-icon")
                row.pack_start(icon, False, False, 0)
                labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
                title_text = item["title"] if lang_is_fr() else item["title_en"]
                note = item["note"] if lang_is_fr() else item["note_en"]
                labels.pack_start(Gtk.Label(label=title_text, xalign=0), False, False, 0)
                note_label = Gtk.Label(label=note, xalign=0)
                note_label.get_style_context().add_class("subtitle")
                labels.pack_start(note_label, False, False, 0)
                row.pack_start(labels, True, True, 0)
                switch = Gtk.Switch()
                switch.set_active(item["key"] in enabled)
                switch.connect("notify::active", lambda sw, _p, key=item["key"]: (set_widget(key, sw.get_active()), self.render()))
                row.pack_start(switch, False, False, 0)
                self.root.pack_start(row, False, False, 0)
                group_rows.append((row, item))
            visible_groups.append((category_row, count, group_rows))
        empty_filter = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        empty_filter.get_style_context().add_class("empty-state")
        empty_filter.pack_start(Gtk.Label(label=tr("Aucun widget trouvé", "No widget found"), xalign=0), False, False, 0)
        empty_note = Gtk.Label(
            label=tr("Essaie un autre mot, une catégorie ou un usage.", "Try another word, category or use."),
            xalign=0,
        )
        empty_note.get_style_context().add_class("subtitle")
        empty_filter.pack_start(empty_note, False, False, 0)
        self.root.pack_start(empty_filter, False, False, 0)

        def update_filter(*_args):
            query = search.get_text().strip().casefold()
            self.settings_query = query
            any_visible = False
            for category_row, count_label, rows in visible_groups:
                visible_in_group = 0
                for row, item in rows:
                    matched = not query or query in widget_search_text(item)
                    row.set_visible(matched)
                    visible_in_group += 1 if matched else 0
                category_row.set_visible(visible_in_group > 0)
                count_label.set_text(f"{sum(1 for _row, item in rows if item['key'] in enabled and (not query or query in widget_search_text(item)))}/{visible_in_group or len(rows)}")
                any_visible = any_visible or visible_in_group > 0
            empty_filter.set_visible(not any_visible)
            return False

        search.connect("search-changed", update_filter)
        search.connect("activate", update_filter)
        GLib.idle_add(update_filter)
        footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        show = Gtk.Button(label=tr("Afficher", "Show"))
        show.connect("clicked", lambda *_: show_widgets())
        restore = Gtk.Button(label=tr("Restaurer", "Restore"))
        restore.set_tooltip_text(tr("Revenir à la configuration widgets précédente.", "Return to the previous widget configuration."))
        restore.set_sensitive(BACKUP_FILE.exists())
        restore.connect("clicked", lambda *_: (restore_previous_config(), self.render()))
        reset = Gtk.Button(label=tr("Réinitialiser", "Reset"))
        reset.connect("clicked", lambda *_: (reset_widgets(), self.render()))
        close = Gtk.Button(label=tr("Fermer", "Close"))
        close.connect("clicked", lambda *_: Gtk.main_quit())
        footer.pack_start(show, True, True, 0)
        footer.pack_start(restore, True, True, 0)
        footer.pack_start(reset, True, True, 0)
        footer.pack_start(close, True, True, 0)
        self.root.pack_end(footer, False, False, 0)

    def render_desktop(self):
        payload = widget_payload()
        state = payload["config"]
        layout_name = layout_key(str(state.get("layout")))
        layout = LAYOUTS[layout_name]
        columns = int(layout.get("columns") or 2)
        enabled = [key for key in state.get("enabled", []) if key in catalog_keys()]
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        header.get_style_context().add_class("home-header")
        labels = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        title = Gtk.Label(label=tr("Accueil SevenOS", "SevenOS Home"), xalign=0)
        title.get_style_context().add_class("title")
        updated = time.strftime("%H:%M", time.localtime(payload["runtime"].get("updated", time.time())))
        subtitle = Gtk.Label(
            label=tr(
                f"{layout_title(layout_name)} · Workspace {state.get('home_workspace', HOME_WORKSPACE)} · {payload['profile'].title()} · mis à jour {updated}",
                f"{layout_title(layout_name)} · Workspace {state.get('home_workspace', HOME_WORKSPACE)} · {payload['profile'].title()} · updated {updated}",
            ),
            xalign=0,
        )
        subtitle.get_style_context().add_class("micro")
        labels.pack_start(title, False, False, 0)
        labels.pack_start(subtitle, False, False, 0)
        header.pack_start(labels, True, True, 0)
        settings = Gtk.Button(label=tr("Ajuster", "Adjust"))
        settings.get_style_context().add_class("compact")
        settings.connect("clicked", lambda *_: launch_native("settings"))
        hide = Gtk.Button(label=tr("Masquer", "Hide"))
        hide.get_style_context().add_class("compact")
        hide.connect("clicked", lambda *_: hide_widgets())
        header.pack_start(settings, False, False, 0)
        header.pack_start(hide, False, False, 0)
        self.root.pack_start(header, False, False, 0)
        spacing = 10 if layout_name == "compact-grid" else 12
        grid = Gtk.Grid(column_spacing=spacing, row_spacing=spacing)
        grid.set_column_homogeneous(columns > 1)
        if not enabled:
            empty = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
            empty.get_style_context().add_class("empty-state")
            empty_title = Gtk.Label(label=tr("Aucun widget actif", "No active widgets"), xalign=0)
            empty_title.get_style_context().add_class("value")
            empty_note = Gtk.Label(
                label=tr("Ajoute un preset ou choisis tes widgets pour personnaliser l’accueil.", "Add a preset or choose widgets to personalize Home."),
                xalign=0,
            )
            empty_note.get_style_context().add_class("subtitle")
            preset = Gtk.Button(label=tr("Appliquer le preset actif", "Apply active preset"))
            preset.connect("clicked", lambda *_: (apply_preset("active"), self.render(), show_widgets()))
            empty.pack_start(empty_title, False, False, 0)
            empty.pack_start(empty_note, False, False, 0)
            empty.pack_start(preset, False, False, 0)
            self.root.pack_start(empty, True, True, 0)
            return
        for index, key in enumerate(enabled):
            card = self.widget_card(key, payload)
            if layout_name == "compact-grid":
                card.get_style_context().add_class("compact")
            if layout_name == "focus-stack":
                card.get_style_context().add_class("focus")
            grid.attach(card, index % columns, index // columns, 1, 1)
        self.root.pack_start(grid, True, True, 0)

    def widget_card(self, key: str, payload: dict):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("widget")
        runtime = payload["runtime"]
        profile = payload["profile"]
        if key == "notes":
            return self.notes_widget_card(payload)
        if key == "tasks":
            return self.tasks_widget_card(payload)
        if key == "mini-os":
            return self.mini_os_widget_card(payload)
        if key == "quick":
            return self.quick_widget_card(payload)
        title, value, note, fraction, action = {
            "clock": (tr("Horloge", "Clock"), time.strftime("%H:%M"), time.strftime("%A %d %B"), None, None),
            "system": (tr("Système", "System"), f"CPU {runtime['cpu']}%", f"RAM {runtime['memory']}% · Disk {runtime['disk']}%", runtime["cpu"] / 100, ["seven", "doctor"]),
            "battery": (
                tr("Énergie", "Power"),
                f"{runtime['battery']['percent']}%" if runtime["battery"].get("percent") is not None else runtime["battery"].get("status", "AC"),
                f"{runtime['battery'].get('status', '')} · {runtime['battery'].get('profile', 'balanced')}",
                (runtime["battery"].get("percent") or 0) / 100 if runtime["battery"].get("percent") is not None else None,
                ["seven-settings", "power"],
            ),
            "storage": (
                tr("Stockage", "Storage"),
                runtime["disk_summary"].get("free", "?"),
                tr("disponible · {used} utilisé", "free · {used} used").format(used=runtime["disk_summary"].get("used", "?")),
                runtime["disk_summary"].get("percent", 0) / 100,
                ["seven-files"],
            ),
            "doctor": ("Seven Doctor", str(runtime["doctor"]["decision"]), f"{runtime['doctor']['issues']} issue(s)", None, ["seven", "doctor"]),
            "prism": ("Prism", profile.title(), tr("Mini OS actif", "Active Mini OS"), None, ["seven-settings", "prism"]),
            "calendar": (
                tr("Calendrier", "Calendar"),
                f"{runtime['calendar']['day']}/{runtime['calendar']['days']}",
                tr("Semaine {week} · {month}", "Week {week} · {month}").format(week=runtime["calendar"]["week"], month=runtime["calendar"]["month"]),
                runtime["calendar"]["fraction"],
                ["seven-settings", "general"],
            ),
            "media": (
                tr("Média", "Media"),
                runtime["media"].get("title", ""),
                f"{runtime['media'].get('state', '')} · {runtime['media'].get('artist', '')}".strip(" ·"),
                None,
                ["playerctl", "play-pause"] if shutil.which("playerctl") else None,
            ),
            "network": (tr("Réseau", "Network"), runtime["network"], tr("Wi-Fi et connexions", "Wi-Fi and connections"), None, ["seven-wifi"]),
            "weather": (
                tr("Météo", "Weather"),
                runtime["weather"].get("location", ""),
                runtime["weather"].get("summary", ""),
                None,
                ["seven", "widgets", "settings"],
            ),
        }.get(key, (key, "", "", None, None))
        title_label = Gtk.Label(label=f"{widget_icon(key)}  {title}", xalign=0)
        title_label.get_style_context().add_class("subtitle")
        value_label = Gtk.Label(label=str(value), xalign=0)
        value_label.get_style_context().add_class("value")
        note_label = Gtk.Label(label=str(note), xalign=0)
        note_label.get_style_context().add_class("subtitle")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        if fraction is not None:
            progress = Gtk.ProgressBar()
            progress.set_fraction(max(0, min(1, float(fraction))))
            card.pack_start(progress, False, False, 0)
        card.pack_start(note_label, False, False, 0)
        if action:
            button = Gtk.Button(label=tr("Ouvrir", "Open"))
            button.get_style_context().add_class("compact")
            button.connect("clicked", lambda *_a, command=action: subprocess.Popen(command))
            card.pack_start(button, False, False, 0)
        return card

    def mini_os_widget_card(self, payload: dict):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("widget")
        profile = payload["profile"]
        title_label = Gtk.Label(label=f"{widget_icon('mini-os')}  {tr('Mini OS', 'Mini OS')}", xalign=0)
        title_label.get_style_context().add_class("subtitle")
        value_label = Gtk.Label(label=profile.title(), xalign=0)
        value_label.get_style_context().add_class("value")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        for label, command in (
            ("EQ", ["seven", "profile", "activate", "equinox"]),
            ("FG", ["seven", "profile", "activate", "forge"]),
            ("ST", ["seven", "profile", "activate", "studio"]),
            ("PL", ["seven", "profile", "activate", "pulse"]),
        ):
            button = Gtk.Button(label=label)
            button.get_style_context().add_class("compact")
            button.connect("clicked", lambda *_a, cmd=command: subprocess.Popen(cmd))
            row.pack_start(button, True, True, 0)
        card.pack_start(row, False, False, 0)
        open_settings = Gtk.Button(label=tr("Tous les espaces", "All spaces"))
        open_settings.get_style_context().add_class("compact")
        open_settings.connect("clicked", lambda *_a: subprocess.Popen(["seven-settings", "profiles"]))
        card.pack_start(open_settings, False, False, 0)
        return card

    def quick_widget_card(self, payload: dict):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("widget")
        title_label = Gtk.Label(label=f"{widget_icon('quick')}  {tr('Actions', 'Actions')}", xalign=0)
        title_label.get_style_context().add_class("subtitle")
        value_label = Gtk.Label(label="SevenOS", xalign=0)
        value_label.get_style_context().add_class("value")
        card.pack_start(title_label, False, False, 0)
        card.pack_start(value_label, False, False, 0)
        for label, command in (
            (tr("Réglages", "Settings"), ["seven-settings", "general"]),
            ("Doctor", ["seven", "doctor", "open"]),
            ("Store", ["seven", "store"]),
            (tr("Fichiers", "Files"), ["seven-files"]),
        ):
            button = Gtk.Button(label=label)
            button.get_style_context().add_class("compact")
