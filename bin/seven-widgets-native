        self.root.pack_start(presets, False, False, 0)

        self.section_label(tr("Disposition", "Layout"))
        layout_grid = Gtk.Grid(column_spacing=8, row_spacing=8)
        layout_grid.get_style_context().add_class("preset-strip")
        active_layout = layout_key(str(state.get("layout")))
        for index, key in enumerate(("calm-grid", "compact-grid", "focus-stack")):
            item = LAYOUTS[key]
            button_label = item["title"] if lang_is_fr() else item["title_en"]
            button = Gtk.Button(label=button_label)
            button.get_style_context().add_class("preset-button")
            if key == active_layout:
                button.get_style_context().add_class("layout-active")
