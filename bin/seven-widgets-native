  background: alpha(@seven_border, 0.68);
}
progressbar progress {
  min-height: 7px;
  border-radius: 999px;
  background: @seven_accent;
}
"""


def install_css() -> None:
    mode = seven_theme.current_theme_mode() if seven_theme else os.environ.get("SEVENOS_THEME_MODE", "dark")
    base = (
        seven_theme.gtk_app_css("widgets", mode)
        + seven_theme.surface_css("widgets", mode=mode)
        if seven_theme
        else ""
    )
    provider = Gtk.CssProvider()
    provider.load_from_data((base + CSS).encode())
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)


class WidgetsWindow(Gtk.Window):
    def __init__(self, mode: str):
        title = {
            "desktop": "Seven Widgets Desktop",
            "settings": "Seven Widgets",
            "menu": "Seven Desktop Menu",
        }.get(mode, "Seven Widgets")
        super().__init__(title=title)
        self.mode = mode
        self.settings_query = ""
        self.set_position(Gtk.WindowPosition.CENTER)
        layout = LAYOUTS[layout_key(config().get("layout"))]
        if mode == "menu":
            self.set_default_size(380, 420)
        elif mode == "desktop":
            self.set_default_size(int(layout["width"]), int(layout["height"]))
        else:
            self.set_default_size(780, 620)
        self.set_keep_above(False)
        self.set_skip_taskbar_hint(mode == "desktop")
        self.set_decorated(mode != "desktop")
        install_css()
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        root.get_style_context().add_class("root")
        root.get_style_context().add_class("desktop-root" if mode == "desktop" else "settings-root")
        self.add(root)
        self.root = root
        self.render()
        if mode == "desktop":
            GLib.timeout_add_seconds(20, self.refresh)

    def refresh(self):
        self.render()
        self.show_all()
        return self.mode == "desktop"

    def render(self):
        for child in list(self.root.get_children()):
            self.root.remove(child)
        if self.mode == "menu":
            self.render_menu()
        elif self.mode == "settings":
            self.render_settings()
        else:
            self.render_desktop()

    def render_header(self, title: str, note: str):
        header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        label = Gtk.Label(label=title, xalign=0)
        label.get_style_context().add_class("title")
        sub = Gtk.Label(label=note, xalign=0)
        sub.get_style_context().add_class("subtitle")
        header.pack_start(label, False, False, 0)
        header.pack_start(sub, False, False, 0)
        self.root.pack_start(header, False, False, 0)

    def section_label(self, text: str):
        label = Gtk.Label(label=text.upper(), xalign=0)
        label.get_style_context().add_class("section-title")
        self.root.pack_start(label, False, False, 0)

    def render_menu(self):
        data = config()
        enabled = [item for item in data.get("enabled", []) if item in catalog_keys()]
        visible = bool(data.get("visible"))
        profile = current_profile()
        self.render_header(
            tr("Accueil SevenOS", "SevenOS Home"),
            tr("Widgets, presets et actions du bureau.", "Widgets, presets and desktop actions."),
        )

        state = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        state.get_style_context().add_class("menu-state")
        status = tr("Visible", "Visible") if visible else tr("Masqué", "Hidden")
        status_label = Gtk.Label(
            label=tr(
                f"{status} · {len(enabled)}/{len(CATALOG)} widgets · {layout_title(str(data.get('layout')))}",
                f"{status} · {len(enabled)}/{len(CATALOG)} widgets · {layout_title(str(data.get('layout')))}",
            ),
            xalign=0,
        )
        status_label.get_style_context().add_class("value")
        note = Gtk.Label(
            label=tr(
                f"Workspace {data.get('home_workspace', HOME_WORKSPACE)} · Mini OS {profile.title()}",
                f"Workspace {data.get('home_workspace', HOME_WORKSPACE)} · Mini OS {profile.title()}",
            ),
            xalign=0,
        )
        note.get_style_context().add_class("subtitle")
        state.pack_start(status_label, False, False, 0)
        state.pack_start(note, False, False, 0)
        self.root.pack_start(state, False, False, 0)

        primary = Gtk.Grid(column_spacing=8, row_spacing=8)
        primary.get_style_context().add_class("menu-grid")
        primary_actions = [
            (tr("Afficher", "Show") if not visible else tr("Masquer", "Hide"), toggle_widgets),
            (tr("Ajouter", "Add"), lambda: launch_native("settings")),
            (tr("Preset actif", "Active preset"), lambda: (apply_preset("active"), show_widgets())),
            (tr("Notes", "Notes"), lambda: subprocess.Popen(["seven-notes"])),
        ]
        for index, (label, callback) in enumerate(primary_actions):
            button = Gtk.Button(label=label)
            button.get_style_context().add_class("preset-button")
            if index == 0:
                button.get_style_context().add_class("primary-action")
            button.connect("clicked", lambda _b, cb=callback: (cb(), Gtk.main_quit()))
            primary.attach(button, index % 2, index // 2, 1, 1)
        self.root.pack_start(primary, False, False, 0)

        layout_row = Gtk.Grid(column_spacing=8, row_spacing=8)
        layout_row.get_style_context().add_class("menu-grid")
        for index, key in enumerate(("calm-grid", "compact-grid", "focus-stack")):
            button = Gtk.Button(label=layout_title(key))
            button.get_style_context().add_class("preset-button")
            if layout_key(str(data.get("layout"))) == key:
                button.get_style_context().add_class("layout-active")
            button.connect("clicked", lambda _b, layout=key: (set_layout(layout), show_widgets(), Gtk.main_quit()))
            layout_row.attach(button, index, 0, 1, 1)
        self.root.pack_start(layout_row, False, False, 0)

        actions = [
            (tr("Fond d’écran", "Wallpaper"), lambda: subprocess.Popen(["seven-settings", "wallpaper"])),
            (tr("Réglages widgets", "Widget settings"), lambda: launch_native("settings")),
            (tr("Réglages SevenOS", "SevenOS Settings"), lambda: subprocess.Popen(["seven-settings", "general"])),
        ]
        for label, callback in actions:
            button = Gtk.Button(label=label)
            button.connect("clicked", lambda _b, cb=callback: (cb(), Gtk.main_quit()))
            self.root.pack_start(button, False, False, 0)

    def render_settings(self):
        self.render_header(tr("Widgets SevenOS", "SevenOS Widgets"), tr("Choisis ce qui reste visible sur l’écran d’accueil.", "Choose what stays visible on the home screen."))
