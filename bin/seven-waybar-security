#!/usr/bin/env bash
set -Eeuo pipefail

mode="${1:-text}"
firewall="MISS"
if systemctl is-active --quiet ufw.service 2>/dev/null; then
  firewall="OK"
fi

lab="MISS"
if command -v firejail >/dev/null 2>&1; then
  lab="OK"
fi

if [[ "$mode" == "json" ]]; then
  if [[ "$firewall" == "OK" && "$lab" == "OK" ]]; then
    printf '{"text":"󰒃","tooltip":"Shield: protected\\nFirewall: OK\\nSandbox: OK\\nClick opens Shield center.","class":"ok"}\n'
  elif [[ "$firewall" == "OK" || "$lab" == "OK" ]]; then
    printf '{"text":"󰒃","tooltip":"Shield: partial\\nFirewall: %s\\nSandbox: %s\\nClick opens Shield center.","class":"warn"}\n' "$firewall" "$lab"
  else
    printf '{"text":"󰒃","tooltip":"Shield: exposed\\nFirewall: MISS\\nSandbox: MISS\\nClick opens Shield center.","class":"miss"}\n'
  fi
else
  printf 'Shield %s Lab %s\n' "$firewall" "$lab"
fi
