#!/usr/bin/env python3
import argparse
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path


ROOT = Path(os.environ.get("SEVENOS_ROOT", Path(__file__).resolve().parent.parent)).resolve()
CATALOG = ROOT / "profiles/catalog.json"
PROFILES = ("forge", "studio", "baobab", "shield", "atlas", "pulse")


def host_home() -> Path:
    if os.environ.get("SEVENOS_HOST_HOME"):
        return Path(os.environ["SEVENOS_HOST_HOME"])
    raw = Path(os.environ.get("HOME", str(Path.home())))
    marker = "/.local/share/sevenos/profile-containers/"
    text = str(raw)
    if marker in text and text.endswith("/home"):
        return Path(text.split(marker, 1)[0])
    user = os.environ.get("USER")
    if user:
        candidate = Path("/home") / user
        if candidate.is_dir():
            return candidate
    return raw


HOST_HOME = host_home()
HOST_DATA_HOME = Path(os.environ.get("SEVENOS_HOST_DATA_HOME", str(HOST_HOME / ".local/share")))
PROFILE_ROOTFS_DIR = HOST_DATA_HOME / "sevenos/profile-rootfs"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", str(HOST_HOME / ".cache"))) / "sevenos"
CACHE_TTL = float(os.environ.get("SEVENOS_MINI_DOCTOR_CACHE_TTL", "300"))


KEY_TOOLS = {
    "forge": ("git", "code", "nodejs", "python", "docker", "podman", "jq", "ripgrep", "caddy"),
    "studio": ("gimp", "krita", "inkscape", "audacity", "ffmpeg", "imagemagick", "pipewire-jack"),
    "baobab": ("foliate", "mpv", "espeak-ng", "translate-shell", "kiwix-desktop"),
    "shield": ("nmap", "wireshark-qt", "tcpdump", "sqlmap", "zaproxy", "metasploit", "firejail", "bubblewrap"),
    "atlas": ("evince", "calibre", "marble", "gnome-maps", "pdfarranger", "tesseract", "simple-scan", "paperwork", "recoll", "xournalpp"),
    "pulse": ("gamemode", "vulkan-icd-loader", "vulkan-tools", "pipewire", "wireplumber", "alsa-utils"),
}

OPTIONAL_ACTIONS = {
    "forge": [
        ("forge.optional.dev", "Installer les conforts Forge", "seven profile requirements forge --optional --apply --yes"),
        ("forge.private.ide", "Installer VS Code dans Forge", "sevenpkg forge install code --source pacman"),
    ],
    "studio": [
        ("studio.packs", "Choisir un pack Studio", "seven profile-packs list studio"),
        ("studio.video", "Installer le pack Video Studio", "seven profile-packs install studio video --yes"),
        ("studio.audio", "Installer le pack Audio Studio", "seven profile-packs install studio audio --yes"),
        ("studio.3d", "Installer le pack 3D Studio", "seven profile-packs install studio 3d --yes"),
    ],
    "baobab": [
        ("baobab.optional.culture", "Installer la bibliotheque complete", "seven profile requirements baobab --optional --apply --yes"),
        ("baobab.private.calibre", "Installer Calibre dans Baobab", "sevenpkg baobab install calibre --source pacman"),
    ],
    "shield": [
        ("shield.optional.security", "Installer les extras Shield", "seven profile requirements shield --optional --apply --yes"),
        ("shield.private.burp", "Installer Burp Suite dans Shield", "sevenpkg shield install burpsuite --source paru"),
    ],
    "atlas": [
        ("atlas.packs", "Choisir un pack Atlas", "seven profile-packs list atlas"),
        ("atlas.aur-helper", "Installer paru dans Atlas", "seven profile-packs install atlas aur-helper --yes"),
        ("atlas.ocr-pdf", "Installer OCR PDF Atlas", "seven profile-packs install atlas ocr-pdf --yes"),
        ("atlas.required.native", "Installer le socle documents, cartes et OCR Atlas", "seven atlas install --yes"),
    ],
    "pulse": [
        ("pulse.packs", "Choisir un pack Pulse", "seven profile-packs list pulse"),
        ("pulse.private.launchers", "Installer Steam et Lutris dans Pulse", "seven-pulse launchers"),
        ("pulse.private.hud", "Installer HUD et frame pacing", "seven-pulse hud"),
    ],
}


def run_json(command: list[str]) -> dict:
    result = subprocess.run(command, cwd=ROOT, text=True, capture_output=True, check=False)
    if result.returncode != 0:
        return {}
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return {}


def load_catalog() -> dict:
    try:
        return json.loads(CATALOG.read_text(encoding="utf-8"))
    except Exception:
        return {}


def rootfs_path(profile: str) -> Path:
    return PROFILE_ROOTFS_DIR / profile / "rootfs"


def rootfs_ready(profile: str) -> bool:
    rootfs = rootfs_path(profile)
    return (rootfs / "usr/bin").is_dir() and (rootfs / "var/lib/pacman").exists()


def rootfs_packages(profile: str) -> set[str]:
    local = rootfs_path(profile) / "var/lib/pacman/local"
    packages = set()
    if not local.is_dir():
        return packages
    for desc in local.glob("*/desc"):
        try:
            lines = desc.read_text(encoding="utf-8", errors="ignore").splitlines()
        except OSError:
            continue
        for index, line in enumerate(lines):
            if line == "%NAME%" and index + 1 < len(lines):
                packages.add(lines[index + 1].strip())
                break
    return packages


def installed_packages() -> set[str]:
    if not shutil.which("pacman"):
        return set()
    result = subprocess.run(["pacman", "-Qq"], text=True, capture_output=True, check=False)
    if result.returncode != 0:
        return set()
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def requirements(profile: str, optional: bool = False) -> dict:
    command = [str(ROOT / "bin/seven-profile-requirements"), "status", profile, "--json"]
    if optional:
        command.append("--optional")
    return run_json(command)


def profile_payload(profile: str) -> dict:
    catalog = load_catalog()
    meta = ((catalog.get("profiles") or {}).get(profile) or {})
    req = requirements(profile, optional=True)
    summary = req.get("summary", {})
    missing = req.get("missing", {})
    private = rootfs_packages(profile)
    installed = installed_packages()
    ready_rootfs = rootfs_ready(profile)
    key_tools = {tool: tool in private or tool in installed for tool in KEY_TOOLS.get(profile, ())}
    blockers = []
    if summary.get("required_missing", 0):
        blockers.append(f"{profile}-required-packages")
    if not ready_rootfs:
        blockers.append(f"{profile}-rootfs")
    commands = {
        "open": f"seven-mini-os-center {profile}",
        "activate": f"seven profile activate {profile}",
        "prepare_rootfs": f"seven profile-rootfs prepare {profile} --apply --yes",
        "build_rootfs": f"seven profile-rootfs build {profile} --apply --yes",
        "install_required": f"seven profile requirements {profile} --apply --yes",
        "install_optional": f"seven profile requirements {profile} --optional --apply --yes",
        "packages": f"sevenpkg {profile} packages",
        "limits": f"sevenpkg {profile} limits",
    }
    plan = []
    if summary.get("required_missing", 0):
        plan.append({
            "id": f"{profile}.install.required",
            "label": f"Installer les essentiels {profile.title()}",
            "command": commands["install_required"],
            "scope": "profile-rootfs",
            "reason": "Install the role baseline inside this mini OS rootfs before relying on this mini OS.",
        })
    if not ready_rootfs:
        plan.append({
            "id": f"{profile}.rootfs.prepare",
            "label": f"Preparer le rootfs {profile.title()}",
            "command": commands["prepare_rootfs"],
            "scope": "profile-rootfs",
            "reason": "A private rootfs is required before profile-scoped package installs can stay isolated.",
        })
    for action_id, label, command in OPTIONAL_ACTIONS.get(profile, ()):
        scope = "profile-rootfs"
        plan.append({"id": action_id, "label": label, "command": command, "scope": scope, "reason": "Optional tools stay profile-specific and user-controlled."})
    return {
        "schema": "sevenos.mini-os.doctor.v1",
        "generated_at": int(time.time()),
        "profile": profile,
        "title": meta.get("title", profile.title()),
        "ready": not blockers,
        "summary": {
            "required": summary.get("required", 0),
            "required_missing": summary.get("required_missing", 0),
            "optional": summary.get("optional", 0),
            "optional_missing": summary.get("optional_missing", 0),
            "rootfs_ready": ready_rootfs,
            "private_package_count": len(private),
        },
        "package_files": req.get("package_files", []),
        "optional_package_files": req.get("optional_package_files", []),
        "missing": missing,
        "key_tools": key_tools,
        "blockers": blockers,
        "commands": commands,
        "plan": plan,
        "notes": [
	            "Mini OS role requirements are evaluated against the private profile rootfs, not the Equinox host.",
            "The mini OS remains independent: extra tools are opt-in and do not leak to other mini OS package views.",
        ],
    }


def set_payload(profiles: list[str]) -> dict:
    items = {profile: profile_payload(profile) for profile in profiles}
    return {
        "schema": "sevenos.mini-os.doctor-set.v1",
        "generated_at": int(time.time()),
        "profiles": items,
        "summary": {
            "profiles": len(items),
            "ready": sum(1 for item in items.values() if item["ready"]),
            "missing_required": sum(item["summary"]["required_missing"] for item in items.values()),
            "missing_rootfs": sum(1 for item in items.values() if not item["summary"]["rootfs_ready"]),
        },
    }


def print_human(data: dict) -> None:
    if data.get("schema") == "sevenos.mini-os.doctor-set.v1":
        print("SevenOS Mini OS Doctor")
        print("======================")
        for profile, item in data["profiles"].items():
            summary = item["summary"]
            print(f"{profile}: {'OK' if item['ready'] else 'needs setup'} · required {summary['required'] - summary['required_missing']}/{summary['required']} · rootfs {'ready' if summary['rootfs_ready'] else 'missing'}")
        return
    summary = data["summary"]
    print(f"SevenOS Mini OS Doctor · {data['title']}")
    print("====================================")
    print(f"State: {'OK' if data['ready'] else 'needs setup'}")
    print(f"Required packages: {summary['required'] - summary['required_missing']}/{summary['required']}")
    print(f"Optional tools: {summary['optional'] - summary['optional_missing']}/{summary['optional']}")
    print(f"Rootfs: {'ready' if summary['rootfs_ready'] else 'missing'}")
    print(f"Private packages: {summary['private_package_count']}")
    missing = data["missing"].get("required", [])[:10]
    if missing:
        print()
        print("Missing essentials:")
        for package in missing:
            print(f"- {package}")
    print()
    print("Plan:")
    for item in data["plan"][:8]:
        print(f"- {item['label']}: {item['command']}")


def run(command: list[str], dry_run: bool) -> int:
    if dry_run:
        print(" ".join(command))
        return 0
    return subprocess.run(command, cwd=ROOT, check=False).returncode


def cache_path(profile: str, action: str) -> Path:
    return CACHE_DIR / f"mini-doctor-{profile}-{action}.json"


def cache_read(profile: str, action: str, refresh: bool) -> dict | None:
    if refresh or os.environ.get("SEVENOS_MINI_DOCTOR_REFRESH") == "1":
        return None
    path = cache_path(profile, action)
    try:
        if time.time() - path.stat().st_mtime > CACHE_TTL:
            return None
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None
    return data if isinstance(data, dict) else None


def cache_write(profile: str, action: str, data: dict) -> None:
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        path = cache_path(profile, action)
        tmp = path.with_suffix(f".tmp.{os.getpid()}")
        tmp.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
        json.loads(tmp.read_text(encoding="utf-8"))
        tmp.replace(path)
    except Exception:
        try:
            tmp.unlink()  # type: ignore[name-defined]
        except Exception:
            pass


def cached_payload(profile_key: str, action: str, refresh: bool, builder) -> dict:
    cached = cache_read(profile_key, action, refresh)
    if cached is not None:
        return cached
    data = builder()
    cache_write(profile_key, action, data)
    return data


def main() -> int:
    parser = argparse.ArgumentParser(prog="seven-mini-doctor")
    parser.add_argument("profile", nargs="?", default="all", choices=("all", *PROFILES))
    parser.add_argument("action", nargs="?", default="doctor", choices=("doctor", "status", "json", "plan", "install", "optional", "rootfs", "open", "activate", "packages", "limits"))
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--refresh", "--no-cache", action="store_true", dest="refresh")
    args = parser.parse_args()

    profiles = list(PROFILES) if args.profile == "all" else [args.profile]
    if args.action in {"doctor", "status", "json", "plan"}:
        profile_key = "all" if len(profiles) > 1 else profiles[0]
        data = cached_payload(
            profile_key,
            args.action,
            args.refresh,
            lambda: set_payload(profiles) if len(profiles) > 1 else profile_payload(profiles[0]),
        )
        if args.action == "plan":
            plan_data = cached_payload(
                profile_key,
                "plan-actions",
                args.refresh,
                lambda: set_payload(profiles) if len(profiles) > 1 else profile_payload(profiles[0]),
            )
            plan_profiles = plan_data.get("profiles", {}) if plan_data.get("schema") == "sevenos.mini-os.doctor-set.v1" else {profiles[0]: plan_data}
            plan = {
                "schema": "sevenos.mini-os.plan.v1",
                "profiles": profiles,
                "actions": [action for item in plan_profiles.values() for action in item.get("plan", [])],
            }
            print(json.dumps(plan, indent=2) if args.json else "\n".join(f"{item['label']}: {item['command']}" for item in plan["actions"]))
            return 0
        if args.json or args.action == "json":
            print(json.dumps(data, indent=2))
        else:
            print_human(data)
        return 0

    if len(profiles) != 1:
        print("seven-mini-doctor: choose one profile for this action", file=sys.stderr)
        return 2
    profile = profiles[0]
    commands = profile_payload(profile)["commands"]
    if args.action == "install":
        return run([str(ROOT / "bin/seven"), "profile", "requirements", profile, "--apply", "--yes"], args.dry_run)
    if args.action == "optional":
        return run([str(ROOT / "bin/seven"), "profile", "requirements", profile, "--optional", "--apply", "--yes"], args.dry_run)
    if args.action == "rootfs":
        return run([str(ROOT / "bin/seven"), "profile-rootfs", "prepare", profile, "--apply", "--yes"], args.dry_run)
    if args.action == "open":
        return run([str(ROOT / "bin/seven-mini-os-center"), profile], args.dry_run)
    if args.action == "activate":
        return run([str(ROOT / "bin/seven"), "profile", "activate", profile], args.dry_run)
    if args.action == "packages":
        return run([str(ROOT / "bin/sevenpkg"), profile, "packages"], args.dry_run)
    if args.action == "limits":
        return run([str(ROOT / "bin/sevenpkg"), profile, "limits"], args.dry_run)
    print(commands)
    return 0


if __name__ == "__main__":
    sys.exit(main())
