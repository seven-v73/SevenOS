#!/usr/bin/env bash
set -Eeuo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/sevenos"
DND_FILE="$STATE_DIR/notifications.dnd"
ROOT_DIR="${SEVENOS_ROOT:-}"

language_code() {
  local language="${SEVENOS_LANGUAGE:-${LANG:-en_US.UTF-8}}"
  local config="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.conf"
  if [[ -z "${SEVENOS_LANGUAGE:-}" && -f "$config" ]]; then
    language="$(awk -F= '/^(SEVENOS_LANGUAGE|LANG)=/{gsub(/["\047]/, "", $2); print $2; exit}' "$config")"
  fi
  case "$language" in
    fr*) printf 'fr\n' ;;
    *) printf 'en\n' ;;
  esac
}

LANG_CODE="$(language_code)"
if [[ "$LANG_CODE" == "fr" ]]; then
  notifications_title="Notifications SevenOS"
  close_prompt="Appuyez sur Entrée pour fermer..."
  no_notifications="Aucune notification"
  no_notifications_detail="Les alertes apparaîtront ici"
  notification_label="Notification"
  rofi_prompt="Notifications"
  test_label="Tester"
  start_label="Démarrer"
  install_label="Installer"
  restore_label="Restaurer"
  dismiss_label="Fermer"
  focus_label="Focus"
  restart_label="Redémarrer"
  active_tooltip="Notifications : actives\nClic : ouvrir les contrôles, clic droit : activer Ne pas déranger, clic milieu : fermer les notifications visibles."
  dnd_tooltip="Notifications : Ne pas déranger activé\nClic : ouvrir les contrôles, clic droit : désactiver Ne pas déranger, clic milieu : fermer les notifications visibles."
  missing_backend_tooltip="Notifications : backend manquant\nClic : ouvrir le centre de notifications avec installation/réparation."
  missing_service_tooltip="Notifications : service arrêté\nClic : ouvrir les contrôles, clic droit : basculer Ne pas déranger."
else
  notifications_title="SevenOS Notifications"
  close_prompt="Press Enter to close..."
  no_notifications="No notifications"
  no_notifications_detail="Alerts will appear here"
  notification_label="Notification"
  rofi_prompt="Notifications"
  test_label="Test"
  start_label="Start"
  install_label="Install"
  restore_label="Restore"
  dismiss_label="Dismiss"
  focus_label="Focus"
  restart_label="Restart"
  active_tooltip="Notifications: active\nClick opens controls, right-click enables DND, middle-click dismisses visible notifications."
  dnd_tooltip="Notifications: Do Not Disturb enabled\nClick opens controls, right-click disables DND, middle-click dismisses visible notifications."
  missing_backend_tooltip="Notifications: backend missing\nClick opens notification center with install/repair action."
  missing_service_tooltip="Notifications: service missing\nClick opens controls, right-click toggles DND."
fi

resolve_native_center() {
  if [[ -n "$ROOT_DIR" && -x "$ROOT_DIR/bin/seven-notification-center-native" ]]; then
    printf '%s\n' "$ROOT_DIR/bin/seven-notification-center-native"
    return 0
  fi
  if command -v seven-notification-center-native >/dev/null 2>&1; then
    command -v seven-notification-center-native
    return 0
  fi
  return 1
}

dry_run() {
  [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]
}

dry_line() {
  printf 'DRY-RUN > Notifications > %s\n' "$*"
}

notify() {
  local title="$1"
  local message="$2"

  if dry_run; then
    dry_line "$title: $message"
    return 0
  fi

  if command -v notify-send >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    notify-send "$title" "$message" || true
  else
    printf '%s: %s\n' "$title" "$message"
  fi
}

run_detached() {
  if dry_run; then
    dry_line "Launch $*"
    return 0
  fi

  setsid -f "$@" >/tmp/sevenos-notifications.log 2>&1 || true
}

run_terminal() {
  local title="$1"
  local command="$2"
  local wrapped
  wrapped="$command; printf '\n%s' '$close_prompt'; read -r"

  if dry_run; then
    dry_line "$title > $command"
    return 0
  fi

  if command -v seven-terminal >/dev/null 2>&1; then
    run_detached seven-terminal -- bash -lc "$wrapped"
  elif command -v kitty >/dev/null 2>&1; then
    run_detached kitty --title "$title" bash -lc "$wrapped"
  else
    bash -lc "$command"
  fi
}

is_mako_running() {
  pgrep -x mako >/dev/null 2>&1
}

swaync_available() {
  command -v swaync >/dev/null 2>&1 && command -v swaync-client >/dev/null 2>&1
}

is_swaync_running() {
  pgrep -x swaync >/dev/null 2>&1
}

swaync_count() {
  timeout 0.8s swaync-client -sw -c 2>/dev/null || printf '0'
}

mako_missing() {
  ! command -v mako >/dev/null 2>&1 && ! swaync_available
}

status() {
  if [[ -f "$DND_FILE" ]]; then
    printf '󰂛\n'
  elif mako_missing; then
    printf '󰂜\n'
  elif is_swaync_running; then
    printf '󰂚\n'
  elif is_mako_running; then
    printf '󰂚\n'
  else
    printf '󰂜\n'
  fi
}

status_json() {
  if [[ -f "$DND_FILE" ]]; then
    printf '{"text":"󰂛","tooltip":"%s","class":"dnd"}\n' "$(printf '%s' "$dnd_tooltip" | sed ':a;N;$!ba;s/\n/\\n/g')"
  elif mako_missing; then
    printf '{"text":"󰂜","tooltip":"%s","class":"miss"}\n' "$(printf '%s' "$missing_backend_tooltip" | sed ':a;N;$!ba;s/\n/\\n/g')"
  elif is_swaync_running; then
    printf '{"text":"󰂚","tooltip":"%s","class":"ok"}\n' "$(printf '%s' "$active_tooltip" | sed ':a;N;$!ba;s/\n/\\n/g')"
  elif is_mako_running; then
    printf '{"text":"󰂚","tooltip":"%s","class":"ok"}\n' "$(printf '%s' "$active_tooltip" | sed ':a;N;$!ba;s/\n/\\n/g')"
  else
    printf '{"text":"󰂜","tooltip":"%s","class":"miss"}\n' "$(printf '%s' "$missing_service_tooltip" | sed ':a;N;$!ba;s/\n/\\n/g')"
  fi
}

notification_feed() {
  if command -v swaync-client >/dev/null 2>&1; then
    local count
    count="$(swaync_count)"
    if [[ "$count" =~ ^[0-9]+$ && "$count" -gt 0 ]]; then
      printf '󰂚  %s    %s\n' "$notification_label" "$count"
      return 0
    fi
  fi

  if command -v makoctl >/dev/null 2>&1; then
    local raw
    raw="$(makoctl list 2>/dev/null || true)"
    if [[ -n "$raw" && "$raw" != "[]" && "$raw" != "{}" ]]; then
      NOTIFICATION_RAW="$raw" python - <<'PY'
import json
import os
import re

text = os.environ.get("NOTIFICATION_RAW", "").strip()
rows = []

def walk(value):
    if isinstance(value, dict):
        summary = str(value.get("summary") or value.get("title") or value.get("app-name") or value.get("app_name") or "").strip()
        body = str(value.get("body") or value.get("text") or "").strip()
        app = str(value.get("app-name") or value.get("app_name") or value.get("app") or os.environ.get("SEVENOS_NOTIFICATION_LABEL", "Notification")).strip()
        if summary or body:
            rows.append((app, summary or app, body))
        for child in value.values():
            walk(child)
    elif isinstance(value, list):
        for child in value:
            walk(child)

try:
    walk(json.loads(text))
except Exception:
    for raw in text.splitlines():
        line = re.sub(r"\s+", " ", raw).strip()
        if line and line not in {"[]", "{}"}:
            rows.append((os.environ.get("SEVENOS_NOTIFICATION_LABEL", "Notification"), line[:72], ""))

for app, summary, body in rows[:5]:
    detail = body[:60] if body else app
    print(f"󰂚  {summary}    {detail}")
PY
      return 0
    fi
  fi
  printf '󰂚  %s    %s\n' "$no_notifications" "$no_notifications_detail"
}

start_mako() {
  if is_swaync_running; then
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Le service de notifications est déjà lancé.' || printf 'Notification service is already running.')"
    return 0
  fi

  if is_mako_running; then
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Le service de notifications est déjà lancé.' || printf 'Notification service is already running.')"
    return 0
  fi

  if mako_missing; then
    systemctl --user reset-failed sevenos-notifications.service >/dev/null 2>&1 || true
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Installe SwayNC ou Mako depuis le centre de notifications.' || printf 'Install SwayNC or Mako from the notification center.')"
    dry_run && return 0
    return 1
  fi

  if systemctl --user list-unit-files sevenos-notifications.service >/dev/null 2>&1; then
    systemctl --user restart sevenos-notifications.service >/dev/null 2>&1 || true
    sleep 0.3
  fi

  if is_swaync_running || is_mako_running; then
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Service de notifications démarré.' || printf 'Notification service started.')"
  elif command -v mako >/dev/null 2>&1; then
    run_detached mako
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Service de notifications démarré.' || printf 'Notification service started.')"
  fi
}

restart_mako() {
  if dry_run; then
    dry_line "Restart Mako"
    return 0
  fi

  if mako_missing; then
    systemctl --user reset-failed sevenos-notifications.service >/dev/null 2>&1 || true
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Installe SwayNC ou Mako depuis le centre de notifications.' || printf 'Install SwayNC or Mako from the notification center.')"
    dry_run && return 0
    return 1
  fi

  pkill -x swaync >/dev/null 2>&1 || true
  pkill -x mako >/dev/null 2>&1 || true
  systemctl --user restart sevenos-notifications.service >/dev/null 2>&1 || {
    if command -v swaync >/dev/null 2>&1; then
      run_detached swaync
    else
      run_detached mako
    fi
  }
  notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Service de notifications redémarré.' || printf 'Notification service restarted.')"
}

install_mako() {
  run_terminal "$notifications_title" "sudo pacman -S --needed swaync mako libnotify && systemctl --user daemon-reload && systemctl --user reset-failed sevenos-notifications.service && systemctl --user enable --now sevenos-notifications.service"
}

dismiss_visible() {
  if command -v swaync-client >/dev/null 2>&1; then
    dry_run && dry_line "Dismiss visible notifications" && return 0
    timeout 1s swaync-client -C >/dev/null 2>&1 || true
    if timeout 1s swaync-client -sw -C >/dev/null 2>&1; then
      return 0
    fi
  fi

  if command -v makoctl >/dev/null 2>&1; then
    dry_run && dry_line "Dismiss visible notifications" && return 0
    makoctl dismiss --all >/dev/null 2>&1 || true
    return 0
  fi
  notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Aucun client de notifications compatible n’est disponible.' || printf 'No compatible notification client is available.')"
}

restore_last() {
  if command -v makoctl >/dev/null 2>&1; then
    dry_run && dry_line "Restore last notification" && return 0
    makoctl restore >/dev/null 2>&1 || true
    return 0
  fi
  notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'La restauration est disponible avec Mako. Avec SwayNC, utilise le centre ou l’historique.' || printf 'Restore is available with Mako. With SwayNC, use the center or history.')"
}

toggle_dnd() {
  mkdir -p "$STATE_DIR"

  if [[ -f "$DND_FILE" ]]; then
    dry_run && dry_line "Toggle Do Not Disturb > off"
    dry_run || rm -f "$DND_FILE"
    if command -v makoctl >/dev/null 2>&1; then
      dry_run || makoctl mode -r do-not-disturb >/dev/null 2>&1 || true
    fi
    if command -v swaync-client >/dev/null 2>&1; then
      dry_run || timeout 1s swaync-client -sw -df >/dev/null 2>&1 || true
    fi
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Ne pas déranger désactivé.' || printf 'Do Not Disturb disabled.')"
  else
    dry_run && dry_line "Toggle Do Not Disturb > on"
    dry_run || touch "$DND_FILE"
    if command -v makoctl >/dev/null 2>&1; then
      dry_run || makoctl mode -a do-not-disturb >/dev/null 2>&1 || true
    fi
    if command -v swaync-client >/dev/null 2>&1; then
      dry_run || timeout 1s swaync-client -sw -dn >/dev/null 2>&1 || true
    fi
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Ne pas déranger activé.' || printf 'Do Not Disturb enabled.')"
  fi
}

menu() {
  export SEVENOS_NOTIFICATION_LABEL="$notification_label"
  notification_feed
  printf '󰅺  %s\n󰐥  %s\n󰚰  %s\n󰕒  %s\n󰅖  %s\n󰂛  %s\n󰜉  %s\n' "$test_label" "$start_label" "$install_label" "$restore_label" "$dismiss_label" "$focus_label" "$restart_label"
}

clean_selection() {
  local selected="$1"
  selected="${selected#*  }"
  selected="${selected%%    *}"
  printf '%s\n' "$selected"
}

open_menu() {
  local selected

  if dry_run; then
    dry_line "Open panel"
    menu
    return 0
  fi

  local native_center
  if [[ "${SEVENOS_NOTIFICATIONS_NATIVE:-1}" != "0" ]] &&
     native_center="$(resolve_native_center)" &&
     "$native_center" --probe >/dev/null 2>&1; then
    "$native_center"
    return $?
  fi

  if ! command -v rofi >/dev/null 2>&1; then
    notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'Le menu de secours SevenOS n’est pas installé.' || printf 'SevenOS fallback menu is not installed.')"
    return 1
  fi

  selected="$(menu | rofi -dmenu -p "$rofi_prompt" -theme "${XDG_CONFIG_HOME:-$HOME/.config}/rofi/sevenos.rasi" 2>/dev/null || true)"
  selected="$(clean_selection "$selected")"

  case "$selected" in
    "Test"|"Tester") notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'La surface de notifications SevenOS est active.' || printf 'SevenOS notification surface is active.')" ;;
    "Start"|"Démarrer") start_mako ;;
    "Install"|"Installer") install_mako ;;
    "Restore"|"Restaurer") restore_last ;;
    "Dismiss"|"Fermer") dismiss_visible ;;
    "Focus") toggle_dnd ;;
    "Restart"|"Redémarrer") restart_mako ;;
    "No notifications"|"Aucune notification") exit 0 ;;
    Notification*) exit 0 ;;
    "") exit 0 ;;
  esac
}

case "${1:-status}" in
  status) status ;;
  status-json|json) status_json ;;
  menu|open) open_menu ;;
  start) start_mako ;;
  install) install_mako ;;
  restart) restart_mako ;;
  dismiss) dismiss_visible ;;
  restore) restore_last ;;
  toggle-dnd|dnd) toggle_dnd ;;
  test) notify "$notifications_title" "$([[ "$LANG_CODE" == "fr" ]] && printf 'La surface de notifications SevenOS est active.' || printf 'SevenOS notification surface is active.')" ;;
  *) printf '%s\n' "$([[ "$LANG_CODE" == "fr" ]] && printf 'Utilisation : seven-waybar-notifications [status|menu|start|restart|dismiss|restore|toggle-dnd|test]' || printf 'Usage: seven-waybar-notifications [status|menu|start|restart|dismiss|restore|toggle-dnd|test]')" >&2; exit 1 ;;
esac
