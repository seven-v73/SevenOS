#!/usr/bin/env bash
set -Eeuo pipefail

# Retired native surface; language/i18n is handled by the delegated assistant.
# seven_i18n

if [[ "${1:-}" == "--probe" ]]; then
  printf 'retired\n'
  exit 0
fi

if [[ "$#" -eq 0 ]]; then
  exec "${SEVENOS_ROOT:-/opt/SevenOS}/bin/seven-windows-assistant" open
fi
exec "${SEVENOS_ROOT:-/opt/SevenOS}/bin/seven-windows-assistant" "$@"
