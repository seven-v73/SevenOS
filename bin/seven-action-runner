#!/usr/bin/env python3
import argparse
import os
import shlex
import subprocess
import sys
import time
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()
    script_dir = Path(__file__).resolve().parent
    candidate = script_dir.parent
    if Path(candidate, "install.sh").is_file():
        return candidate
    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if Path(path, "install.sh").is_file():
            return path
    return Path.cwd()


ROOT = resolve_root()
LOG_DIR = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "sevenos/actions"


def command_exists(command: str) -> bool:
    return subprocess.run(["bash", "-lc", f"command -v {shlex.quote(command)} >/dev/null 2>&1"], check=False).returncode == 0


def notify(title: str, body: str) -> None:
    if command_exists("notify-send"):
        subprocess.Popen(["notify-send", title, body], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def run_terminal(command: list[str], title: str) -> int:
    command_line = shlex.join(command)
    wrapped = f"cd {shlex.quote(str(ROOT))} && {command_line}; printf '\\nPress Enter to close...'; read -r"
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    if command_exists("seven-terminal"):
        return subprocess.Popen(["seven-terminal", "focus", "--", "bash", "-lc", wrapped], cwd=ROOT, env=env).wait()
    if command_exists("kitty"):
        return subprocess.Popen(["kitty", "--title", title, "bash", "-lc", wrapped], cwd=ROOT, env=env).wait()
    return subprocess.Popen(["bash", "-lc", wrapped], cwd=ROOT, env=env).wait()


def main() -> int:
    parser = argparse.ArgumentParser(prog="seven-action-runner", description="Run SevenOS actions without exposing implementation terminals by default")
    parser.add_argument("--title", default="SevenOS Action")
    parser.add_argument("--terminal", action="store_true", help="open a visible terminal for interactive/debug actions")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("command", nargs=argparse.REMAINDER)
    args = parser.parse_args()

    command = args.command
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        print("seven-action-runner: no command provided", file=sys.stderr)
        return 2

    if args.dry_run or os.environ.get("SEVENOS_DRY_RUN") == "1":
        print(shlex.join(command))
        return 0

    if args.terminal:
        return run_terminal(command, args.title)

    LOG_DIR.mkdir(parents=True, exist_ok=True)
    stamp = time.strftime("%Y%m%d-%H%M%S")
    slug = "".join(ch if ch.isalnum() else "-" for ch in args.title.lower()).strip("-")[:48] or "action"
    log_path = LOG_DIR / f"{stamp}-{slug}.log"
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_ACTION_LOG": str(log_path)}

    notify(args.title, "Action lancee en arriere-plan.")
    with log_path.open("w", encoding="utf-8") as log:
        log.write(f"$ {shlex.join(command)}\n\n")
        log.flush()
        result = subprocess.run(command, cwd=ROOT, env=env, text=True, stdout=log, stderr=subprocess.STDOUT, check=False)

    if result.returncode == 0:
        notify(args.title, f"Termine. Journal: {log_path}")
    else:
        notify(args.title, f"Echec ({result.returncode}). Journal: {log_path}")
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
