#!/usr/bin/env python3
"""Native SevenOS Recorder control panel."""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import GLib, Gdk, Gtk  # noqa: E402

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None

STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "sevenos/recorder"
PID_FILE = STATE_DIR / "recorder.pid"
CURRENT_FILE = STATE_DIR / "current-file"


def is_recording() -> bool:
    try:
        pid = PID_FILE.read_text(encoding="utf-8").strip()
    except OSError:
        return False
    return bool(pid and (Path("/proc") / pid).exists())


def current_file() -> str:
    try:
        return CURRENT_FILE.read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def run_recorder(action: str) -> None:
    subprocess.Popen(["seven-recorder", action], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


class RecorderWindow(Gtk.Window):
    def __init__(self) -> None:
        super().__init__(title="Seven Recorder")
        if hasattr(self, "set_wmclass"):
            self.set_wmclass("SevenRecorderNative", "SevenRecorderNative")
        self.set_default_size(360, 260)
        self.set_resizable(False)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.connect("destroy", Gtk.main_quit)
        self.get_style_context().add_class("seven-window")

        self.status = Gtk.Label(xalign=0)
        self.status.get_style_context().add_class("status")
        self.detail = Gtk.Label(xalign=0)
        self.detail.set_line_wrap(True)
        self.detail.get_style_context().add_class("detail")

        title = Gtk.Label(label="Seven Recorder", xalign=0)
        title.get_style_context().add_class("title")
        subtitle = Gtk.Label(label="Capture d'ecran simple pour tous les mini OS", xalign=0)
        subtitle.get_style_context().add_class("subtitle")

        area = self.action_button("󰩭", "Zone", "Choisir une partie de l'ecran", "area")
        full = self.action_button("󰹑", "Ecran", "Enregistrer tout l'ecran", "full")
        stop = self.action_button("󰓛", "Stop", "Arreter et copier le chemin", "stop")
        self.stop_button = stop

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.pack_start(area, True, True, 0)
        actions.pack_start(full, True, True, 0)
        actions.pack_start(stop, True, True, 0)

        open_folder = Gtk.Button(label="Ouvrir les videos")
        open_folder.get_style_context().add_class("ghost")
        open_folder.connect("clicked", self.open_recordings)

        body = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        body.get_style_context().add_class("seven-root")
        body.set_margin_top(18)
        body.set_margin_bottom(18)
        body.set_margin_start(18)
        body.set_margin_end(18)
        body.pack_start(title, False, False, 0)
        body.pack_start(subtitle, False, False, 0)
        body.pack_start(self.status, False, False, 0)
        body.pack_start(actions, False, False, 4)
        body.pack_start(self.detail, False, False, 0)
        body.pack_end(open_folder, False, False, 0)
        self.add(body)

        self.refresh()
        GLib.timeout_add(1000, self.refresh)

    def action_button(self, icon: str, title: str, subtitle: str, action: str) -> Gtk.Button:
        button = Gtk.Button()
        button.get_style_context().add_class("action")
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        glyph = Gtk.Label(label=icon)
        glyph.get_style_context().add_class("glyph")
        label = Gtk.Label(label=title)
        label.get_style_context().add_class("button-title")
        hint = Gtk.Label(label=subtitle)
        hint.get_style_context().add_class("button-hint")
        hint.set_line_wrap(True)
        box.pack_start(glyph, False, False, 0)
        box.pack_start(label, False, False, 0)
        box.pack_start(hint, False, False, 0)
        button.add(box)
        button.connect("clicked", lambda *_: self.run(action))
        return button

    def run(self, action: str) -> None:
        run_recorder(action)
        GLib.timeout_add(700, self.refresh)
        if action in {"area", "full"}:
            self.hide()

    def open_recordings(self, *_args: object) -> None:
        path = Path(os.environ.get("SEVENOS_RECORDING_DIR", str(Path.home() / "Videos/SevenOS-Records")))
        path.mkdir(parents=True, exist_ok=True)
        subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def refresh(self) -> bool:
        active = is_recording()
        if active:
            self.status.set_text("Enregistrement en cours")
            name = Path(current_file()).name or "video en cours"
            self.detail.set_text(f"Fichier: {name}\nClique sur Stop pour terminer proprement.")
            self.stop_button.set_sensitive(True)
            self.get_style_context().add_class("recording")
        else:
            self.status.set_text("Pret a enregistrer")
            self.detail.set_text("Choisis une zone ou l'ecran complet. Les videos sont sauvegardees dans Videos/SevenOS-Records.")
            self.stop_button.set_sensitive(False)
            self.get_style_context().remove_class("recording")
        return True


def install_css() -> None:
    mode = seven_theme.current_theme_mode() if seven_theme else os.environ.get("SEVENOS_THEME_MODE", "dark")
    base = seven_theme.gtk_app_css("recorder", mode) if seven_theme else ""
    css = """
    window {
      background: transparent;
      color: @seven_text;
      border-radius: 16px;
    }
    .title {
      font-size: 20px;
      font-weight: bold;
      color: @seven_text;
    }
    .subtitle, .detail {
      color: @seven_muted;
      font-size: 12px;
    }
    .status {
      min-height: 34px;
      padding: 8px 10px;
      border-radius: 14px;
      color: @seven_text;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    window.recording .status {
      background: alpha(@seven_danger, 0.16);
      border-color: alpha(@seven_danger, 0.34);
    }
    button {
      border-radius: 14px;
      border: 1px solid @seven_border;
      background: @seven_panel_2;
      color: @seven_text;
      box-shadow: none;
      text-shadow: none;
    }
    button:hover {
      background: @seven_hover;
      border-color: alpha(@seven_accent, 0.30);
    }
    button:disabled {
      opacity: 0.45;
    }
    .action {
      min-height: 92px;
      padding: 10px;
    }
    .glyph {
      font-size: 21px;
      color: @seven_accent;
    }
    .button-title {
      font-weight: bold;
      font-size: 13px;
    }
    .button-hint {
      color: @seven_muted;
      font-size: 11px;
    }
    .ghost {
      min-height: 32px;
      border-radius: 999px;
      background: alpha(@seven_text, 0.055);
    }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data((base + css).encode("utf-8"))
    screen = Gdk.Screen.get_default()
    if screen:
        Gtk.StyleContext.add_provider_for_screen(screen, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)


def main() -> int:
    if "--probe" in sys.argv:
        print("OK")
        return 0
    GLib.set_prgname("SevenRecorderNative")
    install_css()
    window = RecorderWindow()
    window.show_all()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
