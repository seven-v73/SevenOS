#!/usr/bin/env python3
"""Native SevenOS shell bar centers for network, Bluetooth, audio, power and system."""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr_text  # noqa: E402
import seven_theme  # noqa: E402


def out(command: list[str]) -> str:
    result = subprocess.run(command, text=True, capture_output=True, check=False)
    return result.stdout.strip()


def run_detached(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def probe() -> int:
    ensure_gi_python()
    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def wifi_state() -> tuple[str, str]:
    if not shutil.which("nmcli"):
        return tr_text("Missing"), tr_text("SevenOS network tools unavailable")
    radio = out(["nmcli", "radio", "wifi"])
    if radio == "disabled":
        return tr_text("Off"), tr_text("Wi-Fi radio disabled")
    ssid = out(["bash", "-lc", "nmcli -t -f active,ssid dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"])
    return tr_text("On"), ssid or tr_text("Not connected")


def wifi_signal() -> str:
    if not shutil.which("nmcli"):
        return "--"
    signal = out(["bash", "-lc", "nmcli -t -f ACTIVE,SIGNAL dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"])
    return f"{signal}%" if signal else "--"


def bluetooth_state() -> tuple[str, str, str]:
    if not shutil.which("bluetoothctl"):
        return tr_text("Missing"), tr_text("Install bluez-utils"), "--"
    raw = out(["bluetoothctl", "show"])
    powered = "unknown"
    discovering = "no"
    for line in raw.splitlines():
        if "Powered:" in line:
            powered = line.split(":", 1)[1].strip()
        if "Discovering:" in line:
            discovering = line.split(":", 1)[1].strip()
    if powered != "yes":
        return tr_text("Off"), tr_text("Bluetooth radio disabled"), "--"
    connected_raw = out(["bluetoothctl", "devices", "Connected"])
    connected = []
    for line in connected_raw.splitlines():
        parts = line.split(maxsplit=2)
        if len(parts) == 3:
            connected.append(parts[2])
    device = ", ".join(connected[:2]) if connected else tr_text("None")
    status = tr_text("Scanning") if discovering == "yes" else tr_text("Ready")
    return tr_text("On"), status, device


def volume_state() -> tuple[int, str]:
    if not shutil.which("wpctl"):
        return 0, tr_text("Audio tools unavailable")
    raw = out(["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"])
    try:
        value = int(float(raw.split()[1]) * 100)
    except Exception:
        value = 0
    muted = tr_text("muted") if "MUTED" in raw else tr_text("active")
    return max(0, min(100, value)), muted


def set_volume(value: float) -> None:
    if shutil.which("wpctl"):
        subprocess.Popen(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def battery_state() -> tuple[str, str]:
    bats = list(Path("/sys/class/power_supply").glob("BAT*"))
    if not bats:
        return "AC", tr_text("No battery detected")
    bat = bats[0]
    status = (bat / "status").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "status").exists() else tr_text("Unknown")
    capacity = (bat / "capacity").read_text(encoding="utf-8", errors="ignore").strip() if (bat / "capacity").exists() else "?"
    return f"{capacity}%", status


def local_command(name: str) -> str:
    candidate = ROOT / "bin" / name
    return str(candidate) if candidate.exists() else name


def idle_policy_status() -> dict:
    try:
        result = subprocess.run(
            [local_command("seven-idle"), "status", "--json"],
            text=True,
            capture_output=True,
            check=False,
            timeout=0.45,
        )
        if result.returncode == 0 and result.stdout.strip():
            data = json.loads(result.stdout)
            return data if isinstance(data, dict) else {}
    except Exception:
        pass
    return {}


def idle_policy_label() -> tuple[str, str]:
    data = idle_policy_status()
    mode = str(data.get("mode") or "standard")
    service = str(data.get("service") or "unknown")
    service_label = tr_text("Running") if service == "active" else service
    if mode == "never":
        return tr_text("Never"), tr_text("Display stays active") + f" · {service_label}"
    sleep = int(data.get("sleep_minutes") or 0)
    screen = int(data.get("screen_minutes") or 0)
    lock = int(data.get("lock_minutes") or 0)
    if sleep > 0:
        return tr_text("After {minutes} min", minutes=sleep), f"{tr_text('Lock')} {lock} · {tr_text('Display')} {screen}"
    return tr_text("SevenOS standard"), tr_text("Lock 10 · Display 15 · no forced sleep")


def set_idle_policy(value: str) -> None:
    if value == "standard":
        command = f"{local_command('seven-idle')} standard"
    elif value == "never":
        command = f"{local_command('seven-idle')} never"
    else:
        command = f"{local_command('seven-idle')} set {value}"
    run_detached(command)


def probe_system() -> tuple[str, str]:
    load = out(["bash", "-lc", "awk '{print $1}' /proc/loadavg"])
    mem = out(["bash", "-lc", "free -h | awk '/Mem:/ {print $3\" / \"$2}'"])
    return load or "0.00", mem or tr_text("Unknown")


def run(panel: str) -> int:
    if os.environ.get("SEVENOS_WAYBAR_CENTER_LEGACY") != "1":
        panel_map = {
            "network": "wifi",
            "bluetooth": "bluetooth",
            "audio": "audio",
            "power": "power",
            "battery": "power",
            "system": "system",
            "time": "time",
        }
        quick = ROOT / "bin/seven-quick-settings-native"
        command = str(quick) if quick.exists() else shutil.which("seven-quick-settings-native")
        if command:
            probe_result = subprocess.run([command, "--probe"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if probe_result.returncode == 0:
                subprocess.Popen(
                    [command, panel_map.get(panel, "system")],
                    cwd=ROOT,
                    env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                return 0

    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    panel = panel if panel in {"network", "bluetooth", "audio", "power", "system", "time"} else "system"
    titles = {
        "network": ("Wi-Fi", tr_text("Connect, toggle and manage nearby networks")),
        "bluetooth": ("Bluetooth", tr_text("Pair, connect and manage nearby devices")),
        "audio": (tr_text("Sound"), tr_text("Volume, mute and output controls")),
        "power": (tr_text("Power"), tr_text("Battery, lock and energy controls")),
        "system": (tr_text("System"), tr_text("Performance, settings and repair")),
        "time": (tr_text("Time"), tr_text("Calendar, clock and date actions")),
    }

    GLib.set_prgname("SevenWaybarCenterNative")
    GLib.set_application_name(f"SevenOS {titles[panel][0]}")
    try:
        Gdk.set_program_class("SevenWaybarCenterNative")
    except Exception:
        pass

    css = seven_theme.gtk_app_css("waybar-center") + """
    * { font-family: "SF Pro Display", "SF UI Display", "San Francisco", system-ui, sans-serif; }
    window.waybar-center-window { background: transparent; }
    .center-root {
      padding: 16px;
      border-radius: 30px;
      background:
        radial-gradient(ellipse at 14% 0%, alpha(@seven_wallpaper_accent, 0.14), transparent 42%),
        radial-gradient(ellipse at 86% 0%, alpha(@seven_wallpaper_secondary, 0.10), transparent 40%),
        @seven_panel;
      border: 1px solid @seven_border;
    }
    .title { color: @seven_text; font-size: 18px; font-weight: 500; }
    .subtitle { color: @seven_muted; font-size: 11px; }
    .hint {
      padding: 10px 12px;
      border-radius: 20px;
      color: @seven_muted;
      font-size: 11px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .metric {
      min-height: 86px;
      padding: 13px;
      border-radius: 22px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .metric-value { color: @seven_text; font-size: 24px; font-weight: 500; }
    .metric-label { color: @seven_muted; font-size: 11px; }
    .wide-card {
      padding: 13px;
      border-radius: 24px;
      background: @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .idle-card {
      padding: 13px;
      border-radius: 24px;
      background:
        linear-gradient(135deg, alpha(@seven_accent, 0.10), transparent),
        @seven_panel_2;
      border: 1px solid @seven_border;
    }
    .idle-title { color: @seven_text; font-size: 13px; font-weight: 500; }
    .idle-note { color: @seven_muted; font-size: 11px; }
    .idle-button {
      min-height: 30px;
      padding: 0 11px;
      border-radius: 999px;
      background: alpha(@seven_panel, 0.72);
      color: @seven_text;
      border: 1px solid @seven_border;
    }
    .idle-button:hover { background: @seven_hover; }
    .idle-button.active {
      background: alpha(@seven_accent, 0.20);
      border-color: alpha(@seven_accent, 0.36);
    }
    .scale trough { min-height: 8px; border-radius: 999px; background: rgba(94,116,130,0.18); }
    .scale highlight { border-radius: 999px; background: rgba(78,139,189,0.75); }
    .scale slider {
      min-width: 22px;
      min-height: 22px;
      border-radius: 999px;
      background: rgba(255,255,255,0.96);
      border: 1px solid rgba(91,127,166,0.22);
    }
    .action-strip {
      padding: 12px;
      border-radius: 22px;
      background: rgba(255,255,255,0.46);
      border: 1px solid rgba(255,255,255,0.68);
    }
    .icon-action {
      min-width: 46px;
      min-height: 46px;
      padding: 0;
      border-radius: 999px;
      background: rgba(255,255,255,0.58);
      border: 1px solid rgba(255,255,255,0.76);
    }
    .icon-action:hover { background: rgba(255,255,255,0.84); }
    """
    if seven_theme.current_theme_mode() == "dark":
        css += """
        .center-root {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.035)),
            rgba(16,18,25,0.94);
          border-color: rgba(255,255,255,0.12);
        }
        .title, .metric-value { color: rgba(245,247,250,0.96); }
        .subtitle, .hint, .metric-label { color: rgba(245,247,250,0.62); }
        .hint, .metric, .wide-card, .idle-card, .action-strip, .icon-action {
          background: rgba(255,255,255,0.07);
          border-color: rgba(255,255,255,0.10);
        }
        .idle-button {
          background: rgba(255,255,255,0.08);
          border-color: rgba(255,255,255,0.12);
          color: rgba(245,247,250,0.94);
        }
        .idle-button.active {
          background: rgba(77,163,255,0.18);
          border-color: rgba(77,163,255,0.34);
        }
        .icon-action:hover { background: rgba(77,163,255,0.14); }
        .scale trough { background: rgba(255,255,255,0.12); }
        .scale highlight { background: rgba(77,163,255,0.74); }
        """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title=f"SevenOS {titles[panel][0]}")
    window.set_wmclass("SevenWaybarCenterNative", "SevenWaybarCenterNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(420, 360)
    window.get_style_context().add_class("waybar-center-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.get_style_context().add_class("center-root")
    window.add(root)

    title = Gtk.Label(label=titles[panel][0], xalign=0)
    title.get_style_context().add_class("title")
    root.pack_start(title, False, False, 0)
    subtitle = Gtk.Label(label=titles[panel][1], xalign=0)
    subtitle.get_style_context().add_class("subtitle")
    root.pack_start(subtitle, False, False, 0)

    if panel == "network":
        state, detail = wifi_state()
        root.pack_start(metric_row(Gtk, [(state, "Wi-Fi"), (detail, tr_text("Network")), (wifi_signal(), tr_text("Signal"))]), False, False, 0)
        root.pack_start(hint(Gtk, tr_text("Choose opens the simple Wi-Fi list: toggle, connected network and nearby SSIDs.")), False, False, 0)
        actions = [("󰤨", tr_text("Networks"), "seven-wifi menu"), ("󰖩", tr_text("On / Off"), "seven-wifi toggle"), ("󰤭", tr_text("Disconnect"), "seven-wifi disconnect"), ("󰒓", tr_text("Settings"), "seven-settings network")]
    elif panel == "bluetooth":
        state, status, device = bluetooth_state()
        root.pack_start(metric_row(Gtk, [(state, "Bluetooth"), (device, tr_text("Connected")), (status, tr_text("Status"))]), False, False, 0)
        root.pack_start(hint(Gtk, tr_text("Use On / Off, Scan and Manager for the full pairing workflow without leaving the bar.")), False, False, 0)
        actions = [("󰂯", tr_text("On / Off"), "seven-bluetooth toggle"), ("󰐢", tr_text("Scan"), "seven-bluetooth scan"), ("󰂱", tr_text("Manager"), "seven-bluetooth manager"), ("󰒓", tr_text("Settings"), "seven-settings network")]
    elif panel == "audio":
        volume, muted = volume_state()
        root.pack_start(metric_row(Gtk, [(f"{volume}%", tr_text("Volume")), (muted.title(), tr_text("State"))]), False, False, 0)
        root.pack_start(slider(Gtk, volume, set_volume), False, False, 0)
        actions = [("󰕾", tr_text("Mixer"), "pavucontrol"), ("󰖁", tr_text("Mute"), "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"), ("󰝝", "Volume +", "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"), ("󰒓", tr_text("Settings"), "seven-settings sound")]
    elif panel == "power":
        capacity, status = battery_state()
        root.pack_start(metric_row(Gtk, [(capacity, tr_text("Battery")), (status, tr_text("State"))]), False, False, 0)
        root.pack_start(idle_card(Gtk), False, False, 0)
        actions = [("󰍁", tr_text("Lock"), "seven-power lock"), ("󰒲", tr_text("Sleep"), "seven-power suspend"), ("󰐥", tr_text("Power"), "seven-power"), ("󰒓", tr_text("Settings"), "seven-settings power")]
    elif panel == "time":
        now = out(["date", "+%H:%M"])
        day = out(["date", "+%A %d %B"])
        root.pack_start(metric_row(Gtk, [(now, tr_text("Local")), (day, tr_text("Date"))]), False, False, 0)
        actions = [("󰃭", tr_text("Calendar"), "gnome-calendar || seven-spotlight calendar"), ("󰥔", tr_text("Clock"), "seven-spotlight time"), ("󰀗", tr_text("World"), "seven-spotlight world time"), ("󰒓", tr_text("Settings"), "seven-settings system")]
    else:
        load, mem = probe_system()
        root.pack_start(metric_row(Gtk, [(load, tr_text("Load")), (mem, tr_text("Memory"))]), False, False, 0)
        root.pack_start(hint(Gtk, tr_text("Use Settings for normal controls; Monitor and Repair remain one-click utilities.")), False, False, 0)
        actions = [("󰍛", tr_text("Monitor"), "seven-terminal -- bash -lc 'btop || top'"), ("󰚰", tr_text("Updates"), "seven-settings system"), ("󰜉", tr_text("Repair UI"), "seven-waybar repair"), ("󰒓", tr_text("Settings"), "seven-settings system")]

    strip = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    strip.set_halign(Gtk.Align.CENTER)
    strip.get_style_context().add_class("action-strip")
    root.pack_end(strip, False, False, 0)
    for glyph, tooltip, command in actions:
        button = Gtk.Button()
        button.get_style_context().add_class("icon-action")
        button.set_tooltip_text(tooltip)
        button.add(Gtk.Label(label=glyph))
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        strip.pack_start(button, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def metric_row(Gtk, items: list[tuple[str, str]]):
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    for value, label in items:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        box.get_style_context().add_class("metric")
        value_label = Gtk.Label(label=value)
        value_label.get_style_context().add_class("metric-value")
        note = Gtk.Label(label=label)
        note.get_style_context().add_class("metric-label")
        box.pack_start(value_label, False, False, 0)
        box.pack_start(note, False, False, 0)
        row.pack_start(box, True, True, 0)
    return row


def idle_card(Gtk):
    card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    card.get_style_context().add_class("idle-card")
    title_text, note_text = idle_policy_label()
    heading = Gtk.Label(label=tr_text("Automatic sleep"), xalign=0)
    heading.get_style_context().add_class("idle-title")
    state = Gtk.Label(label=f"{title_text} · {note_text}", xalign=0)
    state.set_line_wrap(True)
    state.get_style_context().add_class("idle-note")
    card.pack_start(heading, False, False, 0)
    card.pack_start(state, False, False, 0)
    buttons = {}

    def current_choice() -> str:
        data = idle_policy_status()
        mode = str(data.get("mode") or "standard")
        if mode == "never":
            return "never"
        sleep = int(data.get("sleep_minutes") or 0)
        if sleep <= 0:
            return "standard"
        return str(sleep)

    def refresh_state() -> bool:
        fresh_title, fresh_note = idle_policy_label()
        state.set_text(f"{fresh_title} · {fresh_note}")
        active = current_choice()
        for value, button in buttons.items():
            base = button.get_tooltip_text() or value
            if value == active:
                button.set_label(f"✓ {base}")
                button.get_style_context().add_class("active")
            else:
                button.set_label(base)
                button.get_style_context().remove_class("active")
        return False

    def apply(value: str) -> None:
        set_idle_policy(value)
        from gi.repository import GLib

        GLib.timeout_add(450, refresh_state)

    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=7)
    for label, value in ((tr_text("Standard"), "standard"), ("15", "15"), ("30", "30"), ("1h", "60"), (tr_text("Never"), "never")):
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("idle-button")
        button.set_tooltip_text(label)
        buttons[value] = button
        button.connect("clicked", lambda _button, selected=value: apply(selected))
        row.pack_start(button, True, True, 0)
    card.pack_start(row, False, False, 0)
    refresh_state()
    return card


def hint(Gtk, text: str):
    label = Gtk.Label(label=text, xalign=0)
    label.set_line_wrap(True)
    label.get_style_context().add_class("hint")
    return label


def slider(Gtk, value: int, callback):
    card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    card.get_style_context().add_class("wide-card")
    scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
    scale.set_value(value)
    scale.set_draw_value(False)
    scale.get_style_context().add_class("scale")
    scale.connect("value-changed", lambda widget: callback(widget.get_value()))
    card.pack_start(scale, False, False, 0)
    return card


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    panel = sys.argv[1] if len(sys.argv) > 1 else "system"
    return run(panel)


if __name__ == "__main__":
    raise SystemExit(main())
