#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/install.sh" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/../install.sh" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/SevenOS" "$HOME/Code/OS/SevenOS"; do
    if [[ -x "$candidate/install.sh" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-session: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
export SEVENOS_ROOT="$ROOT_DIR"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

log() {
  printf '[seven-session] %s\n' "$*"
}

start_once() {
  local process="$1"
  shift

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN start $process: $*"
    return 0
  fi

  if pgrep -x "$process" >/dev/null 2>&1; then
    log "$process already running"
    return 0
  fi

  if command -v "$process" >/dev/null 2>&1; then
    log "starting $process"
    "$@" >/tmp/sevenos-"$process".log 2>&1 &
  else
    log "$process missing"
  fi
}

stop_conflicting_shell_processes() {
  if [[ "${SEVENOS_SESSION_KEEP_EXISTING:-0}" == "1" ]]; then
    return 0
  fi
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN skip stopping conflicting shell surfaces"
    return 0
  fi

  log "stopping conflicting shell surfaces"
  pkill -x waybar >/dev/null 2>&1 || true
  pkill -x mako >/dev/null 2>&1 || true
  pkill -x swaync >/dev/null 2>&1 || true
  pkill -x dunst >/dev/null 2>&1 || true
  pkill -x wlogout >/dev/null 2>&1 || true
  pkill -x eww >/dev/null 2>&1 || true
  pkill -f 'ags.*ml4w|ml4w.*ags|waybar.*ml4w|swaync.*ml4w' >/dev/null 2>&1 || true
}

start_systemd_session() {
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN start systemd user target"
    return 0
  fi
  if [[ "${SEVENOS_SESSION_NO_SYSTEMD:-0}" == "1" ]]; then
    return 1
  fi

  if ! command -v systemctl >/dev/null 2>&1; then
    return 1
  fi

  if [[ ! -f "$CONFIG_HOME/systemd/user/sevenos-session.target" ]]; then
    return 1
  fi

  log "starting systemd user target"
  systemctl --user daemon-reload >/dev/null 2>&1 || true
  if systemctl --user start sevenos-session.target >/dev/null 2>&1; then
    return 0
  fi

  return 1
}

start_waybar_context() {
  if [[ ! -x "$ROOT_DIR/bin/seven-waybar-context" ]]; then
    return 0
  fi

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN start seven-waybar-context daemon"
    return 0
  fi

  if pgrep -u "$USER" -f '(^|/| )seven-waybar-context daemon( |$)' >/dev/null 2>&1; then
    log "seven-waybar-context already running"
    return 0
  fi

  "$ROOT_DIR/bin/seven-waybar-context" once >/tmp/sevenos-waybar-context.log 2>&1 || true
  log "starting seven-waybar-context"
  "$ROOT_DIR/bin/seven-waybar-context" daemon >>/tmp/sevenos-waybar-context.log 2>&1 &
}

warmup_shell_experience() {
  if [[ "${SEVENOS_SESSION_NO_WARMUP:-0}" == "1" ]]; then
    return 0
  fi
  if [[ -x "$ROOT_DIR/scripts/shell-experience.sh" ]]; then
    log "warming Shell Experience"
    SEVENOS_EXPERIENCE_SILENT_WARMUP=1 "$ROOT_DIR/scripts/shell-experience.sh" warmup >/tmp/sevenos-shell-experience.log 2>&1 || true
  fi
}

sync_theme_session() {
  if [[ -x "$ROOT_DIR/scripts/theme-session.sh" ]]; then
    if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
      log "DRY-RUN sync theme session"
    else
      log "syncing SevenOS theme session"
      "$ROOT_DIR/scripts/theme-session.sh" sync >/tmp/sevenos-theme-session.log 2>&1 || true
    fi
  fi
}

sync_theme_session

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN update dbus activation environment"
  else
    dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE SEVENOS_THEME_MODE SEVENOS_COLOR_SCHEME GTK_THEME QT_QPA_PLATFORMTHEME QT_STYLE_OVERRIDE >/dev/null 2>&1 || true
  fi
fi

if command -v hyprctl >/dev/null 2>&1; then
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN set cursor Bibata-Modern-Classic 24"
  else
    hyprctl setcursor Bibata-Modern-Classic 24 >/dev/null 2>&1 || true
  fi
fi

stop_conflicting_shell_processes

if [[ -x "$ROOT_DIR/bin/seven-wallpaper" ]]; then
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN refresh wallpaper"
  else
    "$ROOT_DIR/bin/seven-wallpaper" refresh >/tmp/sevenos-wallpaper.log 2>&1 || log "wallpaper refresh failed"
  fi
else
  start_once hyprpaper hyprpaper
fi

if ! start_systemd_session; then
  start_waybar_context
  start_once waybar waybar -c "$CONFIG_HOME/waybar/config.jsonc" -s "$CONFIG_HOME/waybar/style.css"
  if [[ -x "$ROOT_DIR/bin/seven-notifications" ]]; then
    start_once seven-notifications "$ROOT_DIR/bin/seven-notifications"
  else
    start_once swaync swaync
    start_once mako mako
  fi

  if [[ -x "$ROOT_DIR/bin/seven-idle" ]]; then
    start_once seven-idle "$ROOT_DIR/bin/seven-idle"
  fi
fi

if command -v /usr/lib/polkit-kde-authentication-agent-1 >/dev/null 2>&1 &&
   ! pgrep -f polkit-kde-authentication-agent-1 >/dev/null 2>&1; then
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN start polkit authentication agent"
  else
    /usr/lib/polkit-kde-authentication-agent-1 >/tmp/sevenos-polkit.log 2>&1 &
  fi
fi

if [[ -x "$ROOT_DIR/bin/seven-welcome" ]]; then
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    log "DRY-RUN welcome notify"
  else
    "$ROOT_DIR/bin/seven-welcome" --notify || true
  fi
fi

warmup_shell_experience

log "session ready"
