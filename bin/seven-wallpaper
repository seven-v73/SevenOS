#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -f "$SEVENOS_ROOT/identity/assets/wallpaper-sevenos.svg" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "$script_dir/../identity/assets/wallpaper-sevenos.svg" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -f "$candidate/identity/assets/wallpaper-sevenos.svg" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-wallpaper: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
WALLPAPER_DIR="$DATA_HOME/sevenos/wallpapers"
SOURCE_SVG="$ROOT_DIR/identity/assets/wallpaper-sevenos.svg"
TARGET_SVG="$WALLPAPER_DIR/wallpaper-sevenos.svg"
TARGET_PNG="$WALLPAPER_DIR/wallpaper-sevenos-royal-kente.png"
CUSTOM_WALLPAPER="$WALLPAPER_DIR/wallpaper-sevenos-custom.png"
ACTIVE_WALLPAPER="$WALLPAPER_DIR/wallpaper-sevenos-active.png"
HYPRPAPER_CONFIG="$CONFIG_HOME/hypr/hyprpaper.conf"
SERVICE_NAME="sevenos-wallpaper.service"

render_wallpaper() {
  mkdir -p "$WALLPAPER_DIR"
  cp "$SOURCE_SVG" "$TARGET_SVG"
  rm -f "$TARGET_PNG"

  if command -v rsvg-convert >/dev/null 2>&1; then
    rsvg-convert -w 1920 -h 1080 "$SOURCE_SVG" -o "$TARGET_PNG"
  elif command -v magick >/dev/null 2>&1; then
    magick "$SOURCE_SVG" -resize 1920x1080! "$TARGET_PNG"
  else
    printf 'seven-wallpaper: missing SVG renderer. Install librsvg or imagemagick.\n' >&2
    exit 1
  fi

  cp "$TARGET_PNG" "$ACTIVE_WALLPAPER"
}

set_custom_wallpaper() {
  local source_file="${1:-}"

  if [[ -z "$source_file" ]]; then
    printf 'seven-wallpaper: missing image path\n' >&2
    exit 1
  fi

  source_file="${source_file/#\~/$HOME}"
  if [[ "$source_file" == file://* ]]; then
    source_file="${source_file#file://}"
    source_file="$(printf '%b' "${source_file//%/\\x}")"
  fi

  if [[ ! -f "$source_file" ]]; then
    printf 'seven-wallpaper: image not found: %s\n' "$source_file" >&2
    exit 1
  fi

  mkdir -p "$WALLPAPER_DIR"
  if command -v magick >/dev/null 2>&1; then
    magick "$source_file" -auto-orient "$CUSTOM_WALLPAPER"
  else
    cp "$source_file" "$CUSTOM_WALLPAPER"
  fi
  cp "$CUSTOM_WALLPAPER" "$ACTIVE_WALLPAPER"
}

write_config() {
  mkdir -p "$CONFIG_HOME/hypr"
  {
    printf 'ipc = on\n'
    printf 'preload = %s\n' "$ACTIVE_WALLPAPER"
    printf 'wallpaper = ,%s\n' "$ACTIVE_WALLPAPER"
    printf 'splash = false\n'
  } > "$HYPRPAPER_CONFIG"
}

systemd_wallpaper_available() {
  [[ "${SEVENOS_WALLPAPER_NO_SYSTEMD:-0}" != "1" ]] &&
    command -v systemctl >/dev/null 2>&1 &&
    [[ -f "$CONFIG_HOME/systemd/user/$SERVICE_NAME" ]] &&
    grep -q 'seven-wallpaper serve' "$CONFIG_HOME/systemd/user/$SERVICE_NAME"
}

start_hyprpaper_detached() {
  pkill -x hyprpaper >/dev/null 2>&1 || true
  if command -v hyprpaper >/dev/null 2>&1; then
    setsid hyprpaper >/tmp/sevenos-hyprpaper.log 2>&1 < /dev/null &
    sleep 0.4
  fi
}

apply_live() {
  if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    return 0
  fi

  if systemd_wallpaper_available; then
    systemctl --user daemon-reload >/dev/null 2>&1 || true
    systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1 || true
    sleep 0.4
  elif ! pgrep -x hyprpaper >/dev/null 2>&1; then
    start_hyprpaper_detached
  fi

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl hyprpaper unload all >/dev/null 2>&1 || true
    hyprctl hyprpaper preload "$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
    hyprctl hyprpaper wallpaper ",$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
  fi
}

serve_hyprpaper() {
  if [[ ! -f "$ACTIVE_WALLPAPER" ]]; then
    render_wallpaper
  fi
  write_config
  if ! command -v hyprpaper >/dev/null 2>&1; then
    printf 'seven-wallpaper: hyprpaper is not installed.\n' >&2
    exit 1
  fi

  hyprpaper >/tmp/sevenos-hyprpaper.log 2>&1 &
  local hyprpaper_pid="$!"
  trap 'kill "$hyprpaper_pid" >/dev/null 2>&1 || true' INT TERM EXIT

  sleep 0.6
  if command -v hyprctl >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    hyprctl hyprpaper unload all >/dev/null 2>&1 || true
    hyprctl hyprpaper preload "$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
    hyprctl hyprpaper wallpaper ",$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
  fi

  wait "$hyprpaper_pid"
}

restart_hyprpaper() {
  write_config

  if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    apply_live
  fi
}

print_status() {
  printf 'SevenOS wallpaper status\n'
  printf '  repo svg:    %s\n' "$SOURCE_SVG"
  printf '  copied svg:  %s\n' "$TARGET_SVG"
  printf '  rendered png:%s\n' "$TARGET_PNG"
  printf '  custom png:  %s\n' "$CUSTOM_WALLPAPER"
  printf '  active png:  %s\n' "$ACTIVE_WALLPAPER"
  printf '  hypr config: %s\n' "$HYPRPAPER_CONFIG"

  if [[ -f "$SOURCE_SVG" ]]; then
    printf '  repo svg sha: '
    sha256sum "$SOURCE_SVG" | awk '{print $1}'
  fi
  if [[ -f "$TARGET_PNG" ]]; then
    printf '  png sha:      '
    sha256sum "$TARGET_PNG" | awk '{print $1}'
    file "$TARGET_PNG" | sed 's/^/  /'
  else
    printf '  png: missing\n'
  fi
  if [[ -f "$ACTIVE_WALLPAPER" ]]; then
    printf '  active sha:  '
    sha256sum "$ACTIVE_WALLPAPER" | awk '{print $1}'
    file "$ACTIVE_WALLPAPER" | sed 's/^/  /'
  else
    printf '  active: missing\n'
  fi
  if [[ -f "$HYPRPAPER_CONFIG" ]]; then
    printf '\nCurrent hyprpaper config:\n'
    sed 's/^/  /' "$HYPRPAPER_CONFIG"
  fi
  if command -v pgrep >/dev/null 2>&1; then
    printf '\nProcesses:\n'
    pgrep -a hyprpaper 2>/dev/null | sed 's/^/  /' || printf '  hyprpaper not running\n'
  fi
  if command -v systemctl >/dev/null 2>&1; then
    printf '\nService:\n'
    systemctl --user is-active "$SERVICE_NAME" 2>/dev/null | sed 's/^/  /' || printf '  unavailable\n'
  fi
}

case "${1:-refresh}" in
  render)
    render_wallpaper
    write_config
    printf '%s\n' "$TARGET_PNG"
    ;;
  refresh)
    render_wallpaper
    restart_hyprpaper
    printf 'SevenOS wallpaper refreshed: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  set)
    set_custom_wallpaper "${2:-}"
    restart_hyprpaper
    if command -v notify-send >/dev/null 2>&1; then
      notify-send "SevenOS Wallpaper" "Wallpaper updated from $(basename -- "${2:-image}")" || true
    fi
    printf 'SevenOS wallpaper set: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  serve)
    serve_hyprpaper
    ;;
  status)
    print_status
    ;;
  path)
    printf '%s\n' "$ACTIVE_WALLPAPER"
    ;;
  *)
    printf 'Usage: seven-wallpaper [refresh|render|serve|status|path|set IMAGE]\n' >&2
    exit 1
    ;;
esac
