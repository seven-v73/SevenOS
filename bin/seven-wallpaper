#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -f "$SEVENOS_ROOT/identity/assets/wallpaper-sevenos.svg" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "$script_dir/../identity/assets/wallpaper-sevenos.svg" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -f "$candidate/identity/assets/wallpaper-sevenos.svg" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf 'seven-wallpaper: could not find SevenOS repository root\n' >&2
  exit 1
}

ROOT_DIR="$(resolve_root)"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
WALLPAPER_DIR="$DATA_HOME/sevenos/wallpapers"
STATE_DIR="$CONFIG_HOME/sevenos"
PROFILE_STATE_DIR="$STATE_DIR/profiles"
PROFILE_WALLPAPER_DIR="$WALLPAPER_DIR/profiles"
SOURCE_SVG="$ROOT_DIR/identity/assets/wallpaper-sevenos.svg"
COLLECTION_DIR="$ROOT_DIR/identity/wallpaper/dynamic"
COLLECTION_MANIFEST="$COLLECTION_DIR/manifest.json"
TARGET_SVG="$WALLPAPER_DIR/wallpaper-sevenos.svg"
TARGET_PNG="$WALLPAPER_DIR/wallpaper-sevenos-royal-kente.png"
CUSTOM_WALLPAPER="$WALLPAPER_DIR/wallpaper-sevenos-custom.png"
ACTIVE_WALLPAPER="$WALLPAPER_DIR/wallpaper-sevenos-active.png"
HYPRPAPER_CONFIG="$CONFIG_HOME/hypr/hyprpaper.conf"
GLOBAL_STATE_FILE="$STATE_DIR/wallpaper-state"
SERVICE_NAME="sevenos-wallpaper.service"

normalize_profile_key() {
  case "${1:-}" in
    horizon) printf 'forge' ;;
    equinox|baobab|forge|shield|studio|windows|pulse) printf '%s' "$1" ;;
    "") printf 'equinox' ;;
    *) printf '%s' "$1" ;;
  esac
}

active_profile() {
  local state_file="$STATE_DIR/profile.env"
  if [[ -n "${SEVENOS_WALLPAPER_PROFILE:-}" ]]; then
    normalize_profile_key "$SEVENOS_WALLPAPER_PROFILE"
    return 0
  fi
  if [[ -f "$state_file" ]]; then
    # shellcheck disable=SC1090
    source "$state_file"
    normalize_profile_key "${SEVENOS_ACTIVE_PROFILE:-equinox}"
  else
    normalize_profile_key "equinox"
  fi
}

profile_state_file() {
  local profile
  profile="$(normalize_profile_key "${1:-$(active_profile)}")"
  printf '%s/%s/wallpaper-state\n' "$PROFILE_STATE_DIR" "$profile"
}

profile_custom_wallpaper() {
  local profile
  profile="$(normalize_profile_key "${1:-$(active_profile)}")"
  printf '%s/%s/wallpaper-custom.png\n' "$PROFILE_WALLPAPER_DIR" "$profile"
}

profile_active_wallpaper() {
  local profile
  profile="$(normalize_profile_key "${1:-$(active_profile)}")"
  printf '%s/%s/wallpaper-active.png\n' "$PROFILE_WALLPAPER_DIR" "$profile"
}

profile_rotation_file() {
  local profile
  profile="$(normalize_profile_key "${1:-$(active_profile)}")"
  printf '%s/%s/wallpaper-rotation.json\n' "$PROFILE_STATE_DIR" "$profile"
}

save_wallpaper_state() {
  local mode="$1"
  local value="${2:-}"
  local profile profile_state profile_active
  profile="$(active_profile)"
  profile_state="$(profile_state_file "$profile")"
  profile_active="$(profile_active_wallpaper "$profile")"
  mkdir -p "$STATE_DIR" "$(dirname "$profile_state")" "$(dirname "$profile_active")"
  if [[ -f "$ACTIVE_WALLPAPER" ]]; then
    cp "$ACTIVE_WALLPAPER" "$profile_active"
  fi
  {
    printf 'profile\t%s\n' "$profile"
    printf 'mode\t%s\n' "$mode"
    printf 'value\t%s\n' "$value"
    printf 'active\t%s\n' "$ACTIVE_WALLPAPER"
    printf 'profile_active\t%s\n' "$profile_active"
  } > "$profile_state"
  {
    printf 'profile\t%s\n' "$profile"
    printf 'mode\t%s\n' "$mode"
    printf 'value\t%s\n' "$value"
    printf 'active\t%s\n' "$ACTIVE_WALLPAPER"
    printf 'profile_state\t%s\n' "$profile_state"
    printf 'profile_active\t%s\n' "$profile_active"
  } > "$GLOBAL_STATE_FILE"
}

wallpaper_state_value() {
  local key="$1"
  local profile_state
  profile_state="$(profile_state_file "$(active_profile)")"
  if [[ -f "$profile_state" ]]; then
    awk -F '\t' -v key="$key" '$1 == key { print $2; exit }' "$profile_state"
    return 0
  fi
  [[ -f "$GLOBAL_STATE_FILE" ]] || return 1
  awk -F '\t' -v key="$key" '$1 == key { print $2; exit }' "$GLOBAL_STATE_FILE"
}

profile_meta_json() {
  local profile="${1:-}"
  local payload
  if [[ -z "$profile" ]]; then
    profile="$("$ROOT_DIR/profiles/profile-manager.sh" current --json 2>/dev/null | python -c 'import json,sys; print(json.load(sys.stdin).get("key","equinox"))' 2>/dev/null || printf 'equinox')"
  fi
  payload="$("$ROOT_DIR/profiles/profile-manager.sh" status --json 2>/dev/null || printf '[]')"
  PROFILE_KEY="$profile" PROFILE_STATUS="$payload" python - <<'PY'
import json
import os

key = os.environ.get("PROFILE_KEY") or "equinox"
try:
    profiles = json.loads(os.environ.get("PROFILE_STATUS") or "[]")
except Exception:
    profiles = []
match = next((item for item in profiles if item.get("key") == key), None) or next((item for item in profiles if item.get("active")), None) or {}
print(json.dumps(match))
PY
}

render_wallpaper() {
  mkdir -p "$WALLPAPER_DIR"
  cp "$SOURCE_SVG" "$TARGET_SVG"
  rm -f "$TARGET_PNG"

  if command -v rsvg-convert >/dev/null 2>&1; then
    rsvg-convert -w 1920 -h 1080 "$SOURCE_SVG" -o "$TARGET_PNG"
  elif command -v magick >/dev/null 2>&1; then
    magick "$SOURCE_SVG" -resize 1920x1080! "$TARGET_PNG"
  else
    printf 'seven-wallpaper: missing SVG renderer. Install librsvg or imagemagick.\n' >&2
    exit 1
  fi

  cp "$TARGET_PNG" "$ACTIVE_WALLPAPER"
}

restore_persistent_wallpaper() {
  local mode value profile profile_png profile_active
  profile="$(active_profile)"
  mode="$(wallpaper_state_value mode 2>/dev/null || true)"
  value="$(wallpaper_state_value value 2>/dev/null || true)"
  profile_active="$(profile_active_wallpaper "$profile")"

  case "$mode" in
    custom)
      if [[ -n "$value" && -f "$value" ]]; then
        cp "$value" "$ACTIVE_WALLPAPER"
        mkdir -p "$(dirname "$profile_active")"
        cp "$ACTIVE_WALLPAPER" "$profile_active"
        return 0
      fi
      if [[ -f "$(profile_custom_wallpaper "$profile")" ]]; then
        cp "$(profile_custom_wallpaper "$profile")" "$ACTIVE_WALLPAPER"
        mkdir -p "$(dirname "$profile_active")"
        cp "$ACTIVE_WALLPAPER" "$profile_active"
        return 0
      fi
      if [[ -f "$CUSTOM_WALLPAPER" ]]; then
        cp "$CUSTOM_WALLPAPER" "$ACTIVE_WALLPAPER"
        mkdir -p "$(dirname "$profile_active")"
        cp "$ACTIVE_WALLPAPER" "$profile_active"
        return 0
      fi
      ;;
    profile)
      profile_png="$WALLPAPER_DIR/wallpaper-sevenos-${value:-equinox}.png"
      if [[ -f "$profile_png" ]]; then
        cp "$profile_png" "$ACTIVE_WALLPAPER"
        return 0
      fi
      render_profile_wallpaper "${value:-equinox}"
      save_wallpaper_state profile "${value:-equinox}"
      return 0
      ;;
    collection)
      if [[ -n "$value" ]]; then
        render_collection_wallpaper "$value"
        save_wallpaper_state collection "$value"
        return 0
      fi
      ;;
    rotation)
      if wallpaper_rotation_enabled; then
        rotate_wallpaper_once >/dev/null
        return 0
      fi
      ;;
    default)
      render_profile_wallpaper "$profile"
      save_wallpaper_state profile "$profile"
      return 0
      ;;
  esac

  if [[ -f "$profile_active" ]]; then
    cp "$profile_active" "$ACTIVE_WALLPAPER"
    return 0
  fi
  render_profile_wallpaper "$profile"
  save_wallpaper_state profile "$profile"
}

set_custom_wallpaper() {
  local source_file="${1:-}"
  local profile scoped_custom scoped_active

  if [[ -z "$source_file" ]]; then
    printf 'seven-wallpaper: missing image path\n' >&2
    exit 1
  fi

  source_file="${source_file/#\~/$HOME}"
  if [[ "$source_file" == file://* ]]; then
    source_file="${source_file#file://}"
    source_file="$(printf '%b' "${source_file//%/\\x}")"
  fi

  if [[ ! -f "$source_file" ]]; then
    printf 'seven-wallpaper: image not found: %s\n' "$source_file" >&2
    exit 1
  fi

  profile="$(active_profile)"
  scoped_custom="$(profile_custom_wallpaper "$profile")"
  scoped_active="$(profile_active_wallpaper "$profile")"
  mkdir -p "$WALLPAPER_DIR" "$(dirname "$scoped_custom")"
  if command -v magick >/dev/null 2>&1; then
    magick "$source_file" -auto-orient "$scoped_custom"
  else
    cp "$source_file" "$scoped_custom"
  fi
  cp "$scoped_custom" "$scoped_active"
  cp "$scoped_custom" "$ACTIVE_WALLPAPER"
  save_wallpaper_state custom "$scoped_custom"
}

render_profile_wallpaper() {
  local profile="${1:-}"
  mkdir -p "$WALLPAPER_DIR"
  PROFILE_JSON="$(profile_meta_json "$profile")" python - "$WALLPAPER_DIR" <<'PY'
import html
import json
import os
import sys

wallpaper_dir = sys.argv[1]
profile = json.loads(os.environ.get("PROFILE_JSON") or "{}")
key = profile.get("key", "equinox")
title = html.escape(profile.get("title", "Equinox Balance"))
role = html.escape(profile.get("role", "Balance"))
accent = profile.get("accent_color", "#8B7CFF")
secondary = profile.get("secondary_color", "#6EA8FF")
mood = html.escape(profile.get("ui_mood", "SevenOS profile"))
principle = html.escape(profile.get("principle", "No profile dependency, only profile collaboration."))
symbol = html.escape(profile.get("waybar_icon", profile.get("icon", "7")))
target = os.path.join(wallpaper_dir, f"wallpaper-sevenos-{key}.svg")

palette = {
    "equinox": ("#11111B", "#1B1F30", "#34365C", "#121528"),
    "baobab": ("#09160E", "#172415", "#4E3923", "#0E1E13"),
    "forge": ("#120F0B", "#21170E", "#45321E", "#15111B"),
    "shield": ("#041411", "#09201B", "#123F38", "#071D23"),
    "studio": ("#130B1B", "#21122B", "#3E244D", "#171129"),
    "windows": ("#07111E", "#0D1C2B", "#183D5A", "#0B1626"),
    "pulse": ("#031522", "#082337", "#0A4961", "#061A2A"),
}.get(key, ("#11111B", "#1B1F30", "#34365C", "#121528"))
bg, mid, ridge, deep = palette

svg = f'''<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <radialGradient id="skyA" cx="20%" cy="8%" r="72%">
      <stop offset="0%" stop-color="{accent}" stop-opacity="0.48"/>
      <stop offset="42%" stop-color="{secondary}" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="{bg}" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="skyB" cx="84%" cy="18%" r="60%">
      <stop offset="0%" stop-color="{secondary}" stop-opacity="0.38"/>
      <stop offset="100%" stop-color="{bg}" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="{mid}"/>
      <stop offset="56%" stop-color="{bg}"/>
      <stop offset="100%" stop-color="{deep}"/>
    </linearGradient>
    <linearGradient id="lake" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="{accent}" stop-opacity="0.22"/>
      <stop offset="42%" stop-color="{secondary}" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#050815" stop-opacity="0.42"/>
    </linearGradient>
    <filter id="soft"><feGaussianBlur stdDeviation="36"/></filter>
    <filter id="grain" x="0" y="0" width="100%" height="100%">
      <feTurbulence type="fractalNoise" baseFrequency="0.68" numOctaves="2" seed="7"/>
      <feColorMatrix type="saturate" values="0"/>
      <feComponentTransfer><feFuncA type="table" tableValues="0 0.08"/></feComponentTransfer>
    </filter>
  </defs>
  <rect width="1920" height="1080" fill="url(#sky)"/>
  <rect width="1920" height="1080" fill="url(#skyA)"/>
  <rect width="1920" height="1080" fill="url(#skyB)"/>
  <circle cx="1580" cy="188" r="112" fill="{accent}" opacity="0.18" filter="url(#soft)"/>
  <circle cx="1540" cy="170" r="42" fill="#FFFFFF" opacity="0.34"/>
  <path d="M-80 655 C 190 520, 330 565, 520 415 C 690 280, 790 410, 930 318 C 1070 230, 1185 405, 1370 338 C 1575 262, 1720 410, 2040 320 L 2040 780 L -80 780 Z" fill="{ridge}" opacity="0.70"/>
  <path d="M-70 710 C 210 580, 420 640, 640 500 C 870 352, 1010 566, 1190 450 C 1410 310, 1615 565, 2010 438 L 2010 840 L -70 840 Z" fill="{deep}" opacity="0.88"/>
  <path d="M-60 805 C 300 700, 560 735, 840 628 C 1110 525, 1360 668, 2010 560 L 2010 1100 L -60 1100 Z" fill="#060A17" opacity="0.82"/>
  <path d="M0 785 C 340 745, 650 785, 960 710 C 1260 638, 1510 730, 1920 650 L 1920 1080 L 0 1080 Z" fill="url(#lake)" opacity="0.84"/>
  <path d="M120 850 C 520 820, 830 870, 1180 795 C 1460 735, 1660 782, 1840 748" fill="none" stroke="{accent}" stroke-opacity="0.18" stroke-width="3"/>
  <path d="M180 908 C 560 890, 830 928, 1200 858 C 1450 812, 1655 852, 1810 828" fill="none" stroke="{secondary}" stroke-opacity="0.12" stroke-width="2"/>
  <ellipse cx="960" cy="1008" rx="1020" ry="210" fill="{accent}" opacity="0.09" filter="url(#soft)"/>
  <g opacity="0.12" stroke="{secondary}" stroke-width="1.4">
    <path d="M120 170 h240 m-120 -120 v240"/>
    <path d="M1510 770 h250 m-125 -125 v250"/>
    <path d="M1360 92 l72 72 l-72 72 l-72 -72z"/>
  </g>
  <g transform="translate(112 725)">
    <rect x="-26" y="-94" width="720" height="238" rx="34" fill="#020617" opacity="0.20"/>
    <text x="0" y="-18" fill="#FFFFFF" opacity="0.94" font-family="SF Pro Display, Inter, sans-serif" font-size="72" font-weight="500">{title}</text>
    <text x="2" y="34" fill="#FFFFFF" opacity="0.70" font-family="SF Pro Text, Inter, sans-serif" font-size="25">{role} · {mood}</text>
    <text x="2" y="78" fill="{accent}" opacity="0.82" font-family="SF Pro Text, Inter, sans-serif" font-size="19">{principle}</text>
  </g>
  <g transform="translate(1660 770)">
    <circle cx="0" cy="0" r="72" fill="{accent}" opacity="0.22"/>
    <circle cx="0" cy="0" r="48" fill="#FFFFFF" opacity="0.10"/>
    <text x="0" y="18" text-anchor="middle" fill="#FFFFFF" opacity="0.86" font-family="JetBrainsMono Nerd Font, SF Pro Display, sans-serif" font-size="48">{symbol}</text>
  </g>
  <rect width="1920" height="1080" filter="url(#grain)" opacity="0.42"/>
</svg>
'''
open(target, "w", encoding="utf-8").write(svg)
PY

  local key
  key="$(PROFILE_JSON="$(profile_meta_json "$profile")" python -c 'import json,os; print(json.loads(os.environ.get("PROFILE_JSON") or "{}").get("key","equinox"))')"
  local profile_svg="$WALLPAPER_DIR/wallpaper-sevenos-$key.svg"
  local profile_png="$WALLPAPER_DIR/wallpaper-sevenos-$key.png"
  rm -f "$profile_png"
  if command -v rsvg-convert >/dev/null 2>&1; then
    rsvg-convert -w 1920 -h 1080 "$profile_svg" -o "$profile_png"
  elif command -v magick >/dev/null 2>&1; then
    magick "$profile_svg" -resize 1920x1080! "$profile_png"
  else
    cp "$profile_svg" "$TARGET_SVG"
    printf 'seven-wallpaper: missing SVG renderer. Install librsvg or imagemagick.\n' >&2
    exit 1
  fi
  cp "$profile_png" "$ACTIVE_WALLPAPER"
  if [[ "${SEVENOS_WALLPAPER_SKIP_STATE:-0}" != "1" ]]; then
    SEVENOS_WALLPAPER_PROFILE="$key" save_wallpaper_state profile "$key"
  fi
}

collection_json() {
  python - "$COLLECTION_MANIFEST" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    payload = {"schema": "sevenos.wallpaper.collection.v1", "count": 0, "items": []}
items = payload.get("items") if isinstance(payload.get("items"), list) else []
payload["count"] = len(items)
payload["manifest"] = str(path)
print(json.dumps(payload, ensure_ascii=False, indent=2))
PY
}

collection_svg_for_slug() {
  local slug="$1"
  python - "$COLLECTION_MANIFEST" "$COLLECTION_DIR" "$slug" <<'PY'
import json
import sys
from pathlib import Path

manifest = Path(sys.argv[1])
base = Path(sys.argv[2])
slug = sys.argv[3]
try:
    payload = json.loads(manifest.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(1)
for item in payload.get("items", []):
    if isinstance(item, dict) and item.get("slug") == slug:
        svg = base / str(item.get("svg") or "")
        if svg.is_file():
            print(svg)
            raise SystemExit(0)
raise SystemExit(1)
PY
}

render_collection_wallpaper() {
  local slug="${1:-}"
  local source_svg target_png collection_target
  if [[ -z "$slug" ]]; then
    printf 'seven-wallpaper: missing collection slug\n' >&2
    exit 1
  fi
  source_svg="$(collection_svg_for_slug "$slug" 2>/dev/null || true)"
  if [[ -z "$source_svg" || ! -f "$source_svg" ]]; then
    printf 'seven-wallpaper: unknown collection wallpaper: %s\n' "$slug" >&2
    exit 1
  fi
  mkdir -p "$WALLPAPER_DIR/collection"
  collection_target="$WALLPAPER_DIR/collection/$slug.svg"
  target_png="$WALLPAPER_DIR/collection/$slug.png"
  cp "$source_svg" "$collection_target"
  rm -f "$target_png"
  if command -v rsvg-convert >/dev/null 2>&1; then
    rsvg-convert -w 1920 -h 1080 "$collection_target" -o "$target_png"
  elif command -v magick >/dev/null 2>&1; then
    magick "$collection_target" -resize 1920x1080! "$target_png"
  else
    printf 'seven-wallpaper: missing SVG renderer. Install librsvg or imagemagick.\n' >&2
    exit 1
  fi
  cp "$target_png" "$ACTIVE_WALLPAPER"
}

wallpaper_rotation_enabled() {
  local rotation_file
  rotation_file="$(profile_rotation_file "$(active_profile)")"
  [[ -s "$rotation_file" ]] || return 1
  python - "$rotation_file" <<'PY'
import json
import sys
try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    raise SystemExit(1)
slugs = data.get("slugs") if isinstance(data.get("slugs"), list) else []
raise SystemExit(0 if data.get("enabled") is True and len(slugs) > 0 else 1)
PY
}

rotation_json() {
  local rotation_file
  rotation_file="$(profile_rotation_file "$(active_profile)")"
  python - "$rotation_file" "$(active_profile)" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
profile = sys.argv[2]
fallback = {
    "schema": "sevenos.wallpaper.rotation.v1",
    "profile": profile,
    "enabled": False,
    "interval": 900,
    "index": 0,
    "slugs": [],
}
try:
    data = json.loads(path.read_text(encoding="utf-8"))
    if isinstance(data, dict):
        fallback.update(data)
except Exception:
    pass
fallback["profile"] = profile
fallback["path"] = str(path)
print(json.dumps(fallback, ensure_ascii=False, indent=2))
PY
}

set_wallpaper_rotation() {
  local interval="${1:-900}"
  shift || true
  if [[ "$#" -lt 1 ]]; then
    printf 'seven-wallpaper: rotation needs at least one collection slug\n' >&2
    exit 1
  fi
  local rotation_file
  rotation_file="$(profile_rotation_file "$(active_profile)")"
  mkdir -p "$(dirname "$rotation_file")"
  COLLECTION_MANIFEST="$COLLECTION_MANIFEST" ROTATION_FILE="$rotation_file" ROTATION_INTERVAL="$interval" python - "$@" <<'PY'
import json
import os
import sys
from pathlib import Path

manifest = Path(os.environ["COLLECTION_MANIFEST"])
target = Path(os.environ["ROTATION_FILE"])
try:
    interval = max(30, int(float(os.environ.get("ROTATION_INTERVAL") or 900)))
except Exception:
    interval = 900
requested = [slug for slug in sys.argv[1:] if slug.strip()]
payload = json.loads(manifest.read_text(encoding="utf-8"))
known = {item.get("slug") for item in payload.get("items", []) if isinstance(item, dict)}
slugs = []
for slug in requested:
    if slug not in known:
        print(f"seven-wallpaper: unknown collection wallpaper: {slug}", file=sys.stderr)
        raise SystemExit(1)
    if slug not in slugs:
        slugs.append(slug)
if not slugs:
    print("seven-wallpaper: no valid wallpapers for rotation", file=sys.stderr)
    raise SystemExit(1)
data = {
    "schema": "sevenos.wallpaper.rotation.v1",
    "enabled": True,
    "interval": interval,
    "index": 0,
    "slugs": slugs,
}
target.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
print(json.dumps(data, ensure_ascii=False))
PY
  save_wallpaper_state rotation "$rotation_file"
}

set_wallpaper_rotation_preset() {
  local preset="${1:-day}"
  local interval="${2:-900}"
  case "$preset" in
    day|daily|journee|journée)
      set_wallpaper_rotation "$interval" prism-dawn aurora-morning orbit-noon terra-afternoon kente-golden prism-dusk aurora-night
      ;;
    calm|soft|calme)
      set_wallpaper_rotation "$interval" terra-mist aurora-dawn prism-morning terra-golden orbit-dusk aurora-night
      ;;
    focus|work|travail)
      set_wallpaper_rotation "$interval" prism-morning orbit-noon terra-afternoon prism-dusk orbit-night
      ;;
    night|nocturne|soir)
      set_wallpaper_rotation "$interval" aurora-dusk prism-night orbit-midnight terra-night kente-midnight
      ;;
    vivid|energy|energie|énergie)
      set_wallpaper_rotation "$interval" aurora-golden kente-noon orbit-afternoon prism-golden terra-dusk
      ;;
    *)
      printf 'seven-wallpaper: unknown rotation preset: %s\n' "$preset" >&2
      printf 'available presets: day calm focus night vivid\n' >&2
      exit 1
      ;;
  esac
}

disable_wallpaper_rotation() {
  local rotation_file
  rotation_file="$(profile_rotation_file "$(active_profile)")"
  mkdir -p "$(dirname "$rotation_file")"
  python - "$rotation_file" "$(active_profile)" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = {
    "schema": "sevenos.wallpaper.rotation.v1",
    "profile": sys.argv[2],
    "enabled": False,
    "interval": 900,
    "index": 0,
    "slugs": [],
}
try:
    old = json.loads(path.read_text(encoding="utf-8"))
    if isinstance(old, dict):
        data.update(old)
        data["enabled"] = False
except Exception:
    pass
path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
}

rotation_interval_seconds() {
  local rotation_file
  rotation_file="$(profile_rotation_file "$(active_profile)")"
  python - "$rotation_file" <<'PY'
import json
import sys
try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
    print(max(30, int(data.get("interval") or 900)))
except Exception:
    print(900)
PY
}

rotate_wallpaper_once() {
  local rotation_file slug
  rotation_file="$(profile_rotation_file "$(active_profile)")"
  slug="$(python - "$rotation_file" <<'PY'
import json
import sys
import time
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
slugs = data.get("slugs") if isinstance(data.get("slugs"), list) else []
if not data.get("enabled") or not slugs:
    raise SystemExit(1)
index = int(data.get("index") or 0) % len(slugs)
slug = slugs[index]
data["index"] = (index + 1) % len(slugs)
data["last_slug"] = slug
data["last_changed"] = int(time.time())
path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
print(slug)
PY
)"
  render_collection_wallpaper "$slug"
  save_wallpaper_state rotation "$rotation_file"
  write_config
  printf '%s\n' "$slug"
}

render_all_profile_wallpapers() {
  local profile
  for profile in equinox baobab forge shield studio windows pulse; do
    SEVENOS_WALLPAPER_SKIP_STATE=1 render_profile_wallpaper "$profile"
  done
}

write_config() {
  mkdir -p "$CONFIG_HOME/hypr"
  {
    printf 'ipc = on\n'
    printf 'preload = %s\n' "$ACTIVE_WALLPAPER"
    printf 'wallpaper = ,%s\n' "$ACTIVE_WALLPAPER"
    printf 'splash = false\n'
  } > "$HYPRPAPER_CONFIG"
}

generate_palette() {
  if [[ -x "$ROOT_DIR/scripts/wallpaper-theme.sh" && -f "$ACTIVE_WALLPAPER" ]]; then
    "$ROOT_DIR/scripts/wallpaper-theme.sh" generate "$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
  fi
}

systemd_wallpaper_available() {
  [[ "${SEVENOS_WALLPAPER_NO_SYSTEMD:-0}" != "1" ]] &&
    command -v systemctl >/dev/null 2>&1 &&
    [[ -f "$CONFIG_HOME/systemd/user/$SERVICE_NAME" ]] &&
    grep -q 'seven-wallpaper serve' "$CONFIG_HOME/systemd/user/$SERVICE_NAME"
}

start_hyprpaper_detached() {
  pkill -x hyprpaper >/dev/null 2>&1 || true
  if command -v hyprpaper >/dev/null 2>&1; then
    setsid hyprpaper >/tmp/sevenos-hyprpaper.log 2>&1 < /dev/null &
    sleep 0.4
  fi
}

apply_live() {
  if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    return 0
  fi

  if systemd_wallpaper_available; then
    systemctl --user daemon-reload >/dev/null 2>&1 || true
    systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1 || true
    sleep 0.4
  elif ! pgrep -x hyprpaper >/dev/null 2>&1; then
    start_hyprpaper_detached
  fi

  if command -v swww >/dev/null 2>&1; then
    swww query >/dev/null 2>&1 || swww init >/dev/null 2>&1 || true
    swww img "$ACTIVE_WALLPAPER" \
      --transition-type grow \
      --transition-pos 0.5,0.5 \
      --transition-duration 1.15 \
      --transition-fps 60 >/dev/null 2>&1 || true
  fi

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl hyprpaper unload all >/dev/null 2>&1 || true
    hyprctl hyprpaper preload "$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
    hyprctl hyprpaper wallpaper ",$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
  fi
  generate_palette
}

serve_hyprpaper() {
  restore_persistent_wallpaper
  write_config
  if ! command -v hyprpaper >/dev/null 2>&1; then
    printf 'seven-wallpaper: hyprpaper is not installed.\n' >&2
    exit 1
  fi

  hyprpaper >/tmp/sevenos-hyprpaper.log 2>&1 &
  local hyprpaper_pid="$!"
  trap 'kill "$hyprpaper_pid" >/dev/null 2>&1 || true' INT TERM EXIT

  sleep 0.6
  if command -v hyprctl >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    hyprctl hyprpaper unload all >/dev/null 2>&1 || true
    hyprctl hyprpaper preload "$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
    hyprctl hyprpaper wallpaper ",$ACTIVE_WALLPAPER" >/dev/null 2>&1 || true
  fi

  while kill -0 "$hyprpaper_pid" >/dev/null 2>&1; do
    if wallpaper_rotation_enabled; then
      sleep "$(rotation_interval_seconds)"
      if wallpaper_rotation_enabled; then
        rotate_wallpaper_once >/dev/null || true
        SEVENOS_WALLPAPER_NO_SYSTEMD=1 apply_live || true
      fi
    else
      wait "$hyprpaper_pid"
      return $?
    fi
  done
}

restart_hyprpaper() {
  write_config

  if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    apply_live
  fi
}

print_status() {
  local profile profile_state profile_active profile_custom
  profile="$(active_profile)"
  profile_state="$(profile_state_file "$profile")"
  profile_active="$(profile_active_wallpaper "$profile")"
  profile_custom="$(profile_custom_wallpaper "$profile")"
  printf 'SevenOS wallpaper status\n'
  printf '  profile:     %s\n' "$profile"
  printf '  repo svg:    %s\n' "$SOURCE_SVG"
  printf '  collection:  %s\n' "$COLLECTION_MANIFEST"
  printf '  copied svg:  %s\n' "$TARGET_SVG"
  printf '  rendered png:%s\n' "$TARGET_PNG"
  printf '  custom png:  %s\n' "$profile_custom"
  printf '  profile png: %s\n' "$profile_active"
  printf '  active png:  %s\n' "$ACTIVE_WALLPAPER"
  printf '  hypr config: %s\n' "$HYPRPAPER_CONFIG"
  printf '  state file:  %s\n' "$profile_state"
  printf '  global last: %s\n' "$GLOBAL_STATE_FILE"
  printf '  rotation:    %s\n' "$(profile_rotation_file "$profile")"
  if [[ -f "$profile_state" ]]; then
    printf '  state mode:  %s\n' "$(wallpaper_state_value mode 2>/dev/null || printf unknown)"
    printf '  state value: %s\n' "$(wallpaper_state_value value 2>/dev/null || printf unknown)"
  else
    printf '  state mode:  profile-default\n'
  fi

  if [[ -f "$SOURCE_SVG" ]]; then
    printf '  repo svg sha: '
    sha256sum "$SOURCE_SVG" | awk '{print $1}'
  fi
  if [[ -f "$TARGET_PNG" ]]; then
    printf '  png sha:      '
    sha256sum "$TARGET_PNG" | awk '{print $1}'
    file "$TARGET_PNG" | sed 's/^/  /'
  else
    printf '  png: missing\n'
  fi
  if [[ -f "$ACTIVE_WALLPAPER" ]]; then
    printf '  active sha:  '
    sha256sum "$ACTIVE_WALLPAPER" | awk '{print $1}'
    file "$ACTIVE_WALLPAPER" | sed 's/^/  /'
  else
    printf '  active: missing\n'
  fi
  if [[ -f "$profile_active" ]]; then
    printf '  profile sha: '
    sha256sum "$profile_active" | awk '{print $1}'
  fi
  if [[ -f "$HYPRPAPER_CONFIG" ]]; then
    printf '\nCurrent hyprpaper config:\n'
    sed 's/^/  /' "$HYPRPAPER_CONFIG"
  fi
  printf '\nRotation:\n'
  rotation_json | sed 's/^/  /'
  if command -v pgrep >/dev/null 2>&1; then
    printf '\nProcesses:\n'
    pgrep -a hyprpaper 2>/dev/null | sed 's/^/  /' || printf '  hyprpaper not running\n'
  fi
  if command -v systemctl >/dev/null 2>&1; then
    printf '\nService:\n'
    systemctl --user is-active "$SERVICE_NAME" 2>/dev/null | sed 's/^/  /' || printf '  unavailable\n'
  fi
}

case "${1:-refresh}" in
  render)
    render_wallpaper
    save_wallpaper_state default "$TARGET_PNG"
    write_config
    generate_palette
    printf '%s\n' "$TARGET_PNG"
    ;;
  refresh)
    restore_persistent_wallpaper
    generate_palette
    restart_hyprpaper
    printf 'SevenOS wallpaper refreshed: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  default|reset)
    render_profile_wallpaper "$(active_profile)"
    save_wallpaper_state profile "$(active_profile)"
    generate_palette
    restart_hyprpaper
    printf 'SevenOS wallpaper reset: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  set)
    set_custom_wallpaper "${2:-}"
    generate_palette
    restart_hyprpaper
    if command -v notify-send >/dev/null 2>&1; then
      notify-send "SevenOS Wallpaper" "Wallpaper updated from $(basename -- "${2:-image}")" || true
    fi
    printf 'SevenOS wallpaper set: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  profile)
    render_profile_wallpaper "${2:-}"
    generate_palette
    restart_hyprpaper
    printf 'SevenOS profile wallpaper set: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  collection|pack|dynamic)
    render_collection_wallpaper "${2:-}"
    save_wallpaper_state collection "${2:-}"
    generate_palette
    restart_hyprpaper
    printf 'SevenOS collection wallpaper set: %s\n' "$ACTIVE_WALLPAPER"
    ;;
  rotation)
    case "${2:-status}" in
      set)
        shift 2 || true
        set_wallpaper_rotation "$@"
        rotate_wallpaper_once >/dev/null || true
        generate_palette
        restart_hyprpaper
        ;;
      preset)
        set_wallpaper_rotation_preset "${3:-day}" "${4:-900}"
        rotate_wallpaper_once >/dev/null || true
        generate_palette
        restart_hyprpaper
        ;;
      once|next)
        rotate_wallpaper_once
        generate_palette
        restart_hyprpaper
        ;;
      off|disable|stop)
        disable_wallpaper_rotation
        restart_hyprpaper
        printf 'SevenOS wallpaper rotation disabled\n'
        ;;
      status|json)
        rotation_json
        ;;
      *)
        printf 'Usage: seven-wallpaper rotation [set INTERVAL_SECONDS SLUG...|preset NAME [INTERVAL_SECONDS]|once|off|status]\n' >&2
        exit 1
        ;;
    esac
    ;;
  collection-list|packs|list)
    collection_json
    ;;
  profiles)
    render_all_profile_wallpapers
    generate_palette
    printf 'SevenOS profile wallpapers generated in %s\n' "$WALLPAPER_DIR"
    ;;
  serve)
    serve_hyprpaper
    ;;
  status)
    print_status
    ;;
  path)
    printf '%s\n' "$ACTIVE_WALLPAPER"
    ;;
  *)
    printf 'Usage: seven-wallpaper [refresh|render|serve|status|path|set IMAGE|profile [PROFILE]|profiles|collection SLUG|collection-list|rotation ...]\n' >&2
    printf 'By default, set/reset/refresh are scoped to the active mini OS profile.\n' >&2
    exit 1
    ;;
esac
