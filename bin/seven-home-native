QUICK_ACTIONS = [
    ("Première configuration", "Langue, Wi-Fi, thème, espaces et Store.", "seven welcome"),
    ("Réglages", "Configurer SevenOS, les espaces et les appareils.", "seven-settings"),
    ("Espaces", "Changer d'espace SevenOS.", "seven profile center"),
    ("SevenStore", "Installer des apps graphiquement.", "seven store home"),
    ("Sauvegarde", "Créer une sauvegarde locale de SevenOS.", "seven recovery backup"),
    ("Actions", "Toutes les actions SevenOS en graphique.", "seven actions open"),
]

CACHE_HOME = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache"))
HOME_CACHE = CACHE_HOME / "sevenos/home-native.json"
HOME_CACHE_TTL = float(os.environ.get("SEVENOS_HOME_CACHE_TTL", "180"))


def run_json(*args: str, fallback=None, timeout: float = 3.0, extra_env: dict[str, str] | None = None):
    fallback = {} if fallback is None else fallback
    try:
        out = subprocess.check_output(
            [str(ROOT / "bin/seven"), *args],
            cwd=ROOT,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT), **(extra_env or {})},
            text=True,
            stderr=subprocess.DEVNULL,
            timeout=timeout,
        )
        return json.loads(out)
    except Exception:
        return fallback


def run_detached(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def read_home_cache() -> dict:
    if os.environ.get("SEVENOS_HOME_REFRESH") == "1":
        return {}
    try:
        if time.time() - HOME_CACHE.stat().st_mtime > HOME_CACHE_TTL:
            return {}
        return json.loads(HOME_CACHE.read_text(encoding="utf-8") or "{}")
    except Exception:
        return {}


def write_home_cache(payload: dict) -> None:
    try:
        HOME_CACHE.parent.mkdir(parents=True, exist_ok=True)
        tmp = HOME_CACHE.with_suffix(".tmp")
        tmp.write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
        tmp.replace(HOME_CACHE)
    except Exception:
        pass


def build_home_payload() -> dict:
    state = run_json("state", "--json", fallback={}, timeout=1.0)
    current = state.get("active_profile") if isinstance(state.get("active_profile"), dict) else {}
    if not current:
        current = run_json("profile", "current", "--json", fallback={}, timeout=1.0)
    health = state.get("health") if isinstance(state.get("health"), dict) else {}
    if not health:
        health = run_json("health", "status", "--json", fallback={}, timeout=1.2, extra_env={"SEVENOS_HEALTH_FAST": "1"})
    bridge = state.get("bridge") if isinstance(state.get("bridge"), dict) else {}
    if not bridge:
        bridge = run_json("bridge", "status", "--json", fallback={}, timeout=1.2)
    shell_experience = state.get("shell_experience") if isinstance(state.get("shell_experience"), dict) else {}
    if not shell_experience:
        shell_experience = run_json("experience", "status", "--json", fallback={}, timeout=1.0)
    motion = shell_experience.get("motion") if isinstance(shell_experience.get("motion"), dict) else {}
    if not motion:
        motion = run_json("motion", "status", "--json", fallback={}, timeout=1.0)
    atlas = state.get("atlas") if isinstance(state.get("atlas"), dict) else {}
    if not atlas:
        atlas = run_json("atlas", "status", "--json", fallback={}, timeout=1.2)
    atlas_summary = atlas.get("summary", {}) if isinstance(atlas.get("summary"), dict) else {}
    return {
        "schema": "sevenos.home.v1",
        "state": "ready",
        "active_profile": current.get("key", bridge.get("active_profile", "equinox")),
        "health": {
            "state": health.get("state", "unknown"),
            "score": health.get("score", 0),
        },
        "motion": {
            "preset": motion.get("preset", "unknown"),
            "mode": motion.get("mode", "auto"),
            "profile_motion": motion.get("profile_motion", ""),
        },
        "shell_experience": {
            "state": shell_experience.get("state", "unknown"),
            "profile_role": shell_experience.get("profile_role", ""),
            "recent_events": shell_experience.get("recent_events", [])[-4:],
            "recommendation": shell_experience.get("recommendation", {}),
            "warmup": shell_experience.get("feedback", {}).get("warmup_command", "seven experience warmup"),
        },
        "bridge": {
            "objects": bridge.get("object_count", 0),
            "profiles_ready": sum(1 for item in bridge.get("profiles", []) if item.get("ready")),
            "profiles_total": len(bridge.get("profiles", [])),
        },
        "atlas": {
            "mode": "explorer",
            "ready": bool(atlas_summary.get("ready", False)),
            "missing": int(atlas_summary.get("required_missing", 0) or 0),
        },
        "profiles": PROFILES,
        "quick_actions": [{"title": title, "description": desc, "command": command} for title, desc, command in QUICK_ACTIONS],
    }


def home_payload() -> dict:
    cached = read_home_cache()
    if cached.get("schema") == "sevenos.home.v1":
        return cached
    payload = build_home_payload()
    write_home_cache(payload)
    return payload


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


