#!/usr/bin/env python3
"""SevenOS Home: native public landing surface for mini OS experiences."""

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python3")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python.resolve():
            return
        result = subprocess.run(
            [str(system_python), "-c", "import gi"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
        if result.returncode == 0:
            env = {**os.environ, "SEVENOS_GI_PYTHON": "1"}
            os.execve(str(system_python), [str(system_python), str(Path(__file__).resolve()), *sys.argv[1:]], env)


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").is_file():
        return Path(env_root).resolve()
    candidate = Path(__file__).resolve().parent.parent
    if (candidate / "bin/seven").is_file():
        return candidate
    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (path / "bin/seven").is_file():
            return path
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None

