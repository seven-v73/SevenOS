class SevenHome:
    def __init__(self, Gtk, Gdk):
        self.Gtk = Gtk
        self.Gdk = Gdk
        self.payload = home_payload()
        self.window = None

    def label(self, text: str, css_class: str, xalign: float = 0.0):
        widget = self.Gtk.Label(label=text)
        widget.set_xalign(xalign)
        widget.set_line_wrap(True)
        widget.get_style_context().add_class(css_class)
        return widget

    def button(self, label: str, command: str, css_class: str = "soft"):
        button = self.Gtk.Button(label=label)
        button.get_style_context().add_class(css_class)
        button.connect("clicked", lambda _button: run_detached(command))
        return button

    def hero(self):
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("hero")
        active = self.payload.get("active_profile", "equinox")
        health = self.payload.get("health", {})
        motion = self.payload.get("motion", {})
        shell_experience = self.payload.get("shell_experience", {})
        bridge = self.payload.get("bridge", {})

        box.pack_start(self.label("SEVENOS HOME", "eyebrow"), False, False, 0)
        box.pack_start(self.label("Tes espaces SevenOS", "title"), False, False, 0)
        box.pack_start(
            self.label(
                "Choisis ton espace, reprends tes activités, ouvre les réglages et garde tes fichiers bien rangés.",
                "subtitle",
            ),
            False,
            False,
            0,
        )

        health_score = int(health.get("score", 0) or 0)
        ready_count = int(bridge.get("profiles_ready", 0) or 0)
        total_count = int(bridge.get("profiles_total", 0) or 0)
        health_text = "SevenOS est prêt" if health_score >= 80 else "Configuration à vérifier"
        spaces_text = "Espaces prêts" if total_count and ready_count >= total_count else "Préparation possible"
        interface_text = "Interface fluide" if str(shell_experience.get("state", "")).lower() in {"ready", "prête", "ok"} else "Interface disponible"
        row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
        for text in (
            f"Espace: {active}",
            health_text,
            interface_text,
            spaces_text,
        ):
            pill = self.label(text, "pill")
            row.pack_start(pill, False, False, 0)
        box.pack_start(row, False, False, 0)

        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
        recommendation = shell_experience.get("recommendation", {})
        actions.pack_start(self.button("Changer d’espace", "seven profile center", "primary"), False, False, 0)
        actions.pack_start(self.button("Réglages", "seven-settings", "soft"), False, False, 0)
        actions.pack_start(self.button("Fluidifier", shell_experience.get("warmup", "seven experience warmup"), "soft"), False, False, 0)
        if recommendation.get("command"):
            actions.pack_start(self.button(str(recommendation.get("title", "Continuer")), str(recommendation.get("command")), "soft"), False, False, 0)
        actions.pack_start(self.button("SevenStore", "seven store home", "soft"), False, False, 0)
        box.pack_start(actions, False, False, 0)
        return box

    def quick_actions(self):
        outer = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        outer.pack_start(self.label("Actions grand public", "section-title"), False, False, 0)
        grid = self.Gtk.FlowBox()
        grid.set_selection_mode(self.Gtk.SelectionMode.NONE)
        grid.set_max_children_per_line(3)
        grid.set_column_spacing(10)
        grid.set_row_spacing(10)
        for title, desc, command in QUICK_ACTIONS:
            card = self.action_card(title, desc, command)
            grid.add(card)
        outer.pack_start(grid, False, False, 0)
        return outer

    def action_card(self, title: str, desc: str, command: str):
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        box.set_size_request(250, 126)
        box.get_style_context().add_class("card")
        box.pack_start(self.label(title, "card-title"), False, False, 0)
        box.pack_start(self.label(desc, "card-body"), True, True, 0)
        box.pack_start(self.button("Ouvrir", command, "soft"), False, False, 0)
        return box

    def profile_grid(self):
        outer = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        outer.pack_start(self.label("Espaces SevenOS", "section-title"), False, False, 0)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(4)
        flow.set_column_spacing(10)
        flow.set_row_spacing(10)
        active = self.payload.get("active_profile", "equinox")
        for profile in PROFILES:
            flow.add(self.profile_card(profile, active))
        outer.pack_start(flow, False, False, 0)
        return outer

    def profile_card(self, profile: dict, active: str):
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        box.set_size_request(240, 174)
        box.get_style_context().add_class("card")
        if profile["key"] == active:
            box.get_style_context().add_class("active-card")

        accent = self.Gtk.DrawingArea()
        accent.set_size_request(1, 4)
        color = profile.get("accent", "#8B7CFF")

        def draw(_widget, cr):
            rgba = self.Gdk.RGBA()
            rgba.parse(color)
            cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, 1.0)
            cr.rectangle(0, 0, 240, 4)
            cr.fill()
            return False

        accent.connect("draw", draw)
        box.pack_start(accent, False, False, 0)
        box.pack_start(self.label(profile["title"], "card-title"), False, False, 0)
        box.pack_start(self.label(profile["subtitle"], "card-subtitle"), False, False, 0)
        box.pack_start(self.label(profile["mood"], "card-body"), True, True, 0)
        row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
        row.pack_start(self.button("Activer", profile["command"], "primary" if profile["key"] != active else "soft"), False, False, 0)
        row.pack_start(self.button("Ouvrir", profile["open"], "soft"), False, False, 0)
        box.pack_start(row, False, False, 0)
        return box

    def build(self):
        self.window = self.Gtk.Window(title="SevenOS Home")
        self.window.set_default_size(1180, 760)
        self.window.set_position(self.Gtk.WindowPosition.CENTER)
        self.window.get_style_context().add_class("seven-home")
        self.window.connect("destroy", self.Gtk.main_quit)
        self.window.connect("key-press-event", self.on_key_press)

        provider = self.Gtk.CssProvider()
        base = seven_theme.gtk_app_css("home") if seven_theme else ""
        provider.load_from_data((base + CSS).encode("utf-8"))
        self.Gtk.StyleContext.add_provider_for_screen(
            self.Gdk.Screen.get_default(),
            provider,
            self.Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=18)
        root.get_style_context().add_class("root")
        root.pack_start(self.hero(), False, False, 0)
        root.pack_start(self.profile_grid(), False, False, 0)
        root.pack_start(self.quick_actions(), False, False, 0)

        scroll = self.Gtk.ScrolledWindow()
        scroll.set_policy(self.Gtk.PolicyType.NEVER, self.Gtk.PolicyType.AUTOMATIC)
        scroll.add(root)
        self.window.add(scroll)
        self.window.show_all()

    def on_key_press(self, _widget, event) -> bool:
        if event.keyval in (self.Gdk.KEY_Escape, self.Gdk.KEY_q):
            self.Gtk.main_quit()
            return True
        return False


def run_app() -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, Gtk

    app = SevenHome(Gtk, Gdk)
    app.build()
    Gtk.main()
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    if "--json" in sys.argv:
        print(json.dumps(home_payload(), indent=2, ensure_ascii=False))
        return 0
    return run_app()


if __name__ == "__main__":
    raise SystemExit(main())
