    active = os.environ.get("SEVENOS_ACTIVE_PROFILE", "").lower()
    actions = {
        "forge": [
            (t("Forge · État Git", "Forge · Git Status"), ["bash", "-lc", "git status --short --branch; printf '\\nPress Enter...'; read -r"]),
            (t("Forge · Commits récents", "Forge · Recent Commits"), ["bash", "-lc", "git log --oneline --decorate -8 2>/dev/null || echo 'Not a git repository'; printf '\\nPress Enter...'; read -r"]),
            (t("Forge · Doctor projet", "Forge · Project Doctor"), ["bash", "-lc", "for f in package.json pyproject.toml Cargo.toml Dockerfile compose.yml docker-compose.yml; do [ -e \"$f\" ] && echo \"found $f\"; done; printf '\\nPress Enter...'; read -r"]),
        ],
        "cyber": [
            (t("Shield · Ports ouverts", "Shield · Listening Ports"), ["bash", "-lc", "ss -tulpn 2>/dev/null | head -80 || netstat -tulpn 2>/dev/null | head -80; printf '\\nPress Enter...'; read -r"]),
            (t("Shield · Hash du dossier", "Shield · Hash CWD Files"), ["bash", "-lc", "find . -maxdepth 1 -type f -printf '%f\\n' | sort | head -20 | xargs -r sha256sum; printf '\\nPress Enter...'; read -r"]),
            (t("Shield · Journaux sécurité", "Shield · Security Logs"), ["bash", "-lc", "journalctl -p warning -n 80 --no-pager 2>/dev/null || echo 'journalctl unavailable'; printf '\\nPress Enter...'; read -r"]),
        ],
        "admin": [
            (t("Admin · Espace disque", "Admin · Disk Usage"), ["bash", "-lc", "df -h; printf '\\n'; du -sh . 2>/dev/null; printf '\\nPress Enter...'; read -r"]),
