    def tool_button(label: str, tooltip: str, callback):
        button = Gtk.Button(label=label)
        button.set_relief(Gtk.ReliefStyle.NONE)
        button.get_style_context().add_class("terminal-tool")
        button.set_tooltip_text(tooltip)
        button.connect("clicked", lambda *_: callback())
        return button

    def prism_badge() -> Gtk.Box:
        badge = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=5)
        badge.get_style_context().add_class("terminal-prism-badge")
        badge.set_tooltip_text(role_hint)
        mark = Gtk.DrawingArea()
        mark.set_size_request(26, 26)
        mark.get_style_context().add_class("terminal-prism-mark")
        accent = PROFILE_ACCENTS.get(profile, wall_accent)
        glyph_text = PROFILE_GLYPHS.get(profile, "◇")

        def draw_mark(widget, cr) -> bool:
            allocation = widget.get_allocation()
            cx = allocation.width / 2
            cy = allocation.height / 2
            radius = min(allocation.width, allocation.height) * 0.34
            rgba = Gdk.RGBA()
            rgba.parse(accent)
            points = [
                (
                    cx + math.cos(-math.pi / 2 + index * math.pi / 3) * radius,
                    cy + math.sin(-math.pi / 2 + index * math.pi / 3) * radius,
                )
                for index in range(6)
            ]
            cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, 0.12)
            cr.arc(cx, cy, radius * 1.15, 0, math.pi * 2)
            cr.fill()
            cr.set_line_width(1.25)
            for point in points:
                cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, 0.34)
                cr.move_to(cx, cy)
                cr.line_to(*point)
                cr.stroke()
            cr.set_source_rgba(rgba.red, rgba.green, rgba.blue, 0.78)
            cr.move_to(*points[0])
            for point in points[1:]:
                cr.line_to(*point)
            cr.close_path()
            cr.stroke()
            if len(glyph_text) > 1:
                cr.select_font_face("Sans", 0, 1)
                cr.set_font_size(7.5)
                extents = cr.text_extents(glyph_text)
                cr.set_source_rgba(1, 1, 1, 0.78 if dark else 0.58)
                cr.move_to(cx - extents.width / 2 - extents.x_bearing, cy - extents.height / 2 - extents.y_bearing)
                cr.show_text(glyph_text)
                return False
            cr.set_source_rgba(1, 1, 1, 0.72 if dark else 0.52)
            cr.arc(cx, cy, 2.0, 0, math.pi * 2)
            cr.fill()
            return False

        mark.connect("draw", draw_mark)
        copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        name = Gtk.Label(label=profile_display_name(profile), xalign=0)
        name.get_style_context().add_class("terminal-profile-name")
        hint = Gtk.Label(label=profile_microcopy(profile), xalign=0)
        hint.get_style_context().add_class("terminal-profile-hint")
        copy.pack_start(name, False, False, 0)
        copy.pack_start(hint, False, False, 0)
        badge.pack_start(mark, False, False, 0)
        badge.pack_start(copy, False, False, 0)
        return badge

    profile_badge = prism_badge()
    titlebar.pack_start(profile_badge, False, False, 0)
    titlebar.reorder_child(profile_badge, 3)

