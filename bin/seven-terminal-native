            (t("Baobab · Documents", "Baobab · Documents"), ["bash", "-lc", "seven-files \"$HOME/Documents\"; printf '\\nPress Enter...'; read -r"]),
            (t("Baobab · Fichiers de lecture", "Baobab · Reading Files"), ["bash", "-lc", "find . -maxdepth 2 \\( -iname '*.pdf' -o -iname '*.epub' -o -iname '*.md' -o -iname '*.txt' \\) | head -60; printf '\\nPress Enter...'; read -r"]),
            (t("Baobab · Compter les mots", "Baobab · Word Count"), ["bash", "-lc", "find . -maxdepth 1 -type f \\( -iname '*.md' -o -iname '*.txt' \\) -print0 | xargs -0 -r wc -w; printf '\\nPress Enter...'; read -r"]),
        ],
        "studio": [
            (t("Studio · Médias", "Studio · Media Assets"), ["bash", "-lc", "find . -maxdepth 2 \\( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.mp4' -o -iname '*.wav' \\) | head -80; printf '\\nPress Enter...'; read -r"]),
