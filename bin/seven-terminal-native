def run_terminal(profile: str, command: list[str]) -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    gi.require_version("Vte", "2.91")
    from gi.repository import Gdk, GLib, Gtk, Pango, Vte
    GLib.set_prgname("SevenTerminalNative")
    GLib.set_application_name("Seven Terminal")
    try:
        Gdk.set_program_class("SevenTerminalNative")
    except Exception:
        pass

    theme = wallpaper_dynamic_theme(profile, THEMES.get(profile, THEMES["classic"]))
    dark = not (current_theme_mode() == "light" or profile in {"light", "focus"})
    clean_mode = os.environ.get("SEVENOS_TERMINAL_CLEAN", "1") != "0"
    show_profile_pill = os.environ.get("SEVENOS_TERMINAL_SHOW_PROFILE", "0") == "1"
    show_status = os.environ.get("SEVENOS_TERMINAL_STATUS", "0") == "1"
    saved_state = load_terminal_state(profile)
    try:
        saved_font_scale = float(saved_state.get("font_scale", 1.0))
    except (TypeError, ValueError):
        saved_font_scale = 1.0
    saved_font_scale = max(0.78, min(1.55, saved_font_scale))
    saved_window_size = saved_state.get("window_size") if isinstance(saved_state.get("window_size"), dict) else {}
    try:
        initial_width = int(saved_window_size.get("width", 760))
        initial_height = int(saved_window_size.get("height", 480))
    except (TypeError, ValueError):
        initial_width, initial_height = 760, 480
    initial_width = max(620, min(1800, initial_width))
    initial_height = max(380, min(1200, initial_height))
    title = "Seven Terminal" if clean_mode else f"Seven Terminal · {profile_display_name(profile)}"
    argv = command or [str(resolve_shell())]
    wall_accent = theme.get("wallpaper_accent", theme["cursor"])
    wall_secondary = theme.get("wallpaper_secondary", theme["selection"])
    wall_cyan = theme.get("wallpaper_cyan", theme["cursor"])
    terminal_alpha = float(os.environ.get("SEVENOS_TERMINAL_ALPHA", "0.66" if dark else "0.72"))
    terminal_alpha = max(0.38, min(0.98, terminal_alpha))
    frame_alpha = max(0.20, min(0.94, terminal_alpha + 0.06))
    notebook_alpha = max(0.18, min(0.92, terminal_alpha + 0.02))
    control_bg = f"alpha({wall_accent}, 0.10)" if dark else f"alpha({wall_accent}, 0.075)"
    control_bg_hover = f"alpha({wall_accent}, 0.18)" if dark else f"alpha({wall_accent}, 0.13)"
    control_border = f"alpha({wall_accent}, 0.18)" if dark else f"alpha({wall_accent}, 0.16)"
    panel_bg = f"alpha({theme['window']}, 0.98)" if dark else "#F8FAFD"
    panel_row_hover = "rgba(255,255,255,0.075)" if dark else "rgba(47,123,255,0.08)"
    panel_selected = "rgba(77,163,255,0.16)" if dark else "rgba(47,123,255,0.14)"
    dialog_border = "rgba(255,255,255,0.10)" if dark else "rgba(20,28,40,0.14)"

    base_css = seven_theme.gtk_app_css("terminal", current_theme_mode()) if seven_theme else ""
    css = base_css + f"""
    * {{
      font-family: "SF Pro Text", "SF UI Text", "San Francisco", system-ui, sans-serif;
    }}
    window.seven-window {{
      background: alpha({theme['window']}, {0.34 if dark else 0.26});
      border-radius: 20px;
      border: 1px solid alpha({wall_accent}, {0.22 if dark else 0.16});
      box-shadow:
        0 24px 72px rgba(0,0,0,{0.34 if dark else 0.12}),
        0 0 34px alpha({wall_accent}, {0.12 if dark else 0.10});
    }}
    .seven-titlebar {{
      min-height: 38px;
      padding: 0 12px;
      background:
        linear-gradient(90deg, alpha({wall_accent}, {0.12 if dark else 0.08}), alpha({wall_secondary}, {0.08 if dark else 0.06})),
        alpha({theme['titlebar']}, {0.82 if dark else 0.72});
      border-bottom: 1px solid {theme['titlebar_border']};
    }}
    .seven-title {{
      color: {theme['foreground']};
      font: 500 11px "SF Pro Text", "SF UI Text", "San Francisco", system-ui, sans-serif;
      letter-spacing: 0;
    }}
    .terminal-prism-badge {{
      min-height: 28px;
      padding: 0 9px 0 3px;
      margin: 0 9px 0 0;
      border-radius: 999px;
      background:
        linear-gradient(135deg, alpha({wall_accent}, {0.14 if dark else 0.10}), alpha({wall_secondary}, {0.10 if dark else 0.07})),
        {control_bg};
      border: 1px solid {control_border};
    }}
    .terminal-prism-mark {{
      min-width: 26px;
      min-height: 26px;
    }}
    .terminal-profile-name {{
      color: {theme['foreground']};
