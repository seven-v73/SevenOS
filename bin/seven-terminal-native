def show_native_palette(
    window,
    profile: str,
    terminal,
    new_tab,
    split_terminal,
    show_search,
    zoom_in=None,
    zoom_out=None,
    zoom_reset=None,
    duplicate_tab=None,
    rename_tab=None,
    reset_tab_title=None,
    new_window_here=None,
    toggle_transparency=None,
) -> None:
    from gi.repository import Gdk, Gtk, Pango

    dialog = Gtk.Dialog(title=t("Seven Terminal", "Seven Terminal"), transient_for=window, flags=Gtk.DialogFlags.MODAL)
    dialog.set_default_size(460, 520)
    dialog.get_style_context().add_class("palette-dialog")
    content = dialog.get_content_area()
    content.get_style_context().add_class("palette-surface")
    content.set_margin_top(16)
    content.set_margin_bottom(16)
    content.set_margin_start(16)
    content.set_margin_end(16)
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
    content.pack_start(box, True, True, 0)
    cwd = terminal_cwd(terminal) if terminal else os.getcwd()

    header = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    title_label = Gtk.Label(label=t("Palette Seven Terminal", "Seven Terminal Palette"), xalign=0)
    title_label.get_style_context().add_class("palette-title")
    subtitle_label = Gtk.Label(label=t("Actions rangées par session, projet, apparence et diagnostic", "Actions grouped by session, project, appearance and diagnostics"), xalign=0)
    subtitle_label.get_style_context().add_class("palette-subtitle")
    header.pack_start(title_label, False, False, 0)
    header.pack_start(subtitle_label, False, False, 0)
    box.pack_start(header, False, False, 0)

    hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    hero.get_style_context().add_class("palette-hero")
    hero_mark = Gtk.Label(label=PROFILE_GLYPHS.get(profile, "◇"))
    hero_mark.get_style_context().add_class("palette-hero-mark")
    hero_copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    hero_title = Gtk.Label(label=f"{profile_display_name(profile)} · {profile_microcopy(profile)}", xalign=0)
    hero_title.get_style_context().add_class("palette-hero-title")
    hero_subtitle = Gtk.Label(label=profile_role(profile)[1], xalign=0)
    hero_subtitle.set_line_wrap(True)
    hero_subtitle.get_style_context().add_class("palette-hero-subtitle")
    hero_copy.pack_start(hero_title, False, False, 0)
    hero_copy.pack_start(hero_subtitle, False, False, 0)
    hero.pack_start(hero_mark, False, False, 0)
    hero.pack_start(hero_copy, True, True, 0)
    box.pack_start(hero, False, False, 0)

    search = Gtk.SearchEntry()
    search.get_style_context().add_class("palette-search")
    search.set_placeholder_text(t("Chercher une action", "Type an action"))
    box.pack_start(search, False, False, 0)

    listbox = Gtk.ListBox()
    listbox.get_style_context().add_class("palette-list")
    listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
    scroller = Gtk.ScrolledWindow()
    scroller.get_style_context().add_class("palette-list")
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    scroller.set_min_content_height(340)
    scroller.add(listbox)
    box.pack_start(scroller, True, True, 0)

    actions: list[tuple[str, str, str, object]] = [
        (t("Session", "Session"), t("Nouvel onglet", "New Tab"), t("Ouvrir un autre shell dans ce dossier", "Open another shell in this folder"), lambda: new_tab(cwd)),
        (t("Session", "Session"), t("Dupliquer l’onglet", "Duplicate Tab"), t("Ouvrir un second shell au même endroit", "Open a second shell in the same folder"), duplicate_tab or (lambda: new_tab(cwd))),
        (t("Session", "Session"), t("Nouvelle fenêtre ici", "New Window Here"), t("Ouvrir un autre Seven Terminal dans ce dossier", "Open another Seven Terminal in this folder"), new_window_here or (lambda: run_detached(["seven-terminal", profile], cwd))),
        (t("Session", "Session"), t("Renommer l’onglet", "Rename Tab"), t("Donner un nom clair à cet espace", "Give this workspace a clear name"), rename_tab or (lambda: None)),
        (t("Session", "Session"), t("Réinitialiser le titre", "Reset Tab Title"), t("Revenir au nom automatique du dossier", "Return to automatic folder naming"), reset_tab_title or (lambda: None)),
        (t("Disposition", "Layout"), t("Scinder verticalement", "Split Vertical"), t("Créer deux panneaux côte à côte", "Create a side-by-side terminal pane"), lambda: split_terminal(Gtk.Orientation.HORIZONTAL)),
        (t("Disposition", "Layout"), t("Scinder horizontalement", "Split Horizontal"), t("Créer deux panneaux empilés", "Create a stacked terminal pane"), lambda: split_terminal(Gtk.Orientation.VERTICAL)),
        (t("Recherche", "Search"), t("Rechercher dans l’historique", "Search Scrollback"), t("Trouver du texte dans l’historique du terminal", "Find text in terminal history"), show_search),
        (t("Projet", "Project"), t("Ouvrir le dossier courant", "Open Current Folder"), cwd, lambda: run_detached(["seven-files", cwd], cwd)),
        (t("Projet", "Project"), t("Insérer le chemin courant", "Insert Current Path"), cwd, lambda: feed_terminal_text(terminal, shlex.quote(cwd))),
    ]
    if toggle_transparency:
        actions.append(
            (
                t("Apparence", "Appearance"),
                t("Fond transparent / opaque", "Toggle Transparent Background"),
                t("Basculer entre verre wallpaper et fond solide", "Switch between wallpaper glass and solid terminal background"),
                toggle_transparency,
            )
        )
    if zoom_in and zoom_out and zoom_reset:
        actions.extend(
            [
                (t("Apparence", "Appearance"), t("Texte plus grand", "Bigger Text"), t("Augmenter la taille du texte", "Increase text size for this terminal profile"), zoom_in),
                (t("Apparence", "Appearance"), t("Texte plus petit", "Smaller Text"), t("Réduire la taille du texte", "Decrease text size for this terminal profile"), zoom_out),
                (t("Apparence", "Appearance"), t("Taille normale", "Reset Text Size"), t("Revenir au texte à 100 %", "Return terminal text to 100%"), zoom_reset),
            ]
        )
    for label, command in profile_actions(profile, cwd):
        actions.append((t("Mini OS", "Mini OS"), label, t("Action contextuelle du mini OS actif", "Active mini OS contextual action"), lambda command=command: new_tab(cwd, command)))
    actions.extend(
        [
            (t("Projet", "Project"), t("Copier le dossier courant", "Copy Working Directory"), cwd, lambda: copy_text_to_clipboard(cwd)),
            (t("Assistance", "Assistance"), t("Expliquer la dernière commande", "Explain Last Command"), t("Demander de l’aide terminal à SevenAI", "Ask SevenAI for terminal help"), lambda: new_tab(cwd, ["bash", "-lc", "seven ai terminal; printf '\\nPress Enter...'; read -r"])),
            (t("Diagnostic", "Diagnostics"), t("Doctor terminal", "Terminal Doctor"), t("Vérifier la santé de Seven Terminal", "Check Seven Terminal health"), lambda: new_tab(cwd, ["bash", "-lc", "seven-terminal status; printf '\\nPress Enter...'; read -r"])),
            (t("Changer d’espace", "Switch Space"), t("Ouvrir Forge", "Switch Forge"), t("Terminal développement", "Development terminal"), lambda: run_detached(["seven-terminal", "forge"], cwd)),
            (t("Changer d’espace", "Switch Space"), t("Ouvrir Shield", "Switch Cyber"), t("Terminal sécurité", "Security terminal"), lambda: run_detached(["seven-terminal", "cyber"], cwd)),
            (t("Changer d’espace", "Switch Space"), t("Ouvrir Focus", "Switch Focus"), t("Terminal calme pour lecture/écriture", "Quiet writing terminal"), lambda: run_detached(["seven-terminal", "focus"], cwd)),
            (t("Changer d’espace", "Switch Space"), t("Ouvrir Admin", "Switch Admin"), t("Terminal système prudent", "Cautious system-control terminal"), lambda: run_detached(["seven-terminal", "admin"], cwd)),
            (t("Changer d’espace", "Switch Space"), t("Ouvrir Windows", "Switch Windows"), t("Terminal passerelle et compatibilité", "Bridge and compatibility terminal"), lambda: run_detached(["seven-terminal", "windows"], cwd)),
        ]
    )

    rows = []
    seen_sections = set()

    def add_section(title: str) -> None:
        if title in seen_sections:
            return
        seen_sections.add(title)
        row = Gtk.ListBoxRow()
        row.get_style_context().add_class("palette-section")
        row.set_selectable(False)
        row.set_activatable(False)
        row.seven_terms = title.lower()
        row.seven_callback = None
        label = Gtk.Label(label=title.upper(), xalign=0)
        label.get_style_context().add_class("palette-section-title")
        row.add(label)
        listbox.add(row)
        rows.append(row)

    def add_row(title: str, subtitle: str, callback) -> None:
        row = Gtk.ListBoxRow()
        row.get_style_context().add_class("palette-row")
        row.seven_terms = f"{title} {subtitle}".lower()
        row.seven_callback = callback
        row_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        row_box.set_margin_top(6)
        row_box.set_margin_bottom(6)
        row_box.set_margin_start(8)
        row_box.set_margin_end(8)
        row_title = Gtk.Label(label=title, xalign=0)
        row_title.get_style_context().add_class("palette-row-title")
        row_subtitle = Gtk.Label(label=subtitle, xalign=0)
        row_subtitle.set_ellipsize(Pango.EllipsizeMode.MIDDLE)
        row_subtitle.get_style_context().add_class("palette-row-subtitle")
        row_box.pack_start(row_title, False, False, 0)
        row_box.pack_start(row_subtitle, False, False, 0)
        row.add(row_box)
        listbox.add(row)
        rows.append(row)

    for section, title, subtitle, callback in actions:
        add_section(section)
        add_row(title, subtitle, callback)

    def filter_rows(*_args) -> None:
        query = search.get_text().strip().lower()
        first_visible = None
        for row in rows:
            is_section = getattr(row, "seven_callback", None) is None
            visible = (not query and is_section) or (not is_section and (not query or all(part in row.seven_terms for part in query.split())))
            row.set_visible(visible)
            if visible and first_visible is None and not is_section:
                first_visible = row
        if first_visible:
            listbox.select_row(first_visible)

    def activate_row(_box, row) -> None:
        if not row:
            return
        callback = getattr(row, "seven_callback", None)
        if not callback:
            return
        callback()
        dialog.response(Gtk.ResponseType.CLOSE)

    search.connect("search-changed", filter_rows)
    search.connect("activate", lambda *_: activate_row(listbox, listbox.get_selected_row()))
    search.connect("key-press-event", lambda _entry, event: dialog.response(Gtk.ResponseType.CLOSE) if (Gdk.keyval_name(event.keyval) or "").lower() == "escape" else False)
    listbox.connect("row-activated", activate_row)
    dialog.show_all()
    filter_rows()
    search.grab_focus()
    dialog.run()
    dialog.destroy()


def copy_text_to_clipboard(text: str) -> None:
    from gi.repository import Gdk, Gtk

    Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD).set_text(text, -1)


def traffic_button(style: str, tooltip: str, callback):
    from gi.repository import Gdk, Gtk

    colors = {
        "close": ("#ff5f57", "#d8463f"),
        "min": ("#febc2e", "#d9a023"),
        "max": ("#28c840", "#1fa334"),
    }
    fill, stroke = colors.get(style, ("#d0d0d0", "#a0a0a0"))

    event_box = Gtk.EventBox()
    event_box.set_visible_window(False)
    event_box.set_above_child(True)
    event_box.set_tooltip_text(tooltip)
    event_box.add_events(Gdk.EventMask.BUTTON_PRESS_MASK | Gdk.EventMask.BUTTON_RELEASE_MASK)
    event_box.connect("button-press-event", lambda _widget, event: activate_traffic(event, callback))

    area = Gtk.DrawingArea()
    area.set_size_request(15, 15)
    area.get_style_context().add_class("traffic")
    area.get_style_context().add_class(style)
    area.connect("draw", draw_traffic_light, fill, stroke, style)
    event_box.add(area)
    return event_box


def activate_traffic(event, callback) -> bool:
    if getattr(event, "button", 0) == 1:
        callback()
        return True
    return False


def draw_traffic_light(widget, cr, fill: str, stroke: str, style: str) -> bool:
    from gi.repository import Gdk

    allocation = widget.get_allocation()
    diameter = min(allocation.width, allocation.height)
    radius = max(4.0, (diameter / 2.0) - 1.0)
    center_x = allocation.width / 2.0
    center_y = allocation.height / 2.0

    fill_rgba = Gdk.RGBA()
    stroke_rgba = Gdk.RGBA()
    fill_rgba.parse(fill)
    stroke_rgba.parse(stroke)

    cr.set_source_rgba(fill_rgba.red, fill_rgba.green, fill_rgba.blue, fill_rgba.alpha)
    cr.arc(center_x, center_y, radius, 0, 6.28318)
    cr.fill_preserve()
    cr.set_line_width(1)
    cr.set_source_rgba(stroke_rgba.red, stroke_rgba.green, stroke_rgba.blue, 0.75)
    cr.stroke()
    draw_traffic_symbol(cr, style, center_x, center_y, radius)
    return False


def draw_traffic_symbol(cr, style: str, center_x: float, center_y: float, radius: float) -> None:
    cr.set_line_width(1.35)
    cr.set_line_cap(1)
    cr.set_source_rgba(0.20, 0.14, 0.10, 0.52)
    if style == "close":
        offset = radius * 0.38
        cr.move_to(center_x - offset, center_y - offset)
        cr.line_to(center_x + offset, center_y + offset)
        cr.move_to(center_x + offset, center_y - offset)
        cr.line_to(center_x - offset, center_y + offset)
    elif style == "min":
        offset = radius * 0.42
        cr.move_to(center_x - offset, center_y)
        cr.line_to(center_x + offset, center_y)
    elif style == "max":
        offset = radius * 0.36
        cr.move_to(center_x, center_y - offset)
        cr.line_to(center_x, center_y + offset)
        cr.move_to(center_x - offset, center_y)
        cr.line_to(center_x + offset, center_y)
    cr.stroke()


def toggle_zoom_or_tile(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE") and subprocess_run(["hyprctl", "dispatch", "togglefloating", "active"]) == 0:
        return
    if window.is_maximized():
        window.unmaximize()
        window.resize(760, 480)
    else:
        window.maximize()


def minimize_window(window) -> None:
    window.present()
    if os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        for command in (
            ["hyprctl", "dispatch", "movetoworkspacesilent", "special:seven"],
            ["hyprctl", "dispatch", "movetoworkspace", "special:seven"],
        ):
            if subprocess_run(command) == 0:
                return
    window.iconify()


def begin_move(window, event) -> bool:
    if getattr(event, "button", 0) == 1:
        window.begin_move_drag(event.button, int(event.x_root), int(event.y_root), event.time)
        return True
    return False


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--probe", action="store_true")
    parser.add_argument("--profile", choices=("classic", "dark", "light", "forge", "cyber", "focus", "admin", "windows"), default=os.environ.get("SEVENOS_TERMINAL_MODE", "classic"))
    parser.add_argument("command", nargs=argparse.REMAINDER)
    args = parser.parse_args()
    if args.probe:
        return probe()
    if args.profile == "classic" and current_theme_mode() == "light" and not os.environ.get("SEVENOS_TERMINAL_MODE"):
        args.profile = "light"
    command = args.command[1:] if args.command[:1] == ["--"] else args.command
    return run_terminal(args.profile, command)


if __name__ == "__main__":
    raise SystemExit(main())
