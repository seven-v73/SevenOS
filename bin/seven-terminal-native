#!/usr/bin/env python3
"""SevenOS native terminal surface with real traffic-light controls."""

from __future__ import annotations

import argparse
import json
import math
import os
import shlex
import subprocess
import sys
import time
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        probe_cmd = [str(system_python), "-c", "import gi"]
        if subprocess_run(probe_cmd) == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def subprocess_run(command: list[str]) -> int:
    import subprocess

    return subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gdk", "3.0")
        gi.require_version("Gtk", "3.0")
        gi.require_version("Vte", "2.91")
        from gi.repository import Gtk, Vte  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin").is_dir():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent.parent / "bin").is_dir():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin").is_dir():
            return candidate
    return Path.home()


ROOT_DIR = resolve_root()
sys.path.insert(0, str(ROOT_DIR / "scripts"))
try:
    from seven_i18n import language_code, tr_text  # noqa: E402
except Exception:  # pragma: no cover
    def language_code() -> str:
        return "en"

    def tr_text(text: str, **values: object) -> str:
        return text.format(**values) if values else text

try:
    import seven_theme  # noqa: E402
except Exception:  # pragma: no cover
    seven_theme = None

LANG_CODE = language_code()


def t(fr: str, en: str) -> str:
    return fr if LANG_CODE == "fr" else en


def resolve_shell() -> Path:
    root = ROOT_DIR
    for candidate in (root / "bin/seven-terminal-shell", Path.home() / ".local/bin/seven-terminal-shell"):
        if candidate.exists():
            return candidate
    return Path(os.environ.get("SHELL", "/bin/sh"))


def hex_to_rgba(value: str):
    value = value.lstrip("#")
    return tuple(int(value[index : index + 2], 16) / 255.0 for index in (0, 2, 4)) + (1.0,)


def hex_to_rgba_with_alpha(value: str, alpha: float):
    red, green, blue, _opaque = hex_to_rgba(value)
    return (red, green, blue, max(0.0, min(1.0, alpha)))


def terminal_state_file(profile: str) -> Path:
    state_root = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "sevenos"
    state_root.mkdir(parents=True, exist_ok=True)
    return state_root / f"terminal-session-{profile}.json"


def load_terminal_state(profile: str) -> dict:
    try:
        payload = json.loads(terminal_state_file(profile).read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    return payload if isinstance(payload, dict) else {}


def terminal_log_path(profile: str) -> Path:
    runtime_root = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "sevenos"
    runtime_root.mkdir(parents=True, exist_ok=True)
    return runtime_root / f"terminal-{profile}-{os.getpid()}.log"


def wallpaper_theme_state() -> dict:
    config = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos/wallpaper-theme.json"
    try:
        payload = json.loads(config.read_text(encoding="utf-8"))
        return payload if isinstance(payload, dict) else {}
    except Exception:
        return {}


def normalize_hex(value: str, fallback: str) -> str:
    value = str(value or "").strip()
    if not value.startswith("#"):
        value = f"#{value}"
    value = value[:7]
    if len(value) != 7:
        return fallback
    try:
        int(value[1:], 16)
        return value.upper()
    except ValueError:
        return fallback


def blend_hex(a: str, b: str, amount: float) -> str:
    amount = max(0.0, min(1.0, amount))
    a = normalize_hex(a, "#000000").lstrip("#")
    b = normalize_hex(b, "#000000").lstrip("#")
    values = []
    for index in (0, 2, 4):
        left = int(a[index : index + 2], 16)
        right = int(b[index : index + 2], 16)
        values.append(round(left * (1 - amount) + right * amount))
    return "#" + "".join(f"{value:02X}" for value in values)


def hex_rgb_int(value: str) -> tuple[int, int, int]:
    value = normalize_hex(value, "#000000").lstrip("#")
    return tuple(int(value[index : index + 2], 16) for index in (0, 2, 4))


def relative_luminance(value: str) -> float:
    channels = []
    for channel in hex_rgb_int(value):
        normalized = channel / 255.0
        if normalized <= 0.03928:
            channels.append(normalized / 12.92)
        else:
            channels.append(((normalized + 0.055) / 1.055) ** 2.4)
    return 0.2126 * channels[0] + 0.7152 * channels[1] + 0.0722 * channels[2]


def contrast_ratio(a: str, b: str) -> float:
    left = relative_luminance(a)
    right = relative_luminance(b)
    lighter = max(left, right)
    darker = min(left, right)
    return (lighter + 0.05) / (darker + 0.05)


def readable_wallpaper_color(value: str, backgrounds: list[str], fallback: str, target: float = 5.0) -> str:
    color = normalize_hex(value, fallback)
    if all(contrast_ratio(color, background) >= target for background in backgrounds):
        return color
    darkest_bg = min(backgrounds, key=relative_luminance)
    lightest_bg = max(backgrounds, key=relative_luminance)
    toward = "#F9FBFF" if relative_luminance(darkest_bg) < 0.42 else "#111827"
    if relative_luminance(darkest_bg) < 0.42 and relative_luminance(lightest_bg) > 0.68:
        toward = "#111827"
    for step in range(1, 19):
        candidate = blend_hex(color, toward, step / 18)
        if all(contrast_ratio(candidate, background) >= target for background in backgrounds):
            return candidate
    return toward


def wallpaper_dynamic_theme(profile: str, base: dict) -> dict:
    if os.environ.get("SEVENOS_TERMINAL_WALLPAPER", "1") == "0":
        return dict(base)
    payload = wallpaper_theme_state()
    colors = payload.get("colors", {}) if isinstance(payload.get("colors"), dict) else {}
    if not colors:
        return dict(base)
    mode = current_theme_mode()
    bg = normalize_hex(str(colors.get("background") or ""), base["window"])
    surface = normalize_hex(str(colors.get("surface") or ""), base["terminal"])
    accent = normalize_hex(str(colors.get("accent") or ""), base["cursor"])
    secondary = normalize_hex(str(colors.get("secondary") or ""), base["selection"])
    cyan = normalize_hex(str(colors.get("cyan") or ""), accent)
    wall_text = normalize_hex(str(colors.get("text") or ""), base["foreground"])
    dynamic = dict(base)
    if mode == "light" or profile in {"light", "focus"}:
        dynamic.update(
            {
                "window": blend_hex("#FFFFFF", surface, 0.18),
                "titlebar": blend_hex("#FFFFFF", surface, 0.12),
                "titlebar_border": blend_hex("#DDE3EA", accent, 0.24),
                "terminal": blend_hex("#FAFBFF", surface, 0.16),
                "selection": blend_hex("#CFE3FF", accent, 0.28),
                "cursor": accent,
            }
        )
        dynamic["foreground"] = readable_wallpaper_color(
            wall_text,
            [dynamic["terminal"], dynamic["window"], "#FFFFFF"],
            "#1C1F26",
            5.2,
        )
        dynamic["muted"] = readable_wallpaper_color(
            blend_hex(dynamic["foreground"], bg, 0.22),
            [dynamic["terminal"], dynamic["window"]],
            "#5C6472",
            3.4,
        )
    else:
        dynamic.update(
            {
                "window": blend_hex("#09090B", bg, 0.42),
                "titlebar": blend_hex("#12131A", surface, 0.44),
                "titlebar_border": blend_hex("#2B3548", accent, 0.34),
                "terminal": blend_hex("#09090B", bg, 0.26),
                "selection": blend_hex(secondary, accent, 0.32),
                "cursor": cyan,
            }
        )
        dynamic["foreground"] = readable_wallpaper_color(
            wall_text,
            [dynamic["terminal"], dynamic["window"], bg],
            "#F4F7FA",
            5.2,
        )
        dynamic["muted"] = readable_wallpaper_color(
            blend_hex(dynamic["foreground"], surface, 0.26),
            [dynamic["terminal"], dynamic["window"], bg],
            "#AEB8C6",
            3.6,
        )
    dynamic["wallpaper_accent"] = accent
    dynamic["wallpaper_secondary"] = secondary
    dynamic["wallpaper_cyan"] = cyan
    dynamic["wallpaper_source"] = str(payload.get("source") or "wallpaper")
    return dynamic


def current_theme_mode() -> str:
    env_mode = os.environ.get("SEVENOS_THEME_MODE", "").strip().lower()
    if env_mode in {"dark", "light"}:
        return env_mode
    config = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos/theme.conf"
    try:
        for raw in config.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = raw.partition("=")
            if key.strip().lower() in {"sevenos_theme_mode", "theme_mode", "mode"}:
                value = value.strip().strip("'\"").lower()
                if value in {"dark", "light"}:
                    return value
    except OSError:
        pass
    return "dark"


PROFILE_ROLES = {
    "classic": ("Equinox", t("Terminal quotidien, fichiers et commandes rapides", "Daily shell, files and quick commands")),
    "dark": ("Pulse", t("Session graphite pour jeux, monitoring et longues commandes", "Graphite shell for games, monitoring and long sessions")),
    "light": ("Equinox", t("Terminal clair et doux pour le travail de jour", "Soft light shell for daylight work")),
    "forge": ("Forge", t("Git, builds, tests et workflows projet", "Git, builds, tests and project workflows")),
    "cyber": ("Shield", t("Réseau, audit et investigation prudente", "Network, audit and cautious investigation")),
    "focus": ("Baobab", t("Écriture, lecture et travail long au calme", "Writing, reading and calm long-form work")),
    "admin": ("Admin", t("Contrôle système avec prudence renforcée", "System control with extra caution")),
    "windows": ("Windows", t("Dossiers passerelle, VM et compatibilité", "Bridge folders, VM and compatibility workflows")),
}


def profile_role(profile: str) -> tuple[str, str]:
    active = os.environ.get("SEVENOS_ACTIVE_PROFILE", "").lower()
    if profile == "dark" and active == "pulse":
        return ("Pulse", t("Jeux, captures, performance et longues sessions", "Games, captures, performance and long sessions"))
    if profile == "focus" and active == "studio":
        return ("Studio", t("Médias, assets et traitements créatifs", "Media, assets and creative batch work"))
    if profile == "focus" and active == "baobab":
        return ("Baobab", t("Documents, collections et lecture calme", "Documents, collections and calm reading"))
    if profile == "cyber" and active == "shield":
        return ("Shield", t("Réseau, audit et investigation prudente", "Network, audit and cautious investigation"))
    return PROFILE_ROLES.get(profile, PROFILE_ROLES["classic"])


