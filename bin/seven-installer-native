#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


ROOT = Path(os.environ.get("SEVENOS_ROOT", Path(__file__).resolve().parents[1]))


def language() -> str:
    value = os.environ.get("SEVENOS_LANGUAGE") or os.environ.get("LANG") or ""
    return "fr" if value.lower().startswith("fr") else "en"


LANG = language()


def tr(fr: str, en: str) -> str:
    return fr if LANG == "fr" else en


def run_json(command: list[str], fallback: dict | None = None, timeout: float = 12) -> dict:
    fallback = fallback or {}
    try:
        result = subprocess.run(
            command,
            cwd=ROOT,
            text=True,
            capture_output=True,
            check=False,
            timeout=timeout,
            env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        )
        return json.loads(result.stdout) if result.stdout.strip() else fallback
    except Exception:
        return fallback


def launch(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def payload() -> dict:
    experience = run_json([str(ROOT / "scripts/installer-experience.sh"), "json"], {"checks": [], "profiles": [], "summary": {}})
    portal = run_json([str(ROOT / "bin/seven-installer"), "status", "--json"], {})
    live = run_json([str(ROOT / "bin/seven-installer"), "live-status", "--json"], {})
    release = run_json([str(ROOT / "scripts/installer-stack.sh"), "release", "--json"], {})
    return {
        "schema": "sevenos.installer-native.v1",
        "state": experience.get("state", "unknown"),
        "score": experience.get("score", 0),
        "experience": experience,
        "portal": portal,
        "live": live,
        "release": release,
    }


def theme_mode() -> str:
    conf = Path.home() / ".config/sevenos/theme.conf"
    try:
        text = conf.read_text(encoding="utf-8", errors="ignore").lower()
        if "light" in text:
            return "light"
    except Exception:
        pass
    return "dark"


def ensure_gtk() -> None:
    try:
        import gi  # noqa: F401
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"seven-installer-native: GTK unavailable: {exc}", file=sys.stderr)
        sys.exit(1)


def state_icon(state: str) -> str:
    return "✓" if state == "OK" else "!"


def main() -> int:
    if "--probe" in sys.argv:
        print(json.dumps({"schema": "sevenos.installer-native.probe.v1", "state": "OK", "root": str(ROOT)}, ensure_ascii=False))
        return 0
    if "--json" in sys.argv:
        print(json.dumps(payload(), ensure_ascii=False, indent=2))
        return 0
    ensure_gtk()
    import gi

    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    data = payload()
    experience = data.get("experience", {}) if isinstance(data.get("experience"), dict) else {}
    portal = data.get("portal", {}) if isinstance(data.get("portal"), dict) else {}
    live = data.get("live", {}) if isinstance(data.get("live"), dict) else {}
    live_ui = live.get("ui", {}) if isinstance(live.get("ui"), dict) else {}
    summary = experience.get("summary", {}) if isinstance(experience.get("summary"), dict) else {}
    hardware = experience.get("hardware", {}) if isinstance(experience.get("hardware"), dict) else {}
    gpu = experience.get("gpu", {}) if isinstance(experience.get("gpu"), dict) else {}

    if theme_mode() == "light":
        css = b"""
    window { background: transparent; }
    .installer-root {
      background: alpha(#f7f9ff, .96);
      color: #172033;
      border: 1px solid alpha(#7f8caf, .28);
      border-radius: 28px;
      box-shadow: 0 22px 70px alpha(#111827, .28);
    }
    .installer-title { font-size: 28px; font-weight: 500; letter-spacing: 0; }
    .installer-subtitle { color: alpha(#344156, .80); font-size: 13px; }
    .installer-card {
      background: alpha(#ffffff, .74);
      border: 1px solid alpha(#8290b1, .20);
      border-radius: 18px;
      padding: 16px;
    }
    .installer-card-strong {
      background: linear-gradient(135deg, alpha(#dfe9ff, .92), alpha(#f8fbff, .88));
      border-color: alpha(#7c8cff, .32);
    }
	    .installer-metric { font-size: 24px; font-weight: 500; }
	    .installer-progress trough { min-height: 8px; border-radius: 999px; background: alpha(#c7d2fe, .32); }
	    .installer-progress progress { min-height: 8px; border-radius: 999px; background: linear-gradient(90deg, #5b86ff, #7c5cff); }
	    .installer-small { color: alpha(#40506a, .74); font-size: 12px; }
    .installer-section { font-size: 11px; font-weight: 500; color: alpha(#40506a, .72); letter-spacing: 1px; }
    button {
      min-height: 38px;
      border-radius: 999px;
      border: 1px solid alpha(#7d8bb0, .24);
      background: alpha(#ffffff, .72);
      color: #172033;
      padding: 0 16px;
      font-weight: 500;
    }
    button.suggested-action {
      background: linear-gradient(135deg, #5b86ff, #7c5cff);
      color: white;
      border-color: alpha(#5b86ff, .6);
    }
    .state-ok { color: #1b9b64; font-weight: 500; }
    .state-warn { color: #b7791f; font-weight: 500; }
    """
    else:
        css = b"""
    window { background: transparent; }
      .installer-root {
        background: alpha(#080d18, .96);
        color: #f4f7ff;
        border-color: alpha(#8fa2ff, .22);
        border-radius: 28px;
      }
      .installer-title { font-size: 28px; font-weight: 500; letter-spacing: 0; }
      .installer-card {
        background: alpha(#121827, .76);
        border-color: alpha(#b8c3ff, .14);
        border-radius: 18px;
        padding: 16px;
      }
      .installer-card-strong {
        background: linear-gradient(135deg, alpha(#17213b, .96), alpha(#0e1422, .92));
      }
      .installer-subtitle, .installer-small, .installer-section { color: alpha(#d9e2ff, .70); }
	      .installer-metric { font-size: 24px; font-weight: 500; }
	      .installer-progress trough { min-height: 8px; border-radius: 999px; background: alpha(#dbe5ff, .12); }
	      .installer-progress progress { min-height: 8px; border-radius: 999px; background: linear-gradient(90deg, #5b86ff, #7c5cff); }
	      .installer-section { font-size: 11px; font-weight: 500; letter-spacing: 1px; }
      button {
        min-height: 38px;
        border-radius: 999px;
        background: alpha(#192234, .78);
        color: #f4f7ff;
        border-color: alpha(#c0c8ff, .18);
        padding: 0 16px;
        font-weight: 500;
      }
      button.suggested-action {
        background: linear-gradient(135deg, #5b86ff, #7c5cff);
        color: white;
        border-color: alpha(#5b86ff, .6);
      }
      .state-ok { color: #63d79b; font-weight: 500; }
      .state-warn { color: #f3c76d; font-weight: 500; }
    """
    provider = Gtk.CssProvider()
    provider.load_from_data(css)
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title="SevenOS Installer")
    window.set_default_size(980, 660)
    window.set_size_request(760, 520)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
    root.set_border_width(22)
    root.get_style_context().add_class("installer-root")
    window.add(root)

    header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
    copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
    title = Gtk.Label(label=str(live_ui.get("title") or tr("Installer SevenOS", "Install SevenOS")), xalign=0)
    title.get_style_context().add_class("installer-title")
    subtitle = Gtk.Label(
        label=str(live_ui.get("subtitle") or tr(
            "Un parcours graphique : matériel, pilotes, profil de départ, installation et post-install.",
            "A graphical route: hardware, drivers, starting profile, installation and post-install.",
        )),
        xalign=0,
    )
    subtitle.set_line_wrap(True)
    subtitle.get_style_context().add_class("installer-subtitle")
    copy.pack_start(title, False, False, 0)
    copy.pack_start(subtitle, False, False, 0)
    header.pack_start(copy, True, True, 0)
    score = Gtk.Label(label=str(live_ui.get("progress_label") or f"{experience.get('score', 0)}%"))
    score.get_style_context().add_class("installer-metric")
    header.pack_start(score, False, False, 0)
    root.pack_start(header, False, False, 0)

    hero = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    root.pack_start(hero, False, False, 0)

    def metric(value: str, label: str) -> Gtk.Box:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        box.get_style_context().add_class("installer-card")
        value_label = Gtk.Label(label=value, xalign=0)
        value_label.get_style_context().add_class("installer-metric")
        note = Gtk.Label(label=label, xalign=0)
        note.get_style_context().add_class("installer-small")
        box.pack_start(value_label, False, False, 0)
        box.pack_start(note, False, False, 0)
        return box

    hero.pack_start(metric(str(live_ui.get("safety_level") or portal.get("state", "unknown")), tr("État", "State")), True, True, 0)
    hero.pack_start(metric(str(live_ui.get("primary_action_label") or portal.get("route", "unknown")), tr("Action", "Action")), True, True, 0)
    hero.pack_start(metric(f"{hardware.get('memory_gib', '?')} GiB", tr("Mémoire", "Memory")), True, True, 0)
    hero.pack_start(metric(str(summary.get("recommended_profile", "balanced")), tr("Profil conseillé", "Suggested profile")), True, True, 0)

    live_progress = Gtk.ProgressBar()
    live_progress.set_fraction(max(0, min(100, int(live.get("progress", 0) or 0))) / 100)
    live_progress.set_show_text(False)
    live_progress.get_style_context().add_class("installer-progress")
    root.pack_start(live_progress, False, False, 0)

    live_summary = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
    live_summary.get_style_context().add_class("installer-card")
    live_summary.get_style_context().add_class("installer-card-strong")
    decision_label = Gtk.Label(xalign=0)
    decision_label.get_style_context().add_class("installer-metric")
    decision_note_label = Gtk.Label(xalign=0)
    decision_note_label.set_line_wrap(True)
    decision_note_label.get_style_context().add_class("installer-small")
    attention_label = Gtk.Label(xalign=0)
    attention_label.set_line_wrap(True)
    attention_label.get_style_context().add_class("installer-small")
    active_step_label = Gtk.Label(xalign=0)
    next_step_label = Gtk.Label(xalign=0)
    priority_label = Gtk.Label(xalign=0)
    active_step_label.get_style_context().add_class("installer-small")
    next_step_label.get_style_context().add_class("installer-small")
    priority_label.get_style_context().add_class("installer-small")
    live_summary.pack_start(decision_label, False, False, 0)
    live_summary.pack_start(decision_note_label, False, False, 0)
    live_summary.pack_start(attention_label, False, False, 0)
    live_summary.pack_start(active_step_label, False, False, 0)
    live_summary.pack_start(next_step_label, False, False, 0)
    live_summary.pack_start(priority_label, False, False, 0)
    action_line = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    action_line.set_halign(Gtk.Align.START)
    primary_live_action = Gtk.Button()
    primary_live_action.get_style_context().add_class("suggested-action")
    primary_command_ref = {"command": "seven-installer live-status"}
    primary_live_action.connect("clicked", lambda _button: launch(primary_command_ref["command"]))
    action_line.pack_start(primary_live_action, False, False, 0)
    secondary_action_buttons = []
    for fallback_label, fallback_command in (
        (tr("État", "Status"), "seven-installer live-status"),
        (tr("Relancer", "Retry"), "seven-installer live-retry"),
        (tr("Disques", "Disks"), "gnome-disks"),
    ):
        command_ref = {"command": fallback_command}
        button = Gtk.Button(label=fallback_label)
        button.connect("clicked", lambda _button, ref=command_ref: launch(ref["command"]))
        action_line.pack_start(button, False, False, 0)
        secondary_action_buttons.append((button, command_ref))
    live_summary.pack_start(action_line, False, False, 0)
    root.pack_start(live_summary, False, False, 0)

    def apply_live_ui(next_live: dict) -> None:
        next_ui = next_live.get("ui", {}) if isinstance(next_live.get("ui"), dict) else {}
        progress = max(0, min(100, int(next_live.get("progress", 0) or 0)))
        live_progress.set_fraction(progress / 100)
        score.set_text(str(next_ui.get("progress_label") or f"{progress}%"))
        title.set_text(str(next_ui.get("title") or tr("Installer SevenOS", "Install SevenOS")))
        subtitle.set_text(str(next_ui.get("subtitle") or tr(
            "Un parcours graphique : matériel, pilotes, profil de départ, installation et post-install.",
            "A graphical route: hardware, drivers, starting profile, installation and post-install.",
        )))
        active = str(next_ui.get("active_step") or tr("Préparation SevenOS", "Preparing SevenOS"))
        following = str(next_ui.get("next_step") or tr("Vérification des prérequis", "Checking requirements"))
        priority = next_ui.get("priority_card", {}) if isinstance(next_ui.get("priority_card"), dict) else {}
        message = next_ui.get("user_message", {}) if isinstance(next_ui.get("user_message"), dict) else {}
        confidence = next_ui.get("confidence")
        pace = next_ui.get("pace_state") or "idle"
        eta = next_ui.get("estimated_remaining_seconds")
        eta_text = tr("presque prêt", "almost ready") if eta in (None, "") else tr(f"environ {eta}s", f"about {eta}s")
        primary_command_ref["command"] = str(next_ui.get("primary_command") or next_live.get("commands", {}).get("recommended") or "seven-installer live-status")
        primary_live_action.set_label(str(next_ui.get("primary_action_label") or tr("Voir l’état", "Inspect status")))
        secondary_actions = next_ui.get("secondary_actions", []) if isinstance(next_ui.get("secondary_actions"), list) else []
        for index, (button, command_ref) in enumerate(secondary_action_buttons):
            action = secondary_actions[index] if index < len(secondary_actions) and isinstance(secondary_actions[index], dict) else {}
            button.set_label(str(action.get("label") or button.get_label()))
            command_ref["command"] = str(action.get("command") or command_ref["command"])
        attention_items = next_ui.get("attention_items", []) if isinstance(next_ui.get("attention_items"), list) else []
        attention_text = " · ".join(str(item.get("title", "")) for item in attention_items[:3] if isinstance(item, dict) and item.get("title"))
        attention_label.set_text(tr(f"À surveiller : {attention_text}", f"Watch: {attention_text}") if attention_text else "")
        decision_label.set_text(str(message.get("headline") or tr("SevenOS prépare l’installation", "SevenOS is preparing installation")))
        decision_note_label.set_text(str(message.get("body") or next_ui.get("subtitle") or ""))
        active_step_label.set_text(tr(f"Maintenant : {active}", f"Now: {active}"))
        next_step_label.set_text(tr(f"Ensuite : {following}", f"Next: {following}"))
        priority_label.set_text(
            tr(
                f"Priorité : {priority.get('title', 'OK')} · rythme {pace} · {eta_text} · confiance {confidence}%",
                f"Priority: {priority.get('title', 'OK')} · pace {pace} · {eta_text} · confidence {confidence}%",
            )
        )

    apply_live_ui(live)

    def refresh_live_ui() -> bool:
        next_live = run_json([str(ROOT / "bin/seven-installer"), "live-status", "--json"], live, timeout=4)
        apply_live_ui(next_live)
        return True

    GLib.timeout_add_seconds(3, refresh_live_ui)

    scroller = Gtk.ScrolledWindow()
    scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    content.set_border_width(2)
    scroller.add(content)
    root.pack_start(scroller, True, True, 0)

    def section(text: str) -> None:
        label = Gtk.Label(label=text.upper(), xalign=0)
        label.get_style_context().add_class("installer-section")
        content.pack_start(label, False, False, 0)

    def info_card(title_text: str, value_text: str, note_text: str, command: str = "", state: str = "INFO") -> None:
        button = Gtk.Button()
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
        title_line = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        marker = Gtk.Label(label=state_icon("OK" if state == "ok" else "PART"))
        marker.get_style_context().add_class("state-ok" if state == "ok" else "state-warn")
        title_label = Gtk.Label(label=title_text, xalign=0)
        title_line.pack_start(marker, False, False, 0)
        title_line.pack_start(title_label, True, True, 0)
        value = Gtk.Label(label=value_text, xalign=0)
        value.get_style_context().add_class("installer-metric")
        note = Gtk.Label(label=note_text, xalign=0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("installer-small")
        box.pack_start(title_line, False, False, 0)
        box.pack_start(value, False, False, 0)
        box.pack_start(note, False, False, 0)
        button.add(box)
        button.get_style_context().add_class("installer-card")
        if command:
            button.connect("clicked", lambda _button, cmd=command: launch(cmd))
        content.pack_start(button, False, False, 0)

    def timeline_card(item: dict) -> None:
        state = str(item.get("state", "pending"))
        symbol = "✓" if state == "done" else "•" if state == "active" else "!" if state in {"blocked", "closed"} else "·"
        label = Gtk.Label(label=f"{symbol}  {item.get('title', '')}", xalign=0)
        label.get_style_context().add_class("state-ok" if state == "done" else "state-warn" if state in {"active", "blocked", "closed"} else "installer-small")
        content.pack_start(label, False, False, 0)

    def row(title_text: str, note_text: str, command: str, state: str = "INFO", primary: bool = False, confirm: bool = False) -> None:
        button = Gtk.Button()
        if primary:
            button.get_style_context().add_class("suggested-action")
        card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        marker = Gtk.Label(label=state_icon(state))
        marker.get_style_context().add_class("state-ok" if state == "OK" else "state-warn")
        text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        title_label = Gtk.Label(label=title_text, xalign=0)
        title_label.set_line_wrap(True)
        note = Gtk.Label(label=note_text, xalign=0)
        note.set_line_wrap(True)
        note.get_style_context().add_class("installer-small")
        text.pack_start(title_label, False, False, 0)
        text.pack_start(note, False, False, 0)
        action = Gtk.Label(label=tr("Ouvrir", "Open"))
        card.pack_start(marker, False, False, 0)
        card.pack_start(text, True, True, 0)
        card.pack_start(action, False, False, 0)
        button.add(card)
        button.get_style_context().add_class("installer-card")

        def on_click(_button) -> None:
            if confirm:
                dialog = Gtk.MessageDialog(
                    transient_for=window,
                    modal=True,
                    message_type=Gtk.MessageType.QUESTION,
                    buttons=Gtk.ButtonsType.CANCEL,
                    text=title_text,
                )
                dialog.format_secondary_text(tr("Cette étape peut modifier la machine. Continuer ?", "This step may change the machine. Continue?"))
                dialog.add_button(tr("Continuer", "Continue"), Gtk.ResponseType.OK)
                response = dialog.run()
                dialog.destroy()
                if response != Gtk.ResponseType.OK:
                    return
            launch(command)

        button.connect("clicked", on_click)
        content.pack_start(button, False, False, 0)

    live_cards = live_ui.get("status_cards", []) if isinstance(live_ui.get("status_cards"), list) else []
    if live_cards:
        section(tr("État de la session live", "Live session state"))
        for card in live_cards:
            info_card(
                str(card.get("title", "")),
                str(card.get("value", "")),
                str(card.get("detail", "")),
                str(card.get("action", "")),
                str(card.get("state", "INFO")),
            )

    live_timeline = live.get("timeline", []) if isinstance(live.get("timeline"), list) else []
    if live_timeline:
        section(tr("Progression SevenOS", "SevenOS progress"))
        for item in live_timeline[:9]:
            if isinstance(item, dict):
                timeline_card(item)

    section(tr("Étapes essentielles", "Essential steps"))
    calamares_command = "pkexec calamares -d" if portal.get("route") == "calamares" else "seven installer release"
    row(
        tr("Démarrer l’installation graphique", "Start graphical installation"),
        tr("Ouvre Calamares si le runtime est présent. Sinon affiche la route sûre restante.", "Opens Calamares when the runtime is present. Otherwise shows the remaining safe route."),
        calamares_command,
        "OK" if portal.get("route") == "calamares" else "PART",
        True,
        portal.get("route") == "calamares",
    )
    for item in experience.get("checks", []):
        row(str(item.get("title", "")), str(item.get("detail", "")), str(item.get("command", "seven installer experience")), str(item.get("state", "INFO")))

    section(tr("Profils de départ", "Starting profiles"))
    for profile in experience.get("profiles", []):
        label = f"{profile.get('title')} · {profile.get('mini_os')}"
        note = str(profile.get("goal", ""))
        row(label, note, str(profile.get("command", "seven universes")), "OK" if profile.get("recommended") else "INFO", confirm=True)

    section(tr("Pilotes et post-install", "Drivers and post-install"))
    row(
        tr("Conseil GPU", "GPU guidance"),
        f"{hardware.get('gpu_vendor', 'unknown')} · {', '.join(gpu.get('packages', [])[:5])}\n{gpu.get('note', '')}",
        str(gpu.get("command", "seven installer experience plan")),
        "OK",
    )
    row(
        tr("Assistant post-install", "Post-install assistant"),
        tr("Applique thèmes, profils, assets, splash, login, langues et vérifications après installation.", "Applies themes, profiles, assets, splash, login, languages and checks after installation."),
        "seven setup new-device --yes",
        "OK",
        confirm=True,
    )

    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    actions.set_halign(Gtk.Align.END)
    for label_text, command, primary in (
        (tr("Rapport", "Report"), "seven installer experience", False),
        (tr("Vérifier", "Verify"), "seven first-run verify", False),
        (tr("Fermer", "Close"), "", False),
    ):
        button = Gtk.Button(label=label_text)
        if primary:
            button.get_style_context().add_class("suggested-action")
        if command:
            button.connect("clicked", lambda _button, cmd=command: launch(cmd))
        else:
            button.connect("clicked", lambda *_: Gtk.main_quit())
        actions.pack_start(button, False, False, 0)
    root.pack_start(actions, False, False, 0)

    window.show_all()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
