#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/bin/sevenpkg" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/sevenpkg" ]]; then
    printf '%s\n' "$script_dir/.."
    return 0
  fi
  if [[ -x "$script_dir/../bin/sevenpkg" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -x "$candidate/bin/sevenpkg" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root || true)"

if command -v sevenpkg >/dev/null 2>&1; then
  sevenpkg_command=(sevenpkg)
elif [[ -n "$ROOT_DIR" && -x "$ROOT_DIR/bin/sevenpkg" ]]; then
  sevenpkg_command=("$ROOT_DIR/bin/sevenpkg")
else
  printf 'Profiles MISS\n'
  exit 0
fi

status="$("${sevenpkg_command[@]}" status 2>/dev/null || true)"
if [[ -z "$status" ]]; then
  printf 'Profiles MISS\n'
  exit 0
fi

ok_count="$(printf '%s\n' "$status" | awk '$2 == "OK" {count++} END {print count + 0}')"
part_count="$(printf '%s\n' "$status" | awk '$2 == "PART" {count++} END {print count + 0}')"

if [[ "$ok_count" -gt 0 ]]; then
  printf 'Profiles %s OK\n' "$ok_count"
elif [[ "$part_count" -gt 0 ]]; then
  printf 'Profiles %s PART\n' "$part_count"
else
  printf 'Profiles MISS\n'
fi
