#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/bin/seven" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$script_dir/seven" ]]; then
    printf '%s\n' "$script_dir/.."
    return 0
  fi
  if [[ -x "$script_dir/../bin/seven" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -x "$candidate/bin/seven" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root || true)"
export SEVENOS_ROOT="${ROOT_DIR:-${SEVENOS_ROOT:-}}"

if command -v seven >/dev/null 2>&1; then
  seven_command=(seven)
elif [[ -n "$ROOT_DIR" && -x "$ROOT_DIR/bin/seven" ]]; then
  seven_command=("$ROOT_DIR/bin/seven")
else
  printf 'Profile MISS\n'
  exit 0
fi

profile_json="$(SEVENOS_DRY_RUN=0 "${seven_command[@]}" profile status --json 2>/dev/null || true)"
if [[ -z "$profile_json" ]]; then
  if [[ "${1:-}" == "json" ]]; then
    printf '{"text":"󰐃","tooltip":"SevenOS profiles are unavailable. Click opens profile center.","class":"miss"}\n'
    exit 0
  fi
  printf 'Profile MISS\n'
  exit 0
fi

python - "$profile_json" "${1:-text}" <<'PY'
import json
import os
import sys
from pathlib import Path

root = Path(os.environ.get("SEVENOS_ROOT") or ".").resolve()
sys.path.insert(0, str(root / "scripts"))
try:
    from seven_i18n import tr_text
except Exception:
    def tr_text(text, **values):
        return text.format(**values) if values else text

try:
    profiles = json.loads(sys.argv[1])
except Exception:
    if len(sys.argv) > 2 and sys.argv[2] == "json":
        print(json.dumps({"text": "󰐃", "tooltip": tr_text("SevenOS profile state could not be parsed."), "class": "miss"}, ensure_ascii=False))
        raise SystemExit(0)
    print(tr_text("Profile MISS"))
    raise SystemExit(0)

mode = sys.argv[2] if len(sys.argv) > 2 else "text"
active = next((item for item in profiles if item.get("active")), None)
if active:
    title = active.get("title") or active.get("key") or tr_text("Profile")
    state = active.get("state") or "MISS"
    installed = active.get("installed", 0)
    total = active.get("total", 0)
    workspace = active.get("workspace") or tr_text("Workspace not configured")
    if mode == "json":
        cls = {"OK": "ok", "PART": "warn", "MISS": "miss"}.get(state, "warn")
        print(json.dumps({
            "text": "󰐃",
            "tooltip": tr_text("Profile: {title}\\nState: {state} · {installed}/{total}\\nWorkspace: {workspace}\\nClick opens profile center.", title=title, state=state, installed=installed, total=total, workspace=workspace),
            "class": cls,
        }, ensure_ascii=False))
        raise SystemExit(0)
    print(f"{title} {state}")
    raise SystemExit(0)

ok_count = sum(1 for item in profiles if item.get("state") == "OK")
part_count = sum(1 for item in profiles if item.get("state") == "PART")

if mode == "json":
    if ok_count:
        text = "󰐃"
        cls = "ok"
    elif part_count:
        text = "󰐃"
        cls = "warn"
    else:
        text = "󰐃"
        cls = "miss"
    print(json.dumps({
        "text": text,
        "tooltip": tr_text("Profiles ready: {ok_count}\\nProfiles partial: {part_count}\\nClick opens profile center.", ok_count=ok_count, part_count=part_count),
        "class": cls,
    }, ensure_ascii=False))
elif ok_count:
    print(tr_text("Profiles {count} OK", count=ok_count))
elif part_count:
    print(tr_text("Profiles {count} PART", count=part_count))
else:
    print(tr_text("Profile MISS"))
PY
