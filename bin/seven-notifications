#!/usr/bin/env bash
set -Eeuo pipefail

if command -v swaync >/dev/null 2>&1; then
  if [ "${SEVENOS_NOTIFICATIONS_KEEP_EXISTING:-0}" != "1" ]; then
    pkill -x mako >/dev/null 2>&1 || true
    pkill -x dunst >/dev/null 2>&1 || true
  fi
  exec swaync
fi

if command -v mako >/dev/null 2>&1; then
  exec mako
fi

printf 'seven-notifications: install swaync or mako for notifications.\n' >&2
exit 1
