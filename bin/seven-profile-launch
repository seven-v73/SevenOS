#!/usr/bin/env python3
"""Launch desktop apps through the active SevenOS mini OS boundary."""

from __future__ import annotations

import os
import json
import shlex
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent


def host_home() -> Path:
    if os.environ.get("SEVENOS_HOST_HOME"):
        return Path(os.environ["SEVENOS_HOST_HOME"])
    raw = Path(os.environ.get("SEVENOS_HOST_HOME", str(Path.home())))
    text = str(raw)
    marker = "/.local/share/sevenos/profile-containers/"
    if marker in text and text.endswith("/home"):
        return Path(text.split(marker, 1)[0])
    user = os.environ.get("USER")
    if user:
        candidate = Path("/home") / user
        if candidate.is_dir():
            return candidate
    return raw


CONFIG = Path(os.environ.get("SEVENOS_CONFIG_HOME", host_home() / ".config")) / "sevenos"


def read_language_env() -> dict[str, str]:
    out: dict[str, str] = {}
    host = host_home()
    for path in (
        Path(os.environ.get("XDG_CONFIG_HOME", str(host / ".config"))) / "sevenos/language.env",
        CONFIG / "language.env",
        host / ".config/sevenos/language.env",
    ):
        if not path.exists():
            continue
        try:
            lines = path.read_text(encoding="utf-8", errors="ignore").splitlines()
        except OSError:
            continue
        for raw in lines:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[len("export ") :]
            if "=" not in line:
                continue
            key, value = line.split("=", 1)
            key = key.strip()
            if key in {"SEVENOS_LANGUAGE", "LANG", "LANGUAGE", "LC_MESSAGES"}:
                out[key] = value.strip().strip("'\"")
        if out:
            break
    if out.get("LANG") and not out.get("SEVENOS_LANGUAGE"):
        out["SEVENOS_LANGUAGE"] = out["LANG"]
    if out.get("SEVENOS_LANGUAGE") and not out.get("LANG"):
        out["LANG"] = out["SEVENOS_LANGUAGE"]
    if out.get("SEVENOS_LANGUAGE") and not out.get("LANGUAGE"):
        out["LANGUAGE"] = out["SEVENOS_LANGUAGE"].split("_", 1)[0].split(".", 1)[0]
    if out.get("SEVENOS_LANGUAGE") and not out.get("LC_MESSAGES"):
        out["LC_MESSAGES"] = out["SEVENOS_LANGUAGE"]
    return out


def active_profile() -> str:
    try:
        for raw in (CONFIG / "profile.env").read_text(encoding="utf-8").splitlines():
            if raw.startswith("SEVENOS_ACTIVE_PROFILE="):
                return raw.split("=", 1)[1].strip().strip("'\"") or "equinox"
    except OSError:
        pass
    return os.environ.get("SEVENOS_ACTIVE_PROFILE", "equinox") or "equinox"


def desktop_exec(path: Path) -> list[str]:
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return []
    exec_line = ""
    for raw in lines:
        if raw.startswith("Exec="):
            exec_line = raw.split("=", 1)[1].strip()
            break
    if not exec_line:
        return []
    try:
        parts = shlex.split(exec_line)
    except ValueError:
        return []
    command: list[str] = []
    field_codes = {"%f", "%F", "%u", "%U", "%i", "%c", "%k", "%d", "%D", "%n", "%N", "%v", "%m"}
    for part in parts:
        if part in field_codes:
            continue
        command.append(part.replace("%%", "%"))
    return command


def is_sevenos_core(command: list[str]) -> bool:
    if not command:
        return False
    name = Path(command[0]).name
    return (
        name.startswith("seven-")
        or name == "seven"
        or name in {"hyprctl", "notify-send", "xdg-open", "gio", "gtk-launch"}
    )


def command_allowed(command: list[str]) -> tuple[bool, str]:
    if not command or is_sevenos_core(command):
        return True, ""
    name = Path(command[0]).name
    try:
        isolation = json.loads((CONFIG / "profile-isolation.json").read_text(encoding="utf-8"))
    except Exception:
        return True, ""
    inactive = set(isolation.get("inactive_commands") or [])
    active = set(isolation.get("active_commands") or [])
    if name in inactive and name not in active:
        selected = ", ".join(isolation.get("selected_profiles") or [active_profile()])
        return False, f"{name} belongs to another mini OS. Active runtime: {selected}."
    return True, ""


def main() -> int:
    if len(sys.argv) < 2:
        print("Usage: seven-profile-launch DESKTOP_ID [DESKTOP_PATH] [-- COMMAND...]", file=sys.stderr)
        return 2

    args = sys.argv[1:]
    desktop_id = args.pop(0)
    desktop_path = Path(args.pop(0)).expanduser() if args and args[0] != "--" else None
    if args and args[0] == "--":
        args = args[1:]

    command = args or (desktop_exec(desktop_path) if desktop_path else [])
    if not command:
        print(f"seven-profile-launch: no executable command for {desktop_id}", file=sys.stderr)
        return 2

    env = os.environ.copy()
    env.setdefault("SEVENOS_ROOT", str(ROOT))
    env.update(read_language_env())
    profile = active_profile()

    if os.environ.get("SEVENOS_DRY_RUN") == "1":
        print(" ".join(shlex.quote(part) for part in command))
        return 0

    allowed, reason = command_allowed(command)
    if not allowed:
        print(f"seven-profile-launch: blocked: {reason}", file=sys.stderr)
        return 126

    if is_sevenos_core(command) or os.environ.get("SEVENOS_PROFILE_STRICT_LAUNCH", "1") == "0":
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=env)
        return 0

    runner = ROOT / "bin" / "seven-profile-run"
    strict_command = [
        str(runner),
        "--profile",
        profile,
        "--container",
        "--workspace-profile",
        *command,
    ]
    subprocess.Popen(strict_command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, env=env)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
