#!/usr/bin/env python3
"""SevenOS native Control Center surface."""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import threading
import warnings
from dataclasses import dataclass
from pathlib import Path

warnings.filterwarnings("ignore", category=DeprecationWarning)


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401

        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr_text  # noqa: E402
try:
    import seven_theme  # noqa: E402
except Exception:  # pragma: no cover
    seven_theme = None

STATE_DIR = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "sevenos"
DND_FILE = STATE_DIR / "notifications.dnd"


@dataclass(frozen=True)
class SystemSnapshot:
    profile_title: str
    profile_key: str
    wifi: str
    wifi_enabled: bool
    bluetooth: str
    bluetooth_enabled: bool
    volume: int
    brightness: int
    battery_percent: int
    battery_note: str
    battery_charging: bool
    vpn_active: bool
    recorder_active: bool


def command_output(command: list[str], timeout: float = 0.45) -> str:
    try:
        result = subprocess.run(command, text=True, capture_output=True, check=False, timeout=timeout)
        return result.stdout.strip()
    except subprocess.TimeoutExpired:
        return ""


def command_available(command: str) -> bool:
    return shutil.which(command) is not None


def current_theme_mode() -> str:
    if os.environ.get("SEVENOS_THEME_MODE") in {"dark", "light"}:
        return str(os.environ["SEVENOS_THEME_MODE"])
    config_dir = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
    profile = os.environ.get("SEVENOS_ACTIVE_PROFILE", "equinox").strip().strip("'\"") or "equinox"
    profile_env = config_dir / "profile.env"
    if profile_env.exists():
        for line in profile_env.read_text(encoding="utf-8", errors="ignore").splitlines():
            if line.startswith("SEVENOS_ACTIVE_PROFILE="):
                profile = line.split("=", 1)[1].strip().strip("'\"") or profile
                break
    for theme_file in (config_dir / "profiles" / profile / "theme.conf", config_dir / "theme.conf"):
        if theme_file.exists():
            for line in theme_file.read_text(encoding="utf-8", errors="ignore").splitlines():
                key, _, value = line.partition("=")
                if key.strip().lower() in {"sevenos_theme_mode", "theme_mode", "mode"}:
                    value = value.strip().strip("'\"").lower()
                    if value in {"dark", "light"}:
                        return value
    return "dark"


def control_center_css(theme_mode: str) -> str:
    shared_css = seven_theme.gtk_app_css("control-center", theme_mode) if seven_theme else ""
    css_path = ROOT / "identity" / f"control-center-{theme_mode}.css"
    if css_path.exists():
        return shared_css + css_path.read_text(encoding="utf-8")
    return shared_css + """
    * { font-family: "SF Pro Display", system-ui, sans-serif; }
    window.quick-window { background: transparent; }
    .quick-root { padding: 16px; border-radius: 28px; background: rgba(18,19,26,0.92); color: #ededed; }
    .tile, .context-card, .slider-card, .detail-card, .battery-row, .ai-row, .footer-card { padding: 12px; border-radius: 20px; background: rgba(255,255,255,0.06); }
    .detail-card { border: 1px solid rgba(255,255,255,0.08); }
    .icon-action { border-radius: 999px; }
    """


def local_command(name: str) -> str:
    candidate = ROOT / "bin" / name
    return str(candidate) if candidate.exists() else name


def notify(title: str, message: str) -> None:
    if command_available("notify-send"):
        subprocess.Popen(["notify-send", title, message], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def run_detached(*command: str) -> None:
    subprocess.Popen(
        [local_command(command[0]), *command[1:]],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if command and command[0] in {
        "seven-settings",
        "seven-spotlight",
        "seven-wifi",
        "seven-bluetooth",
        "seven",
        "pavucontrol",
        "seven-quick-settings",
    }:
        try:
            from gi.repository import GLib, Gtk

            GLib.idle_add(Gtk.main_quit)
        except Exception:
            pass


def active_profile() -> tuple[str, str]:
    profile_file = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos/profile.json"
    if profile_file.exists():
        try:
            payload = json.loads(profile_file.read_text(encoding="utf-8"))
            return str(payload.get("title") or "Equinox"), str(payload.get("key") or "equinox")
        except Exception:
            pass
    return "Equinox", "equinox"


def wifi_state() -> str:
    if not command_available("nmcli"):
        return tr_text("Missing")
    radio = command_output(["nmcli", "radio", "wifi"])
    if radio == "disabled":
        return tr_text("Off")
    active = command_output(["bash", "-lc", "nmcli -t -f active,ssid dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"])
    return active or tr_text("On")


def bluetooth_state() -> str:
    if not command_available("bluetoothctl"):
        return tr_text("Missing")
    state = command_output(["bash", "-lc", "bluetoothctl show 2>/dev/null | awk -F': ' '/Powered/{print $2; exit}'"])
    return tr_text("On") if state == "yes" else tr_text("Off")


def volume_value() -> int:
    if not command_available("wpctl"):
        return 50
    raw = command_output(["wpctl", "get-volume", "@DEFAULT_AUDIO_SINK@"])
    try:
        return max(0, min(100, int(float(raw.split()[1]) * 100)))
    except Exception:
        return 50


def set_volume(value: float) -> None:
    if command_available("wpctl"):
        subprocess.Popen(["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def brightness_value() -> int:
    if not command_available("brightnessctl"):
        return 60
    raw = command_output(["bash", "-lc", "brightnessctl -m 2>/dev/null | awk -F, '{gsub(/%/,\"\",$4); print $4; exit}'"])
    try:
        return max(0, min(100, int(raw)))
    except Exception:
        return 60


def set_brightness(value: float) -> None:
    if command_available("brightnessctl"):
        subprocess.Popen(["brightnessctl", "set", f"{int(value)}%"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def battery_info() -> tuple[int, str, bool]:
    capacity = command_output(["bash", "-lc", "cat /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -n1"], timeout=0.18)
    status = command_output(["bash", "-lc", "cat /sys/class/power_supply/BAT*/status 2>/dev/null | head -n1"], timeout=0.18)
    if capacity:
        try:
            return max(0, min(100, int(capacity))), status or tr_text("Ready"), status.lower() == "charging"
        except Exception:
            pass
    if command_available("upower"):
        devices = command_output(["bash", "-lc", "upower -e | grep -m1 BAT || true"], timeout=0.25)
        if devices:
            percentage = command_output(["bash", "-lc", f"upower -i {devices!r} | awk '/percentage:/{{gsub(/%/,\"\",$2); print int($2); exit}}'"], timeout=0.25)
            state = command_output(["bash", "-lc", f"upower -i {devices!r} | awk -F': *' '/state:/{{print $2; exit}}'"], timeout=0.25)
            time_left = command_output(["bash", "-lc", f"upower -i {devices!r} | awk -F': *' '/time to empty|time to full/{{print $2; exit}}'"], timeout=0.25)
            try:
                return max(0, min(100, int(percentage))), time_left or state or tr_text("Ready"), state == "charging"
            except Exception:
                pass
    return 0, tr_text("No battery"), False


def vpn_active() -> bool:
    if not command_available("nmcli"):
        return False
    return bool(command_output(["bash", "-lc", "nmcli -t -f TYPE,STATE con show --active | awk -F: '$1~/vpn/ && $2==\"activated\"{print 1; exit}'"]))


def recorder_active() -> bool:
    return subprocess.run(["pgrep", "-x", "wf-recorder"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0


def snapshot() -> SystemSnapshot:
    profile_title, profile_key = active_profile()
    wifi = wifi_state()
    bluetooth = bluetooth_state()
    percent, note, charging = battery_info()
    return SystemSnapshot(
        profile_title=profile_title,
        profile_key=profile_key,
        wifi=wifi,
        wifi_enabled=wifi not in {tr_text("Off"), tr_text("Missing")},
        bluetooth=bluetooth,
        bluetooth_enabled=bluetooth == tr_text("On"),
        volume=volume_value(),
        brightness=brightness_value(),
        battery_percent=percent,
        battery_note=note,
        battery_charging=charging,
        vpn_active=vpn_active(),
        recorder_active=recorder_active(),
    )


def toggle_wifi() -> None:
    if command_available("nmcli"):
        state = command_output(["nmcli", "radio", "wifi"])
        subprocess.Popen(["nmcli", "radio", "wifi", "off" if state == "enabled" else "on"])
    else:
        run_detached("seven-waybar-action", "network")


def toggle_bluetooth() -> None:
    if command_available("bluetoothctl"):
        state = bluetooth_state()
        subprocess.Popen(["bluetoothctl", "power", "off" if state == tr_text("On") else "on"])


def toggle_focus() -> None:
    run_detached("seven-waybar-notifications", "toggle-dnd")


def nearby_wifi(limit: int = 5) -> list[tuple[str, str]]:
    if not command_available("nmcli"):
        return []
    raw = command_output(["bash", "-lc", "nmcli -t --escape no -f SSID,SIGNAL,IN-USE dev wifi list --rescan no 2>/dev/null"])
    rows: list[tuple[str, str]] = []
    seen: set[str] = set()
    for line in raw.splitlines():
        parts = line.split(":")
        if len(parts) < 2:
            continue
        ssid = parts[0].strip()
        if not ssid or ssid in seen:
            continue
        seen.add(ssid)
        signal = parts[1].strip() if len(parts) > 1 else "--"
        active = f" · {tr_text('Connected').lower()}" if len(parts) > 2 and parts[2].strip() == "*" else ""
        rows.append((ssid, f"{signal}%{active}"))
        if len(rows) >= limit:
            break
    return rows


def wifi_networks(limit: int = 8, rescan: bool = False) -> list[dict[str, str]]:
    if not command_available("nmcli"):
        return []
    scan = "yes" if rescan else "no"
    raw = command_output(["nmcli", "-t", "--escape", "no", "-f", "SSID,SECURITY,SIGNAL,IN-USE", "dev", "wifi", "list", "--rescan", scan], timeout=2.8)
    rows: list[dict[str, str]] = []
    seen: set[str] = set()
    for line in raw.splitlines():
        parts = line.split(":")
        if len(parts) < 3:
            continue
        ssid = parts[0].strip()
        if not ssid or ssid in seen:
            continue
        seen.add(ssid)
        rows.append(
            {
                "ssid": ssid,
                "security": parts[1].strip() or "open",
                "signal": parts[2].strip() or "--",
                "active": "yes" if len(parts) > 3 and parts[3].strip() == "*" else "no",
            }
        )
        if len(rows) >= limit:
            break
    return rows


def known_wifi_connection(ssid: str) -> str:
    if not command_available("nmcli"):
        return ""
    raw = command_output(["nmcli", "-t", "--escape", "no", "-f", "NAME,TYPE,802-11-wireless.ssid", "connection", "show"], timeout=1.2)
    for line in raw.splitlines():
        parts = line.split(":")
        if len(parts) >= 2 and parts[1] == "802-11-wireless" and (parts[0] == ssid or (len(parts) > 2 and parts[2] == ssid)):
            return parts[0]
    return ""


def wifi_password_dialog(Gtk, parent, ssid: str) -> str:
    dialog = Gtk.Dialog(title=tr_text("Wi-Fi password"), transient_for=parent, modal=True)
    dialog.add_button(tr_text("Cancel"), Gtk.ResponseType.CANCEL)
    dialog.add_button(tr_text("Connect"), Gtk.ResponseType.OK)
    dialog.set_default_response(Gtk.ResponseType.OK)
    box = dialog.get_content_area()
    box.set_spacing(10)
    box.set_border_width(14)
    label = Gtk.Label(label=tr_text("Enter password for {profile}", profile=ssid), xalign=0)
    entry = Gtk.Entry()
    entry.set_visibility(False)
    entry.set_activates_default(True)
    box.pack_start(label, False, False, 0)
    box.pack_start(entry, False, False, 0)
    dialog.show_all()
    response = dialog.run()
    password = entry.get_text().strip() if response == Gtk.ResponseType.OK else ""
    dialog.destroy()
    return password


def connect_wifi_network(Gtk, parent, ssid: str, security: str) -> None:
    if not command_available("nmcli"):
        notify("SevenOS Wi-Fi", "SevenOS network tools are missing.")
        return
    known = known_wifi_connection(ssid)
    password = ""
    if not known and security and security not in {"open", "--"}:
        password = wifi_password_dialog(Gtk, parent, ssid)
        if not password:
            return

    def work():
        try:
            subprocess.run(["nmcli", "radio", "wifi", "on"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=2.0)
            if known:
                status = subprocess.run(["nmcli", "connection", "up", "id", known], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=12.0).returncode
            elif password:
                status = subprocess.run(["nmcli", "device", "wifi", "connect", ssid, "password", password], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=18.0).returncode
            else:
                status = subprocess.run(["nmcli", "device", "wifi", "connect", ssid], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=12.0).returncode
        except Exception:
            status = 1
        notify("SevenOS Wi-Fi", f"Connected to {ssid}." if status == 0 else f"Could not connect to {ssid}.")

    notify("SevenOS Wi-Fi", f"Connecting to {ssid}...")
    threading.Thread(target=work, daemon=True).start()


def bluetooth_devices(limit: int = 4) -> list[tuple[str, str]]:
    if not command_available("bluetoothctl"):
        return []
    connected = command_output(["bluetoothctl", "devices", "Connected"])
    paired = command_output(["bluetoothctl", "devices", "Paired"])
    rows: list[tuple[str, str]] = []
    seen: set[str] = set()
    for raw, state in ((connected, tr_text("Connected")), (paired, tr_text("Paired"))):
        for line in raw.splitlines():
            parts = line.split(maxsplit=2)
            if len(parts) != 3 or parts[1] in seen:
                continue
            seen.add(parts[1])
            rows.append((parts[2], state))
            if len(rows) >= limit:
                return rows
    return rows


def bluetooth_device_rows(limit: int = 8) -> list[dict[str, str]]:
    if not command_available("bluetoothctl"):
        return []
    rows: list[dict[str, str]] = []
    seen: set[str] = set()
    sources = (
        (command_output(["bluetoothctl", "devices", "Connected"], timeout=1.2), tr_text("Connected")),
        (command_output(["bluetoothctl", "devices", "Paired"], timeout=1.2), tr_text("Paired")),
        (command_output(["bluetoothctl", "devices"], timeout=1.2), tr_text("Nearby")),
    )
    for raw, state in sources:
        for line in raw.splitlines():
            parts = line.split(maxsplit=2)
            if len(parts) != 3 or parts[1] in seen:
                continue
            seen.add(parts[1])
            rows.append({"mac": parts[1], "name": parts[2], "state": state})
            if len(rows) >= limit:
                return rows
    return rows


def bluetooth_action(mac: str, connected: bool) -> None:
    if not command_available("bluetoothctl"):
        notify("SevenOS Bluetooth", "Bluetooth tools are missing.")
        return

    def work():
        try:
            subprocess.run(["bluetoothctl", "power", "on"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=3.0)
            if connected:
                status = subprocess.run(["bluetoothctl", "disconnect", mac], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=8.0).returncode
                notify("SevenOS Bluetooth", "Device disconnected." if status == 0 else "Could not disconnect device.")
                return
            subprocess.run(["bluetoothctl", "trust", mac], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=4.0)
            status = subprocess.run(["bluetoothctl", "connect", mac], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=10.0).returncode
            if status != 0:
                subprocess.run(["bluetoothctl", "pair", mac], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=10.0)
                status = subprocess.run(["bluetoothctl", "connect", mac], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=10.0).returncode
        except Exception:
            status = 1
        notify("SevenOS Bluetooth", "Device connected." if status == 0 else "Could not connect device.")

    notify("SevenOS Bluetooth", "Updating device...")
    threading.Thread(target=work, daemon=True).start()


def bluetooth_scan_async() -> None:
    if command_available("bluetoothctl"):
        subprocess.Popen(["bluetoothctl", "power", "on"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.Popen(["bash", "-lc", "timeout 12s bluetoothctl scan on >/dev/null 2>&1 || true"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        notify("SevenOS Bluetooth", "Scanning nearby devices.")


def wifi_scan_async() -> None:
    if command_available("nmcli"):
        subprocess.Popen(["nmcli", "device", "wifi", "rescan"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        notify("SevenOS Wi-Fi", "Refreshing nearby networks.")


def add_classes(widget, classes: list[str]) -> None:
    context = widget.get_style_context()
    for css_class in classes:
        if css_class:
            context.add_class(css_class)


def replace_state_classes(widget, classes: list[str]) -> None:
    context = widget.get_style_context()
    for css_class in ("connected", "disabled", "active", "attention", "success", "critical", "charging"):
        context.remove_class(css_class)
    for css_class in classes:
        if css_class:
            context.add_class(css_class)


def context_signal(state: SystemSnapshot) -> tuple[str, str, str, tuple[str, ...] | None]:
    if state.recorder_active:
        return tr_text("Recording in progress"), tr_text("Click to stop the current screen recording."), "attention", ("seven-recorder", "stop")
    if state.battery_percent and state.battery_percent <= 18 and not state.battery_charging:
        return tr_text("Battery is low"), tr_text("Reduce brightness or open power controls."), "attention", ("seven-quick-settings", "power")
    if not state.wifi_enabled:
        return tr_text("Wi-Fi is off"), tr_text("Turn it on or open nearby networks."), "attention", ("seven-wifi", "menu")
    if state.vpn_active:
        return tr_text("VPN protected"), tr_text("Network traffic is routed through an active VPN."), "success", ("seven-settings", "network")
    return tr_text("System ready"), tr_text("Network, sound and power controls are available."), "success", ("seven-settings",)


def probe() -> int:
    ensure_gi_python()
    try:
        import gi

        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run(panel: str = "system") -> int:
    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk
    try:
        gi.require_version("GtkLayerShell", "0.1")
        from gi.repository import GtkLayerShell
    except Exception:
        GtkLayerShell = None

    GLib.set_prgname("SevenQuickSettingsNative")
    GLib.set_application_name(f"SevenOS {tr_text('Control Center')}")
    try:
        Gdk.set_program_class("SevenQuickSettingsNative")
    except Exception:
        pass

    theme_mode = current_theme_mode()
    active_panel = panel if panel in {"system", "wifi", "bluetooth", "audio", "power", "time"} else "system"
    state = snapshot()

    provider = Gtk.CssProvider()
    provider.load_from_data(control_center_css(theme_mode).encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    display = Gdk.Display.get_default()
    monitor = display.get_primary_monitor() if display else None
    if monitor is None and display and display.get_n_monitors() > 0:
        monitor = display.get_monitor(0)
    screen_height = monitor.get_geometry().height if monitor else 720
    panel_height = min(500 if active_panel == "system" else 560, max(360, screen_height - 110))

    window = Gtk.Window(title=f"SevenOS {tr_text('Control Center')}")
    window.set_wmclass("SevenQuickSettingsNative", "SevenQuickSettingsNative")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.NONE)
    window.set_default_size(384, panel_height)
    window.set_size_request(384, min(panel_height, screen_height - 96))
    window.get_style_context().add_class("quick-window")

    layer_shell_active = False
    if GtkLayerShell is not None:
        try:
            GtkLayerShell.init_for_window(window)
            if hasattr(GtkLayerShell, "set_namespace"):
                GtkLayerShell.set_namespace(window, "sevenos-control-center")
            GtkLayerShell.set_layer(window, GtkLayerShell.Layer.OVERLAY)
            GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.TOP, True)
            GtkLayerShell.set_anchor(window, GtkLayerShell.Edge.RIGHT, True)
            GtkLayerShell.set_margin(window, GtkLayerShell.Edge.TOP, 74)
            GtkLayerShell.set_margin(window, GtkLayerShell.Edge.RIGHT, 28)
            GtkLayerShell.set_exclusive_zone(window, -1)
            # Keep the control center pointer-friendly without stealing focus from
            # full Settings windows opened from it.
            GtkLayerShell.set_keyboard_interactivity(window, False)
            layer_shell_active = True
        except Exception:
            layer_shell_active = False

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
    add_classes(root, ["quick-root", f"mode-{theme_mode}", "catppuccin-mocha" if theme_mode == "dark" else "catppuccin-latte"])
    window.add(root)

    refs: dict[str, object] = {}
    root.pack_start(build_header(Gtk, state, active_panel), False, False, 0)
    if active_panel == "system":
        root.pack_start(build_primary_grid(Gtk, state, refs), False, False, 0)
        root.pack_start(build_context_card(Gtk, state, refs), False, False, 0)
        root.pack_start(build_slider_card(Gtk, tr_text("Volume"), "audio", "󰕾", state.volume, set_volume, refs), False, False, 0)
        if command_available("brightnessctl"):
            root.pack_start(build_slider_card(Gtk, tr_text("Brightness"), "brightness", "󰃠", state.brightness, set_brightness, refs), False, False, 0)
        root.pack_start(build_battery_card(Gtk, state, refs), False, False, 0)
    else:
        scroller = Gtk.ScrolledWindow()
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroller.set_shadow_type(Gtk.ShadowType.NONE)
        scroller.set_size_request(-1, max(260, panel_height - 128))
        scroller.get_style_context().add_class("detail-scroll")
        scroller.add(build_detail_card(Gtk, window, active_panel, state))
        root.pack_start(scroller, True, True, 0)
    root.pack_end(build_footer(Gtk), False, False, 0)

    def place_window(_window):
        if layer_shell_active:
            return False
        try:
            display = Gdk.Display.get_default()
            monitor = display.get_primary_monitor() if display else None
            if monitor is None and display and display.get_n_monitors() > 0:
                monitor = display.get_monitor(0)
            if monitor:
                geometry = monitor.get_geometry()
                window.move(geometry.x + geometry.width - 404, geometry.y + 74)
        except Exception:
            pass
        return False

    window.connect("realize", lambda widget: GLib.idle_add(place_window, widget))
    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    GLib.timeout_add_seconds(2, update_live_refs, refs)
    window.show_all()
    Gtk.main()
    return 0


def build_header(Gtk, state: SystemSnapshot, active_panel: str):
    header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    header.get_style_context().add_class("quick-header")
    titles = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
    panel_titles = {
        "system": tr_text("Control Center"),
        "wifi": "Wi-Fi",
        "bluetooth": "Bluetooth",
        "audio": tr_text("Sound"),
        "power": tr_text("Power"),
        "time": tr_text("Time"),
    }
    title = Gtk.Label(label=panel_titles[active_panel], xalign=0)
    title.get_style_context().add_class("quick-title")
    subtitle = Gtk.Label(label=tr_text("{profile} mode", profile=state.profile_title), xalign=0)
    subtitle.get_style_context().add_class("quick-subtitle")
    titles.pack_start(title, False, False, 0)
    titles.pack_start(subtitle, False, False, 0)
    header.pack_start(titles, True, True, 0)
    close_button = Gtk.Button(label="×")
    add_classes(close_button, ["quick-close"])
    close_button.set_relief(Gtk.ReliefStyle.NONE)
    close_button.connect("clicked", lambda _button: Gtk.main_quit())
    settings_button = Gtk.Button(label="󰒓")
    add_classes(settings_button, ["quick-pill", "quick-icon-pill"])
    settings_button.set_relief(Gtk.ReliefStyle.NONE)
    settings_button.connect("clicked", lambda _button: run_detached("seven-settings"))
    header.pack_end(close_button, False, False, 0)
    header.pack_end(settings_button, False, False, 0)
    return header


def build_primary_grid(Gtk, state: SystemSnapshot, refs: dict[str, object]):
    grid = Gtk.Grid()
    grid.get_style_context().add_class("control-grid")
    grid.set_row_spacing(8)
    grid.set_column_spacing(8)
    grid.set_column_homogeneous(True)
    controls = [
        ("wifi", "Wi-Fi", state.wifi, "󰤨", toggle_wifi, ["connected" if state.wifi_enabled else "disabled"]),
        ("bluetooth", "Bluetooth", state.bluetooth, "󰂯", toggle_bluetooth, ["connected" if state.bluetooth_enabled else "disabled"]),
        ("focus", tr_text("Focus"), tr_text("On") if DND_FILE.exists() else tr_text("Off"), "󰂛", toggle_focus, ["active" if DND_FILE.exists() else ""]),
        ("brightness", tr_text("Brightness"), f"{state.brightness}%", "󰃠", lambda: run_detached("seven-settings", "display"), []),
    ]
    for index, item in enumerate(controls):
        grid.attach(build_tile(Gtk, *item, refs), index % 2, index // 2, 1, 1)
    return grid


def build_tile(Gtk, key: str, label: str, state: str, glyph: str, callback, classes: list[str], refs: dict[str, object]):
    button = Gtk.Button()
    button.set_relief(Gtk.ReliefStyle.NONE)
    add_classes(button, ["tile", *classes])
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    icon = Gtk.Label(label=glyph)
    icon.get_style_context().add_class("tile-glyph")
    text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    title = Gtk.Label(label=label, xalign=0)
    title.get_style_context().add_class("tile-title")
    status = Gtk.Label(label=state, xalign=0)
    status.get_style_context().add_class("tile-state")
    text.pack_start(title, False, False, 0)
    text.pack_start(status, False, False, 0)
    row.pack_start(icon, False, False, 0)
    row.pack_start(text, True, True, 0)
    button.add(row)
    button.connect("clicked", lambda _button: callback())
    refs[f"{key}_button"] = button
    refs[f"{key}_state"] = status
    return button


def build_context_card(Gtk, state: SystemSnapshot, refs: dict[str, object]):
    title, note, css_class, command = context_signal(state)
    card = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    add_classes(card, ["context-card", css_class])
    text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
    title_label = Gtk.Label(label=title, xalign=0)
    title_label.get_style_context().add_class("context-title")
    note_label = Gtk.Label(label=note, xalign=0)
    note_label.set_line_wrap(True)
    note_label.get_style_context().add_class("quick-context-note")
    text.pack_start(title_label, False, False, 0)
    text.pack_start(note_label, False, False, 0)
    card.pack_start(text, True, True, 0)
    if command:
        button = Gtk.Button(label="󰁔")
        add_classes(button, ["icon-action"])
        button.set_relief(Gtk.ReliefStyle.NONE)
        button.connect("clicked", lambda _button: run_detached(*command))
        card.pack_end(button, False, False, 0)
    refs["context_card"] = card
    refs["context_title"] = title_label
    refs["context_note"] = note_label
    return card


def build_slider_card(Gtk, title: str, name: str, glyph: str, value: int, callback, refs: dict[str, object]):
    card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    add_classes(card, ["slider-card", f"slider-{name}"])
    heading = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    heading.pack_start(Gtk.Label(label=glyph), False, False, 0)
    label = Gtk.Label(label=title, xalign=0)
    label.get_style_context().add_class("slider-title")
    value_label = Gtk.Label(label=f"{value}%", xalign=1)
    value_label.get_style_context().add_class("slider-value")
    heading.pack_start(label, True, True, 0)
    heading.pack_end(value_label, False, False, 0)
    card.pack_start(heading, False, False, 0)
    scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
    scale.set_value(value)
    scale.set_draw_value(False)
    scale.get_style_context().add_class("scale")

    def on_change(widget):
        new_value = int(widget.get_value())
        value_label.set_text(f"{new_value}%")
        callback(new_value)

    handler_id = scale.connect("value-changed", on_change)
    refs[f"{name}_scale"] = scale
    refs[f"{name}_value"] = value_label
    refs[f"{name}_handler"] = handler_id
    card.pack_start(scale, False, False, 0)
    return card


def build_battery_card(Gtk, state: SystemSnapshot, refs: dict[str, object]):
    row = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    add_classes(row, ["battery-row", "charging" if state.battery_charging else "", "critical" if state.battery_percent and state.battery_percent <= 18 else ""])
    top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    value = Gtk.Label(label=f"󰁹  {state.battery_percent}%", xalign=0)
    value.get_style_context().add_class("battery-percent")
    note = Gtk.Label(label=state.battery_note, xalign=1)
    note.get_style_context().add_class("battery-note")
    top.pack_start(value, False, False, 0)
    top.pack_end(note, False, False, 0)
    meter = Gtk.Box()
    meter.get_style_context().add_class("battery-meter")
    row.pack_start(top, False, False, 0)
    row.pack_start(meter, False, False, 0)
    refs["battery_row"] = row
    refs["battery_percent"] = value
    refs["battery_note"] = note
    return row


def update_slider_refs(refs: dict[str, object], name: str, value: int) -> None:
    scale = refs.get(f"{name}_scale")
    value_label = refs.get(f"{name}_value")
    handler_id = refs.get(f"{name}_handler")
    if value_label is not None:
        value_label.set_text(f"{value}%")
    if scale is not None:
        try:
            if handler_id is not None:
                scale.handler_block(handler_id)
            scale.set_value(value)
        finally:
            if handler_id is not None:
                scale.handler_unblock(handler_id)


def update_live_refs(refs: dict[str, object]) -> bool:
    state = snapshot()
    updates = {
        "wifi": (state.wifi, ["connected" if state.wifi_enabled else "disabled"]),
        "bluetooth": (state.bluetooth, ["connected" if state.bluetooth_enabled else "disabled"]),
        "focus": (tr_text("On") if DND_FILE.exists() else tr_text("Off"), ["active" if DND_FILE.exists() else ""]),
        "brightness": (f"{state.brightness}%", []),
    }
    for key, (label, classes) in updates.items():
        state_label = refs.get(f"{key}_state")
        button = refs.get(f"{key}_button")
        if state_label is not None:
            state_label.set_text(label)
        if button is not None:
            replace_state_classes(button, classes)

    title, note, css_class, _command = context_signal(state)
    context_card = refs.get("context_card")
    context_title = refs.get("context_title")
    context_note = refs.get("context_note")
    if context_card is not None:
        replace_state_classes(context_card, [css_class])
    if context_title is not None:
        context_title.set_text(title)
    if context_note is not None:
        context_note.set_text(note)

    update_slider_refs(refs, "audio", state.volume)
    if "brightness_scale" in refs:
        update_slider_refs(refs, "brightness", state.brightness)

    battery_row = refs.get("battery_row")
    if battery_row is not None:
        replace_state_classes(battery_row, ["charging" if state.battery_charging else "", "critical" if state.battery_percent and state.battery_percent <= 18 else ""])
    battery_percent = refs.get("battery_percent")
    battery_note = refs.get("battery_note")
    if battery_percent is not None:
        battery_percent.set_text(f"󰁹  {state.battery_percent}%")
    if battery_note is not None:
        battery_note.set_text(state.battery_note)
    return True


def detail_action(Gtk, label: str, command: tuple[str, ...], parent=None, danger: bool = False):
    button = Gtk.Button(label=label)
    button.set_relief(Gtk.ReliefStyle.NONE)
    add_classes(button, ["detail-button", "danger" if danger else ""])

    def activate(_button):
        if danger and parent is not None:
            dialog = Gtk.MessageDialog(
                transient_for=parent,
                modal=True,
                message_type=Gtk.MessageType.WARNING,
                buttons=Gtk.ButtonsType.CANCEL,
                text=label,
            )
            dialog.format_secondary_text(tr_text("Confirm this power action?"))
            dialog.add_button(tr_text("Confirm"), Gtk.ResponseType.OK)
            response = dialog.run()
            dialog.destroy()
            if response != Gtk.ResponseType.OK:
                return
        run_detached(*command)

    button.connect("clicked", activate)
    return button


def detail_row(Gtk, title: str, note: str = ""):
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    row.get_style_context().add_class("detail-row")
    label = Gtk.Label(label=title, xalign=0)
    row.pack_start(label, True, True, 0)
    if note:
        note_label = Gtk.Label(label=note, xalign=1)
        note_label.get_style_context().add_class("detail-row-note")
        row.pack_end(note_label, False, False, 0)
    return row


def detail_button_row(Gtk, title: str, note: str, callback, css_class: str = ""):
    button = Gtk.Button()
    button.set_relief(Gtk.ReliefStyle.NONE)
    add_classes(button, ["detail-row", "network-row", css_class])
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    label = Gtk.Label(label=title, xalign=0)
    row.pack_start(label, True, True, 0)
    if note:
        note_label = Gtk.Label(label=note, xalign=1)
        note_label.get_style_context().add_class("detail-row-note")
        row.pack_end(note_label, False, False, 0)
    button.add(row)
    button.connect("clicked", lambda _button: callback())
    return button


def clear_container(container) -> None:
    for child in list(container.get_children()):
        container.remove(child)


def detail_loading(Gtk, label: str):
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    row.get_style_context().add_class("detail-row")
    spinner = Gtk.Spinner()
    spinner.start()
    text = Gtk.Label(label=label, xalign=0)
    row.pack_start(spinner, False, False, 0)
    row.pack_start(text, True, True, 0)
    return row


def render_wifi_detail(Gtk, parent, body, status: str, networks: list[dict[str, str]]) -> None:
    clear_container(body)
    if status == "missing":
        body.pack_start(detail_row(Gtk, tr_text("Network tools missing"), tr_text("SevenOS network service")), False, False, 0)
    elif status == "off":
        body.pack_start(detail_row(Gtk, tr_text("Wi-Fi is off"), tr_text("Turn it on to see networks")), False, False, 0)
    elif not networks:
        body.pack_start(detail_row(Gtk, tr_text("No network found"), tr_text("Refresh nearby networks")), False, False, 0)
    else:
        for row in networks:
            note = f"{row['signal']}% · {row['security'] or 'open'}"
            if row["active"] == "yes":
                note = tr_text("Connected") + " · " + note
            body.pack_start(
                detail_button_row(
                    Gtk,
                    row["ssid"],
                    note,
                    lambda item=row: connect_wifi_network(Gtk, parent, item["ssid"], item["security"]),
                    "connected" if row["active"] == "yes" else "",
                ),
                False,
                False,
                0,
            )
    append_wifi_actions(Gtk, parent, body)
    body.show_all()


def append_wifi_actions(Gtk, parent, body) -> None:
    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    refresh_button = Gtk.Button(label=tr_text("Refresh"))
    refresh_button.set_relief(Gtk.ReliefStyle.NONE)
    add_classes(refresh_button, ["detail-button"])
    refresh_button.connect("clicked", lambda _button: populate_wifi_detail(Gtk, parent, body, force_rescan=True))
    actions.pack_start(refresh_button, True, True, 0)
    actions.pack_start(detail_action(Gtk, tr_text("Disconnect"), ("seven-wifi", "disconnect")), True, True, 0)
    actions.pack_start(detail_action(Gtk, tr_text("Advanced"), ("seven-settings", "network")), True, True, 0)
    body.pack_start(actions, False, False, 0)


def populate_wifi_detail(Gtk, parent, body, force_rescan: bool = False) -> None:
    clear_container(body)
    body.pack_start(detail_loading(Gtk, tr_text("Loading nearby networks")), False, False, 0)
    body.show_all()

    def work():
        if not command_available("nmcli"):
            return "missing", []
        if command_output(["nmcli", "radio", "wifi"], timeout=0.6) == "disabled":
            return "off", []
        if force_rescan:
            subprocess.run(["nmcli", "device", "wifi", "rescan"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=2.0)
        return "ready", wifi_networks(limit=32)

    def done(result):
        status, networks = result
        render_wifi_detail(Gtk, parent, body, status, networks)
        return False

    from gi.repository import GLib

    threading.Thread(target=lambda: GLib.idle_add(done, work()), daemon=True).start()


def render_bluetooth_detail(Gtk, parent, body, devices: list[dict[str, str]]) -> None:
    clear_container(body)
    for item in devices or [{"mac": "", "name": tr_text("No device"), "state": tr_text("Scan to discover")}]:
        connected = item["state"] == tr_text("Connected")
        if item["mac"]:
            body.pack_start(
                detail_button_row(
                    Gtk,
                    item["name"],
                    item["state"],
                    lambda dev=item, is_connected=connected: bluetooth_action(dev["mac"], is_connected),
                    "connected" if connected else "",
                ),
                False,
                False,
                0,
            )
        else:
            body.pack_start(detail_row(Gtk, item["name"], item["state"]), False, False, 0)
    actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    scan_button = Gtk.Button(label=tr_text("Scan"))
    scan_button.set_relief(Gtk.ReliefStyle.NONE)
    add_classes(scan_button, ["detail-button"])
    scan_button.connect("clicked", lambda _button: populate_bluetooth_detail(Gtk, parent, body, force_scan=True))
    actions.pack_start(scan_button, True, True, 0)
    actions.pack_start(detail_action(Gtk, tr_text("Advanced"), ("seven-bluetooth", "manager")), True, True, 0)
    body.pack_start(actions, False, False, 0)
    body.show_all()


def populate_bluetooth_detail(Gtk, parent, body, force_scan: bool = False) -> None:
    clear_container(body)
    body.pack_start(detail_loading(Gtk, tr_text("Loading Bluetooth devices")), False, False, 0)
    body.show_all()

    def work():
        if force_scan:
            if command_available("bluetoothctl"):
                subprocess.Popen(["bluetoothctl", "power", "on"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                subprocess.run(["bash", "-lc", "timeout 4s bluetoothctl scan on >/dev/null 2>&1 || true"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False, timeout=5.0)
        return bluetooth_device_rows()

    def done(devices):
        render_bluetooth_detail(Gtk, parent, body, devices)
        return False

    from gi.repository import GLib

    threading.Thread(target=lambda: GLib.idle_add(done, work()), daemon=True).start()


def build_detail_card(Gtk, parent, panel: str, state: SystemSnapshot):
    card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    card.get_style_context().add_class("detail-card")
    titles = {
        "wifi": ("Wi-Fi", state.wifi),
        "bluetooth": ("Bluetooth", state.bluetooth),
        "audio": (tr_text("Sound"), f"{state.volume}%"),
        "power": (tr_text("Power"), f"{state.battery_percent}%"),
        "time": (tr_text("Time"), command_output(["date", "+%H:%M"]) or "--"),
    }
    title_text, subtitle_text = titles.get(panel, titles["power"])
    title = Gtk.Label(label=title_text, xalign=0)
    title.get_style_context().add_class("detail-title")
    subtitle = Gtk.Label(label=subtitle_text, xalign=0)
    subtitle.get_style_context().add_class("detail-subtitle")
    card.pack_start(title, False, False, 0)
    card.pack_start(subtitle, False, False, 0)
    body = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
    body.get_style_context().add_class("detail-body")
    card.pack_start(body, True, True, 0)

    if panel == "wifi":
        populate_wifi_detail(Gtk, parent, body)
    elif panel == "bluetooth":
        populate_bluetooth_detail(Gtk, parent, body)
    elif panel == "audio":
        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        actions.pack_start(detail_action(Gtk, tr_text("Mute"), ("wpctl", "set-mute", "@DEFAULT_AUDIO_SINK@", "toggle")), True, True, 0)
        actions.pack_start(detail_action(Gtk, tr_text("Mixer"), ("pavucontrol",)), True, True, 0)
        body.pack_start(actions, False, False, 0)
    elif panel == "power":
        actions = Gtk.Grid()
        actions.set_column_spacing(8)
        actions.set_row_spacing(8)
        actions.attach(detail_action(Gtk, tr_text("Lock"), ("seven-power", "lock"), parent), 0, 0, 1, 1)
        actions.attach(detail_action(Gtk, tr_text("Sleep"), ("seven-power", "suspend"), parent), 1, 0, 1, 1)
        actions.attach(detail_action(Gtk, tr_text("Restart"), ("seven-power", "reboot"), parent, danger=True), 0, 1, 1, 1)
        actions.attach(detail_action(Gtk, tr_text("Shutdown"), ("seven-power", "poweroff"), parent, danger=True), 1, 1, 1, 1)
        body.pack_start(actions, False, False, 0)
    elif panel == "time":
        body.pack_start(detail_row(Gtk, command_output(["date", "+%A %d %B"]) or tr_text("Today"), command_output(["date", "+%Z"]) or ""), False, False, 0)
        body.pack_start(detail_action(Gtk, tr_text("Calendar"), ("seven-spotlight", "calendar")), False, False, 0)
    return card


def build_footer(Gtk):
    footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    footer.get_style_context().add_class("footer-card")
    settings = Gtk.Button(label="󰒓  " + tr_text("Settings"))
    settings.set_relief(Gtk.ReliefStyle.NONE)
    settings.get_style_context().add_class("footer-button")
    settings.connect("clicked", lambda _button: run_detached("seven-settings"))
    power = Gtk.Button(label="󰐥  " + tr_text("Power"))
    power.set_relief(Gtk.ReliefStyle.NONE)
    power.get_style_context().add_class("footer-button")
    power.connect("clicked", lambda _button: run_detached("seven-quick-settings", "power"))
    footer.pack_start(settings, True, True, 0)
    footer.pack_start(power, True, True, 0)
    return footer


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "--probe":
        return probe()
    panel = sys.argv[1] if len(sys.argv) > 1 else "system"
    return run(panel)


if __name__ == "__main__":
    raise SystemExit(main())
