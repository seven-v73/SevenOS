#!/usr/bin/env python3
"""Baobab OS native public interface.

French-first GTK surface for the Baobab cultural mini OS. The generated HTML
pages remain useful offline exports, but this is the normal public UI.
"""

from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
PROFILE_CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/profiles/baobab"
PROFILE_DATA = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share")) / "sevenos/profiles/baobab"
PROFILE_CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos/profiles/baobab"
CONFIG = PROFILE_CONFIG / "baobab"
DATA = PROFILE_DATA / "baobab"
CACHE = PROFILE_CACHE / "baobab"
WORKSPACE = Path.home() / "Baobab"
SETTINGS_FILE = CONFIG / "native-settings.json"
LANGUAGES_SOURCE = ROOT / "identity/baobab_languages.json"


def run_seven(*args: str) -> str:
    return subprocess.check_output([str(ROOT / "bin/seven"), *args], cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})


def load_json(path: Path, fallback):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return fallback


def bootstrap() -> None:
    try:
        run_seven("baobab", "bootstrap")
    except Exception:
        pass


def open_path(path: Path) -> None:
    if path.exists():
        subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def open_url(url: str) -> None:
    if url:
        subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def available(command: str) -> bool:
    return shutil.which(command) is not None


def command_path(*commands: str) -> str:
    for command in commands:
        if command.startswith("/") and Path(command).exists():
            return command
        resolved = shutil.which(command)
        if resolved:
            return resolved
    return ""


def text(value, fallback: str = "") -> str:
    return str(value or fallback)


def slugify(value: str, fallback: str = "collecte") -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-")
    return slug or fallback


def unique_path(path: Path) -> Path:
    if not path.exists():
        return path
    stem = path.stem
    suffix = path.suffix
    for index in range(2, 1000):
        candidate = path.with_name(f"{stem}-{index}{suffix}")
        if not candidate.exists():
            return candidate
    return path.with_name(f"{stem}-new{suffix}")


def save_json(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


class BaobabNative:
    def __init__(self, Gtk, Gdk, initial_view: str = "home"):
        self.Gtk = Gtk
        self.Gdk = Gdk
        self.initial_view = initial_view
        self.catalog = load_json(DATA / "catalog.json", {"records": []})
        self.countries_payload = load_json(DATA / "explore/africa-countries.json", {"countries": []})
        self.unesco_payload = load_json(DATA / "heritage/african-unesco-ich.json", {"items": []})
        self.datasets_payload = load_json(DATA / "offline/datasets.json", {"sources": []})
        self.settings = load_json(SETTINGS_FILE, {"language": "fr", "country_focus": ""})
        self.engines_payload = self.load_engines()
        self.services_payload = self.load_services()
        self.capabilities_payload = self.load_capabilities()
        self.packs_payload = self.load_packs()
        self.audit_payload = self.load_pack_audit()
        self.languages_payload = self.load_languages()
        self.records = self.catalog.get("records", [])
        self.countries = self.countries_payload.get("countries", [])
        self.heritage = self.unesco_payload.get("items", [])
        self.datasets = self.datasets_payload.get("sources", [])
        self.languages = self.languages_payload.get("languages", [])
        self.active_country = ""

    def load_engines(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "engines", "--json"))
        except Exception:
            return {"engines": [], "available": 0, "total": 0, "immersive_score": 0, "immersive_next": []}

    def load_services(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "service-doctor", "--json"))
        except Exception:
            return {"services": [], "score": 0, "state": "unknown", "issues": []}

    def load_capabilities(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "capability-doctor", "--json"))
        except Exception:
            return {"domains": [], "score": 0, "state": "unknown", "goals": []}

    def load_packs(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "packs", "--json"))
        except Exception:
            return {"packs": [], "count": 0}

    def load_pack_audit(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "audit-packs", "--json"))
        except Exception:
            return {"state": "unknown", "score": 0, "packs": []}

    def load_languages(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "languages", "--json"))
        except Exception:
            return load_json(LANGUAGES_SOURCE, {"languages": []})

    def run_action(self, *args: str) -> None:
        try:
            run_seven(*args)
            self.reload()
        except Exception as exc:
            self.show_message("Action Baobab impossible", str(exc), error=True)

    def show_message(self, title: str, body: str = "", error: bool = False) -> None:
        message_type = self.Gtk.MessageType.ERROR if error else self.Gtk.MessageType.INFO
        dialog = self.Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=message_type, buttons=self.Gtk.ButtonsType.OK, text=title)
        if body:
            dialog.format_secondary_text(body)
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def localized(self, item: dict, key: str, fallback: str = "") -> str:
        language = self.settings.get("language", "fr")
        if language == "fr":
            return text(item.get(f"{key}_fr") or item.get(f"{key}_en") or item.get(key), fallback)
        return text(item.get(f"{key}_en") or item.get(f"{key}_fr") or item.get(key), fallback)

    def set_language(self, language: str) -> None:
        self.settings["language"] = language
        save_json(SETTINGS_FILE, self.settings)

    def apply_css(self) -> None:
        css = b"""
        * { font-family: "Noto Sans", "Noto Sans Symbols", "Noto Color Emoji", sans-serif; }
        window { background: #080b0a; color: #f4ead8; }
        .root { background: #080b0a; }
        .rail { background: #0b0f0d; border-right: 1px solid rgba(221,204,168,.10); }
        .brand { padding: 14px; border-radius: 8px; background: #101713; border: 1px solid rgba(139,170,123,.18); }
        .brand-title { font-size: 24px; font-weight: 600; color: #f4ead8; }
        .brand-subtitle { color: #b9c4a5; font-size: 12px; }
        .nav-title { color: #8baa7b; font-size: 11px; font-weight: 600; }
        .nav button { border-radius: 8px; padding: 9px 12px; background: transparent; border: 1px solid transparent; color: #e7dbc3; }
        .nav button:hover { background: #121a16; border-color: rgba(139,170,123,.24); }
        .hero { padding: 26px; border-radius: 8px; background: #101713; border: 1px solid rgba(139,170,123,.22); }
        .title { font-size: 34px; font-weight: 500; color: #f4ead8; letter-spacing: 0; }
        .subtitle { color: #d8ccb5; font-size: 15px; }
        .eyebrow { color: #8baa7b; font-size: 12px; font-weight: 600; }
        .stat { padding: 14px; border-radius: 8px; background: #111411; border: 1px solid rgba(216,204,181,.14); }
        .stat-number { font-size: 26px; font-weight: 500; color: #c89b63; }
        .chip { padding: 8px 10px; border-radius: 8px; background: #121915; border: 1px solid rgba(139,170,123,.18); }
        .card { padding: 14px; border-radius: 8px; background: #0f1311; border: 1px solid rgba(216,204,181,.13); }
        .card:hover { border-color: #4f735a; background: #121814; }
        .station { padding: 18px; border-radius: 8px; background: #101411; border: 1px solid rgba(216,204,181,.14); }
        .station:hover { border-color: rgba(200,155,99,.45); }
        .card-title { font-size: 16px; font-weight: 500; color: #f4ead8; }
        .card-meta { color: #c89b63; font-size: 12px; }
        .card-body { color: #dfd2ba; }
        .detail { padding: 16px; border-radius: 8px; background: #101411; border: 1px solid rgba(216,204,181,.14); }
        .tree-canvas { border-radius: 8px; background: #0d120f; border: 1px solid rgba(139,170,123,.18); }
        .tree-section { padding: 16px; border-radius: 8px; background: #0b100d; border-left: 2px solid #4f735a; border-top: 1px solid rgba(216,204,181,.10); }
        .tree-root { border-left-color: #315e4d; }
        .tree-trunk { border-left-color: #b98248; }
        .tree-branch { border-left-color: #243c63; }
        .tree-leaf { border-left-color: #5d7c62; }
        .tree-collect { border-left-color: #a66a45; }
        .tree-archive { border-left-color: #75664c; }
        .pill { border-radius: 8px; padding: 8px 11px; }
        entry { border-radius: 8px; min-height: 38px; }
        """
        provider = self.Gtk.CssProvider()
        provider.load_from_data(css)
        self.Gtk.StyleContext.add_provider_for_screen(self.Gdk.Screen.get_default(), provider, self.Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    def label(self, value: str, css: str | None = None, wrap: bool = True) -> object:
        label = self.Gtk.Label(label=value)
        label.set_xalign(0)
        if hasattr(label, "set_wrap"):
            label.set_wrap(wrap)
        else:
            label.set_line_wrap(wrap)
        if css:
            label.get_style_context().add_class(css)
        return label

    def button(self, label: str, callback) -> object:
        button = self.Gtk.Button(label=label)
        button.get_style_context().add_class("pill")
        button.connect("clicked", callback)
        return button

    def chip(self, value: str) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=6)
        box.get_style_context().add_class("chip")
        box.add(self.label(value, "card-meta", False))
        return box

    def scroll(self, child) -> object:
        scroller = self.Gtk.ScrolledWindow()
        scroller.set_policy(self.Gtk.PolicyType.NEVER, self.Gtk.PolicyType.AUTOMATIC)
        scroller.add(child)
        return scroller

    def card(self, title: str, meta: str, body: str, on_click=None) -> object:
        event = self.Gtk.EventBox()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=7)
        box.get_style_context().add_class("card")
        box.add(self.label(title, "card-title"))
        if meta:
            box.add(self.label(meta, "card-meta"))
        if body:
            box.add(self.label(body, "card-body"))
        event.add(box)
        if on_click:
            event.connect("button-press-event", lambda *_: on_click())
        return event

    def station(self, title: str, meta: str, body: str, target: str) -> object:
        event = self.Gtk.EventBox()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("station")
        box.add(self.label(title, "card-title"))
        box.add(self.label(meta, "card-meta"))
        box.add(self.label(body, "card-body"))
        event.add(box)
        event.connect("button-press-event", lambda *_: self.stack.set_visible_child_name(target))
        return event

    def tree_canvas(self) -> object:
        area = self.Gtk.DrawingArea()
        area.set_size_request(360, 300)
        area.get_style_context().add_class("tree-canvas")

        def draw(_area, cr):
            width = _area.get_allocated_width()
            height = _area.get_allocated_height()
            cr.set_source_rgb(0.050, 0.070, 0.060)
            cr.paint()
            trunk_x = width * 0.50
            base_y = height * 0.82
            crown_y = height * 0.34
            cr.set_line_cap(1)
            cr.set_line_width(18)
            cr.set_source_rgb(0.55, 0.38, 0.24)
            cr.move_to(trunk_x, base_y)
            cr.curve_to(trunk_x - 28, height * 0.62, trunk_x + 22, height * 0.50, trunk_x, crown_y)
            cr.stroke()
            branches = [
                (-120, -34, 0.29, 0.18),
                (-82, -92, 0.36, 0.11),
                (90, -82, 0.64, 0.13),
                (124, -25, 0.71, 0.23),
                (-42, -124, 0.45, 0.07),
                (38, -128, 0.56, 0.07),
            ]
            for dx, dy, ex, ey in branches:
                cr.set_line_width(5)
                cr.set_source_rgb(0.49, 0.34, 0.22)
                cr.move_to(trunk_x, crown_y + 28)
                cr.curve_to(trunk_x + dx * .26, crown_y + dy * .20, width * ex, height * ey + 40, width * ex, height * ey + 56)
                cr.stroke()
            leaves = [
                (0.30, 0.26, 42), (0.42, 0.18, 52), (0.57, 0.18, 48),
                (0.70, 0.28, 44), (0.48, 0.31, 60), (0.60, 0.36, 40)
            ]
            for x, y, radius in leaves:
                cr.set_source_rgba(0.31, 0.45, 0.35, 0.72)
                cr.arc(width * x, height * y, radius, 0, 6.283)
                cr.fill()
            cr.set_source_rgba(0.78, 0.61, 0.39, 0.82)
            for x, y in [(0.31, .42), (.43, .27), (.58, .26), (.70, .42), (.50, .58)]:
                cr.arc(width * x, height * y, 4, 0, 6.283)
                cr.fill()
            cr.set_source_rgba(0.93, 0.88, 0.78, 0.86)
            cr.select_font_face("Noto Sans", 0, 0)
            cr.set_font_size(12)
            for label, x, y in [("Racines", .18, .86), ("Tronc", .47, .64), ("Branches", .62, .18), ("Feuilles", .70, .52), ("Collecte", .12, .50), ("Archives", .43, .91)]:
                cr.move_to(width * x, height * y)
                cr.show_text(label)
            return False

        area.connect("draw", draw)
        return area

    def clear(self, box) -> None:
        for child in box.get_children():
            box.remove(child)

    def speak_text(self, value: str) -> None:
        spoken = " ".join(value.split())[:900]
        if not spoken:
            return
        piper_model = os.environ.get("SEVENOS_BAOBAB_PIPER_MODEL", "")
        piper_bin = command_path("piper", "/opt/piper-tts/piper")
        if piper_bin and piper_model and available("aplay"):
            process = subprocess.Popen([piper_bin, "--model", piper_model, "--output-raw"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
            subprocess.Popen(["aplay", "-r", "22050", "-f", "S16_LE", "-t", "raw", "-"], stdin=process.stdout, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            if process.stdin:
                process.stdin.write(spoken.encode("utf-8"))
                process.stdin.close()
            return
        if available("espeak-ng"):
            subprocess.Popen(["espeak-ng", "-v", "fr", "-s", "150", spoken], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        dialog = self.Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=self.Gtk.MessageType.INFO, buttons=self.Gtk.ButtonsType.OK, text="Narration non disponible")
        dialog.format_secondary_text("Installe Piper avec un modèle français, ou espeak-ng, pour activer la lecture vocale hors ligne.")
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def open_sound_folder(self) -> None:
        folder = WORKSPACE / "Sound"
        folder.mkdir(parents=True, exist_ok=True)
        try:
            payload = json.loads(run_seven("baobab", "sound", "--json"))
        except Exception:
            payload = {"library": str(folder)}
        audio_files = []
        for library in (Path(payload.get("library", folder)), DATA / "sound"):
            for pattern in ("*.mp3", "*.ogg", "*.flac", "*.wav", "*.m4a", "*.opus"):
                audio_files.extend(library.glob(pattern))
        if audio_files and available("mpv"):
            subprocess.Popen([str(CONFIG / "bin/baobab-sound")], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        if available("xdg-open"):
            open_path(folder)
        message = "Place des fichiers audio dans Baobab Sound. Ils seront lus via la configuration MPV propre au mini-OS Baobab."
        dialog = self.Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=self.Gtk.MessageType.INFO, buttons=self.Gtk.ButtonsType.OK, text="Baobab Sound prêt")
        dialog.format_secondary_text(message)
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def heritage_detail(self, item: dict) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("detail")
        title = self.localized(item, "title", "Sans titre")
        countries = ", ".join(item.get("countries", []))
        concepts = ", ".join(item.get("concepts", [])[:10])
        summary = self.localized(item, "summary")
        box.add(self.label(title, "title"))
        box.add(self.label(f"{countries} · {item.get('year', '')} · {item.get('type_fr') or item.get('type_en') or item.get('type_acronym', 'ICH')}", "card-meta"))
        if concepts:
            box.add(self.label(f"Thèmes: {concepts}", "subtitle"))
        box.add(self.label(summary, "card-body"))
        source = item.get("url_fr") or item.get("url_en")
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Lire le résumé", lambda *_: self.speak_text(summary)))
        actions.add(self.button("Ouvrir la fiche source", lambda *_: open_url(source)))
        actions.add(self.button("Voir dans l'export Patrimoine", lambda *_: open_path(WORKSPACE / "Heritage/index.html")))
        box.add(actions)
        return box

    def stat(self, number: str, caption: str) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        box.get_style_context().add_class("stat")
        box.add(self.label(number, "stat-number", False))
        box.add(self.label(caption, "subtitle"))
        return box

    def header(self) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=18)
        box.get_style_context().add_class("hero")
        left = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        left.add(self.label("BAOBAB OS", "eyebrow", False))
        left.add(self.label("Arbre de connaissance", "title"))
        left.add(self.label("Technologie enracinée: mémoire vivante, transmission calme, apprentissage et création hors ligne.", "subtitle"))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Ouvrir l'arbre local", lambda *_: open_path(WORKSPACE / "Village/index.html")))
        actions.add(self.button("Baobab Sound", lambda *_: self.open_sound_folder()))
        actions.add(self.button("Widget mémoire", lambda *_: subprocess.Popen([str(CONFIG / "bin/baobab-widget")], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)))
        actions.add(self.button("Régénérer les données", lambda *_: self.reload()))
        left.add(actions)
        right = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        right.set_size_request(260, -1)
        right.add(self.chip(f"{self.capabilities_payload.get('score', 0)}% capacités"))
        right.add(self.chip(f"{self.engines_payload.get('immersive_score', 0)}% moteurs immersifs"))
        right.add(self.chip(f"{self.services_payload.get('state', 'runtime')} · runtime"))
        right.add(self.chip("FR d'abord · local/offline"))
        box.pack_start(left, True, True, 0)
        box.pack_start(right, False, False, 0)
        return box

    def home_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        root.add(self.header())

        os_surface = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=16)
        os_surface.add(self.tree_canvas())
        stations = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stations.attach(self.station("Racines", "Orientation", "Recherche, sources, moteurs et santé du mini-OS.", "search"), 0, 0, 1, 1)
        stations.attach(self.station("Tronc", "Mémoire", "Patrimoine, récits et modules de transmission.", "heritage"), 1, 0, 1, 1)
        stations.attach(self.station("Branches", "Territoires", "Pays, langues, relations et futures cartes offline.", "explore"), 0, 1, 1, 1)
        stations.attach(self.station("Feuilles", "Usages", "Son, cuisine, mode, marché et créations vivantes.", "modules"), 1, 1, 1, 1)
        stations.attach(self.station("Collecte", "Terrain", "Ajouter un récit avec source, droits et consentement.", "collect"), 0, 2, 1, 1)
        stations.attach(self.station("Archives", "Préservation", "Packs, musée et exports locaux contrôlés.", "packs"), 1, 2, 1, 1)
        os_surface.pack_start(stations, True, True, 0)
        root.add(os_surface)

        stats = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stats.attach(self.stat(str(len(self.countries)), "Pays africains"), 0, 0, 1, 1)
        stats.attach(self.stat(str(len(self.heritage)), "Éléments UNESCO ICH"), 1, 0, 1, 1)
        stats.attach(self.stat(str(len(self.records)), "Modules Baobab"), 2, 0, 1, 1)
        stats.attach(self.stat(str(len(self.datasets)), "Sources locales"), 3, 0, 1, 1)
        stats.attach(self.stat(f"{self.engines_payload.get('immersive_score', 0)}%", "Maturité immersive"), 0, 1, 1, 1)
        stats.attach(self.stat(text(self.settings.get("language", "fr")).upper(), "Langue prioritaire"), 1, 1, 1, 1)
        stats.attach(self.stat(str(self.packs_payload.get("count", 0)), "Packs culturels"), 2, 1, 1, 1)
        stats.attach(self.stat(f"{self.audit_payload.get('score', 0)}%", "Qualité packs"), 3, 1, 1, 1)
        root.add(stats)

        root.add(self.label("Arbre de connaissance", "title"))
        root.add(self.label("Baobab organise l'OS comme une mémoire vivante: comprendre, relier, transmettre, collecter et préserver.", "subtitle"))

        def tree_section(title: str, meta: str, body: str, css: str, entries: list[tuple[str, str, str, str]]) -> object:
            section = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
            section.get_style_context().add_class("tree-section")
            section.get_style_context().add_class(css)
            section.add(self.label(title, "card-title"))
            section.add(self.label(meta, "card-meta"))
            section.add(self.label(body, "card-body"))
            flow = self.Gtk.FlowBox()
            flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
            for entry_title, entry_meta, entry_body, target in entries:
                flow.add(self.card(entry_title, entry_meta, entry_body, lambda target=target: self.stack.set_visible_child_name(target)))
            section.add(flow)
            return section

        root.add(tree_section(
            "Racines",
            "Orientation et fondation",
            "Voir l'état réel de Baobab: langues, pays, sources, moteurs et qualité des packs avant de produire du contenu.",
            "tree-root",
            [
                ("Recherche", "Point d'entrée calme", "Trouver pays, récits, sources et patrimoine depuis une seule zone.", "search"),
                ("Moteurs", "Capacités locales", "Vérifier narration, son, IA, recherche et shell culturel disponibles.", "engines"),
                ("Sources", "Sol documentaire", "Contrôler les CSV, TSV et JSON qui nourrissent Baobab.", "datasets"),
            ],
        ))
        root.add(tree_section(
            "Tronc",
            "Mémoire centrale",
            "Lire, comprendre et relier les savoirs déjà présents dans la base locale, sans bruit décoratif.",
            "tree-trunk",
            [
                ("Patrimoine", "Mémoire sourcée", "Découvrir pratiques, savoir-faire, musiques et récits avec contexte.", "heritage"),
                ("Modules", "Transmission", "Langues, son, cuisine, mode, marché et sagesse en vues natives.", "modules"),
                ("Récits", "Oralité guidée", "Lire les modules Baobab comme des histoires contextualisées.", "story"),
            ],
        ))
        root.add(tree_section(
            "Branches",
            "Territoires et relations",
            "Explorer les liens entre pays, langues, pratiques, archives et contenus communautaires.",
            "tree-branch",
            [
                ("Explorer", "Branches du territoire", "Relier lieux, contenus, langues et récits.", "explore"),
                ("Langues", "Apprentissage validable", "Consulter les premières langues africaines et leur statut.", "languages"),
                ("Musée", "Archives contemplatives", "Voir les contenus comme objets, traces et archives.", "museum"),
            ],
        ))
        root.add(tree_section(
            "Feuilles",
            "Usages vivants",
            "Les feuilles sont les expériences quotidiennes: écouter, apprendre, créer, cuisiner, transmettre.",
            "tree-leaf",
            [
                ("Son", "Écoute locale", "Ouvrir le dossier Baobab Sound et lire avec mpv quand disponible.", "modules"),
                ("Mode", "Création enracinée", "Préparer textiles, créateurs et pont ElegantStyle.", "modules"),
                ("Cuisine", "Mémoire familiale", "Structurer recettes, gestes et récits culinaires.", "modules"),
            ],
        ))
        root.add(tree_section(
