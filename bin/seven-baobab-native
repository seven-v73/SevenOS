    def session_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        payload = self.session_payload or {}
        root.add(self.label("Séance Baobab", "title"))
        root.add(self.label("Un parcours temporel adapté à l’ambiance active. Chaque phase reste simple, actionnable et local-first.", "subtitle"))
        root.add(self.session_panel(compact=False))
        root.add(self.label("Commandes de séance", "card-title"))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Changer l’ambiance", lambda *_: self.stack.set_visible_child_name("preferences")))
        actions.add(self.button("Ajouter une trace", lambda *_: self.add_memory_dialog()))
        actions.add(self.button("Créer la note du jour", lambda *_: self.create_daily_ritual_note()))
        actions.add(self.button("Créer dossier", lambda *_: self.create_session_folder()))
        actions.add(self.button("Dossiers", lambda *_: self.navigate("sessions")))
        root.add(actions)
        for phase in payload.get("phases", []):
            root.add(self.card(
                text(phase.get("title"), "Phase"),
                f"{phase.get('minutes', 0)} min · {text(phase.get('command'))}",
                text(phase.get("body")),
                lambda phase=phase: self.launch_today_action(text(phase.get("command"))),
            ))
        return self.scroll(root)

    def sessions_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        sessions = self.session_folders()
        root.add(self.label("Dossiers de séance", "title"))
        root.add(self.label("Ateliers, classes et collectes préparés localement avec carte, checklist et zone médias.", "subtitle"))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Créer une séance", lambda *_: self.create_session_folder()))
        actions.add(self.button("Ouvrir le dossier racine", lambda *_: open_path(WORKSPACE / "Sessions Baobab")))
        actions.add(self.button("Médiathèque", lambda *_: self.navigate("media")))
        root.add(actions)
        stats = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        media_total = sum(item["media_count"] for item in sessions)
        ready_total = sum(1 for item in sessions if item["state"] == "ready")
        stats.attach(self.stat(str(len(sessions)), "Séances"), 0, 0, 1, 1)
        stats.attach(self.stat(str(ready_total), "Complètes"), 1, 0, 1, 1)
        stats.attach(self.stat(str(media_total), "Médias"), 2, 0, 1, 1)
        root.add(stats)
        if not sessions:
            root.add(self.empty_state("Aucun dossier de séance", "Crée une séance depuis la Carte de transmission. Baobab préparera carte, checklist et dossier media.", "Créer une séance", lambda *_: self.create_session_folder()))
            return self.scroll(root)
        for item in sessions:
            box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
            box.get_style_context().add_class("session-folder")
            box.get_style_context().add_class("session-ready" if item["state"] == "ready" else "session-partial")
            box.add(self.label(text(item["name"]), "card-title", False))
            box.add(self.label(f"{item['modified']} · {item['media_count']} média(s) · {item['state']}", "card-meta", False))
            box.add(self.label(str(item["path"]), "card-body"))
            row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
            row.add(self.button("Ouvrir", lambda *_args, path=item["path"]: open_path(path)))
            row.add(self.button("Carte", lambda *_args, path=item["path"]: open_path(path / "carte-transmission.md")))
            row.add(self.button("Médias", lambda *_args, path=item["path"]: open_path(path / "media")))
            box.add(row)
            root.add(box)
        root.add(self.card("Principe", "Local-first", "Ces dossiers restent dans ~/Baobab. Ils servent de support de préparation avant toute publication ou partage public."))
        return self.scroll(root)

    def carnet_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        notes = self.ritual_notes()
        events = (self.trail_payload or {}).get("events", [])
        root.add(self.label("Carnet culturel", "title"))
        root.add(self.label("La mémoire lisible de Baobab: notes rituelles, traces locales, séance active et repères de transmission.", "subtitle"))
        root.add(self.carnet_panel(compact=False))
        stats = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stats.attach(self.stat(str(len(notes)), "Notes"), 0, 0, 1, 1)
        stats.attach(self.stat(str(len(events)), "Traces"), 1, 0, 1, 1)
        stats.attach(self.stat(str((self.session_payload or {}).get("duration_minutes", 0)), "Minutes séance"), 2, 0, 1, 1)
        stats.attach(self.stat(text(self.active_ambiance().get("label"), "Calme"), "Ambiance"), 3, 0, 1, 1)
        root.add(stats)
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Créer une note", lambda *_: self.create_daily_ritual_note()))
        actions.add(self.button("Ajouter une trace", lambda *_: self.add_memory_dialog()))
        actions.add(self.button("Séance", lambda *_: self.stack.set_visible_child_name("session")))
        actions.add(self.button("Ouvrir le dossier", lambda *_: open_path(WORKSPACE / "Rituels du jour")))
        root.add(actions)
        root.add(self.label("Fil récent", "card-title"))
        timeline = []
        for path in notes[:8]:
            timeline.append(("note", date.fromtimestamp(path.stat().st_mtime).isoformat(), path.stem.replace("-", " ").title(), str(path), lambda path=path: open_path(path)))
        for event in events[:12]:
            timeline.append(("trace", text(event.get("time")), text(event.get("title"), "Trace"), text(event.get("body")), None))
        timeline.sort(key=lambda item: item[1], reverse=True)
        if not timeline:
            root.add(self.empty_state("Carnet vide", "Crée une note ou une trace. Baobab gardera tout localement dans ton espace culturel.", "Créer une trace", lambda *_: self.add_memory_dialog()))
            return self.scroll(root)
        for kind, when, title, body, callback in timeline[:16]:
            item = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=5)
            item.get_style_context().add_class("carnet-item")
            item.add(self.label(title, "card-title", False))
            item.add(self.label(f"{kind} · {when}", "card-meta", False))
            item.add(self.label(body[:460], "card-body"))
            if callback:
                event_box = self.Gtk.EventBox()
                event_box.add(item)
                event_box.connect("button-press-event", lambda *_args, callback=callback: callback())
                root.add(event_box)
            else:
                root.add(item)
        root.add(self.label("Qualité de transmission", "card-title"))
        for title, body in [
            ("Brouillon avant publication", "Toute note reste privée tant que la source, le contexte et l'accord ne sont pas clarifiés."),
            ("Trace courte, mémoire longue", "Les mémos courts servent à retrouver le fil sans transformer Baobab en réseau social."),
            ("Relier avant exposer", "Associe pays, langue, source et personne ressource avant toute présentation."),
        ]:
            root.add(self.card(title, "Garde-fou Baobab", body))
        return self.scroll(root)

