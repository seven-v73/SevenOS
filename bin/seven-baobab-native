    def media_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        items = self.media_items()
        active_kind = {"value": "all"}
        root.add(self.label("Médiathèque vivante", "title"))
        root.add(self.label("Une vue locale pour retrouver les sons, images, vidéos et documents sans sortir de Baobab.", "subtitle"))
        root.add(self.media_panel(compact=False))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Ouvrir Sound", lambda *_: self.open_sound_folder()))
        actions.add(self.button("Ouvrir les packs", lambda *_: open_path(DATA / "packs")))
        actions.add(self.button("Collecte", lambda *_: self.stack.set_visible_child_name("collect")))
        root.add(actions)
        if not items:
            root.add(self.empty_state("Aucun média local", "Ajoute des fichiers audio, images, vidéos ou PDF dans ~/Baobab/Sound ou dans un pack culturel.", "Ouvrir Sound", lambda *_: self.open_sound_folder()))
            return self.scroll(root)
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Rechercher dans les sons, images, vidéos, documents...")
        root.add(search)
        filters = self.Gtk.FlowBox()
        filters.set_selection_mode(self.Gtk.SelectionMode.NONE)
        filters.set_max_children_per_line(5)
        filter_cards = {}
        counts = {kind: sum(1 for item in items if item["kind"] == kind) for kind in ("audio", "image", "video", "document")}
        result_box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)

        def filter_card(kind: str, label: str, count: int) -> object:
            card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
            card.get_style_context().add_class("media-filter")
            if kind == active_kind["value"]:
                card.get_style_context().add_class("media-active")
            card.add(self.label(label, "card-title", False))
            card.add(self.label(f"{count} élément(s)", "card-meta", False))
            filter_cards[kind] = card
            event = self.Gtk.EventBox()
            event.add(card)
            event.connect("button-press-event", lambda _event, _button, kind=kind: set_kind(kind))
            return event

        def set_kind(kind: str) -> None:
            active_kind["value"] = kind
            for card_kind, card in filter_cards.items():
                context = card.get_style_context()
                if card_kind == kind:
                    context.add_class("media-active")
                else:
                    context.remove_class("media-active")
            render(search.get_text())

        def render(query: str = "") -> None:
            self.clear(result_box)
            q = query.lower().strip()
            kind = active_kind["value"]
            shown = 0
            for item in items:
                haystack = f"{item['name']} {item['kind']} {item['source']} {item['path']}".lower()
                if kind != "all" and item["kind"] != kind:
                    continue
                if q and q not in haystack:
                    continue
                body = f"{item['path']}\n{item['modified']} · {self.format_size(item['size'])}"
                card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=7)
                card.get_style_context().add_class("media-item")
                card.get_style_context().add_class(f"media-{item['kind']}")
                card.add(self.label(text(item["name"]), "card-title"))
                card.add(self.label(f"{item['kind']} · {item['source']}", "card-meta"))
                card.add(self.label(body, "card-body"))
                event = self.Gtk.EventBox()
                event.add(card)
                event.connect("button-press-event", lambda _event, _button, item=item: open_path(item["path"]))
                result_box.add(event)
                shown += 1
                if shown >= 80:
                    break
            if shown == 0:
                result_box.add(self.empty_state("Aucun résultat", "Change le filtre ou ajoute de nouveaux médias dans Baobab Sound et les packs."))
            result_box.show_all()

        filters.add(filter_card("all", "Tout", len(items)))
        filters.add(filter_card("audio", "Sons", counts["audio"]))
        filters.add(filter_card("image", "Images", counts["image"]))
        filters.add(filter_card("video", "Vidéos", counts["video"]))
        filters.add(filter_card("document", "Documents", counts["document"]))
        root.add(filters)
        root.add(self.label("Fichiers récents", "card-title"))
        search.connect("search-changed", lambda entry: render(entry.get_text()))
        render()
        root.add(result_box)
        root.add(self.label("Garde-fous", "card-title"))
        root.add(self.card("Média local avant publication", "Respect", "Un média dans Baobab reste local tant que droits, contexte et consentement ne sont pas clarifiés."))
        return self.scroll(root)

