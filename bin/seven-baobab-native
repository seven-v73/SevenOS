        provider = self.Gtk.CssProvider()
        provider.load_from_data(css)
        self.Gtk.StyleContext.add_provider_for_screen(self.Gdk.Screen.get_default(), provider, self.Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    def label(self, value: str, css: str | None = None, wrap: bool = True) -> object:
        label = self.Gtk.Label(label=value)
        label.set_xalign(0)
        if hasattr(label, "set_wrap"):
            label.set_wrap(wrap)
        else:
            label.set_line_wrap(wrap)
        if css:
            label.get_style_context().add_class(css)
        return label

    def button(self, label: str, callback) -> object:
        button = self.Gtk.Button(label=label)
        button.get_style_context().add_class("pill")
        button.connect("clicked", callback)
        return button

    def chip(self, value: str) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=6)
        box.get_style_context().add_class("chip")
        box.add(self.label(value, "card-meta", False))
        return box

    def format_size(self, size: int) -> str:
        value = float(size)
        for unit in ("o", "Ko", "Mo", "Go"):
            if value < 1024 or unit == "Go":
                return f"{value:.1f} {unit}" if unit != "o" else f"{int(value)} o"
            value /= 1024
        return f"{size} o"

    def journey_strip(self) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("journey-strip")
        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        top.pack_start(self.label("Chemin Baobab", "card-title", False), True, True, 0)
        top.pack_end(self.chip(self.active_ambiance()["label"]), False, False, 0)
        box.add(top)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(6)
        for title, meta, target in [
            ("Entrée", "région + pays", "entry"),
            ("Veillée", "lire + écouter", "veillee"),
            ("Séance", "rythme guidé", "session"),
            ("Dossiers", "atelier + terrain", "sessions"),
            ("Carnet", "mémoire locale", "carnet"),
            ("Médiathèque", "sons + images", "media"),
            ("Boussole", "transmettre", "compass"),
        ]:
            item = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
            item.get_style_context().add_class("journey-step")
            item.add(self.label(title, "card-title", False))
            item.add(self.label(meta, "card-meta", False))
            event = self.Gtk.EventBox()
            event.add(item)
            event.connect("button-press-event", lambda _event, _button, target=target: self.navigate(target))
            flow.add(event)
        box.add(flow)
        return box

    def transmission_payload(self) -> dict[str, str]:
        active = self.active_immersion()
        title, body, target = self.next_route_action()
        return {
            "immersion": text(active.get("name_fr") or active.get("name_en"), "Baobab"),
            "country": text(self.settings.get("country_focus"), "à choisir"),
            "ambiance": self.active_ambiance()["label"],
            "ritual": self.daily_ritual(),
            "next_title": title,
            "next_body": body,
            "next_target": target,
            "trace_count": str(self.trail_payload.get("count", 0)),
        }

    def transmission_text(self) -> str:
        payload = self.transmission_payload()
        return "\n".join([
            f"Carte de transmission Baobab - {date.today().isoformat()}",
            f"Immersion: {payload['immersion']}",
            f"Pays focus: {payload['country']}",
            f"Ambiance: {payload['ambiance']}",
            f"Rituel: {payload['ritual']}",
            f"Prochain geste: {payload['next_title']} - {payload['next_body']}",
            "Garde-fous: source identifiée, contexte noté, consentement vérifié si partage public.",
        ])

    def copy_transmission_card(self) -> None:
        clipboard = self.Gtk.Clipboard.get(self.Gdk.SELECTION_CLIPBOARD)
        clipboard.set_text(self.transmission_text(), -1)
        clipboard.store()
        self.add_trail_event("transmission", "Carte copiée", self.transmission_payload()["next_title"])
        self.show_message("Carte Baobab copiée", "La carte de transmission est dans le presse-papiers.")

    def transmission_card(self, compact: bool = True) -> object:
        payload = self.transmission_payload()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("transmission-card")
        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        title.pack_start(self.label("Carte de transmission", "card-title", False), False, False, 0)
        title.pack_start(self.label("Résumé prêt à noter, partager en brouillon ou relire avant collecte.", "card-meta"), False, False, 0)
        top.pack_start(title, True, True, 0)
        top.pack_end(self.button("Copier", lambda *_: self.copy_transmission_card()), False, False, 0)
        top.pack_end(self.button("Session", lambda *_: self.create_session_folder()), False, False, 0)
        top.pack_end(self.button("Note", lambda *_: self.create_daily_ritual_note()), False, False, 0)
        box.add(top)
        for label, value in [
            ("Immersion", payload["immersion"]),
            ("Pays", payload["country"]),
            ("Rituel", payload["ritual"]),
            ("Prochain geste", payload["next_title"]),
        ]:
            row = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
            row.get_style_context().add_class("transmission-line")
            row.add(self.label(label, "card-meta", False))
            row.add(self.label(value, "card-body", True))
            box.add(row)
            if compact and label == "Rituel":
                break
        guard = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        guard.get_style_context().add_class("transmission-guard")
        guard.add(self.label("Avant partage", "card-title", False))
        guard.add(self.label("Source, contexte, droits et consentement restent à vérifier avant toute transmission publique.", "card-body"))
        box.add(guard)
        return box

    def context_panel(self) -> object:
        active = self.active_immersion()
        country = text(self.settings.get("country_focus"), "à choisir")
        title, body, target = self.next_route_action()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("context-card")
        box.add(self.label("État Baobab", "card-title", False))
        self.context_labels = {}
        for label, value in [
            ("Immersion", text(active.get("name_fr") or active.get("name_en"), "Baobab")),
            ("Pays", country),
            ("Ambiance", self.active_ambiance()["label"]),
            ("Trace", f"{self.trail_payload.get('count', 0)} locale(s)"),
        ]:
            row = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=2)
            row.get_style_context().add_class("context-row")
            row.add(self.label(label, "card-meta", False))
            value_label = self.label(value, "card-body", False)
            self.context_labels[label] = value_label
            row.add(value_label)
            box.add(row)
        next_box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        next_box.get_style_context().add_class("context-action")
        self.context_next_title = self.label(title, "card-title", False)
        self.context_next_body = self.label(body, "card-meta", True)
        next_box.add(self.context_next_title)
        next_box.add(self.context_next_body)
        event = self.Gtk.EventBox()
        event.add(next_box)
        event.connect("button-press-event", lambda *_: self.navigate(self.next_route_action()[2]))
        box.add(event)
        box.add(self.context_quick_actions())
        return box

    def context_quick_button(self, label: str, callback) -> object:
        button = self.Gtk.Button(label=label)
        button.get_style_context().add_class("context-quick")
        button.connect("clicked", callback)
        return button

    def context_quick_actions(self) -> object:
        box = self.Gtk.FlowBox()
        box.set_selection_mode(self.Gtk.SelectionMode.NONE)
        box.set_max_children_per_line(2)
        self.context_quick_box = box
        self.fill_context_quick_actions(box)
        return box

    def fill_context_quick_actions(self, box) -> None:
        for child in box.get_children():
            box.remove(child)
        ambiance = self.active_ambiance_key()
        actions = [
            ("Note", lambda *_: self.create_daily_ritual_note()),
            ("Trace", lambda *_: self.add_memory_dialog()),
            ("Carte", lambda *_: self.copy_transmission_card()),
            ("Session", lambda *_: self.create_session_folder()),
        ]
        if ambiance == "calme":
            actions.extend([("Veillée", lambda *_: self.navigate("veillee")), ("Lire", lambda *_: self.navigate("heritage"))])
        elif ambiance == "apprentissage":
            actions.extend([("Langues", lambda *_: self.navigate("languages")), ("Séance", lambda *_: self.navigate("session"))])
        elif ambiance == "terrain":
            actions.extend([("Collecte", lambda *_: self.navigate("collect")), ("Pays", lambda *_: self.navigate("explore"))])
        else:
            actions.extend([("Sound", lambda *_: self.open_sound_folder()), ("Musée", lambda *_: self.navigate("museum"))])
        for label, callback in actions:
            box.add(self.context_quick_button(label, callback))
        box.show_all()

    def update_context_panel(self) -> None:
        if not hasattr(self, "context_labels"):
            return
        active = self.active_immersion()
        values = {
            "Immersion": text(active.get("name_fr") or active.get("name_en"), "Baobab"),
            "Pays": text(self.settings.get("country_focus"), "à choisir"),
            "Ambiance": self.active_ambiance()["label"],
            "Trace": f"{self.trail_payload.get('count', 0)} locale(s)",
        }
        for key, value in values.items():
            label = self.context_labels.get(key)
            if label is not None:
                label.set_text(value)
        title, body, _target = self.next_route_action()
        if hasattr(self, "context_next_title"):
            self.context_next_title.set_text(title)
        if hasattr(self, "context_next_body"):
            self.context_next_body.set_text(body)
        if hasattr(self, "context_quick_box"):
            self.fill_context_quick_actions(self.context_quick_box)

    def baobab_mark(self, size: int = 54) -> object:
        area = self.Gtk.DrawingArea()
        area.set_size_request(size, size)
        area.get_style_context().add_class("baobab-mark")

        def draw(_area, cr):
            width = _area.get_allocated_width()
            height = _area.get_allocated_height()
            cx = width / 2
            cy = height / 2
            radius = min(width, height) * .38
            cr.set_source_rgba(.14, .44, .28, .22)
            cr.arc(cx, cy, radius, 0, 6.283)
            cr.fill()
            cr.set_line_cap(1)
            cr.set_line_width(max(2, size * .055))
            cr.set_source_rgba(.70, .52, .30, .95)
            cr.move_to(cx, cy + radius * .54)
            cr.curve_to(cx - radius * .18, cy + radius * .08, cx + radius * .14, cy - radius * .16, cx, cy - radius * .48)
            cr.stroke()
            cr.set_line_width(max(1.4, size * .035))
            cr.set_source_rgba(.43, .72, .46, .96)
            for dx, dy in [(-.58, -.22), (-.38, -.52), (.0, -.62), (.40, -.50), (.60, -.20)]:
                cr.move_to(cx, cy - radius * .26)
                cr.curve_to(cx + dx * radius * .36, cy + dy * radius * .20, cx + dx * radius, cy + dy * radius, cx + dx * radius, cy + dy * radius)
                cr.stroke()
            cr.set_source_rgba(.87, .70, .42, .90)
            cr.arc(cx, cy - radius * .52, max(2.2, size * .055), 0, 6.283)
            cr.fill()
            return False

        area.connect("draw", draw)
        return area

    def scroll(self, child) -> object:
        scroller = self.Gtk.ScrolledWindow()
        scroller.set_policy(self.Gtk.PolicyType.NEVER, self.Gtk.PolicyType.AUTOMATIC)
        scroller.add(child)
        return scroller

    def empty_state(self, title: str, body: str, action_label: str = "", action=None) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("empty-state")
        box.add(self.label(title, "card-title"))
        box.add(self.label(body, "card-body"))
        if action_label and action:
            box.add(self.button(action_label, action))
        return box

    def card(self, title: str, meta: str, body: str, on_click=None) -> object:
        event = self.Gtk.EventBox()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=7)
        box.get_style_context().add_class("card")
        box.add(self.label(title, "card-title"))
        if meta:
            box.add(self.label(meta, "card-meta"))
        if body:
            box.add(self.label(body, "card-body"))
        event.add(box)
        if on_click:
            event.connect("button-press-event", lambda *_: on_click())
        return event

    def ambiance_card(self, key: str, item: dict[str, str], compact: bool = False) -> object:
        event = self.Gtk.EventBox()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=5)
        box.get_style_context().add_class("ambiance-button")
        if key == self.active_ambiance_key():
            box.get_style_context().add_class("ambiance-active")
        box.add(self.label(item["label"], "card-title", False))
        box.add(self.label(item["subtitle"], "card-meta", True))
        if not compact:
            box.add(self.label(item["body"], "card-body", True))
        event.add(box)
        event.connect("button-press-event", lambda *_: self.set_ambiance(key))
        return event

    def ambiance_panel(self) -> object:
        active = self.active_ambiance()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("ambiance-panel")
        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        text_box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
        text_box.pack_start(self.label("Ambiance Baobab", "card-title", False), False, False, 0)
        text_box.pack_start(self.label(f"{active['label']} · {active['subtitle']}", "card-meta"), False, False, 0)
        top.pack_start(text_box, True, True, 0)
        top.pack_end(self.chip(f"Sommet · {active['hint']}"), False, False, 0)
        box.add(top)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(4)
        for key, item in self.ambiance_modes().items():
            flow.add(self.ambiance_card(key, item, compact=True))
        box.add(flow)
        return box

    def compass_panel(self, compact: bool = True) -> object:
        payload = getattr(self, "compass_payload", {}) or {}
        next_item = payload.get("next", {})
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("compass-panel")
        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
        title.pack_start(self.label("Boussole Baobab", "card-title", False), False, False, 0)
        title.pack_start(self.label(f"Prochain geste · {next_item.get('title', 'Comprendre')}", "card-meta"), False, False, 0)
        top.pack_start(title, True, True, 0)
        top.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("compass")), False, False, 0)
        box.add(top)
        if next_item.get("body"):
            box.add(self.label(text(next_item.get("body")), "card-body"))
        if not compact:
            flow = self.Gtk.FlowBox()
            flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
            flow.set_max_children_per_line(3)
            for item in payload.get("directions", []):
                card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=6)
                card.get_style_context().add_class("compass-direction")
                card.get_style_context().add_class("compass-ready" if item.get("state") == "ready" else "compass-todo")
                card.add(self.label(text(item.get("title")), "card-title", False))
                card.add(self.label(text(item.get("body")), "card-body"))
                flow.add(card)
            box.add(flow)
        return box

    def today_panel(self, compact: bool = True) -> object:
        payload = getattr(self, "today_payload", {}) or {}
        next_item = payload.get("next", {})
        route = payload.get("route", {})
        immersion = payload.get("immersion", {})
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("today-panel")
        hero = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        hero.get_style_context().add_class("today-hero")
        hero.pack_start(self.baobab_mark(52), False, False, 0)
        text_box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        text_box.pack_start(self.label("Aujourd'hui dans Baobab", "card-title", False), False, False, 0)
        text_box.pack_start(self.label(text(payload.get("ritual"), self.daily_ritual()), "card-body"), False, False, 0)
        text_box.pack_start(self.label(f"{text(immersion.get('name_fr') or immersion.get('name_en'), 'Baobab')} · Route {route.get('done', 0)}/{route.get('total', 0)} · {route.get('score', 0)}%", "card-meta"), False, False, 0)
        hero.pack_start(text_box, True, True, 0)
        hero.pack_end(self.button("Continuer", lambda *_: self.stack.set_visible_child_name("today")), False, False, 0)
        box.add(hero)
        if next_item:
            box.add(self.card(text(next_item.get("title"), "Prochain geste"), "Recommandé maintenant", text(next_item.get("body")), lambda: self.launch_today_action(text(next_item.get("command")))))
        if not compact:
            actions = self.Gtk.FlowBox()
            actions.set_selection_mode(self.Gtk.SelectionMode.NONE)
            actions.set_max_children_per_line(4)
            for item in payload.get("quick_actions", []):
                actions.add(self.card(text(item.get("title")), text(item.get("command")), "", lambda item=item: self.launch_today_action(text(item.get("command")))))
            box.add(actions)
        return box

    def trail_panel(self, compact: bool = True) -> object:
        payload = getattr(self, "trail_payload", {}) or {}
        events = payload.get("events", [])
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("trail-panel")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
        title.pack_start(self.label("Trace vivante", "card-title", False), False, False, 0)
        title.pack_start(self.label(f"{payload.get('count', 0)} trace(s) locales · jamais envoyées", "card-meta"), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.button("Ajouter", lambda *_: self.add_memory_dialog()), False, False, 0)
        header.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("trail")), False, False, 0)
        box.add(header)
        if not events:
            box.add(self.label("Aucune trace pour l’instant. Les choix Baobab importants apparaîtront ici.", "card-body"))
            return box
        for item in events[:4 if compact else 12]:
            row = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
            row.get_style_context().add_class("trail-row")
            row.add(self.label(text(item.get("title"), "Trace"), "card-title", False))
            meta = " · ".join(part for part in [text(item.get("time")), text(item.get("kind")), text(item.get("country_focus"))] if part)
            row.add(self.label(meta, "card-meta", False))
            if item.get("body"):
                row.add(self.label(text(item.get("body")), "card-body"))
            box.add(row)
        return box

    def launch_today_action(self, command: str) -> None:
        if not command:
            return
        subprocess.Popen(shlex.split(command), stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def station(self, title: str, meta: str, body: str, target: str) -> object:
        event = self.Gtk.EventBox()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        box.get_style_context().add_class("station")
        box.add(self.label(title, "card-title"))
        box.add(self.label(meta, "card-meta"))
        box.add(self.label(body, "card-body"))
        event.add(box)
        event.connect("button-press-event", lambda *_: self.stack.set_visible_child_name(target))
        return event

    def route_card(self) -> object:
        steps = self.route_progress()
        done = sum(1 for _label, state, _meta in steps if state)
        fraction = done / max(len(steps), 1)
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("route-card")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=2)
        title.pack_start(self.label("Carnet de route", "card-title"), False, False, 0)
        title.pack_start(self.label("Un fil clair pour explorer sans se perdre.", "card-meta"), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.chip(f"{done}/{len(steps)}"), False, False, 0)
        box.add(header)
        progress = self.Gtk.ProgressBar()
        progress.set_fraction(fraction)
        box.add(progress)
        for label, state, meta in steps:
            row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
            row.get_style_context().add_class("route-row")
            row.pack_start(self.label("✓" if state else "•", "route-ok" if state else "route-wait", False), False, False, 0)
            row.pack_start(self.label(label, "card-body", False), False, False, 0)
            row.pack_end(self.label(meta, "card-meta", False), False, False, 0)
            box.add(row)
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        note = self.todays_ritual_note()
        actions.add(self.button("Ouvrir la note" if note else "Créer la note", lambda *_: open_path(note) if note else self.create_daily_ritual_note()))
        actions.add(self.button("Choisir un pays", lambda *_: self.stack.set_visible_child_name("explore")))
        actions.add(self.button("Changer d’immersion", lambda *_: self.stack.set_visible_child_name("immersions")))
        box.add(actions)
        return box

    def next_action_card(self) -> object:
        title, body, target = self.next_route_action()
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        box.get_style_context().add_class("next-card")
        box.pack_start(self.baobab_mark(46), False, False, 0)
        content = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=5)
        content.pack_start(self.label("Prochain geste", "card-meta", False), False, False, 0)
        content.pack_start(self.label(title, "card-title"), False, False, 0)
        content.pack_start(self.label(body, "card-body"), False, False, 0)
        box.pack_start(content, True, True, 0)
        if target == "journal" and self.todays_ritual_note() is None:
            box.pack_end(self.button("Créer", lambda *_: self.create_daily_ritual_note()), False, False, 0)
        else:
            box.pack_end(self.button("Continuer", lambda *_: self.stack.set_visible_child_name(target)), False, False, 0)
        return box

    def tree_canvas(self) -> object:
        area = self.Gtk.DrawingArea()
        area.set_size_request(360, 300)
        area.get_style_context().add_class("tree-canvas")

        def draw(_area, cr):
            width = _area.get_allocated_width()
            height = _area.get_allocated_height()
            cr.set_source_rgb(0.050, 0.070, 0.060)
            cr.paint()
            trunk_x = width * 0.50
            base_y = height * 0.82
            crown_y = height * 0.34
            cr.set_line_cap(1)
            cr.set_line_width(18)
            cr.set_source_rgb(0.55, 0.38, 0.24)
            cr.move_to(trunk_x, base_y)
            cr.curve_to(trunk_x - 28, height * 0.62, trunk_x + 22, height * 0.50, trunk_x, crown_y)
            cr.stroke()
            branches = [
                (-120, -34, 0.29, 0.18),
                (-82, -92, 0.36, 0.11),
                (90, -82, 0.64, 0.13),
                (124, -25, 0.71, 0.23),
                (-42, -124, 0.45, 0.07),
                (38, -128, 0.56, 0.07),
            ]
            for dx, dy, ex, ey in branches:
                cr.set_line_width(5)
                cr.set_source_rgb(0.49, 0.34, 0.22)
                cr.move_to(trunk_x, crown_y + 28)
                cr.curve_to(trunk_x + dx * .26, crown_y + dy * .20, width * ex, height * ey + 40, width * ex, height * ey + 56)
                cr.stroke()
            leaves = [
                (0.30, 0.26, 42), (0.42, 0.18, 52), (0.57, 0.18, 48),
                (0.70, 0.28, 44), (0.48, 0.31, 60), (0.60, 0.36, 40)
            ]
            for x, y, radius in leaves:
                cr.set_source_rgba(0.31, 0.45, 0.35, 0.72)
                cr.arc(width * x, height * y, radius, 0, 6.283)
                cr.fill()
            cr.set_source_rgba(0.78, 0.61, 0.39, 0.82)
            for x, y in [(0.31, .42), (.43, .27), (.58, .26), (.70, .42), (.50, .58)]:
                cr.arc(width * x, height * y, 4, 0, 6.283)
                cr.fill()
            cr.set_source_rgba(0.93, 0.88, 0.78, 0.86)
            cr.select_font_face("Noto Sans", 0, 0)
            cr.set_font_size(12)
            for label, x, y in [("Racines", .18, .86), ("Tronc", .47, .64), ("Branches", .62, .18), ("Feuilles", .70, .52), ("Collecte", .12, .50), ("Archives", .43, .91)]:
                cr.move_to(width * x, height * y)
                cr.show_text(label)
            return False

        area.connect("draw", draw)
        return area

    def immersion_canvas(self) -> object:
        area = self.Gtk.DrawingArea()
        area.set_size_request(420, 260)
        area.get_style_context().add_class("immersion-map")
        active_id = text(self.active_immersion().get("id"))

        def draw(_area, cr):
            width = _area.get_allocated_width()
            height = _area.get_allocated_height()
            cr.set_source_rgb(0.045, 0.060, 0.055)
            cr.paint()
            center_x = width * 0.50
            center_y = height * 0.53
            cr.set_line_width(1.2)
            for radius, alpha in [(92, .20), (132, .13), (172, .08)]:
                cr.set_source_rgba(0.72, 0.58, 0.36, alpha)
                cr.arc(center_x, center_y, radius, 0, 6.283)
                cr.stroke()
            points = [
                ("sahel", "Sahel", .38, .26, .52, .70, .40),
                ("mande", "Mandé", .30, .42, .48, .68, .38),
                ("swahili-coast", "Swahili", .68, .48, .40, .65, .78),
                ("great-lakes", "Lacs", .58, .54, .58, .82, .58),
                ("kongo-atlantic", "Kongo", .48, .60, .67, .54, .82),
                ("horn", "Corne", .68, .30, .75, .66, .45),
                ("southern-africa", "Australe", .54, .78, .43, .74, .62),
                ("islands", "Îles", .78, .72, .62, .82, .74),
            ]
            for key, label, x, y, r, g, b in points:
                px = width * x
                py = height * y
                is_active = key == active_id
                cr.set_source_rgba(r, g, b, .42 if is_active else .24)
                cr.set_line_width(2.2 if is_active else 1.0)
                cr.move_to(center_x, center_y)
                cr.line_to(px, py)
                cr.stroke()
                if is_active:
                    cr.set_source_rgba(r, g, b, .18)
                    cr.arc(px, py, 19, 0, 6.283)
                    cr.fill()
                cr.set_source_rgba(r, g, b, .88)
                cr.arc(px, py, 9 if is_active else 7, 0, 6.283)
                cr.fill()
                cr.set_source_rgba(.94, .90, .80, .82)
                cr.select_font_face("Noto Sans", 0, 0)
                cr.set_font_size(11)
                cr.move_to(px + 11, py + 4)
                cr.show_text(label)
            cr.set_source_rgba(.82, .67, .42, .96)
            cr.arc(center_x, center_y, 9, 0, 6.283)
            cr.fill()
            cr.set_source_rgba(.95, .91, .80, .90)
            cr.set_font_size(12)
            cr.move_to(center_x - 34, center_y + 28)
            cr.show_text("Baobab")
            return False

        area.connect("draw", draw)
        return area

    def clear(self, box) -> None:
        for child in box.get_children():
            box.remove(child)

    def speak_text(self, value: str) -> None:
        spoken = " ".join(value.split())[:900]
        if not spoken:
            return
        piper_model = os.environ.get("SEVENOS_BAOBAB_PIPER_MODEL", "")
        piper_bin = command_path("piper", "/opt/piper-tts/piper")
        if piper_bin and piper_model and available("aplay"):
            process = subprocess.Popen([piper_bin, "--model", piper_model, "--output-raw"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
            subprocess.Popen(["aplay", "-r", "22050", "-f", "S16_LE", "-t", "raw", "-"], stdin=process.stdout, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            if process.stdin:
                process.stdin.write(spoken.encode("utf-8"))
                process.stdin.close()
            return
        if available("espeak-ng"):
            subprocess.Popen(["espeak-ng", "-v", "fr", "-s", "150", spoken], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        dialog = self.Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=self.Gtk.MessageType.INFO, buttons=self.Gtk.ButtonsType.OK, text="Narration non disponible")
        dialog.format_secondary_text("Installe Piper avec un modèle français, ou espeak-ng, pour activer la lecture vocale hors ligne.")
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def open_sound_folder(self) -> None:
        folder = WORKSPACE / "Sound"
        folder.mkdir(parents=True, exist_ok=True)
        try:
            payload = json.loads(run_seven("baobab", "sound", "--json"))
        except Exception:
            payload = {"library": str(folder)}
        audio_files = []
        for library in (Path(payload.get("library", folder)), DATA / "sound"):
            for pattern in ("*.mp3", "*.ogg", "*.flac", "*.wav", "*.m4a", "*.opus"):
                audio_files.extend(library.glob(pattern))
        if audio_files and available("mpv"):
            subprocess.Popen([str(CONFIG / "bin/baobab-sound")], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        if available("xdg-open"):
            open_path(folder)
        message = "Place des fichiers audio dans Baobab Sound. Ils seront lus via la configuration MPV propre au mini-OS Baobab."
        dialog = self.Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=self.Gtk.MessageType.INFO, buttons=self.Gtk.ButtonsType.OK, text="Baobab Sound prêt")
        dialog.format_secondary_text(message)
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def heritage_detail(self, item: dict) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        box.get_style_context().add_class("detail")
        title = self.localized(item, "title", "Sans titre")
        countries = ", ".join(item.get("countries", []))
        concepts = ", ".join(item.get("concepts", [])[:10])
        summary = self.localized(item, "summary")
        box.add(self.label(title, "title"))
        box.add(self.label(f"{countries} · {item.get('year', '')} · {item.get('type_fr') or item.get('type_en') or item.get('type_acronym', 'ICH')}", "card-meta"))
        if concepts:
            box.add(self.label(f"Thèmes: {concepts}", "subtitle"))
        box.add(self.label(summary, "card-body"))
        source = item.get("url_fr") or item.get("url_en")
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Lire le résumé", lambda *_: self.speak_text(summary)))
        actions.add(self.button("Ouvrir la fiche source", lambda *_: open_url(source)))
        actions.add(self.button("Voir dans l'export Patrimoine", lambda *_: open_path(WORKSPACE / "Heritage/index.html")))
        box.add(actions)
        return box

