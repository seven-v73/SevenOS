#!/usr/bin/env python3
"""Baobab OS native public interface.

French-first GTK surface for the Baobab cultural mini OS. The generated HTML
pages remain useful offline exports, but this is the normal public UI.
"""

from __future__ import annotations

import json
import os
import re
import shlex
import shutil
import subprocess
import sys
from datetime import date, datetime
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None
PROFILE_CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos/profiles/baobab"
PROFILE_DATA = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local/share")) / "sevenos/profiles/baobab"
PROFILE_CACHE = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "sevenos/profiles/baobab"
CONFIG = PROFILE_CONFIG / "baobab"
DATA = PROFILE_DATA / "baobab"
CACHE = PROFILE_CACHE / "baobab"
WORKSPACE = Path.home() / "Baobab"
SETTINGS_FILE = CONFIG / "native-settings.json"
TRAIL_FILE = DATA / "trail/events.jsonl"
LANGUAGES_SOURCE = ROOT / "identity/baobab_languages.json"
IMMERSIONS_SOURCE = ROOT / "identity/baobab_immersions.json"
PROTOCOLS_SOURCE = ROOT / "identity/baobab_protocols.json"


def run_seven(*args: str) -> str:
    return subprocess.check_output([str(ROOT / "bin/seven"), *args], cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})


def load_json(path: Path, fallback):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return fallback


def bootstrap() -> None:
    try:
        run_seven("baobab", "bootstrap")
    except Exception:
        pass


def open_path(path: Path) -> None:
    if path.exists():
        subprocess.Popen(["xdg-open", str(path)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def open_url(url: str) -> None:
    if url:
        subprocess.Popen(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def available(command: str) -> bool:
    return shutil.which(command) is not None


def command_path(*commands: str) -> str:
    for command in commands:
        if command.startswith("/") and Path(command).exists():
            return command
        resolved = shutil.which(command)
        if resolved:
            return resolved
    return ""


def text(value, fallback: str = "") -> str:
    return str(value or fallback)


def slugify(value: str, fallback: str = "collecte") -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-")
    return slug or fallback


def unique_path(path: Path) -> Path:
    if not path.exists():
        return path
    stem = path.stem
    suffix = path.suffix
    for index in range(2, 1000):
        candidate = path.with_name(f"{stem}-{index}{suffix}")
        if not candidate.exists():
            return candidate
    return path.with_name(f"{stem}-new{suffix}")


def save_json(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")


MEDIA_EXTENSIONS = {
    ".mp3": "audio", ".ogg": "audio", ".flac": "audio", ".wav": "audio", ".m4a": "audio", ".opus": "audio",
    ".png": "image", ".jpg": "image", ".jpeg": "image", ".webp": "image", ".gif": "image",
    ".mp4": "video", ".mkv": "video", ".webm": "video", ".mov": "video",
    ".pdf": "document", ".epub": "document",
}


class BaobabNative:
    def __init__(self, Gtk, Gdk, initial_view: str = "home"):
        self.Gtk = Gtk
        self.Gdk = Gdk
        self.initial_view = initial_view
        self.catalog = load_json(DATA / "catalog.json", {"records": []})
        self.countries_payload = load_json(DATA / "explore/africa-countries.json", {"countries": []})
        self.unesco_payload = load_json(DATA / "heritage/african-unesco-ich.json", {"items": []})
        self.datasets_payload = load_json(DATA / "offline/datasets.json", {"sources": []})
        self.settings = load_json(SETTINGS_FILE, {"language": "fr", "country_focus": "", "ambiance": "calme"})
        self.engines_payload = self.load_engines()
        self.services_payload = self.load_services()
        self.capabilities_payload = self.load_capabilities()
        self.packs_payload = self.load_packs()
        self.audit_payload = self.load_pack_audit()
        self.languages_payload = self.load_languages()
        self.protocols_payload = self.load_protocols()
        self.immersions_payload = self.load_immersions()
        self.compass_payload = self.load_compass()
        self.today_payload = self.load_today()
        self.trail_payload = self.load_trail()
        self.session_payload = self.load_session()
        self.nav_buttons = {}
        self.view_labels = {}
        self.records = self.catalog.get("records", [])
        self.countries = self.countries_payload.get("countries", [])
        self.heritage = self.unesco_payload.get("items", [])
        self.datasets = self.datasets_payload.get("sources", [])
        self.languages = self.languages_payload.get("languages", [])
        self.protocols = self.protocols_payload.get("principles", [])
        self.sensitivity_levels = self.protocols_payload.get("sensitivity_levels", [])
        self.immersions = self.immersions_payload.get("regions", [])
        self.pathways = self.immersions_payload.get("pathways", [])
        self.active_country = ""

    def view_label(self, key: str) -> str:
        return text(getattr(self, "view_labels", {}).get(key), key)

    def navigate(self, key: str) -> None:
        if not hasattr(self, "stack"):
            return
        current = self.stack.get_visible_child_name()
        if current == key:
            return
        self.stack.set_visible_child_name(key)
        self.update_nav_state()

    def update_nav_state(self) -> None:
        current = self.stack.get_visible_child_name() if hasattr(self, "stack") else ""
        for key, button in getattr(self, "nav_buttons", {}).items():
            context = button.get_style_context()
            if key == current:
                context.add_class("nav-active")
            else:
                context.remove_class("nav-active")

    def load_engines(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "engines", "--json"))
        except Exception:
            return {"engines": [], "available": 0, "total": 0, "immersive_score": 0, "immersive_next": []}

    def load_services(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "service-doctor", "--json"))
        except Exception:
            return {"services": [], "score": 0, "state": "unknown", "issues": []}

    def load_capabilities(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "capability-doctor", "--json"))
        except Exception:
            return {"domains": [], "score": 0, "state": "unknown", "goals": []}

    def load_packs(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "packs", "--json"))
        except Exception:
            return {"packs": [], "count": 0}

    def load_pack_audit(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "audit-packs", "--json"))
        except Exception:
            return {"state": "unknown", "score": 0, "packs": []}

    def load_languages(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "languages", "--json"))
        except Exception:
            return load_json(LANGUAGES_SOURCE, {"languages": []})

    def load_protocols(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "protocols", "--json"))
        except Exception:
            return load_json(PROTOCOLS_SOURCE, {"principles": [], "sensitivity_levels": []})

    def load_immersions(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "immersions", "--json"))
        except Exception:
            return load_json(IMMERSIONS_SOURCE, {"regions": [], "pathways": []})

    def load_compass(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "compass", "--json"))
        except Exception:
            return {"directions": [], "next": {}, "principles": []}

    def load_today(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "today", "--json"))
        except Exception:
            return {"next": {}, "route": {"steps": []}, "quick_actions": []}

    def load_trail(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "trail", "--json"))
        except Exception:
            return {"events": [], "count": 0, "path": str(TRAIL_FILE)}

    def load_session(self) -> dict:
        try:
            return json.loads(run_seven("baobab", "session", "--json"))
        except Exception:
            return {"phases": [], "duration_minutes": 0, "title": "Séance Baobab", "intent": ""}

    def run_action(self, *args: str) -> None:
        try:
            run_seven(*args)
            self.reload()
        except Exception as exc:
            self.show_message("Action Baobab impossible", str(exc), error=True)

    def show_message(self, title: str, body: str = "", error: bool = False) -> None:
        message_type = self.Gtk.MessageType.ERROR if error else self.Gtk.MessageType.INFO
        dialog = self.Gtk.MessageDialog(transient_for=self.window, flags=0, message_type=message_type, buttons=self.Gtk.ButtonsType.OK, text=title)
        if body:
            dialog.format_secondary_text(body)
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def localized(self, item: dict, key: str, fallback: str = "") -> str:
        language = self.settings.get("language", "fr")
        if language == "fr":
            return text(item.get(f"{key}_fr") or item.get(f"{key}_en") or item.get(key), fallback)
        return text(item.get(f"{key}_en") or item.get(f"{key}_fr") or item.get(key), fallback)

    def set_language(self, language: str) -> None:
        self.settings["language"] = language
        save_json(SETTINGS_FILE, self.settings)
        self.add_trail_event("preference", "Langue Baobab", language)
        self.reload()
        self.refresh_views()

    def set_immersion_focus(self, immersion_id: str) -> None:
        self.settings["immersion_focus"] = immersion_id
        save_json(SETTINGS_FILE, self.settings)
        self.add_trail_event("focus", "Immersion choisie", immersion_id)

    def set_country_focus(self, country_name: str) -> None:
        self.settings["country_focus"] = country_name
        save_json(SETTINGS_FILE, self.settings)
        self.add_trail_event("focus", "Pays focus", country_name)

    def commit_focus(self, immersion_id: str = "", country_name: str = "", target: str = "entry") -> None:
        if immersion_id:
            self.settings["immersion_focus"] = immersion_id
            self.add_trail_event("focus", "Immersion choisie", immersion_id)
        if country_name:
            self.settings["country_focus"] = country_name
            self.add_trail_event("focus", "Pays focus", country_name)
        save_json(SETTINGS_FILE, self.settings)
        self.reload()
        self.refresh_views(target)

    def refresh_views(self, target: str | None = None) -> None:
        if not hasattr(self, "stack"):
            return
        current = target or self.stack.get_visible_child_name() or "home"
        refresh = {
            "home": ("Accueil", self.home_view),
            "entry": ("Entrée", self.entry_view),
            "veillee": ("Veillée", self.veillee_view),
            "session": ("Séance", self.session_view),
            "carnet": ("Carnet", self.carnet_view),
            "sessions": ("Sessions", self.sessions_view),
            "constellation": ("Constellation", self.constellation_view),
            "today": ("Aujourd'hui", self.today_view),
            "compass": ("Boussole", self.compass_view),
            "trail": ("Trace", self.trail_view),
            "explore": ("Explorer", self.explore_view),
            "immersions": ("Immersions", self.immersions_view),
            "media": ("Médiathèque", self.media_view),
            "journal": ("Journal", self.journal_view),
            "protocols": ("Protocoles", self.protocols_view),
            "preferences": ("Préférences", self.preferences_view),
        }
        for view_key, (label, builder) in refresh.items():
            old = self.stack.get_child_by_name(view_key)
            if old is not None:
                self.stack.remove(old)
            self.stack.add_titled(builder(), view_key, label)
        self.stack.set_visible_child_name(current if current in refresh else "home")
        self.update_nav_state()
        self.update_context_panel()

    def add_trail_event(self, kind: str, title: str, body: str = "") -> None:
        TRAIL_FILE.parent.mkdir(parents=True, exist_ok=True)
        event = {
            "schema": "sevenos.baobab.trail.event.v1",
            "time": datetime.now().isoformat(timespec="seconds"),
            "kind": kind,
            "title": title,
            "body": body,
            "ambiance": self.active_ambiance_key() if hasattr(self, "settings") else "calme",
            "immersion_focus": self.settings.get("immersion_focus", ""),
            "country_focus": self.settings.get("country_focus", ""),
        }
        with TRAIL_FILE.open("a", encoding="utf-8") as handle:
            handle.write(json.dumps(event, ensure_ascii=False) + "\n")

    def add_memory_dialog(self) -> None:
        dialog = self.Gtk.Dialog(title="Ajouter une trace Baobab", transient_for=self.window, flags=0)
        dialog.set_default_size(520, 220)
        area = dialog.get_content_area()
        area.set_border_width(16)
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.add(self.label("Mémoire locale", "card-title", False))
        box.add(self.label("Note une lecture, une écoute, une personne ressource, une source à vérifier ou un lien culturel.", "card-body"))
        entry = self.Gtk.Entry()
        entry.set_placeholder_text("Ex: J'ai noté une source sur le balafon...")
        box.add(entry)
        area.add(box)
        dialog.add_button("Annuler", self.Gtk.ResponseType.CANCEL)
        dialog.add_button("Ajouter", self.Gtk.ResponseType.OK)

        def on_response(dialog, response):
            if response == self.Gtk.ResponseType.OK:
                value = entry.get_text().strip()
                if value:
                    self.add_trail_event("memoire", "Mémoire ajoutée", value)
                    self.reload()
                    if hasattr(self, "stack"):
                        old = self.stack.get_child_by_name("trail")
                        if old is not None:
                            self.stack.remove(old)
                        self.stack.add_titled(self.trail_view(), "trail", "Trace")
                        self.stack.set_visible_child_name("trail")
            dialog.destroy()

        dialog.connect("response", on_response)
        dialog.show_all()

    def ambiance_modes(self) -> dict[str, dict[str, str]]:
        return {
            "calme": {
                "label": "Calme",
                "subtitle": "lecture, écoute douce et mémoire personnelle",
                "hint": "Racines",
                "body": "Un Baobab contemplatif pour lire, écouter, prendre des notes et ne pas brusquer l'utilisateur.",
            },
            "apprentissage": {
                "label": "Apprentissage",
                "subtitle": "langues, patrimoine, parcours et transmission",
                "hint": "Mémoire",
                "body": "Un Baobab pédagogique qui met en avant langues, patrimoine, rituels et parcours guidés.",
            },
            "terrain": {
                "label": "Terrain",
                "subtitle": "collecte, source, consentement et relecture locale",
                "hint": "Terrain",
                "body": "Un Baobab orienté collecte responsable: brouillons, sources, droits et validation communautaire.",
            },
            "scene": {
                "label": "Scène",
                "subtitle": "son, récit, musée, création et présentation",
                "hint": "Scène",
                "body": "Un Baobab plus expressif pour écouter, raconter, créer et préparer une présentation culturelle.",
            },
        }

    def active_ambiance_key(self) -> str:
        key = text(self.settings.get("ambiance"), "calme")
        return key if key in self.ambiance_modes() else "calme"

    def active_ambiance(self) -> dict[str, str]:
        return self.ambiance_modes()[self.active_ambiance_key()]

    def set_ambiance(self, key: str) -> None:
        if key not in self.ambiance_modes():
            return
        self.settings["ambiance"] = key
        save_json(SETTINGS_FILE, self.settings)
        self.add_trail_event("ambiance", "Ambiance Baobab", self.ambiance_modes()[key]["label"])
        self.reload()
        self.refresh_views("preferences")

    def matching_immersions(self, country_name: str) -> list[dict]:
        normalized = country_name.lower()
        return [
            item for item in self.immersions
            if any(normalized == text(country).lower() for country in item.get("countries", []))
        ]

    def active_immersion(self) -> dict:
        wanted = text(self.settings.get("immersion_focus"))
        return next((item for item in self.immersions if item.get("id") == wanted), self.immersions[0] if self.immersions else {})

    def daily_ritual(self) -> str:
        active = self.active_immersion()
        rituals = active.get("daily_rituals_fr", []) or active.get("daily_rituals_en", [])
        if not rituals:
            return "Choisir un pays, lire une fiche et créer une note en brouillon."
        return text(rituals[date.today().toordinal() % len(rituals)])

    def todays_ritual_note(self) -> Path | None:
        folder = WORKSPACE / "Rituels du jour"
        if not folder.exists():
            return None
        prefix = f"{date.today().isoformat()}-rituel-baobab"
        return next(iter(sorted(folder.glob(f"{prefix}*.md"))), None)

    def route_progress(self) -> list[tuple[str, bool, str]]:
        active = self.active_immersion()
        country = text(self.settings.get("country_focus"))
        return [
            ("Immersion choisie", bool(active), text(active.get("name_fr") or active.get("name_en"), "Baobab")),
            ("Pays focus", bool(country), country or "à choisir"),
            ("Note du jour", self.todays_ritual_note() is not None, "Markdown local"),
            ("Sources locales", bool(self.datasets), f"{len(self.datasets)} source(s)"),
            ("Packs culturels", bool(self.packs_payload.get("packs")), f"{self.packs_payload.get('count', 0)} pack(s)"),
        ]

    def entry_steps(self) -> list[dict[str, str]]:
        active = self.active_immersion()
        country = text(self.settings.get("country_focus"))
        note = self.todays_ritual_note()
        return [
            {
                "title": "Entrer par une région",
                "body": text(active.get("tone_fr") or active.get("tone_en"), "Choisir une immersion culturelle comme point d'ancrage."),
                "meta": text(active.get("name_fr") or active.get("name_en"), "Immersion à choisir"),
                "target": "immersions",
                "state": "ready" if active else "todo",
            },
            {
                "title": "Relier un pays",
                "body": "Associer territoire, langue, pratique, source et récit avant de collecter.",
                "meta": country or "Pays à choisir",
                "target": "explore",
                "state": "ready" if country else "todo",
            },
            {
                "title": "Créer une trace",
                "body": "Garder une note locale courte pour ne pas perdre le fil de l'exploration.",
                "meta": f"{self.trail_payload.get('count', 0)} trace(s)",
                "target": "trail",
                "state": "ready" if self.trail_payload.get("count", 0) else "todo",
            },
            {
                "title": "Préparer la transmission",
                "body": "Passer par le journal, la collecte et les packs avant tout partage public.",
                "meta": "Note du jour prête" if note else "Note du jour à créer",
                "target": "journal",
                "state": "ready" if note else "todo",
            },
        ]

    def entry_panel(self, compact: bool = False) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("entry-panel")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        header.pack_start(self.baobab_mark(48), False, False, 0)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=3)
        title.pack_start(self.label("Entrée Baobab", "card-title", False), False, False, 0)
        title.pack_start(self.label("Un passage calme: région, pays, trace, transmission.", "card-meta"), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.chip(self.active_ambiance()["label"]), False, False, 0)
        box.add(header)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(4 if compact else 2)
        for step in self.entry_steps():
            card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=6)
            card.get_style_context().add_class("entry-step")
            card.get_style_context().add_class("entry-ready" if step["state"] == "ready" else "entry-todo")
            card.add(self.label(step["title"], "card-title", False))
            card.add(self.label(step["meta"], "card-meta", False))
            if not compact:
                card.add(self.label(step["body"], "card-body"))
            event = self.Gtk.EventBox()
            event.add(card)
            event.connect("button-press-event", lambda _event, _button, target=step["target"]: self.stack.set_visible_child_name(target))
            flow.add(event)
        box.add(flow)
        return box

    def veillee_panel(self, compact: bool = True) -> object:
        active = self.active_immersion()
        ambiance = self.active_ambiance()
        next_item = (self.today_payload or {}).get("next", {})
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        box.get_style_context().add_class("veillee-panel")
        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=16)
        orbit = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=0)
        orbit.get_style_context().add_class("veillee-orbit")
        orbit.pack_start(self.baobab_mark(66), False, False, 0)
        top.pack_start(orbit, False, False, 0)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=5)
        title.pack_start(self.label("Veillée Baobab", "card-title", False), False, False, 0)
        title.pack_start(self.label("Un espace de présence: lire, écouter, noter, puis transmettre avec soin.", "card-body"), False, False, 0)
        meta = f"{text(active.get('name_fr') or active.get('name_en'), 'Baobab')} · {ambiance['label']} · {self.trail_payload.get('count', 0)} trace(s)"
        title.pack_start(self.label(meta, "card-meta", False), False, False, 0)
        top.pack_start(title, True, True, 0)
        top.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("veillee")), False, False, 0)
        box.add(top)
        if not compact:
            ritual = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=6)
            ritual.get_style_context().add_class("veillee-step")
            ritual.add(self.label("Rituel", "card-title", False))
            ritual.add(self.label(self.daily_ritual(), "card-body"))
            box.add(ritual)
        actions = self.Gtk.FlowBox()
        actions.set_selection_mode(self.Gtk.SelectionMode.NONE)
        actions.set_max_children_per_line(4)
        for title_text, meta_text, target in [
            ("Lire", "Patrimoine", "heritage"),
            ("Écouter", "Sound", "modules"),
            ("Noter", "Trace", "trail"),
            ("Transmettre", text(next_item.get("title"), "Boussole"), "compass"),
        ]:
            card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=5)
            card.get_style_context().add_class("veillee-step")
            card.add(self.label(title_text, "card-title", False))
            card.add(self.label(meta_text, "card-meta", False))
            event = self.Gtk.EventBox()
            event.add(card)
            event.connect("button-press-event", lambda _event, _button, target=target: self.stack.set_visible_child_name(target))
            actions.add(event)
        box.add(actions)
        return box

    def session_panel(self, compact: bool = True) -> object:
        payload = self.session_payload or {}
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("session-panel")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        title.pack_start(self.label(text(payload.get("title"), "Séance Baobab"), "card-title", False), False, False, 0)
        title.pack_start(self.label(text(payload.get("intent"), "Un rythme culturel guidé."), "card-body"), False, False, 0)
        title.pack_start(self.label(f"{payload.get('duration_minutes', 0)} min · {text(payload.get('ambiance'), 'calme')} · {payload.get('trail_count', 0)} trace(s)", "card-meta", False), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("session")), False, False, 0)
        box.add(header)
        phases = payload.get("phases", [])
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(5 if compact else 2)
        for phase in phases[:5 if compact else len(phases)]:
            phase_box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=5)
            phase_box.get_style_context().add_class("session-phase")
            phase_box.add(self.label(text(phase.get("title"), "Phase"), "card-title", False))
            phase_box.add(self.label(f"{phase.get('minutes', 0)} min", "card-meta", False))
            if not compact:
                phase_box.add(self.label(text(phase.get("body")), "card-body"))
            event = self.Gtk.EventBox()
            event.add(phase_box)
            command = text(phase.get("command"))
            event.connect("button-press-event", lambda _event, _button, command=command: self.launch_today_action(command))
            flow.add(event)
        box.add(flow)
        return box

    def recent_sessions_panel(self) -> object:
        sessions = self.session_folders()[:3]
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("recent-sessions-panel")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        title.pack_start(self.label("Dernières séances", "card-title", False), False, False, 0)
        title.pack_start(self.label("Dossiers d'atelier et de terrain prêts à reprendre.", "card-body"), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.button("Tout voir", lambda *_: self.navigate("sessions")), False, False, 0)
        box.add(header)
        if not sessions:
            empty = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=6)
            empty.get_style_context().add_class("recent-session-empty")
            empty.add(self.label("Aucune séance enregistrée", "card-title", False))
            empty.add(self.label("Crée une séance pour générer carte, checklist et dossier médias.", "card-body"))
            empty.add(self.button("Créer une séance", lambda *_: self.create_session_folder()))
            box.add(empty)
            return box
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(3)
        for item in sessions:
            card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=6)
            card.get_style_context().add_class("recent-session-card")
            card.get_style_context().add_class("session-ready" if item["state"] == "ready" else "session-partial")
            state_label = "complète" if item["state"] == "ready" else "à compléter"
            card.add(self.label(text(item["name"]), "card-title", False))
            card.add(self.label(f"{item['modified']} · {item['media_count']} média(s)", "card-meta", False))
            card.add(self.label(state_label, "card-body"))
            row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
            row.add(self.button("Ouvrir", lambda *_args, path=item["path"]: open_path(path)))
            row.add(self.button("Carte", lambda *_args, path=item["path"]: open_path(path / "carte-transmission.md")))
            card.add(row)
            flow.add(card)
        box.add(flow)
        return box

    def carnet_panel(self, compact: bool = True) -> object:
        notes = self.ritual_notes()
        events = (self.trail_payload or {}).get("events", [])
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("carnet-panel")
