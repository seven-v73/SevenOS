        box.pack_start(left, True, True, 0)
        box.pack_start(right, False, False, 0)
        return box

    def home_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        root.add(self.header())
        root.add(self.journey_strip())
