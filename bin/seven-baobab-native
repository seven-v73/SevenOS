    def heritage_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        root.set_border_width(18)
        left = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        left.set_size_request(560, -1)
        left.add(self.label("Patrimoine", "title"))
        left.add(self.label("Galerie native en français d'abord, alimentée par la base UNESCO africaine locale.", "subtitle"))
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Rechercher: pays, musique, danse, rituel, artisanat...")
        left.add(search)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        scroller = self.scroll(flow)
        detail = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        detail.add(self.label("Choisis un élément", "title"))
        detail.add(self.label("Clique une carte pour afficher une fiche lisible avec source et contexte.", "subtitle"))

        def render(query: str = "") -> None:
            for child in flow.get_children():
                flow.remove(child)
            q = query.lower().strip()
            shown = 0
            for item in sorted(self.heritage, key=lambda row: row.get("year", ""), reverse=True):
                title = self.localized(item, "title", "Sans titre")
                countries = ", ".join(item.get("countries", []))
                body = self.localized(item, "summary")[:280]
                haystack = " ".join([title, countries, " ".join(item.get("concepts", []))]).lower()
                if q and q not in haystack:
                    continue
                flow.add(self.card(title, f"{countries} · {item.get('year', '')} · {item.get('type_acronym', 'ICH')}", body, lambda item=item: show_detail(item)))
                shown += 1
                if shown >= 80:
                    break
            flow.show_all()

        def show_detail(item: dict) -> None:
            self.clear(detail)
            detail.add(self.heritage_detail(item))
            detail.show_all()

        search.connect("search-changed", lambda entry: render(entry.get_text()))
        render()
        left.add(scroller)
        root.add(left)
        root.add(self.scroll(detail))
        return root

    def explore_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        root.set_border_width(18)
        left = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        left.set_size_request(290, -1)
        left.add(self.label("Explorer l'Afrique", "title"))
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Pays ou capitale")
        left.add(search)
        listbox = self.Gtk.ListBox()
        left.add(self.scroll(listbox))
        detail = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        detail.add(self.label("Sélectionne un pays", "title"))
        detail.add(self.label("Les éléments de patrimoine liés au pays s'afficheront ici.", "subtitle"))

        def fill_list(query: str = "") -> None:
            for row in listbox.get_children():
                listbox.remove(row)
            q = query.lower().strip()
            for country in self.countries:
                label = f"{country.get('flag', '')} {country.get('name', '')} · {country.get('capital', '')}"
                if q and q not in label.lower():
                    continue
                row = self.Gtk.ListBoxRow()
                row.country = country  # type: ignore[attr-defined]
                row.add(self.label(label, None, False))
                listbox.add(row)
            listbox.show_all()

        def select_country(_box, row) -> None:
            if not row:
                return
            country = row.country  # type: ignore[attr-defined]
            for child in detail.get_children():
                detail.remove(child)
            name = country.get("name", "")
            related = [item for item in self.heritage if name in item.get("countries", [])]
            detail.add(self.label(f"{country.get('flag', '')} {name}", "title"))
            detail.add(self.label(f"Capitale: {country.get('capital', 'inconnue')} · Population: {country.get('population', 0):,}", "subtitle"))
            detail.add(self.label(f"{len(related)} élément(s) de patrimoine dans la base locale", "card-meta"))
            profile = self.Gtk.FlowBox()
            profile.set_selection_mode(self.Gtk.SelectionMode.NONE)
            for title, body in [
                ("Patrimoine", f"{len(related)} éléments sourcés disponibles hors ligne."),
                ("Langues", "À enrichir par packs locaux: dictionnaires, prononciation et expressions."),
                ("Cuisine", "Prêt pour recettes régionales, gestes culinaires et récits familiaux."),
                ("Musique", "Prêt pour instruments, playlists locales et lecture mpv."),
                ("Mode", "Prêt pour textiles, gestes de fabrication, créateurs, usages sociaux et pont ElegantStyle."),
                ("Récits", "Prêt pour contes, proverbes, interviews et narration française offline."),
            ]:
                profile.add(self.card(title, name, body))
            detail.add(profile)
            if related:
                detail.add(self.label("Patrimoine associé", "card-title"))
            for item in related[:18]:
                detail.add(self.card(self.localized(item, "title", "Sans titre"), f"{item.get('year', '')} · {item.get('type_acronym', 'ICH')}", self.localized(item, "summary")[:220], lambda item=item: self.show_modal(item)))
            detail.show_all()

        listbox.connect("row-selected", select_country)
        search.connect("search-changed", lambda entry: fill_list(entry.get_text()))
        fill_list()
        root.add(left)
        root.add(self.scroll(detail))
        return root

    def global_search_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Recherche Baobab", "title"))
        root.add(self.label("Recherche native unifiée: pays, patrimoine, modules et sources locales.", "subtitle"))
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Exemple: Burkina, danse, musique, langue, textile...")
        root.add(search)
        results = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)

        def render(query: str = "") -> None:
            self.clear(results)
            q = query.lower().strip()
            if not q:
                results.add(self.label("Entre un mot-clé pour chercher dans toute la mémoire Baobab locale.", "subtitle"))
                results.show_all()
                return
            count = 0
            for country in self.countries:
                haystack = f"{country.get('name', '')} {country.get('capital', '')}".lower()
                if q in haystack:
                    results.add(self.card(country.get("name", "Pays"), "Pays africain", f"Capitale: {country.get('capital', 'inconnue')} · Population: {country.get('population', 0):,}", lambda country=country: self.stack.set_visible_child_name("explore")))
                    count += 1
            for item in self.heritage:
                title = self.localized(item, "title", "Sans titre")
                countries = ", ".join(item.get("countries", []))
                summary = self.localized(item, "summary")
                haystack = " ".join([title, countries, summary, " ".join(item.get("concepts", []))]).lower()
                if q in haystack:
                    results.add(self.card(title, f"Patrimoine · {countries} · {item.get('year', '')}", summary[:230], lambda item=item: self.show_modal(item)))
                    count += 1
                    if count >= 70:
                        break
            for item in self.records:
                haystack = " ".join([text(item.get("title")), text(item.get("module")), text(item.get("summary")), text(item.get("region"))]).lower()
                if q in haystack:
                    results.add(self.card(text(item.get("title"), "Module"), f"Module · {item.get('module', '')}", text(item.get("summary"))[:230]))
                    count += 1
            for item in self.datasets:
                haystack = " ".join([text(item.get("name")), text(item.get("kind")), text(item.get("role")), " ".join(item.get("fields", []))]).lower()
                if q in haystack:
                    results.add(self.card(text(item.get("name"), "Source"), f"Source locale · {item.get('kind', 'data')}", f"{item.get('rows', 0)} lignes · {item.get('role', 'source-dataset')}"))
                    count += 1
            if count == 0:
                results.add(self.label("Aucun résultat local pour cette recherche.", "subtitle"))
            results.show_all()

        search.connect("search-changed", lambda entry: render(entry.get_text()))
        render()
        root.add(self.scroll(results))
        return root

    def modules_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        root.set_border_width(18)
        left = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        left.set_size_request(520, -1)
        left.add(self.label("Modules Baobab", "title"))
        left.add(self.label("Les espaces culturels sont présentés comme des usages publics, pas comme des composants techniques.", "subtitle"))
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        modules = [
            ("languages", "Langues", "Apprendre et transmettre", "Dictionnaires, prononciation, traduction offline et claviers locaux. Priorité: français puis langues africaines."),
            ("sound", "Son", "Écoute culturelle", "Musique, instruments, contes audio et ambiances. mpv sera utilisé quand il est présent sur la machine."),
            ("food", "Cuisine", "Mémoire familiale", "Recettes, gestes, histoires culinaires et parcours par pays ou région."),
            ("fashion", "Mode", "Textiles et création", "Tenues traditionnelles, styles contemporains et futur pont ElegantStyle."),
            ("market", "Marché", "Créateurs africains", "Artisans, stylistes, musiciens, ebooks et objets culturels avec provenance."),
            ("wisdom", "Sagesse", "Proverbes et pensée", "Proverbes, philosophie, cosmologie, récits d'anciens et explications guidées."),
            ("museum", "Musée", "Objets et archives", "Collections, images, objets 3D futurs et fiches sourcées."),
            ("explore", "Explorer", "Pays et peuples", "Fiches pays, patrimoine associé et future carte GeoJSON offline."),
        ]
        detail = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)

        def show_module(key: str, title: str, meta: str, body: str) -> None:
            self.clear(detail)
            related_records = [item for item in self.records if item.get("module") == key]
            concepts = [entry for entry in self.heritage if key in " ".join(entry.get("concepts", [])).lower() or title.lower() in " ".join(entry.get("concepts", [])).lower()]
            detail.add(self.label(title, "title"))
            detail.add(self.label(meta, "subtitle"))
            detail.add(self.label(body, "card-body"))
            detail.add(self.label("Workflow public", "card-title"))
            workflows = {
                "languages": ["Choisir une langue", "Lire expressions et proverbes", "Écouter la prononciation offline", "Préparer un pack local validé"],
                "sound": ["Explorer instruments et chants", "Lire les fiches associées", "Ajouter fichiers audio locaux", "Lire avec mpv quand disponible"],
                "food": ["Choisir un pays", "Ajouter recettes familiales", "Lier ingrédients et histoires", "Créer un parcours cuisine"],
                "fashion": ["Explorer textile et tenue", "Lier pays, créateur et technique", "Préparer le pont ElegantStyle", "Publier un pack sourcé"],
                "market": ["Créer fiche artisan", "Ajouter licence et provenance", "Classer par pays et discipline", "Préparer publication locale"],
                "wisdom": ["Lire proverbes", "Associer contexte culturel", "Narration française", "Validation communautaire"],
                "museum": ["Créer fiche objet", "Ajouter image ou modèle 3D", "Source et droits", "Exposition locale"],
                "explore": ["Choisir un pays", "Voir patrimoine", "Ajouter langues/cuisine/mode", "Préparer GeoJSON offline"],
            }
            for step in workflows.get(key, []):
                detail.add(self.label(f"- {step}", "card-body"))
            if key == "sound":
                actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
                actions.add(self.button("Ouvrir Baobab Sound", lambda *_: self.open_sound_folder()))
                detail.add(actions)
            if related_records:
                detail.add(self.label("Données Baobab déjà présentes", "card-title"))
                for item in related_records[:5]:
                    detail.add(self.card(text(item.get("title"), "Sans titre"), f"{item.get('region', '')} · {item.get('confidence', '')}", text(item.get("summary"))[:220]))
            if concepts:
                detail.add(self.label("Patrimoine lié par concepts", "card-title"))
                for item in concepts[:6]:
                    detail.add(self.card(self.localized(item, "title", "Sans titre"), ", ".join(item.get("countries", [])), self.localized(item, "summary")[:200], lambda item=item: self.show_modal(item)))
            detail.show_all()

        for key, title, meta, body in modules:
            flow.add(self.card(title, meta, body, lambda key=key, title=title, meta=meta, body=body: show_module(key, title, meta, body)))
        left.add(flow)
        root.add(self.scroll(left))
        root.add(self.scroll(detail))
        show_module(*modules[0])
        return root

    def engines_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Capacités Baobab", "title"))
        root.add(self.label("Chaque outil sert un objectif: culture africaine, fonctionnement local/offline, expérience légère et intelligente.", "subtitle"))
        stats = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stats.attach(self.stat(f"{self.capabilities_payload.get('score', 0)}%", "Capacités"), 0, 0, 1, 1)
        stats.attach(self.stat(f"{self.engines_payload.get('immersive_score', 0)}%", "Moteurs"), 1, 0, 1, 1)
        stats.attach(self.stat(f"{self.services_payload.get('score', 0)}%", "Runtime Baobab"), 2, 0, 1, 1)
        root.add(stats)
        root.add(self.label("Objectifs", "card-title"))
        for goal in self.capabilities_payload.get("goals", []):
            root.add(self.label(f"- {goal}", "card-body"))
        root.add(self.label("Domaines", "card-title"))
        for domain in self.capabilities_payload.get("domains", []):
            body = f"{domain.get('purpose', '')}\nSurface: {domain.get('public_surface', '')}"
            if domain.get("missing"):
                body = f"{body}\nÀ connecter: {', '.join(domain.get('missing', [])[:4])}"
            root.add(self.card(text(domain.get("title"), "Domaine"), f"{domain.get('score', 0)}% · {domain.get('state', '')}", body))
        root.add(self.label("Services Baobab", "card-title"))
        root.add(self.label("Ces services passent par les lanceurs du profil Baobab et ne démarrent jamais sans action explicite.", "subtitle"))
        root.add(self.button("Réappliquer la configuration Baobab", lambda *_: self.run_action("baobab", "apply-config")))
        for service in self.services_payload.get("services", []):
            body = f"Lanceur: {service.get('launcher') or service.get('command', '')}\nDémarrage automatique: non"
            root.add(self.card(text(service.get("key"), "service"), text(service.get("state"), "unknown"), body))
        root.add(self.label("Moteurs détectés", "card-title"))
        for item in self.engines_payload.get("engines", []):
            state = "Disponible" if item.get("state") == "available" else "À connecter"
            body = f"{item.get('role', '')}\nCommande: {item.get('command', '')}\nPaquet: {item.get('package', '')}"
            root.add(self.card(text(item.get("key"), "moteur"), f"{state} · {item.get('group', '')}", body))
        if self.engines_payload.get("immersive_next"):
            root.add(self.label("Prochaines connexions", "card-title"))
            for item in self.engines_payload.get("immersive_next", [])[:8]:
                root.add(self.label(f"- {item}", "card-body"))
        return self.scroll(root)

    def datasets_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Sources culturelles", "title"))
        root.add(self.label("Baobab détecte automatiquement les CSV, TSV et JSON placés dans identity/baobab_db.", "subtitle"))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Régénérer l'index", lambda *_: self.reload()))
        root.add(actions)
        if not self.datasets:
            root.add(self.label("Aucune source locale détectée pour le moment.", "subtitle"))
        for item in self.datasets:
            fields = ", ".join(item.get("fields", [])[:10])
            body = f"{item.get('rows', 0)} lignes · {item.get('size', 0):,} octets"
            if item.get("derived_african_records") is not None:
                body = f"{body}\nProjection africaine: {item.get('derived_african_records')} éléments Baobab"
            if fields:
                body = f"{body}\nChamps: {fields}"
            if item.get("error"):
                body = f"{body}\nErreur: {item['error']}"
            root.add(self.card(text(item.get("name"), "Source"), f"{item.get('kind', 'data')} · {item.get('role', 'source-dataset')}", body))
        return self.scroll(root)

    def save_collection_draft(self, fields: dict) -> None:
        pack_name = fields["pack"].get_active_id() or ""
        pack = next((item for item in self.packs_payload.get("packs", []) if item.get("name") == pack_name), None)
        if not pack:
            self.show_message("Choisis un pack culturel", "Crée d'abord les packs de départ ou sélectionne un pack existant.", error=True)
            return
        title = fields["title"].get_text().strip()
        if not title:
            self.show_message("Titre manquant", "Donne un titre simple à cette collecte.", error=True)
            return
        collection_type = fields["type"].get_active_id() or "interview"
        country = fields["country"].get_text().strip() or "à préciser"
        language = fields["language"].get_text().strip() or "fr"
        source = fields["source"].get_text().strip() or "à documenter"
        license_value = fields["license"].get_text().strip() or "à confirmer"
        buffer = fields["notes"].get_buffer()
        start, end = buffer.get_bounds()
        notes = buffer.get_text(start, end, True).strip()
        media_path = Path(fields["media"].get_filename()) if fields["media"].get_filename() else None

        pack_dir = Path(pack.get("path", "")).parent
        folder_by_type = {
            "interview": "interviews",
            "recette": "recipes",
            "audio": "audio",
            "photo": "media",
            "textile": "creators",
            "proverbe": "wisdom",
        }
        labels = {
            "interview": "Interview",
            "recette": "Recette",
            "audio": "Audio",
            "photo": "Photo",
            "textile": "Textile / créateur",
            "proverbe": "Proverbe / sagesse",
        }
        target_dir = pack_dir / folder_by_type.get(collection_type, "interviews")
        target_dir.mkdir(parents=True, exist_ok=True)
        slug = slugify(title)
        draft_path = unique_path(target_dir / f"{slug}.md")
        copied_media = ""
        if media_path and media_path.exists():
            media_dir = pack_dir / "media"
            media_dir.mkdir(parents=True, exist_ok=True)
            copied = unique_path(media_dir / f"{slug}{media_path.suffix.lower()}")
            shutil.copy2(media_path, copied)
            copied_media = str(copied.relative_to(pack_dir))

        draft = f"""# {title}

- Type: {labels.get(collection_type, collection_type)}
- Statut: brouillon
- Pays: {country}
- Langue: {language}
- Source / personne ressource: {source}
- Licence / droits: {license_value}
- Consentement: à confirmer
- Média local: {copied_media or "aucun"}

## Notes de collecte
{notes or "À compléter avec un récit, une transcription, une recette, un contexte ou une description."}

## Validation
- [ ] Source identifiée
- [ ] Consentement documenté
- [ ] Langue et pays vérifiés
- [ ] Média autorisé avant diffusion
- [ ] Relu par une personne locale ou communautaire
"""
        draft_path.write_text(draft, encoding="utf-8")

        consent_dir = pack_dir / "consent"
        consent_dir.mkdir(parents=True, exist_ok=True)
        consent_path = unique_path(consent_dir / f"{slug}-consent.md")
        consent_path.write_text(f"""# Consentement - {title}

- Pack: {pack_name}
- Élément: {draft_path.relative_to(pack_dir)}
- Personne / détenteur: {source}
- Usage autorisé: à préciser
- Usage interdit: à préciser
- Licence: {license_value}
- Date: à compléter
- Signature ou validation locale: à compléter
""", encoding="utf-8")

        manifest_path = pack_dir / "media/media-manifest.json"
        manifest = load_json(manifest_path, {"schema": "sevenos.baobab.media-manifest.v1", "items": []})
        manifest.setdefault("items", []).append({
            "id": draft_path.stem,
            "kind": collection_type,
            "path": str(draft_path.relative_to(pack_dir)),
            "media": copied_media,
            "rights": license_value,
            "status": "draft",
            "country": country,
            "language": language,
        })
        save_json(manifest_path, manifest)
        self.show_message("Collecte créée", f"Brouillon: {draft_path}\nConsentement: {consent_path}")
        self.reload()

    def collect_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Nouvelle collecte", "title"))
        root.add(self.label("Assistant public pour ajouter une mémoire vivante en brouillon: interview, recette, audio, photo, textile ou proverbe.", "subtitle"))
        if not self.packs_payload.get("packs"):
            root.add(self.card("Aucun pack disponible", "Action requise", "Crée les packs de départ dans l'onglet Packs avant de lancer une collecte."))
            root.add(self.button("Aller aux packs", lambda *_: self.stack.set_visible_child_name("packs")))
            return self.scroll(root)

        form = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        form.set_column_homogeneous(False)
        pack = self.Gtk.ComboBoxText()
        for item in self.packs_payload.get("packs", []):
            pack.append(item.get("name", ""), item.get("title", item.get("name", "")))
        pack.set_active(0)
        collection_type = self.Gtk.ComboBoxText()
        for key, label in [("interview", "Interview"), ("recette", "Recette"), ("audio", "Audio"), ("photo", "Photo"), ("textile", "Textile / créateur"), ("proverbe", "Proverbe / sagesse")]:
            collection_type.append(key, label)
        collection_type.set_active_id("interview")
        title = self.Gtk.Entry()
        title.set_placeholder_text("Titre public de la collecte")
        country = self.Gtk.Entry()
        country.set_placeholder_text("Pays ou région")
        language = self.Gtk.Entry()
        language.set_text("fr")
        source = self.Gtk.Entry()
        source.set_placeholder_text("Personne source, archive, famille, association...")
        license_value = self.Gtk.Entry()
        license_value.set_text("à confirmer")
        media = self.Gtk.FileChooserButton(title="Choisir un média local", action=self.Gtk.FileChooserAction.OPEN)
        notes = self.Gtk.TextView()
        notes.set_wrap_mode(self.Gtk.WrapMode.WORD_CHAR)
        notes.set_size_request(-1, 160)

        rows = [
            ("Pack", pack),
            ("Type", collection_type),
            ("Titre", title),
            ("Pays", country),
            ("Langue", language),
            ("Source", source),
            ("Licence", license_value),
            ("Média", media),
        ]
        for index, (label, widget) in enumerate(rows):
            form.attach(self.label(label, "card-title", False), 0, index, 1, 1)
            form.attach(widget, 1, index, 1, 1)
        root.add(form)
        root.add(self.label("Notes, transcription ou contexte", "card-title"))
        root.add(notes)
        fields = {
            "pack": pack,
            "type": collection_type,
            "title": title,
            "country": country,
            "language": language,
            "source": source,
            "license": license_value,
            "media": media,
            "notes": notes,
        }
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Créer le brouillon", lambda *_: self.save_collection_draft(fields)))
        actions.add(self.button("Auditer après collecte", lambda *_: self.run_action("baobab", "audit-packs")))
        root.add(actions)
        root.add(self.card("Qualité culturelle", "Brouillon par défaut", "Baobab crée les fichiers de collecte et de consentement, mais ne marque jamais un contenu comme validé sans source, droits et relecture locale."))
        return self.scroll(root)

    def languages_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Langues africaines", "title"))
        root.add(self.label("Base de départ française-first. Les phrases sont volontairement marquées à valider par locuteurs locaux avant usage pédagogique.", "subtitle"))
        root.add(self.stat(str(len(self.languages)), "Langues starter"))
        for item in self.languages:
            regions = ", ".join(item.get("regions", []))
            phrases = item.get("phrases", [])
            body = f"Famille: {item.get('family', 'à préciser')}\nValidation: {item.get('validation', 'needs-local-speaker')}\nRégions: {regions}"
            root.add(self.card(text(item.get("name_fr") or item.get("name_en"), "Langue"), text(item.get("priority"), "starter"), body))
            for phrase in phrases[:3]:
                root.add(self.card(text(phrase.get("fr"), "Expression"), text(phrase.get("local"), ""), text(phrase.get("note"), "À valider localement.")))
        return self.scroll(root)

    def packs_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Packs culturels", "title"))
        root.add(self.label("Les packs transforment Baobab en mémoire vivante: cuisine, son, mode, langues, récits et archives locales.", "subtitle"))
        stats = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stats.attach(self.stat(str(self.packs_payload.get("count", 0)), "Packs locaux"), 0, 0, 1, 1)
        stats.attach(self.stat(f"{self.audit_payload.get('score', 0)}%", "Score provenance"), 1, 0, 1, 1)
        stats.attach(self.stat(text(self.audit_payload.get("state", "unknown")), "Audit"), 2, 0, 1, 1)
        root.add(stats)
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Créer les packs de départ", lambda *_: self.run_action("baobab", "seed-packs")))
        actions.add(self.button("Préparer collecte vivante", lambda *_: self.run_action("baobab", "enrich-packs")))
        actions.add(self.button("Nouvelle collecte", lambda *_: self.stack.set_visible_child_name("collect")))
        actions.add(self.button("Créer exemples terrain", lambda *_: self.run_action("baobab", "sample-fieldwork")))
        actions.add(self.button("Auditer les packs", lambda *_: self.run_action("baobab", "audit-packs")))
        actions.add(self.button("Ouvrir le dossier packs", lambda *_: open_path(DATA / "packs")))
        root.add(actions)
        if not self.packs_payload.get("packs"):
            root.add(self.label("Aucun pack local. Lance les packs de départ pour créer Burkina Food, Mandingue Sound et Faso Danfani Fashion.", "subtitle"))
        for pack in self.packs_payload.get("packs", []):
            audit = next((item for item in self.audit_payload.get("packs", []) if item.get("name") == pack.get("name")), {})
            warnings = audit.get("warnings", [])
            living_score = audit.get("living_score", 0)
            collection_score = audit.get("collection_score", 0)
            collection_status = audit.get("collection_status", "unknown")
            fieldwork_state = audit.get("fieldwork_state", collection_status)
            sample_count = audit.get("sample_count", 0)
            body = f"{pack.get('records', 0)} fiche(s)\nWorkflow collecte: {living_score}%\nCollecte réelle: {collection_score}% · {fieldwork_state}\nÉléments sample: {sample_count}\n{pack.get('path', '')}"
            if warnings:
                body = f"{body}\nÀ revoir: {warnings[0]}"
            root.add(self.card(text(pack.get("title"), "Pack"), f"{pack.get('name', '')} · {audit.get('score', 'n/a')}%", body, lambda pack=pack: open_path(Path(pack.get("path", "")).parent)))
        return self.scroll(root)

    def preferences_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Préférences Baobab", "title"))
        root.add(self.label("La priorité actuelle reste le français. Ces réglages préparent le futur i18n complet et les langues africaines.", "subtitle"))
        language_row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        language_row.add(self.label("Langue de lecture", "card-title", False))
        language = self.Gtk.ComboBoxText()
        for key, label in [("fr", "Français d'abord"), ("en", "Anglais fallback")]:
            language.append(key, label)
        language.set_active_id(text(self.settings.get("language"), "fr"))
        language.connect("changed", lambda combo: self.set_language(combo.get_active_id() or "fr"))
        language_row.add(language)
        root.add(language_row)
        root.add(self.card("Données multilingues", "Préparation", "Les titres et résumés UNESCO utilisent la préférence de langue. Les packs Baobab pourront ensuite déclarer language, country et curator pour un affichage propre."))
        root.add(self.card("Langues africaines", "À enrichir par packs", "Mooré, Dioula, Bambara, Swahili, Wolof, Yoruba, Lingala, Peul et autres langues pourront être ajoutées comme datasets ou packs communautaires sourcés."))
        return self.scroll(root)

    def story_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Récits", "title"))
        root.add(self.label("Lecture guidée des modules Baobab. Les contenus restent locaux et sourcés.", "subtitle"))
        for item in self.records:
            root.add(self.card(text(item.get("title"), "Sans titre"), f"{item.get('module', '')} · {item.get('region', '')}", text(item.get("summary"))))
        return self.scroll(root)

    def museum_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=14)
        root.set_border_width(18)
        root.add(self.label("Musée", "title"))
        root.add(self.label("Vue native des objets culturels et collections. L'expérience doit rester calme, sourcée et contemplative.", "subtitle"))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Ouvrir la scène immersive", lambda *_: open_path(WORKSPACE / "Museum 3D/index.html")))
        root.add(actions)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        for item in self.records:
            flow.add(self.card(text(item.get("title"), "Sans titre"), f"{item.get('module', '')} · {item.get('kind', '')}", text(item.get("summary"))))
        root.add(flow)
        return self.scroll(root)

    def show_modal(self, item: dict) -> None:
        dialog = self.Gtk.Dialog(title="Fiche patrimoine", transient_for=self.window, flags=0)
        dialog.set_default_size(680, 560)
        area = dialog.get_content_area()
        area.set_border_width(14)
        area.add(self.scroll(self.heritage_detail(item)))
        dialog.add_button("Fermer", self.Gtk.ResponseType.CLOSE)
        dialog.connect("response", lambda dialog, _response: dialog.destroy())
        dialog.show_all()

    def build(self) -> object:
        self.apply_css()
        window = self.Gtk.Window(title="Baobab OS")
        self.window = window
        window.set_default_size(1280, 820)
        window.connect("destroy", self.Gtk.main_quit)
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=0)
        root.get_style_context().add_class("root")
        sidebar = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        sidebar.get_style_context().add_class("rail")
        sidebar.get_style_context().add_class("nav")
        sidebar.set_border_width(14)
        sidebar.set_size_request(230, -1)
        brand = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        brand.get_style_context().add_class("brand")
        brand.add(self.label("Baobab", "brand-title", False))
        brand.add(self.label("Mémoire · école · création", "brand-subtitle", False))
        sidebar.add(brand)
        self.stack = self.Gtk.Stack()
        self.stack.set_transition_type(self.Gtk.StackTransitionType.CROSSFADE)
        views = [
            ("home", "Accueil", self.home_view(), "OS"),
            ("search", "Recherche", self.global_search_view(), "OS"),
            ("heritage", "Patrimoine", self.heritage_view(), "Mémoire"),
            ("explore", "Explorer", self.explore_view(), "Mémoire"),
            ("languages", "Langues", self.languages_view(), "Mémoire"),
            ("story", "Récits", self.story_view(), "Mémoire"),
            ("modules", "Modules", self.modules_view(), "Expériences"),
            ("museum", "Musée", self.museum_view(), "Expériences"),
            ("collect", "Collecte", self.collect_view(), "Transmission"),
            ("packs", "Packs", self.packs_view(), "Transmission"),
            ("datasets", "Sources", self.datasets_view(), "Transmission"),
            ("engines", "Moteurs", self.engines_view(), "Système"),
            ("preferences", "Préférences", self.preferences_view(), "Système"),
        ]
        current_group = ""
        for key, label, widget, group in views:
            self.stack.add_titled(widget, key, label)
            if group != current_group:
                sidebar.add(self.label(group.upper(), "nav-title", False))
                current_group = group
            button = self.Gtk.Button(label=label)
            button.connect("clicked", lambda _button, key=key: self.stack.set_visible_child_name(key))
            sidebar.add(button)
        sidebar.pack_end(self.chip("Baobab isolé · profil dédié"), False, False, 0)
        sidebar.pack_end(self.chip(f"{self.capabilities_payload.get('score', 0)}% prêt"), False, False, 0)
        known_views = {key for key, _label, _widget, _group in views}
        if self.initial_view in known_views:
            self.stack.set_visible_child_name(self.initial_view)
        root.add(sidebar)
        root.add(self.stack)
        window.add(root)
        return window

    def reload(self) -> None:
        bootstrap()
        self.catalog = load_json(DATA / "catalog.json", {"records": []})
        self.countries_payload = load_json(DATA / "explore/africa-countries.json", {"countries": []})
        self.unesco_payload = load_json(DATA / "heritage/african-unesco-ich.json", {"items": []})
        self.datasets_payload = load_json(DATA / "offline/datasets.json", {"sources": []})
        self.settings = load_json(SETTINGS_FILE, {"language": "fr", "country_focus": ""})
        self.engines_payload = self.load_engines()
        self.packs_payload = self.load_packs()
        self.audit_payload = self.load_pack_audit()
        self.languages_payload = self.load_languages()
        self.records = self.catalog.get("records", [])
        self.countries = self.countries_payload.get("countries", [])
        self.heritage = self.unesco_payload.get("items", [])
        self.datasets = self.datasets_payload.get("sources", [])
        self.languages = self.languages_payload.get("languages", [])


def probe() -> int:
    ensure_gi_python()
    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def main() -> int:
    if "--probe" in sys.argv:
        return probe()
    initial_view = os.environ.get("SEVENOS_BAOBAB_VIEW", "home")
    if "--view" in sys.argv:
        index = sys.argv.index("--view")
        if index + 1 < len(sys.argv):
            initial_view = sys.argv[index + 1]
    bootstrap()
    ensure_gi_python()
    import gi
    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, Gtk

    app = BaobabNative(Gtk, Gdk, initial_view=initial_view)
    window = app.build()
    window.show_all()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
