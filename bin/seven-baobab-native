        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        title.pack_start(self.label("Carnet culturel", "card-title", False), False, False, 0)
        title.pack_start(self.label("Notes, traces et séance active dans une mémoire lisible.", "card-body"), False, False, 0)
        title.pack_start(self.label(f"{len(notes)} note(s) · {len(events)} trace(s) · {text((self.session_payload or {}).get('title'), 'Séance Baobab')}", "card-meta", False), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("carnet")), False, False, 0)
        box.add(header)
        if compact:
            preview = []
            if notes:
                preview.append(("Note récente", notes[0].name, str(notes[0])))
            if events:
                preview.append((text(events[0].get("title"), "Trace"), text(events[0].get("time")), text(events[0].get("body"))))
            if not preview:
                box.add(self.label("Le carnet est prêt. Crée une note ou une trace pour commencer.", "card-body"))
            for title_text, meta_text, body_text in preview[:2]:
                item = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
                item.get_style_context().add_class("carnet-item")
                item.add(self.label(title_text, "card-title", False))
                item.add(self.label(meta_text, "card-meta", False))
                item.add(self.label(body_text, "card-body"))
                box.add(item)
        return box

    def constellation_nodes(self) -> list[tuple[str, str, str, str]]:
        active = self.active_immersion()
        country = text(self.settings.get("country_focus"), "à relier")
        languages = ", ".join(text(item.get("name_fr") or item.get("name_en")) for item in self.languages[:2]) or "langues à enrichir"
        sound_count = 0
        for library in (WORKSPACE / "Sound", DATA / "sound"):
            if library.exists():
                sound_count += sum(1 for path in library.iterdir() if path.suffix.lower() in {".mp3", ".ogg", ".flac", ".wav", ".m4a", ".opus"})
        return [
            ("Immersion", text(active.get("name_fr") or active.get("name_en"), "Baobab"), "Région active", "immersions"),
            ("Pays", country, "Territoire focus", "explore"),
            ("Langues", languages, "Mots et transmission", "languages"),
            ("Son", f"{sound_count} fichier(s)", "Voix, instruments, archives", "modules"),
            ("Trace", f"{self.trail_payload.get('count', 0)} trace(s)", "Mémoire locale", "trail"),
            ("Sources", f"{len(self.datasets)} source(s)", "CSV, JSON, index local", "datasets"),
            ("Transmission", text((self.compass_payload or {}).get("next", {}).get("title"), "Boussole"), "Garde-fous", "compass"),
        ]

    def constellation_canvas(self) -> object:
        area = self.Gtk.DrawingArea()
        area.set_size_request(520, 320)
        area.get_style_context().add_class("constellation-canvas")

        def draw(_area, cr):
            width = _area.get_allocated_width()
            height = _area.get_allocated_height()
            cx = width * 0.50
            cy = height * 0.50
            cr.set_source_rgba(.035, .050, .045, .96)
            cr.paint()
            cr.set_line_cap(1)
            cr.set_source_rgba(.72, .58, .36, .16)
            for radius in (58, 102, 146):
                cr.set_line_width(1)
                cr.arc(cx, cy, radius, 0, 6.283)
                cr.stroke()
            nodes = [
                ("Immersion", .50, .18, .55, .70, .48),
                ("Pays", .78, .34, .72, .58, .36),
                ("Langues", .74, .70, .42, .68, .84),
                ("Son", .50, .84, .72, .52, .82),
                ("Trace", .24, .70, .82, .66, .42),
                ("Sources", .20, .34, .48, .72, .55),
                ("Transmission", .50, .50, .86, .80, .58),
            ]
            for label, x, y, r, g, b in nodes:
                px = width * x
                py = height * y
                if label != "Transmission":
                    cr.set_source_rgba(r, g, b, .34)
                    cr.set_line_width(1.5)
                    cr.move_to(cx, cy)
                    cr.line_to(px, py)
                    cr.stroke()
            for label, x, y, r, g, b in nodes:
                px = width * x
                py = height * y
                radius = 16 if label == "Transmission" else 11
                cr.set_source_rgba(r, g, b, .18)
                cr.arc(px, py, radius + 10, 0, 6.283)
                cr.fill()
                cr.set_source_rgba(r, g, b, .90)
                cr.arc(px, py, radius, 0, 6.283)
                cr.fill()
                cr.set_source_rgba(.95, .91, .80, .88)
                cr.select_font_face("Noto Sans", 0, 0)
                cr.set_font_size(11)
                cr.move_to(px + radius + 5, py + 4)
                cr.show_text(label)
            cr.set_source_rgba(.95, .91, .80, .92)
            cr.set_font_size(13)
            cr.move_to(cx - 24, cy + 4)
            cr.show_text("Baobab")
            return False

        area.connect("draw", draw)
        return area

    def constellation_panel(self, compact: bool = True) -> object:
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("constellation-panel")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        title.pack_start(self.label("Constellation Baobab", "card-title", False), False, False, 0)
        title.pack_start(self.label("Voir les liens entre région, pays, langues, sons, traces, sources et transmission.", "card-body"), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("constellation")), False, False, 0)
        box.add(header)
        if not compact:
            box.add(self.constellation_canvas())
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(4 if compact else 3)
        for title_text, value, meta, target in self.constellation_nodes():
            node = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
            node.get_style_context().add_class("constellation-node")
            node.add(self.label(title_text, "card-title", False))
            node.add(self.label(value, "card-meta", False))
            if not compact:
                node.add(self.label(meta, "card-body"))
            event = self.Gtk.EventBox()
            event.add(node)
            event.connect("button-press-event", lambda _event, _button, target=target: self.stack.set_visible_child_name(target))
            flow.add(event)
        box.add(flow)
        return box

    def media_items(self) -> list[dict]:
        roots = [
            ("Sound", WORKSPACE / "Sound"),
            ("Baobab data", DATA / "sound"),
            ("Packs", DATA / "packs"),
            ("Workspace", WORKSPACE),
        ]
        items: list[dict] = []
        seen: set[str] = set()
        for source, root in roots:
            if not root.exists():
                continue
            iterator = root.rglob("*") if source in {"Packs", "Workspace"} else root.glob("*")
            for path in iterator:
                if not path.is_file():
                    continue
                kind = MEDIA_EXTENSIONS.get(path.suffix.lower())
                if not kind:
                    continue
                key = str(path.resolve())
                if key in seen:
                    continue
                seen.add(key)
                try:
                    stat = path.stat()
                except OSError:
                    continue
                items.append({
                    "path": path,
                    "name": path.name,
                    "kind": kind,
                    "source": source,
                    "size": stat.st_size,
                    "modified": datetime.fromtimestamp(stat.st_mtime).isoformat(timespec="minutes"),
                })
        return sorted(items, key=lambda item: item["modified"], reverse=True)[:120]

    def media_panel(self, compact: bool = True) -> object:
        items = self.media_items()
        counts = {kind: sum(1 for item in items if item["kind"] == kind) for kind in ("audio", "image", "video", "document")}
        box = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        box.get_style_context().add_class("media-panel")
        header = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=12)
        title = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
        title.pack_start(self.label("Médiathèque vivante", "card-title", False), False, False, 0)
        title.pack_start(self.label("Sons, images, vidéos et documents culturels retrouvés localement.", "card-body"), False, False, 0)
        title.pack_start(self.label(f"{len(items)} média(s) · {counts['audio']} sons · {counts['image']} images · {counts['document']} documents", "card-meta", False), False, False, 0)
        header.pack_start(title, True, True, 0)
        header.pack_end(self.button("Ouvrir", lambda *_: self.stack.set_visible_child_name("media")), False, False, 0)
        box.add(header)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        flow.set_max_children_per_line(4 if compact else 3)
        shown = items[:4 if compact else 30]
        if not shown:
            box.add(self.label("Ajoute des médias dans ~/Baobab/Sound ou dans les packs culturels pour les voir ici.", "card-body"))
            return box
        for item in shown:
            card = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
            card.get_style_context().add_class("media-item")
            card.get_style_context().add_class(f"media-{item['kind']}")
            card.add(self.label(text(item["name"]), "card-title", False))
            card.add(self.label(f"{item['kind']} · {item['source']}", "card-meta", False))
            if not compact:
                card.add(self.label(f"{item['modified']} · {self.format_size(item['size'])}", "card-body"))
            event = self.Gtk.EventBox()
            event.add(card)
            event.connect("button-press-event", lambda _event, _button, path=item["path"]: open_path(path))
            flow.add(event)
        box.add(flow)
        return box

    def next_route_action(self) -> tuple[str, str, str]:
        for label, done, _meta in self.route_progress():
            if done:
                continue
            if label == "Pays focus":
                return ("Choisir un pays focus", "Relier l’immersion active à un territoire précis.", "explore")
            if label == "Note du jour":
                return ("Créer la note du jour", "Transformer le rituel en trace locale Markdown.", "journal")
            if label == "Packs culturels":
                return ("Préparer les packs", "Créer les contenants culturels pour collecter proprement.", "packs")
        return ("Continuer le journal", "Relire, enrichir et sourcer les notes déjà créées.", "journal")

    def focus_country(self, country_name: str) -> None:
        self.commit_focus(country_name=country_name, target="explore")

    def create_daily_ritual_note(self) -> None:
        active = self.active_immersion()
        folder = WORKSPACE / "Rituels du jour"
        folder.mkdir(parents=True, exist_ok=True)
        path = unique_path(folder / f"{date.today().isoformat()}-rituel-baobab.md")
        country = text(self.settings.get("country_focus"), "à choisir")
        title = text(active.get("name_fr") or active.get("name_en"), "Baobab")
        body = f"""# Rituel Baobab - {date.today().isoformat()}

- Immersion: {title}
- Pays focus: {country}
- Statut: brouillon personnel

## Rituel du jour
{self.daily_ritual()}

## Notes
- Ce que j'ai lu:
- Ce que j'ai écouté:
- Langue, mot ou expression:
- Source ou personne à consulter:
- À vérifier avant partage:

## Respect culturel
- [ ] Source identifiée
- [ ] Contexte noté
- [ ] Consentement nécessaire vérifié
- [ ] Relecture locale à prévoir si le contenu est partagé
"""
        path.write_text(body, encoding="utf-8")
        self.add_trail_event("journal", "Note rituelle créée", str(path))
        open_path(path)
        if hasattr(self, "stack"):
            self.reload()
            self.refresh_views("journal")

    def create_session_folder(self) -> None:
        payload = self.transmission_payload()
        slug = slugify(f"{payload['immersion']}-{payload['country']}-{date.today().isoformat()}", "session-baobab")
        folder = unique_path(WORKSPACE / "Sessions Baobab" / slug)
        media_folder = folder / "media"
        media_folder.mkdir(parents=True, exist_ok=True)
        (folder / "carte-transmission.md").write_text(
            "# Carte de transmission\n\n"
            f"{self.transmission_text()}\n\n"
            "## Notes de séance\n"
            "- Ce qui a été compris:\n"
            "- Ce qui reste à vérifier:\n"
            "- Personnes ou sources à consulter:\n",
            encoding="utf-8",
        )
        (folder / "checklist-respect.md").write_text(
            "# Checklist respect culturel\n\n"
            "- [ ] Source identifiée\n"
            "- [ ] Contexte noté\n"
            "- [ ] Pays, région ou communauté clarifiés\n"
            "- [ ] Consentement vérifié si une personne ou une famille est concernée\n"
            "- [ ] Droits des médias vérifiés\n"
            "- [ ] Relecture locale prévue avant partage public\n",
            encoding="utf-8",
        )
        (folder / "README.md").write_text(
            "# Session Baobab\n\n"
            "Ce dossier est local. Place les sons, images, vidéos ou documents dans `media/`.\n"
            "Baobab peut ensuite les retrouver dans la Médiathèque vivante.\n",
            encoding="utf-8",
        )
        self.add_trail_event("session", "Dossier de séance créé", str(folder))
        open_path(folder)
        if hasattr(self, "stack"):
            self.reload()
            self.refresh_views("carnet")

    def session_folders(self) -> list[dict]:
        root = WORKSPACE / "Sessions Baobab"
        if not root.exists():
            return []
        sessions = []
        for folder in root.iterdir():
            if not folder.is_dir():
                continue
            media_dir = folder / "media"
            media_count = 0
            if media_dir.exists():
                media_count = sum(1 for path in media_dir.rglob("*") if path.is_file())
            card = folder / "carte-transmission.md"
            checklist = folder / "checklist-respect.md"
            try:
                modified = datetime.fromtimestamp(folder.stat().st_mtime).isoformat(timespec="minutes")
            except OSError:
                modified = ""
            sessions.append({
                "path": folder,
                "name": folder.name.replace("-", " ").title(),
                "modified": modified,
                "media_count": media_count,
                "has_card": card.exists(),
                "has_checklist": checklist.exists(),
                "state": "ready" if card.exists() and checklist.exists() else "partial",
            })
        return sorted(sessions, key=lambda item: item["modified"], reverse=True)

    def ritual_notes(self) -> list[Path]:
        folder = WORKSPACE / "Rituels du jour"
        if not folder.exists():
            return []
        return sorted(folder.glob("*.md"), key=lambda path: path.stat().st_mtime, reverse=True)

