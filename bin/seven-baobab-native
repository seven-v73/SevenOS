    def heritage_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        root.set_border_width(18)
        left = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        left.set_size_request(560, -1)
        left.add(self.label("Patrimoine", "title"))
        left.add(self.label("Galerie native en français d'abord, alimentée par la base UNESCO africaine locale.", "subtitle"))
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Rechercher: pays, musique, danse, rituel, artisanat...")
        left.add(search)
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        scroller = self.scroll(flow)
        detail = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
        detail.add(self.label("Choisis un élément", "title"))
        detail.add(self.label("Clique une carte pour afficher une fiche lisible avec source et contexte.", "subtitle"))

        def render(query: str = "") -> None:
            for child in flow.get_children():
                flow.remove(child)
            q = query.lower().strip()
            shown = 0
            for item in sorted(self.heritage, key=lambda row: row.get("year", ""), reverse=True):
                title = self.localized(item, "title", "Sans titre")
                countries = ", ".join(item.get("countries", []))
                body = self.localized(item, "summary")[:280]
                haystack = " ".join([title, countries, " ".join(item.get("concepts", []))]).lower()
                if q and q not in haystack:
                    continue
                flow.add(self.card(title, f"{countries} · {item.get('year', '')} · {item.get('type_acronym', 'ICH')}", body, lambda item=item: show_detail(item)))
                shown += 1
                if shown >= 80:
                    break
            flow.show_all()

        def show_detail(item: dict) -> None:
            self.clear(detail)
            detail.add(self.heritage_detail(item))
            detail.show_all()

        search.connect("search-changed", lambda entry: render(entry.get_text()))
        render()
        left.add(scroller)
        root.add(left)
        root.add(self.scroll(detail))
        return root

    def explore_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=14)
        root.set_border_width(18)
        left = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        left.set_size_request(290, -1)
        left.add(self.label("Explorer l'Afrique", "title"))
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Pays ou capitale")
        left.add(search)
        listbox = self.Gtk.ListBox()
        left.add(self.scroll(listbox))
        detail = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        detail.add(self.label("Sélectionne un pays", "title"))
        detail.add(self.label("Les éléments de patrimoine liés au pays s'afficheront ici.", "subtitle"))

        def fill_list(query: str = "") -> None:
            for row in listbox.get_children():
                listbox.remove(row)
            q = query.lower().strip()
            focus = text(self.settings.get("country_focus")).lower()
            focused_row = None
            for country in self.countries:
                label = f"{country.get('flag', '')} {country.get('name', '')} · {country.get('capital', '')}"
                if q and q not in label.lower():
                    continue
                row = self.Gtk.ListBoxRow()
                row.country = country  # type: ignore[attr-defined]
                row.add(self.label(label, None, False))
                listbox.add(row)
                if not q and focus and focus == text(country.get("name")).lower():
                    focused_row = row
            listbox.show_all()
            if focused_row is not None:
                listbox.select_row(focused_row)

        def select_country(_box, row) -> None:
            if not row:
                return
            country = row.country  # type: ignore[attr-defined]
            for child in detail.get_children():
                detail.remove(child)
            name = country.get("name", "")
            related = [item for item in self.heritage if name in item.get("countries", [])]
            regions = self.matching_immersions(name)
            detail.add(self.label(f"{country.get('flag', '')} {name}", "title"))
            detail.add(self.label(f"Capitale: {country.get('capital', 'inconnue')} · Population: {country.get('population', 0):,}", "subtitle"))
            detail.add(self.label(f"{len(related)} élément(s) de patrimoine dans la base locale", "card-meta"))
            focus_actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
            focus_actions.add(self.button("Définir comme pays focus", lambda *_: self.commit_focus(country_name=name, target="entry")))
            focus_actions.add(self.button("Collecter depuis ce pays", lambda *_: self.commit_focus(country_name=name, target="collect")))
            detail.add(focus_actions)
            if regions:
                detail.add(self.label("Immersions liées", "card-title"))
                region_flow = self.Gtk.FlowBox()
                region_flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
                for region in regions:
                    region_flow.add(self.card(
                        text(region.get("name_fr") or region.get("name_en"), "Immersion"),
                        text(region.get("id"), ""),
                        text(region.get("tone_fr") or region.get("tone_en"))[:220],
                        lambda region=region: self.show_immersion(region),
                    ))
                detail.add(region_flow)
            profile = self.Gtk.FlowBox()
            profile.set_selection_mode(self.Gtk.SelectionMode.NONE)
            for title, body in [
                ("Patrimoine", f"{len(related)} éléments sourcés disponibles hors ligne."),
                ("Langues", "À enrichir par packs locaux: dictionnaires, prononciation et expressions."),
                ("Cuisine", "Prêt pour recettes régionales, gestes culinaires et récits familiaux."),
                ("Musique", "Prêt pour instruments, playlists locales et lecture mpv."),
                ("Mode", "Prêt pour textiles, gestes de fabrication, créateurs, usages sociaux et pont ElegantStyle."),
                ("Récits", "Prêt pour contes, proverbes, interviews et narration française offline."),
            ]:
                profile.add(self.card(title, name, body))
            detail.add(profile)
            if related:
                detail.add(self.label("Patrimoine associé", "card-title"))
            for item in related[:18]:
                detail.add(self.card(self.localized(item, "title", "Sans titre"), f"{item.get('year', '')} · {item.get('type_acronym', 'ICH')}", self.localized(item, "summary")[:220], lambda item=item: self.show_modal(item)))
            detail.show_all()

        listbox.connect("row-selected", select_country)
        search.connect("search-changed", lambda entry: fill_list(entry.get_text()))
        fill_list()
        root.add(left)
        root.add(self.scroll(detail))
        return root

    def immersions_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        root.add(self.label("Immersions culturelles", "title"))
        root.add(self.label("Entrer dans Baobab par des régions, routes, sons, langues et gestes quotidiens. Tout reste local, sourcé et à valider par les communautés concernées.", "subtitle"))
        active = self.active_immersion()
        if active:
            focus = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
            focus.get_style_context().add_class("immersion-band")
            focus.add(self.label(f"Focus actuel · {active.get('name_fr') or active.get('name_en')}", "card-title"))
            focus.add(self.label(text(active.get("tone_fr") or active.get("tone_en")), "card-body"))
            focus.add(self.label(f"Rituel: {self.daily_ritual()}", "card-meta"))
            countries_row = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=8)
            for country in active.get("countries", [])[:5]:
                countries_row.add(self.button(text(country), lambda _button, country=country: self.focus_country(text(country))))
            focus.add(countries_row)
            root.add(focus)

        top = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=16)
        top.add(self.immersion_canvas())
        intro = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=10)
        intro.get_style_context().add_class("immersion-band")
        intro.add(self.label("Mode d’usage", "card-title"))
        intro.add(self.label("Choisis une immersion, puis ouvre un pays, une langue, un son ou une collecte. Baobab garde le fil culturel; Atlas reste réservé aux documents, OCR et cartes générales.", "card-body"))
        actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        actions.add(self.button("Explorer les pays", lambda *_: self.stack.set_visible_child_name("explore")))
        actions.add(self.button("Langues", lambda *_: self.stack.set_visible_child_name("languages")))
        actions.add(self.button("Nouvelle collecte", lambda *_: self.stack.set_visible_child_name("collect")))
        intro.add(actions)
        top.pack_start(intro, True, True, 0)
        root.add(top)
        search = self.Gtk.SearchEntry()
        search.set_placeholder_text("Filtrer par région, pays, langue, son, route...")
        root.add(search)

        if self.pathways:
            root.add(self.label("Parcours guidés", "card-title"))
            path_flow = self.Gtk.FlowBox()
            path_flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
            for item in self.pathways:
                steps = item.get("steps_fr", []) or item.get("steps_en", [])
                body = "\n".join(f"{index + 1}. {step}" for index, step in enumerate(steps[:5]))
                path_flow.add(self.card(text(item.get("title_fr") or item.get("title_en"), "Parcours"), text(item.get("id"), ""), body))
            root.add(path_flow)

        root.add(self.label("Régions d’immersion", "card-title"))
        flow = self.Gtk.FlowBox()
        flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
        def render(query: str = "") -> None:
            for child in flow.get_children():
                flow.remove(child)
            q = query.lower().strip()
            for item in self.immersions:
                countries = ", ".join(item.get("countries", [])[:6])
                anchors = ", ".join(item.get("anchors", [])[:6])
                haystack = " ".join([
                    text(item.get("id")),
                    text(item.get("name_fr")),
                    text(item.get("name_en")),
                    text(item.get("tone_fr")),
                    text(item.get("tone_en")),
                    " ".join(item.get("countries", [])),
                    " ".join(item.get("anchors", [])),
                ]).lower()
                if q and q not in haystack:
                    continue
                body = f"{item.get('tone_fr') or item.get('tone_en', '')}\n\nPays: {countries}\nAncres: {anchors}"
                flow.add(self.card(text(item.get("name_fr") or item.get("name_en"), "Immersion"), text(item.get("id"), ""), body, lambda item=item: self.show_immersion(item)))
            flow.show_all()
        search.connect("search-changed", lambda entry: render(entry.get_text()))
        render()
        root.add(flow)
        return self.scroll(root)

    def compass_view(self) -> object:
        root = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=16)
        root.set_border_width(18)
        payload = self.compass_payload
        next_item = payload.get("next", {})
        root.add(self.label("Boussole Baobab", "title"))
        root.add(self.label("Un repère d'usage pour que chaque geste reste culturellement responsable, local-first et lisible.", "subtitle"))
        root.add(self.compass_panel(compact=False))
        if next_item:
            action = text(next_item.get("command"), "seven baobab open")
            box = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
            box.get_style_context().add_class("next-card")
            content = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=4)
            content.pack_start(self.label("Action conseillée", "card-meta", False), False, False, 0)
            content.pack_start(self.label(text(next_item.get("title"), "Comprendre"), "card-title"), False, False, 0)
            content.pack_start(self.label(text(next_item.get("body")), "card-body"), False, False, 0)
            box.pack_start(content, True, True, 0)
            box.pack_end(self.button("Lancer", lambda *_: subprocess.Popen(shlex.split(action), stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)), False, False, 0)
            root.add(box)
        root.add(self.label("Principes de transmission", "card-title"))
        for principle in payload.get("principles", []):
            root.add(self.label(f"- {principle}", "card-body"))
        root.add(self.card("Pourquoi cette boussole ?", "Identité Baobab", "Baobab ne doit pas seulement afficher des contenus africains. Il doit guider l'usage: comprendre avant de classer, sourcer avant de partager, collecter en brouillon, préserver localement et transmettre avec consentement."))
        return self.scroll(root)

    def today_view(self) -> object:
