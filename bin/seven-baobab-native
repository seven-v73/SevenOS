        root.add(self.entry_panel(compact=True))
        root.add(self.veillee_panel(compact=True))
        root.add(self.session_panel(compact=True))
        root.add(self.recent_sessions_panel())
        root.add(self.carnet_panel(compact=True))
        root.add(self.constellation_panel(compact=True))
        root.add(self.media_panel(compact=True))
        root.add(self.today_panel(compact=True))
        root.add(self.ambiance_panel())
        root.add(self.compass_panel(compact=True))
        root.add(self.trail_panel(compact=True))
        active = self.active_immersion()
        ritual = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=8)
        ritual.get_style_context().add_class("immersion-band")
        ritual.add(self.label("Rituel du jour", "card-title"))
        ritual.add(self.label(self.daily_ritual(), "card-body"))
        if active:
            ritual.add(self.label(f"Focus: {active.get('name_fr') or active.get('name_en')}", "card-meta"))
        ritual_actions = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=10)
        ritual_actions.add(self.button("Créer une note", lambda *_: self.create_daily_ritual_note()))
        ritual_actions.add(self.button("Journal", lambda *_: self.stack.set_visible_child_name("journal")))
        ritual_actions.add(self.button("Immersions", lambda *_: self.stack.set_visible_child_name("immersions")))
        ritual_actions.add(self.button("Collecte", lambda *_: self.stack.set_visible_child_name("collect")))
        ritual.add(ritual_actions)
        root.add(ritual)
        root.add(self.route_card())
        root.add(self.next_action_card())

        os_surface = self.Gtk.Box(orientation=self.Gtk.Orientation.HORIZONTAL, spacing=16)
        os_surface.add(self.tree_canvas())
        stations = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stations.attach(self.station("Racines", "Orientation", "Recherche, sources et préparation Baobab.", "search"), 0, 0, 1, 1)
        stations.attach(self.station("Tronc", "Mémoire", "Patrimoine, récits et modules de transmission.", "heritage"), 1, 0, 1, 1)
        stations.attach(self.station("Branches", "Territoires", "Pays, langues, immersions et relations culturelles.", "immersions"), 0, 1, 1, 1)
        stations.attach(self.station("Feuilles", "Usages", "Son, cuisine, mode, marché et créations vivantes.", "modules"), 1, 1, 1, 1)
        stations.attach(self.station("Collecte", "Terrain", "Ajouter un récit avec source, droits et consentement.", "collect"), 0, 2, 1, 1)
        stations.attach(self.station("Archives", "Préservation", "Packs, musée et exports locaux contrôlés.", "packs"), 1, 2, 1, 1)
        os_surface.pack_start(stations, True, True, 0)
        root.add(os_surface)

        stats = self.Gtk.Grid(column_spacing=12, row_spacing=12)
        stats.attach(self.stat(str(len(self.countries)), "Pays africains"), 0, 0, 1, 1)
        stats.attach(self.stat(str(len(self.heritage)), "Éléments UNESCO ICH"), 1, 0, 1, 1)
        stats.attach(self.stat(str(len(self.records)), "Modules Baobab"), 2, 0, 1, 1)
        stats.attach(self.stat(str(len(self.datasets)), "Sources locales"), 3, 0, 1, 1)
        stats.attach(self.stat(str(len(self.immersions)), "Immersions"), 0, 1, 1, 1)
        stats.attach(self.stat(text(self.settings.get("language", "fr")).upper(), "Langue prioritaire"), 1, 1, 1, 1)
        stats.attach(self.stat(str(self.packs_payload.get("count", 0)), "Packs culturels"), 2, 1, 1, 1)
        stats.attach(self.stat(f"{self.audit_payload.get('score', 0)}%", "Qualité packs"), 3, 1, 1, 1)
        root.add(stats)

        root.add(self.label("Arbre de connaissance", "title"))
        root.add(self.label("Baobab organise l'OS comme une mémoire vivante: comprendre, relier, transmettre, collecter et préserver.", "subtitle"))

        def tree_section(title: str, meta: str, body: str, css: str, entries: list[tuple[str, str, str, str]]) -> object:
            section = self.Gtk.Box(orientation=self.Gtk.Orientation.VERTICAL, spacing=12)
            section.get_style_context().add_class("tree-section")
            section.get_style_context().add_class(css)
            section.add(self.label(title, "card-title"))
            section.add(self.label(meta, "card-meta"))
            section.add(self.label(body, "card-body"))
            flow = self.Gtk.FlowBox()
            flow.set_selection_mode(self.Gtk.SelectionMode.NONE)
            for entry_title, entry_meta, entry_body, target in entries:
                flow.add(self.card(entry_title, entry_meta, entry_body, lambda target=target: self.stack.set_visible_child_name(target)))
            section.add(flow)
            return section

        root.add(tree_section(
            "Racines",
            "Orientation et fondation",
            "Voir ce qui est prêt dans Baobab: langues, pays, sources et qualité des contenus avant d’ajouter ou de publier.",
            "tree-root",
            [
                ("Recherche", "Point d'entrée calme", "Trouver pays, récits, sources et patrimoine depuis une seule zone.", "search"),
