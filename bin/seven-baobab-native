                ("Langues", "Apprentissage validable", "Consulter les premières langues africaines et leur statut.", "languages"),
                ("Musée", "Archives contemplatives", "Voir les contenus comme objets, traces et archives.", "museum"),
            ],
        ))
        root.add(tree_section(
