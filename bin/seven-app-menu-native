#!/usr/bin/env python3
"""Native SevenOS app-menu panel for the Waybar menu bar."""

from __future__ import annotations

import json
import os
import subprocess
import sys
import warnings
import atexit
from pathlib import Path

from seven_waybar_app_profiles import (
    active_window as shared_active_window,
    context_for_window,
    items_for as shared_items_for,
)


ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT / "scripts"))
try:
    import seven_theme
except Exception:  # pragma: no cover
    seven_theme = None
AREA = sys.argv[1] if len(sys.argv) > 1 else "file"
REQUEST_FILE = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "sevenos/app-menu-request.json"
STATUS_FILE = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "sevenos/app-menu-status.json"
ENGINE_VERSION = "cairo-pango-v2"
warnings.filterwarnings("ignore", category=DeprecationWarning)


def run(command: list[str], timeout: float = 1.0) -> str:
    try:
        return subprocess.run(command, text=True, capture_output=True, check=False, timeout=timeout).stdout.strip()
    except Exception:
        return ""


def active_window() -> dict:
    return shared_active_window()


def active_profile() -> str:
    manager = ROOT / "profiles/profile-manager.sh"
    if manager.exists():
        text = run([str(manager), "current", "--json"], timeout=0.8)
        try:
            return str(json.loads(text or "{}").get("key") or "equinox").lower()
        except json.JSONDecodeError:
            pass
    return os.environ.get("SEVENOS_PROFILE", "equinox").lower()


def context_mode(window: dict) -> str:
    return str(context_for_window(window, active_profile()).get("mode") or "default")
    klass = str(window.get("class") or window.get("initialClass") or "").lower()
    profile = active_profile()
    if any(token in klass for token in ("google-chrome", "chromium", "chrome", "firefox", "brave", "vivaldi", "librewolf", "browser", "edge")):
        return "browser"
    if any(token in klass for token in ("code", "codium", "cursor", "jetbrains", "idea", "pycharm", "webstorm")):
        return "developer"
    if any(token in klass for token in ("terminal", "kitty", "foot", "alacritty", "wezterm", "console")):
        return "terminal"
    if any(token in klass for token in ("nautilus", "seven-files", "thunar", "dolphin", "nemo", "file")):
        return "files"
    if any(token in klass for token in ("libreoffice", "onlyoffice", "writer", "calc", "impress", "evince", "okular", "zathura", "reader")):
        return "documents"
    if any(token in klass for token in ("vlc", "mpv", "spotify", "audacious", "rhythmbox", "celluloid")):
        return "media"
    if any(token in klass for token in ("gimp", "inkscape", "blender", "kdenlive", "obs", "krita", "studio")):
        return "studio"
    if profile in {"studio", "shield", "windows", "forge", "pulse", "baobab"}:
        return profile
    return "default"


def app_key(window: dict) -> str:
    return str(context_for_window(window, active_profile()).get("key") or "generic")
    klass = str(window.get("class") or window.get("initialClass") or "").lower()
    if "google-chrome" in klass:
        return "chrome"
    if "chromium" in klass:
        return "chromium"
    if "firefox" in klass or "librewolf" in klass:
        return "firefox"
    if klass in {"code", "code-url-handler"} or "visual-studio-code" in klass:
        return "vscode"
    if "kitty" in klass:
        return "kitty"
    if "sevenfiles" in klass or "seven-files" in klass:
        return "seven-files"
    if "vlc" in klass:
        return "vlc"
    if "spotify" in klass:
        return "spotify"
    if "obs" in klass:
        return "obs"
    return "generic"


def service_key(window: dict, key: str) -> str:
    return str(context_for_window(window, active_profile()).get("service") or "")
    title = str(window.get("title") or "").lower()
    if key not in {"chrome", "chromium", "firefox"}:
        return ""
    if "youtube" in title:
        return "youtube"
    if "gmail" in title or ("inbox" in title and "mail" in title):
        return "gmail"
    if "google docs" in title or "docs.google" in title:
        return "google-docs"
    if "google sheets" in title or "sheets.google" in title:
        return "google-sheets"
    if "google drive" in title or "drive.google" in title:
        return "google-drive"
    if "github" in title:
        return "github"
    if "figma" in title:
        return "figma"
    if "notion" in title:
        return "notion"
    if "spotify" in title:
        return "spotify-web"
    if "netflix" in title or "prime video" in title or "disney+" in title:
        return "streaming"
    return ""


