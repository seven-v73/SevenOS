def rgba(hex_color: str, alpha: float = 1.0) -> Gdk.RGBA:
    color = Gdk.RGBA()
    color.parse(hex_color)
    color.alpha = alpha
    return color


def style_label(label: Gtk.Label, color: Gdk.RGBA, font: str) -> Gtk.Label:
    label.override_color(Gtk.StateFlags.NORMAL, color)
    label.override_font(Pango.FontDescription(font))
    return label


class AppMenu(Gtk.Window):
    def __init__(self, area: str):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        write_status()
        atexit.register(clear_status)
        self.current_area = area
        self.last_request_time = ""
        self.window = active_window()
        self.address = str(self.window.get("address") or "")
        self.mode = context_mode(self.window)
        self.app_key = app_key(self.window)
        self.service = service_key(self.window, self.app_key)
        self.title, self.items = items_for(area, self.mode, self.app_key, self.service)
        self.pointer_inside = True
        self.close_source = 0
        self.selected_index = 0
        self.hover_index = -1
        self.canvas: Gtk.DrawingArea | None = None
        self.set_name("seven-app-menu-native")
        self.set_title("App Menu")
        self.set_wmclass("seven-app-menu-native", "seven-app-menu-native")
        self.set_app_paintable(False)
        self.get_style_context().add_class("seven-app-menu")
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_resizable(False)
        self.set_type_hint(Gdk.WindowTypeHint.UTILITY)
        self.panel_height = max(142, 58 + (len(self.items) * 36))
        self.set_default_size(336, self.panel_height)
        self.set_size_request(336, self.panel_height)
        self.add_events(Gdk.EventMask.ENTER_NOTIFY_MASK | Gdk.EventMask.LEAVE_NOTIFY_MASK | Gdk.EventMask.KEY_PRESS_MASK)
        self.connect("key-press-event", self.on_key)
        self.connect("enter-notify-event", self.on_enter)
        self.connect("leave-notify-event", self.on_leave)
        self.build()
        self.place(area)
        GLib.timeout_add(80, self.place_after_map)
        GLib.timeout_add(90, self.poll_request)

    def build(self) -> None:
        self.canvas = Gtk.DrawingArea()
        self.canvas.set_size_request(336, self.panel_height)
        self.canvas.add_events(
            Gdk.EventMask.BUTTON_PRESS_MASK
            | Gdk.EventMask.POINTER_MOTION_MASK
            | Gdk.EventMask.LEAVE_NOTIFY_MASK
        )
        self.canvas.connect("draw", self.on_draw)
        self.canvas.connect("motion-notify-event", self.on_motion)
        self.canvas.connect("button-press-event", self.on_button)
        self.canvas.connect("leave-notify-event", self.on_canvas_leave)
        self.add(self.canvas)

    def populate_items(self) -> None:
        self.selected_index = 0
        self.hover_index = -1
        self.panel_height = max(142, 58 + (len(self.items) * 36))
        self.set_default_size(336, self.panel_height)
        self.set_size_request(336, self.panel_height)
        if self.canvas is not None:
            self.canvas.set_size_request(336, self.panel_height)
            self.canvas.queue_draw()

    def rounded_rect(self, cr, x: float, y: float, width: float, height: float, radius: float) -> None:
        cr.new_sub_path()
        cr.arc(x + width - radius, y + radius, radius, -1.5708, 0)
        cr.arc(x + width - radius, y + height - radius, radius, 0, 1.5708)
        cr.arc(x + radius, y + height - radius, radius, 1.5708, 3.14159)
        cr.arc(x + radius, y + radius, radius, 3.14159, 4.71239)
        cr.close_path()

    def draw_text(self, cr, text: str, x: int, y: int, width: int, font: str, color: tuple[float, float, float, float]) -> None:
        layout = self.create_pango_layout(text)
        layout.set_width(width * Pango.SCALE)
        layout.set_ellipsize(Pango.EllipsizeMode.END)
        layout.set_font_description(Pango.FontDescription(font))
        cr.set_source_rgba(*color)
        cr.move_to(x, y)
        PangoCairo.show_layout(cr, layout)

    def on_draw(self, _widget, cr) -> bool:
        width = 336
        height = self.panel_height
        cr.set_source_rgb(0.055, 0.065, 0.090)
        cr.paint()

        self.rounded_rect(cr, 1, 1, width - 2, height - 2, 14)
        cr.set_source_rgb(0.055, 0.065, 0.090)
        cr.fill_preserve()
        cr.set_source_rgba(0.72, 0.92, 1.0, 0.72)
        cr.set_line_width(1.0)
        cr.stroke()

        self.draw_text(cr, self.title, 16, 12, 210, "SF Pro Text SemiBold 13", (1, 1, 1, 0.96))
        subtitle = str(self.window.get("title") or "Application active")[:72]
        self.draw_text(cr, subtitle, 16, 31, 300, "SF Pro Text 11", (0.88, 0.92, 0.98, 0.58))

        cr.set_source_rgba(0.30, 0.72, 1.0, 0.85)
        cr.rectangle(16, 51, 78, 2)
        cr.fill()
        cr.set_source_rgba(1, 1, 1, 0.08)
        cr.rectangle(1, 56, width - 2, 1)
        cr.fill()

        for index, (icon_text, label_text, shortcut_text) in enumerate(self.items):
            y = 64 + index * 34
            active = index == self.selected_index or index == self.hover_index
            if active:
                self.rounded_rect(cr, 8, y - 1, width - 16, 30, 9)
                cr.set_source_rgba(1, 1, 1, 0.13)
                cr.fill_preserve()
                cr.set_source_rgba(1, 1, 1, 0.08)
                cr.set_line_width(1)
                cr.stroke()
            self.draw_text(cr, icon_text, 17, y + 5, 24, "Symbols Nerd Font 16", (0.49, 0.81, 1.0, 0.95))
            self.draw_text(cr, label_text, 48, y + 6, 190, "SF Pro Text 12", (0.97, 0.98, 1.0, 0.94))
            if shortcut_text:
                self.draw_text(cr, shortcut_text, 238, y + 7, 80, "SF Mono 11", (0.88, 0.92, 0.98, 0.50))
        return False

    def item_at(self, y: float) -> int:
        index = int((y - 64) // 34)
        if 0 <= index < len(self.items):
            return index
        return -1

    def on_motion(self, _widget, event) -> bool:
        index = self.item_at(event.y)
        if index != self.hover_index:
            self.hover_index = index
            if index >= 0:
                self.selected_index = index
            if self.canvas is not None:
                self.canvas.queue_draw()
        return False

    def on_button(self, _widget, event) -> bool:
        index = self.item_at(event.y)
        if index >= 0:
            _icon_text, label_text, _shortcut_text = self.items[index]
            self.activate(label_text)
            return True
        return False

    def on_canvas_leave(self, *_args) -> bool:
        self.hover_index = -1
        if self.canvas is not None:
            self.canvas.queue_draw()
        return False

    def update_area(self, area: str) -> None:
        if area not in {"file", "edit", "view", "extra", "tools", "window", "help"}:
            return
        self.current_area = area
        self.window = active_window()
        self.address = str(self.window.get("address") or "")
        self.mode = context_mode(self.window)
        self.app_key = app_key(self.window)
        self.service = service_key(self.window, self.app_key)
        self.title, self.items = items_for(area, self.mode, self.app_key, self.service)
        self.populate_items()
        self.place(area)
        self.present()
        self.show_all()

    def poll_request(self) -> bool:
        payload = request_payload()
        stamp = str(payload.get("time") or "")
        area = str(payload.get("area") or "")
        if stamp and stamp != self.last_request_time:
            self.last_request_time = stamp
            self.pointer_inside = True
            if self.close_source:
                GLib.source_remove(self.close_source)
                self.close_source = 0
            self.update_area(area)
        return True

    def place(self, area: str) -> None:
        offsets = {"file": 260, "edit": 316, "view": 382, "extra": 472, "tools": 568, "window": 638, "help": 708}
        x = offsets.get(area, 260)
        y = 32
        try:
            display = Gdk.Display.get_default()
            seat = display.get_default_seat() if display else None
            pointer = seat.get_pointer() if seat else None
            screen, pointer_x, _pointer_y = pointer.get_position() if pointer else (None, x, y)
            monitor = screen.get_monitor_geometry(screen.get_monitor_at_point(pointer_x, y)) if screen else None
            if monitor:
                x = max(monitor.x + 8, min(pointer_x - 44, monitor.x + monitor.width - 352))
        except Exception:
            pass
        self.move(x, y)

    def place_after_map(self) -> bool:
        self.place(self.current_area)
        if self.canvas is not None:
            self.canvas.queue_draw()
        return False

    def activate(self, label: str) -> None:
        run_action(label, self.address)
        self.close()

    def select_index(self, index: int) -> None:
        if not self.items:
            return
        self.selected_index = index % len(self.items)
        if self.canvas is not None:
            self.canvas.queue_draw()

    def on_enter(self, *_args) -> bool:
        self.pointer_inside = True
        if self.close_source:
            GLib.source_remove(self.close_source)
            self.close_source = 0
        return False

    def on_leave(self, *_args) -> bool:
        self.pointer_inside = False
        return False

    def close_if_outside(self) -> bool:
        self.close_source = 0
        if not self.pointer_inside:
            self.close()
        return False

    def on_key(self, _window, event) -> bool:
        if event.keyval == Gdk.KEY_Escape:
            self.close()
            return True
        if event.keyval in {Gdk.KEY_Down, Gdk.KEY_j}:
            self.select_index(self.selected_index + 1)
            return True
        if event.keyval in {Gdk.KEY_Up, Gdk.KEY_k}:
            self.select_index(self.selected_index - 1)
            return True
        if event.keyval in {Gdk.KEY_Return, Gdk.KEY_KP_Enter, Gdk.KEY_space} and self.items:
            icon_text, label_text, _shortcut_text = self.items[self.selected_index]
            self.activate(label_text)
            return True
        return False


def main() -> int:
    app = AppMenu(AREA)
    app.show_all()
    app.present()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
