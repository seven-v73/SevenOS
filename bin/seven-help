#!/usr/bin/env bash
set -Eeuo pipefail

title="SevenOS Help"

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT/hyprland/rofi" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/../hyprland/rofi" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -d "$candidate/hyprland/rofi" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root)"

run_terminal() {
  local command="$1"
  if command -v kitty >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    kitty --title "$title" bash -lc "$command; printf '\nPress Enter to close...'; read -r" &
  else
    bash -lc "$command"
  fi
}

menu=$'󰒓  Open Seven Hub    Super+Space / Super+H\n󰀻  Open Apps    Super+A / Super+D\n󰖲  Window Overview    Super+Tab\n󰒓  Quick Settings    Super+N / Super+O\n󰆍  Open Terminal    Super+Enter\n󰉋  Open Files    Super+E\n󰐥  Power Menu    Super+Shift+P\n󰍁  Lock Screen    Super+L\n󰆍  Scratchpad    Super+S\n󰄀  Screenshot Region    Super+Shift+S\n󰜉  Reload Desktop    Reapply Hyprland config\n󰩂  Post-Install Check    Diagnose missing UI pieces\n󰁨  Repair UX    Reapply theme, hub and commands'

if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
  printf '%s\n' "$menu"
  exit 0
fi

if command -v rofi >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
  selected="$(printf '%s\n' "$menu" | rofi -dmenu -i -p "$title" -mesg "SevenOS desktop controls" -theme "$ROOT_DIR/hyprland/rofi/sevenos.rasi" 2>/dev/null || true)"
else
  printf '%s\n' "$menu"
  exit 0
fi

selected="${selected#*  }"
selected="${selected%%    *}"

case "$selected" in
  "Open Seven Hub") seven-hub ;;
  "Open Apps") seven-overview apps ;;
  "Window Overview") seven-overview windows ;;
  "Quick Settings") seven-quick-settings ;;
  "Open Terminal") kitty & ;;
  "Open Files") seven-files ;;
  "Power Menu") seven-power ;;
  "Lock Screen") seven-power lock ;;
  "Scratchpad") hyprctl dispatch togglespecialworkspace seven ;;
  "Screenshot Region") grim -g "$(slurp)" - | swappy -f - ;;
  "Reload Desktop") hyprctl reload ;;
  "Post-Install Check") run_terminal "seven post-install" ;;
  "Repair UX") run_terminal "seven repair ux --apply" ;;
  "") exit 0 ;;
esac
