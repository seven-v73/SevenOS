## Daily Flow

1. Super opens apps.
2. Super+Space searches apps, files and actions.
3. Super+H returns here.
4. Super+N opens Wi-Fi/Bluetooth/audio/battery controls.
5. Super+E opens files.
6. `seven mini-os suggest` shows useful capabilities for the current context.
EOF
  fi

  if [[ "$topic" != "all" ]]; then
    printf '\n\n---\nTopic requested: %s\n' "$topic" >> "$HELP_DOC"
  fi
}

show_doc() {
  local topic="${1:-all}"
  write_help_doc "$topic"
  local pager='less -R'
  if ! command -v less >/dev/null 2>&1; then
    pager='cat'
  fi
  run_terminal "$pager $(printf '%q' "$HELP_DOC")"
}

open_command_doc() {
  show_doc commands
}

if [[ "${1:-}" == "--manual" || "${1:-}" == "manual" ]]; then
  write_help_doc all
  cat "$HELP_DOC"
  exit 0
fi

if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
  printf '%s\n' "$menu"
  exit 0
fi

if command -v rofi >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
  selected="$(printf '%s\n' "$menu" | rofi -dmenu -p "$title" -mesg "$message" -theme "$ROOT_DIR/hyprland/rofi/sevenos.rasi" 2>/dev/null || true)"
else
  printf '%s\n' "$menu"
  exit 0
fi

selected="${selected#*  }"
selected="${selected%%    *}"

case "$selected" in
  "Desktop Helpers"|"Aide du bureau") seven-help ;;
  "Install SevenOS"|"Installer SevenOS") run_terminal "seven new" ;;
  "Setup Windows Bridge"|"Configurer Windows Bridge") run_terminal "seven windows setup" ;;
  "Complete SevenOS Guide"|"Guide complet SevenOS") show_doc all ;;
  "Keyboard Shortcuts"|"Raccourcis clavier") show_doc shortcuts ;;
  "Terminal Commands"|"Commandes terminal") open_command_doc ;;
  "SevenOS Mini OS"|"Mini OS SevenOS") show_doc mini-os ;;
  "Mini OS Collaboration"|"Collaboration mini OS") show_doc mini-os-collaboration ;;
  "SevenOS Spotlight"|"Spotlight SevenOS") seven-spotlight ;;
  "Open Seven Hub"|"Ouvrir Seven Hub") seven-hub ;;
  "Open Apps"|"Ouvrir les apps") seven-overview apps ;;
  "Toggle Dock"|"Basculer le Dock") seven-dock toggle ;;
  "Window Overview"|"Vue des fenêtres") seven-overview windows ;;
  "Quick Settings"|"Réglages rapides") seven-quick-settings ;;
  "SevenOS Bar and Control Center"|"Barre SevenOS et panneau de contrôle") show_doc waybar ;;
  "Smart Window System") show_doc windows ;;
  "Terminal Classic"|"Terminal classique") seven-terminal classic ;;
  "Terminal Dark"|"Terminal sombre") seven-terminal dark ;;
  "Terminal Theme Menu"|"Menu du terminal") seven-terminal menu ;;
  "Open Files"|"Ouvrir Fichiers") seven-files ;;
  "Seven Files") show_doc files ;;
  "Seven Reader") show_doc reader ;;
  "SevenStore") show_doc store ;;
  "Power Menu"|"Menu énergie") seven-power ;;
  "Lock Screen"|"Verrouiller l’écran") seven-power lock ;;
  "Scratchpad") hyprctl dispatch togglespecialworkspace seven ;;
  "Screenshot Save"|"Capture enregistrée") seven-screenshot area save ;;
  "Screenshot Edit"|"Capture avec édition") seven-screenshot area edit ;;
  "Screenshot Copy"|"Capture copiée") seven-screenshot area copy ;;
  "Record Area"|"Enregistrer une zone") seven-recorder area ;;
  "Stop Recording"|"Arrêter l’enregistrement") seven-recorder stop ;;
  "Refresh Desktop"|"Rafraîchir le bureau") seven hypr apply ;;
  "Diagnostics and Repair"|"Diagnostic et réparation") show_doc diagnostics ;;
  "Post-Install Check"|"Vérification post-install") run_terminal "seven post-install" ;;
  "Repair UX"|"Réparer l’UX") run_terminal "seven repair ux --apply" ;;
  "") exit 0 ;;
esac
