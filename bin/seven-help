topic_heading() {
  local topic="${1:-all}"
  if [[ "$LANG_CODE" == "fr" ]]; then
    case "$topic" in
      install) printf 'Première installation\n' ;;
      quick|commands) printf 'Commandes à connaître\n' ;;
      architecture) printf 'Architecture SevenOS\n' ;;
      shortcuts) printf 'Raccourcis essentiels\n' ;;
      waybar) printf 'Barre SevenOS et panneau de contrôle\n' ;;
      actions) printf 'Actions SevenOS\n' ;;
      themes) printf 'Thèmes et apparence\n' ;;
      mini-os|mini-os-collaboration) printf 'Mini OS SevenOS\n' ;;
      files|reader|store|terminal|ai|apps) printf 'Applications SevenOS\n' ;;
      system|manual|network|fonts|backup|iso|installer) printf 'Manuel système\n' ;;
      packages|software|sevenpkg) printf 'Paquets et installation\n' ;;
      security|shield|windows-bridge) printf 'Sécurité, Shield et Windows\n' ;;
      faq|questions) printf 'FAQ locale\n' ;;
      glossary|vocabulary|vocabulaire) printf 'Glossaire SevenOS\n' ;;
      dev|development|checks) printf 'Développement SevenOS\n' ;;
      diagnostics|troubleshooting) printf 'Diagnostics et réparation\n' ;;
      windows) printf 'Système de fenêtres et raccourcis\n' ;;
      *) return 1 ;;
    esac
  else
    case "$topic" in
      install) printf 'First Install\n' ;;
      quick|commands) printf 'Commands To Know\n' ;;
      architecture) printf 'SevenOS Architecture\n' ;;
      shortcuts) printf 'Essential Shortcuts\n' ;;
      waybar) printf 'SevenOS Bar And Control Center\n' ;;
      actions) printf 'SevenOS Actions\n' ;;
      themes) printf 'Themes And Appearance\n' ;;
      mini-os|mini-os-collaboration) printf 'SevenOS Mini OS\n' ;;
      files|reader|store|terminal|ai|apps) printf 'SevenOS Applications\n' ;;
      system|manual|network|fonts|backup|iso|installer) printf 'System Manual\n' ;;
      packages|software|sevenpkg) printf 'Packages And Install\n' ;;
      security|shield|windows-bridge) printf 'Security, Shield And Windows\n' ;;
      faq|questions) printf 'Local FAQ\n' ;;
      glossary|vocabulary|vocabulaire) printf 'SevenOS Glossary\n' ;;
      dev|development|checks) printf 'SevenOS Development\n' ;;
      diagnostics|troubleshooting) printf 'Diagnostics And Repair\n' ;;
      windows) printf 'Window System And Shortcuts\n' ;;
      *) return 1 ;;
    esac
  fi
}

show_doc() {
  local topic="${1:-all}"
  write_help_doc "$topic"
  local viewer=""
  local heading=""
  heading="$(topic_heading "$topic" 2>/dev/null || true)"
  if command -v less >/dev/null 2>&1; then
    if [[ -n "$heading" ]]; then
      viewer="less -R $(printf '%q' "+/^## ${heading}") $(printf '%q' "$HELP_DOC")"
    else
      viewer="less -R $(printf '%q' "$HELP_DOC")"
    fi
  elif command -v bat >/dev/null 2>&1; then
    viewer="bat --paging=always --style=plain --language=markdown $(printf '%q' "$HELP_DOC")"
  else
    viewer="cat $(printf '%q' "$HELP_DOC")"
  fi
  run_terminal "$viewer"
}

search_doc() {
  if [[ "$#" -eq 0 || -z "${*// /}" ]]; then
    if [[ "$LANG_CODE" == "fr" ]]; then
      printf 'Usage: seven-help search <mot ou phrase>\n'
      printf 'Exemple: seven-help search wifi\n'
    else
      printf 'Usage: seven-help search <word or phrase>\n'
      printf 'Example: seven-help search wifi\n'
    fi
    return 1
  fi

  local query="$*"
  write_help_doc all
  awk -v query="$query" '
    function lower(value) { return tolower(value) }
    /^## / { section=$0 }
    /^### / { subsection=$0 }
    {
      haystack=lower($0)
      needle=lower(query)
      if (index(haystack, needle) > 0) {
        place=section
        if (subsection != "") {
          place=place " / " subsection
        }
        if (place != last_place) {
          if (printed) {
            print ""
          }
          print place
          last_place=place
          printed=1
        }
        print "  " $0
      }
    }
    END {
      if (!printed) {
        exit 2
      }
    }
  ' "$HELP_DOC" || {
    local status="$?"
    if [[ "$status" -eq 2 ]]; then
      if [[ "$LANG_CODE" == "fr" ]]; then
        printf 'Aucun résultat local pour: %s\n' "$query"
        printf 'Astuce: seven-help topics\n'
      else
        printf 'No local result for: %s\n' "$query"
        printf 'Tip: seven-help topics\n'
      fi
      return 0
    fi
    return "$status"
  }
}

