show_doc() {
  local topic="${1:-all}"
  write_help_doc "$topic"
  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    local heading=""
    heading="$(topic_heading "$topic" 2>/dev/null || true)"
    if [[ -n "$heading" ]]; then
      if [[ "$topic" == "docs" || "$topic" == "documentation" || "$topic" == "project-docs" ]]; then
        awk -v heading="## ${heading}" '$0 == heading { printing=1 } printing { print }' "$HELP_DOC"
      else
        awk -v heading="## ${heading}" '
          $0 == heading { printing=1 }
          printing && /^## / && $0 != heading { exit }
          printing { print }
        ' "$HELP_DOC"
      fi
    else
      cat "$HELP_DOC"
    fi
    return 0
  fi
  local viewer=""
  local heading=""
  heading="$(topic_heading "$topic" 2>/dev/null || true)"
  if command -v less >/dev/null 2>&1; then
    if [[ -n "$heading" ]]; then
      viewer="less -R $(printf '%q' "+/^## ${heading}") $(printf '%q' "$HELP_DOC")"
    else
      viewer="less -R $(printf '%q' "$HELP_DOC")"
    fi
  elif command -v bat >/dev/null 2>&1; then
    viewer="bat --paging=always --style=plain --language=markdown $(printf '%q' "$HELP_DOC")"
  else
    viewer="cat $(printf '%q' "$HELP_DOC")"
  fi
  run_terminal "$viewer"
}

search_doc() {
  if [[ "$#" -eq 0 || -z "${*// /}" ]]; then
    if [[ "$LANG_CODE" == "fr" ]]; then
      printf 'Usage: seven-help search <mot ou phrase>\n'
      printf 'Exemple: seven-help search wifi\n'
    else
      printf 'Usage: seven-help search <word or phrase>\n'
      printf 'Example: seven-help search wifi\n'
    fi
    return 1
  fi

  local query="$*"
  write_help_doc all
  awk -v query="$query" '
    function lower(value) { return tolower(value) }
    /^## / { section=$0; subsection="" }
    /^### / { subsection=$0 }
    {
      haystack=lower($0)
      needle=lower(query)
      if (index(haystack, needle) > 0) {
        place=section
        if (subsection != "") {
          place=place " / " subsection
        }
        if (place != last_place) {
          if (printed) {
            print ""
          }
          print place
          last_place=place
          printed=1
        }
        print "  " $0
      }
    }
    END {
      if (!printed) {
        exit 2
      }
    }
  ' "$HELP_DOC" || {
    local status="$?"
    if [[ "$status" -eq 2 ]]; then
      if [[ "$LANG_CODE" == "fr" ]]; then
        printf 'Aucun résultat local pour: %s\n' "$query"
        printf 'Astuce: seven-help topics\n'
      else
        printf 'No local result for: %s\n' "$query"
        printf 'Tip: seven-help topics\n'
      fi
      return 0
    fi
    return "$status"
  }
}

