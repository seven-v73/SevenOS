#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -d "$SEVENOS_ROOT/hyprland/rofi" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/../hyprland/rofi" ]]; then
    cd -- "$script_dir/.." && pwd
    return 0
  fi

  for candidate in /opt/SevenOS "$HOME/Code/OS/SevenOS" "$HOME/SevenOS"; do
    if [[ -d "$candidate/hyprland/rofi" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

ROOT_DIR="$(resolve_root)"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/sevenos"
HELP_DOC="$STATE_DIR/help-center.md"

prepare_help_state() {
  local probe=""
  if mkdir -p "$STATE_DIR" 2>/dev/null; then
    probe="$STATE_DIR/.sevenos-help-write-test"
    if (: >"$probe") 2>/dev/null; then
      rm -f "$probe"
      return 0
    fi
  fi

  STATE_DIR="/tmp/sevenos-help-${UID:-user}"
  HELP_DOC="$STATE_DIR/help-center.md"
  mkdir -p "$STATE_DIR"
}

prepare_help_state

language_code() {
  local language="${SEVENOS_LANGUAGE:-${LANG:-en_US.UTF-8}}"
  local config="${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.conf"
  if [[ -z "${SEVENOS_LANGUAGE:-}" && -f "$config" ]]; then
    language="$(awk -F= '/^(SEVENOS_LANGUAGE|LANG)=/{gsub(/["\047]/, "", $2); print $2; exit}' "$config")"
  fi
  case "$language" in
    fr*) printf 'fr\n' ;;
    *) printf 'en\n' ;;
  esac
}

