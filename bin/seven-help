case "${1:-}" in
  install|quick|commands|architecture|shortcuts|waybar|actions|themes|mini-os|mini-os-collaboration|files|reader|store|terminal|ai|apps|system|manual|network|fonts|backup|iso|installer|packages|software|sevenpkg|security|shield|windows-bridge|faq|questions|glossary|vocabulary|vocabulaire|dev|development|checks|diagnostics|troubleshooting|windows)
    if open_native_help "$1"; then
      exit 0
    fi
    show_doc "$1"
    exit 0
    ;;
esac

