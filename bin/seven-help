  Super+I                       general settings
  Super+Enter                   terminal
  Super+Q                       close window
  Super+1..9                    switch workspace
  Print                         area screenshot
  Super+Shift+S                 screenshot with edit

Quick repair:
  seven network repair --yes
  seven fonts refresh
  seven theme doctor
  seven hypr apply
  seven recovery
  seven events --limit 30

Windows and security:
  seven windows setup
  seven windows setup --iso ~/Downloads/Win11.iso
  seven shield status
  seven shield lab --preset web

SevenOS development:
  seven smoke
  seven pre-push
  seven phase-gate
  ./scripts/ux-check.sh
EOF
  fi
}

open_command_doc() {
  show_doc commands
}

open_native_help() {
  local topic="${1:-start}"
  case "$topic" in
    network|fonts|backup|iso|installer|manual) topic="system" ;;
    software|sevenpkg) topic="packages" ;;
    security|shield|windows-bridge) topic="security-windows" ;;
    faq|questions|glossary|vocabulary|vocabulaire) topic="repair" ;;
    dev|development|checks) topic="developer" ;;
  esac
  local native="$ROOT_DIR/bin/seven-help-native"
  if [[ "${SEVENOS_HELP_LEGACY:-0}" != "1" && -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    if [[ -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
      "$native" "$topic" &
      return 0
    fi
    if command -v seven-help-native >/dev/null 2>&1 && seven-help-native --probe >/dev/null 2>&1; then
      seven-help-native "$topic" &
      return 0
    fi
  fi
  return 1
}

if [[ "${1:-}" == "--manual" || "${1:-}" == "manual" ]]; then
  write_help_doc all
  cat "$HELP_DOC"
  exit 0
fi

if [[ "${1:-}" == "search" || "${1:-}" == "--search" ]]; then
  shift || true
  search_doc "$@"
  exit $?
fi

if [[ "${1:-}" == "cheat" || "${1:-}" == "cheatsheet" || "${1:-}" == "--cheat" ]]; then
  print_cheatsheet
  exit 0
fi

if [[ "${1:-}" == "topics" || "${1:-}" == "--topics" ]]; then
  if [[ "$LANG_CODE" == "fr" ]]; then
    cat <<'EOF'
