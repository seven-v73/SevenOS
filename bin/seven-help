case "${1:-}" in
  docs|documentation|project-docs|future|roadmap|features)
    show_doc "$1"
    exit 0
    ;;
  install|quick|commands|architecture|shortcuts|waybar|actions|server|deploy|hosting|domain|dns|core|seven-core|sevenbus|shell|ags|seven-shell|themes|mini-os|mini-os-collaboration|files|reader|store|terminal|ai|apps|system|manual|network|fonts|language|langue|backup|iso|installer|packages|software|sevenpkg|global-policy|global-expose|global-restrict|profile-service|mongodb|mongo|service|services|security|shield|atlas|faq|questions|glossary|vocabulary|vocabulaire|dev|development|checks|diagnostics|troubleshooting|windows)
