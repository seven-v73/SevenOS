open_command_doc() {
  show_doc commands
}

open_native_help() {
  local topic="${1:-start}"
  case "$topic" in
    network|fonts|language|langue|backup|iso|installer|manual) topic="system" ;;
    software|sevenpkg|global-policy|global-expose|global-restrict|profile-service|mongodb|mongo|service|services) topic="packages" ;;
    security|shield|atlas) topic="security-atlas" ;;
    faq|questions|glossary|vocabulary|vocabulaire) topic="repair" ;;
    dev|development|checks) topic="developer" ;;
    deploy|hosting|domain|dns) topic="server" ;;
    seven-core|sevenbus) topic="core" ;;
    ags|seven-shell) topic="shell" ;;
  esac
  local native="$ROOT_DIR/bin/seven-help-native"
  if [[ "${SEVENOS_HELP_LEGACY:-0}" != "1" && "${SEVENOS_DRY_RUN:-0}" != "1" && -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    if [[ -x "$native" ]] && SEVENOS_HELP_REQUIRE_SCREEN=1 "$native" --probe >/dev/null 2>&1; then
      "$native" "$topic" &
      return 0
    fi
    if command -v seven-help-native >/dev/null 2>&1 && SEVENOS_HELP_REQUIRE_SCREEN=1 seven-help-native --probe >/dev/null 2>&1; then
      seven-help-native "$topic" &
      return 0
    fi
  fi
  return 1
}

