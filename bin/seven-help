}

topic_heading() {
  local topic="${1:-all}"
  if [[ "$LANG_CODE" == "fr" ]]; then
    case "$topic" in
      install) printf 'Première installation\n' ;;
      quick|commands) printf 'Commandes à connaître\n' ;;
      architecture) printf 'Architecture SevenOS\n' ;;
      shortcuts) printf 'Raccourcis essentiels\n' ;;
      waybar) printf 'Barre SevenOS et panneau de contrôle\n' ;;
      actions) printf 'Actions SevenOS\n' ;;
      themes) printf 'Thèmes et apparence\n' ;;
      mini-os|mini-os-collaboration) printf 'Mini OS SevenOS\n' ;;
      files|reader|store|terminal|ai|apps) printf 'Applications SevenOS\n' ;;
      diagnostics|troubleshooting) printf 'Diagnostics et réparation\n' ;;
      windows) printf 'Système de fenêtres et raccourcis\n' ;;
      *) return 1 ;;
    esac
  else
    case "$topic" in
      install) printf 'First Install\n' ;;
      quick|commands) printf 'Commands To Know\n' ;;
      architecture) printf 'SevenOS Architecture\n' ;;
      shortcuts) printf 'Essential Shortcuts\n' ;;
      waybar) printf 'SevenOS Bar And Control Center\n' ;;
      actions) printf 'SevenOS Actions\n' ;;
      themes) printf 'Themes And Appearance\n' ;;
      mini-os|mini-os-collaboration) printf 'SevenOS Mini OS\n' ;;
      files|reader|store|terminal|ai|apps) printf 'SevenOS Applications\n' ;;
      diagnostics|troubleshooting) printf 'Diagnostics And Repair\n' ;;
      windows) printf 'Window System And Shortcuts\n' ;;
      *) return 1 ;;
    esac
  fi
}

show_doc() {
  local topic="${1:-all}"
  write_help_doc "$topic"
  local viewer=""
  local heading=""
  heading="$(topic_heading "$topic" 2>/dev/null || true)"
  if command -v less >/dev/null 2>&1; then
    if [[ -n "$heading" ]]; then
      viewer="less -R $(printf '%q' "+/^## ${heading}") $(printf '%q' "$HELP_DOC")"
    else
      viewer="less -R $(printf '%q' "$HELP_DOC")"
    fi
  elif command -v bat >/dev/null 2>&1; then
    viewer="bat --paging=always --style=plain --language=markdown $(printf '%q' "$HELP_DOC")"
  else
    viewer="cat $(printf '%q' "$HELP_DOC")"
  fi
  run_terminal "$viewer"
}

open_command_doc() {
  show_doc commands
}

open_native_help() {
  local topic="${1:-start}"
  local native="$ROOT_DIR/bin/seven-help-native"
  if [[ "${SEVENOS_HELP_LEGACY:-0}" != "1" && -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    if [[ -x "$native" ]] && "$native" --probe >/dev/null 2>&1; then
      "$native" "$topic" &
      return 0
    fi
    if command -v seven-help-native >/dev/null 2>&1 && seven-help-native --probe >/dev/null 2>&1; then
      seven-help-native "$topic" &
      return 0
    fi
  fi
  return 1
}

if [[ "${1:-}" == "--manual" || "${1:-}" == "manual" ]]; then
  write_help_doc all
  cat "$HELP_DOC"
  exit 0
fi

case "${1:-}" in
  install|quick|commands|architecture|shortcuts|waybar|actions|themes|mini-os|mini-os-collaboration|files|reader|store|terminal|ai|apps|diagnostics|troubleshooting|windows)
    if open_native_help "$1"; then
      exit 0
    fi
    show_doc "$1"
    exit 0
    ;;
esac

if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
  printf '%s\n' "$menu"
  exit 0
fi

if [[ $# -eq 0 ]] && open_native_help start; then
  exit 0
fi

if command -v rofi >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
  selected="$(printf '%s\n' "$menu" | rofi -dmenu -p "$title" -mesg "$message" -theme "$ROOT_DIR/hyprland/rofi/sevenos.rasi" 2>/dev/null || true)"
else
  printf '%s\n' "$menu"
  exit 0
fi

selected="${selected#*  }"
selected="${selected%%    *}"

case "$selected" in
  "Desktop Helpers"|"Aide du bureau") seven-help ;;
  "Install SevenOS"|"Installer SevenOS") run_terminal "seven new" ;;
  "Setup Windows Bridge"|"Configurer Windows Bridge") run_terminal "seven windows setup" ;;
  "Complete SevenOS Guide"|"Guide complet SevenOS") show_doc all ;;
  "SevenOS Architecture"|"Architecture SevenOS") show_doc architecture ;;
  "SevenOS Actions"|"Actions SevenOS") show_doc actions ;;
  "Themes and Appearance"|"Thèmes et apparence") show_doc themes ;;
  "Keyboard Shortcuts"|"Raccourcis clavier") show_doc shortcuts ;;
  "Terminal Commands"|"Commandes terminal") open_command_doc ;;
  "SevenOS Mini OS"|"Mini OS SevenOS") show_doc mini-os ;;
  "Mini OS Collaboration"|"Collaboration mini OS") show_doc mini-os-collaboration ;;
  "SevenOS Spotlight"|"Spotlight SevenOS") seven-spotlight ;;
  "Open Seven Hub"|"Ouvrir Seven Hub") seven-hub ;;
  "Open Apps"|"Ouvrir les apps") seven-overview apps ;;
  "Toggle Dock"|"Basculer le Dock") seven-dock toggle ;;
  "Window Overview"|"Vue des fenêtres") seven-overview windows ;;
  "Quick Settings"|"Réglages rapides") seven-quick-settings ;;
  "SevenOS Bar and Control Center"|"Barre SevenOS et panneau de contrôle") show_doc waybar ;;
  "Smart Window System") show_doc windows ;;
  "Terminal Classic"|"Terminal classique") seven-terminal classic ;;
  "Terminal Dark"|"Terminal sombre") seven-terminal profile ;;
  "Terminal Theme Menu"|"Menu du terminal") seven-terminal menu ;;
  "Open Files"|"Ouvrir Fichiers") seven-files ;;
  "Seven Files") show_doc files ;;
  "Seven Reader") show_doc reader ;;
  "SevenStore") show_doc store ;;
  "Power Menu"|"Menu énergie") seven-power ;;
  "Lock Screen"|"Verrouiller l’écran") seven-power lock ;;
  "Scratchpad") hyprctl dispatch togglespecialworkspace seven ;;
  "Screenshot Save"|"Capture enregistrée") seven-screenshot area save ;;
  "Screenshot Edit"|"Capture avec édition") seven-screenshot area edit ;;
  "Screenshot Copy"|"Capture copiée") seven-screenshot area copy ;;
  "Record Area"|"Enregistrer une zone") seven-recorder area ;;
  "Stop Recording"|"Arrêter l’enregistrement") seven-recorder stop ;;
  "Refresh Desktop"|"Rafraîchir le bureau") seven hypr apply ;;
  "Diagnostics and Repair"|"Diagnostic et réparation") show_doc diagnostics ;;
  "Post-Install Check"|"Vérification post-install") run_terminal "seven post-install" ;;
  "Repair UX"|"Réparer l’UX") run_terminal "seven repair ux --apply" ;;
  "") exit 0 ;;
esac
