def handle_launchpad(args):
    action = args.action
    if action in ("open", "apps"):
        run_script(args, "bin/seven-apps", "open")
        return
    if action == "refresh":
        run_script(args, "bin/seven-launchpad-native", "--refresh")
        return
    if action == "doctor":
        extra = ["--doctor"]
        if args.json:
            extra.append("--json")
        run_script(args, "bin/seven-launchpad-native", *extra)
        return
    if action in ("json", "status"):
        run_script(args, "bin/seven-launchpad-native", "--json")
        return
    if action in ("catalog", "catalog-json"):
        run_script(args, "bin/seven-launchpad-native", "--catalog-json")
        return
    print("seven launchpad: supported actions are open, refresh, doctor, status and catalog", file=sys.stderr)
    sys.exit(2)


def main():
    dry_run_requested = "--dry-run" in sys.argv[1:]
