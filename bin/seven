def handle_installer(args):
    extra = [args.action, *args.extra]
    if args.json:
        extra.append("--json")
    if args.action in {"iso-runtime", "calamares-iso"} and is_dry_run(args):
        if "--dry-run" not in extra:
            extra.append("--dry-run")
        run_script_with_dry_env("scripts/installer-stack.sh", *extra)
        return
    run_script(args, "scripts/installer-stack.sh", *extra)


