def handle_dynamic(args):
    extra = [args.action]
    if args.json:
        extra = ["json"]
    run_script(args, "scripts/adaptive-ui.sh", *extra)


def handle_welcome(args):
    extra = [args.action]
    if args.json:
        extra.append("--json")
    run_script(args, "bin/seven-welcome", *extra)


def handle_session(args):
    if args.action == "status":
        extra = ["--json"] if args.json else []
        run_script(args, "bin/seven-session-status", *extra)
    elif args.action == "start":
        run_script(args, "bin/seven-session")
    elif args.action == "restart":
        run(["bash", "-lc", f"systemctl --user restart sevenos-session.target || {shlex.quote(str(ROOT_DIR / 'bin' / 'seven-session'))}"], args)
    else:
        print(f"seven: unknown session action: {args.action}", file=sys.stderr)
        sys.exit(1)


