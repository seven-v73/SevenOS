#!/usr/bin/env python3
import argparse
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


def resolve_root():
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()

    script_dir = Path(__file__).resolve().parent
    candidate = script_dir.parent
    if Path(candidate, "install.sh").is_file():
        return candidate

    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if Path(path, "install.sh").is_file():
            return path

    print("seven: could not find SevenOS repository root", file=sys.stderr)
    sys.exit(1)


ROOT_DIR = resolve_root()


def is_dry_run(args):
    return args.dry_run or os.environ.get("SEVENOS_DRY_RUN") == "1"


def run(command, args):
    if is_dry_run(args):
        print(" ".join(shlex.quote(str(part)) for part in command))
        return
    subprocess.run(command, check=True)


def install_target(target, args, extra=None):
    extra = extra or []
    run([str(ROOT_DIR / "install.sh"), target, *extra], args)


def sevenpkg(args, *extra):
    run([str(ROOT_DIR / "bin" / "sevenpkg"), *extra], args)


def run_script(args, relative_path, *extra):
    run([str(ROOT_DIR / relative_path), *extra], args)


def capture_json(command, fallback):
    result = subprocess.run(command, cwd=ROOT_DIR, text=True, capture_output=True, check=False)
    if result.returncode != 0:
        return fallback
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return fallback


def primary_payload():
    daily = capture_json(
        [str(ROOT_DIR / "scripts" / "daily-driver.sh"), "status", "--json"],
        {"decision": "unknown", "summary": {}, "blockers": [], "warnings": [], "actions": []},
    )
    shield = capture_json(
        [str(ROOT_DIR / "security" / "shield-status.sh"), "--json"],
        {"percent": 0, "posture": "unknown", "recommendations": []},
    )
    profiles = capture_json(
        [str(ROOT_DIR / "profiles" / "profile-manager.sh"), "plan", "--json"],
        {"summary": {}, "next": []},
    )
    windows = capture_json(
        [str(ROOT_DIR / "bin" / "seven-windows-assistant"), "status", "--json"],
        {"mode": "unknown", "ready": False, "app_ready": False},
    )
    core = capture_json(
        [str(ROOT_DIR / "scripts" / "core.sh"), "health", "--json"],
        {"state": "unknown", "checks": []},
    )
    flatpak = capture_json(
        [str(ROOT_DIR / "scripts" / "flatpak.sh"), "status", "--json"],
        {"ready": False, "installed": 0, "total": 0},
    )
    server = capture_json(
        [str(ROOT_DIR / "server" / "seven-server.sh"), "status", "--json"],
        {"state": "unknown", "runtime_ready": False},
    )

    daily_summary = daily.get("summary", {}) if isinstance(daily.get("summary"), dict) else {}
    blockers = daily.get("blockers", []) or []
    profile_next = profiles.get("next", []) or []
    critical_profiles = [
        item for item in profile_next
        if item.get("priority") in ("critical", "high")
    ]
    decision = daily.get("decision", "unknown")
    if decision == "ready":
        primary_state = "ready"
    elif len(blockers) <= 1 and int(daily_summary.get("readiness", 0) or 0) >= 85:
        primary_state = "usable-with-caution"
    else:
        primary_state = "not-ready"

    next_actions = []
    for item in blockers[:4]:
        next_actions.append({
            "title": item.get("title", item.get("key", "Gate")),
            "command": item.get("command", "seven daily plan"),
            "reason": item.get("reason", "Resolve daily-driver blocker"),
            "impact": "packages" if "install" in item.get("command", "") or "improve" in item.get("command", "") else "safe",
        })
    if critical_profiles:
        next_actions.append({
            "title": "Bootstrap profile workspaces",
            "command": "seven profile bootstrap all",
            "reason": "Profiles need visible workspaces, checklists and launchers after package installation.",
            "impact": "safe",
        })
    if not flatpak.get("ready"):
        next_actions.append({
            "title": "Prepare Flatpak app delivery",
            "command": "seven flatpak setup",
            "reason": "Mainstream desktop apps should not depend only on pacman or AUR.",
            "impact": "packages",
        })

    return {
        "schema": "sevenos.primary-pc.v1",
        "decision": primary_state,
        "daily_decision": decision,
        "summary": {
            "readiness": daily_summary.get("readiness", 0),
            "shield": shield.get("percent", daily_summary.get("shield", 0)),
            "profiles_open": profiles.get("summary", {}).get("total", len(profile_next)),
            "critical_profiles": len(critical_profiles),
            "windows_mode": windows.get("mode", "unknown"),
            "windows_app_ready": bool(windows.get("app_ready", False)),
            "core_state": core.get("state", "unknown"),
            "server_state": "RUN" if server.get("runtime_ready") else server.get("state", "unknown"),
            "flatpak_ready": bool(flatpak.get("ready", False)),
            "flatpak_apps": f"{flatpak.get('installed', 0)}/{flatpak.get('total', 0)}",
        },
        "blockers": blockers,
        "warnings": daily.get("warnings", []) or [],
        "next_actions": next_actions[:8],
    }


def print_primary_human(payload):
    summary = payload.get("summary", {})
    print("SevenOS Primary PC Gate")
    print("=======================")
    print(f"Decision: {payload.get('decision', 'unknown')}")
    print(f"Daily gate: {payload.get('daily_decision', 'unknown')}")
    print(f"Readiness: {summary.get('readiness', 0)}%")
    print(f"Shield: {summary.get('shield', 0)}%")
    print(f"Profiles open: {summary.get('profiles_open', 0)} ({summary.get('critical_profiles', 0)} critical/high)")
    print(f"Windows Mode: {summary.get('windows_mode', 'unknown')} (app-ready: {summary.get('windows_app_ready', False)})")
    print(f"Core: {summary.get('core_state', 'unknown')}")
    print(f"Server: {summary.get('server_state', 'unknown')}")
    print(f"Flatpak: {'ready' if summary.get('flatpak_ready') else 'not ready'} ({summary.get('flatpak_apps', '0/0')})")
    print()
    actions = payload.get("next_actions", [])
    if actions:
        print("Next actions:")
        for item in actions:
            print(f"- {item.get('title')}: {item.get('command')}")
            print(f"  {item.get('reason')}")
    else:
        print("Next actions: none")


def handle_profile(args):
    extra = [args.name, *args.extra]
    if args.json:
        extra.append("--json")
    run_script(args, "profiles/profile-manager.sh", *extra)


def handle_shield(args):
    shield_json = args.json or "--json" in args.extra or "json" in args.extra
    shield_extra = [item for item in args.extra if item not in ("--json", "json")]
    if args.action in ("dashboard", "open", "labs", "tools", "scope", "report"):
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-control.sh", args.action, *extra, *shield_extra)
    elif args.action in ("mode", "workspaces", "context", "layout", "hud"):
        extra = ["--json"] if shield_json else []
        run_script(args, "security/cyberspace.sh", args.action, *extra, *shield_extra)
    elif args.action in ("status", "plan"):
        shield_action = ["plan"] if args.action == "plan" else []
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-status.sh", *shield_action, *extra, *shield_extra)
    elif args.action in ("bootstrap", "workspace"):
        workspace_action = "bootstrap" if args.action == "bootstrap" else "status"
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-workspace.sh", workspace_action, *extra, *shield_extra)
    elif args.action == "enable":
        install_target("security", args)
    elif args.action == "audit":
        install_target("cyber-audit", args)
    elif args.action == "lab":
        install_target("cyber-lab", args, shield_extra)
    else:
        print(f"seven: unknown shield action: {args.action}", file=sys.stderr)
        sys.exit(1)


def handle_vm(args):
    if args.action == "check":
        install_target("vm-check", args)
    elif args.action == "network":
        install_target("vm-network", args)
    elif args.action == "start" and args.name == "windows":
        run(["virsh", "-c", "qemu:///system", "start", "sevenos-windows"], args)
    elif args.action == "console" and args.name == "windows":
        run(["virt-manager", "--connect", "qemu:///system", "--show-domain-console", "sevenos-windows"], args)
    else:
        print("seven: supported VM actions are check, network, start windows, console windows", file=sys.stderr)
        sys.exit(1)


