def handle_primary(args):
    if args.action == "apply":
        run_script(args, "scripts/daily-driver.sh", "apply", "--yes")
        return
    payload = primary_payload()
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        print_primary_human(payload)


