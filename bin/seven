        extra.append("--json")
    run_script(args, "profiles/profile-manager.sh", *extra)


def handle_mini_os(args):
    extra = [args.action, *args.items]
    if args.json:
        extra.append("--json")
    if args.yes:
        extra.append("--yes")
    run_script(args, "scripts/mini-os-bridge.sh", *extra)


def handle_bridge(args):
    extra = [args.action, *args.items]
    if args.source:
        extra.extend(["--from", args.source])
    if args.target:
        extra.extend(["--to", args.target])
    if args.profile:
        extra.extend(["--profile", args.profile])
    if args.kind:
        extra.extend(["--kind", args.kind])
    if args.title:
        extra.extend(["--title", args.title])
    if args.rights:
        extra.extend(["--rights", args.rights])
    if args.limit is not None:
        extra.extend(["--limit", str(args.limit)])
    for flag_name, flag_value in (
        ("--app", getattr(args, "app", None)),
        ("--path", getattr(args, "path", None)),
        ("--task", getattr(args, "task", None)),
        ("--mood", getattr(args, "mood", None)),
        ("--pin", getattr(args, "pin", None)),
    ):
        if flag_value:
            extra.extend([flag_name, flag_value])
    if getattr(args, "apply", False):
        extra.append("--apply")
    if args.json:
        extra.append("--json")
    run_script(args, "scripts/mini-os-relay.sh", *extra)


