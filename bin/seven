    args = parser.parse_args()

    if args.command == "update":
        handle_update(args)
    elif args.command == "upgrade":
        args.action = "install"
        handle_update(args)
    elif args.command == "recovery":
        handle_recovery(args)
    elif args.command == "health":
        handle_health(args)
    elif args.command == "smoke":
        handle_smoke(args)
    elif args.command == "support":
        handle_support(args)
    elif args.command == "pre-push":
        if args.action == "full":
            run_script(args, "scripts/check.sh")
        else:
            run_script(args, "scripts/pre-push-fast.sh")
    elif args.command == "welcome":
        handle_welcome(args)
    elif args.command == "dashboard":
        run_script(args, "seven-hub/bin/seven-control-center", "open")
    elif args.command == "architecture":
        handle_architecture(args)
    elif args.command == "ecosystem":
        handle_ecosystem(args)
    elif args.command == "ai":
        handle_ai(args)
    elif args.command == "store":
        handle_store(args)
    elif args.command == "box":
        handle_box(args)
    elif args.command == "cloud":
        handle_cloud(args)
    elif args.command == "flow":
        handle_flow(args)
    elif args.command == "cluster":
        handle_cluster(args)
    elif args.command == "stack":
        handle_stack(args)
    elif args.command == "shell":
        handle_shell(args)
    elif args.command == "core":
        handle_core(args)
    elif args.command == "scheduler":
        handle_scheduler(args)
    elif args.command == "runtime":
        handle_runtime(args)
    elif args.command == "profile-rootfs":
        handle_profile_rootfs(args)
    elif args.command == "mini-os":
        handle_mini_os(args)
    elif args.command == "mini-doctor":
        extra = [args.profile, args.action]
        if args.json:
            extra.append("--json")
        if args.dry_run:
            extra.append("--dry-run")
        run_script(args, "bin/seven-mini-doctor", *extra)
    elif args.command == "mini-boundaries":
        if args.open:
            run_script(args, "bin/seven-mini-boundaries-native")
        else:
            extra = ["--json"] if args.json else []
            run_script(args, "bin/seven-mini-boundaries", *extra)
    elif args.command == "bridge":
        handle_bridge(args)
    elif args.command == "baobab":
        handle_baobab(args)
    elif args.command == "window":
        handle_window(args)
    elif args.command == "context":
        handle_context(args)
    elif args.command == "adaptive":
        handle_adaptive(args)
    elif args.command == "dynamic":
        handle_dynamic(args)
    elif args.command == "identity":
        handle_identity(args)
    elif args.command == "theme":
        handle_theme(args)
    elif args.command == "hypr":
        handle_hypr(args)
    elif args.command == "motion":
        handle_motion(args)
    elif args.command == "experience":
        handle_experience(args)
    elif args.command in ("quality", "public-experience"):
        handle_quality(args)
    elif args.command == "control":
        handle_control(args)
    elif args.command == "events":
        handle_events(args)
    elif args.command == "insights":
        handle_insights(args)
    elif args.command == "manifest":
        handle_manifest(args)
    elif args.command == "migrate":
        handle_migrate(args)
    elif args.command == "migrate-ml4w":
        handle_migrate_ml4w(args)
    elif args.command == "keyboard":
        handle_keyboard(args)
    elif args.command == "fonts":
        handle_fonts(args)
    elif args.command == "network":
        handle_network(args)
    elif args.command == "system-profile":
        handle_system_profile(args)
    elif args.command == "boot-splash":
        run_script(args, "scripts/boot-splash.sh", args.action, *args.extra)
    elif args.command == "login-theme":
        run_script(args, "scripts/login-theme.sh", args.action, *args.extra)
    elif args.command == "language":
        handle_language(args)
    elif args.command == "phase-gate":
        handle_phase_gate(args)
    elif args.command == "b3":
        handle_b3(args)
    elif args.command == "daily":
        handle_daily(args)
    elif args.command == "primary":
        handle_primary(args)
    elif args.command == "setup":
        handle_setup(args)
    elif args.command == "new":
        handle_new(args)
    elif args.command == "actions":
        handle_actions(args)
    elif args.command == "spotlight":
        handle_spotlight(args)
    elif args.command == "launchpad":
        handle_launchpad(args)
    elif args.command in ("software", "pkg"):
        sevenpkg(args, *args.extra)
    elif args.command == "post-install":
        install_target("post-install", args)
    elif args.command == "readiness":
        extra = []
        if args.json:
            extra.append("--json")
        if args.record:
            extra.append("--record")
        run_script(args, "scripts/readiness.sh", *extra)
    elif args.command == "improve":
        extra = [args.criterion]
        if args.apply:
            extra.append("--apply")
        if args.yes:
            extra.append("--yes")
        run_script(args, "scripts/improve.sh", *extra)
    elif args.command == "repair":
        handle_repair(args)
    elif args.command == "release":
        handle_release(args)
    elif args.command == "channel":
        handle_channel(args)
    elif args.command == "autonomy":
        handle_autonomy(args)
    elif args.command == "platform":
        handle_platform(args)
    elif args.command == "mask":
        handle_mask(args)
    elif args.command == "surfaces":
        handle_surfaces(args)
    elif args.command == "routes":
        handle_routes(args)
    elif args.command in ("distribution", "distro"):
        handle_distribution(args)
    elif args.command == "about":
        handle_about(args)
    elif args.command == "lifecycle":
        handle_lifecycle(args)
    elif args.command == "product":
        handle_product(args)
    elif args.command in ("foundations", "foundation"):
        handle_foundations(args)
    elif args.command == "doctor":
        if args.action in ("fix", "repair"):
            handle_repair(args)
        elif args.action in ("open", "dashboard"):
            run_script(args, "bin/seven-doctor-native")
        elif args.action in ("release", "release-freeze"):
            extra = ["release"]
            if args.json:
                extra.append("--json")
            run_script(args, "scripts/doctor.sh", *extra)
        elif args.action == "check":
            extra = [args.area]
            if args.json:
                extra.append("--json")
            run_script(args, "scripts/doctor.sh", *extra)
        else:
            print("seven: supported doctor actions are check, open, fix and release", file=sys.stderr)
            sys.exit(1)
    elif args.command == "status":
        extra = ["--json"] if args.json else []
        if args.json:
            run_script(args, "scripts/status.sh", *extra)
        else:
            install_target("status", args, extra)
    elif args.command == "state":
        extra = ["--json"] if args.json else []
        run_script(args, "scripts/state.sh", *extra)
    elif args.command == "session":
        handle_session(args)
    elif args.command == "hub":
        handle_hub(args)
    elif args.command == "home":
        handle_home(args)
    elif args.command == "files":
        run_script(args, "bin/seven-files", *args.extra)
    elif args.command == "reader":
        extra = ["--json", *args.extra] if args.json else args.extra
        run_script(args, "bin/seven-reader", *extra)
    elif args.command == "recorder":
        run_script(args, "bin/seven-recorder", args.action)
    elif args.command == "profile":
        handle_profile(args)
    elif args.command == "shield":
        handle_shield(args)
    elif args.command == "vm":
        handle_vm(args)
    elif args.command == "atlas":
        handle_atlas(args)
    elif args.command == "pulse":
        extra = [args.action]
        if args.json:
            extra.append("--json")
        if args.dry_run:
            extra.append("--dry-run")
        run_script(args, "bin/seven-pulse", *extra)
    elif args.command == "run":
        handle_run(args)
    elif args.command == "server":
        handle_server(args)
    elif args.command == "installer":
        handle_installer(args)
    elif args.command == "hub-gui":
        handle_hub_gui(args)
    elif args.command == "hub-native":
        handle_hub_native(args)
    elif args.command == "settings":
        handle_settings(args)
    elif args.command == "flatpak":
        handle_flatpak(args)
    elif args.command == "deploy":
        handle_deploy(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
