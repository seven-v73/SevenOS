def handle_experience(args):
    json_requested = args.json or "--json" in args.extra
    extra_args = [item for item in args.extra if item != "--json"]
    if args.action in {"status", "apply", "doctor", "launch", "focus", "workspace", "notify", "warmup", "events", "recommend", "score", "json"}:
        extra = [args.action, *extra_args]
        if json_requested and args.action in {"status", "json"}:
            extra = ["status", "--json"]
        elif json_requested:
            extra.append("--json")
        run_script(args, "scripts/shell-experience.sh", *extra)
        return
    extra = ["--json"] if json_requested else []
    run_script(args, "scripts/experience.sh", *extra)


