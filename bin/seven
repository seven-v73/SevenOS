def main():
    dry_run_requested = "--dry-run" in sys.argv[1:]
    if dry_run_requested:
        sys.argv = [sys.argv[0], *[arg for arg in sys.argv[1:] if arg != "--dry-run"]]

    parser = argparse.ArgumentParser(prog="seven", description="SevenOS system controller")
    parser.add_argument("--dry-run", action="store_true", default=dry_run_requested, help="show commands without changing the system")
    subparsers = parser.add_subparsers(dest="command")

    subparsers.add_parser("update", help="update SevenOS packages")
    welcome_parser = subparsers.add_parser("welcome", help="show SevenOS onboarding overview")
    welcome_parser.add_argument("action", nargs="?", default="show", choices=("show", "status", "plan"))
    welcome_parser.add_argument("--json", action="store_true", help="print machine-readable first-run status or plan")
    subparsers.add_parser("dashboard", help="show SevenOS dashboard")
    architecture_parser = subparsers.add_parser("architecture", help="show or validate SevenOS architecture")
    architecture_parser.add_argument("action", nargs="?", default="map")
    architecture_parser.add_argument("--json", action="store_true", help="print machine-readable architecture status")
    ecosystem_parser = subparsers.add_parser("ecosystem", help="show SevenOS ecosystem modules and roadmap")
    ecosystem_parser.add_argument("action", nargs="?", default="status")
    ecosystem_parser.add_argument("--json", action="store_true", help="print machine-readable ecosystem map")
    ai_parser = subparsers.add_parser("ai", help="ask SevenAI or show local system guidance")
    ai_parser.add_argument("action", nargs="?", default="brief")
    ai_parser.add_argument("extra", nargs=argparse.REMAINDER)
    ai_parser.add_argument("--json", action="store_true", help="print machine-readable SevenAI local payload")
    ai_parser.add_argument("--apply", action="store_true", help="allow SevenAI to execute system actions that require confirmation")
    ai_parser.add_argument("--yes", action="store_true", help="run non-interactively where supported")
    ai_parser.add_argument("--web", action="store_true", help="allow SevenAI web lookup for this request")
    store_parser = subparsers.add_parser("store", help="browse SevenStore modules, apps and actions")
    store_parser.add_argument("action", nargs="?", default="status", choices=("status", "modules", "catalog", "apps", "actions", "doctor", "install", "json"))
    store_parser.add_argument("--json", action="store_true", help="print machine-readable SevenStore catalog")
    store_parser.add_argument("extra", nargs=argparse.REMAINDER)
    box_parser = subparsers.add_parser("box", help="inspect SevenBox sandbox and container readiness")
    box_parser.add_argument("action", nargs="?", default="status", choices=("status", "profiles", "doctor", "json"))
    box_parser.add_argument("--json", action="store_true", help="print machine-readable SevenBox status")
    cloud_parser = subparsers.add_parser("cloud", help="inspect SevenCloud backup and restore readiness")
    cloud_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "doctor", "json"))
    cloud_parser.add_argument("--json", action="store_true", help="print machine-readable SevenCloud plan")
    flow_parser = subparsers.add_parser("flow", help="inspect SevenFlow automation recipes")
    flow_parser.add_argument("action", nargs="?", default="status", choices=("status", "recipes", "plan", "doctor", "json"))
    flow_parser.add_argument("--json", action="store_true", help="print machine-readable SevenFlow recipes")
    cluster_parser = subparsers.add_parser("cluster", help="inspect SevenCluster private multi-machine readiness")
    cluster_parser.add_argument("action", nargs="?", default="status", choices=("status", "nodes", "plan", "doctor", "json"))
    cluster_parser.add_argument("--json", action="store_true", help="print machine-readable SevenCluster status")
    stack_parser = subparsers.add_parser("stack", help="show SevenOS technology stack strategy")
    stack_parser.add_argument("action", nargs="?", default="status")
    stack_parser.add_argument("--json", action="store_true", help="print machine-readable stack strategy")
    shell_parser = subparsers.add_parser("shell", help="inspect Seven Shell AGS foundation")
    shell_parser.add_argument("action", nargs="?", default="status")
    shell_parser.add_argument("--json", action="store_true", help="print machine-readable shell status or plan")
    shell_parser.add_argument("extra", nargs=argparse.REMAINDER)
    core_parser = subparsers.add_parser("core", help="inspect Seven Core and SevenBus foundation")
    core_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "doctor", "bus", "schema", "snapshot", "health", "profiles", "observe", "install-service", "install-observer", "start", "start-observer", "stop", "stop-observer", "logs", "observer-logs"))
    core_parser.add_argument("--json", action="store_true", help="print machine-readable core status, health, plan or bus schema")
    scheduler_parser = subparsers.add_parser("scheduler", help="inspect SevenOS process and thread orchestration")
    scheduler_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "apply"))
    scheduler_parser.add_argument("--json", action="store_true", help="print machine-readable scheduler state or plan")
    scheduler_parser.add_argument("--apply", action="store_true", help="apply safe user-space scheduler hints")
    scheduler_parser.add_argument("--yes", action="store_true", help="run non-interactively where supported")
    context_parser = subparsers.add_parser("context", help="inspect SevenOS semantic user context")
    context_parser.add_argument("action", nargs="?", default="status", choices=("status", "graph", "plan", "emit"))
    context_parser.add_argument("--json", action="store_true", help="print machine-readable context engine state")
    adaptive_parser = subparsers.add_parser("adaptive", help="inspect SevenOS adaptive profile-aware UI")
    adaptive_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "doctor", "json"))
    adaptive_parser.add_argument("--json", action="store_true", help="print machine-readable adaptive UI contract")
    identity_parser = subparsers.add_parser("identity", help="show SevenOS visual identity language")
    identity_parser.add_argument("action", nargs="?", default="status")
    identity_parser.add_argument("--json", action="store_true", help="print machine-readable identity contract")
    identity_parser.add_argument("extra", nargs=argparse.REMAINDER)
    experience_parser = subparsers.add_parser("experience", help="audit whether SevenOS feels like a coherent OS")
    experience_parser.add_argument("--json", action="store_true", help="print machine-readable experience audit")
    control_parser = subparsers.add_parser("control", help="show prioritized SevenOS control plane actions")
    control_parser.add_argument("action", nargs="?", default="plan", choices=("plan", "apply"))
    control_parser.add_argument("--json", action="store_true", help="print machine-readable control plane")
    control_parser.add_argument("--apply", action="store_true", help="execute prioritized actions instead of previewing them")
    control_parser.add_argument("--yes", action="store_true", help="run supported package installs non-interactively")
    control_parser.add_argument("--safe-only", action="store_true", help="only include actions marked safe")
    control_parser.add_argument("--limit", type=int, help="maximum actions to preview or execute")
    events_parser = subparsers.add_parser("events", help="show SevenOS local event journal")
    events_parser.add_argument("action", nargs="?", default="list", choices=("list", "summary-json"))
    events_parser.add_argument("--json", action="store_true", help="print machine-readable events")
    events_parser.add_argument("--limit", type=int, help="maximum events to show")
    insights_parser = subparsers.add_parser("insights", help="show product-facing SevenOS health insights")
    insights_parser.add_argument("--json", action="store_true", help="print machine-readable insights")
    insights_parser.add_argument("--limit", type=int, help="maximum insights to show")
    manifest_parser = subparsers.add_parser("manifest", help="inspect SevenOS install, restore and packaging manifest")
    manifest_parser.add_argument("action", nargs="?", default="show")
    migrate_parser = subparsers.add_parser("migrate", help="plan or back up protected SevenOS user state before upgrades")
    migrate_parser.add_argument("action", nargs="?", default="plan")
    migrate_ml4w_parser = subparsers.add_parser("migrate-ml4w", help="quarantine ML4W configs and switch fully to SevenOS")
    migrate_ml4w_parser.add_argument("action", nargs="?", default="plan", choices=("plan", "backup", "remove", "switch"))
    keyboard_parser = subparsers.add_parser("keyboard", help="inspect or apply SevenOS keyboard layouts")
    keyboard_parser.add_argument("action", nargs="?", default="status", choices=("status", "apply"))
    keyboard_parser.add_argument("--json", action="store_true", help="print machine-readable keyboard state")
    fonts_parser = subparsers.add_parser("fonts", help="inspect, import and apply SevenOS font roles")
    fonts_parser.add_argument("action", nargs="?", default="status")
    fonts_parser.add_argument("extra", nargs=argparse.REMAINDER)
    language_parser = subparsers.add_parser("language", help="inspect and apply SevenOS user language")
    language_parser.add_argument("action", nargs="?", default="status", choices=("status", "list", "set", "ensure", "menu"))
    language_parser.add_argument("locale", nargs="?")
    language_parser.add_argument("--json", action="store_true", help="print machine-readable language state")
    phase_gate_parser = subparsers.add_parser("phase-gate", help="run consolidation checks before moving to the next phase")
    phase_gate_parser.add_argument("--json", action="store_true", help="print machine-readable phase decision")
    b3_parser = subparsers.add_parser("b3", help="orchestrate B2 to B3 consolidation")
    b3_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "apply", "doctor"))
    b3_parser.add_argument("--json", action="store_true", help="print machine-readable B3 consolidation plan")
    b3_parser.add_argument("--apply", action="store_true", help="execute B3 consolidation actions")
    b3_parser.add_argument("--yes", action="store_true", help="run supported installs non-interactively")
    b3_parser.add_argument("--phase", choices=("all", "trust", "backend", "profiles", "shell", "installer"), help="filter B3 actions by phase")
    b3_parser.add_argument("--limit", type=int, help="maximum actions to preview or execute")
    daily_parser = subparsers.add_parser("daily", help="check or apply daily-driver consolidation")
    daily_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "apply"))
    daily_parser.add_argument("--json", action="store_true", help="print machine-readable daily-driver gate")
    daily_parser.add_argument("--apply", action="store_true", help="execute daily-driver consolidation")
    daily_parser.add_argument("--yes", action="store_true", help="run supported installs non-interactively")
    primary_parser = subparsers.add_parser("primary", help="inspect or apply SevenOS primary-PC readiness")
    primary_parser.add_argument("action", nargs="?", default="status", choices=("status", "plan", "doctor", "apply"))
    primary_parser.add_argument("--json", action="store_true", help="print machine-readable primary-PC gate")
    actions_parser = subparsers.add_parser("actions", help="show or run SevenOS registered UI/system actions")
    actions_parser.add_argument("action", nargs="?", default="list")
    actions_parser.add_argument("--json", action="store_true", help="print machine-readable action registry")
    actions_parser.add_argument("extra", nargs=argparse.REMAINDER)
    subparsers.add_parser("post-install", help="check common post-install blockers")
    readiness_parser = subparsers.add_parser("readiness", help="score SevenOS against OS choice criteria")
    readiness_parser.add_argument("--json", action="store_true", help="print machine-readable score output")
    readiness_parser.add_argument("--record", action="store_true", help="append the score to the local readiness history")
    improve_parser = subparsers.add_parser("improve", help="show or apply improvements by OS choice criterion")
    improve_parser.add_argument("criterion", nargs="?", default="all")
    improve_parser.add_argument("--apply", action="store_true", help="execute the improvement plan")
    improve_parser.add_argument("--yes", action="store_true", help="run supported installs non-interactively")

    repair_parser = subparsers.add_parser("repair", help="show or apply guided repair plans")
    repair_parser.add_argument("area", nargs="?", default="all")
    repair_parser.add_argument("--apply", action="store_true", help="execute the repair plan")
    repair_parser.add_argument("--yes", action="store_true", help="run supported installs non-interactively")

    doctor_parser = subparsers.add_parser("doctor", help="check host readiness")
    doctor_parser.add_argument("action", nargs="?", default="check")
    doctor_parser.add_argument("area", nargs="?", default="all")
    doctor_parser.add_argument("--apply", action="store_true", help="execute repair plan when using 'fix'")
    doctor_parser.add_argument("--yes", action="store_true", help="run supported installs non-interactively")
    status_parser = subparsers.add_parser("status", help="show SevenOS status")
    status_parser.add_argument("--json", action="store_true", help="print machine-readable system status")
    state_parser = subparsers.add_parser("state", help="show unified SevenOS machine state")
    state_parser.add_argument("--json", action="store_true", help="print machine-readable unified state")
    session_parser = subparsers.add_parser("session", help="inspect or start the SevenOS desktop session")
    session_parser.add_argument("action", nargs="?", default="status", choices=("status", "start", "restart"))
    session_parser.add_argument("--json", action="store_true", help="print machine-readable session status")
    hub_parser = subparsers.add_parser("hub", help="launch or inspect Seven Hub")
    hub_parser.add_argument("action", nargs="?", default="open", choices=("open", "status", "plan", "doctor", "json"))
    hub_parser.add_argument("--json", action="store_true", help="print machine-readable Hub readiness")
    files_parser = subparsers.add_parser("files", help="open Seven Files")
    files_parser.add_argument("extra", nargs=argparse.REMAINDER)
    recorder_parser = subparsers.add_parser("recorder", help="record the screen with SevenOS Recorder")
    recorder_parser.add_argument("action", nargs="?", default="area", choices=("area", "full", "stop", "status", "path", "help"))

    profile_parser = subparsers.add_parser("profile", help="list, inspect, activate, or install a SevenOS profile")
    profile_parser.add_argument("name")
    profile_parser.add_argument("--json", action="store_true", help="print machine-readable profile status for list/status")
    profile_parser.add_argument("extra", nargs=argparse.REMAINDER)

    shield_parser = subparsers.add_parser("shield", help="security and cyber controls")
    shield_parser.add_argument("action", choices=("dashboard", "status", "plan", "enable", "audit", "lab", "bootstrap", "workspace", "open", "labs", "tools", "scope", "report", "mode", "workspaces", "context", "layout", "hud"), nargs="?", default="dashboard")
    shield_parser.add_argument("--json", action="store_true", help="print machine-readable Shield posture or plan")
    shield_parser.add_argument("extra", nargs=argparse.REMAINDER)

    vm_parser = subparsers.add_parser("vm", help="virtual machine controls")
    vm_parser.add_argument("action")
    vm_parser.add_argument("name", nargs="?")

    windows_parser = subparsers.add_parser("windows", help="guided Windows Mode controls")
    windows_parser.add_argument("action", nargs="?", default="status")
    windows_parser.add_argument("extra", nargs=argparse.REMAINDER)

    run_parser = subparsers.add_parser("run", help="run an app through the SevenOS compatibility resolver")
    run_parser.add_argument("target", help="app name or Windows executable path")
    run_parser.add_argument("extra", nargs=argparse.REMAINDER)

    server_parser = subparsers.add_parser("server", help="SevenOS local server and API controls")
    server_parser.add_argument("action", nargs="?", default="status")
    server_parser.add_argument("extra", nargs=argparse.REMAINDER)

    installer_parser = subparsers.add_parser("installer", help="SevenOS installer stack controls")
    installer_parser.add_argument("action", nargs="?", default="status")
    installer_parser.add_argument("--json", action="store_true", help="print machine-readable installer status or plan")
    installer_parser.add_argument("extra", nargs=argparse.REMAINDER)

    hub_gui_parser = subparsers.add_parser("hub-gui", help="Seven Hub native GUI stack controls")
    hub_gui_parser.add_argument("action", nargs="?", default="status")
    hub_native_parser = subparsers.add_parser("hub-native", help="open or inspect the native Seven Hub prototype")
    hub_native_parser.add_argument("action", nargs="?", default="open", choices=("open", "status", "doctor"))
    hub_native_parser.add_argument("--dry-run", dest="dry_run_native", action="store_true", help="show native Hub launch command")

    settings_parser = subparsers.add_parser("settings", help="open native SevenOS Settings")
    settings_parser.add_argument("page", nargs="?", help="open a specific settings page")
    settings_parser.add_argument("--probe", action="store_true", help="check whether the native settings stack is available")

    flatpak_parser = subparsers.add_parser("flatpak", help="SevenOS Flatpak bridge controls")
    flatpak_parser.add_argument("action", nargs="?", default="status")
    flatpak_parser.add_argument("extra", nargs=argparse.REMAINDER)

    deploy_parser = subparsers.add_parser("deploy", help="detect and prepare project deployments")
    deploy_parser.add_argument("action", nargs="?", default="plan")
    deploy_parser.add_argument("extra", nargs=argparse.REMAINDER)

    args = parser.parse_args()

    if args.command == "update":
        sevenpkg(args, "update")
    elif args.command == "welcome":
        handle_welcome(args)
    elif args.command == "dashboard":
        run_script(args, "seven-hub/bin/seven-control-center", "open")
    elif args.command == "architecture":
        handle_architecture(args)
    elif args.command == "ecosystem":
        handle_ecosystem(args)
    elif args.command == "ai":
        handle_ai(args)
    elif args.command == "store":
        handle_store(args)
    elif args.command == "box":
        handle_box(args)
    elif args.command == "cloud":
        handle_cloud(args)
    elif args.command == "flow":
        handle_flow(args)
    elif args.command == "cluster":
        handle_cluster(args)
    elif args.command == "stack":
        handle_stack(args)
    elif args.command == "shell":
        handle_shell(args)
    elif args.command == "core":
        handle_core(args)
    elif args.command == "scheduler":
        handle_scheduler(args)
    elif args.command == "context":
        handle_context(args)
    elif args.command == "adaptive":
        handle_adaptive(args)
    elif args.command == "identity":
        handle_identity(args)
    elif args.command == "experience":
        handle_experience(args)
    elif args.command == "control":
        handle_control(args)
    elif args.command == "events":
        handle_events(args)
    elif args.command == "insights":
        handle_insights(args)
    elif args.command == "manifest":
        handle_manifest(args)
    elif args.command == "migrate":
        handle_migrate(args)
    elif args.command == "migrate-ml4w":
        handle_migrate_ml4w(args)
    elif args.command == "keyboard":
        handle_keyboard(args)
    elif args.command == "fonts":
        handle_fonts(args)
    elif args.command == "language":
        handle_language(args)
    elif args.command == "phase-gate":
        handle_phase_gate(args)
    elif args.command == "b3":
        handle_b3(args)
    elif args.command == "daily":
        handle_daily(args)
    elif args.command == "primary":
        handle_primary(args)
    elif args.command == "actions":
        handle_actions(args)
    elif args.command == "post-install":
        install_target("post-install", args)
    elif args.command == "readiness":
        extra = []
        if args.json:
            extra.append("--json")
        if args.record:
            extra.append("--record")
        run_script(args, "scripts/readiness.sh", *extra)
    elif args.command == "improve":
        extra = [args.criterion]
        if args.apply:
            extra.append("--apply")
        if args.yes:
            extra.append("--yes")
        run_script(args, "scripts/improve.sh", *extra)
    elif args.command == "repair":
        handle_repair(args)
    elif args.command == "doctor":
        if args.action in ("fix", "repair"):
            handle_repair(args)
        elif args.action == "check":
            install_target("doctor", args)
        else:
            print("seven: supported doctor actions are check and fix", file=sys.stderr)
            sys.exit(1)
    elif args.command == "status":
        extra = ["--json"] if args.json else []
        if args.json:
            run_script(args, "scripts/status.sh", *extra)
        else:
            install_target("status", args, extra)
    elif args.command == "state":
        extra = ["--json"] if args.json else []
        run_script(args, "scripts/state.sh", *extra)
    elif args.command == "session":
        handle_session(args)
    elif args.command == "hub":
        handle_hub(args)
    elif args.command == "files":
        run_script(args, "bin/seven-files", *args.extra)
    elif args.command == "recorder":
        run_script(args, "bin/seven-recorder", args.action)
    elif args.command == "profile":
        handle_profile(args)
    elif args.command == "shield":
        handle_shield(args)
    elif args.command == "vm":
        handle_vm(args)
    elif args.command == "windows":
        handle_windows(args)
    elif args.command == "run":
        handle_run(args)
    elif args.command == "server":
        handle_server(args)
    elif args.command == "installer":
        handle_installer(args)
    elif args.command == "hub-gui":
        handle_hub_gui(args)
    elif args.command == "hub-native":
        handle_hub_native(args)
    elif args.command == "settings":
        handle_settings(args)
    elif args.command == "flatpak":
        handle_flatpak(args)
    elif args.command == "deploy":
        handle_deploy(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
