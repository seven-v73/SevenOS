def handle_shield(args):
    shield_json = args.json or "--json" in args.extra or "json" in args.extra
    shield_extra = [item for item in args.extra if item not in ("--json", "json")]
    if args.action in ("dashboard", "open", "labs", "tools", "report"):
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-control.sh", args.action, *extra, *shield_extra)
    elif args.action == "scope":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-scope.sh", *extra, *shield_extra)
    elif args.action == "network":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-network-guard.sh", *extra, *shield_extra)
    elif args.action == "evidence":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-evidence.sh", *extra, *shield_extra)
    elif args.action == "optional-tools":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-optional-tools.sh", *extra, *shield_extra)
    elif args.action == "toolchain":
        extra = ["--json"] if shield_json else []
        if is_dry_run(args):
            run_script_with_dry_env("security/shield-toolchain.sh", *extra, *shield_extra)
        else:
            run_script(args, "security/shield-toolchain.sh", *extra, *shield_extra)
    elif args.action == "bundles":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-bundles.sh", *extra, *shield_extra)
    elif args.action == "wrappers":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-wrappers.sh", *extra, *shield_extra)
    elif args.action == "tool-doctor":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-tool-doctor.sh", *extra, *shield_extra)
    elif args.action == "performance":
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-performance.sh", *extra, *shield_extra)
    elif args.action in ("persona", "personas", "session", "cleanup"):
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-persona.sh", args.action, *extra, *shield_extra)
    elif args.action in ("mode", "workspaces", "context", "layout", "hud"):
        extra = ["--json"] if shield_json else []
        run_script(args, "security/cyberspace.sh", args.action, *extra, *shield_extra)
    elif args.action in ("status", "plan"):
        shield_action = ["plan"] if args.action == "plan" else []
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-status.sh", *shield_action, *extra, *shield_extra)
    elif args.action in ("bootstrap", "workspace"):
        workspace_action = "bootstrap" if args.action == "bootstrap" else "status"
        extra = ["--json"] if shield_json else []
        run_script(args, "security/shield-workspace.sh", workspace_action, *extra, *shield_extra)
    elif args.action == "enable":
        install_target("security", args)
    elif args.action == "audit":
        install_target("cyber-audit", args)
    elif args.action == "lab":
        install_target("cyber-lab", args, shield_extra)
    else:
        print(f"seven: unknown shield action: {args.action}", file=sys.stderr)
        sys.exit(1)


def handle_vm(args):
    if args.action == "check":
        install_target("vm-check", args)
    elif args.action == "network":
        install_target("vm-network", args)
    elif args.action == "start" and args.name == "windows":
        print("seven: Windows VM has been retired from SevenOS. Use Atlas as the seventh mini OS and app-native alternatives instead.", file=sys.stderr)
        sys.exit(2)
    elif args.action == "console" and args.name == "windows":
        print("seven: Windows VM console is retired from SevenOS.", file=sys.stderr)
        sys.exit(2)
    else:
        print("seven: supported VM actions are check, network, start windows, console windows", file=sys.stderr)
        sys.exit(1)


def handle_atlas(args):
    if args.action in ("open", "center"):
        run_script(args, "bin/seven-mini-os-center", "atlas")
    elif args.action == "install":
        extra = []
        if getattr(args, "yes", False):
            extra.append("--yes")
        install_target("atlas", args, extra)
    elif args.action in ("status", "requirements"):
        extra = ["status", "atlas"]
        if args.json:
            extra.append("--json")
        run_script(args, "bin/seven-profile-requirements", *extra)
    elif args.action == "activate":
        run_script(args, "profiles/profile-manager.sh", "activate", "atlas")
    else:
        print(f"seven: unknown atlas action: {args.action}", file=sys.stderr)
        sys.exit(1)


def handle_run(args):
    print("seven: Windows VM app runner has been retired. Use native Linux apps, Pulse/Proton, or Bottles/Lutris from the Store when needed.", file=sys.stderr)
    sys.exit(2)


