            def render_actions() -> None:
                clear(actions_page)
                heading(
                    actions_page,
                    "System Actions",
                    "Actions come from seven actions --json, so the native Hub follows the same contract as the CLI and server.",
                )

                payload = actions_payload()
                by_category: dict[str, list[dict]] = {}
                for action in payload.get("actions", []):
                    by_category.setdefault(action.get("category", "System"), []).append(action)

                wanted = ("Desktop", "System", "Profiles", "Security", "Apps", "Atlas", "Server", "Ecosystem", "Installer")
                for category in wanted:
                    items = by_category.get(category, [])
                    if not items:
                        continue
                    group = Adw.PreferencesGroup(title=category)
                    for item in items[:6]:
                        row = make_row(
                            item.get("title", item.get("id", "Action")),
                            f"{item.get('impact', 'safe')} · {item.get('description', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name(icon_for_action(item.get("id", ""), item.get("impact", "safe")))
                        button.set_tooltip_text(f"Run {item.get('title', item.get('id', 'action'))}")
                        button.add_css_class("suggested-action" if item.get("impact") == "safe" else "destructive-action")
                        button.connect("clicked", lambda _button, action_id=item["id"]: run_registered_action(action_id))
                        row.add_suffix(button)
                        group.add(row)
                    actions_page.append(group)

            def render_ecosystem() -> None:
                clear(ecosystem_page)
                payload = ecosystem_payload()
                heading(
                    ecosystem_page,
                    "Seven Ecosystem",
                    "All-in-one process map: desktop, profiles, apps, Atlas, security, deployment and future cloud/store layers.",
                )

                modules = payload.get("modules", [])
                processes = payload.get("processes", [])
                active = sum(1 for item in modules if item.get("state") == "active")
                preview = sum(1 for item in modules if item.get("state") == "preview")
                planned = sum(1 for item in modules if item.get("state") == "planned")

                overview = Adw.PreferencesGroup(title="Ecosystem overview")
                for title_text, subtitle in (
                    ("Positioning", payload.get("positioning", "SevenOS ecosystem")),
                    ("Modules", f"{active} active · {preview} preview · {planned} planned"),
                    ("Processes", f"{len(processes)} all-in-one flows declared"),
                ):
                    overview.add(make_row(title_text, subtitle))
                ecosystem_page.append(overview)

                module_group = Adw.PreferencesGroup(title="Modules")
                for module in modules:
                    row = make_row(
                        module.get("name", "Module"),
                        f"{module.get('state', 'planned')} · phase {module.get('phase', '?')} · {module.get('purpose', '')}",
                    )
                    module_group.add(row)
                ecosystem_page.append(module_group)

                process_group = Adw.PreferencesGroup(title="Processes")
                for process in processes:
                    row = make_row(
                        process.get("name", "Process"),
                        f"{process.get('state', 'planned')} · {process.get('flow', '')} · {process.get('command', '')}",
                    )
                    button = Gtk.Button()
                    button.set_icon_name("media-playback-start-symbolic")
                    button.set_tooltip_text(f"Start {process.get('name', 'process')}")
                    button.add_css_class("suggested-action")
                    button.connect(
                        "clicked",
                        lambda _button, command=process.get("command", ""), name=process.get("name", "Process"): run_ecosystem_command(
                            command,
                            title=f"SevenOS Process - {name}",
                        ),
                    )
                    row.add_suffix(button)
                    process_group.add(row)
                ecosystem_page.append(process_group)

