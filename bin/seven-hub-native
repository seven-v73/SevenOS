                    tile_button("AI", "Seven AI", tr("hub.tile.ai_note", "local system assistant"), "seven ai focus", "good"),
                    tile_button("!", tr("hub.security", "Security"), shield.get("posture", "unknown"), "seven shield dashboard", metric_state(shield_percent)),
                    tile_button("AT", tr("hub.atlas", "Atlas"), atlas.get("state", "unknown"), "seven atlas status", "good" if not atlas.get("missing_required") else "warn"),
                    tile_button("S", tr("hub.server", "Server"), server.get("state", server.get("service", {}).get("state", "MISS")), "seven server status", "good" if str(server.get("state", "")).upper() == "RUN" else "warn"),
