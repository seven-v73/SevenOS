                for profile in profile_payload():
                    title_text = profile.get("title", profile.get("key", "Profile"))
                    state = profile.get("state", "MISS")
                    note = "active" if profile.get("active") else f"{profile.get('installed', 0)}/{profile.get('total', 0)} ready"
                    command = f"seven profile activate {profile['key']}" if state == "OK" else f"seven profile install {profile['key']}"
                    icon = title_text[:1].upper()
                    tiles.append(tile_button(icon, title_text, note, command, metric_state(100 if state == "OK" else 65 if state == "PART" else 20)))
                add_tiles(grid, tiles, 3)
                profiles_page.append(grid)

                actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
                actions.add_css_class("seven-glass-strip")
