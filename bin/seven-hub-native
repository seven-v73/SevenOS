def status_text() -> str:
    global PREFER_STATE_ONLY
    PREFER_STATE_ONLY = True
    state_payload(force=False)
    welcome = welcome_payload()
    welcome_plan = welcome_plan_payload()
    session = session_payload()
    identity = identity_payload()
    profiles = profile_payload()
    profile_gaps = profile_gaps_payload()
    profile_plan = profile_plan_payload()
    ecosystem = ecosystem_payload()
    stack = stack_payload()
    shell = shell_payload()
    core = core_payload()
    core_plan = core_plan_payload()
    experience = experience_payload()
    shield = shield_payload()
    server = server_payload()
    control = control_payload()
    events = events_payload()
    support = support_payload()
    smoke = smoke_payload()
    insights = insights_payload()
    phase_gate = phase_gate_payload()
    b3 = b3_payload()
    daily = daily_payload()
    active = next((item for item in profiles if item.get("active")), None)
    ready = sum(1 for item in profiles if item.get("state") == "OK")
    partial = sum(1 for item in profiles if item.get("state") == "PART")
    missing = sum(1 for item in profiles if item.get("state") == "MISS")
    profile_gap_count = sum(1 for item in profile_gaps.get("profiles", []) if item.get("state") != "OK")
    next_profile = (profile_plan.get("next") or [{}])[0].get("title", "none")
    active_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "active")
    preview_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "preview")
    next_stack = ", ".join(stack.get("next_focus", [])[:2]) or "Seven Shell AGS, seven-daemon Rust"
    return (
        "Seven Hub\n"
        f"Root: {ROOT}\n"
        f"First run: {welcome.get('mode', 'unknown')} · {welcome.get('percent', 0)}% · {welcome_plan.get('summary', {}).get('total', 0)} actions\n"
        f"Session: {session.get('mode', 'unknown')} · {session.get('percent', 0)}% · {session.get('summary', {}).get('running', 0)} running\n"
        f"Identity: {identity.get('positioning', 'Next generation intelligent Linux experience')}\n"
        f"Active profile: {active.get('title') if active else 'none'}\n"
        f"Profiles: {ready} OK, {partial} PART, {missing} MISS\n"
        f"Profile gaps: {profile_gap_count} incomplete modes\n"
        f"Next profile: {next_profile}\n"
        f"Ecosystem: {active_modules} active, {preview_modules} preview, {len(ecosystem.get('processes', []))} processes\n"
        f"Stack: {stack.get('phase', 'B2-B3')} · next {next_stack}\n"
        f"Shell: {shell.get('state', 'unknown')} · {len(shell.get('surfaces', []))} surfaces\n"
        f"Core: {core.get('state', 'unknown')} · {core_plan.get('summary', {}).get('total', 0)} actions\n"
        f"Experience: {experience.get('percent', 0)}% ({experience.get('score', 0)}/{experience.get('max', 0)})\n"
        f"Shield: {shield.get('posture', 'unknown')} ({shield.get('percent', 0)}%)\n"
        f"Server: {server.get('state', server.get('service', {}).get('state', 'MISS'))}\n"
        f"Control: {control.get('overall', 0)}% · {control.get('summary', {}).get('total', 0)} actions\n"
        f"Events: {events.get('total', 0)} recorded\n"
        f"Smoke: {smoke.get('state', 'unknown')} · {smoke.get('score', 0)}%\n"
        f"Support: {support.get('state', 'unknown')} · {support.get('score', 0)}%\n"
        f"Insights: phase {insights.get('phase', 'unknown')} · {insights.get('summary', {}).get('total', 0)} open items\n"
        f"Phase gate: {phase_gate.get('decision', 'unknown')} · {phase_gate.get('summary', {}).get('block', 0)} blockers\n"
        f"B3: {b3.get('overall', 0)}% · {b3.get('summary', {}).get('total', 0)} actions · {b3.get('state', 'blocked')}\n"
        f"Daily: {daily.get('decision', 'unknown')} · {len(daily.get('blockers', []))} blockers · Shield {daily.get('summary', {}).get('shield', 0)}%\n"
    )


def run_profile_action(action: str, key: str) -> None:
    run_visible(str(ROOT / "bin" / "seven"), "profile", action, key, title=f"SevenOS Profile - {key}")


def run_registered_action(action_id: str) -> None:
    run_visible(str(ROOT / "bin" / "seven"), "actions", "run", action_id, title=f"SevenOS Action - {action_id}")


def run_ecosystem_command(command: str, title: str = "SevenOS Process") -> None:
    try:
        parts = shlex.split(command)
    except ValueError:
        run_visible("bash", "-lc", command, title=title)
        return

    if not parts:
        return
    if parts[0] == "seven":
        parts[0] = str(ROOT / "bin" / "seven")
    elif parts[0] == "sevenpkg":
        parts[0] = str(ROOT / "bin" / "sevenpkg")
    elif parts[0] == "seven-hub-native":
        parts[0] = str(ROOT / "bin" / "seven-hub-native")
    elif parts[0] == "seven-settings":
        parts[0] = str(ROOT / "bin" / "seven-settings")

    run_visible(*parts, title=title)


def icon_for_action(action_id: str, impact: str = "safe") -> str:
    if action_id.startswith("profile."):
        return "avatar-default-symbolic"
    if action_id.startswith("security."):
        return "security-high-symbolic"
    if action_id.startswith("atlas."):
        return "folder-documents-symbolic"
    if action_id.startswith("server.") or action_id.startswith("deploy."):
        return "network-server-symbolic"
    if action_id.startswith("installer."):
        return "drive-harddisk-symbolic"
    if action_id.startswith("flatpak.") or action_id.startswith("sevenpkg.") or action_id.startswith("apps."):
        return "application-x-executable-symbolic"
    if action_id.startswith("files."):
        return "seven-files"
    if action_id.startswith("identity."):
        return "seven-hub"
    if action_id.startswith("settings."):
        return "seven-settings"
    if impact != "safe":
        return "emblem-system-symbolic"
    return "system-run-symbolic"


def run_gui() -> int:
    global PREFER_STATE_ONLY
    PREFER_STATE_ONLY = True

    try:
        import gi

        gi.require_version("Gtk", "4.0")
        gi.require_version("Adw", "1")
        from gi.repository import Adw, Gdk, Gio, GLib, Gtk
    except Exception as error:
        print("seven-hub-native: GTK4/libadwaita is not available yet.", file=sys.stderr)
        print("Install the GUI stack with: seven hub-gui install", file=sys.stderr)
        print(f"Details: {error}", file=sys.stderr)
        return 1

    try:
        manager = Adw.StyleManager.get_default()
        if current_theme_mode() == "light":
            manager.set_color_scheme(Adw.ColorScheme.FORCE_LIGHT)
        else:
            manager.set_color_scheme(Adw.ColorScheme.FORCE_DARK)
    except Exception:
        pass

    def install_css() -> None:
        base_css = seven_theme.gtk_app_css("hub") if seven_theme else ""
