#!/usr/bin/env python3
import argparse
import json
import os
import shlex
import subprocess
import sys
import threading
import time
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()

    script_dir = Path(__file__).resolve().parent
    candidate = script_dir.parent
    if Path(candidate, "install.sh").is_file():
        return candidate

    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if Path(path, "install.sh").is_file():
            return path

    print("seven-hub-native: could not find SevenOS root", file=sys.stderr)
    sys.exit(1)


ROOT = resolve_root()
sys.path.insert(0, str(ROOT / "scripts"))
from seven_i18n import tr  # noqa: E402
try:
    import seven_theme  # noqa: E402
except Exception:  # pragma: no cover
    seven_theme = None

STATE_CACHE: dict = {"data": None, "expires": 0.0}
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache"))) / "sevenos"
HUB_STATE_CACHE = CACHE_DIR / "hub-state.json"
PREFER_STATE_ONLY = False


def current_theme_mode() -> str:
    if seven_theme:
        return seven_theme.current_theme_mode()
    config_dir = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos"
    theme_file = config_dir / "theme.conf"
    if theme_file.exists():
        for line in theme_file.read_text(encoding="utf-8", errors="ignore").splitlines():
            key, _, value = line.partition("=")
            if key.strip().lower() in {"sevenos_theme_mode", "theme_mode", "mode"}:
                value = value.strip().strip("'\"").lower()
                if value in {"dark", "light"}:
                    return value
    if os.environ.get("SEVENOS_THEME_MODE") in {"dark", "light"}:
        return str(os.environ["SEVENOS_THEME_MODE"])
    return "dark"


def ensure_gtk_python() -> None:
    """Re-exec with the system Python when pyenv lacks GTK bindings."""
    if os.environ.get("SEVENOS_NATIVE_PYTHON") == "1":
        return

    try:
        import gi  # noqa: F401
        return
    except Exception:
        pass

    system_python = Path("/usr/bin/python3")
    if not system_python.is_file() or Path(sys.executable).resolve() == system_python.resolve():
        return

    probe = subprocess.run(
        [str(system_python), "-c", "import gi"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    if probe.returncode != 0:
        return

    env = {**os.environ, "SEVENOS_NATIVE_PYTHON": "1"}
    os.execve(str(system_python), [str(system_python), str(Path(__file__).resolve()), *sys.argv[1:]], env)


def run_text(*command: str) -> str:
    if PREFER_STATE_ONLY and not (
        len(command) >= 3
        and Path(command[0]).name == "seven"
        and command[1] == "state"
        and command[2] == "--json"
    ):
        raise RuntimeError("state-only mode: fallback command skipped")
    is_state_snapshot = len(command) >= 3 and Path(command[0]).name == "seven" and command[1] == "state" and command[2] == "--json"
    timeout = 20 if is_state_snapshot else 8
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_DRY_RUN": "0"}
    output = subprocess.check_output(command, cwd=ROOT, text=True, env=env, timeout=timeout)
    return output.strip()


def load_persistent_state() -> dict:
    try:
        data = json.loads(HUB_STATE_CACHE.read_text(encoding="utf-8"))
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def save_persistent_state(data: dict) -> None:
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        tmp = HUB_STATE_CACHE.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(data, indent=2), encoding="utf-8")
        tmp.replace(HUB_STATE_CACHE)
    except Exception:
        pass


def state_payload(force: bool = False) -> dict:
    now = time.monotonic()
    cached = STATE_CACHE.get("data")
    if not force and isinstance(cached, dict) and float(STATE_CACHE.get("expires", 0.0)) > now:
        return cached
    if not force and PREFER_STATE_ONLY:
        persistent = load_persistent_state()
        if persistent:
            persistent["_hub_cache"] = "persistent"
            STATE_CACHE["data"] = persistent
            STATE_CACHE["expires"] = now + 8.0
            return persistent
    try:
        data = json.loads(run_text(str(ROOT / "bin" / "seven"), "state", "--json"))
        if isinstance(data, dict):
            STATE_CACHE["data"] = data
            STATE_CACHE["expires"] = now + 20.0
            save_persistent_state(data)
            return data
    except Exception:
        pass
    if isinstance(cached, dict):
        return cached
    persistent = load_persistent_state()
    if persistent:
        persistent["_hub_cache"] = "persistent"
        STATE_CACHE["data"] = persistent
        STATE_CACHE["expires"] = now + 8.0
        return persistent
    fallback = {"schema": "sevenos.state.v1", "state": "unavailable"}
    STATE_CACHE["data"] = fallback
    STATE_CACHE["expires"] = now + 5.0
    return fallback


def state_value(key: str, fallback):
    data = state_payload()
    value = data.get(key)
    if isinstance(fallback, dict):
        return value if isinstance(value, dict) else fallback
    if isinstance(fallback, list):
        return value if isinstance(value, list) else fallback
    return value if value is not None else fallback


def command_exists(command: str) -> bool:
    return subprocess.run(
        ["bash", "-lc", f"command -v {shlex.quote(command)} >/dev/null 2>&1"],
        check=False,
    ).returncode == 0


def run_visible(*command: str, title: str = "SevenOS Action") -> None:
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    command_line = shlex.join(command)
    wrapped = f"cd {shlex.quote(str(ROOT))} && {command_line}; printf '\\nPress Enter to close...'; read -r"

    if os.environ.get("SEVENOS_DRY_RUN") == "1":
        print(command_line)
        return

    interactive = False
    if command:
        first = Path(str(command[0])).name
        command_text = " ".join(str(part) for part in command)
        interactive = (
            first in {"bash", "sh", "zsh", "fish", "seven-terminal"}
            or " read " in f" {command_text} "
            or "journalctl" in command_text
        )

    runner = ROOT / "bin" / "seven-action-runner"
    if runner.is_file() and os.access(runner, os.X_OK) and not interactive:
        subprocess.Popen(
            [str(runner), "--title", title, "--", *[str(part) for part in command]],
            cwd=ROOT,
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return

    if os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY"):
        if command_exists("seven-terminal"):
            subprocess.Popen(["seven-terminal", "focus", "--", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("kitty"):
            subprocess.Popen(["kitty", "--title", title, "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("foot"):
            subprocess.Popen(["foot", "-e", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("alacritty"):
            subprocess.Popen(["alacritty", "-e", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("xterm"):
            subprocess.Popen(["xterm", "-e", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return

    subprocess.Popen(["bash", "-lc", wrapped], cwd=ROOT, env=env)


def profile_payload() -> list[dict]:
    value = state_value("profiles", [])
    if value:
        return value
    if PREFER_STATE_ONLY:
        return []
    try:
        return json.loads(run_text(str(ROOT / "bin" / "seven"), "profile", "status", "--json"))
    except Exception:
        return []


def profile_ui_payload() -> dict:
    path = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "sevenos/profile-ui.json"
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


