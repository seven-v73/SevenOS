            def render_runtime_compact() -> None:
                clear(runtime_page)
                state = state_payload()
                active_manifest = state.get("profile_runtime_manifest") if isinstance(state.get("profile_runtime_manifest"), dict) else {}
                manifests = state.get("profile_runtime_manifests") if isinstance(state.get("profile_runtime_manifests"), dict) else {}
                profile_index = manifests.get("profiles", {}) if isinstance(manifests.get("profiles"), dict) else {}
                isolation = state.get("profile_run") if isinstance(state.get("profile_run"), dict) else {}
                runtime = state.get("runtime") if isinstance(state.get("runtime"), dict) else {}

                heading(
                    runtime_page,
                    "Runtime & Mini OS",
                    "Live execution boundaries, profile manifests, isolated data roots and composition state from seven state --json.",
                )

                metrics = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                metrics.add_css_class("seven-metric-row")
                metrics.append(metric_card("Active", active_manifest.get("profile", "unknown"), active_manifest.get("engine", "runtime"), "good" if active_manifest else "warn"))
                metrics.append(metric_card("Manifests", str(manifests.get("count", len(profile_index))), "mini OS contracts", "good" if profile_index else "warn"))
                metrics.append(metric_card("Container", "OK" if isolation.get("container_available") else "PART", "strict app-data", "good" if isolation.get("container_available") else "warn"))
                metrics.append(metric_card("Composition", str((runtime.get("state") or runtime.get("mode") or "active"))[:14], "LAPA runtime", "good"))
                runtime_page.append(metrics)

                active_group = Adw.PreferencesGroup(title="Active runtime manifest")
                workspace = active_manifest.get("workspace") if isinstance(active_manifest.get("workspace"), dict) else {}
                roots = active_manifest.get("roots") if isinstance(active_manifest.get("roots"), dict) else {}
                commands = active_manifest.get("commands") if isinstance(active_manifest.get("commands"), dict) else {}
                for title_text, subtitle, command in [
                    ("Profile", f"{active_manifest.get('profile', 'unknown')} · {active_manifest.get('engine', 'unknown')}", commands.get("inspect", "seven-profile-run --manifest")),
                    ("Workspace", f"{workspace.get('default', 'unknown')} · {workspace.get('policy', 'explicit')}", commands.get("workspace_shell", "seven-profile-run --container --workspace-profile sh")),
                    ("Data roots", f"home={roots.get('home', 'unknown')} · cache/data isolated", commands.get("strict_shell", "seven-profile-run --container sh")),
                    ("Ephemeral", "temporary HOME/cache/data removed on exit", commands.get("ephemeral_shell", "seven-profile-run --ephemeral sh")),
                ]:
                    row = make_row(title_text, subtitle)
                    button = Gtk.Button()
                    button.set_icon_name("media-playback-start-symbolic")
                    button.set_tooltip_text(command)
                    button.connect("clicked", lambda _button, command=command, title_text=title_text: run_ecosystem_command(command, title=f"SevenOS Runtime - {title_text}"))
                    row.add_suffix(button)
                    active_group.add(row)
                runtime_page.append(active_group)

                profiles_group = Adw.PreferencesGroup(title="Mini OS runtime contracts")
                for key, item in sorted(profile_index.items()):
                    if not isinstance(item, dict):
                        continue
                    row = make_row(
                        key.title(),
                        f"{item.get('engine', 'runtime')} · workspace {item.get('workspace', 'unknown')}",
                    )
                    for icon_name, command, tooltip in [
                        ("dialog-information-symbolic", f"seven-profile-run --profile {key} --manifest", "Manifest"),
                        ("utilities-terminal-symbolic", item.get("strict_shell") or f"seven profile exec {key} --container sh", "Strict shell"),
                        ("edit-clear-symbolic", item.get("ephemeral_shell") or f"seven profile exec {key} --ephemeral sh", "Ephemeral shell"),
                    ]:
                        button = Gtk.Button()
                        button.set_icon_name(icon_name)
                        button.set_tooltip_text(tooltip)
                        button.connect("clicked", lambda _button, command=command, tooltip=tooltip: run_ecosystem_command(command, title=f"SevenOS Runtime - {tooltip}"))
                        row.add_suffix(button)
                    profiles_group.add(row)
                runtime_page.append(profiles_group)

            def search_items() -> list[dict]:
                state = state_payload()
                items: list[dict] = []
                for action in (actions_payload().get("actions") or []):
                    if not isinstance(action, dict):
                        continue
                    items.append({
                        "kind": "Action",
                        "title": action.get("title", action.get("id", "Action")),
                        "subtitle": f"{action.get('category', 'System')} · {action.get('description', '')}",
                        "command": f"seven actions run {action.get('id')}",
                    })
                for profile in profile_payload():
                    if not isinstance(profile, dict):
                        continue
                    key = profile.get("key", "")
                    items.append({
                        "kind": "Mini OS",
                        "title": profile.get("title", key),
                        "subtitle": f"{profile.get('role', 'profile')} · {profile.get('state')} · {profile.get('workspace', '')}",
                        "command": f"seven profile center {key}",
                    })
                manifests = state.get("profile_runtime_manifests") if isinstance(state.get("profile_runtime_manifests"), dict) else {}
                for key, item in (manifests.get("profiles") or {}).items():
                    if not isinstance(item, dict):
                        continue
                    items.append({
                        "kind": "Runtime",
                        "title": f"{key.title()} runtime",
                        "subtitle": f"{item.get('engine', 'runtime')} · {item.get('workspace', 'workspace')}",
                        "command": f"seven-profile-run --profile {key} --manifest",
                    })
                for label, command in [
                    ("Wi-Fi and Bluetooth", "seven-quick-settings"),
                    ("Atlas Explorer", "seven atlas open"),
                    ("Shield scope", "seven shield scope"),
                    ("SevenStore", "seven-store"),
                    ("Seven Reader", "seven-reader"),
                    ("Updates and packages", "sevenpkg plan"),
                    ("Doctor and repair", "seven doctor"),
                    ("Graphical installer runtime", "seven installer runtime"),
                ]:
                    items.append({"kind": "Shortcut", "title": label, "subtitle": command, "command": command})
                return items

            def render_search_results(query: str = "") -> None:
                clear(search_page)
                heading(search_page, "Search SevenOS", "Find settings, mini OS, runtime contracts and safe actions without leaving Hub.")
                search = Gtk.SearchEntry()
                search.set_placeholder_text("Search Wi-Fi, Atlas, Shield, Store, runtime, updates...")
                search.set_text(query)
                search_page.append(search)
                results_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
                search_page.append(results_box)

                def update_results(text: str) -> None:
                    clear(results_box)
                    group = Adw.PreferencesGroup(title="Results")
                    normalized = text.strip().lower()
                    matches = []
                    for item in search_items():
                        haystack = " ".join(str(item.get(part, "")) for part in ("kind", "title", "subtitle", "command")).lower()
                        if not normalized or normalized in haystack:
                            matches.append(item)
                    for item in matches[:18]:
                        row = make_row(f"{item.get('kind')} · {item.get('title')}", item.get("subtitle", ""))
                        command = item.get("command", "")
                        title_text = item.get("title", "Search")
                        button = Gtk.Button()
                        button.set_icon_name("media-playback-start-symbolic")
                        button.set_tooltip_text(command)
                        button.connect("clicked", lambda _button, command=command, title_text=title_text: run_ecosystem_command(command, title=f"SevenOS Search - {title_text}"))
                        row.add_suffix(button)
                        group.add(row)
                    if not matches:
                        group.add(make_row("No result", "Try network, Atlas, Shield, profile, store, runtime or updates."))
                    results_box.append(group)

                update_results(query)
                search.connect("search-changed", lambda entry: update_results(entry.get_text()))

            def render_actions_compact() -> None:
                clear(actions_page)
                heading(actions_page, "Actions", "One tap operations for the system. Technical details stay tucked away until you ask.")
                payload = actions_payload()
                interesting = []
                preferred = {
                    "actions.open",
                    "apps.open",
                    "files.open",
                    "security.dashboard",
                    "security.audit",
                    "atlas.open",
                    "atlas.status",
                    "server.status",
                    "daily.status",
                    "doctor.run",
                    "readiness.run",
                    "installer.status",
                    "installer.runtime",
                    "flatpak.status",
                }
                for item in payload.get("actions", []):
                    if item.get("id") in preferred:
                        interesting.append(item)
                if not interesting:
                    interesting = (payload.get("actions") or [])[:12]

                grid = compact_grid()
                tiles = [
                    tile_button(
                        item.get("title", item.get("id", "Action"))[:1].upper(),
                        item.get("title", item.get("id", "Action")),
                        item.get("category", "System"),
                        f"seven actions run {item.get('id')}",
                        "good" if item.get("impact") == "safe" else "warn",
                    )
                    for item in interesting[:12]
                ]
                add_tiles(grid, tiles, 4)
                actions_page.append(grid)

            def render_ecosystem_compact() -> None:
                clear(ecosystem_page)
                payload = ecosystem_payload()
                stack = stack_payload()
                core = core_payload()
                shell = shell_payload()
                heading(ecosystem_page, "Ecosystem", "SevenOS layers as a product map.")

                modules = payload.get("modules", [])
                active = sum(1 for item in modules if item.get("state") == "active")
                preview = sum(1 for item in modules if item.get("state") == "preview")
                planned = sum(1 for item in modules if item.get("state") == "planned")
                metrics = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                metrics.add_css_class("seven-metric-row")
                metrics.append(metric_card("Active", str(active), "modules", "good"))
                metrics.append(metric_card("Preview", str(preview), "modules", "warn"))
                metrics.append(metric_card("Planned", str(planned), "modules", "warn"))
                metrics.append(metric_card("Stack", stack.get("phase", "B2-B3"), "strategy", "warn"))
                ecosystem_page.append(metrics)

                grid = compact_grid()
                tiles = [
                    tile_button("C", "Seven Core", core.get("state", "foundation"), "seven core status", "good" if core.get("state") == "ready" else "warn"),
                    tile_button("S", "Seven Shell", shell.get("state", "foundation"), "seven shell status", "warn"),
                    tile_button("P", "Profiles", "work modes", "seven profile status", "warn"),
                    tile_button("AT", "Atlas", "knowledge layer", "seven atlas status", "warn"),
                    tile_button("H", "Hub", "control center", "seven hub", "good"),
                    tile_button("D", "Deploy", "server layer", "seven server status", "warn"),
                ]
                for module in modules[:6]:
                    tiles.append(
                        tile_button(
                            module.get("name", "Module")[:1].upper(),
                            module.get("name", "Module"),
                            module.get("state", "planned"),
                            module.get("command", "seven ecosystem summary"),
                            "good" if module.get("state") == "active" else "warn",
                        )
                    )
                add_tiles(grid, tiles[:12], 4)
                ecosystem_page.append(grid)

            def render_all() -> None:
                render_dashboard_compact()
                render_search_results()
                render_profiles_compact()
                render_runtime_compact()
                render_actions_compact()
                render_ecosystem_compact()

            def render_error(message: str) -> None:
                clear(dashboard)
                heading(
                    dashboard,
                    "Seven Hub",
                    "Seven Hub reste ouvert. Une donnée live n'a pas pu être chargée, mais l'interface système continue.",
                )
                dashboard.append(
                    status_card(
                        "Chargement partiel",
                        message[:180],
                        "WARN",
                        "warn",
                    )
                )

            def safe_render_all() -> bool:
                try:
                    render_all()
                    return True
                except Exception as error:
                    print(f"seven-hub-native: render warning: {error}", file=sys.stderr)
                    render_error(str(error))
                    return False

            def update_live_status() -> bool:
                try:
                    cached = STATE_CACHE.get("data")
                    state_snapshot = cached if isinstance(cached, dict) else {}
                    daily = state_snapshot.get("daily") if isinstance(state_snapshot.get("daily"), dict) else {}
                    session = state_snapshot.get("session") if isinstance(state_snapshot.get("session"), dict) else {}
                    state = daily.get("decision", session.get("mode", "live"))
                    running = session.get("summary", {}).get("running", 0)
                    cache_note = "cached" if state_snapshot.get("_hub_cache") == "persistent" else "live"
                    live_label.set_text(f"{state} · {running} services · {cache_note}")
                except Exception:
                    live_label.set_text("live · guarded")
                return True

            refresh_state = {"running": False}

            def start_state_refresh(force: bool = False) -> bool:
                if refresh_state["running"]:
                    return False

                refresh_state["running"] = True
                live_label.set_text("loading · guarded")

                def worker() -> None:
                    error_message = None
                    try:
                        snapshot = state_payload(force=force)
                        if not any(key in snapshot for key in ("profiles", "daily", "session", "actions")):
                            error_message = "seven state --json is unavailable or returned a partial snapshot."
                    except Exception as error:
                        error_message = str(error)

                    def finish() -> bool:
                        refresh_state["running"] = False
                        cached = STATE_CACHE.get("data")
                        has_live_snapshot = isinstance(cached, dict) and any(
                            key in cached for key in ("profiles", "daily", "session", "actions")
                        )
                        if error_message and not has_live_snapshot:
                            live_label.set_text("live · guarded")
                            render_error(error_message)
                        else:
                            safe_render_all()
                            update_live_status()
                        return False

                    GLib.idle_add(finish)

                threading.Thread(target=worker, name="seven-hub-state-refresh", daemon=True).start()
                return False

            def refresh_live_surface() -> bool:
                start_state_refresh(True)
                return True

            def render_loading_shell() -> None:
                clear(dashboard)
                heading(dashboard, "SevenOS Dashboard", "Loading live system state...")
                dashboard.append(
                    status_card(
                        "Preparing Control Center",
                        "Seven Hub is opening first, then loading readiness, profiles, actions and ecosystem state.",
                        "RUN",
                        "accent",
                    )
                )

                clear(profiles_page)
                heading(profiles_page, "Profiles", "Loading profile workspaces...")
                profiles_page.append(status_card("Profile Engine", "Collecting Forge DevOps, Shield, Studio, Atlas and Pulse state.", "LOAD", "info"))

                clear(search_page)
                heading(search_page, "Search", "Loading searchable actions and runtime contracts...")
                search_page.append(status_card("Search Index", "Preparing actions, mini OS shortcuts and runtime manifests.", "LOAD", "info"))

                clear(runtime_page)
                heading(runtime_page, "Runtime & Mini OS", "Loading runtime manifests...")
                runtime_page.append(status_card("Runtime Contracts", "Preparing profile isolation, composition and strict execution state.", "LOAD", "info"))

                clear(actions_page)
                heading(actions_page, "Actions", "Loading available repairs and system actions...")
                actions_page.append(status_card("Action Plane", "Preparing safe controls and contextual fixes.", "LOAD", "info"))

                clear(ecosystem_page)
                heading(ecosystem_page, "Ecosystem", "Loading ecosystem modules and processes...")
                ecosystem_page.append(status_card("Seven Ecosystem", "Preparing Server, Store, Shell, Core and deployment state.", "LOAD", "info"))

            def load_after_present() -> bool:
                start_state_refresh(True)
                return False

            refresh.connect("clicked", lambda _button: start_state_refresh(True))
            render_loading_shell()
            win.present()
            GLib.timeout_add(80, load_after_present)
            GLib.timeout_add_seconds(10, update_live_status)
            GLib.timeout_add_seconds(60, refresh_live_surface)

    app = SevenHubNative()
    return app.run([sys.argv[0]])


def main() -> int:
    parser = argparse.ArgumentParser(prog="seven-hub-native", description="SevenOS Control Center")
    parser.add_argument("action", nargs="?", default="open", choices=("open", "status", "doctor"))
    parser.add_argument("--dry-run", action="store_true", help="show what would happen")
    args = parser.parse_args()

    if args.action in ("status", "doctor"):
      print(status_text())
      return 0

    if args.dry_run or os.environ.get("SEVENOS_DRY_RUN") == "1":
        print("seven-hub-native open")
        return 0

    ensure_gtk_python()
    return run_gui()


if __name__ == "__main__":
    raise SystemExit(main())
