          transition:
            background 160ms ease,
            color 160ms ease,
            border-color 160ms ease,
            outline-color 160ms ease;
        }
        """
        provider = Gtk.CssProvider()
        try:
            provider.load_from_data(css.encode("utf-8"))
        except TypeError:
            provider.load_from_data(css)
        display = Gdk.Display.get_default()
        if display is not None:
            Gtk.StyleContext.add_provider_for_display(
                display,
                provider,
                Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
            )

    class SevenHubNative(Adw.Application):
        def __init__(self) -> None:
            super().__init__(
                application_id=None,
                flags=Gio.ApplicationFlags.NON_UNIQUE,
            )
            self.connect("activate", self.on_activate)

        def on_activate(self, app: Adw.Application) -> None:
            install_css()
            win = Adw.ApplicationWindow(application=app)
            win.set_title("Seven Hub")
            display = Gdk.Display.get_default()
            screen_width, screen_height = 1280, 720
            try:
                monitors = display.get_monitors() if display else None
                monitor = monitors.get_item(0) if monitors and monitors.get_n_items() else None
                geometry = monitor.get_geometry() if monitor else None
                if geometry:
                    screen_width, screen_height = geometry.width, geometry.height
            except Exception:
                pass
            compact_screen = screen_width < 1180 or screen_height < 720
            hub_width = min(1180, max(760, int(screen_width * 0.78)))
            hub_height = min(740, max(520, int(screen_height * 0.74)))
            sidebar_width = 214 if compact_screen else 250
            win.set_default_size(hub_width, hub_height)
            win.add_css_class("seven-hub-window")

            stack = Gtk.Stack()
            stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
            stack.set_vexpand(True)
            stack.add_css_class("seven-content")

            refresh = Gtk.Button(label="Refresh")
            refresh.add_css_class("pill")

            sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
            sidebar.set_size_request(sidebar_width, -1)
            sidebar.add_css_class("seven-sidebar")

            brand = Gtk.Label(label="7  SevenOS")
            brand.set_xalign(0)
            brand.add_css_class("seven-brand")
            sidebar.append(brand)

            nav_buttons = []

            def nav_button(label_text: str, icon_name: str, page_name: str) -> Gtk.Button:
                button = Gtk.Button()
                button.add_css_class("seven-nav-item")
                content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                icon = Gtk.Image.new_from_icon_name(icon_name)
                text = Gtk.Label(label=label_text)
                text.set_xalign(0)
                text.set_hexpand(True)
                content.append(icon)
                content.append(text)
                button.set_child(content)

                def activate(_button: Gtk.Button) -> None:
                    stack.set_visible_child_name(page_name)
                    for item in nav_buttons:
                        item.remove_css_class("active")
                    button.add_css_class("active")

                button.connect("clicked", activate)
                nav_buttons.append(button)
                sidebar.append(button)
                return button

            dashboard_nav = nav_button(tr("hub.dashboard", "Dashboard"), "view-dashboard-symbolic", "dashboard")
            nav_button(tr("hub.search", "Search"), "system-search-symbolic", "search")
            nav_button(tr("hub.profiles", "Profiles"), "avatar-default-symbolic", "profiles")
            nav_button(tr("hub.runtime", "Runtime"), "emblem-system-symbolic", "runtime")
            nav_button(tr("hub.actions", "Actions"), "system-run-symbolic", "actions")
            nav_button(tr("hub.ecosystem", "Ecosystem"), "network-workgroup-symbolic", "ecosystem")
            dashboard_nav.add_css_class("active")

            sidebar_status_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
            sidebar_status_card.add_css_class("seven-status-card")
            status_title = Gtk.Label(label=tr("hub.system_status", "SYSTEM STATUS"))
            status_title.set_xalign(0)
            status_title.add_css_class("dim-label")
            status_value = Gtk.Label(label=tr("hub.native_online", "Native Hub online"))
            status_value.set_xalign(0)
            status_value.add_css_class("seven-pill")
            status_note = Gtk.Label(label=tr("hub.control_center", "SevenOS Control Center"))
            status_note.set_xalign(0)
            status_note.add_css_class("dim-label")
            live_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            live_row.add_css_class("seven-live-row")
            live_orb = Gtk.Box()
            live_orb.add_css_class("seven-live-orb")
            live_label = Gtk.Label(label="Live")
            live_label.set_xalign(0)
            live_label.add_css_class("dim-label")
            live_row.append(live_orb)
            live_row.append(live_label)
            sidebar_status_card.append(status_title)
            sidebar_status_card.append(status_value)
            sidebar_status_card.append(status_note)
            sidebar_status_card.append(live_row)
            sidebar.append(sidebar_status_card)
            sidebar.append(refresh)

            body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
            body.add_css_class("seven-body")
            body.append(sidebar)
            body.append(stack)

            root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            root.add_css_class("seven-root")
            root.add_css_class(f"mode-{current_theme_mode()}")
            root.append(body)
            win.set_content(root)

            def make_row(title_text: str, subtitle: str) -> Adw.ActionRow:
                row = Adw.ActionRow()
                row.add_css_class("seven-card")
                row.set_title(title_text)
                row.set_subtitle(subtitle)
                return row

            def page():
                box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
                box.add_css_class("seven-page")
                box.set_margin_top(0)
                box.set_margin_bottom(0)
                box.set_margin_start(0)
                box.set_margin_end(0)

                scrolled = Gtk.ScrolledWindow()
                scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
                scrolled.set_child(box)
                return box, scrolled

            dashboard, dashboard_scroll = page()
            search_page, search_scroll = page()
            profiles_page, profiles_scroll = page()
            runtime_page, runtime_scroll = page()
            actions_page, actions_scroll = page()
            ecosystem_page, ecosystem_scroll = page()

            stack.add_titled(dashboard_scroll, "dashboard", "Dashboard")
            stack.add_titled(search_scroll, "search", "Search")
            stack.add_titled(profiles_scroll, "profiles", "Profiles")
            stack.add_titled(runtime_scroll, "runtime", "Runtime")
            stack.add_titled(actions_scroll, "actions", "Actions")
            stack.add_titled(ecosystem_scroll, "ecosystem", "Ecosystem")

            def clear(box: Gtk.Box) -> None:
                while child := box.get_first_child():
                    box.remove(child)

            def heading(box: Gtk.Box, title_text: str, subtitle: str) -> None:
                hero = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
                hero.add_css_class("seven-hero")
                label = Gtk.Label()
                label.set_markup(f"<span weight='500'>{title_text}</span>")
                label.set_xalign(0)
                label.add_css_class("seven-hero-title")
                hero.append(label)

                intro = Gtk.Label(label=subtitle)
                intro.set_xalign(0)
                intro.add_css_class("seven-hero-subtitle")
                intro.set_wrap(True)
                hero.append(intro)
                box.append(hero)

            def metric_card(label_text: str, value_text: str, note_text: str, state: str = "warn") -> Gtk.Box:
                card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
                card.add_css_class("seven-metric-card")
                if state in ("good", "warn", "bad"):
                    card.add_css_class(state)
                label = Gtk.Label(label=label_text.upper())
                label.set_xalign(0)
                label.add_css_class("seven-metric-label")
                value = Gtk.Label(label=value_text)
                value.set_xalign(0)
                value.add_css_class("seven-metric-value")
                note = Gtk.Label(label=note_text)
                note.set_xalign(0)
                note.add_css_class("seven-metric-note")
                note.set_wrap(True)
                card.append(label)
                card.append(value)
                card.append(note)
                return card

            def metric_state(percent: int) -> str:
                if percent >= 85:
                    return "good"
                if percent >= 60:
                    return "warn"
                return "bad"

            def state_short(state: str) -> str:
                value = str(state or "unknown").replace("-", " ")
                return value[:22]

            def status_card(title_text: str, subtitle: str, state: str = "RUN", css_state: str = "warn") -> Gtk.Box:
                card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
                card.add_css_class("seven-tile")
                if css_state in ("good", "warn", "bad"):
                    card.add_css_class(css_state)
                icon = Gtk.Label(label="●")
                icon.set_xalign(0)
                icon.add_css_class("seven-tile-icon")
                title = Gtk.Label(label=title_text)
                title.set_xalign(0)
                title.add_css_class("seven-tile-title")
                note = Gtk.Label(label=f"{state} · {subtitle}")
                note.set_xalign(0)
                note.set_wrap(True)
                note.set_lines(2)
                note.add_css_class("seven-tile-note")
                card.append(icon)
                card.append(title)
                card.append(note)
                return card

            def tile_button(icon_text: str, title_text: str, note_text: str, command: str, state: str = "warn") -> Gtk.Button:
                button = Gtk.Button()
                button.add_css_class("seven-tile")
                if state in ("good", "warn", "bad"):
                    button.add_css_class(state)
                button.set_tooltip_text(command)
                box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
                icon = Gtk.Label(label=icon_text)
                icon.set_xalign(0)
                icon.add_css_class("seven-tile-icon")
                title = Gtk.Label(label=title_text)
                title.set_xalign(0)
                title.add_css_class("seven-tile-title")
                note = Gtk.Label(label=note_text)
                note.set_xalign(0)
                note.set_wrap(True)
                note.set_lines(2)
                note.add_css_class("seven-tile-note")
                box.append(icon)
                box.append(title)
                box.append(note)
                button.set_child(box)
                button.connect(
                    "clicked",
                    lambda _button, command=command, title_text=title_text: run_ecosystem_command(
                        command,
                        title=f"SevenOS Hub - {title_text}",
                    ),
                )
                return button

            def icon_action(icon_name: str, tooltip: str, command: str) -> Gtk.Button:
                button = Gtk.Button()
                button.add_css_class("seven-action-dot")
                button.set_icon_name(icon_name)
                button.set_tooltip_text(tooltip)
                button.connect(
                    "clicked",
                    lambda _button, command=command, tooltip=tooltip: run_ecosystem_command(
                        command,
                        title=f"SevenOS - {tooltip}",
                    ),
                )
                return button

            def command_pill(icon_name: str, label_text: str, command: str) -> Gtk.Button:
                button = Gtk.Button()
                button.add_css_class("seven-command-pill")
                button.set_tooltip_text(command)
                content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=9)
                icon = Gtk.Image.new_from_icon_name(icon_name)
                label = Gtk.Label(label=label_text)
                label.set_xalign(0)
                content.append(icon)
                content.append(label)
                button.set_child(content)
                button.connect(
                    "clicked",
                    lambda _button, command=command, label_text=label_text: run_ecosystem_command(
                        command,
                        title=f"SevenOS - {label_text}",
                    ),
                )
                return button

            def command_center(active_profile: str, daily_state: str) -> Gtk.Box:
                center = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
                center.add_css_class("seven-command-center")
                orb = Gtk.Box()
                orb.add_css_class("seven-ai-orb")
                center.append(orb)

                copy = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
                copy.set_hexpand(True)
                title = Gtk.Label(label=tr("hub.command.title", "What do you want to do?"))
                title.set_xalign(0)
                title.add_css_class("seven-command-title")
                note = Gtk.Label(
                    label=tr(
                        "hub.command.note",
                        "{profile} mode · {state} · Spotlight, Seven AI and settings are one click away.",
                    ).format(profile=active_profile, state=daily_state.replace("-", " "))
                )
                note.set_xalign(0)
                note.set_wrap(True)
                note.add_css_class("seven-command-note")
                copy.append(title)
                copy.append(note)
                center.append(copy)

                for icon_name, label_text, command in [
                    ("seven-spotlight", "Spotlight", "seven-spotlight"),
                    ("seven-ai", "Seven AI", "seven ai focus"),
                    ("seven-settings", tr("hub.settings", "Settings"), "seven-settings"),
                ]:
                    center.append(command_pill(icon_name, label_text, command))
                return center

            def compact_grid() -> Gtk.Grid:
                grid = Gtk.Grid()
                grid.add_css_class("seven-compact-grid")
                grid.set_column_spacing(12)
                grid.set_row_spacing(12)
                return grid

            def add_tiles(grid: Gtk.Grid, tiles: list[Gtk.Widget], columns: int = 4) -> None:
                for index, tile in enumerate(tiles):
                    grid.attach(tile, index % columns, index // columns, 1, 1)

            def render_dashboard() -> None:
                clear(dashboard)
                welcome = welcome_payload()
                welcome_plan = welcome_plan_payload()
                session = session_payload()
                identity = identity_payload()
                readiness = readiness_payload()
                profiles = profile_payload()
                profile_gaps = profile_gaps_payload()
                profile_plan = profile_plan_payload()
                ecosystem = ecosystem_payload()
                stack = stack_payload()
                shell = shell_payload()
                core = core_payload()
                core_plan = core_plan_payload()
                experience = experience_payload()
                shield = shield_payload()
                shield_plan = shield_plan_payload()
                server = server_payload()
                server_plan = server_plan_payload()
                atlas = atlas_payload()
                atlas_plan = atlas_plan_payload()
                installer = installer_payload()
                installer_plan = installer_plan_payload()
                packages_plan = packages_plan_payload()
                control = control_payload()
                events = events_payload()
                insights = insights_payload()
                phase_gate = phase_gate_payload()
                b3 = b3_payload()
                daily = daily_payload()
                active = next((item for item in profiles if item.get("active")), None)
                ready = sum(1 for item in profiles if item.get("state") == "OK")
                partial = sum(1 for item in profiles if item.get("state") == "PART")
                missing = sum(1 for item in profiles if item.get("state") == "MISS")
                profile_gap_count = sum(1 for item in profile_gaps.get("profiles", []) if item.get("state") != "OK")
                next_profile = (profile_plan.get("next") or [{}])[0].get("title", "none")
                active_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "active")
                preview_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "preview")
                next_stack = ", ".join(stack.get("next_focus", [])[:2]) or "Seven Shell AGS, seven-daemon Rust"

                heading(dashboard, "SevenOS Dashboard", "System state, readiness and common repair paths from native GTK.")

                metrics = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                metrics.add_css_class("seven-metric-row")
                readiness_percent = int(readiness.get("percent", 0) or 0)
                shield_percent = int(shield.get("percent", 0) or 0)
                experience_percent = int(experience.get("percent", 0) or 0)
                daily_state = daily.get("decision", "unknown")
                metrics.append(metric_card("Readiness", f"{readiness_percent}%", "primary PC gate", metric_state(readiness_percent)))
                metrics.append(metric_card("Shield", f"{shield_percent}%", shield.get("posture", "unknown"), metric_state(shield_percent)))
                metrics.append(metric_card("Experience", f"{experience_percent}%", "UI/UX coherence", metric_state(experience_percent)))
                metrics.append(metric_card("Daily", daily_state.replace("-", " "), f"{len(daily.get('blockers', []))} blockers", "good" if daily_state == "ready" else "warn"))
                dashboard.append(metrics)

                identity_group = Adw.PreferencesGroup(title="SevenOS identity")
                identity_group.add(make_row(
                    identity.get("tagline", "Beyond the Desktop."),
                    identity.get("positioning", "Next generation intelligent Linux experience for creators, developers and cybersecurity."),
                ))
                current_pack = identity.get("current_pack", {})
                identity_group.add(make_row(
                    "Active accent pack",
                    f"{current_pack.get('title', 'Default')} · {current_pack.get('accent', 'seven-blue')} · {current_pack.get('pattern', 'glass')}",
                ))
                principle_names = ", ".join(item.get("label", item.get("key", "")) for item in identity.get("principles", [])[:6])
                identity_group.add(make_row("Product principles", principle_names or "Fluidity, transparency, intelligent minimalism, depth, contextuality"))
                packs = identity.get("regional_packs", [])
                pack_names = ", ".join(item.get("title", "") for item in packs[:4])
