#!/usr/bin/env python3
import argparse
import json
import os
import subprocess
import sys
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()

    script_dir = Path(__file__).resolve().parent
    candidate = script_dir.parent
    if Path(candidate, "install.sh").is_file():
        return candidate

    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if Path(path, "install.sh").is_file():
            return path

    print("seven-hub-native: could not find SevenOS root", file=sys.stderr)
    sys.exit(1)


ROOT = resolve_root()


def run_text(*command: str) -> str:
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_DRY_RUN": "0"}
    output = subprocess.check_output(command, cwd=ROOT, text=True, env=env)
    return output.strip()


def profile_payload() -> list[dict]:
    return json.loads(run_text(str(ROOT / "bin" / "seven"), "profile", "status", "--json"))


def readiness_payload() -> dict:
    try:
        return json.loads(run_text(str(ROOT / "scripts" / "readiness.sh"), "--json"))
    except Exception:
        return {"score": 0, "max": 0, "percent": 0, "recommendations": []}


def actions_payload() -> dict:
    try:
        return json.loads(run_text(str(ROOT / "scripts" / "actions.sh"), "--json"))
    except Exception:
        return {"schema": "sevenos.actions.v1", "actions": []}


def status_text() -> str:
    profiles = profile_payload()
    active = next((item for item in profiles if item.get("active")), None)
    ready = sum(1 for item in profiles if item.get("state") == "OK")
    partial = sum(1 for item in profiles if item.get("state") == "PART")
    missing = sum(1 for item in profiles if item.get("state") == "MISS")
    return (
        "Seven Hub Native\n"
        f"Root: {ROOT}\n"
        f"Active profile: {active.get('title') if active else 'none'}\n"
        f"Profiles: {ready} OK, {partial} PART, {missing} MISS\n"
    )


def run_profile_action(action: str, key: str) -> None:
    subprocess.Popen(
        [str(ROOT / "bin" / "seven"), "profile", action, key],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
    )


def run_registered_action(action_id: str) -> None:
    subprocess.Popen(
        [str(ROOT / "bin" / "seven"), "actions", "run", action_id],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
    )


def run_gui() -> int:
    try:
        import gi

        gi.require_version("Gtk", "4.0")
        gi.require_version("Adw", "1")
        from gi.repository import Adw, Gtk
    except Exception as error:
        print("seven-hub-native: GTK4/libadwaita is not available yet.", file=sys.stderr)
        print("Install the GUI stack with: seven hub-gui install", file=sys.stderr)
        print(f"Details: {error}", file=sys.stderr)
        return 1

    class SevenHubNative(Adw.Application):
        def __init__(self) -> None:
            super().__init__(application_id="os.seven.SevenHubNative")
            self.connect("activate", self.on_activate)

        def on_activate(self, app: Adw.Application) -> None:
            win = Adw.ApplicationWindow(application=app)
            win.set_title("Seven Hub")
            win.set_default_size(1080, 720)

            toolbar = Adw.HeaderBar()
            title = Adw.WindowTitle(title="Seven Hub", subtitle="Native SevenOS Control Center")
            toolbar.set_title_widget(title)

            refresh = Gtk.Button(label="Refresh")
            toolbar.pack_end(refresh)

            stack = Gtk.Stack()
            stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
            stack.set_vexpand(True)

            sidebar = Gtk.StackSidebar()
            sidebar.set_stack(stack)
            sidebar.set_width_request(180)

            body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
            body.append(sidebar)
            body.append(stack)

            root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            root.append(toolbar)
            root.append(body)
            win.set_content(root)

            def make_row(title_text: str, subtitle: str) -> Adw.ActionRow:
                row = Adw.ActionRow()
                row.set_title(title_text)
                row.set_subtitle(subtitle)
                return row

            def page():
                box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
                box.set_margin_top(24)
                box.set_margin_bottom(24)
                box.set_margin_start(24)
                box.set_margin_end(24)

                scrolled = Gtk.ScrolledWindow()
                scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
                scrolled.set_child(box)
                return box, scrolled

            dashboard, dashboard_scroll = page()
            profiles_page, profiles_scroll = page()
            actions_page, actions_scroll = page()

            stack.add_titled(dashboard_scroll, "dashboard", "Dashboard")
            stack.add_titled(profiles_scroll, "profiles", "Profiles")
            stack.add_titled(actions_scroll, "actions", "Actions")

            def clear(box: Gtk.Box) -> None:
                while child := box.get_first_child():
                    box.remove(child)

            def heading(box: Gtk.Box, title_text: str, subtitle: str) -> None:
                label = Gtk.Label()
                label.set_markup(f"<span size='22000' weight='500'>{title_text}</span>")
                label.set_xalign(0)
                box.append(label)

                intro = Gtk.Label(label=subtitle)
                intro.set_xalign(0)
                intro.add_css_class("dim-label")
                intro.set_wrap(True)
                box.append(intro)

            def render_dashboard() -> None:
                clear(dashboard)
                readiness = readiness_payload()
                profiles = profile_payload()
                active = next((item for item in profiles if item.get("active")), None)
                ready = sum(1 for item in profiles if item.get("state") == "OK")
                partial = sum(1 for item in profiles if item.get("state") == "PART")
                missing = sum(1 for item in profiles if item.get("state") == "MISS")

                heading(dashboard, "SevenOS Dashboard", "System state, readiness and common repair paths from native GTK.")

                group = Adw.PreferencesGroup(title="System overview")
                for title_text, subtitle in (
                    ("Readiness", f"{readiness.get('percent', 0)}% · {readiness.get('score', 0)}/{readiness.get('max', 0)} checks passed"),
                    ("Active profile", active.get("title") if active else "No active profile yet"),
                    ("Profiles", f"{ready} OK · {partial} PART · {missing} MISS"),
                    ("Root", str(ROOT)),
                ):
                    group.add(make_row(title_text, subtitle))
                dashboard.append(group)

                recommendations = readiness.get("recommendations") or []
                if recommendations:
                    rec_group = Adw.PreferencesGroup(title="Recommended next actions")
                    for recommendation in recommendations[:4]:
                        rec_group.add(make_row(
                            recommendation.get("command", "seven doctor"),
                            recommendation.get("reason", "Review this SevenOS improvement."),
                        ))
                    dashboard.append(rec_group)

            def render_profiles() -> None:
                clear(profiles_page)
                heading(
                    profiles_page,
                    "Professional Profiles",
                    "Install, inspect and activate real SevenOS workspaces without opening a terminal.",
                )

                group = Adw.PreferencesGroup(title="Workspaces")
                for profile in profile_payload():
                    row = Adw.ActionRow()
                    row.set_title(profile.get("title", profile.get("key", "Profile")))
                    row.set_subtitle(
                        f"{profile.get('state')} · {profile.get('installed')}/{profile.get('total')} packages · {profile.get('workspace')}"
                    )
                    row.add_prefix(Gtk.Label(label="●" if profile.get("active") else "○"))

                    details = Gtk.Button(label="Details")
                    details.connect("clicked", lambda _button, key=profile["key"]: run_profile_action("show", key))
                    row.add_suffix(details)

                    action_label = "Active" if profile.get("active") else "Activate" if profile.get("state") == "OK" else "Install"
                    action_name = "activate" if profile.get("state") == "OK" else "install"
                    action = Gtk.Button(label=action_label)
                    action.set_sensitive(not profile.get("active"))
                    action.add_css_class("suggested-action")
                    action.connect("clicked", lambda _button, name=action_name, key=profile["key"]: run_profile_action(name, key))
                    row.add_suffix(action)

                    group.add(row)

                profiles_page.append(group)

            def render_actions() -> None:
                clear(actions_page)
                heading(
                    actions_page,
                    "System Actions",
                    "Actions come from seven actions --json, so the native Hub follows the same contract as the CLI and server.",
                )

                payload = actions_payload()
                by_category: dict[str, list[dict]] = {}
                for action in payload.get("actions", []):
                    by_category.setdefault(action.get("category", "System"), []).append(action)

                wanted = ("Desktop", "System", "Profiles", "Security", "Apps", "Windows", "Server", "Installer")
                for category in wanted:
                    items = by_category.get(category, [])
                    if not items:
                        continue
                    group = Adw.PreferencesGroup(title=category)
                    for item in items[:6]:
                        row = make_row(
                            item.get("title", item.get("id", "Action")),
                            f"{item.get('impact', 'safe')} · {item.get('description', '')}",
                        )
                        button = Gtk.Button(label="Run")
                        button.add_css_class("suggested-action" if item.get("impact") == "safe" else "destructive-action")
                        button.connect("clicked", lambda _button, action_id=item["id"]: run_registered_action(action_id))
                        row.add_suffix(button)
                        group.add(row)
                    actions_page.append(group)

            def render_all() -> None:
                render_dashboard()
                render_profiles()
                render_actions()

            refresh.connect("clicked", lambda _button: render_all())
            render_all()
            win.present()

    app = SevenHubNative()
    return app.run(sys.argv)


def main() -> int:
    parser = argparse.ArgumentParser(prog="seven-hub-native", description="Native SevenOS Control Center prototype")
    parser.add_argument("action", nargs="?", default="open", choices=("open", "status", "doctor"))
    parser.add_argument("--dry-run", action="store_true", help="show what would happen")
    args = parser.parse_args()

    if args.action in ("status", "doctor"):
      print(status_text())
      return 0

    if args.dry_run or os.environ.get("SEVENOS_DRY_RUN") == "1":
        print("seven-hub-native open")
        return 0

    return run_gui()


if __name__ == "__main__":
    raise SystemExit(main())
