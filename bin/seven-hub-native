def status_text() -> str:
    welcome = welcome_payload()
    welcome_plan = welcome_plan_payload()
    session = session_payload()
    profiles = profile_payload()
    profile_gaps = profile_gaps_payload()
    profile_plan = profile_plan_payload()
    ecosystem = ecosystem_payload()
    experience = experience_payload()
    shield = shield_payload()
    server = server_payload()
    control = control_payload()
    events = events_payload()
    insights = insights_payload()
    active = next((item for item in profiles if item.get("active")), None)
    ready = sum(1 for item in profiles if item.get("state") == "OK")
    partial = sum(1 for item in profiles if item.get("state") == "PART")
    missing = sum(1 for item in profiles if item.get("state") == "MISS")
    profile_gap_count = sum(1 for item in profile_gaps.get("profiles", []) if item.get("state") != "OK")
    next_profile = (profile_plan.get("next") or [{}])[0].get("title", "none")
    active_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "active")
    preview_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "preview")
    return (
        "Seven Hub Native\n"
        f"Root: {ROOT}\n"
        f"First run: {welcome.get('mode', 'unknown')} · {welcome.get('percent', 0)}% · {welcome_plan.get('summary', {}).get('total', 0)} actions\n"
        f"Session: {session.get('mode', 'unknown')} · {session.get('percent', 0)}% · {session.get('summary', {}).get('running', 0)} running\n"
        f"Active profile: {active.get('title') if active else 'none'}\n"
        f"Profiles: {ready} OK, {partial} PART, {missing} MISS\n"
        f"Profile gaps: {profile_gap_count} incomplete modes\n"
        f"Next profile: {next_profile}\n"
        f"Ecosystem: {active_modules} active, {preview_modules} preview, {len(ecosystem.get('processes', []))} processes\n"
        f"Experience: {experience.get('percent', 0)}% ({experience.get('score', 0)}/{experience.get('max', 0)})\n"
        f"Shield: {shield.get('posture', 'unknown')} ({shield.get('percent', 0)}%)\n"
        f"Server: {server.get('service', {}).get('state', 'MISS')}\n"
        f"Control: {control.get('overall', 0)}% · {control.get('summary', {}).get('total', 0)} actions\n"
        f"Events: {events.get('total', 0)} recorded\n"
        f"Insights: phase {insights.get('phase', 'unknown')} · {insights.get('summary', {}).get('total', 0)} open items\n"
    )


def run_profile_action(action: str, key: str) -> None:
    run_visible(str(ROOT / "bin" / "seven"), "profile", action, key, title=f"SevenOS Profile - {key}")


def run_registered_action(action_id: str) -> None:
    run_visible(str(ROOT / "bin" / "seven"), "actions", "run", action_id, title=f"SevenOS Action - {action_id}")


def run_ecosystem_command(command: str, title: str = "SevenOS Process") -> None:
    try:
        parts = shlex.split(command)
    except ValueError:
        run_visible("bash", "-lc", command, title=title)
        return

    if not parts:
        return
    if parts[0] == "seven":
        parts[0] = str(ROOT / "bin" / "seven")
    elif parts[0] == "sevenpkg":
        parts[0] = str(ROOT / "bin" / "sevenpkg")
    elif parts[0] == "seven-hub-native":
        parts[0] = str(ROOT / "bin" / "seven-hub-native")

    run_visible(*parts, title=title)


def icon_for_action(action_id: str, impact: str = "safe") -> str:
    if action_id.startswith("profile."):
        return "avatar-default-symbolic"
    if action_id.startswith("security."):
        return "security-high-symbolic"
    if action_id.startswith("windows."):
        return "computer-symbolic"
    if action_id.startswith("server.") or action_id.startswith("deploy."):
        return "network-server-symbolic"
    if action_id.startswith("installer."):
        return "drive-harddisk-symbolic"
    if action_id.startswith("flatpak.") or action_id.startswith("sevenpkg.") or action_id.startswith("apps."):
        return "application-x-executable-symbolic"
    if action_id.startswith("files."):
        return "folder-symbolic"
    if impact != "safe":
        return "emblem-system-symbolic"
    return "system-run-symbolic"


def run_gui() -> int:
    try:
        import gi

        gi.require_version("Gtk", "4.0")
        gi.require_version("Adw", "1")
        from gi.repository import Adw, Gtk
    except Exception as error:
        print("seven-hub-native: GTK4/libadwaita is not available yet.", file=sys.stderr)
        print("Install the GUI stack with: seven hub-gui install", file=sys.stderr)
        print(f"Details: {error}", file=sys.stderr)
        return 1

    class SevenHubNative(Adw.Application):
        def __init__(self) -> None:
            super().__init__(application_id="os.seven.SevenHubNative")
            self.connect("activate", self.on_activate)

        def on_activate(self, app: Adw.Application) -> None:
            win = Adw.ApplicationWindow(application=app)
            win.set_title("Seven Hub")
            win.set_default_size(1080, 720)

            toolbar = Adw.HeaderBar()
            title = Adw.WindowTitle(title="Seven Hub", subtitle="Native SevenOS Control Center")
            toolbar.set_title_widget(title)

            refresh = Gtk.Button(label="Refresh")
            toolbar.pack_end(refresh)

            stack = Gtk.Stack()
            stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
            stack.set_vexpand(True)

            sidebar = Gtk.StackSidebar()
            sidebar.set_stack(stack)
            sidebar.set_width_request(180)

            body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
            body.append(sidebar)
            body.append(stack)

            root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            root.append(toolbar)
            root.append(body)
            win.set_content(root)

            def make_row(title_text: str, subtitle: str) -> Adw.ActionRow:
                row = Adw.ActionRow()
                row.set_title(title_text)
                row.set_subtitle(subtitle)
                return row

            def page():
                box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
                box.set_margin_top(24)
                box.set_margin_bottom(24)
                box.set_margin_start(24)
                box.set_margin_end(24)

                scrolled = Gtk.ScrolledWindow()
                scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
                scrolled.set_child(box)
                return box, scrolled

            dashboard, dashboard_scroll = page()
            profiles_page, profiles_scroll = page()
            actions_page, actions_scroll = page()
            ecosystem_page, ecosystem_scroll = page()

            stack.add_titled(dashboard_scroll, "dashboard", "Dashboard")
            stack.add_titled(profiles_scroll, "profiles", "Profiles")
            stack.add_titled(actions_scroll, "actions", "Actions")
            stack.add_titled(ecosystem_scroll, "ecosystem", "Ecosystem")

            def clear(box: Gtk.Box) -> None:
                while child := box.get_first_child():
                    box.remove(child)

            def heading(box: Gtk.Box, title_text: str, subtitle: str) -> None:
                label = Gtk.Label()
                label.set_markup(f"<span size='22000' weight='500'>{title_text}</span>")
                label.set_xalign(0)
                box.append(label)

                intro = Gtk.Label(label=subtitle)
                intro.set_xalign(0)
                intro.add_css_class("dim-label")
                intro.set_wrap(True)
                box.append(intro)

            def render_dashboard() -> None:
                clear(dashboard)
                welcome = welcome_payload()
                welcome_plan = welcome_plan_payload()
                session = session_payload()
                readiness = readiness_payload()
                profiles = profile_payload()
                profile_gaps = profile_gaps_payload()
                profile_plan = profile_plan_payload()
                ecosystem = ecosystem_payload()
                experience = experience_payload()
                shield = shield_payload()
                shield_plan = shield_plan_payload()
                server = server_payload()
                server_plan = server_plan_payload()
                windows = windows_payload()
                windows_plan = windows_plan_payload()
                installer = installer_payload()
                installer_plan = installer_plan_payload()
                packages_plan = packages_plan_payload()
                control = control_payload()
                events = events_payload()
                insights = insights_payload()
                active = next((item for item in profiles if item.get("active")), None)
                ready = sum(1 for item in profiles if item.get("state") == "OK")
                partial = sum(1 for item in profiles if item.get("state") == "PART")
                missing = sum(1 for item in profiles if item.get("state") == "MISS")
                profile_gap_count = sum(1 for item in profile_gaps.get("profiles", []) if item.get("state") != "OK")
                next_profile = (profile_plan.get("next") or [{}])[0].get("title", "none")
                active_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "active")
                preview_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "preview")

                heading(dashboard, "SevenOS Dashboard", "System state, readiness and common repair paths from native GTK.")

                group = Adw.PreferencesGroup(title="System overview")
                for title_text, subtitle in (
                    ("First run", f"{welcome.get('mode', 'unknown')} · {welcome.get('percent', 0)}% · {welcome_plan.get('summary', {}).get('total', 0)} onboarding actions"),
                    ("Session", f"{session.get('mode', 'unknown')} · {session.get('percent', 0)}% · {session.get('summary', {}).get('running', 0)} services running"),
                    ("Readiness", f"{readiness.get('percent', 0)}% · {readiness.get('score', 0)}/{readiness.get('max', 0)} checks passed"),
                    ("Experience", f"{experience.get('percent', 0)}% · {experience.get('score', 0)}/{experience.get('max', 0)} coherence score"),
                    ("Shield", f"{shield.get('posture', 'unknown')} · {shield.get('percent', 0)}% trust posture"),
                    ("Shield plan", f"{shield_plan.get('summary', {}).get('total', 0)} trust actions · first: {(shield_plan.get('next') or [{}])[0].get('title', 'none')}"),
                    ("Server", f"{server.get('service', {}).get('state', 'MISS')} · local API service"),
                    ("Server plan", f"{server_plan.get('summary', {}).get('total', 0)} backend actions · first: {(server_plan.get('next') or [{}])[0].get('title', 'none')}"),
                    ("Windows Mode", f"{windows.get('mode', 'setup-needed')} · ready: {str(windows.get('ready', False)).lower()}"),
                    ("Windows plan", f"{windows_plan.get('summary', {}).get('total', 0)} compatibility actions · first: {(windows_plan.get('next') or [{}])[0].get('title', 'none')}"),
                    ("Installer", f"{installer.get('mode', 'foundation')} · ready: {str(installer.get('ready', False)).lower()}"),
                    ("Installer plan", f"{installer_plan.get('summary', {}).get('total', 0)} distribution actions · first: {(installer_plan.get('next') or [{}])[0].get('title', 'none')}"),
                    ("Software plan", f"{packages_plan.get('summary', {}).get('total', 0)} app actions · first: {(packages_plan.get('next') or [{}])[0].get('title', 'none')}"),
                    ("Control Plane", f"{control.get('overall', 0)}% · {control.get('summary', {}).get('total', 0)} prioritized actions"),
                    ("Events", f"{events.get('total', 0)} recorded · {events.get('last', {}).get('type', 'none') if events.get('last') else 'no local history yet'}"),
                    ("Insights", f"phase {insights.get('phase', 'unknown')} · {insights.get('summary', {}).get('total', 0)} open product items"),
                    ("Active profile", active.get("title") if active else "No active profile yet"),
                    ("Profiles", f"{ready} OK · {partial} PART · {missing} MISS"),
                    ("Profile gaps", f"{profile_gap_count} incomplete modes · install from Profiles"),
                    ("Next profile", f"{next_profile} · prioritized completion plan"),
                    ("Ecosystem", f"{active_modules} active modules · {preview_modules} preview · {len(ecosystem.get('processes', []))} processes"),
                    ("Root", str(ROOT)),
                ):
                    group.add(make_row(title_text, subtitle))
                dashboard.append(group)

                welcome_actions = welcome_plan.get("next") or []
                if welcome_actions:
                    welcome_group = Adw.PreferencesGroup(title="First-run plan")
                    for item in welcome_actions[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "First-run")),
                            f"{item.get('severity', 'medium')} · {item.get('phase', 'welcome')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("go-next-symbolic" if item.get("state") == "READY" else "emblem-system-symbolic")
                        button.set_tooltip_text(item.get("command", "seven welcome plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven welcome plan"), title_text=item.get("title", "First-run Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS First Run - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        welcome_group.add(row)
                    dashboard.append(welcome_group)

                recommendations = readiness.get("recommendations") or []
                if recommendations:
                    rec_group = Adw.PreferencesGroup(title="Recommended next actions")
                    for recommendation in recommendations[:4]:
                        rec_group.add(make_row(
                            recommendation.get("command", "seven doctor"),
                            recommendation.get("reason", "Review this SevenOS improvement."),
                        ))
                    dashboard.append(rec_group)

                control_actions = control.get("actions") or []
                if control_actions:
                    control_group = Adw.PreferencesGroup(title="Priority actions")
                    for item in control_actions[:6]:
                        row = make_row(
                            item.get("title", item.get("command", "SevenOS action")),
                            f"{item.get('severity', 'medium')} · {item.get('source', 'control')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name(icon_for_action(item.get("action_id") or "", item.get("impact", "safe")))
                        button.set_tooltip_text(item.get("command", "seven control"))
                        command = item.get("command", "seven control")
                        title_text = item.get("title", "SevenOS Control")
                        button.connect(
                            "clicked",
                            lambda _button, command=command, title_text=title_text: run_ecosystem_command(
                                command,
                                title=f"SevenOS Control - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        control_group.add(row)
                    dashboard.append(control_group)

                shield_actions = shield_plan.get("next") or []
                if shield_actions:
                    shield_group = Adw.PreferencesGroup(title="Shield plan")
                    for item in shield_actions[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "Shield")),
                            f"{item.get('severity', 'high')} · {item.get('phase', 'trust')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("security-high-symbolic")
                        button.set_tooltip_text(item.get("command", "seven shield plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven shield plan"), title_text=item.get("title", "Shield Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Shield - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        shield_group.add(row)
                    dashboard.append(shield_group)

                server_actions = server_plan.get("next") or []
                if server_actions:
                    server_group = Adw.PreferencesGroup(title="Server plan")
                    for item in server_actions[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "Server")),
                            f"{item.get('severity', 'medium')} · {item.get('phase', 'service')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("network-server-symbolic")
                        button.set_tooltip_text(item.get("command", "seven server plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven server plan"), title_text=item.get("title", "Server Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Server - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        server_group.add(row)
                    dashboard.append(server_group)

                windows_actions = windows_plan.get("next") or []
                if windows_actions:
                    windows_group = Adw.PreferencesGroup(title="Windows plan")
                    for item in windows_actions[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "Windows")),
                            f"{item.get('severity', 'medium')} · {item.get('phase', 'apps')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("computer-symbolic")
                        button.set_tooltip_text(item.get("command", "seven windows plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven windows plan"), title_text=item.get("title", "Windows Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Windows - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        windows_group.add(row)
                    dashboard.append(windows_group)

                installer_actions = installer_plan.get("next") or []
                if installer_actions:
                    installer_group = Adw.PreferencesGroup(title="Installer plan")
                    for item in installer_actions[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "Installer")),
                            f"{item.get('severity', 'medium')} · {item.get('phase', 'iso')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("drive-harddisk-symbolic")
                        button.set_tooltip_text(item.get("command", "seven installer plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven installer plan"), title_text=item.get("title", "Installer Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Installer - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        installer_group.add(row)
                    dashboard.append(installer_group)

                package_actions = packages_plan.get("next") or []
                if package_actions:
                    packages_group = Adw.PreferencesGroup(title="Software plan")
                    for item in package_actions[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "Software")),
                            f"{item.get('severity', 'medium')} · {item.get('phase', 'apps')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("package-x-generic-symbolic")
                        button.set_tooltip_text(item.get("command", "sevenpkg plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "sevenpkg plan"), title_text=item.get("title", "Software Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Software - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        packages_group.add(row)
                    dashboard.append(packages_group)

                insight_items = insights.get("insights") or []
                if insight_items:
                    insight_group = Adw.PreferencesGroup(title="Product insights")
                    for item in insight_items[:6]:
                        row = make_row(
                            item.get("title", "SevenOS insight"),
                            f"{item.get('severity', 'medium')} · {item.get('domain', 'system')} · {item.get('detail', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("emblem-system-symbolic")
                        button.set_tooltip_text(item.get("command", "seven insights"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven insights"), title_text=item.get("title", "SevenOS Insight"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Insight - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        insight_group.add(row)
                    dashboard.append(insight_group)

                experience_checks = experience.get("checks") or []
                if experience_checks:
                    exp_group = Adw.PreferencesGroup(title="Experience blockers")
                    for item in [entry for entry in experience_checks if entry.get("state") != "OK"][:5]:
                        row = make_row(
                            item.get("category", "Experience"),
                            f"{item.get('state', 'MISS')} · {item.get('detail', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("media-playback-start-symbolic")
                        button.set_tooltip_text(item.get("command", "seven experience"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven experience"), category=item.get("category", "Experience"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Experience - {category}",
                            ),
                        )
                        row.add_suffix(button)
                        exp_group.add(row)
                    dashboard.append(exp_group)

            def render_profiles() -> None:
                clear(profiles_page)
                heading(
                    profiles_page,
                    "Professional Profiles",
                    "Install, inspect and activate real SevenOS workspaces without opening a terminal.",
                )

                group = Adw.PreferencesGroup(title="Workspaces")
                for profile in profile_payload():
                    row = Adw.ActionRow()
                    row.set_title(profile.get("title", profile.get("key", "Profile")))
                    row.set_subtitle(
                        f"{profile.get('state')} · {profile.get('installed')}/{profile.get('total')} packages · {profile.get('workspace')}"
                    )
                    row.add_prefix(Gtk.Label(label="●" if profile.get("active") else "○"))

                    details = Gtk.Button(label="Details")
                    details.set_icon_name("dialog-information-symbolic")
                    details.set_label("")
                    details.set_tooltip_text(f"Show {profile.get('title', profile['key'])} details")
                    details.connect("clicked", lambda _button, key=profile["key"]: run_profile_action("show", key))
                    row.add_suffix(details)

                    action_label = "Active" if profile.get("active") else "Activate" if profile.get("state") == "OK" else "Install"
                    action_name = "activate" if profile.get("state") == "OK" else "install"
                    action = Gtk.Button(label=action_label)
                    action.set_icon_name("emblem-ok-symbolic" if profile.get("state") == "OK" else "document-save-symbolic")
                    action.set_label("")
                    action.set_tooltip_text(action_label)
                    action.set_sensitive(not profile.get("active"))
                    action.add_css_class("suggested-action")
                    action.connect("clicked", lambda _button, name=action_name, key=profile["key"]: run_profile_action(name, key))
                    row.add_suffix(action)

                    group.add(row)

                profiles_page.append(group)

                gaps = profile_gaps_payload().get("profiles", [])
                gap_items = [item for item in gaps if item.get("state") != "OK"]
                if gap_items:
                    gap_group = Adw.PreferencesGroup(title="Profile gaps")
                    for item in gap_items:
                        row = make_row(
                            item.get("title", item.get("key", "Profile")),
                            f"{item.get('priority', 'medium')} · {item.get('missing_count', 0)} packages missing · {item.get('missing_app_count', 0)} apps unavailable",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("document-save-symbolic")
                        button.set_tooltip_text(item.get("install_command", "seven profile gaps"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("install_command", "seven profile gaps"), title_text=item.get("title", "Profile"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Profile - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        gap_group.add(row)
                    profiles_page.append(gap_group)

                plan = profile_plan_payload()
                plan_items = plan.get("next", [])
                if plan_items:
                    plan_group = Adw.PreferencesGroup(title="Completion plan")
                    for item in plan_items[:5]:
                        row = make_row(
                            item.get("title", item.get("key", "Profile")),
                            f"{item.get('priority', 'medium')} · {item.get('reason', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name("media-playback-start-symbolic")
                        button.set_tooltip_text(item.get("command", "seven profile plan"))
                        button.connect(
                            "clicked",
                            lambda _button, command=item.get("command", "seven profile plan"), title_text=item.get("title", "Profile Plan"): run_ecosystem_command(
                                command,
                                title=f"SevenOS Profile Plan - {title_text}",
                            ),
                        )
                        row.add_suffix(button)
                        plan_group.add(row)
                    profiles_page.append(plan_group)

            def render_actions() -> None:
                clear(actions_page)
                heading(
                    actions_page,
                    "System Actions",
                    "Actions come from seven actions --json, so the native Hub follows the same contract as the CLI and server.",
                )

                payload = actions_payload()
                by_category: dict[str, list[dict]] = {}
                for action in payload.get("actions", []):
                    by_category.setdefault(action.get("category", "System"), []).append(action)

                wanted = ("Desktop", "System", "Profiles", "Security", "Apps", "Windows", "Server", "Ecosystem", "Installer")
                for category in wanted:
                    items = by_category.get(category, [])
                    if not items:
                        continue
                    group = Adw.PreferencesGroup(title=category)
                    for item in items[:6]:
                        row = make_row(
                            item.get("title", item.get("id", "Action")),
                            f"{item.get('impact', 'safe')} · {item.get('description', '')}",
                        )
                        button = Gtk.Button()
                        button.set_icon_name(icon_for_action(item.get("id", ""), item.get("impact", "safe")))
                        button.set_tooltip_text(f"Run {item.get('title', item.get('id', 'action'))}")
                        button.add_css_class("suggested-action" if item.get("impact") == "safe" else "destructive-action")
                        button.connect("clicked", lambda _button, action_id=item["id"]: run_registered_action(action_id))
                        row.add_suffix(button)
                        group.add(row)
                    actions_page.append(group)

            def render_ecosystem() -> None:
                clear(ecosystem_page)
                payload = ecosystem_payload()
                heading(
                    ecosystem_page,
                    "Seven Ecosystem",
                    "All-in-one process map: desktop, profiles, apps, Windows, security, deployment and future cloud/store layers.",
                )

                modules = payload.get("modules", [])
                processes = payload.get("processes", [])
                active = sum(1 for item in modules if item.get("state") == "active")
                preview = sum(1 for item in modules if item.get("state") == "preview")
                planned = sum(1 for item in modules if item.get("state") == "planned")

                overview = Adw.PreferencesGroup(title="Ecosystem overview")
                for title_text, subtitle in (
                    ("Positioning", payload.get("positioning", "SevenOS ecosystem")),
                    ("Modules", f"{active} active · {preview} preview · {planned} planned"),
                    ("Processes", f"{len(processes)} all-in-one flows declared"),
                ):
                    overview.add(make_row(title_text, subtitle))
                ecosystem_page.append(overview)

                module_group = Adw.PreferencesGroup(title="Modules")
                for module in modules:
                    row = make_row(
                        module.get("name", "Module"),
                        f"{module.get('state', 'planned')} · phase {module.get('phase', '?')} · {module.get('purpose', '')}",
                    )
                    module_group.add(row)
                ecosystem_page.append(module_group)

                process_group = Adw.PreferencesGroup(title="Processes")
                for process in processes:
                    row = make_row(
                        process.get("name", "Process"),
                        f"{process.get('state', 'planned')} · {process.get('flow', '')} · {process.get('command', '')}",
                    )
                    button = Gtk.Button()
                    button.set_icon_name("media-playback-start-symbolic")
                    button.set_tooltip_text(f"Start {process.get('name', 'process')}")
                    button.add_css_class("suggested-action")
                    button.connect(
                        "clicked",
                        lambda _button, command=process.get("command", ""), name=process.get("name", "Process"): run_ecosystem_command(
                            command,
                            title=f"SevenOS Process - {name}",
                        ),
                    )
                    row.add_suffix(button)
                    process_group.add(row)
                ecosystem_page.append(process_group)

            def render_all() -> None:
                render_dashboard()
                render_profiles()
                render_actions()
                render_ecosystem()

            refresh.connect("clicked", lambda _button: render_all())
            render_all()
            win.present()

    app = SevenHubNative()
    return app.run(sys.argv)


def main() -> int:
    parser = argparse.ArgumentParser(prog="seven-hub-native", description="Native SevenOS Control Center prototype")
    parser.add_argument("action", nargs="?", default="open", choices=("open", "status", "doctor"))
    parser.add_argument("--dry-run", action="store_true", help="show what would happen")
    args = parser.parse_args()

    if args.action in ("status", "doctor"):
      print(status_text())
      return 0

    if args.dry_run or os.environ.get("SEVENOS_DRY_RUN") == "1":
        print("seven-hub-native open")
        return 0

    return run_gui()


if __name__ == "__main__":
    raise SystemExit(main())
