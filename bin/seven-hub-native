def status_text() -> str:
    welcome = welcome_payload()
    welcome_plan = welcome_plan_payload()
    session = session_payload()
    identity = identity_payload()
    profiles = profile_payload()
    profile_gaps = profile_gaps_payload()
    profile_plan = profile_plan_payload()
    ecosystem = ecosystem_payload()
    stack = stack_payload()
    shell = shell_payload()
    core = core_payload()
    core_plan = core_plan_payload()
    experience = experience_payload()
    shield = shield_payload()
    server = server_payload()
    control = control_payload()
    events = events_payload()
    insights = insights_payload()
    phase_gate = phase_gate_payload()
    b3 = b3_payload()
    daily = daily_payload()
    active = next((item for item in profiles if item.get("active")), None)
    ready = sum(1 for item in profiles if item.get("state") == "OK")
    partial = sum(1 for item in profiles if item.get("state") == "PART")
    missing = sum(1 for item in profiles if item.get("state") == "MISS")
    profile_gap_count = sum(1 for item in profile_gaps.get("profiles", []) if item.get("state") != "OK")
    next_profile = (profile_plan.get("next") or [{}])[0].get("title", "none")
    active_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "active")
    preview_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "preview")
    next_stack = ", ".join(stack.get("next_focus", [])[:2]) or "Seven Shell AGS, seven-daemon Rust"
    return (
        "Seven Hub Native\n"
        f"Root: {ROOT}\n"
        f"First run: {welcome.get('mode', 'unknown')} · {welcome.get('percent', 0)}% · {welcome_plan.get('summary', {}).get('total', 0)} actions\n"
        f"Session: {session.get('mode', 'unknown')} · {session.get('percent', 0)}% · {session.get('summary', {}).get('running', 0)} running\n"
        f"Identity: {identity.get('positioning', 'African first SevenOS')}\n"
        f"Active profile: {active.get('title') if active else 'none'}\n"
        f"Profiles: {ready} OK, {partial} PART, {missing} MISS\n"
        f"Profile gaps: {profile_gap_count} incomplete modes\n"
        f"Next profile: {next_profile}\n"
        f"Ecosystem: {active_modules} active, {preview_modules} preview, {len(ecosystem.get('processes', []))} processes\n"
        f"Stack: {stack.get('phase', 'B2-B3')} · next {next_stack}\n"
        f"Shell: {shell.get('state', 'unknown')} · {len(shell.get('surfaces', []))} surfaces\n"
        f"Core: {core.get('state', 'unknown')} · {core_plan.get('summary', {}).get('total', 0)} actions\n"
        f"Experience: {experience.get('percent', 0)}% ({experience.get('score', 0)}/{experience.get('max', 0)})\n"
        f"Shield: {shield.get('posture', 'unknown')} ({shield.get('percent', 0)}%)\n"
        f"Server: {server.get('state', server.get('service', {}).get('state', 'MISS'))}\n"
        f"Control: {control.get('overall', 0)}% · {control.get('summary', {}).get('total', 0)} actions\n"
        f"Events: {events.get('total', 0)} recorded\n"
        f"Insights: phase {insights.get('phase', 'unknown')} · {insights.get('summary', {}).get('total', 0)} open items\n"
        f"Phase gate: {phase_gate.get('decision', 'unknown')} · {phase_gate.get('summary', {}).get('block', 0)} blockers\n"
        f"B3: {b3.get('overall', 0)}% · {b3.get('summary', {}).get('total', 0)} actions · {b3.get('state', 'blocked')}\n"
        f"Daily: {daily.get('decision', 'unknown')} · {len(daily.get('blockers', []))} blockers · Shield {daily.get('summary', {}).get('shield', 0)}%\n"
    )


def run_profile_action(action: str, key: str) -> None:
    run_visible(str(ROOT / "bin" / "seven"), "profile", action, key, title=f"SevenOS Profile - {key}")


def run_registered_action(action_id: str) -> None:
    run_visible(str(ROOT / "bin" / "seven"), "actions", "run", action_id, title=f"SevenOS Action - {action_id}")


def run_ecosystem_command(command: str, title: str = "SevenOS Process") -> None:
    try:
        parts = shlex.split(command)
    except ValueError:
        run_visible("bash", "-lc", command, title=title)
        return

    if not parts:
        return
    if parts[0] == "seven":
        parts[0] = str(ROOT / "bin" / "seven")
    elif parts[0] == "sevenpkg":
        parts[0] = str(ROOT / "bin" / "sevenpkg")
    elif parts[0] == "seven-hub-native":
        parts[0] = str(ROOT / "bin" / "seven-hub-native")

    run_visible(*parts, title=title)


def icon_for_action(action_id: str, impact: str = "safe") -> str:
    if action_id.startswith("profile."):
        return "avatar-default-symbolic"
    if action_id.startswith("security."):
        return "security-high-symbolic"
    if action_id.startswith("windows."):
        return "computer-symbolic"
    if action_id.startswith("server.") or action_id.startswith("deploy."):
        return "network-server-symbolic"
    if action_id.startswith("installer."):
        return "drive-harddisk-symbolic"
    if action_id.startswith("flatpak.") or action_id.startswith("sevenpkg.") or action_id.startswith("apps."):
        return "application-x-executable-symbolic"
    if action_id.startswith("files."):
        return "folder-symbolic"
    if impact != "safe":
        return "emblem-system-symbolic"
    return "system-run-symbolic"


def run_gui() -> int:
    try:
        import gi

        gi.require_version("Gtk", "4.0")
        gi.require_version("Adw", "1")
        from gi.repository import Adw, Gdk, Gio, GLib, Gtk
    except Exception as error:
        print("seven-hub-native: GTK4/libadwaita is not available yet.", file=sys.stderr)
        print("Install the GUI stack with: seven hub-gui install", file=sys.stderr)
        print(f"Details: {error}", file=sys.stderr)
        return 1

    def install_css() -> None:
        css = """
        window.seven-hub-window {
          background: #eef4f8;
          color: rgba(23, 35, 43, 0.96);
        }

        .seven-root {
          background:
            linear-gradient(135deg, rgba(255, 255, 255, 0.68), rgba(111, 157, 188, 0.16) 42%, rgba(238, 244, 248, 0.94) 72%),
            #eef4f8;
        }

        .seven-body {
          background: rgba(255, 255, 255, 0.48);
          border: 1px solid rgba(255, 255, 255, 0.78);
          border-radius: 24px;
          margin: 24px;
        }

        .seven-sidebar {
          background: rgba(255, 255, 255, 0.42);
          border-right: 1px solid rgba(122, 153, 170, 0.22);
          padding: 24px 18px;
        }

        .seven-brand {
          color: #17232b;
          font-size: 24px;
          font-weight: 500;
          margin-bottom: 18px;
        }

        .seven-nav-item {
          min-height: 46px;
          padding: 0 14px;
          border-radius: 13px;
          background: transparent;
          color: rgba(77, 96, 106, 0.90);
        }

        .seven-nav-item:hover {
          background: rgba(255, 255, 255, 0.54);
        }

        .seven-nav-item.active {
          background: rgba(255, 255, 255, 0.68);
          color: #17232b;
          outline: 1px solid rgba(111, 157, 188, 0.42);
        }

        .seven-status-card {
          background: rgba(255, 255, 255, 0.50);
          border: 1px solid rgba(255, 255, 255, 0.74);
          border-radius: 16px;
          padding: 14px;
          margin-top: 18px;
          color: rgba(23, 35, 43, 0.88);
        }

        .seven-content {
          background: rgba(238, 246, 250, 0.30);
        }

        .seven-page {
          padding: 30px;
        }

        .seven-hero {
          background: rgba(255, 255, 255, 0.48);
          border: 1px solid rgba(255, 255, 255, 0.78);
          border-radius: 18px;
          padding: 20px 22px;
          margin-bottom: 4px;
        }

        .seven-hero-title {
          color: rgba(23, 35, 43, 0.98);
          font-size: 28px;
          font-weight: 500;
        }

        .seven-hero-subtitle {
          color: rgba(77, 96, 106, 0.72);
          font-size: 14px;
        }

        .seven-metric-row {
          margin-top: 8px;
          margin-bottom: 4px;
        }

        .seven-metric-card {
          min-width: 154px;
          min-height: 84px;
          background: rgba(255, 255, 255, 0.50);
          border: 1px solid rgba(255, 255, 255, 0.78);
          border-radius: 18px;
          padding: 14px;
        }

        .seven-metric-card.good {
          border-color: rgba(90, 173, 114, 0.34);
          background: rgba(90, 173, 114, 0.075);
        }

        .seven-metric-card.warn {
          border-color: rgba(111, 157, 188, 0.34);
          background: rgba(111, 157, 188, 0.075);
        }

        .seven-metric-card.bad {
          border-color: rgba(196, 103, 58, 0.34);
          background: rgba(196, 103, 58, 0.075);
        }

        .seven-metric-label {
          color: rgba(77, 96, 106, 0.62);
          font-size: 11px;
          letter-spacing: 0.08em;
        }

        .seven-metric-value {
          color: rgba(23, 35, 43, 0.98);
          font-size: 26px;
          font-weight: 500;
        }

        .seven-metric-note {
          color: rgba(77, 96, 106, 0.62);
          font-size: 12px;
        }

        preferencesgroup {
          margin-top: 10px;
        }

        row.seven-card {
          min-height: 58px;
          margin-top: 6px;
          margin-bottom: 6px;
          border-radius: 14px;
          background: rgba(255, 255, 255, 0.48);
          border: 1px solid rgba(255, 255, 255, 0.76);
        }

        row.seven-card:hover {
          background: rgba(255, 255, 255, 0.66);
          border-color: rgba(111, 157, 188, 0.38);
        }

        .seven-pill {
          border-radius: 999px;
          padding: 4px 9px;
          background: rgba(90, 173, 114, 0.14);
          color: #5aad72;
        }
        """
        provider = Gtk.CssProvider()
        try:
            provider.load_from_data(css.encode("utf-8"))
        except TypeError:
            provider.load_from_data(css)
        display = Gdk.Display.get_default()
        if display is not None:
            Gtk.StyleContext.add_provider_for_display(
                display,
                provider,
                Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
            )

    class SevenHubNative(Adw.Application):
        def __init__(self) -> None:
            super().__init__(
                application_id=None,
                flags=Gio.ApplicationFlags.NON_UNIQUE,
            )
            self.connect("activate", self.on_activate)

        def on_activate(self, app: Adw.Application) -> None:
            install_css()
            win = Adw.ApplicationWindow(application=app)
            win.set_title("Seven Hub")
            win.set_default_size(1280, 780)
            win.add_css_class("seven-hub-window")

            stack = Gtk.Stack()
            stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT_RIGHT)
            stack.set_vexpand(True)
            stack.add_css_class("seven-content")

            refresh = Gtk.Button(label="Refresh")
            refresh.add_css_class("pill")

            sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
            sidebar.set_size_request(250, -1)
            sidebar.add_css_class("seven-sidebar")

            brand = Gtk.Label(label="7  SevenOS")
            brand.set_xalign(0)
            brand.add_css_class("seven-brand")
            sidebar.append(brand)

            nav_buttons = []

            def nav_button(label_text: str, icon_name: str, page_name: str) -> Gtk.Button:
                button = Gtk.Button()
                button.add_css_class("seven-nav-item")
                content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                icon = Gtk.Image.new_from_icon_name(icon_name)
                text = Gtk.Label(label=label_text)
                text.set_xalign(0)
                text.set_hexpand(True)
                content.append(icon)
                content.append(text)
                button.set_child(content)

                def activate(_button: Gtk.Button) -> None:
                    stack.set_visible_child_name(page_name)
                    for item in nav_buttons:
                        item.remove_css_class("active")
                    button.add_css_class("active")

                button.connect("clicked", activate)
                nav_buttons.append(button)
                sidebar.append(button)
                return button

            dashboard_nav = nav_button("Dashboard", "view-dashboard-symbolic", "dashboard")
            nav_button("Profiles", "avatar-default-symbolic", "profiles")
            nav_button("Actions", "system-run-symbolic", "actions")
            nav_button("Ecosystem", "network-workgroup-symbolic", "ecosystem")
            dashboard_nav.add_css_class("active")

            status_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
            status_card.add_css_class("seven-status-card")
            status_title = Gtk.Label(label="SYSTEM STATUS")
            status_title.set_xalign(0)
            status_title.add_css_class("dim-label")
            status_value = Gtk.Label(label="Native Hub online")
            status_value.set_xalign(0)
            status_value.add_css_class("seven-pill")
            status_note = Gtk.Label(label="SevenOS Control Center")
            status_note.set_xalign(0)
            status_note.add_css_class("dim-label")
            status_card.append(status_title)
            status_card.append(status_value)
            status_card.append(status_note)
            sidebar.append(status_card)
            sidebar.append(refresh)

            body = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
            body.add_css_class("seven-body")
            body.append(sidebar)
            body.append(stack)

            root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            root.add_css_class("seven-root")
            root.append(body)
            win.set_content(root)

            def make_row(title_text: str, subtitle: str) -> Adw.ActionRow:
                row = Adw.ActionRow()
                row.add_css_class("seven-card")
                row.set_title(title_text)
                row.set_subtitle(subtitle)
                return row

            def page():
                box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=18)
                box.add_css_class("seven-page")
                box.set_margin_top(0)
                box.set_margin_bottom(0)
                box.set_margin_start(0)
                box.set_margin_end(0)

                scrolled = Gtk.ScrolledWindow()
                scrolled.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
                scrolled.set_child(box)
                return box, scrolled

            dashboard, dashboard_scroll = page()
            profiles_page, profiles_scroll = page()
            actions_page, actions_scroll = page()
            ecosystem_page, ecosystem_scroll = page()

            stack.add_titled(dashboard_scroll, "dashboard", "Dashboard")
            stack.add_titled(profiles_scroll, "profiles", "Profiles")
            stack.add_titled(actions_scroll, "actions", "Actions")
            stack.add_titled(ecosystem_scroll, "ecosystem", "Ecosystem")

            def clear(box: Gtk.Box) -> None:
                while child := box.get_first_child():
                    box.remove(child)

            def heading(box: Gtk.Box, title_text: str, subtitle: str) -> None:
                hero = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
                hero.add_css_class("seven-hero")
                label = Gtk.Label()
                label.set_markup(f"<span weight='500'>{title_text}</span>")
                label.set_xalign(0)
                label.add_css_class("seven-hero-title")
                hero.append(label)

                intro = Gtk.Label(label=subtitle)
                intro.set_xalign(0)
                intro.add_css_class("seven-hero-subtitle")
                intro.set_wrap(True)
                hero.append(intro)
                box.append(hero)

            def metric_card(label_text: str, value_text: str, note_text: str, state: str = "warn") -> Gtk.Box:
                card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=5)
                card.add_css_class("seven-metric-card")
                if state in ("good", "warn", "bad"):
                    card.add_css_class(state)
                label = Gtk.Label(label=label_text.upper())
                label.set_xalign(0)
                label.add_css_class("seven-metric-label")
                value = Gtk.Label(label=value_text)
                value.set_xalign(0)
                value.add_css_class("seven-metric-value")
                note = Gtk.Label(label=note_text)
                note.set_xalign(0)
                note.add_css_class("seven-metric-note")
                note.set_wrap(True)
                card.append(label)
                card.append(value)
                card.append(note)
                return card

            def metric_state(percent: int) -> str:
                if percent >= 85:
                    return "good"
                if percent >= 60:
                    return "warn"
                return "bad"

            def render_dashboard() -> None:
                clear(dashboard)
                welcome = welcome_payload()
                welcome_plan = welcome_plan_payload()
                session = session_payload()
                identity = identity_payload()
                readiness = readiness_payload()
                profiles = profile_payload()
                profile_gaps = profile_gaps_payload()
                profile_plan = profile_plan_payload()
                ecosystem = ecosystem_payload()
                stack = stack_payload()
                shell = shell_payload()
                core = core_payload()
                core_plan = core_plan_payload()
                experience = experience_payload()
                shield = shield_payload()
                shield_plan = shield_plan_payload()
                server = server_payload()
                server_plan = server_plan_payload()
                windows = windows_payload()
                windows_plan = windows_plan_payload()
                installer = installer_payload()
                installer_plan = installer_plan_payload()
                packages_plan = packages_plan_payload()
                control = control_payload()
                events = events_payload()
                insights = insights_payload()
                phase_gate = phase_gate_payload()
                b3 = b3_payload()
                daily = daily_payload()
                active = next((item for item in profiles if item.get("active")), None)
                ready = sum(1 for item in profiles if item.get("state") == "OK")
                partial = sum(1 for item in profiles if item.get("state") == "PART")
                missing = sum(1 for item in profiles if item.get("state") == "MISS")
                profile_gap_count = sum(1 for item in profile_gaps.get("profiles", []) if item.get("state") != "OK")
                next_profile = (profile_plan.get("next") or [{}])[0].get("title", "none")
                active_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "active")
                preview_modules = sum(1 for item in ecosystem.get("modules", []) if item.get("state") == "preview")
                next_stack = ", ".join(stack.get("next_focus", [])[:2]) or "Seven Shell AGS, seven-daemon Rust"

                heading(dashboard, "SevenOS Dashboard", "System state, readiness and common repair paths from native GTK.")

                metrics = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
                metrics.add_css_class("seven-metric-row")
                readiness_percent = int(readiness.get("percent", 0) or 0)
                shield_percent = int(shield.get("percent", 0) or 0)
                experience_percent = int(experience.get("percent", 0) or 0)
                daily_state = daily.get("decision", "unknown")
                metrics.append(metric_card("Readiness", f"{readiness_percent}%", "primary PC gate", metric_state(readiness_percent)))
                metrics.append(metric_card("Shield", f"{shield_percent}%", shield.get("posture", "unknown"), metric_state(shield_percent)))
                metrics.append(metric_card("Experience", f"{experience_percent}%", "UI/UX coherence", metric_state(experience_percent)))
                metrics.append(metric_card("Daily", daily_state.replace("-", " "), f"{len(daily.get('blockers', []))} blockers", "good" if daily_state == "ready" else "warn"))
                dashboard.append(metrics)

                identity_group = Adw.PreferencesGroup(title="African first")
                identity_group.add(make_row(
                    "Sovereign by design",
                    identity.get("positioning", "African first Linux ecosystem for sovereignty, creation, security and deployment."),
                ))
                current_pack = identity.get("current_pack", {})
                identity_group.add(make_row(
                    "Active accent pack",
                    f"{current_pack.get('title', 'Pan-African')} · {current_pack.get('accent', 'gold')} · {current_pack.get('pattern', 'kente')}",
                ))
                principle_names = ", ".join(item.get("label", item.get("key", "")) for item in identity.get("principles", [])[:6])
                identity_group.add(make_row("Product principles", principle_names or "Sovereignty, transmission, creation, protection, community, resilience"))
                packs = identity.get("regional_packs", [])
                pack_names = ", ".join(item.get("title", "") for item in packs[:4])
                identity_group.add(make_row("Accent packs", pack_names or "Pan-African, West Africa, North Africa, Central Africa"))
                dashboard.append(identity_group)

                group = Adw.PreferencesGroup(title="System overview")
                for title_text, subtitle in (
                    ("First run", f"{welcome.get('mode', 'unknown')} · {welcome.get('percent', 0)}% · {welcome_plan.get('summary', {}).get('total', 0)} onboarding actions"),
