#!/usr/bin/env python3
import argparse
import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()

    script_dir = Path(__file__).resolve().parent
    candidate = script_dir.parent
    if Path(candidate, "install.sh").is_file():
        return candidate

    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if Path(path, "install.sh").is_file():
            return path

    print("seven-hub-native: could not find SevenOS root", file=sys.stderr)
    sys.exit(1)


ROOT = resolve_root()


def run_text(*command: str) -> str:
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT), "SEVENOS_DRY_RUN": "0"}
    output = subprocess.check_output(command, cwd=ROOT, text=True, env=env)
    return output.strip()


def command_exists(command: str) -> bool:
    return subprocess.run(
        ["bash", "-lc", f"command -v {shlex.quote(command)} >/dev/null 2>&1"],
        check=False,
    ).returncode == 0


def run_visible(*command: str, title: str = "SevenOS Action") -> None:
    env = {**os.environ, "SEVENOS_ROOT": str(ROOT)}
    command_line = shlex.join(command)
    wrapped = f"cd {shlex.quote(str(ROOT))} && {command_line}; printf '\\nPress Enter to close...'; read -r"

    if os.environ.get("SEVENOS_DRY_RUN") == "1":
        print(command_line)
        return

    if os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY"):
        if command_exists("kitty"):
            subprocess.Popen(["kitty", "--title", title, "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("foot"):
            subprocess.Popen(["foot", "-e", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("alacritty"):
            subprocess.Popen(["alacritty", "-e", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return
        if command_exists("xterm"):
            subprocess.Popen(["xterm", "-e", "bash", "-lc", wrapped], cwd=ROOT, env=env)
            return

    subprocess.Popen(["bash", "-lc", wrapped], cwd=ROOT, env=env)


def profile_payload() -> list[dict]:
    return json.loads(run_text(str(ROOT / "bin" / "seven"), "profile", "status", "--json"))


def profile_gaps_payload() -> dict:
    try:
        return json.loads(run_text(str(ROOT / "bin" / "seven"), "profile", "gaps", "--json"))
    except Exception:
        return {"schema": "sevenos.profile-gaps.v1", "profiles": []}


def profile_plan_payload() -> dict:
