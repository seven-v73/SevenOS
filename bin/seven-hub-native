                    ("view-refresh-symbolic", "Bootstrap active profile", "seven profile bootstrap active"),
                    ("folder-symbolic", "Open profile workspace", "seven-files profile"),
                    ("dialog-information-symbolic", "Profile guide", "seven profile guide"),
