#!/usr/bin/python3
import hashlib
import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent


def host_home() -> Path:
    if os.environ.get("SEVENOS_HOST_HOME"):
        return Path(os.environ["SEVENOS_HOST_HOME"])
    raw = Path(os.environ.get("SEVENOS_HOST_HOME", str(Path.home())))
    text = str(raw)
    marker = "/.local/share/sevenos/profile-containers/"
    if marker in text and text.endswith("/home"):
        return Path(text.split(marker, 1)[0])
    user = os.environ.get("USER")
    if user:
        candidate = Path("/home") / user
        if candidate.is_dir():
            return candidate
    return raw


HOST_HOME = host_home()
SYSTEM_PROFILE = "equinox"


def state_dir() -> Path:
    return Path(os.environ.get("SEVENOS_CONFIG_HOME", str(HOST_HOME / ".config"))) / "sevenos"


def load_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return {}


def active_profile() -> str:
    env_path = state_dir() / "profile.env"
    try:
        for line in env_path.read_text(encoding="utf-8").splitlines():
            if line.startswith("SEVENOS_ACTIVE_PROFILE="):
                return line.split("=", 1)[1].strip().strip('"') or "equinox"
    except OSError:
        pass
    return "equinox"


def known_profiles(isolation: dict) -> set[str]:
    profiles = set()
    profiles.update((isolation.get("profile_containers") or {}).keys())
    profiles.update((isolation.get("profile_overlays") or {}).keys())
    profiles.update(isolation.get("selected_profiles") or [])
    return profiles or {"equinox", "baobab", "forge", "shield", "studio", "windows", "pulse"}


def profile_roots(profile: str, isolation: dict) -> dict:
    if is_system_profile(profile):
        return {
            "config": HOST_HOME / ".config",
            "home": HOST_HOME,
            "cache": HOST_HOME / ".cache",
            "data": HOST_HOME / ".local/share",
            "package_view": Path("/usr/bin"),
            "rootfs": Path("/"),
        }
    containers = isolation.get("profile_containers") or {}
    configured = containers.get(profile) if isinstance(containers, dict) else {}
    if not isinstance(configured, dict):
        configured = {}
    base = HOST_HOME / ".local/share/sevenos/profile-containers" / profile
    config_base = state_dir() / "profiles" / profile
    return {
        "config": Path(configured.get("config") or config_base),
        "home": Path(configured.get("home") or base / "home"),
        "cache": Path(configured.get("cache") or base / "cache"),
        "data": Path(configured.get("data") or base / "data"),
        "package_view": Path(configured.get("package_view") or HOST_HOME / ".local/share/sevenos/profile-package-views" / profile / "bin"),
        "rootfs": Path(configured.get("rootfs") or HOST_HOME / ".local/share/sevenos/profile-rootfs" / profile / "rootfs"),
    }


def default_workspace(profile: str) -> Path:
    mapping = {
        "equinox": "SevenOS",
        "baobab": "Baobab",
        "forge": "Forge",
        "shield": "ShieldLab",
        "studio": "Studio",
        "windows": "WindowsMode",
        "pulse": "Pulse",
    }
    return HOST_HOME / mapping.get(profile, "SevenOS")


def safe_mount_name(value: str) -> str:
    cleaned = "".join(ch if ch.isalnum() or ch in "-_." else "-" for ch in value.strip())
    cleaned = cleaned.strip(".-")
    return cleaned[:48] or "folder"


def load_folder_grants(profile: str) -> list[dict]:
    data = load_json(state_dir() / "profile-folder-grants.json")
    grants = []
    for raw in (data.get("profiles") or {}).get(profile, []):
        if not isinstance(raw, dict):
            continue
        path = Path(str(raw.get("path", ""))).expanduser()
        try:
            resolved = path.resolve()
        except OSError:
            continue
        if not resolved.is_dir():
            continue
        mode = "rw" if raw.get("mode") == "rw" else "ro"
        name = safe_mount_name(str(raw.get("name") or resolved.name or "folder"))
        grants.append({"name": name, "path": resolved, "mode": mode})
    return grants


def append_folder_grants(command_line: list[str], grants: list[dict]) -> list[str]:
    used = set()
    for grant in grants:
        name = str(grant["name"])
        if name in used:
            suffix = 2
            original = name
            while f"{original}-{suffix}" in used:
                suffix += 1
            name = f"{original}-{suffix}"
        used.add(name)
        target = f"/external/{name}"
        bind = "--bind" if grant.get("mode") == "rw" else "--ro-bind"
        command_line.extend(["--dir", "/external", bind, str(grant["path"]), target])
    return command_line


def default_isolation_mode(profile: str, rootfs: bool = False) -> str:
    if os.environ.get("SEVENOS_PROFILE_ISOLATION"):
        return os.environ["SEVENOS_PROFILE_ISOLATION"]
    if is_system_profile(profile):
        return "system"
    if profile in {"shield"}:
        return "strict"
    if rootfs:
        return "balanced"
    return "balanced"


def isolation_policy(profile: str, mode: str) -> dict:
    policies = {
        "system": {
            "network": "host",
            "dev": "host",
            "runtime_dir": "host",
            "dbus": "host",
            "gpu": "host",
            "audio": "host-runtime",
            "vm_equivalent": False,
            "package_boundary": "global-pacman-store",
        },
        "balanced": {
            "network": "shared",
            "dev": "host",
            "runtime_dir": "shared",
            "dbus": "available-through-runtime",
            "gpu": "host",
            "audio": "host-runtime",
            "vm_equivalent": False,
        },
        "strict": {
            "network": "disabled",
            "dev": "minimal",
            "runtime_dir": "not-mounted-by-default",
            "dbus": "blocked-by-default",
            "gpu": "blocked-by-default",
            "audio": "blocked-by-default",
            "vm_equivalent": False,
        },
        "independent": {
            "network": "shared-native",
            "dev": "host",
            "runtime_dir": "shared",
            "dbus": "available-through-runtime",
            "gpu": "host",
            "audio": "host-runtime",
            "vm_equivalent": False,
            "rootfs_required": True,
            "rootfs_mount": "read-only",
            "package_boundary": "profile-rootfs",
        },
    }
    policy = policies.get(mode, policies["balanced"]).copy()
    policy["profile"] = profile
    policy["mode"] = mode
    return policy


ROOTFS_MAINTENANCE_COMMANDS = {"pacman", "paru", "yay", "makepkg"}


def is_system_profile(profile: str) -> bool:
    return profile == SYSTEM_PROFILE and os.environ.get("SEVENOS_EQUINOX_FORCE_ISOLATION") != "1"


def ensure_profile_requirements(profile: str, command_name: str) -> bool:
    runner = Path(__file__).resolve().parent / "seven-profile-requirements"
    if not runner.exists():
        return False
    if os.environ.get("SEVENOS_PROFILE_REQUIREMENTS_AUTO", "1") == "0":
        return False
    args = [str(runner), "ensure", profile, "--apply", "--yes", "--command", command_name]
    if os.environ.get("SEVENOS_PROFILE_REQUIREMENTS_OPTIONAL") == "1":
        args.append("--optional")
    result = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=False)
    if result.returncode != 0 and result.stderr:
        print(result.stderr.strip(), file=sys.stderr)
    return result.returncode == 0


def package_db(rootfs: Path) -> list[dict]:
    local = rootfs / "var/lib/pacman/local"
    packages = []
    if not local.is_dir():
        return packages
    for desc in sorted(local.glob("*/desc")):
        data = {"id": desc.parent.name}
        try:
            lines = desc.read_text(encoding="utf-8", errors="ignore").splitlines()
        except OSError:
            continue
        key = None
        for line in lines:
            if line.startswith("%") and line.endswith("%"):
                key = line.strip("%").lower()
                continue
            if key and line:
                data[key] = line
                key = None
        packages.append({
            "name": data.get("name", desc.parent.name.rsplit("-", 2)[0]),
            "version": data.get("version", ""),
        })
    return packages


def rootfs_fingerprint(rootfs: Path) -> dict:
    packages = package_db(rootfs)
    package_fingerprint = hashlib.sha256(
        "\n".join(f"{item['name']}={item['version']}" for item in packages).encode("utf-8")
    ).hexdigest()
    try:
        os_release_hash = hashlib.sha256((rootfs / "etc/os-release").read_bytes()).hexdigest()
    except OSError:
        os_release_hash = ""
    try:
        marker = (rootfs / "etc/sevenos-profile").read_text(encoding="utf-8", errors="ignore").strip()
    except OSError:
        marker = ""
    return {
        "marker": marker,
        "os_release_sha256": os_release_hash,
        "package_count": len(packages),
        "package_fingerprint": package_fingerprint,
    }


USER_DIRS = {
    "DESKTOP": "Desktop",
    "DOWNLOAD": "Downloads",
    "TEMPLATES": "Templates",
    "PUBLICSHARE": "Public",
    "DOCUMENTS": "Documents",
    "MUSIC": "Music",
    "PICTURES": "Pictures",
    "VIDEOS": "Videos",
    "CODE": "Code",
}


def ensure_profile_user_dirs(home: Path) -> None:
    for dirname in USER_DIRS.values():
        (home / dirname).mkdir(parents=True, exist_ok=True)
    config = home / ".config"
    config.mkdir(parents=True, exist_ok=True)
    lines = [
        'XDG_DESKTOP_DIR="$HOME/Desktop"',
        'XDG_DOWNLOAD_DIR="$HOME/Downloads"',
        'XDG_TEMPLATES_DIR="$HOME/Templates"',
        'XDG_PUBLICSHARE_DIR="$HOME/Public"',
        'XDG_DOCUMENTS_DIR="$HOME/Documents"',
        'XDG_MUSIC_DIR="$HOME/Music"',
        'XDG_PICTURES_DIR="$HOME/Pictures"',
        'XDG_VIDEOS_DIR="$HOME/Videos"',
    ]
    (config / "user-dirs.dirs").write_text("\n".join(lines) + "\n", encoding="utf-8")


def xdg_user_dir_env(home_prefix: str) -> dict[str, str]:
    return {
        "XDG_DESKTOP_DIR": f"{home_prefix}/Desktop",
        "XDG_DOWNLOAD_DIR": f"{home_prefix}/Downloads",
        "XDG_TEMPLATES_DIR": f"{home_prefix}/Templates",
        "XDG_PUBLICSHARE_DIR": f"{home_prefix}/Public",
        "XDG_DOCUMENTS_DIR": f"{home_prefix}/Documents",
        "XDG_MUSIC_DIR": f"{home_prefix}/Music",
        "XDG_PICTURES_DIR": f"{home_prefix}/Pictures",
        "XDG_VIDEOS_DIR": f"{home_prefix}/Videos",
        "SEVENOS_CODE_DIR": f"{home_prefix}/Code",
    }


def append_setenv(command_line: list[str], values: dict[str, str]) -> None:
    for key, value in values.items():
        command_line.extend(["--setenv", key, value])


def verify_rootfs_seal(profile: str, rootfs: Path, *, required: bool) -> tuple[bool, str]:
    seal_path = HOST_HOME / ".local/share/sevenos/profile-rootfs" / profile / "seal.json"
    seal = load_json(seal_path)
    if not seal:
        return (not required, f"rootfs seal missing: {seal_path}")
    current = rootfs_fingerprint(rootfs)
    checks = {
        "marker": current["marker"] == profile,
        "os_release": current["os_release_sha256"] == seal.get("os_release_sha256"),
        "packages": current["package_fingerprint"] == seal.get("package_fingerprint"),
    }
    if all(checks.values()):
        return True, "rootfs seal verified"
    failed = ", ".join(key for key, ok in checks.items() if not ok)
    return False, f"rootfs seal mismatch for {profile}: {failed}"


def runtime_manifest(profile: str, isolation: dict) -> dict:
    roots = profile_roots(profile, isolation)
    workspace = default_workspace(profile)
    system_profile = is_system_profile(profile)
    engine = "host" if system_profile else ("bubblewrap" if shutil.which("bwrap") else "host-scope")
    workspace_policy = "host-home" if system_profile else "explicit-bind-only"
    home_hint = str(HOST_HOME) if system_profile else "/profile/home in strict container mode"
    config_hint = str(HOST_HOME / ".config") if system_profile else "/profile/config in strict container mode"
    cache_hint = str(HOST_HOME / ".cache") if system_profile else "/profile/cache in strict container mode"
    data_hint = str(HOST_HOME / ".local/share") if system_profile else "/profile/data in strict container mode"
    user_dir_prefix = str(HOST_HOME) if system_profile else "/profile/home"
    return {
        "schema": "sevenos.profile-runtime-manifest.v1",
        "profile": profile,
        "active_profile": active_profile(),
        "engine": engine,
        "container_available": shutil.which("bwrap") is not None,
        "systemd_scope_available": shutil.which("systemd-run") is not None,
        "roots": {key: str(path) for key, path in roots.items()},
        "workspace": {
            "default": str(workspace),
            "exists": workspace.is_dir(),
            "sandbox_path": "native" if system_profile else "/workspace",
            "policy": workspace_policy,
        },
        "external_folders": [
            {"name": item["name"], "path": str(item["path"]), "mode": item["mode"], "sandbox_path": f"/external/{item['name']}"}
            for item in load_folder_grants(profile)
        ],
        "environment": {
            "SEVENOS_EXEC_PROFILE": profile,
            "SEVENOS_PROFILE_CONTAINER": "host" if system_profile else profile,
            "SEVENOS_SYSTEM_PROFILE": "1" if system_profile else "0",
            "SEVENOS_WORKSPACE": "native host path" if system_profile else "/workspace when --workspace or --workspace-profile is used",
            "SEVENOS_EPHEMERAL": "not used for system profile" if system_profile else "1 when --ephemeral is used",
            "SEVENOS_ROOTFS_WRITABLE": "not used for system profile" if system_profile else "1 only during explicit --rootfs-writable maintenance sessions",
            "HOME": home_hint,
            "XDG_CONFIG_HOME": config_hint,
            "XDG_CACHE_HOME": cache_hint,
            "XDG_DATA_HOME": data_hint,
            "XDG_DOWNLOAD_DIR": f"{user_dir_prefix}/Downloads",
            "XDG_DOCUMENTS_DIR": f"{user_dir_prefix}/Documents",
            "XDG_MUSIC_DIR": f"{user_dir_prefix}/Music",
            "XDG_PICTURES_DIR": f"{user_dir_prefix}/Pictures",
            "XDG_VIDEOS_DIR": f"{user_dir_prefix}/Videos",
            "SEVENOS_CODE_DIR": f"{user_dir_prefix}/Code",
            "PATH": "normal host PATH" if system_profile else "/profile/bin first in strict container mode",
        },
        "commands": {
            "inspect": f"seven-profile-run --profile {profile} --manifest",
            "strict_shell": f"seven profile exec {profile} --container sh",
            "workspace_shell": f"seven profile exec {profile} --container --workspace-profile sh",
            "ephemeral_shell": f"seven profile exec {profile} --ephemeral sh",
            "run_app": f"seven profile exec {profile} --container <command>",
            "independent_shell": f"seven profile exec {profile} --independent sh",
            "independent_app": f"seven profile exec {profile} --independent <command>",
            "rootfs_shell": f"seven profile exec {profile} --rootfs sh",
            "rootfs_maintenance": f"seven profile exec {profile} --rootfs-writable sh",
        },
        "policy": {
            "packages": "direct global pacman-store access" if system_profile else "global-pacman-store with profile package view",
            "native_independence": "system admin profile uses the host directly" if system_profile else "use --independent for sealed read-only rootfs plus profile HOME/cache/data without VM",
            "rootfs": "not applicable for system profile" if system_profile else "read-only by default when --rootfs is requested and profile rootfs is ready",
            "rootfs_writable": "not applicable for system profile" if system_profile else "explicit maintenance mode only with --rootfs-writable",
            "seal": "verified before rootfs execution when a seal exists; required in strict mode",
            "isolation": isolation_policy(profile, default_isolation_mode(profile)),
            "app_data": "host-home-cache-data" if system_profile else "profile-config-home-cache-data",
            "workspace": workspace_policy,
            "ephemeral": "not used for system profile" if system_profile else "temporary-home-cache-data",
            "runtime": "host-process" if system_profile else ("systemd-user-scope" if shutil.which("systemd-run") else "direct-process"),
        },
    }


def print_status(profile: str, isolation: dict) -> int:
    manifest = runtime_manifest(profile, isolation)
    payload = {
        "schema": "sevenos.profile-run.v1",
        "profile": profile,
        "active_profile": active_profile(),
        "engine": manifest["engine"],
        "container_available": manifest["container_available"],
        "systemd_scope_available": manifest["systemd_scope_available"],
        "roots": manifest["roots"],
        "boundary": {
            "packages": "global-pacman-store",
            "app_data": "profile-config-home-cache-data",
            "rootfs": "read-only-by-default",
            "rootfs_writable": "explicit-maintenance-only",
            "workspace": "explicit-bind-only",
            "ephemeral": "available-with-ephemeral-flag",
            "runtime": "systemd-user-scope",
            "note": "SevenOS isolates execution state and services; pacman packages remain globally installed on Arch.",
        },
        "workspace_mount": {
            "supported": True,
            "flag": "--workspace PATH",
            "profile_flag": "--workspace-profile",
            "sandbox_path": "/workspace",
            "default": "disabled unless explicitly requested",
            "profile_default": manifest["workspace"]["default"],
            "profile_default_exists": manifest["workspace"]["exists"],
        },
        "ephemeral": {
            "supported": True,
            "flag": "--ephemeral",
            "state": "temporary HOME/cache/data removed after command exit",
            "workspace_policy": "workspace mounts remain explicit and are not deleted",
        },
        "manifest": manifest,
    }
    print(json.dumps(payload, indent=2))
    return 0


def main() -> int:
    if len(sys.argv) < 2:
        print("Usage: seven-profile-run [--profile PROFILE] [--container|--rootfs|--independent] [--rootfs-writable] [--isolation balanced|strict|independent] [--ephemeral] [--workspace PATH|--workspace-profile] [--json|--manifest] <command> [args...]", file=sys.stderr)
        return 2

    use_container = False
    use_rootfs = False
    rootfs_writable = False
    isolation_mode = None
    verify_seal = True
    seal_required = False
    json_status = False
    manifest_status = False
    forced_profile = None
    workspace_path = None
    use_profile_workspace = False
    ephemeral = False
    raw_args = sys.argv[1:]
    while raw_args:
        if raw_args[0] == "--container":
            use_container = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--rootfs":
            use_rootfs = True
            use_container = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--independent":
            use_rootfs = True
            use_container = True
            isolation_mode = "independent"
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--rootfs-writable":
            rootfs_writable = True
            use_rootfs = True
            use_container = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--isolation":
            if len(raw_args) < 2 or raw_args[1] not in {"balanced", "strict", "independent"}:
                print("[SevenOS] --isolation requires: balanced, strict or independent", file=sys.stderr)
                return 2
            isolation_mode = raw_args[1]
            if isolation_mode == "independent":
                use_rootfs = True
                use_container = True
            raw_args = raw_args[2:]
            continue
        if raw_args[0] == "--no-seal-verify":
            verify_seal = False
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--seal-required":
            seal_required = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--ephemeral":
            ephemeral = True
            use_container = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] in ("--json", "status", "--status"):
            json_status = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--manifest":
            manifest_status = True
            raw_args = raw_args[1:]
            continue
        if raw_args[0] == "--profile":
            if len(raw_args) < 2:
                print("[SevenOS] --profile requires a profile key", file=sys.stderr)
                return 2
            forced_profile = raw_args[1]
            raw_args = raw_args[2:]
            continue
        if raw_args[0] in ("--workspace", "--project"):
            if len(raw_args) < 2:
                print("[SevenOS] --workspace requires a path", file=sys.stderr)
                return 2
            workspace_path = Path(raw_args[1]).expanduser().resolve()
            if not workspace_path.exists() or not workspace_path.is_dir():
                print(f"[SevenOS] workspace path not found or not a directory: {workspace_path}", file=sys.stderr)
                return 2
            raw_args = raw_args[2:]
            continue
        if raw_args[0] == "--workspace-profile":
            use_profile_workspace = True
            raw_args = raw_args[1:]
            continue
        break

    isolation = load_json(state_dir() / "profile-isolation.json")
    active = forced_profile or active_profile()
    if active not in known_profiles(isolation):
        print(f"[SevenOS] unknown profile: {active}", file=sys.stderr)
        return 2
    system_profile = is_system_profile(active)
    if system_profile:
        use_container = False
        use_rootfs = False
        rootfs_writable = False
        ephemeral = False

    if json_status and not raw_args:
        return print_status(active, isolation)
    if manifest_status and not raw_args:
        print(json.dumps(runtime_manifest(active, isolation), indent=2))
        return 0

    if use_profile_workspace and workspace_path is None:
        workspace_path = default_workspace(active)
        workspace_path.mkdir(parents=True, exist_ok=True)

    if not raw_args:
        print("Usage: seven-profile-run [--profile PROFILE] [--container|--rootfs|--independent] [--rootfs-writable] [--isolation balanced|strict|independent] [--ephemeral] [--workspace PATH|--workspace-profile] <command> [args...]", file=sys.stderr)
        return 2

    command = raw_args[0]
    command_name = Path(command).name
    args = raw_args[1:]
    runtime = load_json(state_dir() / "runtime.json")
    active_commands = set(isolation.get("active_commands") or [])
    inactive_commands = set(isolation.get("inactive_commands") or [])

    if not isolation:
        print("[SevenOS] WARN: profile isolation state missing; run: seven profile isolation apply --yes", file=sys.stderr)
    elif not system_profile and not forced_profile and command_name in inactive_commands and command_name not in active_commands:
        selected = ", ".join(isolation.get("selected_profiles") or [active])
        owners = []
        for profile, commands in {
            "forge": ["docker", "node", "npm", "pnpm", "python", "cargo", "go", "code", "nvim", "helix", "hx", "podman", "buildah", "skopeo", "caddy", "seven-deploy", "ssh", "rsync", "jq"],
            "baobab": ["seven-reader", "foliate", "calibre", "ebook-viewer", "espeak-ng", "festival", "trans"],
            "shield": ["nmap", "wireshark", "tcpdump", "sqlmap", "zaproxy", "msfconsole", "aircrack-ng"],
            "studio": ["gimp", "krita", "inkscape", "blender", "kdenlive", "obs", "obs-studio", "audacity"],
            "windows": ["wine", "winetricks", "lutris", "virt-manager", "virt-install"],
            "pulse": ["gamemoderun", "game-mode", "gamescope", "mangohud", "vulkaninfo", "lutris"],
        }.items():
            if command_name in commands:
                owners.append(profile)
        owner_hint = ", ".join(owners) if owners else "another profile"
        print(
            f"[SevenOS] {command_name} belongs to {owner_hint}, but the active runtime is {selected}.",
            file=sys.stderr,
        )
        print(f"[SevenOS] Activate a matching profile or run: seven runtime activate {active} {' '.join(owners)} --apply --yes", file=sys.stderr)
        return 126

    shims_dir = str(HOST_HOME / ".local/share/sevenos/profile-shims")
    roots = profile_roots(active, isolation)
    package_view = roots["package_view"]
    search_path = os.pathsep.join(
        item for item in os.environ.get("PATH", "").split(os.pathsep)
        if item
        and os.path.abspath(item) != os.path.abspath(shims_dir)
        and "profile-package-views" not in item
        and (not system_profile or "/.local/share/sevenos/profile-containers/" not in item)
    )
    profile_search_path = search_path if system_profile else os.pathsep.join([str(package_view), search_path])
    if os.path.isabs(command):
        executable = command if Path(command).exists() else None
        if not system_profile and command_name in inactive_commands and command_name not in active_commands:
            selected = ", ".join(isolation.get("selected_profiles") or [active])
            print(f"[SevenOS] absolute command blocked outside active package view: {command_name} ({selected})", file=sys.stderr)
            return 126
    else:
        executable = shutil.which(command_name, path=profile_search_path)
    if not executable:
        if not system_profile and ensure_profile_requirements(active, command_name):
            executable = shutil.which(command_name, path=profile_search_path)
            if executable:
                print(f"[SevenOS] Installed missing {active} requirements; continuing with {command_name}.", file=sys.stderr)
            else:
                print(f"[SevenOS] Installed {active} requirements, but {command_name} is still not visible in the active package view.", file=sys.stderr)
                print(f"[SevenOS] Refresh isolation: seven profile isolation apply {active} --yes", file=sys.stderr)
                return 127
        else:
            if system_profile:
                print(f"[SevenOS] command not found in host PATH: {command_name}", file=sys.stderr)
            else:
                print(f"[SevenOS] Missing requirements for {active}. Run: seven profile requirements {active} --apply --yes", file=sys.stderr)
                print(f"[SevenOS] command not visible in active mini OS package view: {command_name}", file=sys.stderr)
            return 127

    slice_name = (
        runtime.get("resource_plan", {})
        .get("cpu", {})
        .get("primary_slice")
        or f"seven-{active}.slice"
    )
    env = os.environ.copy()
    env["SEVENOS_ACTIVE_PROFILE"] = active
    env["SEVENOS_PROFILE"] = active
    env["SEVENOS_RUNTIME_SLICE"] = slice_name
    env["SEVENOS_EXEC_PROFILE"] = active
    env["SEVENOS_PACKAGE_VIEW"] = "" if system_profile else str(package_view)
    env["PATH"] = profile_search_path
    isolation_mode = isolation_mode or default_isolation_mode(active, use_rootfs)
    policy = isolation_policy(active, isolation_mode)
    env["SEVENOS_ISOLATION_MODE"] = isolation_mode
    folder_grants = load_folder_grants(active)
    if folder_grants:
        env["SEVENOS_EXTERNAL_FOLDERS"] = ":".join(f"/external/{item['name']}" for item in folder_grants)
    elif system_profile:
        env.pop("SEVENOS_EXTERNAL_FOLDERS", None)
    if system_profile and env.get("XDG_DATA_DIRS"):
        env["XDG_DATA_DIRS"] = os.pathsep.join(
            item for item in env["XDG_DATA_DIRS"].split(os.pathsep)
            if item and "/.local/share/sevenos/profile-containers/" not in item
        )
    host_config = roots["config"]
    host_home = roots["home"]
    host_cache = roots["cache"]
    host_data = roots["data"]
    for path in (host_config, host_home, host_cache, host_data):
        path.mkdir(parents=True, exist_ok=True)
    ensure_profile_user_dirs(host_home)
    env.update({
        "HOME": str(host_home),
        "XDG_CONFIG_HOME": str(host_config),
        "XDG_CACHE_HOME": str(host_cache),
        "XDG_DATA_HOME": str(host_data),
        "SEVENOS_PROFILE_CONTAINER": "host" if system_profile else active,
        "SEVENOS_SYSTEM_PROFILE": "1" if system_profile else "0",
    })
    env.update(xdg_user_dir_env(str(host_home)))

    if use_rootfs:
        rootfs = roots["rootfs"]
        if not shutil.which("bwrap"):
            print("[SevenOS] --rootfs requires bubblewrap", file=sys.stderr)
            return 126
        if not (rootfs / "usr/bin").is_dir():
            print(f"[SevenOS] rootfs for {active} is not ready: {rootfs}", file=sys.stderr)
            print(f"[SevenOS] build it with: seven profile-rootfs build {active} --apply --yes", file=sys.stderr)
            return 126
        if not rootfs_writable and command_name in ROOTFS_MAINTENANCE_COMMANDS:
            print(f"[SevenOS] {command_name} needs writable rootfs maintenance mode for {active}.", file=sys.stderr)
            print(f"[SevenOS] Run: seven profile exec {active} --rootfs-writable {command_name} {' '.join(args)}", file=sys.stderr)
            print("[SevenOS] Then verify and reseal: seven profile-rootfs verify all && seven profile-rootfs seal all --apply --yes", file=sys.stderr)
            return 126
        rootfs_path = shutil.which(command_name, path=os.pathsep.join([str(rootfs / "usr/local/bin"), str(rootfs / "usr/bin"), str(rootfs / "bin")]))
        if not rootfs_path:
            print(f"[SevenOS] command not found inside {active} rootfs: {command_name}", file=sys.stderr)
            return 127
        if verify_seal:
            ok, message = verify_rootfs_seal(active, rootfs, required=seal_required or isolation_mode == "strict")
            if not ok:
                print(f"[SevenOS] {message}", file=sys.stderr)
                print("[SevenOS] Run: seven profile-rootfs verify all", file=sys.stderr)
                print("[SevenOS] To reseal after an intentional rebuild: seven profile-rootfs seal all --apply --yes", file=sys.stderr)
                return 125
            if message.startswith("rootfs seal missing"):
                print(f"[SevenOS] WARN: {message}", file=sys.stderr)
        if rootfs_writable:
            print(
                "[SevenOS] WARN: rootfs writable maintenance mode is active; run `seven profile-rootfs verify all` and reseal after intentional package changes.",
                file=sys.stderr,
            )
        config = roots["config"]
        home = roots["home"]
        cache = roots["cache"]
        data = roots["data"]
        for path in (config, home, cache, data):
            path.mkdir(parents=True, exist_ok=True)
        ensure_profile_user_dirs(home)
        sandbox_config = "/profile/config"
        sandbox_home = "/profile/home"
        sandbox_cache = "/profile/cache"
        sandbox_data = "/profile/data"
        sandbox_workspace = "/workspace"
        rootfs_executable = "/" + str(Path(rootfs_path).relative_to(rootfs)).lstrip("/")
        env.update({
            "HOME": sandbox_home,
            "XDG_CONFIG_HOME": sandbox_config,
            "XDG_CACHE_HOME": sandbox_cache,
            "XDG_DATA_HOME": sandbox_data,
            "SEVENOS_PROFILE_CONTAINER": active,
            "SEVENOS_ROOTFS": "/",
            "SEVENOS_ROOTFS_WRITABLE": "1" if rootfs_writable else "0",
            "SEVENOS_ISOLATION_MODE": isolation_mode,
            "PATH": "/usr/local/bin:/usr/bin:/bin",
        })
        env.update(xdg_user_dir_env(sandbox_home))
        runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
        command_line = [
            "bwrap",
            "--die-with-parent",
            "--unshare-ipc",
            "--unshare-uts",
            "--bind" if rootfs_writable else "--ro-bind", str(rootfs), "/",
            "--proc", "/proc",
            "--tmpfs", "/tmp",
            "--bind", str(config), sandbox_config,
            "--bind", str(home), sandbox_home,
            "--bind", str(cache), sandbox_cache,
            "--bind", str(data), sandbox_data,
            "--setenv", "HOME", sandbox_home,
            "--setenv", "XDG_CONFIG_HOME", sandbox_config,
            "--setenv", "XDG_CACHE_HOME", sandbox_cache,
            "--setenv", "XDG_DATA_HOME", sandbox_data,
            "--setenv", "SEVENOS_PROFILE_CONTAINER", active,
            "--setenv", "SEVENOS_ROOTFS", "/",
            "--setenv", "SEVENOS_ROOTFS_WRITABLE", "1" if rootfs_writable else "0",
            "--setenv", "SEVENOS_ISOLATION_MODE", isolation_mode,
            "--setenv", "PATH", "/usr/local/bin:/usr/bin:/bin",
        ]
        append_setenv(command_line, xdg_user_dir_env(sandbox_home))
        if policy["network"] == "disabled":
            command_line.insert(2, "--unshare-net")
        if policy["dev"] == "minimal":
            command_line.extend(["--dev", "/dev"])
        else:
            command_line.extend(["--dev-bind", "/dev", "/dev"])
        if workspace_path:
            command_line.extend([
                "--bind", str(workspace_path), sandbox_workspace,
                "--setenv", "SEVENOS_WORKSPACE", sandbox_workspace,
            ])
        append_folder_grants(command_line, folder_grants)
        command_line.extend(["--chdir", sandbox_workspace if workspace_path else sandbox_home])
        if runtime_dir and policy["runtime_dir"] == "shared":
            command_line.extend(["--bind-try", runtime_dir, runtime_dir, "--setenv", "XDG_RUNTIME_DIR", runtime_dir])
        elif runtime_dir:
            command_line.extend(["--unsetenv", "XDG_RUNTIME_DIR", "--unsetenv", "DBUS_SESSION_BUS_ADDRESS"])
        command_line.extend([rootfs_executable, *args])
        if shutil.which("systemd-run"):
            command_line = ["systemd-run", "--user", "--scope", f"--slice={slice_name}", "--quiet", *command_line]
        result = subprocess.run(command_line, env=env, check=False)
        return int(result.returncode)

    if use_container and shutil.which("bwrap"):
        temp_context = None
        if ephemeral:
            temp_context = tempfile.TemporaryDirectory(prefix=f"sevenos-{active}-ephemeral-")
            temp_root = Path(temp_context.name)
            roots = {
                "config": temp_root / "config",
                "home": temp_root / "home",
                "cache": temp_root / "cache",
                "data": temp_root / "data",
            }
        else:
            roots = profile_roots(active, isolation)
        config = roots["config"]
        home = roots["home"]
        cache = roots["cache"]
        data = roots["data"]
        package_view = profile_roots(active, isolation)["package_view"]
        for path in (config, home, cache, data):
            path.mkdir(parents=True, exist_ok=True)
        ensure_profile_user_dirs(home)
        package_view.mkdir(parents=True, exist_ok=True)
        sandbox_config = "/profile/config"
        sandbox_home = "/profile/home"
        sandbox_cache = "/profile/cache"
        sandbox_data = "/profile/data"
        sandbox_bin = "/profile/bin"
        sandbox_workspace = "/workspace"
        env.update({
            "HOME": sandbox_home,
            "XDG_CONFIG_HOME": sandbox_config,
            "XDG_CACHE_HOME": sandbox_cache,
            "XDG_DATA_HOME": sandbox_data,
            "SEVENOS_PROFILE_CONTAINER": active,
            "SEVENOS_PACKAGE_VIEW": sandbox_bin,
            "SEVENOS_ISOLATION_MODE": isolation_mode,
            "PATH": os.pathsep.join([sandbox_bin, "/usr/local/bin", "/usr/bin"]),
        })
        env.update(xdg_user_dir_env(sandbox_home))
        if ephemeral:
            env["SEVENOS_EPHEMERAL"] = "1"
        if workspace_path:
            env["SEVENOS_WORKSPACE"] = sandbox_workspace
        runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
        sandbox_executable = f"{sandbox_bin}/{command_name}" if Path(executable).parent == package_view else executable
        command_line = [
            "bwrap",
            "--die-with-parent",
            "--unshare-ipc",
            "--unshare-uts",
            "--proc", "/proc",
            "--tmpfs", "/tmp",
            "--ro-bind", "/usr", "/usr",
            "--ro-bind-try", "/etc", "/etc",
            "--ro-bind-try", "/opt", "/opt",
            "--ro-bind-try", str(ROOT), str(ROOT),
            "--ro-bind-try", "/var/lib/flatpak", "/var/lib/flatpak",
            "--dir", "/profile",
            "--symlink", "usr/bin", "/bin",
            "--symlink", "usr/sbin", "/sbin",
            "--symlink", "usr/lib", "/lib",
            "--symlink", "usr/lib", "/lib64",
            "--bind", str(config), sandbox_config,
            "--bind", str(home), sandbox_home,
            "--bind", str(cache), sandbox_cache,
            "--bind", str(data), sandbox_data,
            "--ro-bind", str(package_view), sandbox_bin,
            "--setenv", "HOME", sandbox_home,
            "--setenv", "XDG_CONFIG_HOME", sandbox_config,
            "--setenv", "XDG_CACHE_HOME", sandbox_cache,
            "--setenv", "XDG_DATA_HOME", sandbox_data,
            "--setenv", "SEVENOS_PROFILE_CONTAINER", active,
            "--setenv", "SEVENOS_PACKAGE_VIEW", sandbox_bin,
            "--setenv", "SEVENOS_ISOLATION_MODE", isolation_mode,
            "--setenv", "PATH", os.pathsep.join([sandbox_bin, "/usr/local/bin", "/usr/bin"]),
        ]
        append_setenv(command_line, xdg_user_dir_env(sandbox_home))
        if policy["network"] == "disabled":
            command_line.insert(2, "--unshare-net")
        if policy["dev"] == "minimal":
            command_line.extend(["--dev", "/dev"])
        else:
            command_line.extend(["--dev-bind", "/dev", "/dev"])
        if workspace_path:
            command_line.extend([
                "--bind", str(workspace_path), sandbox_workspace,
                "--setenv", "SEVENOS_WORKSPACE", sandbox_workspace,
            ])
        append_folder_grants(command_line, folder_grants)
        command_line.extend(["--chdir", sandbox_workspace if workspace_path else sandbox_home])
        if runtime_dir and policy["runtime_dir"] == "shared":
            command_line.extend([
                "--bind-try", runtime_dir, runtime_dir,
                "--setenv", "XDG_RUNTIME_DIR", runtime_dir,
            ])
        elif runtime_dir:
            command_line.extend(["--unsetenv", "XDG_RUNTIME_DIR", "--unsetenv", "DBUS_SESSION_BUS_ADDRESS"])
        command_line.extend([
            sandbox_executable,
            *args,
        ])
        if shutil.which("systemd-run"):
            command_line = [
                "systemd-run",
                "--user",
                "--scope",
                f"--slice={slice_name}",
                "--quiet",
                *command_line,
            ]
        try:
            result = subprocess.run(command_line, env=env, check=False)
            return int(result.returncode)
        finally:
            if temp_context is not None:
                temp_context.cleanup()

    if not system_profile and shutil.which("systemd-run"):
        result = subprocess.run(
            [
                "systemd-run",
                "--user",
                "--scope",
                f"--slice={slice_name}",
                "--quiet",
                executable,
                *args,
            ],
            env=env,
            cwd=str(workspace_path) if workspace_path else None,
            check=False,
        )
        return int(result.returncode)

    result = subprocess.run([executable, *args], env=env, cwd=str(workspace_path) if workspace_path else None, check=False)
    return int(result.returncode)


if __name__ == "__main__":
    raise SystemExit(main())
