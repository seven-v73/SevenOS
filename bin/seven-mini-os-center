          border-color: rgba(47,123,255,0.22);
        }
        .signal { color: rgba(148,92,0,0.82); }
        .accent { color: rgba(47,123,255,0.88); }
        """
    else:
        css += """
        * { font-family: "SF Pro Display", "Inter", system-ui, sans-serif; }
        window.mini-os-window { background: transparent; }
        .root {
          padding: 18px;
          border-radius: 22px;
          background:
            linear-gradient(180deg, rgba(255,255,255,0.105), rgba(255,255,255,0.035)),
            rgba(16,18,25,0.955);
          border: 1px solid rgba(255,255,255,0.135);
          box-shadow: 0 24px 72px rgba(0,0,0,0.48);
