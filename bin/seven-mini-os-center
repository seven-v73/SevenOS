def profile_terminal_mode(key: str) -> str:
    return {
        "forge": "forge",
        "shield": "cyber",
        "windows": "windows",
        "studio": "focus",
        "baobab": "focus",
        "pulse": "dark",
    }.get(key, "classic")


def run_detached(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def memory_command(key: str, label: str, command: str) -> str:
    return (
        f"seven bridge remember --profile {shlex.quote(key)} --app {shlex.quote(label)} >/dev/null 2>&1 || true; "
        f"exec {command}"
    )


def strict_app(key: str, command: str, workspace: bool = True) -> str:
    if key == "equinox":
        return command
    workspace_arg = " --workspace-profile" if workspace else ""
    return f"seven profile exec {key} --container{workspace_arg} {command}"


def boundary_actions(key: str) -> list[tuple[str, str, str]]:
    if key == "equinox":
        return [
            (t("Limite système", "System boundary"), t("Afficher le contrat runtime Equinox côté système hôte", "Show the host-system Equinox runtime contract"), "seven-terminal classic -- bash -lc 'seven-profile-run --profile equinox --json | python -m json.tool; read -r -p \"Press Enter to close...\"'"),
            (t("Terminal système", "System terminal"), t("Ouvrir un terminal SevenOS normal avec le vrai HOME", "Open a normal SevenOS terminal with the real HOME"), "seven-terminal classic"),
            (t("Paquets", "Packages"), t("Voir les paquets Arch depuis le côté admin Equinox", "Open Arch package status from the Equinox admin side"), "seven-terminal admin -- bash -lc 'pacman -Qq | less'"),
            (t("État isolation", "Isolation state"), t("Inspecter l'isolation des mini OS depuis Equinox", "Inspect mini OS isolation while staying in Equinox"), "seven-terminal classic -- bash -lc 'seven profile isolation status; read -r -p \"Press Enter to close...\"'"),
        ]
    return [
        (t("Limite stricte", "Strict boundary"), t("Afficher le contrat HOME/cache/data isolé de ce mini OS", "Show the isolated HOME/cache/data contract for this mini OS"), f"seven-terminal {profile_terminal_mode(key)} -- bash -lc 'seven-profile-run --profile {key} --json | python -m json.tool; read -r -p \"Press Enter to close...\"'"),
        (t("Shell strict", "Strict shell"), t("Ouvrir un shell dans la limite de données de ce mini OS", "Open a shell with this mini OS data boundary"), f"seven-terminal {profile_terminal_mode(key)} -- seven profile exec {key} --container sh"),
        (t("Shell espace", "Workspace shell"), t("Ouvrir un shell strict avec l'espace monté sur /workspace", "Open a strict shell with the mini OS workspace mounted at /workspace"), f"seven-terminal {profile_terminal_mode(key)} -- seven profile exec {key} --container --workspace-profile sh"),
        (t("Shell temporaire", "Ephemeral shell"), t("Ouvrir un shell strict jetable nettoyé à la sortie", "Open a disposable strict shell cleaned on exit"), f"seven-terminal {profile_terminal_mode(key)} -- seven profile exec {key} --ephemeral sh"),
    ]


