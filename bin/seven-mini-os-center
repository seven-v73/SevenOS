def probe() -> int:
    ensure_gi_python()
    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run() -> int:
    if "--probe" in sys.argv:
        return probe()

    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    catalog = load_catalog()
    requested = next((arg for arg in sys.argv[1:] if not arg.startswith("-")), "")
    key = requested or active_profile()
    profiles = catalog.get("profiles", {})
    if key not in profiles:
        key = active_profile()
    meta = profiles.get(key, {})
    profile_ui = load_profile_ui()
    home = profile_ui.get("home_screen") if profile_ui.get("profile") == key and isinstance(profile_ui.get("home_screen"), dict) else default_home_contract(key, meta)
    if not isinstance(home, dict):
        home = default_home_contract(key, meta)
    health = run_json("profile", "status", "--json", fallback=[])
    status = next((item for item in health if item.get("key") == key), {})
    runtime = run_json("runtime", "plan", key, "--json", fallback={})
    isolation = run_json("profile", "isolation", "plan", key, "--json", fallback={})
    strict_runtime = (isolation.get("strict_runtime") or {}).get(key, {}) if isinstance(isolation, dict) else {}
    bridge = bridge_state()
    bridge_overview = bridge_status()
    session = bridge_session(key)
    windows_runtime = windows_bridge_runtime() if key == "windows" else {}

    GLib.set_prgname("SevenMiniOSCenter")
    GLib.set_application_name(meta.get("title", "SevenOS Mini OS"))
    try:
        Gdk.set_program_class("SevenMiniOSCenter")
    except Exception:
        pass

    accent = meta.get("resource_intent", {}).get("gpu", "foreground")
    css = f"""
    * {{ font-family: "SF Pro Display", "Inter", system-ui, sans-serif; }}
    window.mini-os-window {{ background: transparent; }}
    .root {{
      padding: 18px;
      border-radius: 30px;
      background:
        radial-gradient(ellipse at 10% 0%, rgba(137,180,250,0.18), transparent 42%),
        radial-gradient(ellipse at 90% 0%, rgba(166,227,161,0.12), transparent 44%),
        rgba(17,18,25,0.92);
      border: 1px solid rgba(255,255,255,0.13);
    }}
    .eyebrow {{ color: rgba(245,247,250,0.58); font-size: 11px; }}
    .title {{ color: rgba(245,247,250,0.98); font-size: 25px; font-weight: 600; }}
    .subtitle {{ color: rgba(245,247,250,0.68); font-size: 12px; }}
    .card {{
      padding: 14px;
      border-radius: 22px;
      background: rgba(255,255,255,0.065);
      border: 1px solid rgba(255,255,255,0.11);
    }}
    .card-title {{ color: rgba(245,247,250,0.95); font-size: 13px; font-weight: 600; }}
    .card-text {{ color: rgba(245,247,250,0.63); font-size: 11px; }}
    .pill {{
      min-height: 42px;
      border-radius: 999px;
      color: rgba(245,247,250,0.95);
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
    }}
    .pill:hover {{ background: rgba(255,255,255,0.13); }}
    .signal {{ color: rgba(249,226,175,0.86); font-size: 10px; }}
    .accent {{ color: rgba(156,203,255,0.92); font-size: 11px; }}
    .hidden-note {{ color: rgba(245,247,250,0.48); font-size: 10px; }}
    """
    provider = Gtk.CssProvider()
    provider.load_from_data(css.encode("utf-8"))
    Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    window = Gtk.Window(title=meta.get("title", "SevenOS Mini OS"))
    window.set_wmclass("SevenMiniOSCenter", "SevenMiniOSCenter")
    window.set_decorated(False)
    window.set_resizable(False)
    window.set_keep_above(True)
    window.set_position(Gtk.WindowPosition.CENTER)
    window.set_default_size(820, 760)
    window.get_style_context().add_class("mini-os-window")

    root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
    root.get_style_context().add_class("root")
    window.add(root)

    eyebrow = Gtk.Label(label=f"{key.upper()} · mini OS autonome · {accent}", xalign=0)
    eyebrow.get_style_context().add_class("eyebrow")
    root.pack_start(eyebrow, False, False, 0)

    title = Gtk.Label(label=meta.get("title", key.title()), xalign=0)
    title.get_style_context().add_class("title")
    root.pack_start(title, False, False, 0)

    subtitle = Gtk.Label(label=home.get("focus") or meta.get("purpose", meta.get("domain", "")), xalign=0)
    subtitle.set_line_wrap(True)
    subtitle.get_style_context().add_class("subtitle")
    root.pack_start(subtitle, False, False, 0)

    grid = Gtk.Grid()
    grid.set_column_spacing(10)
    grid.set_row_spacing(10)
    root.pack_start(grid, True, True, 0)

    layers = meta.get("layers", {})
    for index, name in enumerate(("kernel", "runtime", "experience", "intelligence")):
        grid.attach(info_card(Gtk, name.title(), compact(layers.get(name))), index % 2, index // 2, 1, 1)

    runtime_summary = runtime.get("resource_plan", {})
    grid.attach(info_card(Gtk, "Resources", compact([
        f"CPU {runtime_summary.get('cpu', {}).get('strategy', 'unknown')}",
        f"RAM {runtime_summary.get('ram', {}).get('strategy', 'unknown')}",
        f"IO {runtime_summary.get('io', {}).get('strategy', 'unknown')}",
    ])), 0, 2, 1, 1)
    grid.attach(info_card(Gtk, "Isolation", compact([
        f"{isolation.get('active_package_count', 0)} active packages",
        f"{isolation.get('inactive_package_count', 0)} quiet packages",
        f"strict {strict_runtime.get('score', 0)}% via {strict_runtime.get('engine', 'planned')}",
        f"{len(isolation.get('service_policy', []))} service rules",
    ])), 1, 2, 1, 1)
    grid.attach(info_card(Gtk, "Home", compact([home.get("title"), home.get("session_restore")])), 0, 3, 1, 1)
    grid.attach(info_card(Gtk, "Library", compact([home.get("library"), *(home.get("collections") or [])], 5)), 1, 3, 1, 1)
    grid.attach(info_card(Gtk, "Workflow", compact(workflow_lines(key), 4)), 0, 4, 1, 1)
    grid.attach(info_card(Gtk, "Autonomy", compact([
        f"{home.get('autonomy_score', 0)}% mini OS score",
        f"AI: {home.get('ai_persona', 'SevenAI')}",
    ])), 1, 4, 1, 1)
    runtime_context = profile_ui.get("runtime_context", {}) if isinstance(profile_ui, dict) else {}
    context_line = "aligned"
    if isinstance(runtime_context, dict) and runtime_context:
        detected = runtime_context.get("detected_title") or runtime_context.get("detected_profile") or "unknown"
        scheduler_group = runtime_context.get("scheduler_group") or runtime_context.get("detected_profile") or "unknown"
        if runtime_context.get("temporary_optimization"):
            context_line = f"temporary: {detected} -> {scheduler_group}"
        else:
            context_line = f"detected: {detected}"

    grid.attach(info_card(Gtk, "Composition", compact([
        f"primary: {runtime.get('primary_profile', {}).get('key', key) if isinstance(runtime.get('primary_profile'), dict) else key}",
        f"injected: {compact((runtime.get('composite_runtime') or {}).get('injected_profiles'), 3)}",
        f"context: {context_line}",
        f"conflicts: {len(runtime.get('conflicts', []))}",
    ])), 0, 5, 2, 1)
    profile_bridge = next((item for item in bridge_overview.get("profiles", []) if item.get("profile") == key), {}) if isinstance(bridge_overview, dict) else {}
    session_tasks = session.get("tasks", []) if isinstance(session.get("tasks"), list) else []
    session_apps = session.get("recent_apps", []) if isinstance(session.get("recent_apps"), list) else []
    grid.attach(info_card(Gtk, "Session Memory", compact([
        f"mood: {session.get('mood', 'ready')}",
        f"apps: {compact(session_apps, 3)}",
        f"tasks: {len(session_tasks)}",
        f"pins: {len(session.get('pinned_objects', []) if isinstance(session.get('pinned_objects'), list) else [])}",
    ], 4)), 0, 6, 1, 1)
    grid.attach(info_card(Gtk, "Bridge", compact([
        f"inbox: {profile_bridge.get('inbox_count', 0)}",
        f"outbox: {profile_bridge.get('outbox_count', 0)}",
        f"objects: {bridge_overview.get('object_count', 0) if isinstance(bridge_overview, dict) else 0}",
        f"recent: {len(session.get('recent_objects', []) if isinstance(session.get('recent_objects'), list) else [])}",
    ], 4)), 1, 6, 1, 1)
    if key == "windows":
        grid.attach(info_card(Gtk, "Windows Runtime", compact([
            f"profile: {windows_runtime.get('active_profile', 'unknown')}",
            f"VM: {windows_runtime.get('vm_state', 'unknown')}",
            f"console: {windows_runtime.get('console', 'unknown')}",
            f"sync: {str(windows_runtime.get('synchronized', False)).lower()}",
            f"next: {windows_runtime.get('recommended_action', 'none')}",
        ], 5)), 0, 7, 2, 1)
    else:
        suggestions = bridge.get("suggestions", []) if isinstance(bridge, dict) else []
        grid.attach(info_card(Gtk, "Borrow", compact([
            f"{item.get('profile')}: {item.get('label')}" for item in suggestions[:3] if isinstance(item, dict)
        ] or ["no suggested capability now"], 3)), 0, 7, 2, 1)

    actions_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_start(actions_box, False, False, 0)
    action_rows = [(str(item.get("label", "")), str(item.get("description", "")), str(item.get("command", ""))) for item in home.get("actions", []) if isinstance(item, dict)] or profile_actions(key)
    for label, tooltip, command in action_rows[:5]:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("pill")
        button.set_tooltip_text(tooltip)
        button.connect("clicked", lambda _button, cmd=command, app_label=label: run_detached(memory_command(key, app_label, cmd)))
        actions_box.pack_start(button, True, True, 0)

    bridge_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_start(bridge_box, False, False, 0)
    for label, tooltip, command in [
        ("Inbox", "Open received SevenOS objects for this mini OS", f"seven-terminal {profile_terminal_mode(key)} -- bash -lc 'seven bridge inbox --profile {key}; read -r -p \"Press Enter to close...\"'"),
        ("Outbox", "Open sent SevenOS objects for this mini OS", f"seven-terminal {profile_terminal_mode(key)} -- bash -lc 'seven bridge outbox --profile {key}; read -r -p \"Press Enter to close...\"'"),
        ("Relations", "Show allowed communication paths between mini OS experiences", f"seven-terminal classic -- bash -lc 'seven bridge relations; read -r -p \"Press Enter to close...\"'"),
        ("Passage", "Preview the transition language toward this mini OS", f"seven-terminal {profile_terminal_mode(key)} -- bash -lc 'seven bridge switch --to {key}; read -r -p \"Press Enter to close...\"'"),
    ]:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("pill")
        button.set_tooltip_text(tooltip)
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        bridge_box.pack_start(button, True, True, 0)

    strict_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_start(strict_box, False, False, 0)
    for label, tooltip, command in [
        ("Strict boundary", "Show the isolated HOME/cache/data contract for this mini OS", f"seven-terminal {profile_terminal_mode(key)} -- bash -lc 'seven-profile-run --profile {key} --json | python -m json.tool; read -r -p \"Press Enter to close...\"'"),
        ("Strict shell", "Open a shell with this mini OS data boundary", f"seven-terminal {profile_terminal_mode(key)} -- seven profile exec {key} --container sh"),
        ("Workspace shell", "Open a strict shell with the mini OS workspace mounted at /workspace", f"seven-terminal {profile_terminal_mode(key)} -- seven profile exec {key} --container --workspace-profile sh"),
        ("Ephemeral shell", "Open a disposable strict shell cleaned on exit", f"seven-terminal {profile_terminal_mode(key)} -- seven profile exec {key} --ephemeral sh"),
    ]:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("pill")
        button.set_tooltip_text(tooltip)
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        strict_box.pack_start(button, True, True, 0)

    footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
    root.pack_end(footer, False, False, 0)
    for label, command in [
        ("Activate", f"seven profile activate {key}"),
        ("Suggest", "seven mini-os suggest"),
        ("Apply runtime", f"seven runtime activate {key} --apply --yes"),
        ("Apply isolation", f"seven profile isolation apply {key} --yes"),
        ("Profile apps", f"seven profile apps {key}"),
    ]:
        button = Gtk.Button(label=label)
        button.get_style_context().add_class("pill")
        button.connect("clicked", lambda _button, cmd=command: run_detached(cmd))
        footer.pack_start(button, True, True, 0)

    state_line = Gtk.Label(
        label=f"State: {status.get('runtime', {}).get('lifecycle', 'UNKNOWN')} · packages {status.get('installed', 0)}/{status.get('total', 0)} · anti-noise: {compact(meta.get('anti_nuisance'), 2)}",
        xalign=0,
    )
    state_line.get_style_context().add_class("hidden-note")
    root.pack_end(state_line, False, False, 0)

    window.connect("destroy", Gtk.main_quit)
    window.connect("key-press-event", lambda _w, event: Gtk.main_quit() if event.keyval == Gdk.KEY_Escape else False)
    window.show_all()
    Gtk.main()
    return 0


def info_card(Gtk, title: str, text: str):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=7)
    box.set_hexpand(True)
    box.set_vexpand(False)
    box.get_style_context().add_class("card")
    title_label = Gtk.Label(label=title, xalign=0)
    title_label.get_style_context().add_class("card-title")
    text_label = Gtk.Label(label=text, xalign=0)
    text_label.set_line_wrap(True)
    text_label.set_max_width_chars(40)
    text_label.get_style_context().add_class("card-text")
    box.pack_start(title_label, False, False, 0)
    box.pack_start(text_label, False, False, 0)
    return box


if __name__ == "__main__":
    raise SystemExit(run())
