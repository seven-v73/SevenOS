#!/usr/bin/env python3
"""SevenOS mini OS center.

This is a profile-aware surface used by Baobab, Forge, Shield, Studio,
Windows and Pulse while Profile Center remains the global compositor view.
"""

from __future__ import annotations

import json
import os
import shlex
import subprocess
import sys
from pathlib import Path


def ensure_gi_python() -> None:
    if os.environ.get("SEVENOS_GI_PYTHON") == "1":
        return
    try:
        import gi  # noqa: F401
        return
    except Exception:
        system_python = Path("/usr/bin/python")
        if not system_python.exists() or Path(sys.executable).resolve() == system_python:
            return
        result = subprocess.run([str(system_python), "-c", "import gi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        if result.returncode == 0:
            os.environ["SEVENOS_GI_PYTHON"] = "1"
            os.execv(str(system_python), [str(system_python), *sys.argv])


def resolve_root() -> Path:
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and (Path(env_root) / "bin/seven").exists():
        return Path(env_root)
    here = Path(__file__).resolve()
    if (here.parent / "seven").exists():
        return here.parent.parent
    for candidate in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if (candidate / "bin/seven").exists():
            return candidate
    return Path.cwd()


ROOT = resolve_root()
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sevenos"
PROFILE_UI_FILE = CONFIG_DIR / "profile-ui.json"


def run_json(*args: str, fallback=None):
    fallback = {} if fallback is None else fallback
    try:
        out = subprocess.check_output([str(ROOT / "bin/seven"), *args], cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
        return json.loads(out)
    except Exception:
        return fallback


def load_catalog() -> dict:
    try:
        return json.loads((ROOT / "profiles/catalog.json").read_text(encoding="utf-8"))
    except Exception:
        return {}


def load_profile_ui() -> dict:
    try:
        data = json.loads(PROFILE_UI_FILE.read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def default_home_contract(key: str, meta: dict) -> dict:
    fallback = {
        "equinox": ("Daily balance", "Everyday Workspace", 86, "general SevenOS assistant"),
        "baobab": ("African cultural OS", "Baobab Village", 86, "cultural heritage assistant"),
        "forge": ("DevOps cockpit", "Forge Projects & Deployments", 88, "software engineering and deployment assistant"),
        "shield": ("Authorized security lab", "Shield Cases", 88, "defensive security assistant"),
        "studio": ("Creator studio", "Studio Assets", 78, "creative production assistant"),
        "windows": ("Windows bridge", "Windows Apps", 72, "Windows compatibility assistant"),
        "pulse": ("Gaming performance", "Pulse Games", 55, "gaming performance assistant"),
    }
    title, library, score, ai = fallback.get(key, fallback["equinox"])
    return {
        "title": title,
        "focus": meta.get("purpose", meta.get("domain", "")),
        "library": library,
        "collections": meta.get("capabilities", [])[:4],
        "actions": [{"label": label, "description": tooltip, "command": command} for label, tooltip, command in profile_actions(key)],
        "session_restore": f"Restore {meta.get('title', key.title())} workspace",
        "autonomy_score": score,
        "ai_persona": ai,
    }


def bridge_state() -> dict:
    try:
        out = subprocess.check_output([str(ROOT / "bin/seven"), "mini-os", "suggest", "--json"], cwd=ROOT, text=True, env={**os.environ, "SEVENOS_ROOT": str(ROOT)})
        data = json.loads(out)
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}


def windows_bridge_runtime() -> dict:
    return run_json("windows", "bridge-status", "--json", fallback={})


def bridge_status() -> dict:
    return run_json("bridge", "status", "--json", fallback={})


def bridge_session(key: str) -> dict:
    return run_json("bridge", "session", "--profile", key, "--json", fallback={})


def active_profile() -> str:
    payload = run_json("profile", "current", "--json", fallback={})
    return payload.get("key") or "equinox"


def compact(items, limit: int = 4) -> str:
    values = [str(item) for item in (items or []) if str(item).strip()]
    if not values:
        return "none"
    if len(values) <= limit:
        return " · ".join(values)
    return " · ".join(values[:limit]) + f" +{len(values) - limit}"


