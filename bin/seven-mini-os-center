    workflows = {
        "equinox": [
            "Continuity: recent files, active profile, system health",
            "Balance: neutral resources and shared capabilities",
            "Next: pick a mini OS only when the task needs a stronger context",
        ],
        "baobab": [
            "Knowledge tree: roots, library, stories, sound, explore",
            "Collect: source, license, curator, confidence, community review",
            "Offline: local catalog, packs, narration and language tools",
        ],
        "forge": [
            "Cockpit: project, build, containers, services, deploy targets",
            "Observe: logs, health checks, local APIs, release readiness",
            "Protect: secrets stay profile-owned; Shield can audit explicitly",
        ],
        "shield": [
            "Case first: authorized scope, evidence, timeline, report",
            "Guard rails: VPN, recorder, cleanup and visible risk state",
            "Collaborate: audit Forge projects without merging workspaces",
        ],
        "studio": [
            "Atelier: canvas, palettes, captures, assets, exports",
            "Create: Krita, Blender, Kdenlive, Inkscape and media controls",
            "Bridge: send textiles/assets to Baobab or Windows apps on demand",
        ],
        "windows": [
            "Bridge: app-first Wine/Bottles/Lutris before VM",
            "VM: official ISO, VirtIO, qcow2 disk and libvirt network",
            "Sync: enter/leave keeps Windows resources quiet when inactive",
        ],
        "pulse": [
            "Stage: game library, GameMode, recorder, low-latency focus",
            "Tune: MangoHud/Gamescope optional overlays and frame pacing",
            "Protect: gaming services stay quiet outside Pulse",
        ],
    }
    return workflows.get(key, workflows["equinox"])


def profile_terminal_mode(key: str) -> str:
    return {
        "forge": "forge",
        "shield": "cyber",
        "windows": "windows",
        "studio": "focus",
        "baobab": "focus",
        "pulse": "dark",
    }.get(key, "classic")


def run_detached(command: str) -> None:
    subprocess.Popen(
        ["bash", "-lc", command],
        cwd=ROOT,
        env={**os.environ, "SEVENOS_ROOT": str(ROOT)},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def memory_command(key: str, label: str, command: str) -> str:
    return (
        f"seven bridge remember --profile {shlex.quote(key)} --app {shlex.quote(label)} >/dev/null 2>&1 || true; "
        f"exec {command}"
    )


def strict_app(key: str, command: str, workspace: bool = True) -> str:
    workspace_arg = " --workspace-profile" if workspace else ""
    return f"seven profile exec {key} --container{workspace_arg} {command}"


