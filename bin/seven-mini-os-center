        .card-text { color: rgba(245,247,250,0.62); font-size: 11px; }
        .pill {
          min-height: 34px;
          padding: 0 11px;
          border-radius: 10px;
          color: rgba(245,247,250,0.92);
          background: rgba(255,255,255,0.052);
          border: 1px solid rgba(255,255,255,0.09);
          font-size: 11px;
