def probe() -> int:
    ensure_gi_python()
    try:
        import gi
        gi.require_version("Gtk", "3.0")
        from gi.repository import Gtk  # noqa: F401
    except Exception as exc:
        print(f"MISS: {exc}", file=sys.stderr)
        return 1
    print("OK")
    return 0


def run() -> int:
    if "--probe" in sys.argv:
        return probe()

    ensure_gi_python()
    import gi

    gi.require_version("Gdk", "3.0")
    gi.require_version("Gtk", "3.0")
    from gi.repository import Gdk, GLib, Gtk

    catalog = load_catalog()
    requested = next((arg for arg in sys.argv[1:] if not arg.startswith("-")), "")
    key = requested or active_profile()
    profiles = catalog.get("profiles", {})
    if key not in profiles:
        key = active_profile()
    meta = profiles.get(key, {})
    profile_ui = load_profile_ui()
    home = profile_ui.get("home_screen") if profile_ui.get("profile") == key and isinstance(profile_ui.get("home_screen"), dict) else default_home_contract(key, meta)
    if not isinstance(home, dict):
        home = default_home_contract(key, meta)
    health = run_json("profile", "status", "--json", fallback=[])
    status = next((item for item in health if item.get("key") == key), {})
    runtime = run_json("runtime", "plan", key, "--json", fallback={})
    isolation = run_json("profile", "isolation", "plan", key, "--json", fallback={})
    strict_runtime = (isolation.get("strict_runtime") or {}).get(key, {}) if isinstance(isolation, dict) else {}
    bridge = bridge_state()
    bridge_overview = bridge_status()
    session = bridge_session(key)
    windows_runtime = windows_bridge_runtime() if key == "windows" else {}

    GLib.set_prgname("SevenMiniOSCenter")
    GLib.set_application_name(meta.get("title", "SevenOS Mini OS"))
    try:
        Gdk.set_program_class("SevenMiniOSCenter")
    except Exception:
        pass

    accent = meta.get("resource_intent", {}).get("gpu", "foreground")
    css = ""
    if key == "windows":
        css = """
        * { font-family: "SF Pro Display", "Inter", system-ui, sans-serif; }
        window.mini-os-window { background: transparent; }
        .root {
          padding: 18px;
          border-radius: 30px;
          background:
            radial-gradient(ellipse at 10% 0%, rgba(137,180,250,0.18), transparent 42%),
            radial-gradient(ellipse at 90% 0%, rgba(166,227,161,0.12), transparent 44%),
            rgba(17,18,25,0.92);
          border: 1px solid rgba(255,255,255,0.13);
        }
        .eyebrow { color: rgba(245,247,250,0.58); font-size: 11px; }
        .title { color: rgba(245,247,250,0.98); font-size: 25px; font-weight: 500; }
        .subtitle { color: rgba(245,247,250,0.68); font-size: 12px; }
        .card {
          padding: 14px;
          border-radius: 22px;
          background: rgba(255,255,255,0.065);
          border: 1px solid rgba(255,255,255,0.11);
        }
        .card-title { color: rgba(245,247,250,0.95); font-size: 13px; font-weight: 500; }
        .card-text { color: rgba(245,247,250,0.63); font-size: 11px; }
        .pill {
          min-height: 42px;
          border-radius: 999px;
          color: rgba(245,247,250,0.95);
          background: rgba(255,255,255,0.08);
          border: 1px solid rgba(255,255,255,0.12);
        }
        .pill:hover { background: rgba(255,255,255,0.13); }
        .signal { color: rgba(249,226,175,0.86); font-size: 10px; }
        .accent { color: rgba(156,203,255,0.92); font-size: 11px; }
        .hidden-note { color: rgba(245,247,250,0.48); font-size: 10px; }
        """
    if not css:
        css = """
        * { font-family: "SF Pro Display", "Inter", system-ui, sans-serif; }
        window.mini-os-window { background: transparent; }
        .root {
          padding: 18px;
          border-radius: 22px;
          background:
            linear-gradient(180deg, rgba(255,255,255,0.105), rgba(255,255,255,0.035)),
            rgba(16,18,25,0.955);
          border: 1px solid rgba(255,255,255,0.135);
          box-shadow: 0 24px 72px rgba(0,0,0,0.48);
        }
        .eyebrow {
          color: rgba(245,247,250,0.58);
          font-size: 11px;
          letter-spacing: 0;
        }
        .title { color: rgba(245,247,250,0.98); font-size: 20px; font-weight: 500; }
        .subtitle { color: rgba(245,247,250,0.66); font-size: 12px; }
        .card {
          padding: 11px;
          border-radius: 14px;
          background:
            linear-gradient(180deg, rgba(255,255,255,0.060), rgba(255,255,255,0.032)),
            rgba(255,255,255,0.026);
          border: 1px solid rgba(255,255,255,0.095);
        }
        .card-title { color: rgba(245,247,250,0.94); font-size: 12px; font-weight: 500; }
        .card-text { color: rgba(245,247,250,0.62); font-size: 11px; }
        .pill {
          min-height: 34px;
          padding: 0 11px;
          border-radius: 10px;
          color: rgba(245,247,250,0.92);
          background: rgba(255,255,255,0.052);
          border: 1px solid rgba(255,255,255,0.09);
          font-size: 11px;
        }
        .pill:hover {
          background: rgba(255,255,255,0.085);
          border-color: rgba(156,203,255,0.26);
        }
        .signal { color: rgba(249,226,175,0.82); font-size: 10px; }
        .accent { color: rgba(156,203,255,0.86); font-size: 11px; }
        .hidden-note { color: rgba(245,247,250,0.48); font-size: 10px; }
        """
    if seven_theme.current_theme_mode() == "light":
        css += """
        .root {
          background:
            linear-gradient(180deg, rgba(255,255,255,0.92), rgba(245,247,252,0.76)),
            rgba(255,255,255,0.82);
          border-color: rgba(28,31,38,0.10);
          box-shadow: 0 24px 72px rgba(43,63,100,0.16);
        }
        .eyebrow, .subtitle, .card-text, .row-note, .hidden-note { color: rgba(28,31,38,0.58); }
        .title, .card-title, .row-title { color: rgba(28,31,38,0.96); }
        .card {
          background: rgba(255,255,255,0.68);
          border-color: rgba(28,31,38,0.08);
        }
