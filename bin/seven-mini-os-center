        .subtitle { color: rgba(245,247,250,0.66); font-size: 12px; }
        .card {
          padding: 11px;
          border-radius: 14px;
          background:
            linear-gradient(180deg, rgba(255,255,255,0.060), rgba(255,255,255,0.032)),
            rgba(255,255,255,0.026);
          border: 1px solid rgba(255,255,255,0.095);
        }
