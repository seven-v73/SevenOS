        shell_bg = "radial-gradient(ellipse at 0% 0%, alpha(@seven_accent, 0.26), transparent 42%), alpha(@seven_panel, 0.96)"
        hero_bg = "linear-gradient(135deg, alpha(@seven_accent, 0.22), alpha(@seven_wallpaper_cyan, 0.10))"
        card_bg = "alpha(@seven_panel_2, 0.72)"
