def run_json(command: list[str], fallback: dict | None = None, timeout: float = 8.0) -> dict:
    try:
        result = subprocess.run(command, cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, text=True, capture_output=True, check=False, timeout=timeout)
        return json.loads(result.stdout or "{}") if result.stdout.strip() else (fallback or {})
    except Exception:
        return fallback or {}


def command_exists(command: str) -> bool:
    if (ROOT / "bin" / command).exists():
        return True
    return shutil.which(command) is not None


def file_ok(path: str) -> bool:
    full = ROOT / path
    return full.exists() and (full.is_dir() or full.stat().st_size > 0)


def check(
    state: str,
    title: str,
    detail: str,
    command: str = "",
    group: str = "system",
    severity: str = "medium",
    findings: list[str] | None = None,
) -> dict:
    item = {"state": state, "title": title, "detail": detail, "command": command, "group": group, "severity": severity}
    if findings:
        item["findings"] = findings
    return item


def first_run_checks() -> list[dict]:
    checks: list[dict] = []
    required_commands = [
        "seven", "seven-settings-native", "seven-experience-center", "seven-help-native", "seven-hub-native",
        "seven-files", "seven-store", "seven-wallpaper", "seven-waybar", "seven-profile-run",
        "seven-profile-rootfs", "seven-public-studio",
    ]
    for command in required_commands:
        checks.append(check("OK" if command_exists(command) else "MISS", command, tr("Commande publique disponible.", "Public command is available."), f"command -v {command}", "commands", "high"))

    required_assets = [
        "identity/assets/logo-sevenos.svg",
        "identity/assets/symbol-seven-prism.svg",
        "identity/assets/symbol-seven-prism-mark.svg",
        "branding/plymouth/sevenos/seven-prism.png",
        "branding/sddm/sevenos/assets/seven-prism.png",
        "identity/wallpaper/dynamic/manifest.json",
        "seven-hub/seven-experience-center.desktop",
        "seven-hub/seven-public-studio.desktop",
    ]
    for path in required_assets:
        checks.append(check("OK" if file_ok(path) else "MISS", path, tr("Asset système livré avec SevenOS.", "System asset shipped with SevenOS."), "", "assets", "high"))

    dynamic_count = len(list((ROOT / "identity/wallpaper/dynamic").glob("*.svg"))) if (ROOT / "identity/wallpaper/dynamic").is_dir() else 0
    checks.append(check("OK" if dynamic_count >= 94 else "MISS", tr("Fonds dynamiques", "Dynamic wallpapers"), tr(f"{dynamic_count} fond(s) disponible(s).", f"{dynamic_count} wallpaper(s) available."), "seven-wallpaper collection-list", "assets", "high"))

    desktop_entries = [
        "seven-experience-center.desktop",
        "seven-public-studio.desktop",
        "seven-store.desktop",
        "seven-terminal.desktop",
        "seven-doctor.desktop",
    ]
    for entry in desktop_entries:
        repo_entry = list((ROOT / "seven-hub").glob(entry))
        user_entry = Path.home() / ".local/share/applications" / entry
        state = "OK" if repo_entry and repo_entry[0].exists() else "MISS"
        detail = tr("Entrée desktop prête dans le dépôt.", "Desktop entry ready in repository.")
        if state == "OK" and user_entry.exists():
            detail = tr("Entrée desktop prête et installée pour l’utilisateur.", "Desktop entry ready and installed for the user.")
        checks.append(check(state, entry, detail, "", "desktop", "medium"))

    state_scripts = [
        ("scripts/install-cli.sh", tr("Installation CLI", "CLI installation")),
        ("scripts/apply-theme.sh", tr("Application thème", "Theme application")),
        ("scripts/system-install.sh", tr("Installation /opt/SevenOS", "/opt/SevenOS installation")),
        ("scripts/system-assets.sh", tr("Assets système", "System assets")),
        ("scripts/design-check.sh", tr("Design gate", "Design gate")),
    ]
    for path, title in state_scripts:
        checks.append(check("OK" if file_ok(path) else "MISS", title, path, "", "install", "high"))

    assets = run_json([str(ROOT / "scripts/system-assets.sh"), "json"], {}, timeout=12)
    if assets:
        checks.append(check("OK" if assets.get("state") == "OK" else "MISS", tr("Contrat assets système", "System assets contract"), tr(f"État: {assets.get('state')}", f"State: {assets.get('state')}"), "scripts/system-assets.sh doctor", "install", "high"))

    return checks


def iter_scan_files(base: Path):
    skip_dirs = {"node_modules", ".git", "__pycache__", "dist", "build", ".venv", "out", "pkg", "src"}
    allowed_suffixes = {".py", ".sh", ".css", ".scss", ".js", ".ts", ".json", ".jsonc", ".qml", ".ui", ".conf", ".desktop", ""}
    for root, dirs, files in os.walk(base):
        dirs[:] = [item for item in dirs if item not in skip_dirs and not item.startswith(".cache")]
        for name in files:
            path = Path(root) / name
            if path.suffix.lower() not in allowed_suffixes:
                continue
            yield path


def visual_checks() -> list[dict]:
    checks: list[dict] = []
    design = subprocess.run([str(ROOT / "scripts/design-check.sh")], cwd=str(ROOT), env={**os.environ, "SEVENOS_ROOT": str(ROOT)}, text=True, capture_output=True, check=False, timeout=60)
    checks.append(check("OK" if design.returncode == 0 else "WARN", tr("Design coherence gate", "Design coherence gate"), tr("Le gate design est vert.", "Design gate passed.") if design.returncode == 0 else design.stdout[-300:], "scripts/design-check.sh", "visual", "high"))

    surfaces = run_json([str(ROOT / "scripts/surfaces.sh"), "json"], {"score": 0, "summary": {}}, timeout=30)
    surface_score = int(surfaces.get("score", 0) or 0)
    legacy = int((surfaces.get("summary") or {}).get("legacy_blockers", 0) or 0)
    checks.append(check("OK" if surface_score >= 85 and legacy == 0 else "INFO", tr("Surfaces publiques", "Public surfaces"), tr(f"Score {surface_score}% · anciens écrans bloquants {legacy}.", f"Score {surface_score}% · legacy blockers {legacy}."), "seven surfaces doctor", "visual", "high"))

    native_fallback = run_json([str(ROOT / "scripts/native-fallback-gate.sh"), "status", "--json"], {"score": 0, "summary": {}, "state": "unknown"}, timeout=20)
    native_score = int(native_fallback.get("score", 0) or 0)
    native_summary = native_fallback.get("summary") if isinstance(native_fallback.get("summary"), dict) else {}
    checks.append(check(
        "OK" if native_score >= 90 and native_fallback.get("state") == "ready" else "WARN",
        tr("Routes natives avant secours", "Native routes before fallback"),
        tr(
            f"Score {native_score}% · {native_summary.get('ok', 0)}/{native_summary.get('routes', 0)} route(s) ouvrent une surface native avant secours.",
            f"Score {native_score}% · {native_summary.get('ok', 0)}/{native_summary.get('routes', 0)} route(s) open a native surface before fallback.",
        ),
        "seven native-fallback-gate",
        "visual",
        "high",
    ))

    scan_targets = [
        ROOT / "bin",
        ROOT / "seven-hub",
        ROOT / "hyprland",
    ]
    hardcoded_black = 0
    overflowing_windows = 0
    old_screen_terms = 0
    untranslated_visible = 0
    finding_limit = 6
    hardcoded_black_findings: list[str] = []
    overflowing_window_findings: list[str] = []
    old_screen_findings: list[str] = []
    untranslated_findings: list[str] = []
    black_re = re.compile(r"(color\s*:\s*#?000(?:000)?\b|#[0]{6}\b|rgba?\(\s*0\s*,\s*0\s*,\s*0\s*(?:,\s*1(?:\.0)?)?\s*\))", re.I)
    size_re = re.compile(r"set_default_size\(\s*(1[2-9]\d{2}|[2-9]\d{3})\s*,|min-width\s*:\s*(1[2-9]\d{2}|[2-9]\d{3})px", re.I)
    old_re = re.compile(r"\b(rofi\s+-|zenity\s+--|yad\s+--)\b", re.I)
    visible_en_re = re.compile(r"(?:Gtk\.(?:Button|Label)\([^)]*label\s*=\s*|(?<![A-Za-z0-9_])label\s*=\s*)['\"](?:Open|Close|Refresh|Settings|Install|Cancel|Run|Apply)\b")
    for base in scan_targets:
        if not base.exists():
            continue
        for path in iter_scan_files(base):
            try:
                text = path.read_text(encoding="utf-8", errors="ignore")
            except Exception:
                continue
            rel = str(path.relative_to(ROOT))
            for line_no, line in enumerate(text.splitlines(), start=1):
                stripped = line.strip()
                if black_re.search(stripped):
                    if "normalize_hex" not in stripped and "box-shadow" not in stripped and "text-shadow" not in stripped:
                        hardcoded_black += len(black_re.findall(stripped))
                        if len(hardcoded_black_findings) < finding_limit:
                            hardcoded_black_findings.append(f"{rel}:{line_no} {stripped[:96]}")
                if size_re.search(stripped):
                    if "fullscreen()" not in text and "set_resizable(False)" not in text:
                        overflowing_windows += len(size_re.findall(stripped))
                        if len(overflowing_window_findings) < finding_limit:
                            overflowing_window_findings.append(f"{rel}:{line_no} {stripped[:96]}")
                if old_re.search(stripped):
                    old_screen_terms += len(old_re.findall(stripped))
                    if len(old_screen_findings) < finding_limit:
                        old_screen_findings.append(f"{rel}:{line_no} {stripped[:96]}")
                if visible_en_re.search(stripped):
                    untranslated_visible += len(visible_en_re.findall(stripped))
                    if len(untranslated_findings) < finding_limit:
                        untranslated_findings.append(f"{rel}:{line_no} {stripped[:96]}")

    def detail(count: int, fr: str, en: str, findings: list[str]) -> str:
        base = tr(fr.format(count=count), en.format(count=count))
        if not findings:
            return base
        return base + "\n" + "\n".join(f"  - {item}" for item in findings)

    checks.append(check(
        "OK" if hardcoded_black == 0 else "WARN",
        tr("Texte noir dur dans les surfaces", "Hard-coded black text in surfaces"),
        detail(hardcoded_black, "{count} occurrence(s) suspecte(s).", "{count} suspicious occurrence(s).", hardcoded_black_findings),
        "seven visual-gate --json",
        "visual",
        "medium",
    ))
    checks.append(check(
        "OK" if overflowing_windows <= 2 else "WARN",
        tr("Tailles fixes trop larges", "Over-wide fixed sizes"),
        detail(overflowing_windows, "{count} occurrence(s) à surveiller.", "{count} occurrence(s) to review.", overflowing_window_findings),
        "seven visual-gate --json",
        "visual",
        "medium",
    ))
    legacy_state = "OK" if legacy == 0 else "WARN"
    legacy_detail = detail(old_screen_terms, "{count} appel(s) rofi/zenity/yad visible(s).", "{count} visible rofi/zenity/yad call(s).", old_screen_findings)
    if old_screen_terms and legacy == 0:
        legacy_detail = tr(
            f"Aucun ancien écran bloquant dans les surfaces actives. {old_screen_terms} fallback(s) interne(s) conservé(s).",
            f"No blocking legacy screen in active surfaces. {old_screen_terms} internal fallback(s) kept.",
        )
    checks.append(check(
        legacy_state,
        tr("Anciens écrans publics", "Legacy public screens"),
        legacy_detail,
        "seven surfaces doctor",
        "visual",
        "high",
        old_screen_findings,
    ))
    checks.append(check(
        "OK" if untranslated_visible <= 10 else "INFO",
        tr("Libellés possiblement non traduits", "Possibly untranslated labels"),
        detail(untranslated_visible, "{count} libellé(s) anglais brut(s) à vérifier.", "{count} raw English label(s) to review.", untranslated_findings),
        "seven visual-gate --json",
        "visual",
        "low",
    ))
    return checks


def workflow_checks() -> list[dict]:
    checks: list[dict] = []
    workflow = run_json([str(ROOT / "scripts/workflow-gate.sh"), "status", "--json"], {"score": 0, "state": "unknown", "issues": []}, timeout=25)
    score = int(workflow.get("score", 0) or 0)
    state = "OK" if workflow.get("state") == "ready" and score >= 90 else "WARN"
    issues = workflow.get("issues") if isinstance(workflow.get("issues"), list) else []
    detail = tr(
        f"Score {score}% · {len(issues)} parcours à revoir.",
        f"Score {score}% · {len(issues)} workflow(s) to review.",
    )
    checks.append(check(state, tr("Parcours publics guidés", "Guided public workflows"), detail, "seven workflow-gate", "workflow", "high"))

    interaction = run_json([str(ROOT / "scripts/interaction-contract.sh"), "status", "--json"], {"score": 0, "state": "unknown", "issues": []}, timeout=80)
    interaction_score = int(interaction.get("score", 0) or 0)
    checks.append(check(
        "OK" if interaction.get("state") == "ready" and interaction_score >= 90 else "WARN",
        tr("Contrat interaction/accessibilité", "Interaction/accessibility contract"),
        tr(f"Score {interaction_score}% · état {interaction.get('state', 'unknown')}.", f"Score {interaction_score}% · state {interaction.get('state', 'unknown')}."),
        "seven interaction-gate",
        "workflow",
        "high",
    ))

    accessibility = run_json([str(ROOT / "scripts/interaction-contract.sh"), "accessibility", "--json"], {"score": 0, "state": "unknown", "summary": {}}, timeout=80)
    accessibility_score = int(accessibility.get("score", 0) or 0)
    accessibility_summary = accessibility.get("summary") if isinstance(accessibility.get("summary"), dict) else {}
    checks.append(check(
        "OK" if accessibility.get("state") == "ready" and accessibility_score >= 90 else "WARN",
        tr("Accessibilité et focus clavier", "Accessibility and keyboard focus"),
        tr(
            f"Score {accessibility_score}% · {accessibility_summary.get('ok', 0)} contrôle(s) OK.",
            f"Score {accessibility_score}% · {accessibility_summary.get('ok', 0)} check(s) OK.",
        ),
        "seven accessibility-gate",
        "workflow",
        "high",
    ))

    contract_ok = file_ok("identity/WORKFLOW_CONTRACT.md") and file_ok("identity/workflow-contract.json")
    checks.append(check(
        "OK" if contract_ok else "MISS",
        tr("Contrat workflow livré", "Workflow contract shipped"),
        tr("Le contrat des parcours est disponible pour nouvelle machine.", "The workflow contract is available for new machines."),
        "cat identity/WORKFLOW_CONTRACT.md",
        "workflow",
        "high",
    ))
    return checks


