#!/usr/bin/env python3
import argparse
from contextlib import contextmanager
from datetime import datetime, timezone
import errno
import fcntl
from functools import lru_cache
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


PACKAGE_RE = re.compile(r"^[A-Za-z0-9@._+-]+$")


def log(message):
    print(f"[sevenpkg] {message}")


def error(message):
    print(f"[sevenpkg] ERROR: {message}", file=sys.stderr)


def resolve_root():
    env_root = os.environ.get("SEVENOS_ROOT")
    if env_root and Path(env_root, "install.sh").is_file():
        return Path(env_root).resolve()

    script_dir = Path(__file__).resolve().parent
    candidate = script_dir.parent
    if Path(candidate, "install.sh").is_file():
        return candidate

    for path in (Path("/opt/SevenOS"), Path.home() / "Code/OS/SevenOS", Path.home() / "SevenOS"):
        if Path(path, "install.sh").is_file():
            return path

    error("could not find SevenOS repository root")
    sys.exit(1)


ROOT_DIR = resolve_root()
MANIFEST_PATH = ROOT_DIR / "sevenpkg" / "metapackages.json"
ALIASES = {
    "horizon": "forge",
    "vscode": "code",
    "visual-studio-bin": "code",
    "visual-studio-code": "code",
    "visual-studio-code-bin": "code",
}
PROFILE_KEYS = {"equinox", "baobab", "forge", "shield", "studio", "windows", "pulse"}
SYSTEM_PROFILE = "equinox"


def host_home() -> Path:
    if os.environ.get("SEVENOS_HOST_HOME"):
        return Path(os.environ["SEVENOS_HOST_HOME"])
    raw = Path(os.environ.get("HOME", str(Path.home())))
    marker = "/.local/share/sevenos/profile-containers/"
    text = str(raw)
    if marker in text and text.endswith("/home"):
        return Path(text.split(marker, 1)[0])
    user = os.environ.get("USER")
    if user:
        candidate = Path("/home") / user
        if candidate.is_dir():
            return candidate
    return raw


HOST_HOME = host_home()
HOST_CONFIG_HOME = Path(os.environ.get("SEVENOS_HOST_CONFIG_HOME", str(HOST_HOME / ".config")))
HOST_DATA_HOME = Path(os.environ.get("SEVENOS_HOST_DATA_HOME", str(HOST_HOME / ".local/share")))
PROFILE_ROOTFS_DIR = HOST_DATA_HOME / "sevenos" / "profile-rootfs"
PROFILE_CONTAINERS_DIR = HOST_DATA_HOME / "sevenos" / "profile-containers"
GLOBAL_PACKAGE_POLICY_PATH = HOST_CONFIG_HOME / "sevenos" / "global-package-policy.json"
USER_SYSTEMD_DIR = HOST_CONFIG_HOME / "systemd" / "user"
STATE_DIR = Path(os.environ.get("SEVENPKG_STATE_DIR", str(HOST_DATA_HOME / "sevenos" / "sevenpkg")))
TRANSACTION_LOG = STATE_DIR / "transactions.jsonl"
TRANSACTION_LOCK = STATE_DIR / "transaction.lock"


def is_dry_run(args):
    return args.dry_run or os.environ.get("SEVENOS_DRY_RUN") == "1"


def assume_yes() -> bool:
    return os.environ.get("SEVENOS_YES") == "1" or os.environ.get("CI") == "1"


def run(command, args, check=True):
    if is_dry_run(args):
        print(" ".join(shlex_quote(part) for part in command))
        return subprocess.CompletedProcess(command, 0)
    return subprocess.run(command, check=check)


def run_quiet(command):
    return subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0


def shlex_quote(value):
    import shlex

    return shlex.quote(str(value))


def command_exists(command):
    return shutil.which(command) is not None


def daemon_json(action):
    daemon = ROOT_DIR / "bin" / "seven-daemon"
    if not daemon.is_file() or not os.access(daemon, os.X_OK):
        return None

    result = subprocess.run(
        [str(daemon), action, "--json"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        check=False,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return None
    return result.stdout.strip()


def pacman_has(package):
    return subprocess.run(["pacman", "-Si", package], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def package_installed(package):
    installed = installed_package_set()
    if package in installed:
        return True
    return any(alternative in installed for alternative in package_alternatives(package))


def package_present(package, installed):
    if package in installed:
        return True
    return any(alternative in installed for alternative in package_alternatives(package))


def package_alternatives(package):
    return {
        "code": ("visual-studio-code-bin", "vscodium-bin", "vscodium"),
        "visual-studio-code-bin": ("code", "vscodium-bin", "vscodium"),
        "visual-studio-bin": ("code", "vscodium-bin", "vscodium"),
        "p7zip": ("7zip",),
        "7zip": ("p7zip",),
    }.get(package, ())


@lru_cache(maxsize=1)
def installed_package_set():
    if not command_exists("pacman"):
        return set()
    result = subprocess.run(
        ["pacman", "-Qq"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return set()
    return {line.strip() for line in result.stdout.splitlines() if line.strip()}


def paru_has(package):
    if not command_exists("paru"):
        return False
    return subprocess.run(["paru", "-Si", package], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def yay_has(package):
    if not command_exists("yay"):
        return False
    return subprocess.run(["yay", "-Si", package], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def validate_package_name(package):
    if not PACKAGE_RE.match(package):
        error(f"invalid package name: {package}")
        sys.exit(1)


def load_manifest():
    if not MANIFEST_PATH.is_file():
        return {}
    with MANIFEST_PATH.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def normalize_name(name):
    return ALIASES.get(name, name)


def alias_notice(name, normalized):
    if name != normalized:
        print(f"[sevenpkg] '{name}' is retired; using '{normalized}' instead", file=sys.stderr)


def read_package_file(relative_path):
    package_file = ROOT_DIR / relative_path
    packages = []

    if not package_file.is_file():
        return packages

    with package_file.open("r", encoding="utf-8") as handle:
        for line in handle:
            package = line.split("#", 1)[0].strip()
            if package:
                packages.append(package)

    return packages


def meta_packages(meta):
    if meta.get("kind") == "pacman":
        return list(meta.get("packages", []))

    packages = []
    for package_file in meta.get("package_files", []):
        packages.extend(read_package_file(package_file))
    return packages


def meta_optional_packages(meta):
    packages = []
    for package_file in meta.get("optional_package_files", []):
        packages.extend(read_package_file(package_file))
    return packages


def meta_all_packages(meta, include_optional=False):
    packages = list(meta_packages(meta))
    if include_optional:
        packages.extend(meta_optional_packages(meta))
    return packages


def meta_state(meta):
    packages = meta_packages(meta)
    if not packages:
        return "RUN", 0, 0

    installed = sum(1 for package in packages if package_installed(package))
    if installed == len(packages):
        state = "OK"
    elif installed > 0:
        state = "PART"
    else:
        state = "MISS"
    return state, installed, len(packages)


def meta_state_for_profile(meta, profile):
    packages = meta_packages(meta)
    if not packages:
        return "RUN", 0, 0
    if profile == SYSTEM_PROFILE or profile not in PROFILE_KEYS or not profile_rootfs_ready(profile):
        return meta_state(meta)
    installed_names = rootfs_package_names(profile)
    installed = sum(1 for package in packages if package_present(package, installed_names))
    if installed == len(packages):
        state = "OK"
    elif installed > 0:
        state = "PART"
    else:
        state = "MISS"
    return state, installed, len(packages)


def meta_state_for_name(name, meta):
    profile = normalize_name(name)
    if profile in PROFILE_KEYS:
        return meta_state_for_profile(meta, profile)
    return meta_state(meta)


def package_owner_map(manifest=None, include_optional=True):
    manifest = manifest or load_manifest()
    owners = {}
    for name, meta in manifest.items():
        for package in meta_all_packages(meta, include_optional=include_optional):
            owners.setdefault(package, []).append(name)
            for alternative in package_alternatives(package):
                owners.setdefault(alternative, []).append(name)
    return owners


def active_profile():
    env_path = HOST_CONFIG_HOME / "sevenos" / "profile.env"
    try:
        for line in env_path.read_text(encoding="utf-8").splitlines():
            if line.startswith("SEVENOS_ACTIVE_PROFILE="):
                return line.split("=", 1)[1].strip().strip('"') or "equinox"
    except OSError:
        pass
    return "equinox"


def normalize_profile(profile):
    normalized = normalize_name(profile)
    if normalized not in PROFILE_KEYS:
        error(f"unknown SevenOS profile: {profile}")
        sys.exit(2)
    return normalized


def normalize_profile_list(raw_profiles):
    if not raw_profiles:
        return sorted(PROFILE_KEYS - {SYSTEM_PROFILE})
    profiles = []
    for raw in raw_profiles:
        for item in str(raw).split(","):
            profile = item.strip()
            if not profile:
                continue
            normalized = normalize_profile(profile)
            if normalized == SYSTEM_PROFILE:
                error("profile-helper-all only targets mini OS profiles, not Equinox")
                sys.exit(2)
            if normalized not in profiles:
                profiles.append(normalized)
    return profiles


def normalize_mini_profile_list(raw_profiles, *, allow_all=False):
    profiles = []
    for raw in raw_profiles or []:
        for item in str(raw).split(","):
            profile = item.strip()
            if not profile:
                continue
            if allow_all and profile in {"all", "all-mini-os", "*"}:
                return ["*"]
            normalized = normalize_profile(profile)
            if normalized == SYSTEM_PROFILE:
                error("global package exposure targets mini OS profiles; Equinox already uses the host directly")
                sys.exit(2)
            if normalized not in profiles:
                profiles.append(normalized)
    return profiles


def profile_rootfs(profile):
    return PROFILE_ROOTFS_DIR / profile / "rootfs"


def profile_rootfs_ready(profile):
    rootfs = profile_rootfs(profile)
    return (rootfs / "usr/bin").is_dir() and (rootfs / "var/lib/pacman").exists()


def rootfs_package_count(profile):
    local = profile_rootfs(profile) / "var/lib/pacman/local"
    if not local.is_dir():
        return 0
    return sum(1 for item in local.iterdir() if item.is_dir())


def parse_pacman_local(local_dir):
    packages = []
    if not local_dir.is_dir():
        return packages
    for desc in sorted(local_dir.glob("*/desc")):
        data = {"id": desc.parent.name}
        try:
            lines = desc.read_text(encoding="utf-8", errors="ignore").splitlines()
        except OSError:
            continue
        key = None
        values = {}
        for line in lines:
            if line.startswith("%") and line.endswith("%"):
                key = line.strip("%").lower()
                values.setdefault(key, [])
                continue
            if key and line:
                values.setdefault(key, []).append(line)
        name = values.get("name", [desc.parent.name.rsplit("-", 2)[0]])[0]
        version = values.get("version", [""])[0]
        desc_text = values.get("desc", [""])[0]
        packages.append({
            "id": data["id"],
            "name": name,
            "version": version,
            "description": desc_text,
        })
    return packages


def rootfs_packages(profile):
    return parse_pacman_local(profile_rootfs(profile) / "var/lib/pacman/local")


def rootfs_package_names(profile):
    return {item.get("name") for item in rootfs_packages(profile) if item.get("name")}


def host_packages():
    local = Path("/var/lib/pacman/local")
    if local.is_dir():
        return parse_pacman_local(local)
    installed = installed_package_set()
    return [{"id": item, "name": item, "version": "", "description": ""} for item in sorted(installed)]


def helper_available_for_profile(profile, helper):
    if profile == SYSTEM_PROFILE:
        return command_exists(helper)
    return (profile_rootfs(profile) / "usr/bin" / helper).exists()


def rootfs_prepare_command(profile):
    return [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "prepare", profile, "--apply", "--yes"]


def rootfs_build_command(profile):
    return [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "build", profile, "--apply", "--yes"]


def rootfs_repair_commands(profile):
    return [
        [str(ROOT_DIR / "profiles" / "profile-manager.sh"), "bootstrap", profile],
        [str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", profile, "--yes"],
        rootfs_prepare_command(profile),
        rootfs_build_command(profile),
    ]


def helper_setup_hint(profile, helper):
    return (
        f"install {helper} inside {profile} first: "
        f"sevenpkg {profile} helper {helper}"
    )


def profile_helper_build_deps(helper):
    if helper == "paru":
        return ["base-devel", "git", "rust"]
    if helper == "yay":
        return ["base-devel", "git", "go"]
    return ["base-devel", "git"]


def profile_helper_runtime_deps(helper):
    return ["base-devel", "git"]


def profile_cache_dir(profile):
    return PROFILE_CONTAINERS_DIR / profile / "cache"


def cached_helper_packages(helper):
    packages = []
    candidates = [
        *PROFILE_CONTAINERS_DIR.glob(f"*/cache/sevenos-aur/{helper}/{helper}-*.pkg.tar.*"),
        *(HOST_HOME / ".cache" / "sevenos" / "aur" / helper).glob(f"{helper}-*.pkg.tar.*"),
    ]
    for package in candidates:
        if "-debug-" in package.name:
            continue
        if package.is_file():
            packages.append(package)
    return sorted(set(packages), key=lambda item: (item.stat().st_mtime, str(item)), reverse=True)


def cached_helper_package(helper):
    packages = cached_helper_packages(helper)
    return packages[0] if packages else None


def cached_helper_copy_script(source_profile, target_profile, helper):
    source_dir = profile_cache_dir(source_profile) / "sevenos-aur" / helper
    target_dir = profile_cache_dir(target_profile) / "sevenos-aur" / helper
    return (
        "set -Eeuo pipefail\n"
        f"src_dir={shlex_quote(str(source_dir))}\n"
        f"target_dir={shlex_quote(str(target_dir))}\n"
        f"pkg=$(find \"$src_dir\" -maxdepth 1 -type f -name {shlex_quote(helper + '-*.pkg.tar.*')} ! -name '*-debug-*' | sort | tail -n 1)\n"
        "test -n \"$pkg\"\n"
        "install -Dm644 \"$pkg\" \"$target_dir/$(basename \"$pkg\")\"\n"
    )


def profile_helper_build_script(helper):
    repo = f"https://aur.archlinux.org/{helper}.git"
    return (
        "set -Eeuo pipefail\n"
        "export MAKEFLAGS=${MAKEFLAGS:-}\n"
        "mkdir -p /profile/cache/sevenos-aur\n"
        f"rm -rf /profile/cache/sevenos-aur/{helper}\n"
        f"git clone {shlex_quote(repo)} /profile/cache/sevenos-aur/{helper}\n"
        f"cd /profile/cache/sevenos-aur/{helper}\n"
        "makepkg -s --noconfirm\n"
    )


def profile_helper_install_script(helper):
    return (
        "set -Eeuo pipefail\n"
        "export PACMAN_COLOR=never\n"
        f"cd /profile/cache/sevenos-aur/{helper}\n"
        f"pkg=$(find . -maxdepth 1 -type f -name {shlex_quote(helper + '-*.pkg.tar.*')} ! -name '*-debug-*' | sort | tail -n 1)\n"
        "test -n \"$pkg\"\n"
        "pacman --disable-sandbox -U --needed --noconfirm \"$pkg\"\n"
        f"{helper} --version\n"
    )


def profile_helper_runtime_deps_script(deps):
    quoted = " ".join(shlex_quote(dep) for dep in deps)
    return (
        "set -Eeuo pipefail\n"
        "export PACMAN_COLOR=never\n"
        f"missing=$(pacman -T {quoted} || true)\n"
        "if [ -n \"$missing\" ]; then\n"
        "  pacman --disable-sandbox -Sy --needed --noconfirm $missing\n"
        "fi\n"
    )


def rootfs_pacman_args(*args):
    return ["pacman", "--disable-sandbox", *args]


def load_global_package_policy():
    if not GLOBAL_PACKAGE_POLICY_PATH.is_file():
        return {"schema": "sevenos.global-package-policy.v1", "packages": {}}
    try:
        with GLOBAL_PACKAGE_POLICY_PATH.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except (OSError, json.JSONDecodeError):
        return {"schema": "sevenos.global-package-policy.v1", "packages": {}}
    data.setdefault("schema", "sevenos.global-package-policy.v1")
    data.setdefault("packages", {})
    return data


def save_global_package_policy(policy):
    GLOBAL_PACKAGE_POLICY_PATH.parent.mkdir(parents=True, exist_ok=True)
    GLOBAL_PACKAGE_POLICY_PATH.write_text(json.dumps(policy, indent=2, ensure_ascii=False, sort_keys=True) + "\n", encoding="utf-8")


def split_csv_values(values):
    items = []
    for raw in values or []:
        for item in str(raw).split(","):
            item = item.strip()
            if item and item not in items:
                items.append(item)
    return items


def global_package_policy_payload(package=None):
    policy = load_global_package_policy()
    packages = policy.get("packages", {})
    if package:
        normalized = normalize_name(package)
        packages = {normalized: packages.get(normalized, {"visibility": "equinox-only", "profiles": [], "commands": []})}
    items = []
    for name, entry in sorted(packages.items()):
        profiles = entry.get("profiles", [])
        commands = entry.get("commands", [])
        visibility = entry.get("visibility", "equinox-only")
        missing_commands = [command for command in commands if not command_available(command)]
        items.append({
            "package": name,
            "visibility": visibility,
            "profiles": profiles,
            "commands": commands,
            "missing_commands": missing_commands,
            "policy": "host package exposed to selected mini OS package views" if visibility == "exposed" else "host package restricted to Equinox",
        })
    return {
        "schema": "sevenos.global-package-policy.v1",
        "path": str(GLOBAL_PACKAGE_POLICY_PATH),
        "items": items,
        "commands": {
            "expose": "sevenpkg global-expose <package> --profiles forge --commands <command>",
            "expose_all": "sevenpkg global-expose <package> --all-mini-os --commands <command>",
            "restrict": "sevenpkg global-restrict <package>",
        },
    }


def apply_profile_isolation(quiet=False):
    return subprocess.run(
        [str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", SYSTEM_PROFILE, "--yes"],
        stdout=subprocess.DEVNULL if quiet else None,
        stderr=subprocess.DEVNULL if quiet else None,
        check=False,
    ).returncode


def global_expose(args):
    package = normalize_name(args.package)
    validate_package_name(package)
    profiles = ["*"] if args.all_mini_os else normalize_mini_profile_list(args.profiles, allow_all=True)
    if not profiles:
        error("choose target mini OS profiles with --profiles or use --all-mini-os")
        sys.exit(2)
    commands = split_csv_values(args.commands)
    if not commands:
        commands = [package]
    policy = load_global_package_policy()
    policy.setdefault("packages", {})[package] = {
        "visibility": "exposed",
        "profiles": profiles,
        "commands": commands,
    }
    save_global_package_policy(policy)
    rc = apply_profile_isolation(quiet=args.json)
    payload = global_package_policy_payload(package)
    payload["applied"] = rc == 0
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
    else:
        scope = "all mini OS" if profiles == ["*"] else ", ".join(profiles)
        print(f"{package}: exposed to {scope} via commands: {', '.join(commands)}")
        if rc != 0:
            print("profile isolation apply returned a non-zero status; rerun scripts/profile-isolation.sh apply equinox --yes", file=sys.stderr)
    sys.exit(rc)


def global_restrict(args):
    package = normalize_name(args.package)
    validate_package_name(package)
    policy = load_global_package_policy()
    entry = policy.setdefault("packages", {}).get(package, {})
    commands = entry.get("commands", [])
    policy["packages"][package] = {
        "visibility": "equinox-only",
        "profiles": [],
        "commands": commands,
    }
    save_global_package_policy(policy)
    rc = apply_profile_isolation(quiet=args.json)
    payload = global_package_policy_payload(package)
    payload["applied"] = rc == 0
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
    else:
        print(f"{package}: restricted to Equinox")
        if rc != 0:
            print("profile isolation apply returned a non-zero status; rerun scripts/profile-isolation.sh apply equinox --yes", file=sys.stderr)
    sys.exit(rc)


def global_clear(args):
    package = normalize_name(args.package)
    validate_package_name(package)
    policy = load_global_package_policy()
    removed = policy.setdefault("packages", {}).pop(package, None) is not None
    save_global_package_policy(policy)
    rc = apply_profile_isolation(quiet=args.json)
    payload = global_package_policy_payload(package)
    payload["removed"] = removed
    payload["applied"] = rc == 0
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
    else:
        print(f"{package}: policy cleared" if removed else f"{package}: no explicit policy to clear")
        if rc != 0:
            print("profile isolation apply returned a non-zero status; rerun scripts/profile-isolation.sh apply equinox --yes", file=sys.stderr)
    sys.exit(rc)


def show_global_policy(args):
    payload = global_package_policy_payload(getattr(args, "package", None))
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenOS Global Package Policy")
    print("=============================")
    print(f"Path: {payload['path']}")
    if not payload["items"]:
        print("No explicit global package exposure policy yet. Host packages stay Equinox-only by default.")
        return
    for item in payload["items"]:
        profiles = "all mini OS" if item["profiles"] == ["*"] else ", ".join(item["profiles"]) or "none"
        print(f"- {item['package']}: {item['visibility']} · profiles={profiles} · commands={', '.join(item['commands']) or 'none'}")
        if item["missing_commands"]:
            print(f"  missing commands on host: {', '.join(item['missing_commands'])}")


def profile_service_safe_name(value):
    safe = re.sub(r"[^A-Za-z0-9_.@-]+", "-", value.strip())
    return safe.strip("-") or "service"


def profile_service_unit_name(profile, name):
    return f"sevenos-profile-{profile}-{profile_service_safe_name(name)}.service"


def systemd_quote(value):
    value = str(value)
    if re.match(r"^[A-Za-z0-9_@%+=:,./-]+$", value):
        return value
    escaped = value.replace("\\", "\\\\").replace('"', '\\"').replace("$", "\\$")
    return f'"{escaped}"'


def profile_service_unit_path(profile, name):
    return USER_SYSTEMD_DIR / profile_service_unit_name(profile, name)


def systemctl_user(*args, quiet=False):
    return subprocess.run(
        ["systemctl", "--user", *args],
        stdout=subprocess.DEVNULL if quiet else None,
        stderr=subprocess.DEVNULL if quiet else None,
        text=True,
        check=False,
    )


def profile_service_payload(profile=None, name=None):
    units = []
    paths = []
    if profile and name:
        paths = [profile_service_unit_path(profile, name)]
    else:
        paths = sorted(USER_SYSTEMD_DIR.glob("sevenos-profile-*.service")) if USER_SYSTEMD_DIR.is_dir() else []
    for path in paths:
        unit = path.name
        active = systemctl_user("is-active", unit, quiet=True).returncode == 0
        enabled = systemctl_user("is-enabled", unit, quiet=True).returncode == 0
        units.append({
            "unit": unit,
            "path": str(path),
            "exists": path.is_file(),
            "active": active,
            "enabled": enabled,
        })
    return {
        "schema": "sevenos.profile-service.v1",
        "units": units,
        "commands": {
            "mongodb": "sevenpkg profile-service mongodb forge --start",
            "create": "sevenpkg profile-service create forge name -- <command>",
            "start": "sevenpkg profile-service start forge name",
            "stop": "sevenpkg profile-service stop forge name",
            "remove": "sevenpkg profile-service remove forge name",
        },
    }


def write_profile_service(profile, name, command, *, description=None, start=False, enable=False):
    profile = normalize_profile(profile)
    if profile == SYSTEM_PROFILE:
        error("profile services target mini OS rootfs; use normal systemd services for Equinox")
        sys.exit(2)
    if not command:
        error("profile service command is required")
        sys.exit(2)
    if not profile_rootfs_ready(profile):
        error(f"{profile} rootfs is not ready; build it before creating profile services")
        sys.exit(2)
    USER_SYSTEMD_DIR.mkdir(parents=True, exist_ok=True)
    unit_path = profile_service_unit_path(profile, name)
    exec_command = [
        str(ROOT_DIR / "bin" / "seven-profile-run"),
        "--profile", profile,
        "--rootfs",
        *command,
    ]
    unit_text = "\n".join([
        "[Unit]",
        f"Description={description or f'SevenOS {profile} profile service: {name}'}",
        "Documentation=man:systemd.service(5)",
        "",
        "[Service]",
        "Type=simple",
        "Restart=on-failure",
        "RestartSec=3",
        "Environment=SEVENOS_PROFILE_SERVICE=1",
        f"ExecStart={' '.join(systemd_quote(part) for part in exec_command)}",
        "",
        "[Install]",
        "WantedBy=default.target",
        "",
    ])
    unit_path.write_text(unit_text, encoding="utf-8")
    systemctl_user("daemon-reload", quiet=True)
    unit = unit_path.name
    if enable:
        systemctl_user("enable", unit, quiet=True)
    if start:
        systemctl_user("start", unit, quiet=True)
    return profile_service_payload(profile, name)


def handle_profile_service(args):
    action = args.profile_service_action
    if action == "list":
        payload = profile_service_payload()
    elif action == "status":
        payload = profile_service_payload(normalize_profile(args.profile), args.name)
    elif action == "create":
        command = list(args.service_command or [])
        if command and command[0] == "--":
            command = command[1:]
        if "--json" in command:
            args.json = True
            command = [item for item in command if item != "--json"]
        payload = write_profile_service(
            args.profile,
            args.name,
            command,
            description=args.description,
            start=args.start,
            enable=args.enable,
        )
    elif action == "mongodb":
        profile = normalize_profile(args.profile)
        data_dir = f"/profile/data/{args.name}"
        host_data_dir = profile_cache_dir(profile).parent / "data" / args.name
        host_data_dir.mkdir(parents=True, exist_ok=True)
        command = [
            args.binary,
            "--dbpath", data_dir,
            "--bind_ip", args.bind,
            "--port", str(args.port),
        ]
        payload = write_profile_service(
            profile,
            args.name,
            command,
            description=f"SevenOS {profile} MongoDB profile service",
            start=args.start,
            enable=args.enable,
        )
        payload["preset"] = {
            "name": "mongodb",
            "profile": profile,
            "data_dir": data_dir,
            "host_data_dir": str(host_data_dir),
            "bind": args.bind,
            "port": args.port,
            "install_hint": f"sevenpkg {profile} install mongodb --source pacman",
        }
    elif action in {"start", "stop", "restart", "enable", "disable"}:
        profile = normalize_profile(args.profile)
        unit = profile_service_unit_name(profile, args.name)
        rc = systemctl_user(action, unit, quiet=getattr(args, "json", False)).returncode
        payload = profile_service_payload(profile, args.name)
        payload["applied"] = rc == 0
        payload["action"] = action
        if rc != 0 and not getattr(args, "json", False):
            print(f"systemctl --user {action} {unit} failed", file=sys.stderr)
    elif action == "remove":
        profile = normalize_profile(args.profile)
        unit = profile_service_unit_name(profile, args.name)
        systemctl_user("disable", "--now", unit, quiet=True)
        path = profile_service_unit_path(profile, args.name)
        removed = path.exists()
        if path.exists():
            path.unlink()
        systemctl_user("daemon-reload", quiet=True)
        payload = profile_service_payload(profile, args.name)
        payload["removed"] = removed
    else:
        error("unknown profile-service action")
        sys.exit(2)

    if getattr(args, "json", False):
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenOS Profile Services")
    print("========================")
    for item in payload.get("units", []):
        state = "active" if item["active"] else "inactive"
        enabled = "enabled" if item["enabled"] else "disabled"
        exists = "exists" if item["exists"] else "missing"
        print(f"- {item['unit']}: {state}, {enabled}, {exists}")
        print(f"  {item['path']}")
    if payload.get("preset"):
        preset = payload["preset"]
        print(f"Data: {preset['data_dir']} ({preset['host_data_dir']})")


def select_profile_source(package, requested):
    if requested == "auto":
        if pacman_has(package):
            return "pacman"
        if paru_has(package):
            return "paru"
        if yay_has(package):
            return "yay"
        return None
    if requested == "aur":
        if paru_has(package):
            return "paru"
        if yay_has(package):
            return "yay"
        return None
    return requested


def command_available(command):
    path = ROOT_DIR / command
    return path.exists() or shutil.which(command) is not None


def record_transaction(payload):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    event = dict(payload)
    event["timestamp"] = datetime.now(timezone.utc).isoformat()
    with TRANSACTION_LOG.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(event, ensure_ascii=False, sort_keys=True) + "\n")


@contextmanager
def transaction_lock(wait=False):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with TRANSACTION_LOCK.open("w", encoding="utf-8") as handle:
        try:
            flags = fcntl.LOCK_EX if wait else fcntl.LOCK_EX | fcntl.LOCK_NB
            fcntl.flock(handle.fileno(), flags)
        except OSError as exc:
            if exc.errno in (errno.EACCES, errno.EAGAIN):
                raise RuntimeError("another SevenPkg transaction is already running") from exc
            raise
        handle.seek(0)
        handle.truncate()
        handle.write(json.dumps({
            "pid": os.getpid(),
            "started_at": datetime.now(timezone.utc).isoformat(),
        }))
        handle.flush()
        try:
            yield
        finally:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)


def transaction_commands(action, packages, source="auto", include_optional=False, force=False):
    manifest = load_manifest()
    normalized = [normalize_name(package) for package in packages]
    commands = []
    resolved_packages = []
    meta_targets = []
    warnings = []
    blockers = []

    if action == "install" and normalized and normalized[0] in manifest:
        name = normalized[0]
        meta = manifest[name]
        meta_targets.append(name)
        if meta.get("kind") == "sevenos-target":
            if name == "forge":
                commands.append([str(ROOT_DIR / "install.sh"), "dev", *normalized[1:]])
                commands.append([str(ROOT_DIR / "install.sh"), "server", *normalized[1:]])
            else:
                commands.append([str(ROOT_DIR / "install.sh"), meta.get("target", name), *normalized[1:]])
        elif meta.get("kind") == "pacman":
            resolved_packages.extend(meta.get("packages", []))
            if resolved_packages:
                commands.append(["sudo", "pacman", "-S", "--needed", *resolved_packages])
        if include_optional:
            optional = meta_optional_packages(meta)
            if optional:
                commands.append(["sudo", "pacman", "-S", "--needed", *optional])
                resolved_packages.extend(optional)
        resolved_packages.extend(meta_packages(meta))
    elif action == "install":
        pacman_packages = []
        aur_packages = []
        for package in normalized:
            validate_package_name(package)
            selected_source = source
            if selected_source == "auto":
                if pacman_has(package):
                    selected_source = "pacman"
                elif paru_has(package):
                    selected_source = "paru"
                elif yay_has(package):
                    selected_source = "yay"
                else:
                    blockers.append(f"package not found in pacman repos or AUR helpers: {package}")
                    continue
            if selected_source == "pacman":
                pacman_packages.append(package)
            elif selected_source in {"aur", "paru", "yay"}:
                helper = "paru" if selected_source == "aur" else selected_source
                if selected_source == "aur" and not command_exists(helper) and command_exists("yay"):
                    helper = "yay"
                if not command_exists(helper):
                    blockers.append(f"{helper} is required for AUR installs")
                else:
                    aur_packages.append((helper, package))
            elif selected_source == "sevenrepo":
                blockers.append("SevenRepo is planned but not enabled yet")
            else:
                blockers.append(f"unknown source: {selected_source}")
        if pacman_packages:
            commands.append(["sudo", "pacman", "-S", "--needed", *pacman_packages])
        if aur_packages:
            for helper in ("paru", "yay"):
                helper_packages = [package for item_helper, package in aur_packages if item_helper == helper]
                if helper_packages:
                    commands.append([helper, "-S", "--needed", *helper_packages])
        resolved_packages.extend(pacman_packages + [package for _, package in aur_packages])
    elif action == "remove":
        owners = package_owner_map(manifest)
        protected = {}
        for package in normalized:
            validate_package_name(package)
            if package in ALIASES:
                blockers.append(f"{package} is a retired SevenOS alias, not a removable package")
                continue
            package_owners = owners.get(package, [])
            if package_owners:
                protected[package] = package_owners
        if protected and not force:
            for package, package_owners in protected.items():
                warnings.append(f"{package} belongs to SevenOS layer(s): {', '.join(package_owners)}")
            blockers.append("removing SevenOS-owned packages requires --force")
        commands.append(["sudo", "pacman", "-Rns", *normalized])
        resolved_packages.extend(normalized)
    elif action == "update":
        commands.append(["sudo", "pacman", "-Syu"])
        if command_exists("paru"):
            commands.append(["paru", "-Sua"])
        else:
            warnings.append("paru not found; AUR update will be skipped")
    else:
        blockers.append(f"unsupported transaction action: {action}")

    owner_map = package_owner_map(manifest)
    if meta_targets:
        affected_profiles = sorted(item for item in meta_targets if item in PROFILE_KEYS)
    else:
        affected_profiles = sorted(
            profile
            for package in resolved_packages
            for profile in owner_map.get(package, [])
            if profile in PROFILE_KEYS
        )
    repairs = []
    for profile in affected_profiles:
        repairs.extend([
            [str(ROOT_DIR / "profiles" / "profile-manager.sh"), "bootstrap", profile],
            [str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", profile, "--yes"],
            [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "prepare", profile, "--apply", "--yes"],
        ])

    impact = "packages" if action in {"install", "remove", "update"} else "safe"
    if action == "remove":
        impact = "destructive" if force else "guarded"
    flag_hint = ""
    if include_optional:
        flag_hint += " --optional"
    if force:
        flag_hint += " --force"
    elif action == "remove":
        flag_hint += " --force"
    items_text = f" {' '.join(normalized)}" if normalized else ""
    return {
        "schema": "sevenos.package-transaction.v1",
        "action": action,
        "items": normalized,
        "source": source,
        "include_optional": include_optional,
        "force": force,
        "impact": impact,
        "active_profile": active_profile(),
        "affected_profiles": affected_profiles,
        "commands": commands,
        "repairs": repairs,
        "warnings": warnings,
        "blockers": blockers,
        "apply_hint": f"sevenpkg transaction {action}{items_text}{flag_hint} --apply --yes",
    }


def profile_transaction_commands(profile, packages, source="auto", include_optional=False):
    profile = normalize_profile(profile)
    normalized = [normalize_name(package) for package in packages]
    commands = []
    repairs = []
    warnings = []
    blockers = []
    resolved = []
    grouped = {"pacman": [], "paru": [], "yay": []}

    for package in normalized:
        validate_package_name(package)

    if profile == SYSTEM_PROFILE:
        system_commands = []
        if source in {"paru", "yay"}:
            helper_packages = []
            for package in normalized:
                if not command_exists(source):
                    blockers.append(f"{source} is not installed on Equinox")
                else:
                    helper_packages.append(package)
            if helper_packages:
                system_commands.append([source, "-S", "--needed", *helper_packages])
        else:
            selected_source = "aur" if source == "aur" else source
            base = transaction_commands("install", normalized, source=selected_source, include_optional=include_optional)
            system_commands.extend(base.get("commands", []))
            blockers.extend(base.get("blockers", []))
            warnings.extend(base.get("warnings", []))
            resolved.extend(base.get("items", normalized))
        return {
            "schema": "sevenos.profile-package-transaction.v1",
            "action": "install",
            "profile": profile,
            "profile_scope": "global-system",
            "visibility": "global; available to mini OS package views when exposed by profile policy",
            "items": normalized,
            "source": source,
            "impact": "global-system-packages",
            "rootfs": "host-system",
            "rootfs_ready": True,
            "commands": system_commands,
            "repairs": [[str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", SYSTEM_PROFILE, "--yes"]],
            "warnings": warnings,
            "blockers": blockers,
            "apply_hint": f"sevenpkg install --profile equinox {' '.join(normalized)} --source {source}",
        }

    rootfs = profile_rootfs(profile)
    rootfs_was_ready = profile_rootfs_ready(profile)
    if not rootfs_was_ready:
        warnings.append(f"{profile} rootfs is not ready yet; SevenPkg will build it before package installation.")

    for package in normalized:
        selected = select_profile_source(package, source)
        if selected is None:
            blockers.append(f"package not found in pacman repos or AUR helpers: {package}")
            continue
        if selected == "sevenrepo":
            blockers.append("SevenRepo is planned but not enabled yet")
            continue
        if selected in {"paru", "yay"} and not helper_available_for_profile(profile, selected):
            blockers.append(
                f"{selected} is not installed inside the {profile} rootfs; {helper_setup_hint(profile, selected)} or use --source pacman"
            )
            continue
        grouped[selected].append(package)
        resolved.append(package)

    runner = str(ROOT_DIR / "bin" / "seven-profile-run")
    if not rootfs_was_ready and not blockers:
        commands.extend(rootfs_repair_commands(profile))
    if grouped["pacman"]:
        commands.append([runner, "--profile", profile, "--rootfs-admin", *rootfs_pacman_args("-Sy", "--needed", "--noconfirm", *grouped["pacman"])])
    for helper in ("paru", "yay"):
        if grouped[helper]:
            commands.append([runner, "--profile", profile, "--rootfs-writable", helper, "-S", "--needed", *grouped[helper]])

    repairs.extend([
        [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "verify", profile],
        [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "seal", profile, "--apply", "--yes"],
        [str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", SYSTEM_PROFILE, "--yes"],
    ])
    if source in {"aur", "paru", "yay"}:
        warnings.append("AUR installs stay private only when the AUR helper runs inside the target profile rootfs.")
    return {
        "schema": "sevenos.profile-package-transaction.v1",
        "action": "install",
        "profile": profile,
        "profile_scope": "profile-rootfs",
        "visibility": f"private to {profile}; not exposed to other mini OS package views",
        "items": normalized,
        "source": source,
        "impact": "profile-rootfs-packages",
        "rootfs": str(rootfs),
        "rootfs_ready": profile_rootfs_ready(profile),
        "commands": commands,
        "repairs": repairs,
        "warnings": warnings,
        "blockers": blockers,
        "apply_hint": f"sevenpkg install --profile {profile} {' '.join(normalized)} --source {source}",
    }


def profile_remove_transaction_commands(profile, packages, force=False):
    profile = normalize_profile(profile)
    normalized = [normalize_name(package) for package in packages]
    warnings = []
    blockers = []
    commands = []
    repairs = []

    for package in normalized:
        validate_package_name(package)

    if profile == SYSTEM_PROFILE:
        base = transaction_commands("remove", normalized, force=force)
        return {
            **base,
            "schema": "sevenos.profile-package-transaction.v1",
            "profile": profile,
            "profile_scope": "global-system",
            "visibility": "global; removal affects the host Arch system",
            "impact": "destructive" if force else "guarded",
            "rootfs": "host-system",
            "rootfs_ready": True,
            "apply_hint": f"sevenpkg remove --profile equinox {' '.join(normalized)} --force",
        }

    rootfs = profile_rootfs(profile)
    if not profile_rootfs_ready(profile):
        blockers.append(f"{profile} rootfs is not ready; build it first with: seven profile-rootfs build {profile} --apply --yes")

    for package in normalized:
        if package in ALIASES:
            blockers.append(f"{package} is a retired SevenOS alias, not a rootfs package name")
            continue
        if profile_rootfs_ready(profile) and package not in rootfs_package_names(profile):
            blockers.append(f"{package} is not installed inside the {profile} rootfs")

    if not blockers:
        commands.append([
            str(ROOT_DIR / "bin" / "seven-profile-run"),
            "--profile", profile,
            "--rootfs-admin",
            *rootfs_pacman_args("-Rns", "--noconfirm", *normalized),
        ])
    repairs.extend([
        [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "verify", profile],
        [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "seal", profile, "--apply", "--yes"],
        [str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", SYSTEM_PROFILE, "--yes"],
    ])
    warnings.append("This removes packages only from the target mini OS rootfs.")
    return {
        "schema": "sevenos.profile-package-transaction.v1",
        "action": "remove",
        "profile": profile,
        "profile_scope": "profile-rootfs",
        "visibility": f"private to {profile}; removal does not touch other mini OS package views",
        "items": normalized,
        "force": force,
        "impact": "profile-rootfs-packages",
        "rootfs": str(rootfs),
        "rootfs_ready": profile_rootfs_ready(profile),
        "commands": commands,
        "repairs": repairs,
        "warnings": warnings,
        "blockers": blockers,
        "apply_hint": f"sevenpkg remove --profile {profile} {' '.join(normalized)}",
    }


def profile_update_transaction_commands(profile):
    profile = normalize_profile(profile)
    if profile == SYSTEM_PROFILE:
        base = transaction_commands("update", [])
        return {
            **base,
            "schema": "sevenos.profile-package-transaction.v1",
            "profile": profile,
            "profile_scope": "global-system",
            "visibility": "global; update affects the host Arch system",
            "impact": "global-system-packages",
            "rootfs": "host-system",
            "rootfs_ready": True,
            "apply_hint": "sevenpkg update --profile equinox",
        }

    rootfs = profile_rootfs(profile)
    commands = []
    warnings = []
    blockers = []
    if not profile_rootfs_ready(profile):
        warnings.append(f"{profile} rootfs is not ready yet; SevenPkg will build it before updating.")
        commands.extend(rootfs_repair_commands(profile))
    runner = str(ROOT_DIR / "bin" / "seven-profile-run")
    commands.append([
        runner,
        "--profile", profile,
        "--rootfs-admin",
        "--no-seal-verify",
        *rootfs_pacman_args("-Syu", "--noconfirm"),
    ])
    if helper_available_for_profile(profile, "paru"):
        commands.append([runner, "--profile", profile, "--rootfs-writable", "--no-seal-verify", "paru", "-Sua", "--noconfirm"])
    elif helper_available_for_profile(profile, "yay"):
        commands.append([runner, "--profile", profile, "--rootfs-writable", "--no-seal-verify", "yay", "-Sua", "--noconfirm"])
    else:
        warnings.append(f"{profile} has no AUR helper inside its rootfs; AUR updates are skipped until you run: sevenpkg {profile} helper paru")
    repairs = [
        [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "verify", profile],
        [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "seal", profile, "--apply", "--yes"],
        [str(ROOT_DIR / "scripts" / "profile-isolation.sh"), "apply", SYSTEM_PROFILE, "--yes"],
    ]
    return {
        "schema": "sevenos.profile-package-transaction.v1",
        "action": "update",
        "profile": profile,
        "profile_scope": "profile-rootfs",
        "visibility": f"private to {profile}; update does not touch other mini OS package views",
        "items": [],
        "impact": "profile-rootfs-packages",
        "rootfs": str(rootfs),
        "rootfs_ready": profile_rootfs_ready(profile),
        "commands": commands,
        "repairs": repairs,
        "warnings": warnings,
        "blockers": blockers,
        "apply_hint": f"sevenpkg update --profile {profile}",
    }


def profile_helper_transaction_commands(profile, helper, deferred_cache_profile=None):
    profile = normalize_profile(profile)
    helper = normalize_name(helper)
    warnings = []
    blockers = []
    commands = []
    repairs = []
    dependency_packages = []
    cached_package_path = None
    if helper not in {"paru", "yay"}:
        blockers.append("profile helper must be paru or yay")
    if profile == SYSTEM_PROFILE:
        if not command_exists(helper):
            blockers.append(f"{helper} is not installed on Equinox")
        else:
            warnings.append(f"{helper} already belongs to the Equinox/global system.")
        return {
            "schema": "sevenos.profile-package-transaction.v1",
            "action": "helper",
            "profile": profile,
            "profile_scope": "global-system",
            "visibility": "global; Equinox uses host package helpers",
            "items": [helper],
            "impact": "global-system-packages",
            "rootfs": "host-system",
            "rootfs_ready": True,
            "commands": [] if blockers else [[helper, "--version"]],
            "repairs": [],
            "warnings": warnings,
            "blockers": blockers,
            "apply_hint": f"sevenpkg {profile} helper {helper}",
        }
    rootfs_ready = profile_rootfs_ready(profile)
    if not rootfs_ready:
        warnings.append(f"{profile} rootfs is not ready yet; SevenPkg will build it before preparing {helper}.")
        commands.extend(rootfs_repair_commands(profile))
    helper_present = helper_available_for_profile(profile, helper)
    if helper_present:
        warnings.append(f"{helper} is already available inside {profile}.")
    else:
        cached_package = cached_helper_package(helper)
        reuse_cached = bool(cached_package or deferred_cache_profile)
        if reuse_cached:
            if deferred_cache_profile and not cached_package:
                cached_package_path = f"after-build:{deferred_cache_profile}"
                commands.append(["sh", "-lc", cached_helper_copy_script(deferred_cache_profile, profile, helper)])
            else:
                cached_package_path = str(cached_package)
                target_package = profile_cache_dir(profile) / "sevenos-aur" / helper / cached_package.name
                if cached_package.resolve() != target_package.resolve():
                    commands.append(["install", "-Dm644", str(cached_package), str(target_package)])
            warnings.append(
                f"SevenPkg will reuse cached {helper} package for {profile}."
            )
            deps = profile_helper_runtime_deps(helper)
        else:
            warnings.append(
                f"SevenPkg will build the {helper} AUR helper inside {profile} so AUR packages stay private to that mini OS."
            )
            deps = profile_helper_build_deps(helper)
        dependency_packages = deps
        if reuse_cached:
            commands.append([
                str(ROOT_DIR / "bin" / "seven-profile-run"),
                "--profile", profile,
                "--rootfs-admin",
                "--no-seal-verify",
                "sh", "-lc",
                profile_helper_runtime_deps_script(deps),
            ])
        else:
            commands.append([
                str(ROOT_DIR / "bin" / "seven-profile-run"),
                "--profile", profile,
                "--rootfs-admin",
                "--no-seal-verify",
                *rootfs_pacman_args("-Sy", "--needed", "--noconfirm", *deps),
            ])
        if not reuse_cached:
            commands.append([
                str(ROOT_DIR / "bin" / "seven-profile-run"),
                "--profile", profile,
                "--rootfs-writable",
                "--no-seal-verify",
                "sh", "-lc",
                profile_helper_build_script(helper),
            ])
        commands.append([
            str(ROOT_DIR / "bin" / "seven-profile-run"),
            "--profile", profile,
            "--rootfs-admin",
            "--no-seal-verify",
            "sh", "-lc",
            profile_helper_install_script(helper),
        ])
        repairs.extend([
            [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "verify", profile],
            [str(ROOT_DIR / "bin" / "seven-profile-rootfs"), "seal", profile, "--apply", "--yes"],
        ])
    return {
        "schema": "sevenos.profile-package-transaction.v1",
        "action": "helper",
        "profile": profile,
        "profile_scope": "profile-rootfs",
        "visibility": f"private to {profile}; helper is used only inside that mini OS rootfs",
        "items": [helper],
        "impact": "profile-rootfs-helper",
        "rootfs": str(profile_rootfs(profile)),
        "rootfs_ready": rootfs_ready,
        "dependency_packages": dependency_packages,
        "bootstrap_packages": [] if helper_present or cached_package_path else profile_helper_build_deps(helper),
        "cached_package": cached_package_path,
        "aur_repo": f"https://aur.archlinux.org/{helper}.git",
        "commands": commands,
        "repairs": repairs,
        "warnings": warnings,
        "blockers": blockers,
        "apply_hint": f"sevenpkg {profile} helper {helper}",
    }


def profile_helper_all_transaction_commands(helper, profiles=None, include_installed=False):
    helper = normalize_name(helper)
    profiles = normalize_profile_list(profiles)
    commands = []
    repairs = []
    warnings = []
    blockers = []
    children = []
    skipped = []
    cached_exists = cached_helper_package(helper) is not None
    seed_profile = None
    if not cached_exists:
        for profile in profiles:
            if not helper_available_for_profile(profile, helper):
                seed_profile = profile
                break
    for profile in profiles:
        if helper_available_for_profile(profile, helper) and not include_installed:
            skipped.append(profile)
            continue
        deferred_cache_profile = seed_profile if seed_profile and profile != seed_profile else None
        child = profile_helper_transaction_commands(profile, helper, deferred_cache_profile=deferred_cache_profile)
        children.append(child)
        commands.extend(child.get("commands", []))
        repairs.extend(child.get("repairs", []))
        warnings.extend(f"{profile}: {warning}" for warning in child.get("warnings", []))
        blockers.extend(f"{profile}: {blocker}" for blocker in child.get("blockers", []))
    if skipped:
        warnings.append(f"{helper} already present; skipped: {', '.join(skipped)}")
    return {
        "schema": "sevenos.profile-package-transaction.v1",
        "action": "helper-all",
        "profile": "all-mini-os",
        "profile_scope": "profile-rootfs",
        "visibility": "private helpers installed inside each mini OS rootfs",
        "items": [helper],
        "impact": "profile-rootfs-helper",
        "rootfs": str(PROFILE_ROOTFS_DIR),
        "rootfs_ready": all(profile_rootfs_ready(profile) for profile in profiles),
        "profiles": profiles,
        "target_profiles": [child.get("profile") for child in children],
        "skipped_profiles": skipped,
        "seed_profile": seed_profile,
        "children": children,
        "commands": commands,
        "repairs": repairs,
        "warnings": warnings,
        "blockers": blockers,
        "apply_hint": f"sevenpkg profile-helper-all {helper}",
    }


def print_transaction(payload, json_output=False):
    if json_output:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Transaction")
    print("====================")
    print(f"Action:  {payload.get('action')}")
    print(f"Impact:  {payload.get('impact')}")
    if payload.get("profile"):
        print(f"Profile: {payload.get('profile')} · {payload.get('profile_scope')} · {payload.get('visibility')}")
    profiles = payload.get("affected_profiles") or []
    print(f"Profiles: {', '.join(profiles) if profiles else 'none'}")
    if payload.get("warnings"):
        print("\nWarnings:")
        for warning in payload["warnings"]:
            print(f"- {warning}")
    if payload.get("blockers"):
        print("\nBlocked:")
        for blocker in payload["blockers"]:
            print(f"- {blocker}")
    print("\nCommands:")
    for command in payload.get("commands", []):
        print("  " + " ".join(shlex_quote(part) for part in command))
    repairs = payload.get("repairs", [])
    if repairs:
        print("\nSevenOS repair after apply:")
        for command in repairs:
            print("  " + " ".join(shlex_quote(part) for part in command))
    print(f"\nApply: {payload.get('apply_hint')}")


def apply_transaction(payload, args, run_repairs=True):
    if payload.get("blockers") and not getattr(args, "force", False):
        record_transaction({**payload, "status": "blocked"})
        print_transaction(payload, getattr(args, "json", False))
        return 126
    try:
        with transaction_lock(wait=getattr(args, "wait", False)):
            record_transaction({**payload, "status": "started"})
            for command in payload.get("commands", []):
                run(command, args)
            if run_repairs:
                for command in payload.get("repairs", []):
                    if Path(command[0]).exists() or shutil.which(command[0]):
                        run(command, args, check=False)
            record_transaction({**payload, "status": "completed"})
            return 0
    except RuntimeError as exc:
        blocked = {**payload, "status": "blocked", "blockers": [*payload.get("blockers", []), str(exc)]}
        record_transaction(blocked)
        print_transaction(blocked, getattr(args, "json", False))
        return 126
    except subprocess.CalledProcessError as exc:
        command = " ".join(shlex_quote(part) for part in (exc.cmd if isinstance(exc.cmd, list) else [exc.cmd]))
        blocked = {
            **payload,
            "status": "failed",
            "blockers": [
                *payload.get("blockers", []),
                f"command failed with exit code {exc.returncode}: {command}",
            ],
        }
        record_transaction(blocked)
        print_transaction(blocked, getattr(args, "json", False))
        return exc.returncode or 1


def install_meta(name, meta, args):
    kind = meta.get("kind")
    log(f"installing SevenOS meta-package: {name}")

    if kind == "sevenos-target":
        target = meta["target"]
        if name == "forge":
            run([str(ROOT_DIR / "install.sh"), "dev", *args.meta_args], args)
            run([str(ROOT_DIR / "install.sh"), "server", *args.meta_args], args)
            return
        run([str(ROOT_DIR / "install.sh"), target, *args.meta_args], args)
        return

    if kind == "pacman":
        packages = meta.get("packages", [])
        if not packages:
            log(f"meta-package '{name}' has no packages")
            return
        run(["sudo", "pacman", "-S", "--needed", *packages], args)
        return

    error(f"unknown meta-package kind for {name}: {kind}")
    sys.exit(1)


def install_one(package, args):
    validate_package_name(package)
    manifest = load_manifest()
    original = package
    package = normalize_name(package)
    alias_notice(original, package)

    if package in manifest:
        install_meta(package, manifest[package], args)
        return

    source = args.source
    if source == "auto":
        if pacman_has(package):
            source = "pacman"
        elif paru_has(package):
            source = "aur"
        else:
            error(f"package not found in enabled pacman repos or AUR via paru: {package}")
            sys.exit(1)

    if source == "pacman":
        run(["sudo", "pacman", "-S", "--needed", package], args)
    elif source in {"aur", "paru", "yay"}:
        helper = "paru" if source == "aur" else source
        if source == "aur" and not command_exists(helper) and command_exists("yay"):
            helper = "yay"
        if not command_exists(helper):
            error(f"{helper} is required for AUR installs")
            sys.exit(1)
        run([helper, "-S", "--needed", package], args)
    elif source == "sevenrepo":
        error("SevenRepo is planned but not enabled in this phase")
        sys.exit(1)
    else:
        error(f"unknown source: {source}")
        sys.exit(1)


def install_packages(args):
    manifest = load_manifest()
    original_first = args.packages[0]
    first_package = normalize_name(original_first)
    alias_notice(original_first, first_package)

    if getattr(args, "profile", None):
        payload = profile_transaction_commands(
            args.profile,
            args.packages,
            source=args.source,
            include_optional=getattr(args, "optional", False),
        )
        if getattr(args, "preview", False):
            print_transaction(payload, getattr(args, "json", False))
            return
        sys.exit(apply_transaction(payload, args))

    default_profile = active_profile()
    if (
        default_profile != SYSTEM_PROFILE
        and first_package not in manifest
        and not getattr(args, "global_install", False)
    ):
        payload = profile_transaction_commands(
            default_profile,
            args.packages,
            source=args.source,
            include_optional=getattr(args, "optional", False),
        )
        payload["default_profile_source"] = "active-profile"
        if getattr(args, "preview", False):
            print_transaction(payload, getattr(args, "json", False))
            return
        sys.exit(apply_transaction(payload, args))

    if getattr(args, "preview", False):
        payload = transaction_commands("install", args.packages, source=args.source, include_optional=getattr(args, "optional", False))
        print_transaction(payload, getattr(args, "json", False))
        return
    if getattr(args, "transaction", False):
        payload = transaction_commands("install", args.packages, source=args.source, include_optional=getattr(args, "optional", False))
        sys.exit(apply_transaction(payload, args))

    if first_package in manifest:
        args.meta_args = args.packages[1:]
        install_meta(first_package, manifest[first_package], args)
        if getattr(args, "optional", False):
            optional = meta_optional_packages(manifest[first_package])
            if optional:
                run(["sudo", "pacman", "-S", "--needed", *optional], args)
        return

    args.meta_args = []
    pacman_packages = []
    aur_packages = []

    for package in args.packages:
        validate_package_name(package)
        original = package
        package = normalize_name(package)
        alias_notice(original, package)

        source = args.source
        if source == "auto":
            if pacman_has(package):
                source = "pacman"
            elif paru_has(package):
                source = "aur"
            else:
                error(f"package not found in enabled pacman repos or AUR via paru: {package}")
                sys.exit(1)

        if source == "pacman":
            pacman_packages.append(package)
        elif source in {"aur", "paru", "yay"}:
            helper = "paru" if source == "aur" else source
            if source == "aur" and not command_exists(helper) and command_exists("yay"):
                helper = "yay"
            if not command_exists(helper):
                error(f"{helper} is required for AUR installs")
                sys.exit(1)
            aur_packages.append((helper, package))
        elif source == "sevenrepo":
            error("SevenRepo is planned but not enabled in this phase")
            sys.exit(1)
        else:
            error(f"unknown source: {source}")
            sys.exit(1)

    if pacman_packages:
        run(["sudo", "pacman", "-S", "--needed", *pacman_packages], args)
    if aur_packages:
        for helper in ("paru", "yay"):
            helper_packages = [package for item_helper, package in aur_packages if item_helper == helper]
            if helper_packages:
                run([helper, "-S", "--needed", *helper_packages], args)


def remove_packages(args):
    if getattr(args, "profile", None):
        payload = profile_remove_transaction_commands(args.profile, args.packages, force=getattr(args, "force", False))
        if getattr(args, "preview", False):
            print_transaction(payload, getattr(args, "json", False))
            return
        sys.exit(apply_transaction(payload, args))

    default_profile = active_profile()
    if default_profile != SYSTEM_PROFILE and not getattr(args, "global_install", False):
        payload = profile_remove_transaction_commands(default_profile, args.packages, force=getattr(args, "force", False))
        payload["default_profile_source"] = "active-profile"
        if getattr(args, "preview", False):
            print_transaction(payload, getattr(args, "json", False))
            return
        sys.exit(apply_transaction(payload, args))

    payload = transaction_commands("remove", args.packages, force=getattr(args, "force", False))
    if getattr(args, "preview", False):
        print_transaction(payload, getattr(args, "json", False))
        return
    if payload.get("blockers") and not getattr(args, "force", False):
        if is_dry_run(args):
            for warning in payload.get("warnings", []):
                log(f"WARN: {warning}")
            log("dry-run only; real removal would require --force")
        else:
            print_transaction(payload, getattr(args, "json", False))
            sys.exit(126)
    for package in args.packages:
        validate_package_name(package)
        if package in ALIASES:
            error(f"'{package}' is a retired SevenOS alias, not a removable system package. Use '{ALIASES[package]}' or remove concrete packages explicitly.")
            sys.exit(1)
    run(["sudo", "pacman", "-Rns", *args.packages], args)


def update_system(args):
    target_profile = getattr(args, "profile", None)
    default_profile = active_profile()
    if target_profile or (default_profile != SYSTEM_PROFILE and not getattr(args, "global_install", False)):
        payload = profile_update_transaction_commands(target_profile or default_profile)
        if not target_profile:
            payload["default_profile_source"] = "active-profile"
        if getattr(args, "preview", False):
            print_transaction(payload, getattr(args, "json", False))
            return
        sys.exit(apply_transaction(payload, args))

    if getattr(args, "preview", False):
        payload = transaction_commands("update", [])
        print_transaction(payload, getattr(args, "json", False))
        return
    pacman_args = ["pacman", "-Syu"]
    if assume_yes():
        pacman_args.append("--noconfirm")
    pacman_command = pacman_args if hasattr(os, "geteuid") and os.geteuid() == 0 else ["sudo", *pacman_args]
    run(pacman_command, args)
    if hasattr(os, "geteuid") and os.geteuid() == 0:
        log("AUR update skipped from privileged graphical update; use SevenStore or sevenpkg as a normal user for community packages.")
        return
    if command_exists("paru"):
        run(["paru", "-Sua"], args)
    else:
        log("paru not found; skipped AUR update")


def search_package(query, args):
    validate_package_name(query)
    manifest = load_manifest()
    query = normalize_name(query)

    for name, meta in manifest.items():
        if query.lower() in name.lower() or query.lower() in meta.get("description", "").lower():
            print(f"sevenos/{name} - {meta.get('description', '')}")

    run(["pacman", "-Ss", query], args, check=False)
    if command_exists("paru"):
        run(["paru", "-Ss", query], args, check=False)


def show_meta(args):
    manifest = load_manifest()
    if not manifest:
        if args.json:
            print("[]")
            return
        log("no SevenOS meta-packages found")
        return

    if args.json:
        items = []
        for name in sorted(manifest):
            meta = manifest[name]
            items.append(
                {
                    "name": name,
                    "description": meta.get("description", ""),
                    "kind": meta.get("kind", ""),
                    "target": meta.get("target", ""),
                    "optional": bool(meta.get("optional", False)),
                }
            )
        print(json.dumps(items, indent=2))
        return

    for name in sorted(manifest):
        print(f"{name:8} {manifest[name].get('description', '')}")


def show_status(args):
    manifest = load_manifest()
    if not manifest:
        if args.json:
            print("[]")
            return
        log("no SevenOS meta-packages found")
        return

    if args.json:
        items = []
        for name in sorted(manifest):
            meta = manifest[name]
            state, installed, total = meta_state_for_name(name, meta)
            items.append(
                {
                    "name": name,
                    "state": state,
                    "installed": installed,
                    "total": total,
                    "description": meta.get("description", ""),
                    "kind": meta.get("kind", ""),
                    "target": meta.get("target", ""),
                    "optional": bool(meta.get("optional", False)),
                    "packages": meta_packages(meta),
                }
            )
        print(json.dumps(items, indent=2))
        return

    for name in sorted(manifest):
        state, installed, total = meta_state_for_name(name, manifest[name])
        print(f"{name:8} {state:4} {installed:>2}/{total:<2} {manifest[name].get('description', '')}")


def flatpak_apps():
    app_file = ROOT_DIR / "scripts" / "flatpak-apps.txt"
    if not app_file.is_file():
        return []
    apps = []
    with app_file.open("r", encoding="utf-8") as handle:
        for line in handle:
            app = line.split("#", 1)[0].strip()
            if app:
                apps.append(app)
    return apps


def flatpak_app_installed(app_id):
    if not command_exists("flatpak"):
        return False
    return subprocess.run(["flatpak", "info", app_id], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def flathub_present():
    if not command_exists("flatpak"):
        return False
    result = subprocess.run(
        ["flatpak", "remotes", "--columns=name"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return False
    return "flathub" in {line.strip() for line in result.stdout.splitlines()}


def plan_payload(limit=None):
    manifest = load_manifest()
    mini_profiles = sorted(PROFILE_KEYS - {SYSTEM_PROFILE})
    rank = {"critical": 0, "high": 1, "medium": 2, "low": 3}
    priority = {
        "baobab": "critical",
        "shield": "critical",
        "forge": "high",
        "studio": "high",
        "windows": "high",
        "griot": "medium",
    }
    phase = {
        "baobab": "base",
        "shield": "security",
        "forge": "dev",
        "studio": "creative",
        "windows": "compatibility",
        "griot": "knowledge",
    }
    actions = []

    for name in sorted(manifest):
        meta = manifest[name]
        if meta.get("optional") is True:
            continue
        state, installed, total = meta_state_for_name(name, meta)
        if state == "OK":
            continue
        missing = max(total - installed, 0)
        severity = priority.get(name, "medium")
        actions.append(
            {
                "key": name,
                "state": state,
                "title": f"Install {'Forge DevOps' if name == 'forge' else name.title()} software layer",
                "severity": severity,
                "impact": "packages",
                "phase": phase.get(name, "software"),
                "reason": f"{'Forge DevOps' if name == 'forge' else name.title()} is {state} with {missing} missing packages.",
                "command": f"sevenpkg install {name}",
                "missing_count": missing,
                "installed": installed,
                "total": total,
            }
        )

    if not command_exists("flatpak"):
        actions.append(
            {
                "key": "flatpak",
                "state": "MISS",
                "title": "Install Flatpak",
                "severity": "high",
                "impact": "packages",
                "phase": "apps",
                "reason": "SevenOS needs Flatpak for mainstream creative and Windows app delivery.",
                "command": "seven flatpak setup",
            }
        )
    elif not flathub_present():
        actions.append(
            {
                "key": "flathub",
                "state": "MISS",
                "title": "Enable Flathub",
                "severity": "high",
                "impact": "changes",
                "phase": "apps",
                "reason": "Flathub is the default application source for Flatpak apps.",
                "command": "seven flatpak setup",
            }
        )

    missing_flatpaks = [app for app in flatpak_apps() if not flatpak_app_installed(app)]
    if missing_flatpaks:
        actions.append(
            {
                "key": "flatpak-defaults",
                "state": "PART" if command_exists("flatpak") else "MISS",
                "title": "Install default Flatpak apps",
                "severity": "medium",
                "impact": "packages",
                "phase": "apps",
                "reason": f"{len(missing_flatpaks)} default Flatpak apps are missing.",
                "command": "seven flatpak install",
                "missing_apps": missing_flatpaks,
            }
        )

    actions.sort(key=lambda item: (rank.get(item["severity"], 9), item.get("phase", ""), item.get("key", "")))
    if limit is not None:
        actions = actions[:limit]

    return {
        "schema": "sevenos.packages-plan.v1",
        "summary": {
            "total": len(actions),
            "critical": sum(1 for item in actions if item["severity"] == "critical"),
            "high": sum(1 for item in actions if item["severity"] == "high"),
            "medium": sum(1 for item in actions if item["severity"] == "medium"),
        },
        "sources": {
            "pacman": command_exists("pacman"),
            "paru": command_exists("paru"),
            "flatpak": command_exists("flatpak"),
            "flathub": flathub_present(),
            "sevenrepo": False,
            "profile_rootfs": all(profile_rootfs_ready(profile) for profile in mini_profiles),
            "profile_paru": all(helper_available_for_profile(profile, "paru") for profile in mini_profiles),
            "profile_yay": all(helper_available_for_profile(profile, "yay") for profile in mini_profiles),
        },
        "next": actions,
    }


def show_plan(args):
    payload = plan_payload(args.limit)
    if args.json:
        print(json.dumps(payload, indent=2))
        return

    summary = payload["summary"]
    print("SevenOS Software Plan")
    print("=====================")
    print(
        f"Open actions: {summary['total']} "
        f"({summary['critical']} critical, {summary['high']} high, {summary['medium']} medium)"
    )
    print()
    print(f"{'Severity':<9} {'Phase':<13} {'Command'}")
    print(f"{'--------':<9} {'-----':<13} {'-------'}")
    for item in payload["next"]:
        print(f"{item.get('severity',''):<9} {item.get('phase',''):<13} {item.get('command','')}")
        print(f"{'':<9} {'':<13} {item.get('reason','')}")

    optional = optional_payload()
    if optional["items"]:
        print()
        print("Optional layers available:")
        for item in optional["items"]:
            print(f"- {item['name']}: {item['state']} {item['installed']}/{item['total']} · sevenpkg install {item['name']} --optional")


def show_info(name, args):
    validate_package_name(name)
    manifest = load_manifest()

    if name in manifest:
        meta = manifest[name]
        print(f"Name:        {name}")
        print(f"Description: {meta.get('description', '')}")
        print(f"Kind:        {meta.get('kind', '')}")
        print(f"Optional:    {'yes' if meta.get('optional') else 'no'}")
        if "target" in meta:
            print(f"Target:      {meta['target']}")

        packages = meta_packages(meta)
        if packages:
            state, installed, total = meta_state_for_name(name, meta)
            installed_names = rootfs_package_names(name) if name in PROFILE_KEYS and name != SYSTEM_PROFILE and profile_rootfs_ready(name) else installed_package_set()
            print(f"Status:      {state} {installed}/{total}")
            print("Packages:")
            for package in packages:
                marker = "OK" if package_present(package, installed_names) else "MISS"
                print(f"  [{marker}] {package}")
        return

    if pacman_has(name):
        run(["pacman", "-Si", name], args, check=False)
        return

    if paru_has(name):
        run(["paru", "-Si", name], args, check=False)
        return

    error(f"package or meta-package not found: {name}")
    sys.exit(1)


def show_sources(_args):
    payload = {
        "schema": "sevenos.package-sources.v1",
        "sources": [
            {"key": "pacman", "state": "OK" if command_exists("pacman") else "MISS", "scope": "global-system", "detail": "Arch Linux repositories"},
            {"key": "paru", "state": "OK" if command_exists("paru") else "MISS", "scope": "global-system", "detail": "AUR helper"},
            {"key": "yay", "state": "OK" if command_exists("yay") else "MISS", "scope": "global-system", "detail": "AUR helper"},
            {"key": "flatpak", "state": "OK" if command_exists("flatpak") else "MISS", "scope": "user-apps", "detail": "Flatpak applications"},
            {"key": "sevenos", "state": "OK" if MANIFEST_PATH.is_file() else "MISS", "scope": "meta-packages", "detail": "SevenOS meta-packages"},
            {"key": "sevenrepo", "state": "PLANNED", "scope": "future", "detail": "planned SevenOS repository"},
        ],
    }
    if getattr(_args, "json", False):
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    for item in payload["sources"]:
        print(f"{item['key']:<9} {item['state']:<7} {item['scope']:<15} {item['detail']}")


def profile_sources_payload(profile):
    profile = normalize_profile(profile)
    if profile == SYSTEM_PROFILE:
        return {
            "schema": "sevenos.profile-package-sources.v1",
            "profile": profile,
            "scope": "global-system",
            "visibility": "global; Equinox installs on the host Arch system",
            "rootfs": "host-system",
            "rootfs_ready": True,
            "sources": [
                {
                    "key": "pacman",
                    "state": "OK" if command_exists("pacman") else "MISS",
                    "detail": "official Arch repositories",
                    "command": "sevenpkg equinox install <package> --source pacman",
                },
                {
                    "key": "paru",
                    "state": "OK" if command_exists("paru") else "MISS",
                    "detail": "global AUR helper",
                    "command": "sevenpkg equinox install <package> --source paru",
                },
                {
                    "key": "yay",
                    "state": "OK" if command_exists("yay") else "MISS",
                    "detail": "global AUR helper",
                    "command": "sevenpkg equinox install <package> --source yay",
                },
            ],
            "commands": {
                "install_pacman": "sevenpkg equinox install <package> --source pacman",
                "install_paru": "sevenpkg equinox install <package> --source paru",
                "install_yay": "sevenpkg equinox install <package> --source yay",
                "global_policy": "sevenpkg global-policy <package>",
                "global_expose": "sevenpkg global-expose <package> --profiles forge --commands <command>",
                "global_expose_all": "sevenpkg global-expose <package> --all-mini-os --commands <command>",
                "global_restrict": "sevenpkg global-restrict <package>",
                "packages": "sevenpkg equinox packages --query <package>",
                "limits": "sevenpkg equinox limits",
            },
            "next_actions": [],
        }

    ready = profile_rootfs_ready(profile)
    rootfs = profile_rootfs(profile)
    has_paru = helper_available_for_profile(profile, "paru")
    has_yay = helper_available_for_profile(profile, "yay")
    next_actions = []
    if not ready:
        next_actions.extend([
            f"seven profile-rootfs prepare {profile} --apply --yes",
            f"seven profile-rootfs build {profile} --apply --yes",
        ])
    if ready and not (has_paru or has_yay):
        next_actions.append(f"sevenpkg {profile} helper paru")

    return {
        "schema": "sevenos.profile-package-sources.v1",
        "profile": profile,
        "scope": "profile-rootfs",
        "visibility": f"private to {profile}; installs do not leak to other mini OS profiles",
        "rootfs": str(rootfs),
        "rootfs_ready": ready,
        "sources": [
            {
                "key": "pacman",
                "state": "OK" if ready else "AUTO-REPAIR",
                "detail": "official Arch repositories inside this mini OS rootfs",
                "command": f"sevenpkg {profile} install <package> --source pacman",
            },
            {
                "key": "paru",
                "state": "OK" if has_paru else "MISS",
                "detail": "private AUR helper inside this mini OS rootfs",
                "command": f"sevenpkg {profile} install <package> --source paru",
                "helper_command": f"sevenpkg {profile} helper paru",
            },
            {
                "key": "yay",
                "state": "OK" if has_yay else "MISS",
                "detail": "private AUR helper inside this mini OS rootfs",
                "command": f"sevenpkg {profile} install <package> --source yay",
                "helper_command": f"sevenpkg {profile} helper yay",
            },
        ],
        "commands": {
            "install_auto": f"sevenpkg {profile} install <package>",
            "install_pacman": f"sevenpkg {profile} install <package> --source pacman",
            "install_paru": f"sevenpkg {profile} install <package> --source paru",
            "install_yay": f"sevenpkg {profile} install <package> --source yay",
            "helper_paru": f"sevenpkg {profile} helper paru",
            "helper_yay": f"sevenpkg {profile} helper yay",
            "packages": f"sevenpkg {profile} packages --query <package>",
            "limits": f"sevenpkg {profile} limits",
        },
        "next_actions": next_actions,
    }


def show_profile_sources(args):
    payload = profile_sources_payload(args.profile)
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Profile Sources")
    print("========================")
    print(f"Profile:    {payload['profile']} · {payload['scope']}")
    print(f"Visibility: {payload['visibility']}")
    print(f"RootFS:     {payload['rootfs']}")
    print(f"Ready:      {'yes' if payload['rootfs_ready'] else 'no'}")
    print()
    print(f"{'Source':<7} {'State':<11} {'Command'}")
    print(f"{'------':<7} {'-----':<11} {'-------'}")
    for item in payload["sources"]:
        print(f"{item['key']:<7} {item['state']:<11} {item['command']}")
        if item.get("helper_command") and item["state"] != "OK":
            print(f"{'':<7} {'':<11} prepare: {item['helper_command']}")
    if payload.get("next_actions"):
        print()
        print("Next actions:")
        for action in payload["next_actions"]:
            print(f"  {action}")


def profile_limits_payload(profile_filter=None):
    if profile_filter:
        profile_filter = normalize_profile(profile_filter)
    profiles = []
    for profile in sorted(PROFILE_KEYS):
        if profile_filter and profile != profile_filter:
            continue
        if profile == SYSTEM_PROFILE:
            profiles.append({
                "profile": profile,
                "scope": "global-system",
                "visibility": "global; mini OS can receive exposed commands through package-view policy",
                "rootfs": "host-system",
                "rootfs_ready": True,
                "package_count": len(installed_package_set()),
                "install_sources": {
                    "pacman": command_exists("pacman"),
                    "paru": command_exists("paru"),
                    "yay": command_exists("yay"),
                },
                "commands": {
                    "pacman": "sevenpkg install --profile equinox <package> --source pacman",
                    "paru": "sevenpkg install --profile equinox <package> --source paru",
                    "yay": "sevenpkg install --profile equinox <package> --source yay",
                },
                "next_actions": [],
                "limits": [
                    "Installs modify the host Arch system.",
                    "Packages can be exposed to mini OS package views only through SevenOS policy.",
                ],
            })
            continue

        rootfs = profile_rootfs(profile)
        ready = profile_rootfs_ready(profile)
        has_paru = helper_available_for_profile(profile, "paru")
        has_yay = helper_available_for_profile(profile, "yay")
        next_actions = []
        if not ready:
            next_actions.append(f"seven profile-rootfs prepare {profile} --apply --yes")
            next_actions.append(f"seven profile-rootfs build {profile} --apply --yes")
            next_actions.append(f"sevenpkg install --profile {profile} code --source pacman")
        if ready and not (has_paru or has_yay):
            next_actions.append(f"add paru or yay to the {profile} rootfs before using --source paru|yay")
            next_actions.append("sevenpkg profile-helper-all paru --preview")
        profiles.append({
            "profile": profile,
            "scope": "profile-rootfs",
            "visibility": f"private to {profile}; not visible to other mini OS package views by default",
            "rootfs": str(rootfs),
            "rootfs_ready": ready,
            "package_count": rootfs_package_count(profile),
            "install_sources": {
                "pacman": ready,
                "paru": has_paru,
                "yay": has_yay,
            },
            "commands": {
                "pacman": f"sevenpkg install --profile {profile} <package> --source pacman",
                "paru": f"sevenpkg install --profile {profile} <package> --source paru",
                "yay": f"sevenpkg install --profile {profile} <package> --source yay",
                "prepare": f"seven profile-rootfs prepare {profile} --apply --yes",
                "build": f"seven profile-rootfs build {profile} --apply --yes",
            },
            "next_actions": next_actions,
            "limits": [
                "Requires a ready profile rootfs before package installs can apply.",
                "AUR helpers must be installed inside this profile rootfs.",
                "Rootfs is resealed after package maintenance.",
            ],
        })
    return {
        "schema": "sevenos.profile-package-limits.v1",
        "system_profile": SYSTEM_PROFILE,
        "active_profile": active_profile(),
        "profile_filter": profile_filter,
        "profiles": profiles,
        "summary": {
            "profiles": len(profiles),
            "global_system": sum(1 for item in profiles if item["scope"] == "global-system"),
            "profile_rootfs": sum(1 for item in profiles if item["scope"] == "profile-rootfs"),
            "ready_rootfs": sum(1 for item in profiles if item["scope"] == "profile-rootfs" and item["rootfs_ready"]),
        },
    }


def show_profile_limits(args):
    payload = profile_limits_payload(getattr(args, "profile", None))
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Profile Package Limits")
    print("===============================")
    print(f"System profile: {payload['system_profile']} · Active: {payload['active_profile']}")
    print()
    print(f"{'Profile':<8} {'Scope':<15} {'RootFS':<8} {'pacman':<6} {'paru':<5} {'yay':<5}")
    print(f"{'-------':<8} {'-----':<15} {'------':<8} {'------':<6} {'----':<5} {'---':<5}")
    for item in payload["profiles"]:
        sources = item["install_sources"]
        print(
            f"{item['profile']:<8} {item['scope']:<15} "
            f"{'ready' if item['rootfs_ready'] else 'missing':<8} "
            f"{'yes' if sources.get('pacman') else 'no':<6} "
            f"{'yes' if sources.get('paru') else 'no':<5} "
            f"{'yes' if sources.get('yay') else 'no':<5}"
        )
    if len(payload["profiles"]) == 1:
        item = payload["profiles"][0]
        print()
        print(f"Visibility: {item['visibility']}")
        print(f"RootFS:     {item['rootfs']}")
        print("Commands:")
        for key, command in item["commands"].items():
            print(f"  {key:<6} {command}")
        if item.get("next_actions"):
            print("Next actions:")
            for action in item["next_actions"]:
                print(f"  {action}")
    print()
    print("Use: sevenpkg install --profile <profile> <package> --source pacman|paru|yay")


def profile_packages_payload(profile_filter=None, query=None, limit=None):
    if profile_filter:
        profile_filter = normalize_profile(profile_filter)
    profiles = []
    for profile in sorted(PROFILE_KEYS):
        if profile_filter and profile != profile_filter:
            continue
        scope = "global-system" if profile == SYSTEM_PROFILE else "profile-rootfs"
        packages = host_packages() if profile == SYSTEM_PROFILE else rootfs_packages(profile)
        if query:
            query_lower = query.lower()
            packages = [
                item for item in packages
                if query_lower in item.get("name", "").lower()
                or query_lower in item.get("description", "").lower()
            ]
        total = len(packages)
        shown = packages[:limit] if limit is not None else packages
        profiles.append({
            "profile": profile,
            "scope": scope,
            "rootfs": "host-system" if profile == SYSTEM_PROFILE else str(profile_rootfs(profile)),
            "rootfs_ready": True if profile == SYSTEM_PROFILE else profile_rootfs_ready(profile),
            "rootfs_state": "host-system" if profile == SYSTEM_PROFILE else "ready" if profile_rootfs_ready(profile) else "prepared" if profile_rootfs(profile).exists() else "missing",
            "repair_commands": [] if profile == SYSTEM_PROFILE or profile_rootfs_ready(profile) else [
                "seven profile-rootfs prepare {profile} --apply --yes".format(profile=profile),
                "seven profile-rootfs build {profile} --apply --yes".format(profile=profile),
            ],
            "install_hint": None if profile == SYSTEM_PROFILE or profile_rootfs_ready(profile) else "sevenpkg install --profile {profile} code --source pacman".format(profile=profile),
            "package_count": total,
            "packages": shown,
            "truncated": limit is not None and total > len(shown),
        })
    return {
        "schema": "sevenos.profile-package-inventory.v1",
        "system_profile": SYSTEM_PROFILE,
        "active_profile": active_profile(),
        "profile_filter": profile_filter,
        "query": query,
        "limit": limit,
        "summary": {
            "profiles": len(profiles),
            "packages": sum(item["package_count"] for item in profiles),
            "ready_rootfs": sum(1 for item in profiles if item["scope"] == "profile-rootfs" and item["rootfs_ready"]),
        },
        "profiles": profiles,
    }


def show_profile_packages(args):
    payload = profile_packages_payload(args.profile, query=args.query, limit=args.limit)
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Profile Packages")
    print("=========================")
    for profile in payload["profiles"]:
        print(f"{profile['profile']} · {profile['scope']} · {profile['package_count']} package(s)")
        if not profile["rootfs_ready"]:
            print(f"  rootfs {profile.get('rootfs_state', 'missing')}: {profile['rootfs']}")
            if args.query and normalize_name(args.query) != args.query:
                print(f"  package alias: {args.query} -> {normalize_name(args.query)}")
            print("  repair:")
            for command in profile.get("repair_commands", []):
                print(f"    {command}")
            if profile.get("install_hint"):
                print(f"  after rootfs is ready: {profile['install_hint']}")
            print("  full new-machine setup: seven new --rootfs")
            continue
        for item in profile["packages"]:
            version = f" {item['version']}" if item.get("version") else ""
            print(f"  {item['name']}{version}")
        if profile["truncated"]:
            print(f"  ... {profile['package_count'] - len(profile['packages'])} more")


def owner_payload(packages):
    manifest = load_manifest()
    owners = package_owner_map(manifest)
    items = []
    for package in packages:
        validate_package_name(package)
        normalized = normalize_name(package)
        package_owners = sorted(set(owners.get(normalized, [])))
        alternatives = package_alternatives(normalized)
        if not package_owners:
            for alternative in alternatives:
                package_owners.extend(owners.get(alternative, []))
            package_owners = sorted(set(package_owners))
        items.append({
            "package": package,
            "normalized": normalized,
            "installed": package_installed(normalized),
            "owners": package_owners,
            "profiles": [owner for owner in package_owners if owner in PROFILE_KEYS],
            "optional": [
                name for name, meta in manifest.items()
                if normalized in meta_optional_packages(meta)
            ],
            "alternatives": list(alternatives),
            "removal_guarded": bool(package_owners),
            "remove_preview": f"sevenpkg transaction remove {normalized}",
        })
    return {"schema": "sevenos.package-owner.v1", "items": items}


def show_owner(args):
    payload = owner_payload(args.packages)
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Ownership")
    print("==================")
    for item in payload["items"]:
        owners = ", ".join(item["owners"]) if item["owners"] else "none"
        state = "installed" if item["installed"] else "not installed"
        print(f"{item['normalized']}: {owners} · {state}")
        if item["removal_guarded"]:
            print(f"  removal is guarded: {item['remove_preview']}")


def optional_payload():
    manifest = load_manifest()
    items = []
    for name in sorted(manifest):
        meta = manifest[name]
        optional_packages = meta_optional_packages(meta) if meta.get("optional") is not True else meta_packages(meta)
        if not optional_packages:
            continue
        profile = normalize_name(name)
        if profile in PROFILE_KEYS and profile != SYSTEM_PROFILE and profile_rootfs_ready(profile):
            installed_names = rootfs_package_names(profile)
        else:
            installed_names = installed_package_set()
        installed = sum(1 for package in optional_packages if package_present(package, installed_names))
        total = len(optional_packages)
        state = "OK" if installed == total else ("PART" if installed else "MISS")
        items.append({
            "name": name,
            "state": state,
            "installed": installed,
            "total": total,
            "packages": optional_packages,
            "description": meta.get("description", ""),
            "command": f"sevenpkg install {name} --optional",
        })
    return {"schema": "sevenos.optional-software.v1", "items": items}


def show_optional(args):
    payload = optional_payload()
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenOS Optional Software")
    print("========================")
    if not payload["items"]:
        print("No optional software layer declared.")
        return
    for item in payload["items"]:
        print(f"{item['name']:8} {item['state']:4} {item['installed']:>2}/{item['total']:<2} {item['description']}")
        print(f"         {item['command']}")


def show_history(args):
    events = []
    if TRANSACTION_LOG.is_file():
        with TRANSACTION_LOG.open("r", encoding="utf-8") as handle:
            for line in handle:
                try:
                    events.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
    events = events[-args.limit :]
    if args.json:
        print(json.dumps({"schema": "sevenos.package-transaction-history.v1", "events": events}, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Transaction History")
    print("============================")
    if not events:
        print("No transaction recorded yet.")
        return
    for event in events:
        print(f"{event.get('timestamp', '')} {event.get('status', ''):<9} {event.get('action', ''):<7} {' '.join(event.get('items', []))}")


def doctor_payload():
    manifest = load_manifest()
    plan = plan_payload()
    optional = optional_payload()
    checks = []

    def add_check(key, title, ok, severity, detail="", command=""):
        checks.append({
            "key": key,
            "title": title,
            "state": "OK" if ok else ("WARN" if severity in {"low", "medium"} else "BLOCK"),
            "severity": severity,
            "detail": detail,
            "command": command,
        })

    add_check(
        "manifest",
        "SevenPkg manifest",
        MANIFEST_PATH.is_file() and bool(manifest),
        "high",
        str(MANIFEST_PATH),
        "python -m json.tool sevenpkg/metapackages.json",
    )
    required_profiles = {"equinox", "baobab", "forge", "shield", "studio", "windows", "pulse"}
    missing_profiles = sorted(required_profiles - set(manifest))
    add_check(
        "profile-layers",
        "Mini OS software layers",
        not missing_profiles,
        "high",
        "missing: " + ", ".join(missing_profiles) if missing_profiles else "all core mini OS layers are declared",
        "sevenpkg meta",
    )
    add_check("pacman", "pacman source", command_exists("pacman"), "critical", "required Arch package source", "sevenpkg sources")
    add_check("flatpak", "Flatpak source", command_exists("flatpak"), "medium", "used for mainstream apps", "seven flatpak setup")
    add_check("flathub", "Flathub remote", flathub_present(), "medium", "default Flatpak application source", "seven flatpak setup")
    add_check("aur-helper", "AUR helper", command_exists("paru") or command_exists("yay"), "low", "optional; used for AUR packages", "sevenpkg sources")
    equinox_tx = profile_transaction_commands(SYSTEM_PROFILE, ["htop"], source="pacman")
    forge_tx = profile_transaction_commands("forge", ["htop"], source="pacman")
    add_check(
        "profile-package-equinox",
        "Equinox package scope",
        equinox_tx.get("profile_scope") == "global-system" and equinox_tx.get("impact") == "global-system-packages",
        "critical",
        "Equinox package installs must target the global system",
        "sevenpkg install --profile equinox htop --source pacman --preview",
    )
    add_check(
        "profile-package-mini-os",
        "Mini OS package scope",
        forge_tx.get("profile_scope") == "profile-rootfs" and "private to forge" in forge_tx.get("visibility", ""),
        "critical",
        "Mini OS package installs must stay private to the target rootfs",
        "sevenpkg profile-limits",
    )
    add_check(
        "transactions",
        "Transaction journal",
        TRANSACTION_LOG.exists() or STATE_DIR.exists(),
        "low",
        str(TRANSACTION_LOG),
        "sevenpkg history",
    )
    add_check(
        "transaction-lock",
        "Transaction lock",
        TRANSACTION_LOCK.parent.exists() or STATE_DIR.exists(),
        "low",
        str(TRANSACTION_LOCK),
        "sevenpkg transaction install forge",
    )
    guarded = transaction_commands("remove", ["nmap"])
    add_check(
        "remove-guard",
        "SevenOS removal guard",
        bool(guarded.get("blockers")),
        "critical",
        "SevenOS-owned packages are blocked unless --force is explicit",
        "sevenpkg transaction remove nmap",
    )
    add_check(
        "software-plan",
        "Software readiness plan",
        plan["summary"]["critical"] == 0 and plan["summary"]["high"] == 0,
        "high",
        f"{plan['summary']['total']} open actions",
        "sevenpkg plan",
    )
    optional_open = [item for item in optional["items"] if item["state"] != "OK"]
    limits = profile_limits_payload()
    missing_rootfs = [
        item["profile"]
        for item in limits["profiles"]
        if item["scope"] == "profile-rootfs" and not item["rootfs_ready"]
    ]
    add_check(
        "profile-rootfs-readiness",
        "Mini OS rootfs readiness",
        not missing_rootfs,
        "medium",
        "missing rootfs: " + ", ".join(missing_rootfs) if missing_rootfs else "all mini OS rootfs targets are ready",
        "sevenpkg profile-limits",
    )
    add_check(
        "optional-visibility",
        "Optional software visibility",
        True,
        "low",
        f"{len(optional_open)} optional layer(s) not complete",
        "sevenpkg optional",
    )

    score = 100
    penalties = {"critical": 35, "high": 20, "medium": 10, "low": 4}
    for check in checks:
        if check["state"] != "OK":
            score -= penalties.get(check["severity"], 5)
    score = max(0, score)
    blockers = [check for check in checks if check["state"] == "BLOCK"]
    warnings = [check for check in checks if check["state"] == "WARN"]
    return {
        "schema": "sevenos.package-doctor.v1",
        "score": score,
        "state": "OK" if not blockers and score >= 85 else ("WARN" if not blockers else "BLOCK"),
        "sources": plan["sources"],
        "summary": {
            "checks": len(checks),
            "blockers": len(blockers),
            "warnings": len(warnings),
            "optional_open": len(optional_open),
        },
        "checks": checks,
        "next": [
            {"title": check["title"], "command": check["command"], "detail": check["detail"]}
            for check in [*blockers, *warnings]
            if check.get("command")
        ][:6],
    }


def show_doctor(args):
    payload = doctor_payload()
    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
        return
    print("SevenPkg Doctor")
    print("===============")
    print(f"State: {payload['state']} · Score: {payload['score']}/100")
    print(f"Checks: {payload['summary']['checks']} · Blockers: {payload['summary']['blockers']} · Warnings: {payload['summary']['warnings']}")
    print()
    for check in payload["checks"]:
        print(f"[{check['state']}] {check['title']}")
        if check.get("detail"):
            print(f"     {check['detail']}")
    if payload["next"]:
        print()
        print("Next actions:")
        for item in payload["next"]:
            print(f"- {item['command']}")


def handle_transaction(args):
    payload = transaction_commands(
        args.tx_action,
        args.items,
        source=args.source,
        include_optional=args.optional,
        force=args.force,
    )
    if not args.apply:
        print_transaction(payload, args.json)
        return
    sys.exit(apply_transaction(payload, args, run_repairs=not args.no_repair))


def main():
    dry_run_requested = "--dry-run" in sys.argv[1:]
    if dry_run_requested:
        sys.argv = [sys.argv[0], *[arg for arg in sys.argv[1:] if arg != "--dry-run"]]

    parser = argparse.ArgumentParser(prog="sevenpkg", description="SevenOS package and application manager")
    parser.add_argument("--dry-run", action="store_true", default=dry_run_requested, help="show commands without changing the system")
    subparsers = parser.add_subparsers(dest="command")

    install_parser = subparsers.add_parser("install", help="install a package or SevenOS meta-package")
    install_parser.add_argument("packages", nargs="+")
    install_parser.add_argument("--source", choices=("auto", "pacman", "aur", "paru", "yay", "sevenrepo"), default="auto")
    install_parser.add_argument("--profile", choices=sorted(PROFILE_KEYS), help="install into one SevenOS profile; mini OS profiles use their private rootfs, Equinox uses the global system")
    install_parser.add_argument("--global", dest="global_install", action="store_true", help="force the global Equinox/system package scope even when a mini OS is active")
    install_parser.add_argument("--optional", action="store_true", help="include optional packages declared for this SevenOS layer")
    install_parser.add_argument("--preview", action="store_true", help="preview the SevenOS transaction without changing the system")
    install_parser.add_argument("--transaction", action="store_true", help="apply through the SevenOS transaction layer and run post-install repair")
    install_parser.add_argument("--json", action="store_true", help="print machine-readable preview when using --preview")

    remove_parser = subparsers.add_parser("remove", help="remove a package")
    remove_parser.add_argument("packages", nargs="+")
    remove_parser.add_argument("--profile", choices=sorted(PROFILE_KEYS), help="remove from one SevenOS profile; mini OS profiles use their private rootfs")
    remove_parser.add_argument("--global", dest="global_install", action="store_true", help="force the global Equinox/system package scope even when a mini OS is active")
    remove_parser.add_argument("--force", action="store_true", help="allow removal of packages owned by SevenOS layers")
    remove_parser.add_argument("--preview", action="store_true", help="show removal impact without changing the system")
    remove_parser.add_argument("--json", action="store_true", help="print machine-readable preview when using --preview")

    search_parser = subparsers.add_parser("search", help="search packages and meta-packages")
    search_parser.add_argument("query")

    info_parser = subparsers.add_parser("info", help="show package or meta-package details")
    info_parser.add_argument("name")

    update_parser = subparsers.add_parser("update", help="update system packages")
    update_parser.add_argument("--profile", choices=sorted(PROFILE_KEYS), help="update one SevenOS profile; mini OS profiles use their private rootfs")
    update_parser.add_argument("--global", dest="global_install", action="store_true", help="force the global Equinox/system package scope even when a mini OS is active")
    update_parser.add_argument("--preview", action="store_true", help="show update commands without changing the system")
    update_parser.add_argument("--json", action="store_true", help="print machine-readable preview when using --preview")
    meta_parser = subparsers.add_parser("meta", help="list SevenOS meta-packages")
    meta_parser.add_argument("--json", action="store_true", help="print machine-readable meta-packages")
    status_parser = subparsers.add_parser("status", help="show SevenOS meta-package installation status")
    status_parser.add_argument("--json", action="store_true", help="print machine-readable installation status")
    owner_parser = subparsers.add_parser("owner", help="show which SevenOS layer owns packages")
    owner_parser.add_argument("packages", nargs="+")
    owner_parser.add_argument("--json", action="store_true", help="print machine-readable package ownership")
    doctor_parser = subparsers.add_parser("doctor", help="diagnose SevenPkg sources, layers and guarded transactions")
    doctor_parser.add_argument("--json", action="store_true", help="print machine-readable SevenPkg doctor report")
    plan_parser = subparsers.add_parser("plan", help="show prioritized software completion plan")
    plan_parser.add_argument("--json", action="store_true", help="print machine-readable software plan")
    plan_parser.add_argument("--limit", type=int, help="maximum actions to show")
    optional_parser = subparsers.add_parser("optional", help="show optional SevenOS software layers")
    optional_parser.add_argument("--json", action="store_true", help="print machine-readable optional software")
    transaction_parser = subparsers.add_parser("transaction", help="preview or apply a guarded SevenOS package transaction")
    transaction_parser.add_argument("tx_action", choices=("install", "remove", "update"))
    transaction_parser.add_argument("items", nargs="*")
    transaction_parser.add_argument("--source", choices=("auto", "pacman", "aur", "paru", "yay", "sevenrepo"), default="auto")
    transaction_parser.add_argument("--optional", action="store_true", help="include optional packages for meta-package installs")
    transaction_parser.add_argument("--force", action="store_true", help="allow guarded removals")
    transaction_parser.add_argument("--apply", action="store_true", help="execute the transaction")
    transaction_parser.add_argument("--yes", action="store_true", help="accepted for non-interactive SevenOS flows")
    transaction_parser.add_argument("--wait", action="store_true", help="wait for another SevenPkg transaction to finish")
    transaction_parser.add_argument("--no-repair", action="store_true", help="skip SevenOS post-transaction repair hooks")
    transaction_parser.add_argument("--json", action="store_true", help="print machine-readable transaction")
    history_parser = subparsers.add_parser("history", help="show recent SevenPkg transactions")
    history_parser.add_argument("--json", action="store_true", help="print machine-readable transaction history")
    history_parser.add_argument("--limit", type=int, default=12, help="maximum events to show")
    sources_parser = subparsers.add_parser("sources", help="show package sources")
    sources_parser.add_argument("--json", action="store_true", help="print machine-readable package sources")
    global_policy_parser = subparsers.add_parser("global-policy", help="show Equinox host package exposure policy for mini OS package views")
    global_policy_parser.add_argument("package", nargs="?", help="show one package policy")
    global_policy_parser.add_argument("--json", action="store_true")
    global_expose_parser = subparsers.add_parser("global-expose", help="expose an Equinox/global package command to selected mini OS package views")
    global_expose_parser.add_argument("package")
    global_expose_parser.add_argument("--profiles", nargs="+", help="target mini OS profiles; accepts space or comma separated names")
    global_expose_parser.add_argument("--all-mini-os", action="store_true", help="expose to every mini OS profile")
    global_expose_parser.add_argument("--commands", nargs="+", help="commands to expose; accepts space or comma separated names")
    global_expose_parser.add_argument("--json", action="store_true")
    global_restrict_parser = subparsers.add_parser("global-restrict", help="restrict an Equinox/global package to Equinox only")
    global_restrict_parser.add_argument("package")
    global_restrict_parser.add_argument("--json", action="store_true")
    global_clear_parser = subparsers.add_parser("global-clear", help="remove an explicit Equinox/global package exposure policy")
    global_clear_parser.add_argument("package")
    global_clear_parser.add_argument("--json", action="store_true")
    profile_service_parser = subparsers.add_parser("profile-service", help="manage user services that run inside a mini OS rootfs")
    profile_service_sub = profile_service_parser.add_subparsers(dest="profile_service_action")
    profile_service_list = profile_service_sub.add_parser("list", help="list SevenOS profile services")
    profile_service_list.add_argument("--json", action="store_true")
    profile_service_status = profile_service_sub.add_parser("status", help="show one SevenOS profile service")
    profile_service_status.add_argument("profile", choices=sorted(PROFILE_KEYS - {SYSTEM_PROFILE}))
    profile_service_status.add_argument("name")
    profile_service_status.add_argument("--json", action="store_true")
    profile_service_create = profile_service_sub.add_parser("create", help="create a generic profile service; command follows --")
    profile_service_create.add_argument("profile", choices=sorted(PROFILE_KEYS - {SYSTEM_PROFILE}))
    profile_service_create.add_argument("name")
    profile_service_create.add_argument("--description")
    profile_service_create.add_argument("--enable", action="store_true")
    profile_service_create.add_argument("--start", action="store_true")
    profile_service_create.add_argument("--json", action="store_true")
    profile_service_create.add_argument("service_command", nargs=argparse.REMAINDER)
    profile_service_mongodb = profile_service_sub.add_parser("mongodb", help="create a MongoDB service inside one mini OS rootfs")
    profile_service_mongodb.add_argument("profile", choices=sorted(PROFILE_KEYS - {SYSTEM_PROFILE}))
    profile_service_mongodb.add_argument("--name", default="mongodb")
    profile_service_mongodb.add_argument("--binary", default="mongod")
    profile_service_mongodb.add_argument("--bind", default="127.0.0.1")
    profile_service_mongodb.add_argument("--port", type=int, default=27017)
    profile_service_mongodb.add_argument("--enable", action="store_true")
    profile_service_mongodb.add_argument("--start", action="store_true")
    profile_service_mongodb.add_argument("--json", action="store_true")
    for service_action in ("start", "stop", "restart", "enable", "disable", "remove"):
        service_parser = profile_service_sub.add_parser(service_action, help=f"{service_action} a SevenOS profile service")
        service_parser.add_argument("profile", choices=sorted(PROFILE_KEYS - {SYSTEM_PROFILE}))
        service_parser.add_argument("name")
        service_parser.add_argument("--json", action="store_true")
    profile_limits_parser = subparsers.add_parser("profile-limits", help="show package installation limits for Equinox and mini OS profiles")
    profile_limits_parser.add_argument("profile", nargs="?", choices=sorted(PROFILE_KEYS), help="show one profile instead of the full matrix")
    profile_limits_parser.add_argument("--json", action="store_true", help="print machine-readable profile package limits")
    profile_packages_parser = subparsers.add_parser("profile-packages", help="show installed packages by SevenOS profile/rootfs")
    profile_packages_parser.add_argument("profile", nargs="?", choices=sorted(PROFILE_KEYS), help="show one profile instead of every profile")
    profile_packages_parser.add_argument("--query", help="filter package names and descriptions")
    profile_packages_parser.add_argument("--limit", type=int, default=25, help="maximum packages to print per profile; use 0 for all")
    profile_packages_parser.add_argument("--json", action="store_true", help="print machine-readable package inventory")
    profile_sources_parser = subparsers.add_parser("profile-sources", help="show pacman/AUR sources for one SevenOS profile")
    profile_sources_parser.add_argument("profile", choices=sorted(PROFILE_KEYS))
    profile_sources_parser.add_argument("--json", action="store_true", help="print machine-readable profile package sources")
    profile_helper_all_parser = subparsers.add_parser("profile-helper-all", help="prepare an AUR helper inside every mini OS rootfs")
    profile_helper_all_parser.add_argument("helper", choices=("paru", "yay"))
    profile_helper_all_parser.add_argument("--profiles", nargs="+", help="mini OS profiles to target; accepts space or comma separated names")
    profile_helper_all_parser.add_argument("--include-installed", action="store_true", help="verify/reseal profiles where the helper is already present")
    profile_helper_all_parser.add_argument("--preview", action="store_true")
    profile_helper_all_parser.add_argument("--json", action="store_true")
    profile_install_parser = subparsers.add_parser("profile-install", help="install packages into a specific SevenOS profile rootfs")
    profile_install_parser.add_argument("profile", choices=sorted(PROFILE_KEYS))
    profile_install_parser.add_argument("packages", nargs="+")
    profile_install_parser.add_argument("--source", choices=("auto", "pacman", "aur", "paru", "yay", "sevenrepo"), default="auto")
    profile_install_parser.add_argument("--preview", action="store_true", help="preview the profile-scoped transaction")
    profile_install_parser.add_argument("--json", action="store_true", help="print machine-readable profile transaction")
    profile_remove_parser = subparsers.add_parser("profile-remove", help="remove packages from a specific SevenOS profile rootfs")
    profile_remove_parser.add_argument("profile", choices=sorted(PROFILE_KEYS))
    profile_remove_parser.add_argument("packages", nargs="+")
    profile_remove_parser.add_argument("--force", action="store_true", help="allow guarded global removals when profile is Equinox")
    profile_remove_parser.add_argument("--preview", action="store_true", help="preview the profile-scoped removal")
    profile_remove_parser.add_argument("--json", action="store_true", help="print machine-readable profile transaction")
    profile_shortcuts = {}
    for profile_name in sorted(PROFILE_KEYS):
        shortcut = subparsers.add_parser(profile_name, help=f"manage packages for the {profile_name} profile")
        shortcut_sub = shortcut.add_subparsers(dest="profile_action")
        shortcut_install = shortcut_sub.add_parser("install", help=f"install packages into {profile_name}")
        shortcut_install.add_argument("packages", nargs="+")
        shortcut_install.add_argument("--source", choices=("auto", "pacman", "aur", "paru", "yay", "sevenrepo"), default="auto")
        shortcut_install.add_argument("--preview", action="store_true")
        shortcut_install.add_argument("--json", action="store_true")
        shortcut_remove = shortcut_sub.add_parser("remove", help=f"remove packages from {profile_name}")
        shortcut_remove.add_argument("packages", nargs="+")
        shortcut_remove.add_argument("--force", action="store_true")
        shortcut_remove.add_argument("--preview", action="store_true")
        shortcut_remove.add_argument("--json", action="store_true")
        shortcut_update = shortcut_sub.add_parser("update", help=f"update packages inside {profile_name}")
        shortcut_update.add_argument("--preview", action="store_true")
        shortcut_update.add_argument("--json", action="store_true")
        shortcut_packages = shortcut_sub.add_parser("packages", help=f"show packages installed in {profile_name}")
        shortcut_packages.add_argument("--query")
        shortcut_packages.add_argument("--limit", type=int, default=25)
        shortcut_packages.add_argument("--json", action="store_true")
        shortcut_limits = shortcut_sub.add_parser("limits", help=f"show install limits for {profile_name}")
        shortcut_limits.add_argument("--json", action="store_true")
        shortcut_sources = shortcut_sub.add_parser("sources", help=f"show pacman/AUR sources for {profile_name}")
        shortcut_sources.add_argument("--json", action="store_true")
        shortcut_helper = shortcut_sub.add_parser("helper", help=f"prepare an AUR helper inside {profile_name}")
        shortcut_helper.add_argument("helper", choices=("paru", "yay"))
        shortcut_helper.add_argument("--preview", action="store_true")
        shortcut_helper.add_argument("--json", action="store_true")
        profile_shortcuts[profile_name] = shortcut

    args = parser.parse_args()

    if args.command == "install":
        install_packages(args)
    elif args.command == "profile-install":
        payload = profile_transaction_commands(args.profile, args.packages, source=args.source)
        if args.preview:
            print_transaction(payload, args.json)
            return
        sys.exit(apply_transaction(payload, args))
    elif args.command == "profile-remove":
        payload = profile_remove_transaction_commands(args.profile, args.packages, force=args.force)
        if args.preview:
            print_transaction(payload, args.json)
            return
        sys.exit(apply_transaction(payload, args))
    elif args.command in PROFILE_KEYS:
        profile = args.command
        action = getattr(args, "profile_action", None)
        if action == "install":
            payload = profile_transaction_commands(profile, args.packages, source=args.source)
            if args.preview:
                print_transaction(payload, args.json)
                return
            sys.exit(apply_transaction(payload, args))
        if action == "remove":
            payload = profile_remove_transaction_commands(profile, args.packages, force=args.force)
            if args.preview:
                print_transaction(payload, args.json)
                return
            sys.exit(apply_transaction(payload, args))
        if action == "update":
            payload = profile_update_transaction_commands(profile)
            if args.preview:
                print_transaction(payload, args.json)
                return
            sys.exit(apply_transaction(payload, args))
        if action == "packages":
            if args.limit == 0:
                args.limit = None
            args.profile = profile
            show_profile_packages(args)
            return
        if action == "limits":
            args.profile = profile
            show_profile_limits(args)
            return
        if action == "sources":
            args.profile = profile
            show_profile_sources(args)
            return
        if action == "helper":
            payload = profile_helper_transaction_commands(profile, args.helper)
            if args.preview:
                print_transaction(payload, args.json)
                return
            sys.exit(apply_transaction(payload, args))
        profile_shortcuts[profile].print_help()
    elif args.command == "remove":
        remove_packages(args)
    elif args.command == "update":
        update_system(args)
    elif args.command == "search":
        search_package(args.query, args)
    elif args.command == "info":
        show_info(args.name, args)
    elif args.command == "meta":
        show_meta(args)
    elif args.command == "status":
        show_status(args)
    elif args.command == "owner":
        show_owner(args)
    elif args.command == "doctor":
        show_doctor(args)
    elif args.command == "plan":
        show_plan(args)
    elif args.command == "optional":
        show_optional(args)
    elif args.command == "transaction":
        handle_transaction(args)
    elif args.command == "history":
        show_history(args)
    elif args.command == "sources":
        show_sources(args)
    elif args.command == "global-policy":
        show_global_policy(args)
    elif args.command == "global-expose":
        global_expose(args)
    elif args.command == "global-restrict":
        global_restrict(args)
    elif args.command == "global-clear":
        global_clear(args)
    elif args.command == "profile-service":
        handle_profile_service(args)
    elif args.command == "profile-limits":
        show_profile_limits(args)
    elif args.command == "profile-packages":
        if args.limit == 0:
            args.limit = None
        show_profile_packages(args)
    elif args.command == "profile-sources":
        show_profile_sources(args)
    elif args.command == "profile-helper-all":
        payload = profile_helper_all_transaction_commands(
            args.helper,
            profiles=args.profiles,
            include_installed=args.include_installed,
        )
        if args.preview:
            print_transaction(payload, args.json)
            return
        sys.exit(apply_transaction(payload, args))
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
