      "scripts/packages-creation.txt"
    ]
  },
  "baobab": {
    "description": "SevenOS base system and desktop layer",
    "kind": "sevenos-target",
    "target": "base",
    "package_files": [
      "scripts/packages-base.txt"
    ]
