package_file_state() {
  local package_file="$1"
  local installed=0
  local total=0
  local package

  [[ -f "$package_file" ]] || { printf 'MISS'; return 0; }

  while IFS= read -r package; do
    package="${package%%#*}"
    package="${package//[[:space:]]/}"
    [[ -z "$package" ]] && continue

    total=$((total + 1))
    if pacman -Q "$package" >/dev/null 2>&1; then
      installed=$((installed + 1))
    fi
  done < "$package_file"

  if [[ "$total" -eq 0 ]]; then
    printf 'MISS'
  elif [[ "$installed" -eq "$total" ]]; then
    printf 'OK'
  elif [[ "$installed" -gt 0 ]]; then
    printf 'PART'
  else
    printf 'MISS'
  fi
}

service_state() {
  local service="$1"
  if systemctl is-active --quiet "$service" 2>/dev/null; then
    printf 'OK'
  elif systemctl is-enabled --quiet "$service" 2>/dev/null; then
    printf 'PART'
  else
    printf 'MISS'
  fi
}

app_state() {
  local command_name="$1"
  if command -v "$command_name" >/dev/null 2>&1; then
    printf 'OK'
  else
    printf 'MISS'
  fi
}

blackarch_state() {
  if pacman-conf --repo-list 2>/dev/null | grep -qx 'blackarch'; then
    printf 'OK'
  elif grep -Eq '^\[blackarch\]' /etc/pacman.conf 2>/dev/null; then
    printf 'PART'
  else
    printf 'MISS'
  fi
}

action_badge() {
  local label="$1"

  case "$label" in
    "Control Center"|"Dashboard"|"Profiles"|"Cyber"|"Desktop"|"VM & Windows"|"Server & Deploy"|"Ecosystem"|"Installer"|"Apps") printf 'OPEN' ;;
    "Welcome"|"System Dashboard"|"Architecture Map"|"Architecture Doctor"|"Ecosystem Map"|"Ecosystem Roadmap"|"Ecosystem Doctor"|"Phase Gate"|"Readiness Score"|"Improve Plan"|"Repair Plan"|"Improve Security"|"Improve Compatibility"|"Improve Deployment"|"Improve Workspaces"|"System Status"|"Doctor"|"SevenPkg Meta"|"SevenPkg Status"|"SevenPkg Sources"|"Seven Update"|"Preview Full Install"|"Power Menu"|"Lock Session"|"Seven Files"|"Seven Files Places"|"Installer Stack"|"Installer Stack Doctor"|"Installer Stack Plan"|"Hub GUI Stack"|"Hub GUI Doctor"|"Flatpak Bridge"|"Flatpak Setup"|"Install Default Flatpaks"|"Build ISO Dry Run"|"Windows Mode Status"|"Windows Mode Start"|"Windows Mode Console"|"Server Status"|"Server Doctor"|"Deploy Status"|"Deploy Current Project") printf 'RUN' ;;
    "Profile Forge") package_file_state "$SEVENOS_ROOT/scripts/packages-dev.txt" ;;
    "Profile Shield") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity.txt" ;;
    "Profile Studio") package_file_state "$SEVENOS_ROOT/scripts/packages-creation.txt" ;;
    "Apply Branding") [[ -f /etc/sevenos-release ]] && printf 'OK' || printf 'MISS' ;;
    "Apply Theme") [[ -f "$HOME/.config/hypr/hyprland.conf" ]] && printf 'OK' || printf 'MISS' ;;
    "Install Base") package_file_state "$SEVENOS_ROOT/scripts/packages-base.txt" ;;
    "Install DEV") package_file_state "$SEVENOS_ROOT/scripts/packages-dev.txt" ;;
    "Install CYBERSECURITY") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity.txt" ;;
    "Install CYBER Core") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity.txt" ;;
    "Install CYBER Sandbox") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity-sandbox.txt" ;;
    "Cyber Audit") printf 'RUN' ;;
    "Cyber Lab Web"|"Cyber Lab Forensics"|"Cyber Lab Offline") app_state firejail ;;
    "BlackArch Setup") blackarch_state ;;
    "Install CREATION") package_file_state "$SEVENOS_ROOT/scripts/packages-creation.txt" ;;
    "Install WINDOWS") package_file_state "$SEVENOS_ROOT/scripts/packages-windows.txt" ;;
    "Install Server Layer") package_file_state "$SEVENOS_ROOT/scripts/packages-server.txt" ;;
    "Install User Service")
      if systemctl --user is-enabled --quiet seven-server.service 2>/dev/null; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    "Start Server")
      if systemctl --user is-active --quiet seven-server.service 2>/dev/null; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    "Stop Server") printf 'RUN' ;;
    "Apply SECURITY") package_file_state "$SEVENOS_ROOT/scripts/packages-security.txt" ;;
    "Install ALL") printf 'RUN' ;;
    "VM Check") service_state libvirtd.service ;;
    "VM Network")
      if command -v virsh >/dev/null 2>&1 && virsh -c qemu:///system net-info default 2>/dev/null | grep -q 'Active:.*yes'; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    "Installer Plan"|"Installer Plan Preview"|"Installer Script Preview") printf 'RUN' ;;
    "Install Installer Stack") package_file_state "$SEVENOS_ROOT/scripts/packages-installer.txt" ;;
    "ISO Tools") package_file_state "$SEVENOS_ROOT/scripts/packages-iso.txt" ;;
    "Open Virt Manager") app_state virt-manager ;;
    "Open Bottles")
      if command -v flatpak >/dev/null 2>&1 && flatpak info com.usebottles.bottles >/dev/null 2>&1; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    *) printf 'RUN' ;;
  esac
}

select_with_rofi() {
  local menu_title="$1"
  local message="$2"
  local menu=""
  local item label description badge

  for item in "${actions[@]}"; do
    IFS='|' read -r label _ description <<<"$item"
    badge="$(action_badge "$label")"
    menu+="$(display_row "$label" "$description" "$badge")"$'\n'
  done

  printf '%s' "$menu" | rofi -dmenu -i -p "$menu_title" -mesg "$message" -theme "$SEVENOS_ROOT/hyprland/rofi/hub.rasi"
}

select_with_terminal() {
  local menu_title="$1"
  local index=1
  local item label description choice badge

  printf '%s\n\n' "$menu_title" >&2
  for item in "${actions[@]}"; do
    IFS='|' read -r label _ description <<<"$item"
    badge="$(action_badge "$label")"
    printf '%2d. %-24s [%s] %s\n' "$index" "$(display_label "$label")" "$badge" "$description" >&2
    index=$((index + 1))
  done

  if [[ ! -t 0 || "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    return 0
  fi

  printf '\nChoose an action: ' >&2
  read -r choice

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#actions[@]} )); then
    IFS='|' read -r label _ _ <<<"${actions[$((choice - 1))]}"
    printf '%s\n' "$label"
  fi
}

select_category() {
  actions=("${categories[@]}")

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    select_with_terminal "$title" >&2
    return 0
  fi

  if command -v rofi >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    local selected
    selected="$(select_with_rofi "$title" "Choose a focused SevenOS workspace" || true)"
    selected="$(clean_selection "$selected")"
    printf '%s\n' "$selected"
  else
    select_with_terminal "$title"
  fi
}

select_action() {
  local category="$1"
  load_actions "$category"

  if [[ "${SEVENOS_DRY_RUN:-0}" == "1" ]]; then
    select_with_terminal "$category" >&2
    return 0
  fi

  if command -v rofi >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    local selected
    selected="$(select_with_rofi "$category" "Seven Hub · $category" || true)"
    selected="$(clean_selection "$selected")"
    printf '%s\n' "$selected"
  else
    select_with_terminal "$category"
  fi
}

main() {
  local category selected item label action
  local skip_native=0

  category="${1:-}"
  case "$category" in
    -h|--help|help)
      usage
      exit 0
      ;;
    doctor|--doctor|status|--status)
      doctor
      exit 0
      ;;
    native|open)
      open_native_hub || die "Native Hub unavailable. Install it with: seven hub-gui install"
      exit 0
      ;;
    menu|rofi)
      category=""
      skip_native=1
      ;;
  esac

  if [[ -z "$category" ]]; then
    if [[ "$skip_native" -eq 0 ]] && open_native_hub; then
      exit 0
    fi
    category="$(select_category)"
  fi

  [[ -n "$category" ]] || exit 0

  selected="$(select_action "$category")"

  [[ -n "$selected" ]] || exit 0

  for item in "${actions[@]}"; do
    IFS='|' read -r label action _ <<<"$item"
    if [[ "$label" == "$selected" ]]; then
      run_action "$action"
      exit 0
    fi
  done

  die "unknown action: $selected"
}

main "$@"
