#!/usr/bin/env bash
set -Eeuo pipefail

resolve_root() {
  if [[ -n "${SEVENOS_ROOT:-}" && -x "$SEVENOS_ROOT/install.sh" ]]; then
    printf '%s\n' "$SEVENOS_ROOT"
    return 0
  fi

  local script_dir
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

  for candidate in \
    "$script_dir/../.." \
    "$script_dir/.." \
    "/opt/SevenOS" \
    "$HOME/SevenOS" \
    "$HOME/Code/OS/SevenOS"; do
    if [[ -x "$candidate/install.sh" && -d "$candidate/seven-hub" ]]; then
      cd -- "$candidate" && pwd
      return 0
    fi
  done

  printf 'Seven Hub: could not find SevenOS repository root\n' >&2
  exit 1
}

SEVENOS_ROOT="$(resolve_root)"
INSTALLER="$SEVENOS_ROOT/install.sh"

title="Seven Hub"

categories=(
  "Dashboard|category:Dashboard|System overview and common actions"
  "Profiles|category:Profiles|Forge, Shield, Studio and SevenPkg status"
  "Cyber|category:Cyber|Cyber audit, labs and BlackArch bridge"
  "Desktop|category:Desktop|Theme, branding, power and session controls"
  "VM & Windows|category:VM & Windows|Windows compatibility and libvirt"
  "Server & Deploy|category:Server & Deploy|Local API, personal cloud and project deploy"
  "Ecosystem|category:Ecosystem|AI, cloud, store, containers and automation roadmap"
  "Installer|category:Installer|ISO and installation planning"
  "Apps|category:Apps|External desktop applications"
)

actions=()

die() {
  printf 'Seven Hub: %s\n' "$*" >&2
  if command -v notify-send >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    notify-send "Seven Hub" "$*" || true
  fi
  exit 1
}

usage() {
  cat <<'EOF'
Seven Hub

Usage:
  seven-hub [category]
  seven-hub doctor
  seven-hub --help

Categories:
  Dashboard
  Profiles
  Cyber
  Desktop
  VM & Windows
  Server & Deploy
  Ecosystem
  Installer
  Apps
EOF
}

doctor() {
  printf 'Seven Hub Doctor\n'
  printf '================\n'
  printf 'command:      %s\n' "$(command -v seven-hub 2>/dev/null || printf 'missing')"
  printf 'script:       %s\n' "${BASH_SOURCE[0]}"
  printf 'root:         %s\n' "$SEVENOS_ROOT"
  printf 'installer:    %s\n' "$INSTALLER"
  printf 'rofi:         %s\n' "$(command -v rofi 2>/dev/null || printf 'missing')"
  printf 'kitty:        %s\n' "$(command -v kitty 2>/dev/null || printf 'missing')"
  printf 'display:      %s\n' "${WAYLAND_DISPLAY:-${DISPLAY:-none}}"
  printf 'theme:        %s\n' "$SEVENOS_ROOT/hyprland/rofi/sevenos.rasi"

  [[ -x "$INSTALLER" ]] || die "installer not executable: $INSTALLER"
  [[ -f "$SEVENOS_ROOT/hyprland/rofi/sevenos.rasi" ]] || die "Rofi theme missing"

  if command -v rofi >/dev/null 2>&1; then
    rofi -no-config -theme "$SEVENOS_ROOT/hyprland/rofi/sevenos.rasi" -dump-theme >/dev/null
    printf 'rofi theme:   OK\n'
  fi
}

run_in_terminal() {
  local command="$1"
  local terminal="${TERMINAL:-}"

  if [[ -z "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    bash -lc "$command"
    return 0
  fi

  if [[ -z "$terminal" ]]; then
    if command -v kitty >/dev/null 2>&1; then
      terminal="kitty"
    elif command -v foot >/dev/null 2>&1; then
      terminal="foot"
    elif command -v alacritty >/dev/null 2>&1; then
      terminal="alacritty"
    elif command -v xterm >/dev/null 2>&1; then
      terminal="xterm"
    fi
  fi

  if [[ -n "$terminal" ]]; then
    case "$(basename "$terminal")" in
      kitty)
        "$terminal" --title "$title" bash -lc "$command; printf '\nPress Enter to close...'; read -r" &
        ;;
      foot|alacritty|xterm)
        "$terminal" -e bash -lc "$command; printf '\nPress Enter to close...'; read -r" &
        ;;
      *)
        "$terminal" -e bash -lc "$command; printf '\nPress Enter to close...'; read -r" &
        ;;
    esac
  else
    bash -lc "$command"
  fi
}

run_action() {
  local action="$1"

  case "$action" in
    app:*)
      local app_command="${action#app:}"
      run_in_terminal "$app_command"
      ;;
    sevenpkg:*)
      local sevenpkg_command="${action#sevenpkg:}"
      run_in_terminal "cd '$SEVENOS_ROOT' && ./bin/sevenpkg $sevenpkg_command"
      ;;
    seven:*)
      local seven_command="${action#seven:}"
      run_in_terminal "cd '$SEVENOS_ROOT' && ./bin/seven $seven_command"
      ;;
    dashboard:*)
      run_in_terminal "cd '$SEVENOS_ROOT' && ./scripts/dashboard.sh"
      ;;
    *)
      [[ -x "$INSTALLER" ]] || die "installer not executable: $INSTALLER"
      run_in_terminal "cd '$SEVENOS_ROOT' && ./install.sh $action"
      ;;
  esac
}

load_actions() {
  local category="$1"

  case "$category" in
    "Dashboard")
      actions=(
        "Welcome|seven:welcome|Show onboarding and next steps"
        "System Dashboard|dashboard:system|Open SevenOS overview"
        "Ecosystem Map|seven:ecosystem|Show all SevenOS ecosystem modules"
        "Readiness Score|seven:readiness|Score SevenOS against OS choice criteria"
        "Improve Plan|seven:improve|Plan improvements for all OS criteria"
        "Repair Plan|seven:repair|Show guided repair plan"
        "Improve Security|seven:improve security|Plan trust and hardening improvements"
        "Improve Compatibility|seven:improve compatibility|Plan Windows and app compatibility improvements"
        "Improve Deployment|seven:improve deployment|Plan server and deployment improvements"
        "Improve Workspaces|seven:improve target|Plan Forge, Shield and Studio completion"
        "System Status|status|Show installed profiles and services"
        "Doctor|doctor|Check host readiness"
        "Seven Update|seven:update|Update pacman and AUR packages"
        "Dry Run ALL|all --dry-run|Preview full installation"
      )
      ;;
    "Profiles")
      actions=(
        "SevenPkg Meta|sevenpkg:meta|List SevenOS meta-packages"
        "SevenPkg Status|sevenpkg:status|Show meta-package installation status"
        "SevenPkg Sources|sevenpkg:sources|Show package sources"
        "Profile Forge|seven:profile forge|Install development workspace"
        "Profile Shield|seven:profile shield|Install cybersecurity workspace"
        "Profile Studio|seven:profile studio|Install creative workspace"
        "Install Base|base|Install Hyprland desktop layer"
        "Install ALL|all|Install every SevenOS layer"
      )
      ;;
    "Cyber")
      actions=(
        "Install CYBERSECURITY|cybersecurity|Install security tooling profile"
        "Install CYBER Core|cybersecurity core|Install core security tools only"
        "Install CYBER Sandbox|cybersecurity sandbox|Install lab isolation helpers"
        "Cyber Audit|cyber-audit|Review security tools and isolation readiness"
        "Cyber Lab Web|cyber-lab --preset web|Open web testing lab"
        "Cyber Lab Forensics|cyber-lab --preset forensics|Open forensic lab"
        "Cyber Lab Offline|cyber-lab --preset offline|Open offline lab"
        "Apply SECURITY|security|Apply base firewall and hardening"
        "BlackArch Setup|blackarch-setup --dry-run|Preview optional BlackArch bridge"
      )
      ;;
    "Desktop")
      actions=(
        "Apply Branding|branding|Install SevenOS system identity"
        "Apply Theme|theme|Apply African first desktop identity"
        "Power Menu|app:seven-power|Open power controls"
        "Lock Session|app:seven-power lock|Lock the desktop"
      )
      ;;
    "VM & Windows")
      actions=(
        "Windows Mode Status|windows-mode status|Show Windows compatibility readiness"
        "Windows Mode Start|windows-mode start|Start SevenOS Windows VM"
        "Windows Mode Console|windows-mode console|Open SevenOS Windows VM console"
        "Install WINDOWS|windows|Install Wine, Lutris, QEMU, Bottles"
        "VM Check|vm-check|Check KVM and libvirt readiness"
        "VM Network|vm-network|Start libvirt default network"
        "Open Virt Manager|app:virt-manager|Launch VM manager"
        "Open Bottles|app:flatpak run com.usebottles.bottles|Launch Bottles"
      )
      ;;
    "Server & Deploy")
      actions=(
        "Server Status|seven:server status|Show SevenOS local API readiness"
        "Server Doctor|seven:server doctor|Check deployment dependencies"
        "Install Server Layer|server|Install server and deployment packages"
        "Install User Service|seven:server install-user-service|Install seven-server user service"
        "Start Server|seven:server start|Start local SevenOS API"
        "Stop Server|seven:server stop|Stop local SevenOS API"
        "Deploy Status|seven:deploy status|Show generated deployment plans"
        "Deploy Current Project|seven:deploy .|Generate a plan for this repository"
        "Improve Deployment|seven:improve deployment|Plan server and deploy improvements"
      )
      ;;
    "Ecosystem")
      actions=(
        "Ecosystem Map|seven:ecosystem|Show modules and maturity"
        "Ecosystem Roadmap|seven:ecosystem roadmap|Show Phase 4 and Phase 5 priorities"
        "Ecosystem Doctor|seven:ecosystem doctor|Validate ecosystem foundation"
        "Repair Plan|seven:repair|Show guided repair plan"
        "Phase Gate|seven:phase-gate|Run next-phase checks"
        "Readiness Score|seven:readiness|Score SevenOS criteria"
        "Improve Plan|seven:improve|Plan system improvements"
      )
      ;;
    "Installer")
      actions=(
        "ISO Tools|iso-tools|Install ISO build tooling"
        "Build ISO Dry Run|iso --dry-run|Preview ISO build"
        "Installer Plan|installer-plan|Create non-destructive install plan"
        "Installer Check|installer-check|Validate install plan"
        "Installer Script|installer-script|Generate install preview script"
      )
      ;;
    "Apps")
      actions=(
        "Open Virt Manager|app:virt-manager|Launch VM manager"
        "Open Bottles|app:flatpak run com.usebottles.bottles|Launch Bottles"
        "SevenPkg Meta|sevenpkg:meta|List SevenOS meta-packages"
        "SevenPkg Status|sevenpkg:status|Show meta-package installation status"
      )
      ;;
    *)
      die "unknown category: $category"
      ;;
  esac
}

package_file_state() {
  local package_file="$1"
  local installed=0
  local total=0
  local package

  [[ -f "$package_file" ]] || { printf 'MISS'; return 0; }

  while IFS= read -r package; do
    package="${package%%#*}"
    package="${package//[[:space:]]/}"
    [[ -z "$package" ]] && continue

    total=$((total + 1))
    if pacman -Q "$package" >/dev/null 2>&1; then
      installed=$((installed + 1))
    fi
  done < "$package_file"

  if [[ "$total" -eq 0 ]]; then
    printf 'MISS'
  elif [[ "$installed" -eq "$total" ]]; then
    printf 'OK'
  elif [[ "$installed" -gt 0 ]]; then
    printf 'PART'
  else
    printf 'MISS'
  fi
}

service_state() {
  local service="$1"
  if systemctl is-active --quiet "$service" 2>/dev/null; then
    printf 'OK'
  elif systemctl is-enabled --quiet "$service" 2>/dev/null; then
    printf 'PART'
  else
    printf 'MISS'
  fi
}

app_state() {
  local command_name="$1"
  if command -v "$command_name" >/dev/null 2>&1; then
    printf 'OK'
  else
    printf 'MISS'
  fi
}

blackarch_state() {
  if pacman-conf --repo-list 2>/dev/null | grep -qx 'blackarch'; then
    printf 'OK'
  elif grep -Eq '^\[blackarch\]' /etc/pacman.conf 2>/dev/null; then
    printf 'PART'
  else
    printf 'MISS'
  fi
}

action_badge() {
  local label="$1"

  case "$label" in
    "Dashboard"|"Profiles"|"Cyber"|"Desktop"|"VM & Windows"|"Server & Deploy"|"Ecosystem"|"Installer"|"Apps") printf 'OPEN' ;;
    "Welcome"|"System Dashboard"|"Ecosystem Map"|"Ecosystem Roadmap"|"Ecosystem Doctor"|"Phase Gate"|"Readiness Score"|"Improve Plan"|"Repair Plan"|"Improve Security"|"Improve Compatibility"|"Improve Deployment"|"Improve Workspaces"|"System Status"|"Doctor"|"SevenPkg Meta"|"SevenPkg Status"|"SevenPkg Sources"|"Seven Update"|"Dry Run ALL"|"Power Menu"|"Lock Session"|"Build ISO Dry Run"|"Windows Mode Status"|"Windows Mode Start"|"Windows Mode Console"|"Server Status"|"Server Doctor"|"Deploy Status"|"Deploy Current Project") printf 'RUN' ;;
    "Profile Forge") package_file_state "$SEVENOS_ROOT/scripts/packages-dev.txt" ;;
    "Profile Shield") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity.txt" ;;
    "Profile Studio") package_file_state "$SEVENOS_ROOT/scripts/packages-creation.txt" ;;
    "Apply Branding") [[ -f /etc/sevenos-release ]] && printf 'OK' || printf 'MISS' ;;
    "Apply Theme") [[ -f "$HOME/.config/hypr/hyprland.conf" ]] && printf 'OK' || printf 'MISS' ;;
    "Install Base") package_file_state "$SEVENOS_ROOT/scripts/packages-base.txt" ;;
    "Install DEV") package_file_state "$SEVENOS_ROOT/scripts/packages-dev.txt" ;;
    "Install CYBERSECURITY") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity.txt" ;;
    "Install CYBER Core") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity.txt" ;;
    "Install CYBER Sandbox") package_file_state "$SEVENOS_ROOT/scripts/packages-cybersecurity-sandbox.txt" ;;
    "Cyber Audit") printf 'RUN' ;;
    "Cyber Lab Web"|"Cyber Lab Forensics"|"Cyber Lab Offline") app_state firejail ;;
    "BlackArch Setup") blackarch_state ;;
    "Install CREATION") package_file_state "$SEVENOS_ROOT/scripts/packages-creation.txt" ;;
    "Install WINDOWS") package_file_state "$SEVENOS_ROOT/scripts/packages-windows.txt" ;;
    "Install Server Layer") package_file_state "$SEVENOS_ROOT/scripts/packages-server.txt" ;;
    "Install User Service")
      if systemctl --user is-enabled --quiet seven-server.service 2>/dev/null; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    "Start Server")
      if systemctl --user is-active --quiet seven-server.service 2>/dev/null; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    "Stop Server") printf 'RUN' ;;
    "Apply SECURITY") package_file_state "$SEVENOS_ROOT/scripts/packages-security.txt" ;;
    "Install ALL") printf 'RUN' ;;
    "VM Check") service_state libvirtd.service ;;
    "VM Network")
      if command -v virsh >/dev/null 2>&1 && virsh -c qemu:///system net-info default 2>/dev/null | grep -q 'Active:.*yes'; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    "Installer Plan"|"Installer Check"|"Installer Script") printf 'RUN' ;;
    "ISO Tools") package_file_state "$SEVENOS_ROOT/scripts/packages-iso.txt" ;;
    "Open Virt Manager") app_state virt-manager ;;
    "Open Bottles")
      if command -v flatpak >/dev/null 2>&1 && flatpak info com.usebottles.bottles >/dev/null 2>&1; then
        printf 'OK'
      else
        printf 'MISS'
      fi
      ;;
    *) printf 'RUN' ;;
  esac
}

select_with_rofi() {
  local menu_title="$1"
  local message="$2"
  local menu=""
  local item label description badge

  for item in "${actions[@]}"; do
    IFS='|' read -r label _ description <<<"$item"
    badge="$(action_badge "$label")"
    menu+="$label    [$badge] $description"$'\n'
  done

  printf '%s' "$menu" | rofi -dmenu -i -p "$menu_title" -mesg "$message" -theme "$SEVENOS_ROOT/hyprland/rofi/sevenos.rasi" -theme-str 'window { width: 44%; }'
}

select_with_terminal() {
  local menu_title="$1"
  local index=1
  local item label description choice badge

  printf '%s\n\n' "$menu_title" >&2
  for item in "${actions[@]}"; do
    IFS='|' read -r label _ description <<<"$item"
    badge="$(action_badge "$label")"
    printf '%2d. %-18s [%s] %s\n' "$index" "$label" "$badge" "$description" >&2
    index=$((index + 1))
  done

  printf '\nChoose an action: ' >&2
  read -r choice

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#actions[@]} )); then
    IFS='|' read -r label _ _ <<<"${actions[$((choice - 1))]}"
    printf '%s\n' "$label"
  fi
}

select_category() {
  actions=("${categories[@]}")

  if command -v rofi >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    local selected
    selected="$(select_with_rofi "$title" "Choose a focused SevenOS workspace" || true)"
    selected="${selected%%    *}"
    printf '%s\n' "$selected"
  else
    select_with_terminal "$title"
  fi
}

select_action() {
  local category="$1"
  load_actions "$category"

  if command -v rofi >/dev/null 2>&1 && [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]]; then
    local selected
    selected="$(select_with_rofi "$category" "Seven Hub · $category" || true)"
    selected="${selected%%    *}"
    printf '%s\n' "$selected"
  else
    select_with_terminal "$category"
  fi
}

main() {
  local category selected item label action

  category="${1:-}"
  case "$category" in
    -h|--help|help)
      usage
      exit 0
      ;;
    doctor|--doctor|status|--status)
      doctor
      exit 0
      ;;
  esac

  if [[ -z "$category" ]]; then
    category="$(select_category)"
  fi

  [[ -n "$category" ]] || exit 0

  selected="$(select_action "$category")"

  [[ -n "$selected" ]] || exit 0

  for item in "${actions[@]}"; do
    IFS='|' read -r label action _ <<<"$item"
    if [[ "$label" == "$selected" ]]; then
      run_action "$action"
      exit 0
    fi
  done

  die "unknown action: $selected"
}

main "$@"
