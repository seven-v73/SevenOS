#!/usr/bin/env python3
import html
import json
import os
import socket
import subprocess
import sys
import time
import webbrowser
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs


HOST = "127.0.0.1"
PORT = int(os.environ.get("SEVENOS_CONTROL_CENTER_PORT", "7787"))


def resolve_root() -> Path:
    env = os.environ.get("SEVENOS_ROOT")
    if env and Path(env, "install.sh").is_file():
        return Path(env).resolve()
    script = Path(__file__).resolve()
    for candidate in (
        script.parents[2],
        Path("/opt/SevenOS"),
        Path.home() / "SevenOS",
        Path.home() / "Code/OS/SevenOS",
    ):
        if Path(candidate, "install.sh").is_file():
            return Path(candidate).resolve()
    print("seven-control-center: could not find SevenOS root", file=sys.stderr)
    sys.exit(1)


ROOT = resolve_root()


def run_text(command, timeout=12):
    result = subprocess.run(command, cwd=ROOT, text=True, capture_output=True, timeout=timeout, check=False)
    return result.stdout.strip() if result.stdout.strip() else result.stderr.strip()


def command_state(command):
    return "OK" if subprocess.run(["bash", "-lc", f"command -v {command} >/dev/null"], check=False).returncode == 0 else "MISS"


def service_state(service, user=False):
    cmd = ["systemctl"]
    if user:
        cmd.append("--user")
    cmd += ["is-active", "--quiet", service]
    if subprocess.run(cmd, check=False).returncode == 0:
        return "RUN"
    return "MISS"


def readiness_summary():
    try:
        payload = json.loads(run_text([str(ROOT / "scripts/readiness.sh"), "--json"], timeout=18))
        return payload
    except Exception:
        return {"score": 0, "max": 1, "percent": 0, "categories": {}, "recommendations": []}


def json_command(command, fallback, timeout=18):
    try:
        output = run_text(command, timeout=timeout)
        return json.loads(output)
    except Exception:
        return fallback


def daily_summary():
    return json_command(
        [str(ROOT / "bin/seven"), "daily", "--json"],
        {
            "schema": "sevenos.daily-driver.v1",
            "decision": "unknown",
            "summary": {},
            "blockers": [],
            "warnings": [],
        },
    )


def shield_summary():
    return json_command(
        [str(ROOT / "bin/seven"), "shield", "status", "--json"],
        {"schema": "sevenos.shield.v1", "posture": "unknown", "percent": 0, "checks": []},
        timeout=12,
    )


def windows_summary():
    return json_command(
        [str(ROOT / "bin/seven"), "windows", "status", "--json"],
        {"schema": "sevenos.windows.v1", "mode": "unknown", "ready": False, "app_ready": False},
        timeout=12,
    )


def server_summary():
    return json_command(
        [str(ROOT / "bin/seven"), "server", "status", "--json"],
        {"schema": "sevenos.server.v1", "state": "unknown", "runtime_ready": False},
        timeout=12,
    )


def package_profile(path):
    total = installed = 0
    try:
        for line in Path(path).read_text(encoding="utf-8").splitlines():
            pkg = line.split("#", 1)[0].strip()
            if not pkg:
                continue
            total += 1
            if subprocess.run(["pacman", "-Q", pkg], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode == 0:
                installed += 1
    except FileNotFoundError:
        return "MISS", "0/0"
    if total == 0:
        return "MISS", "0/0"
    if installed == total:
        return "OK", f"{installed}/{total}"
    if installed:
        return "PART", f"{installed}/{total}"
    return "MISS", f"0/{total}"


ACTIONS = {
    "theme": ("Apply Theme", ["./install.sh", "theme"]),
    "repair-ux": ("Repair UX", ["./bin/seven", "repair", "ux", "--apply"]),
    "daily-status": ("Daily Driver Gate", ["./bin/seven", "daily"]),
    "daily-plan": ("Daily Driver Plan", ["./bin/seven", "daily", "plan"]),
    "daily-apply": ("Apply Daily Driver", ["./bin/seven", "daily", "apply", "--yes"]),
    "core-health": ("Core Health", ["./bin/seven", "core", "health"]),
    "core-start": ("Start Core Runtime", ["./bin/seven", "core", "start"]),
    "wallpaper-refresh": ("Refresh Wallpaper", ["./bin/seven-wallpaper", "refresh"]),
    "security-plan": ("Security Plan", ["./bin/seven", "improve", "security"]),
    "security-apply": ("Apply Security", ["./bin/seven", "improve", "security", "--apply", "--yes"]),
    "compatibility-plan": ("Compatibility Plan", ["./bin/seven", "improve", "compatibility"]),
    "target-plan": ("Target Plan", ["./bin/seven", "improve", "target"]),
    "deployment-plan": ("Deployment Plan", ["./bin/seven", "improve", "deployment"]),
    "server-status": ("Server Status", ["./bin/seven", "server", "status"]),
    "windows-status": ("Windows Status", ["./bin/seven", "windows", "status"]),
    "files": ("Seven Files", ["./bin/seven", "files"]),
    "files-menu": ("Seven Files Places", ["./bin/seven", "files", "menu"]),
    "phase-gate": ("Phase Gate", ["./bin/seven", "phase-gate"]),
}


def open_action(action_id):
    label, command = ACTIONS[action_id]
    if action_id in ("files", "files-menu"):
        subprocess.Popen(command, cwd=ROOT)
        return
    shell_command = "cd " + subprocess.list2cmdline([str(ROOT)]) + " && " + subprocess.list2cmdline(command) + "; printf '\\nPress Enter to close...'; read -r"
    if os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY"):
        for terminal in ("kitty", "foot", "alacritty", "xterm"):
            if command_state(terminal) == "OK":
                if terminal == "kitty":
                    subprocess.Popen([terminal, "--title", f"SevenOS - {label}", "bash", "-lc", shell_command])
                else:
                    subprocess.Popen([terminal, "-e", "bash", "-lc", shell_command])
                return
    subprocess.Popen(["bash", "-lc", shell_command], cwd=ROOT)


def card(title, status, detail, action=None):
    status_class = status.lower()
    button = f'<form method="post" action="/action"><input type="hidden" name="id" value="{html.escape(action)}"><button>Fix now</button></form>' if action else ""
    return f"""
    <section class="card">
      <div class="card-head"><h2>{html.escape(title)}</h2><span class="badge {status_class}">{html.escape(status)}</span></div>
      <p>{html.escape(detail)}</p>
      {button}
    </section>
    """


def render_dashboard():
    readiness = readiness_summary()
    daily = daily_summary()
    shield_state = shield_summary()
    windows_state = windows_summary()
    server_state = server_summary()
    forge = package_profile(ROOT / "scripts/packages-dev.txt")
    shield = package_profile(ROOT / "scripts/packages-cybersecurity.txt")
    studio = package_profile(ROOT / "scripts/packages-creation.txt")
    windows = package_profile(ROOT / "scripts/packages-windows.txt")
    horizon = package_profile(ROOT / "scripts/packages-server.txt")
    ufw = "OK" if command_state("ufw") == "OK" else "MISS"
    firewall = service_state("ufw.service")
    api = service_state("seven-server.service", user=True)
    files = command_state("nautilus")
    gvfs = command_state("gio")
    daily_decision = str(daily.get("decision", "unknown"))
    daily_summary_block = daily.get("summary", {}) if isinstance(daily.get("summary", {}), dict) else {}
    blocker_count = len(daily.get("blockers", []) or [])
    shield_percent = int(shield_state.get("percent", daily_summary_block.get("shield", 0)) or 0)
    windows_mode = str(windows_state.get("mode", "unknown"))
    server_runtime = "RUN" if server_state.get("runtime_ready") else str(server_state.get("state", api))

    cards = [
        card("Readiness", f"{readiness.get('percent', 0)}%", f"{readiness.get('score', 0)}/{readiness.get('max', 0)} OS criteria covered.", "phase-gate"),
        card("Daily Driver", "OK" if daily_decision == "ready" else "PART", f"Decision: {daily_decision}. Blockers: {blocker_count}.", "daily-plan"),
        card("Security", "OK" if shield_percent >= 70 else "PART", f"Shield: {shield_percent}%. UFW: {ufw}. Firewall: {firewall}.", "security-plan"),
        card("Seven Files", "OK" if files == "OK" and gvfs == "OK" else "PART", f"Nautilus: {files}. GVfs/GIO: {gvfs}.", "files"),
        card("Forge", forge[0], f"Development workspace packages: {forge[1]}.", "target-plan"),
        card("Shield", shield[0], f"Cybersecurity workspace packages: {shield[1]}.", "security-plan"),
        card("Studio", studio[0], f"Creative workspace packages: {studio[1]}.", "target-plan"),
        card("Windows Mode", "OK" if windows_state.get("app_ready") else windows[0], f"Mode: {windows_mode}. Packages: {windows[1]}.", "windows-status"),
        card("Server & Deploy", "OK" if server_runtime == "RUN" else horizon[0], f"Horizon packages: {horizon[1]}. Runtime: {server_runtime}.", "deployment-plan"),
        card("Theme & Session", "OK", "SevenOS Design System v1 across wallpaper, Waybar, Rofi, Kitty and Mako.", "theme"),
    ]

    actions = "".join(
        f'<form method="post" action="/action"><input type="hidden" name="id" value="{key}"><button>{html.escape(label)}</button></form>'
        for key, (label, _) in ACTIONS.items()
    )

    return f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>SevenOS Control Center</title>
  <style>
    :root {{
      --ebene:#efe3cf; --surface-0:#f6ead8; --surface-1:#fbf5ea; --surface-2:#ead9bd; --surface-3:#d8bd91;
      --glass:#fbf5eab8; --glass-2:#fbf5eae0; --glass-3:#f6ead8; --glass-border:#c7a86f; --glass-border-2:#c7a86f;
      --gold:#c8a96e; --gold-bright:#e2c07a; --gold-dim:#8a7048;
      --clay:#c4673a; --clay-dim:#8a4525; --clay-pale:rgba(196,103,58,.14);
      --baobab:#4a8c5c; --baobab-bright:#5aad72; --baobab-pale:rgba(74,140,92,.14);
      --indigo:#5b7fa6; --indigo-bright:#7ba3cf; --indigo-pale:rgba(91,127,166,.14);
      --text-1:#2a1f12; --text-2:#5c4d3a; --text-3:#827158;
      --font-display:"Cormorant Garamond", Georgia, serif; --font-interface:"DM Sans", system-ui, sans-serif; --font-mono:"JetBrains Mono", monospace;
    }}
    * {{ box-sizing: border-box; }}
    body {{
      margin: 0; min-height: 100vh; color: var(--text-1);
      font-family: var(--font-interface);
      background:
        linear-gradient(135deg, rgba(200,169,110,.08), transparent 30%),
