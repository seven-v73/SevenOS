    </header>
    <div class="grid">{''.join(cards)}</div>
    <div class="actions">{actions}</div>
  </main>
</body>
</html>"""


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path in ("/", "/index.html"):
            body = render_dashboard().encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif self.path == "/api/status":
            payload = json.dumps(readiness_summary()).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
        else:
            self.send_error(404)

    def do_POST(self):
        if self.path != "/action":
            self.send_error(404)
            return
        length = int(self.headers.get("Content-Length", "0"))
        data = parse_qs(self.rfile.read(length).decode())
        action_id = data.get("id", [""])[0]
        if action_id in ACTIONS:
            open_action(action_id)
        self.send_response(303)
        self.send_header("Location", "/")
        self.end_headers()

    def log_message(self, fmt, *args):
        print("seven-control-center:", fmt % args)


def port_open():
    with socket.socket() as sock:
        return sock.connect_ex((HOST, PORT)) == 0


def open_browser():
    url = f"http://{HOST}:{PORT}"
    if os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY"):
        if command_state("xdg-open") == "OK":
            result = subprocess.run(["xdg-open", url], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
            if result.returncode == 0:
                return True
        if webbrowser.open(url):
            return True
    print(url)
    return False


def open_fallback_menu():
    hub = ROOT / "seven-hub" / "bin" / "seven-hub"
    if hub.is_file() and (os.environ.get("WAYLAND_DISPLAY") or os.environ.get("DISPLAY")):
        subprocess.Popen([str(hub)])


def start_server_detached():
    subprocess.Popen(
        [sys.executable, str(Path(__file__).resolve()), "serve"],
        cwd=ROOT,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    for _ in range(20):
        if port_open():
            return True
        time.sleep(0.1)
    return False


def serve():
    print(f"SevenOS Control Center: http://{HOST}:{PORT}")
    ThreadingHTTPServer((HOST, PORT), Handler).serve_forever()


def main():
    action = sys.argv[1] if len(sys.argv) > 1 else "open"
    if os.environ.get("SEVENOS_DRY_RUN") == "1" and action == "open":
        print(f"xdg-open http://{HOST}:{PORT}")
        return
    if action == "status":
        print(f"http://{HOST}:{PORT} {'RUN' if port_open() else 'MISS'}")
    elif action == "serve":
        serve()
    elif action == "open":
        if port_open() or start_server_detached():
            if not open_browser():
                open_fallback_menu()
            return
        print("seven-control-center: could not start local dashboard", file=sys.stderr)
        open_fallback_menu()
        sys.exit(1)
    elif action in ("-h", "--help", "help"):
        print("Usage: seven-control-center [open|serve|status]")
    else:
        print(f"unknown action: {action}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
