    .sub {{ color: var(--text-2); margin: 8px 0 0; }}
    .score {{ color: #2a1f12; background: var(--gold); border: 1px solid var(--gold-dim); border-radius: 10px; padding: 10px 14px; font-weight: 500; }}
    .grid {{ display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }}
    .card {{
      min-height: 156px; padding: 16px; border-radius: 16px;
      background: var(--glass); border: 1px solid var(--glass-border);
      animation: card-in 350ms cubic-bezier(.4,0,.2,1) both;
    }}
    .card-head {{ display: flex; align-items: center; justify-content: space-between; gap: 10px; }}
    h2 {{ margin: 0; font-size: 15px; font-weight: 500; }}
