{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Seven Hub",
  "version": "0.1.0",
  "identifier": "os.seven.seven-hub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Seven Hub",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
