#!/usr/bin/env bash
set -Eeuo pipefail

export SEVENOS_ROOT="${SEVENOS_ROOT:-/opt/SevenOS}"
export SEVENOS_LIVE_SESSION=1
export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-Hyprland}"
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-SevenOS}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
export TERMINAL="${TERMINAL:-seven-terminal}"
export SEVENOS_TERMINAL="${SEVENOS_TERMINAL:-seven-terminal}"

if [[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.env" ]]; then
  # shellcheck disable=SC1091
  . "${XDG_CONFIG_HOME:-$HOME/.config}/sevenos/language.env"
fi

log_dir="${XDG_CACHE_HOME:-$HOME/.cache}/sevenos"
log_file="$log_dir/live-session.log"
mkdir -p "$log_dir"

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd \
    SEVENOS_ROOT SEVENOS_LIVE_SESSION XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE \
    LANG LANGUAGE LC_MESSAGES TERMINAL SEVENOS_TERMINAL >/dev/null 2>&1 || true
fi

printf '[sevenos-live-session] starting Hyprland\n' >>"$log_file"
if command -v Hyprland >/dev/null 2>&1; then
  if [[ -r /etc/sevenos/live-hyprland.conf ]]; then
    Hyprland -c /etc/sevenos/live-hyprland.conf >>"$log_file" 2>&1 && exit 0
  fi
  Hyprland >>"$log_file" 2>&1 && exit 0
  status=$?
  printf '[sevenos-live-session] Hyprland exited with status %s\n' "$status" >>"$log_file"
else
  printf '[sevenos-live-session] Hyprland command not found\n' >>"$log_file"
fi

printf '[sevenos-live-session] starting safe graphical installer fallback\n' >>"$log_file"
export XDG_CURRENT_DESKTOP=SevenOS
export XDG_SESSION_DESKTOP=SevenOS-Safe
if command -v cage >/dev/null 2>&1 && command -v seven-installer >/dev/null 2>&1; then
  exec cage -s -- seven-installer gui
fi

printf '\nSevenOS Live could not start the graphical session.\n' >&2
printf 'Open another TTY and inspect: journalctl -b -u sevenos-live-session.service\n' >&2
printf 'Live log: %s\n' "$log_file" >&2
sleep infinity
