#!/usr/bin/env bash
set -Eeuo pipefail

export SEVENOS_ROOT="${SEVENOS_ROOT:-/opt/SevenOS}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/sevenos"
started_marker="$state_dir/live-first-screen-started"
ready_marker="$state_dir/live-installer-opened"
log_file="${XDG_CACHE_HOME:-$HOME/.cache}/sevenos/live-ready.log"
status_file="$state_dir/live-status.json"
lock_dir="$state_dir/live-ready.lock"
session_started_at="$(date +%s)"
session_id="$(python - <<'PY' 2>/dev/null || printf 'live-session'
import uuid

print(uuid.uuid4().hex[:12])
PY
)"

mkdir -p "$state_dir" "$(dirname "$log_file")"

if [[ -e "$ready_marker" ]]; then
  exit 0
fi

if [[ -d "$lock_dir" ]]; then
  lock_age="$(python - "$lock_dir" <<'PY' 2>/dev/null || printf 0
import os
import sys
import time

try:
    print(int(time.time() - os.stat(sys.argv[1]).st_mtime))
except OSError:
    print(0)
PY
)"
  if [[ "$lock_age" =~ ^[0-9]+$ && "$lock_age" -gt 45 ]]; then
    rmdir "$lock_dir" 2>/dev/null || true
  fi
fi

if ! mkdir "$lock_dir" 2>/dev/null; then
  exit 0
fi
trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT

live_notify() {
  local title="$1"
  local body="${2:-}"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a "SevenOS Live" -i seven-installer "$title" "$body" >/dev/null 2>&1 || true
  fi
}

write_state() {
  local state="$1"
  local step="$2"
  local detail="${3:-}"
  local pid="${4:-}"
  local progress="${5:-0}"
  local hint="${6:-}"
  STATE="$state" STEP="$step" DETAIL="$detail" LOG_FILE="$log_file" PID="$pid" PROGRESS="$progress" HINT="$hint" SESSION_STARTED_AT="$session_started_at" SESSION_ID="$session_id" python - <<'PY' >"$status_file.tmp"
import json
import os
import time

now = int(time.time())
try:
    started_at = int(os.environ.get("SESSION_STARTED_AT", "") or now)
except ValueError:
    started_at = now

payload = {
    "schema": "sevenos.live-ready.v1",
    "session_id": os.environ.get("SESSION_ID", ""),
    "state": os.environ.get("STATE", "unknown"),
    "step": os.environ.get("STEP", ""),
    "detail": os.environ.get("DETAIL", ""),
    "hint": os.environ.get("HINT", ""),
    "progress": max(0, min(100, int(os.environ.get("PROGRESS", "0") or 0))),
    "log_file": os.environ.get("LOG_FILE", ""),
    "started_at": started_at,
    "updated_at": now,
    "elapsed_seconds": max(0, now - started_at),
}
pid = os.environ.get("PID", "")
if pid:
    payload["pid"] = int(pid) if pid.isdigit() else pid
print(json.dumps(payload, ensure_ascii=False, indent=2))
PY
  mv "$status_file.tmp" "$status_file"
}

live_lang() {
  case "${LANGUAGE:-${LC_MESSAGES:-${LANG:-}}}" in
    fr*|*:fr*) printf fr ;;
    *) printf en ;;
  esac
}

live_text() {
  local fr="$1"
  local en="$2"
  if [[ "$(live_lang)" == "fr" ]]; then
    printf '%s' "$fr"
  else
    printf '%s' "$en"
  fi
}

wait_for_hyprland() {
  local _i
  for _i in $(seq 1 30); do
    if [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v hyprctl >/dev/null 2>&1 && hyprctl monitors >/dev/null 2>&1; then
      return 0
    fi
    if (( _i % 5 == 0 )); then
      write_state "starting" "graphical-session" "Waiting for Hyprland and Wayland." "" "$((10 + (_i / 5) * 2))" "SevenOS is still preparing the graphical session."
    fi
    sleep 0.4
  done
  return 1
}

open_installer() {
  if command -v seven-installer >/dev/null 2>&1; then
    printf '[sevenos-live-ready] opening SevenOS installer portal\n' >&2
    seven-installer gui >/dev/null 2>&1 &
    printf '%s' "$!"
    return 0
  fi
  if command -v calamares >/dev/null 2>&1; then
    printf '[sevenos-live-ready] opening Calamares\n' >&2
    calamares -d >/dev/null 2>&1 &
    printf '%s' "$!"
    return 0
  fi
  return 1
}

process_alive() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1
}

confirm_installer_window() {
  local pid="$1"
  local _i
  for _i in $(seq 1 6); do
    if ! process_alive "$pid"; then
      write_state "closed" "installer" "Installer portal closed before it became interactive." "$pid" 100
      live_notify \
        "$(live_text "Installateur fermé" "Installer closed")" \
        "$(live_text "Le portail s’est fermé trop vite. Relance possible depuis l’icône Installation ou seven-installer live-retry." "The portal closed too quickly. Retry from the Installation icon or seven-installer live-retry.")"
      return 1
    fi
    write_state "opening" "installer" "Confirming the installer window is interactive." "$pid" "$((94 + _i))" "SevenOS is checking that the installer window stays open."
    sleep 0.35
  done
  touch "$ready_marker"
  write_state "ready" "installer" "Graphical installer portal is interactive." "$pid" 100
  return 0
}

{
  touch "$started_marker"
  write_state "starting" "graphical-session" "Waiting for Hyprland and Wayland." "" 10
  printf '[sevenos-live-ready] waiting for graphical session\n'
  live_notify \
    "$(live_text "Préparation de SevenOS" "Preparing SevenOS")" \
    "$(live_text "La session graphique se stabilise avant l’installation." "The graphical session is settling before installation.")"
  if wait_for_hyprland; then
    write_state "starting" "environment" "Graphical session is ready." "" 24
  else
    write_state "degraded" "environment" "Hyprland readiness timed out." "" 24
    printf '[sevenos-live-ready] warning: Hyprland readiness timed out\n'
  fi

  if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    write_state "starting" "dbus" "Importing SevenOS live environment." "" 36
    dbus-update-activation-environment --systemd \
      SEVENOS_ROOT SEVENOS_LIVE_SESSION WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP \
      LANG LANGUAGE LC_MESSAGES >/dev/null 2>&1 || true
  fi

  if command -v systemctl >/dev/null 2>&1; then
    write_state "starting" "services" "Starting SevenOS user services." "" 48
    systemctl --user import-environment \
      SEVENOS_ROOT SEVENOS_LIVE_SESSION WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP \
      LANG LANGUAGE LC_MESSAGES >/dev/null 2>&1 || true
    systemctl --user start sevenos-session.target >/dev/null 2>&1 || true
  fi

  if command -v xdg-user-dirs-update >/dev/null 2>&1; then
    write_state "starting" "user-folders" "Preparing user folders." "" 58
    xdg-user-dirs-update >/dev/null 2>&1 || true
  fi

  if command -v nmcli >/dev/null 2>&1; then
    write_state "starting" "network" "Enabling networking and Wi-Fi." "" 68
    live_notify \
      "$(live_text "Réseau SevenOS" "SevenOS Network")" \
      "$(live_text "Activation du Wi-Fi et des connexions disponibles." "Enabling Wi-Fi and available connections.")"
    nmcli networking on >/dev/null 2>&1 || true
    nmcli radio wifi on >/dev/null 2>&1 || true
  fi

  if [[ -x "$SEVENOS_ROOT/scripts/theme-session.sh" ]]; then
    write_state "starting" "theme" "Synchronizing SevenOS theme session." "" 78
    SEVENOS_ROOT="$SEVENOS_ROOT" "$SEVENOS_ROOT/scripts/theme-session.sh" sync >/dev/null 2>&1 || true
  fi

  if command -v seven-welcome >/dev/null 2>&1; then
    write_state "starting" "welcome" "Showing SevenOS welcome notification." "" 86
    seven-welcome --notify >/dev/null 2>&1 || true
  fi

  write_state "opening" "installer" "Opening graphical installer portal." "" 94
  live_notify \
    "$(live_text "Installation SevenOS" "SevenOS Installation")" \
    "$(live_text "Ouverture du portail d’installation graphique." "Opening the graphical installation portal.")"
  installer_pid=""
  if installer_pid="$(open_installer)"; then
    confirm_installer_window "$installer_pid" || exit 1
  else
    printf '[sevenos-live-ready] no graphical installer command found\n'
    write_state "error" "installer" "No graphical installer command found." "" 0
    live_notify \
      "$(live_text "Installateur indisponible" "Installer unavailable")" \
      "$(live_text "Ouvre SevenOS Terminal et lance seven installer release pour le diagnostic." "Open SevenOS Terminal and run seven installer release for diagnostics.")"
    rm -f "$started_marker"
    exit 1
  fi
} >>"$log_file" 2>&1
